Функция ДепозитарнаяИнструкцияСсылка(InstrumentType, Брокер, ПлатежныеУсловия, СвойствоInstrumentType, ДатаСделки, СубъектМестаХранения = Неопределено)

Запрос = Новый Запрос;
Запрос.Текст =
"ВЫБРАТЬ
|	РеквизитыДляРасчетовПоЦБ.Ссылка КАК РеквизитыДляРасчетовПоЦБСсылка
|ИЗ
|	Справочник.РеквизитыДляРасчетовПоЦБ.ДополнительныеРеквизиты КАК РеквизитыДляРасчетовПоЦБДополнительныеРеквизиты
|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.РеквизитыДляРасчетовПоЦБ КАК РеквизитыДляРасчетовПоЦБ
|		ПО РеквизитыДляРасчетовПоЦБДополнительныеРеквизиты.Ссылка = РеквизитыДляРасчетовПоЦБ.Ссылка
|ГДЕ
|	РеквизитыДляРасчетовПоЦБ.Владелец = &Контагент
|	И РеквизитыДляРасчетовПоЦБ.ТипСделки = &ТипСделки
|	И РеквизитыДляРасчетовПоЦБДополнительныеРеквизиты.Свойство = &Свойство
|	И РеквизитыДляРасчетовПоЦБДополнительныеРеквизиты.Значение = &Значение
|	И (НАЧАЛОПЕРИОДА(&ДатаСделки, ДЕНЬ) МЕЖДУ РеквизитыДляРасчетовПоЦБ.ДатаНачала И РеквизитыДляРасчетовПоЦБ.ДатаОкончания
|			ИЛИ РеквизитыДляРасчетовПоЦБ.ДатаНачала <= НАЧАЛОПЕРИОДА(&ДатаСделки, ДЕНЬ)
|				И ЕСТЬNULL(РеквизитыДляРасчетовПоЦБ.ДатаОкончания, ДАТАВРЕМЯ(1, 1, 1)) = ДАТАВРЕМЯ(1, 1, 1))
|	И РеквизитыДляРасчетовПоЦБ.ПометкаУдаления = ЛОЖЬ
|	И 1 = 1";

Запрос.УстановитьПараметр("Контагент", Брокер);
Запрос.УстановитьПараметр("ТипСделки", ПлатежныеУсловия);
Запрос.УстановитьПараметр("Значение", InstrumentType);
Запрос.УстановитьПараметр("Свойство", СвойствоInstrumentType);
Запрос.УстановитьПараметр("ДатаСделки", ДатаСделки);

// MPazhukov IMAPPS-8887 23.08.2019
Если СубъектМестаХранения <> Неопределено Тогда
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "1 = 1", "РеквизитыДляРасчетовПоЦБ.МестоРасчетов = &МестоРасчетов");
	Запрос.УстановитьПараметр("МестоРасчетов", СубъектМестаХранения);
КонецЕсли;
// MPazhukov IMAPPS-8887 23.08.2019

РезультаЗапроса = Запрос.Выполнить().Выгрузить();
Если РезультаЗапроса.Количество() <> 1 Тогда
	сообщить("Не удалось определить реквизиты для расчетов по ЦБ по параметрам: " + "Брокер " + Брокер + ", ПлатежныеУсловия " + ПлатежныеУсловия + ", InstrumentType " + InstrumentType + ", ДатаСделки " + ДатаСделки);
	Возврат Справочники.РеквизитыДляРасчетовПоЦБ.ПустаяСсылка();
Иначе
Возврат РезультаЗапроса[0].РеквизитыДляРасчетовПоЦБСсылка;
КонецЕсли;

