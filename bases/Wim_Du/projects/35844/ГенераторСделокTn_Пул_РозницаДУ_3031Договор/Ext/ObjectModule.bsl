СтрокаДокументов = Макет.ПолучитьОбласть("СтрокаТаблицы");

МассивУдаления = Новый Массив;

ВсегоЗагружено = 0;

Для Каждого ТекСтрока Из СписокЗагрузки Цикл

Если Найти(ТекСтрока.РежимТоргов.Наименование, "RP") > 0
	ИЛИ Найти(ТекСтрока.РежимТоргов.Наименование, "RD") > 0
	ИЛИ Найти(ТекСтрока.РежимТоргов.Наименование, "RE") > 0
	ИЛИ Найти(ТекСтрока.РежимТоргов.Наименование, "WP") > 0
	ИЛИ Найти(ТекСтрока.РежимТоргов.Наименование, "WD") > 0
	ИЛИ Найти(ТекСтрока.РежимТоргов.Наименование, "WE") > 0
	ИЛИ (Найти(ТекСтрока.РежимТоргов.Наименование, "EQ") > 0 И Найти(ТекСтрока.РежимТоргов.Наименование, "BND") > 0)
	ИЛИ ЭтоРЕПО_КСУ(ТекСтрока.РежимТоргов.Наименование) И ЗначениеЗаполнено(ТекСтрока.КодБрокера) Тогда
	
	ТекСделка = СделкаПоНомеру(ТекСтрока.НомерСделки, ТекСтрока.Продажа);
	Если НЕ ЗначениеЗаполнено(ТекСделка) Тогда
		МассивУдаления.Добавить(ТекСтрока);
		Продолжить;
	КонецЕсли;
	
	ТекСделкаОбъект = ТекСделка.ПолучитьОбъект();
	
	ТекСделкаОбъект.Партнер = ПолучитьКонтрагентаПоКодуБрокера(ТекСтрока.КодБрокера);
	Если НЕ ЗначениеЗаполнено(ТекСделкаОбъект.Партнер) Тогда
		ТекстОшибки = "На дату " + Формат(ТекСтрока.ДатаСделки, "ДФ=dd.MM.yyyy") + " для БП Сделка РЕПО не найден партнер по коду брокера: " + СокрЛП(ТекСтрока.КодБрокера);
		Отказ = Истина;
	КонецЕсли;
	
	Отказ = Ложь;
	Попытка
		ТекСделкаОбъект.ОбменДанными.Загрузка = Истина;
		ТекСделкаОбъект.Записать();
	Исключение
		Отказ = Истина;
		ТекстОшибки = ПолучитьТекстОшибки("Ошибки проведения:");
	КонецПопытки;
	
	СтрокаДокументов.Параметры.Заполнить(ТекСтрока);
	СтрокаДокументов.Параметры.Сделка = ?(Отказ, "", ТекСделкаОбъект.Ссылка);
	СтрокаДокументов.Параметры.ОшибкаСделки = ?(Отказ, ТекстОшибки, "");
	СтрокаДокументов.Параметры.ЕстьОшибки = ?(Отказ, "ДА", "");
	
	Если ТекСтрока.ДоговорДУ.Пустая() Тогда
		СтрокаДокументов.Параметры.ДоговорДУ = "<???>";
	КонецЕсли;
	Лог.Вывести(СтрокаДокументов);
	
	Если НЕ Отказ Тогда
		МассивУдаления.Добавить(ТекСтрока);
		ВсегоЗагружено = ВсегоЗагружено + 1;
	КонецЕсли;
	
КонецЕсли;
КонецЦикла;

Для Каждого ТекСтрока Из МассивУдаления Цикл
СписокЗагрузки.Удалить(ТекСтрока);
