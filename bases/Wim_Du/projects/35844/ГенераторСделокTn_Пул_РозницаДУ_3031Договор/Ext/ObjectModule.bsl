Функция РежимТорговПоID(Знач BoardId)
	Перем Запрос, Результат, Выборка;
	Перем НовыйРежим;
	
	Запрос = Новый Запрос();
	Запрос.УстановитьПараметр("BoardId", BoardId);
	Запрос.Текст =
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	РежимыТоргов.Ссылка КАК Ссылка,
		|	РежимыТоргов.BoardId КАК BoardId
		|ИЗ
		|	Справочник.РежимыТоргов КАК РежимыТоргов
		|ГДЕ
		|	РежимыТоргов.BoardId = &BoardId
		|
		|УПОРЯДОЧИТЬ ПО
		|	Ссылка УБЫВ";
	
	Результат = Запрос.Выполнить();
	
	Если Результат.Пустой() Тогда
		НовыйРежим = Справочники.РежимыТоргов.СоздатьЭлемент();
		НовыйРежим.BoardId = BoardId;
		НовыйРежим.Наименование = BoardId;
		НовыйРежим.Записать();
		
		Возврат НовыйРежим.Ссылка;
	КонецЕсли;
	
	Выборка = Результат.Выбрать();
	Выборка.Следующий();
	
	Возврат Выборка.Ссылка;
КонецФункции // РежимТорговПоID()

Функция ТорговыйКодПоКоду(КодКлиента, КодБрокера, КодБиржи, ВалютаДС = Неопределено)
	
	//	IMAPPS-1246
	
	//	IMAPPS-1246
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	ТорговыеКоды.АналитическийСчетЦБ КАК АналитическийСчетЦБ,
