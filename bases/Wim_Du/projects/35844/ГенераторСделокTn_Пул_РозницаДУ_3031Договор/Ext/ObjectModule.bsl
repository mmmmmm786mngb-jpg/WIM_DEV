Функция ПолучитьИзКэшаДопСведенияАктива(ОбъектАктива)

СтруктураДопСведенияАктивов = Новый Структура("НеСчитатьКомиссиюБиржиПоСделкам, НеСчитатьКомиссиюБрокераПоСделкам", Ложь, Ложь);

Если НЕ ЗначениеЗаполнено(ОбъектАктива) Тогда
Возврат СтруктураДопСведенияАктивов;
КонецЕсли;

Если НЕ мСтруктураКэшДанных.Свойство("ДопСведенияАктивов") Тогда
мСтруктураКэшДанных.Вставить("ДопСведенияАктивов", Новый Соответствие);
КонецЕсли;

Если мСтруктураКэшДанных.ДопСведенияАктивов.Получить(ОбъектАктива) = Неопределено Тогда

ДопСведениеНеСчитатьКомБиржи = ПланыВидовХарактеристик.ДополнительныеРеквизитыИСведения.НайтиПоНаименованию("Не считать комиссию биржи по сделкам", Истина);
ДопСведениеНеСчитатьКомБрокера = ПланыВидовХарактеристик.ДополнительныеРеквизитыИСведения.НайтиПоНаименованию("Не считать комиссию брокера по сделкам", Истина);

МассивСвойств = Новый Массив;
Если НЕ ДопСведениеНеСчитатьКомБиржи.Пустая() Тогда
	МассивСвойств.Добавить(ДопСведениеНеСчитатьКомБиржи);
КонецЕсли;
Если НЕ ДопСведениеНеСчитатьКомБрокера.Пустая() Тогда
МассивСвойств.Добавить(ДопСведениеНеСчитатьКомБрокера);
КонецЕсли;

Если МассивСвойств.Количество() <> 0 Тогда
ТаблицаСвойств = УправлениеСвойствами.ПолучитьЗначенияСвойств(ОбъектАктива, Ложь, Истина, МассивСвойств);
Если НЕ ДопСведениеНеСчитатьКомБиржи.Пустая() Тогда
	НайденнаяСтрока = ТаблицаСвойств.Найти(ДопСведениеНеСчитатьКомБиржи, "Свойство");
	Если НайденнаяСтрока <> Неопределено Тогда
		СтруктураДопСведенияАктивов.НеСчитатьКомиссиюБиржиПоСделкам = НайденнаяСтрока.Значение;
	КонецЕсли;
КонецЕсли;
Если НЕ ДопСведениеНеСчитатьКомБрокера.Пустая() Тогда
НайденнаяСтрока = ТаблицаСвойств.Найти(ДопСведениеНеСчитатьКомБрокера, "Свойство");
Если НайденнаяСтрока <> Неопределено Тогда
	СтруктураДопСведенияАктивов.НеСчитатьКомиссиюБрокераПоСделкам = НайденнаяСтрока.Значение;
КонецЕсли;
КонецЕсли;
КонецЕсли;

мСтруктураКэшДанных.ДопСведенияАктивов.Вставить(ОбъектАктива, СтруктураДопСведенияАктивов);

КонецЕсли;

Возврат мСтруктураКэшДанных.ДопСведенияАктивов.Получить(ОбъектАктива);

КонецФункции

