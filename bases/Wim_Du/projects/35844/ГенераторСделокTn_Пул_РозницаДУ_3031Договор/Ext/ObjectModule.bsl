Процедура ПрочитатьСделкиРЕПО(Отказ, ТекстОшибки = "") Экспорт

Лог = Новый ТабличныйДокумент;
Лог.ОтображатьГруппировки = Ложь;
Лог.ОтображатьСетку = Ложь;
Лог.ОтображатьЗаголовки = Ложь;

Заголовок = Макет.ПолучитьОбласть("Заголовок");
Лог.Вывести(Заголовок);

Шапка = Макет.ПолучитьОбласть("Шапка");
Шапка.Параметры.ДатаНачала = ДатаНачала;
Шапка.Параметры.ДатаОкончания = ДатаОкончания;
Шапка.Параметры.ДатаФормирования = ТекущаяДата();
Шапка.Параметры.Настройки = ПредставлениеНастроек;
