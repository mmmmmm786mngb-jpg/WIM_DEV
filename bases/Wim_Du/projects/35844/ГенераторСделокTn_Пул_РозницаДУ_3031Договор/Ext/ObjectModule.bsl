				ИндексыПаев.Добавить(Индекс);
			КонецЕсли;
		КонецЦикла;
		
		// Вычисляем количество продаж каждого типа с сохранением пропорций покупок
		//КоличествоПродаж = 70;
		КоличествоПродаж = 23;   // !!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!  23  ПРОДАЖ !!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
		КоличествоАкций = ИндексыАкций.Количество();
		КоличествоОблигаций = ИндексыОблигаций.Количество();
		КоличествоПаев = ИндексыПаев.Количество();
		
		КоличествоПродажАкций = Окр(КоличествоПродаж * КоличествоАкций / КоличествоАктивовВПуле, 0);
		КоличествоПродажОблигаций = Окр(КоличествоПродаж * КоличествоОблигаций / КоличествоАктивовВПуле, 0);
		КоличествоПродажПаев = КоличествоПродаж - КоличествоПродажАкций - КоличествоПродажОблигаций;
		
