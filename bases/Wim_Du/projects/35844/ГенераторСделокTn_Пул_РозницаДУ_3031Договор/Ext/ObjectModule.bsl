		|	ОБЪЕДИНИТЬ
		|	
		|	ВЫБРАТЬ
		|		АкцииБиржаЛистинга.Ссылка,
		|		2 * ВЫБОР
		|			КОГДА АкцииБиржаЛистинга.Ссылка.ПометкаУдаления
		|				ТОГДА 100
		|			ИНАЧЕ 1
		|		КОНЕЦ
		|	ИЗ
		|		Справочник.Акции.БиржиЛистинга КАК АкцииБиржаЛистинга
		|	ГДЕ
		|		АкцииБиржаЛистинга.КодЦБ В(&КодЦБ)
		|		И АкцииБиржаЛистинга.КодЦБ > """"
		|		И АкцииБиржаЛистинга.БиржаЛистинга = &БиржаЛистинга
		|		И НЕ АкцииБиржаЛистинга.Ссылка.ПометкаУдаления
		|	
		|	ОБЪЕДИНИТЬ
		|	
		|	ВЫБРАТЬ
		|		АкцииБиржаЛистинга.Ссылка,
		|		3 * ВЫБОР
		|			КОГДА АкцииБиржаЛистинга.Ссылка.ПометкаУдаления
		|				ТОГДА 100
		|			ИНАЧЕ 1
		|		КОНЕЦ
		|	ИЗ
		|		Справочник.Акции.БиржиЛистинга КАК АкцииБиржаЛистинга
		|	ГДЕ
		|		АкцииБиржаЛистинга.КодЦБ В(&КодЦБ)
		|		И АкцииБиржаЛистинга.КодЦБ > """"
		|		И НЕ АкцииБиржаЛистинга.Ссылка.ПометкаУдаления
		|	
		|	ОБЪЕДИНИТЬ
		|	
		|	ВЫБРАТЬ
		|		Облигации.Ссылка,
		|		4 * ВЫБОР
		|			КОГДА Облигации.ПометкаУдаления
		|				ТОГДА 100
		|			ИНАЧЕ 1
		|		КОНЕЦ
		|	ИЗ
		|		Справочник.Облигации КАК Облигации
		|	ГДЕ
		|		Облигации.ISIN В(&КодЦБ)
		|		И Облигации.ISIN > """"
		|		И НЕ Облигации.ПометкаУдаления
		|	
		|	ОБЪЕДИНИТЬ
		|	
		|	ВЫБРАТЬ
		|		ОблигацииБиржаЛистинга.Ссылка,
		|		5 * ВЫБОР
		|			КОГДА ОблигацииБиржаЛистинга.Ссылка.ПометкаУдаления
		|				ТОГДА 100
		|			ИНАЧЕ 1
		|		КОНЕЦ
		|	ИЗ
		|		Справочник.Облигации.БиржиЛистинга КАК ОблигацииБиржаЛистинга
		|	ГДЕ
		|		ОблигацииБиржаЛистинга.КодЦБ В(&КодЦБ)
		|		И ОблигацииБиржаЛистинга.КодЦБ > """"
		|		И ОблигацииБиржаЛистинга.БиржаЛистинга = &БиржаЛистинга
		|		И НЕ ОблигацииБиржаЛистинга.Ссылка.ПометкаУдаления
		|	
		|	ОБЪЕДИНИТЬ
		|	
		|	ВЫБРАТЬ
		|		ОблигацииБиржаЛистинга.Ссылка,
		|		6 * ВЫБОР
		|			КОГДА ОблигацииБиржаЛистинга.Ссылка.ПометкаУдаления
