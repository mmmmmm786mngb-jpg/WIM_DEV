Функция СведенияОВнешнейОбработке() Экспорт
	Перем ПараметрыРегистрации, ТаблицаКоманд;
	
	ПараметрыРегистрации = Новый Структура();
	ПараметрыРегистрации.Вставить("Вид", "ДополнительнаяОбработка");
	ПараметрыРегистрации.Вставить("Назначение", Неопределено);
	ПараметрыРегистрации.Вставить("Наименование", "Загрузка сделок");
	ПараметрыРегистрации.Вставить("Версия", "4.38");
	ПараметрыРегистрации.Вставить("БезопасныйРежим", Ложь);
	ПараметрыРегистрации.Вставить("Информация", "Загрузка сделок через web-service ВТБ");
	ПараметрыРегистрации.Вставить("ВерсияБСП", "2.1.1.12");
	
	ТаблицаКоманд = ПолучитьТаблицуКоманд();
	
	ДобавитьКоманду(
		ТаблицаКоманд,
		"Загрузить сделки через web-service",
		"ЗаполнитьWEB_VTB",
		"ОткрытиеФормы"
	);
	
	ДобавитьКоманду(
		ТаблицаКоманд,
		"Загрузить сделки через web-service (фон.)",
		"ФоновоеВыполнение",
		"ВызовСерверногоМетода"
	);
	
	// IMAPPS-15985 ++
	ДобавитьКоманду(
		ТаблицаКоманд,
		"Загрузить сделки через web-service за T-1 (фон.)",
		"ФоновоеВыполнениеT1",
		"ВызовСерверногоМетода"
	);
	// IMAPPS-15985 --
	
	ДобавитьКоманду(
		ТаблицаКоманд,
		"Загрузить сделки розничного ДУ через web-service (фон.)",
		"ФоновоеВыполнениеРозничноеДУ",
		"ВызовСерверногоМетода"
	);
	
	ПараметрыРегистрации.Вставить("Команды", ТаблицаКоманд);
	
	Возврат ПараметрыРегистрации;
КонецФункции // СведенияОВнешнейОбработке()

Функция ПолучитьТаблицуКоманд()
	Перем Команды;
	
	Команды = Новый ТаблицаЗначений();
	Команды.Колонки.Добавить("Представление", Новый ОписаниеТипов("Строка"));
	Команды.Колонки.Добавить("Идентификатор", Новый ОписаниеТипов("Строка"));
	Команды.Колонки.Добавить("Использование", Новый ОписаниеТипов("Строка"));
	Команды.Колонки.Добавить("ПоказыватьОповещение", Новый ОписаниеТипов("Булево"));
	Команды.Колонки.Добавить("Модификатор", Новый ОписаниеТипов("Строка"));
	
	Возврат Команды;
КонецФункции // ПолучитьТаблицуКоманд()

Процедура ДобавитьКоманду(ТаблицаКоманд, Знач Представление, Знач Идентификатор, Знач Использование, Знач ПоказыватьОповещение = Ложь, Знач Модификатор = "")
	Перем НоваяКоманда;
	
	НоваяКоманда = ТаблицаКоманд.Добавить();
	НоваяКоманда.Представление = Представление;
	НоваяКоманда.Идентификатор = Идентификатор;
	НоваяКоманда.Использование = Использование;
	НоваяКоманда.ПоказыватьОповещение = ПоказыватьОповещение;
	НоваяКоманда.Модификатор = Модификатор;
КонецПроцедуры // ДобавитьКоманду()

Процедура ВыполнитьКоманду(ИдентификаторКоманды, ПараметрыВыполненияКоманды) Экспорт
	Перем Наименование;
	
	// Реализация логики команды
	// IMAPPS-15985 ++
	//Если ИдентификаторКоманды <> "ФоновоеВыполнение" Тогда Возврат; КонецЕсли;
	Если ИдентификаторКоманды <> "ФоновоеВыполнение"
		И ИдентификаторКоманды <> "ФоновоеВыполнениеT1"
		И ИдентификаторКоманды <> "ФоновоеВыполнениеРозничноеДУ" Тогда
		Возврат;
	КонецЕсли;
	// IMAPPS-15985 --
	
	//IMAPPS-559
	DV_НеГрузитьВнебиржу = Истина;
	
	ПредставлениеНастроек = УстановитьНастройки(ПараметрыВыполненияКоманды);
	
	ДопОбработка = ПараметрыВыполненияКоманды.ДополнительнаяОбработкаСсылка;
	
	// IMAPPS-15985 ++
	Если ИдентификаторКоманды = "ФоновоеВыполнениеT1" Тогда
		ПредыдущийДень = Истина;
		ДатаНачала = НачалоДня(КалендарныеГрафики.ПолучитьСледующуюРабочуюДату( , ТекущаяДата(), -1));
		ДатаОкончания = КонецДня(КалендарныеГрафики.ПолучитьСледующуюРабочуюДату( , ТекущаяДата(), -1));
		ПредставлениеНастроек = "Период с:" + Формат(ДатаНачала, "ДФ=dd.MM.yyyy") + " по:" + Формат(ДатаОкончания, "ДФ=dd.MM.yyyy") + " ";
	КонецЕсли;
	// IMAPPS-15985 --
	
	ОтборПоПулу = ?(ИдентификаторКоманды = "ФоновоеВыполнениеРозничноеДУ", 1, 2);
	
	Задача = Задачи.ЗадачаИнтеграции.СоздатьЗадачу();
	Задача.Дата = ТекущаяДата();
	
	Наименование = "Загрузка сделок в фоновом режиме";
	
	Задача.ВидОбмена = ДопОбработка;
	Задача.ВерсияОбработки = ОбщегоНазначения.ПолучитьЗначениеРеквизита(ДопОбработка, "Версия");
	Задача.Наименование = Наименование;
	Задача.ПараметрыВыполнения = ПредставлениеНастроек;
	
	Отказ = Ложь;
	ТекстОшибки = "";
	ЗагрузитьОбъекты(Отказ, ТекстОшибки);
	СоздатьОбъекты(Отказ, ТекстОшибки);
	
	Задача.ХранилищеЛога = Новый ХранилищеЗначения(Лог, Новый СжатиеДанных(9));
	
	Задача.Описание = "Настройки: " + ПредставлениеНастроек;
	
	Если Отказ Тогда
		Задача.Описание = Задача.Описание + Символы.ПС + "При выполнении были ошибки:";
		Задача.ЗавершеноСОшибками = Истина;
	Иначе
		Задача.Описание = Задача.Описание + Символы.ПС + "Загрузка успешна";
		Задача.ЗавершеноСОшибками = Ложь;
	КонецЕсли;
	
	ТекстОписания = "Всего сделок:" + ВсегоПрочтено + " из них новых:" + ВсегоНовых + Символы.ПС + "Сделок с ошибками:" + (ВсегоНовых - ВсегоЗагружено) + " Итого загружено:" + ВсегоЗагружено;
	Задача.Описание = Задача.Описание + Символы.ПС + ТекстОписания;
	
	Если ПредыдущийДень Тогда
		Задача.ДатаИсполнения = ТекущаяДата() - 1;
	Иначе
		Задача.ДатаИсполнения = ТекущаяДата();
	КонецЕсли;
	
	Если СписокРассылки.Количество() > 0 И НЕ ПочтовыйЛогин.Пустая() Тогда
		ПараметрыПисьма = Новый Структура("Кому, Тема, Тело, Вложения, Важность");
		ПараметрыПисьма.Тема = ?(Задача.ЗавершеноСОшибками, "{FAIL} ", "{OK} ") + "Аванкор ДУ: " + Наименование + " за " + ПредставлениеНастроек + ПропискаРассылки("r4");
		ПараметрыПисьма.Важность = ?(Задача.ЗавершеноСОшибками, ВажностьИнтернетПочтовогоСообщения.Высокая, ВажностьИнтернетПочтовогоСообщения.Обычная);
		
		Кому = Новый Массив;
		Для Каждого ТекЯщик Из СписокРассылки Цикл
			Кому.Добавить(Новый Структура("Адрес,Представление", ТекЯщик.ПочтовыйЯщик, ТекЯщик.Представление));
		КонецЦикла;
		
		ПараметрыПисьма.Кому = кому;
		
		ПутьКФайлу = ПолучитьИмяВременногоФайла("XLS");
		Лог.Записать(ПутьКФайлу, ТипФайлаТабличногоДокумента.XLS);
		
		//Упаковка в zip
		ПутьКZip = ПолучитьИмяВременногоФайла("zip");
		Упаковка = Новый ЗаписьZipФайла(ПутьКZip);
		Упаковка.Добавить(ПутьКФайлу);
		Упаковка.Записать();
		//
		ДвоичныеДанные = Новый ДвоичныеДанные(ПутьКZip);
		АдресВложения = ПоместитьВоВременноеХранилище(ДвоичныеДанные);
		
		Вложения = Новый Соответствие;
		Вложения.Вставить("Лог.zip", АдресВложения);
		
		ПараметрыПисьма.Вложения = Вложения;
		
		ПараметрыПисьма.Тело = Задача.Описание;
		Попытка
			РаботаСПочтовымиСообщениями.ОтправитьСообщение(ПочтовыйЛогин, ПараметрыПисьма);
			текстРассылки = "Рассылка завершена";
		Исключение
			текстРассылки = "Рассылка не удалась: ";
			Сообщения = ПолучитьСообщенияПользователю(Истина);
			Для Каждого Элемент Из Сообщения Цикл
				текстРассылки = текстРассылки + Символы.ПС + Элемент.Текст;
			КонецЦикла;
		КонецПопытки;
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ТекстОшибкиНеНайденКонтрагент) Тогда
		
		Если СписокРассылкиНеНайденКонтрагент.Количество() > 0 И НЕ ПочтовыйЛогин.Пустая() Тогда
			
			ПараметрыПисьма = Новый Структура("Кому, Тема, Тело, Вложения, Важность");
			ПараметрыПисьма.Тема = "{FAIL} " + "Аванкор ДУ: " + Наименование + " за " + ПредставлениеНастроек + " - не найден партнер" + ПропискаРассылки("r4.1");
			ПараметрыПисьма.Важность = ВажностьИнтернетПочтовогоСообщения.Высокая;
			
			Кому = Новый Массив;
			Для Каждого ТекЯщик Из СписокРассылкиНеНайденКонтрагент Цикл
				Кому.Добавить(Новый Структура("Адрес,Представление", ТекЯщик.ПочтовыйЯщик, ТекЯщик.Представление));
			КонецЦикла;
			
			ПараметрыПисьма.Кому = Кому;
			
			Вложения = Новый Соответствие;
			ПараметрыПисьма.Вложения = Вложения;
			
			ПараметрыПисьма.Тело = ТекстОшибкиНеНайденКонтрагент;
			
			Попытка
				РаботаСПочтовымиСообщениями.ОтправитьСообщение(ПочтовыйЛогин, ПараметрыПисьма);
				текстРассылки = "Рассылка завершена";
			Исключение
				текстРассылки = "Рассылка не удалась: ";
				Сообщения = ПолучитьСообщенияПользователю(Истина);
				Для Каждого Элемент Из Сообщения Цикл
					текстРассылки = текстРассылки + Символы.ПС + Элемент.Текст;
				КонецЦикла;
			КонецПопытки;
			
		КонецЕсли;
	КонецЕсли;
	
	Задача.Описание = Задача.Описание + Символы.ПС + текстРассылки;
	Задача.ВыполнитьЗадачу();
	
КонецПроцедуры

Функция УстановитьНастройки(ПараметрыВыполненияКоманды)
	
	
	// ПараметрыВыполненияКоманды = Новый Структура();
	//ПараметрыВыполненияКоманды.Вставить("ДополнительнаяОбработкаСсылка", ВнешняяОбработкаСсылка);
	//ПараметрыВыполненияКоманды.Вставить("ПараметрыДополнительнойОбработки",Справочники.ДополнительныеОтчетыИОбработки.НастройкиОбработки(ВнешняяОбработкаСсылка));
	
	НастройкиВыполнения = ПараметрыВыполненияКоманды.ПараметрыДополнительнойОбработки;
	Если ТипЗнч(НастройкиВыполнения) <> Тип("Структура") Тогда Возврат "<Настройки не установлены>"; КонецЕсли;
	
	ЗначенияНастроек = НастройкиВыполнения;
	
	ПредставлениеНастроек = "";
	
	Если ЗначенияНастроек.Значения.ПредыдущийДень Тогда
		ДатаНачала = НачалоДня(КалендарныеГрафики.ПолучитьСледующуюРабочуюДату( , ТекущаяДата(), -1));
		ДатаОкончания = КонецДня(КалендарныеГрафики.ПолучитьСледующуюРабочуюДату( , ТекущаяДата(), -1));
	Иначе
		ДатаНачала = НачалоДня(ТекущаяДата()); //НачалоДня(КалендарныеГрафики.ПолучитьСледующуюРабочуюДату(,ТекущаяДата(),-1));
		ДатаОкончания = КонецДня(ТекущаяДата());
	КонецЕсли;
	
	
	УстановитьПользовательскиеНастройки(ЗначенияНастроек, ПредставлениеНастроек);
	
	Возврат ПредставлениеНастроек;
	
КонецФункции

Процедура УстановитьНастройкиИзДопОбработки(ДопОбработкаСсылка) Экспорт
	Настройки = ДопОбработкаСсылка.ХранилищеНастроек.Получить();
	УстановитьПользовательскиеНастройки(Настройки);
КонецПроцедуры

Процедура УстановитьПользовательскиеНастройки(Настройки, ПредставлениеНастроек = "") Экспорт
	
	Если Настройки.Свойство("Значения") Тогда
		ОбработкаЗагрузкиАктивов = Настройки.Значения.ОбработкаЗагрузкиАктивов;
		КомандаЗагрузкиАктивов = Настройки.Значения.КомандаЗагрузкиАктивов;
		ТестовыйРежим = Настройки.Значения.ТестовыйРежим;
		ПредыдущийДень = Настройки.Значения.ПредыдущийДень;
		Настройки.Значения.Свойство("Пул", Пул);
		
		БУ = Настройки.Значения.БУ;
		ВУ = Настройки.Значения.ВУ;
		УУ = Настройки.Значения.УУ;
		
		КомиссияБиржи = Настройки.Значения.КомиссияБиржи;
		КомиссияБрокера = Настройки.Значения.КомиссияБрокера;
		Если НЕ Настройки.Значения.Свойство("КомиссияБиржиДДС", КомиссияБиржиДДС) Тогда
			КомиссияБиржиДДС = Справочники.СтатьиДвиженияДенежныхСредств.ПустаяСсылка();
		КонецЕсли;
		Если НЕ Настройки.Значения.Свойство("КомиссияБрокераДДС", КомиссияБрокераДДС) Тогда
			КомиссияБрокераДДС = Справочники.СтатьиДвиженияДенежныхСредств.ПустаяСсылка();
		КонецЕсли;
		КомиссияТС = Настройки.Значения.КомиссияТС;
		Если НЕ Настройки.Значения.Свойство("КомиссияТСДДС", КомиссияТСДДС) Тогда
			КомиссияТСДДС = Справочники.СтатьиДвиженияДенежныхСредств.ПустаяСсылка();
		КонецЕсли;
		
		Почта = Неопределено;
		Если Настройки.Значения.Свойство("ПочтовыйЛогин", Почта) Тогда
			ПочтовыйЛогин = Почта;
			
			Ящики = XMLЗначение(Тип("ХранилищеЗначения"), Настройки.Значения.СписокРассылки);
			СписокРассылки.Загрузить(Ящики.Получить());
			
		КонецЕсли;
		
		Настройки.Значения.Свойство("Свойство_КодКонтрагента", Свойство_КодКонтрагента);
		
		Если Настройки.Значения.Свойство("СписокРассылкиНеНайденКонтрагент") Тогда
			Ящики = XMLЗначение(Тип("ХранилищеЗначения"), Настройки.Значения.СписокРассылкиНеНайденКонтрагент);
			СписокРассылкиНеНайденКонтрагент.Загрузить(Ящики.Получить());
		КонецЕсли;
		
		// IMAPPS-31762
		Настройки.Значения.Свойство("ДУСКомиссиейБиржи", ДУСКомиссиейБиржи);
		
		ПредставлениеНастроек = "Период с:" + Формат(ДатаНачала, "ДФ=dd.MM.yyyy") + " по:" + Формат(ДатаОкончания, "ДФ=dd.MM.yyyy") + " ";
		
	КонецЕсли;
КонецПроцедуры

Функция ПропискаРассылки(Знач НомерРассылки) Экспорт // IMDEV-7091
	Перем ПараметрыПодключения, ИмяИБ;
	
	Попытка
		ПараметрыПодключения = ОбщегоНазначенияКлиентСервер.ПолучитьПараметрыПодключенияИзСтрокиСоединенияИнформационнойБазы(СтрокаСоединенияИнформационнойБазы());
		ИмяИБ = ПараметрыПодключения.ИмяИнформационнойБазыНаСервере1СПредприятия;
	Исключение
	КонецПопытки;
	
	Прописка = " {" + НомерРассылки + ", ib: " + ?(ЗначениеЗаполнено(ИмяИБ), ИмяИБ, "< .. >") + "}";
	
	Возврат Прописка;
КонецФункции // ПропискаРассылки()

