	Шапка = Макет.ПолучитьОбласть("Шапка");
	Шапка.Параметры.ДатаНачала = ДатаНачала;
	Шапка.Параметры.ДатаОкончания = ДатаОкончания;
	Шапка.Параметры.ДатаФормирования = ТекущаяДата();
	Шапка.Параметры.Настройки = ПредставлениеНастроек;
	Лог.Вывести(Шапка);
	
	Ошибка = Макет.ПолучитьОбласть("Ошибка");
	
	ПолноеИмяФайлаWSDL = ПолучитьИмяВременногоФайла("wsdl");
	
	ФайлWSDL = ПолучитьМакет("WSDL");
	ФайлWSDL.Записать(ПолноеИмяФайлаWSDL);
	
	Попытка
		//		 Определение = Новый WSОпределения(ПолноеИмяФайлаWSDL);
		//TIBCO_URL = ?(ТестовыйРежим, "http://smsk02ap209u:8889/", "http://amaptibco:8889/");
		TIBCO_URL = ?(ЛОЖЬ, "http://smsk02ap209u:8889/", "http://amaptibco:8889/");
		
		Определение = Новый WSОпределения(TIBCO_URL);
		
		Фабрика = Определение.ФабрикаXDTO;
		
		Корень_ТИП = Фабрика.Тип(ОсновноеПространствоИмен, "Корень");
		Условия_ТИП = Фабрика.Тип(ОсновноеПространствоИмен, "Условия");
		Корень = Фабрика.Создать(Корень_ТИП);
		Условия = Фабрика.Создать(Условия_ТИП);
		
		Условия.ДатаС = ДатаНачала;
		Условия.ДатаПо = ДатаОкончания;
		Условия.База = DV_BrokerCode(ДоговорДУ);
		Условия.База = DV_BrokerCode1;
		Условия.База2 = DV_BrokerCode2;
		//IMAPPS-15318++
		//Условия.ТолькоOTC = ТолькоОТССделки;;
		
		Условия.ОтборOTC = ОтборOTC;;
		Если ОтборАктивы.Количество() Тогда
			Для Каждого СтрОтборАктив Из ОтборАктивы Цикл
				Если ЗначениеЗаполнено(СтрОтборАктив.Актив) Тогда
					Если ЗначениеЗаполнено(СтрОтборАктив.Актив.ISIN) Тогда
						Условия.ISIN.Добавить(СтрОтборАктив.Актив.ISIN);
					КонецЕсли;
					
					Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(СтрОтборАктив.Актив.Объект, "БиржиЛистинга") Тогда
						Для Каждого СтрБиржаЛистинга Из СтрОтборАктив.Актив.Объект.БиржиЛистинга Цикл
							Если ЗначениеЗаполнено(СтрБиржаЛистинга.КодЦБ) Тогда
								Условия.ISIN.Добавить(СтрБиржаЛистинга.КодЦБ);
							КонецЕсли;
						КонецЦикла;
					КонецЕсли;
					
					Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(СтрОтборАктив.Актив.Объект, "ISIN")
						И ЗначениеЗаполнено(СтрОтборАктив.Актив.Объект.ISIN) Тогда
						Условия.ISIN.Добавить(СтрОтборАктив.Актив.Объект.ISIN);
					КонецЕсли;
					
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
		//IMAPPS-15318--
		
		Корень.Условия = Условия;
		//Если ТестовыйРежим тогда
		//	 Ответ = ТестовыйОтвет(Фабрика, Корень_ТИП);
		//Иначе
		Ответ = ОтветЧерезСервис(Определение, Корень);
		//КонецЕсли;
	Исключение
		ТекстОшибки = "Ошибка подключения: " + ОписаниеОшибки();
		сообщить(ТекстОшибки);
		Отказ = Истина;
		Ошибка.Параметры.ОписаниеОшибки = ТекстОшибки;
		Лог.Вывести(Ошибка);
		
	КонецПопытки;
	
	Если Отказ = Истина Тогда Возврат; КонецЕсли;
	
	Если Ответ.Сделки.Количество() = 0 Тогда
		Сообщить("Сделок за указанный период нет");
		Возврат;
	КонецЕсли;
	
	ПрочитатьНаСервере(Ответ.Сделки[0].Сделка, Отказ);
	
КонецПроцедуры

