		|	ИЗ
		|		Справочник.ПаиПИФ КАК ПаиПИФ
		|	ГДЕ
		|		ПаиПИФ.ISIN В(&КодЦБ)
		|		И ПаиПИФ.ISIN > """"
		|		И НЕ ПаиПИФ.ПометкаУдаления
		|	
		|	ОБЪЕДИНИТЬ
		|	
		|	ВЫБРАТЬ
		|		ПаиПИФБиржаЛистинга.Ссылка,
		|		8 * ВЫБОР
		|			КОГДА ПаиПИФБиржаЛистинга.Ссылка.ПометкаУдаления
		|				ТОГДА 100
		|			ИНАЧЕ 1
		|		КОНЕЦ
		|	ИЗ
		|		Справочник.ПаиПИФ.БиржиЛистинга КАК ПаиПИФБиржаЛистинга
		|	ГДЕ
		|		ПаиПИФБиржаЛистинга.КодЦБ В(&КодЦБ)
		|		И ПаиПИФБиржаЛистинга.КодЦБ > """"
		|		И ПаиПИФБиржаЛистинга.БиржаЛистинга = &БиржаЛистинга
		|		И НЕ ПаиПИФБиржаЛистинга.Ссылка.ПометкаУдаления
		|	
		|	ОБЪЕДИНИТЬ
		|	
		|	ВЫБРАТЬ
		|		ПаиПИФБиржаЛистинга.Ссылка,
		|		9 * ВЫБОР
		|			КОГДА ПаиПИФБиржаЛистинга.Ссылка.ПометкаУдаления
		|				ТОГДА 100
		|			ИНАЧЕ 1
		|		КОНЕЦ
		|	ИЗ
		|		Справочник.ПаиПИФ.БиржиЛистинга КАК ПаиПИФБиржаЛистинга
		|	ГДЕ
		|		ПаиПИФБиржаЛистинга.КодЦБ В(&КодЦБ)
		|		И ПаиПИФБиржаЛистинга.КодЦБ > """"
		|		И НЕ ПаиПИФБиржаЛистинга.Ссылка.ПометкаУдаления
		|	
		|	ОБЪЕДИНИТЬ
		|	
		|	ВЫБРАТЬ
		|		СрочныеКонтракты.Ссылка,
		|		10 * ВЫБОР
		|			КОГДА СрочныеКонтракты.ПометкаУдаления
		|				ТОГДА 100
		|			ИНАЧЕ 1
		|		КОНЕЦ
		|	ИЗ
		|		Справочник.СрочныеКонтракты КАК СрочныеКонтракты
		|	ГДЕ
		|		СрочныеКонтракты.Код В(&КодЦБ)
		|		И СрочныеКонтракты.Код > """"
		|		И НЕ СрочныеКонтракты.ПометкаУдаления) КАК Бумаги
		|
		|УПОРЯДОЧИТЬ ПО
		|	Бумаги.Приоритет,
		|	Бумага";
	
	Результат = Запрос.Выполнить();
	Если Результат.Пустой() Тогда
		Если ВыполнятьПоискИзВнешнейОбработки И ЗначениеЗаполнено(ЭтотОбъект.ОбработкаЗагрузкиАктивов) И ЗначениеЗаполнено(ЭтотОбъект.КомандаЗагрузкиАктивов) Тогда
			ДополнительныеОтчетыИОбработки.ВыполнитьКомандуОбработкиПоПараметрам(
				ОбработкаЗагрузкиАктивов,
				КомандаЗагрузкиАктивов,
				Новый Структура("Тикер", КодЦБ)
			);
			
			НайденныйАктив = АктивПоКоду(КодЦБ, Биржа, Ложь, СтатусПоискаАктива, СчетчикРекурсии);
			
			Возврат НайденныйАктив;
		КонецЕсли;
		
		СтатусПоискаАктива = "Актив не найден";
		
		Возврат Неопределено;
	КонецЕсли;
	
	Выборка = Результат.Выбрать();
	Выборка.Следующий();
	
	НайденныйАктив = АктивСервер.ПолучитьАктивПоОбъекту(Выборка.Бумага);
	СоответствиеАктивов.Вставить(КодЦБ, НайденныйАктив);
	
	Если НЕ ВыполнятьПоискИзВнешнейОбработки Тогда
		СтатусПоискаАктива = "Актив загружен через web-service";
	КонецЕсли;
	
	Возврат НайденныйАктив;
КонецФункции // АктивПоКоду()

Функция ВалютаПоКоду(Знач Валюта, СтатусПоискаВалюты = "")
	Перем НайденнаяВалюта;
	Перем Запрос;
	
	СтатусПоискаВалюты = "";
	
	НайденнаяВалюта = СоответствиеВалют.Получить(Валюта);
	Если НайденнаяВалюта <> Неопределено Тогда
		Возврат НайденнаяВалюта;
	КонецЕсли;
	
	Запрос = Новый Запрос();
	Запрос.УстановитьПараметр("Наименование", Валюта);
	Запрос.Текст =
		"ВЫБРАТЬ
		|	Валюты.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.Валюты КАК Валюты
		|ГДЕ
		|	Валюты.Наименование = &Наименование
		|	И НЕ Валюты.ПометкаУдаления";
	
	Результат = Запрос.Выполнить();
	Если Результат.Пустой() Тогда
		СтатусПоискаВалюты = "Валюта не найдена";
		Возврат Неопределено;
	КонецЕсли;
	
	Выборка = Результат.Выбрать();
	Выборка.Следующий();
	НайденнаяВалюта = Выборка.Ссылка;
	
	СоответствиеАктивов.Вставить(Валюта, НайденнаяВалюта);
	
	Возврат НайденнаяВалюта;
	
КонецФункции // АктивПоКоду()

Функция СделкаПоНомеру(Номер, Продажа)
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("НомерСделки", Номер);
	Запрос.УстановитьПараметр("ВидОперации", ?(Продажа, Перечисления.ВидыОперацийСделка.Продажа, Перечисления.ВидыОперацийСделка.Поступление));
	Запрос.УстановитьПараметр("ВидОперации2", ?(Продажа, Перечисления.ВидОперацииБПВнебиржеваяСделка.Продажа, Перечисления.ВидОперацииБПВнебиржеваяСделка.Покупка));
	Запрос.УстановитьПараметр("ВидОперации3", ?(Продажа, Перечисления.ВидыОперацийСделкаНаСрочномРынке.Продажа, Перечисления.ВидыОперацийСделкаНаСрочномРынке.Покупка));
	
	Запрос.Текст = "ВЫБРАТЬ
		|	Сделка.Ссылка
		|ИЗ
		|	Документ.Сделка КАК Сделка
		|ГДЕ
		|	Сделка.НомерВходящегоДокумента = &НомерСделки
		|	И Сделка.ВидОперации = &ВидОперации
		|	И Сделка.ПометкаУдаления = ЛОЖЬ
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	СделкиTn.Ссылка
		|ИЗ
		|	БизнесПроцесс.СделкиTn КАК СделкиTn
		|ГДЕ
		|	СделкиTn.ВидОперации = &ВидОперации
		|	И СделкиTn.НомерСделки = &НомерСделки
		|	И СделкиTn.ПометкаУдаления = ЛОЖЬ
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ВнебиржеваяСделка.Ссылка
		|ИЗ
		|	БизнесПроцесс.ВнебиржеваяСделка КАК ВнебиржеваяСделка
		|ГДЕ
		|	ВнебиржеваяСделка.ВидОперации = &ВидОперации2
		|	И (
		|		ВнебиржеваяСделка.Номер = &НомерСделки
		// VTB-Borisov  - 23.10.2017 {
		|		ИЛИ ВнебиржеваяСделка.НомерСделки = &НомерСделки
		// VTB-Borisov  - 23.10.2017 }
		|	  )			   
		|	И ВнебиржеваяСделка.ПометкаУдаления = ЛОЖЬ
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	СделкиРЕПО.Ссылка
		|ИЗ
		|	БизнесПроцесс.СделкиРЕПО КАК СделкиРЕПО
		|ГДЕ
		|	СделкиРЕПО.НомерСделки = &НомерСделки
		|	И СделкиРЕПО.ПометкаУдаления = ЛОЖЬ
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	СделкаНаСрочномРынке.Ссылка
		|ИЗ
		|	Документ.СделкаНаСрочномРынке КАК СделкаНаСрочномРынке
		|ГДЕ
		|	СделкаНаСрочномРынке.ВидОперации = &ВидОперации3
		|	И СделкаНаСрочномРынке.НомерСделки = &НомерСделки
		|	И СделкаНаСрочномРынке.ПометкаУдаления = ЛОЖЬ";
	Результат = Запрос.Выполнить();
	Если Результат.Пустой() Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Выборка = Результат.Выбрать();
	Выборка.Следующий();
	
	Возврат Выборка.Ссылка;
	
КонецФункции

