СрочныйРынок = Ложь;

Если ТипЗнч(Актив) <> Тип("СправочникСсылка.Активы") Тогда
КодЦБнаММВБ = Актив.КодЦБнаММВБ;
АктивСпр = АктивПоКоду(КодЦБнаММВБ, Биржа);
Иначе
АктивСпр = Актив;
КонецЕсли;

Запрос = Новый Запрос;
Запрос.Текст =
"ВЫБРАТЬ
|	Активы.ВидАктива В ИЕРАРХИИ(&СрочныеКонтаркты) КАК СрочныйРынок
|ИЗ
|	Справочник.Активы КАК Активы
|ГДЕ
|	Активы.Ссылка = &АктивСпр";

Запрос.УстановитьПараметр("АктивСпр", АктивСпр);
Запрос.УстановитьПараметр("СрочныеКонтаркты", ПланыВидовХарактеристик.ВидыАктивов.СрочныеКонтракты);

РезультатЗапроса = Запрос.Выполнить();

ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();

Если ВыборкаДетальныеЗаписи.Следующий() Тогда
СрочныйРынок = ВыборкаДетальныеЗаписи.СрочныйРынок;
КонецЕсли;

Возврат СрочныйРынок;

