ВидАктиваАкции.Добавить(ПланыВидовХарактеристик.ВидыАктивов.АкцииИГ);
ВидАктиваАкции.Добавить(ПланыВидовХарактеристик.ВидыАктивов.АкцииАИФ);

СписокГруппВидовАктивовДляОпределенияInstrumentType.Вставить("FixedIncome", FixedIncome);
СписокГруппВидовАктивовДляОпределенияInstrumentType.Вставить("LocalShares", LocalShares);
СписокГруппВидовАктивовДляОпределенияInstrumentType.Вставить("ADRGDRForeignSharesETF", ADRGDRForeignSharesETF);
СписокГруппВидовАктивовДляОпределенияInstrumentType.Вставить("ВидАктиваАкции", ВидАктиваАкции);

Возврат СписокГруппВидовАктивовДляОпределенияInstrumentType;

КонецФункции

Функция InstrumentType(Актив, ОбъектАктива, СписокГруппВидовАктивовДляОпределенияInstrumentType, СписокInstrumentType)

ЭтоДепозитарнаяРасписка = Ложь;
ЭтоАкция = ТипЗнч(ОбъектАктива) = Тип("СправочникСсылка.Акции");
Если ЭтоАкция Тогда
	ЭтоДепозитарнаяРасписка = ОбщегоНазначения.ПолучитьЗначениеРеквизита(ОбъектАктива, "ДепозитарнаяРасписка");
КонецЕсли;

Запрос = Новый Запрос;
Запрос.Текст =
"ВЫБРАТЬ
|	ВЫБОР
|		КОГДА Активы.ВидАктива В (&FixedIncome)
|			ТОГДА ""FixedIncome""
|		КОГДА Активы.ВидАктива В (&LocalShares)
|			ТОГДА ""LocalShares""
|		КОГДА Активы.ВидАктива В (&ADRGDRForeignSharesETF)
|			ТОГДА ""ADRGDRForeignSharesETF""
|		КОГДА Активы.ВидАктива В (&ВидАктиваАкции)
|				И &ЭтоДепозитарнаяРасписка
|			ТОГДА ""ADRGDRForeignSharesETF""
|	КОНЕЦ КАК InstrumentType
|ИЗ
|	Справочник.Активы КАК Активы
|ГДЕ
|	Активы.Ссылка = &АктивСсылка";
Запрос.УстановитьПараметр("FixedIncome", СписокГруппВидовАктивовДляОпределенияInstrumentType.FixedIncome);
Запрос.УстановитьПараметр("LocalShares", СписокГруппВидовАктивовДляОпределенияInstrumentType.LocalShares);
Запрос.УстановитьПараметр("ADRGDRForeignSharesETF", СписокГруппВидовАктивовДляОпределенияInstrumentType.ADRGDRForeignSharesETF);
Запрос.УстановитьПараметр("ВидАктиваАкции", СписокГруппВидовАктивовДляОпределенияInstrumentType.ВидАктиваАкции);
Запрос.УстановитьПараметр("ЭтоДепозитарнаяРасписка", ЭтоДепозитарнаяРасписка);
Запрос.УстановитьПараметр("АктивСсылка", Актив);

РезультатЗапроса = Запрос.Выполнить();

Если НЕ РезультатЗапроса.Пустой() Тогда
	ВыборкаИзРезультатаЗапроса = РезультатЗапроса.Выбрать();
	ВыборкаИзРезультатаЗапроса.Следующий();
	Возврат СписокInstrumentType.Получить(ВыборкаИзРезультатаЗапроса.InstrumentType);
КонецЕсли;

КонецФункции

Функция СписокInstrumentType(СвойствоInstrumentType)

СписокInstrumentType = Новый Соответствие;

Если НЕ СвойствоInstrumentType.Пустая() Тогда
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ЗначенияСвойствОбъектов.Ссылка КАК InstrumentTypeСсылка,
	|	ЗначенияСвойствОбъектов.Наименование КАК InstrumentTypeНаименование
	|ИЗ
	|	Справочник.ЗначенияСвойствОбъектов КАК ЗначенияСвойствОбъектов
	|ГДЕ
	|	ЗначенияСвойствОбъектов.Владелец = &СвойствоInstrumentType";
	Запрос.УстановитьПараметр("СвойствоInstrumentType", СвойствоInstrumentType);
	ВыборкаИзРезультатаЗапроса = Запрос.Выполнить().Выбрать();
	
	Пока ВыборкаИзРезультатаЗапроса.Следующий() Цикл
		
		Если ВыборкаИзРезультатаЗапроса.InstrumentTypeНаименование = "Fixed income" Тогда
			СписокInstrumentType.Вставить("FixedIncome", ВыборкаИзРезультатаЗапроса.InstrumentTypeСсылка);
		ИначеЕсли ВыборкаИзРезультатаЗапроса.InstrumentTypeНаименование = "Local shares" Тогда
			СписокInstrumentType.Вставить("LocalShares", ВыборкаИзРезультатаЗапроса.InstrumentTypeСсылка);
		ИначеЕсли ВыборкаИзРезультатаЗапроса.InstrumentTypeНаименование = "ADR/GDR/Foreign shares/ETF" Тогда
			СписокInstrumentType.Вставить("ADRGDRForeignSharesETF", ВыборкаИзРезультатаЗапроса.InstrumentTypeСсылка);
		КонецЕсли;
		
	КонецЦикла;
КонецЕсли;

Возврат СписокInstrumentType;

КонецФункции

Функция ПолучитьСчетПолучателя(Брокер, ВалютаСделки)
Запрос = Новый Запрос;
запрос.Текст = "ВЫБРАТЬ
|	БанковскиеСчета.Ссылка
|ИЗ
|	Справочник.БанковскиеСчета КАК БанковскиеСчета
|ГДЕ
|	БанковскиеСчета.Владелец = &Брокер
|	И БанковскиеСчета.ДействующийCчетДляРасчетовПоOTCсделкам = ИСТИНА
|	И БанковскиеСчета.ПометкаУдаления = ЛОЖЬ
|	И БанковскиеСчета.ВидСчета = ЗНАЧЕНИЕ(Перечисление.ВидБанковскогоСчета.Расчетный)
|	И БанковскиеСчета.ВалютаДенежныхСредств = &ВалютаСделки";

Запрос.УстановитьПараметр("Брокер", Брокер);
Запрос.УстановитьПараметр("ВалютаСделки", ВалютаСделки);

тз = Запрос.Выполнить().Выгрузить();

Если тз.Количество() > 1 Тогда
	Сообщить("Внимание! Для контрагента " + Брокер + " и валюты " + ВалютаСделки + " найдено более одного Счета получателя");
	Возврат Справочники.БанковскиеСчета.ПустаяСсылка();
ИначеЕсли тз.Количество() = 1 Тогда
Возврат тз[0].Ссылка;
Иначе
Сообщить("Внимание! Для контрагента " + Брокер + " и валюты " + ВалютаСделки + " не найдено Счет получателя");
Возврат Справочники.БанковскиеСчета.ПустаяСсылка();
КонецЕсли;

КонецФункции

