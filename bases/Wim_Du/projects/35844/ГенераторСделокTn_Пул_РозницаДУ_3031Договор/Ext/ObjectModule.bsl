Процедура СоздатьОбъекты(Отказ, ТекстОшибки = "") Экспорт
	
	Если Отказ Тогда Возврат; КонецЕсли;
	
	// Группировка сделок по ДоговорДУ для параллельной обработки
	СделкиПоДоговорам = Новый Соответствие;
	
	// Кэшируем структуру колонок для быстрого создания таблиц
	СтруктураКолонок = СписокЗагрузки.ВыгрузитьКолонки();
	
	Для Каждого ТекСтрока Из СписокЗагрузки Цикл
		ДоговорДУ = ТекСтрока.ДоговорДУ;
		
		Если НЕ ЗначениеЗаполнено(ДоговорДУ) Тогда
			Продолжить;
		КонецЕсли;
		
		ТаблицаСделокДоговора = СделкиПоДоговорам.Получить(ДоговорДУ);
		Если ТаблицаСделокДоговора = Неопределено Тогда
			ТаблицаСделокДоговора = СтруктураКолонок.Скопировать();
			СделкиПоДоговорам.Вставить(ДоговорДУ, ТаблицаСделокДоговора);
		КонецЕсли;
		
		ЗаполнитьЗначенияСвойств(ТаблицаСделокДоговора.Добавить(), ТекСтрока);
	КонецЦикла;
	
	// Создание очереди договоров для обработки
	ОчередьДоговоров = Новый Массив;
	Для Каждого ЭлементДанных Из СделкиПоДоговорам Цикл
		ОчередьДоговоров.Добавить(ЭлементДанных.Ключ);
	КонецЦикла;
	
	// Инициализация структур для управления заданиями
	АктивныеЗадания = Новый Соответствие; // GUID -> Структура с информацией
	ИндексОчереди = 0;
	МаксимумОдновременныхЗаданий = 20;
	
	// Счетчики для статистики
	ВсегоСделокОбработано = 0;
	ВсегоОшибок = 0;
	ВсеОшибки = Новый Массив;
	ВремяНачалаФормированияСделок = ТекущаяУниверсальнаяДатаВМиллисекундах();
	КвоЗапущенных = 0;
	
	// Основной цикл управления пулом заданий
	Пока ИндексОчереди < ОчередьДоговоров.Количество() ИЛИ АктивныеЗадания.Количество() > 0 Цикл
		
		// ШАГ 1: Проверить завершенные задания (неблокирующая проверка)
		МассивЗавершенныхGUID = Новый Массив;
		
		Для Каждого ЭлементЗадания Из АктивныеЗадания Цикл
			GUIDЗадания = ЭлементЗадания.Ключ;
			ИнформацияОЗадании = ЭлементЗадания.Значение;
			
			Попытка
				ФоновоеЗадание = ФоновыеЗадания.НайтиПоУникальномуИдентификатору(GUIDЗадания);
				
				Если ФоновоеЗадание = Неопределено Тогда
					МассивЗавершенныхGUID.Добавить(GUIDЗадания);
					Продолжить;
				КонецЕсли;
				
				СостояниеЗадания = ФоновоеЗадание.Состояние;
				
				Если СостояниеЗадания = СостояниеФоновогоЗадания.Завершено Тогда
					Попытка
						РезультатЗадания = ПолучитьИзВременногоХранилища(ИнформацияОЗадании.АдресХранилищаРезультата);
						
						ВсегоСделокОбработано = ВсегоСделокОбработано + РезультатЗадания.Обработано;
						ВсегоОшибок = ВсегоОшибок + РезультатЗадания.Ошибок;
						
						Для Каждого Ошибка Из РезультатЗадания.СписокОшибок Цикл
							ВсеОшибки.Добавить(Ошибка);
						КонецЦикла;
					Исключение
						СтруктураОшибки = Новый Структура;
						СтруктураОшибки.Вставить("ДоговорДУ", ИнформацияОЗадании.ДоговорДУ);
						СтруктураОшибки.Вставить("ТекстОшибки", "Ошибка чтения результатов: " + ОписаниеОшибки());
						ВсеОшибки.Добавить(СтруктураОшибки);
					КонецПопытки;
					
					МассивЗавершенныхGUID.Добавить(GUIDЗадания);
					
				ИначеЕсли СостояниеЗадания = СостояниеФоновогоЗадания.ЗавершеноАварийно Тогда
					СтруктураОшибки = Новый Структура;
					СтруктураОшибки.Вставить("ДоговорДУ", ИнформацияОЗадании.ДоговорДУ);
					СтруктураОшибки.Вставить("ТекстОшибки", "Задание завершилось с ошибкой");
					ВсеОшибки.Добавить(СтруктураОшибки);
					МассивЗавершенныхGUID.Добавить(GUIDЗадания);
					
				ИначеЕсли СостояниеЗадания = СостояниеФоновогоЗадания.Отменено Тогда
					МассивЗавершенныхGUID.Добавить(GUIDЗадания);
				КонецЕсли;
				
			Исключение
				СтруктураОшибки = Новый Структура;
				СтруктураОшибки.Вставить("ДоговорДУ", ИнформацияОЗадании.ДоговорДУ);
				СтруктураОшибки.Вставить("ТекстОшибки", "Ошибка проверки задания: " + ОписаниеОшибки());
				ВсеОшибки.Добавить(СтруктураОшибки);
				МассивЗавершенныхGUID.Добавить(GUIDЗадания);
			КонецПопытки;
			
		КонецЦикла;
		
		// Удалить завершенные из активных
		Для Каждого ЗавершенныйGUID Из МассивЗавершенныхGUID Цикл
			АктивныеЗадания.Удалить(ЗавершенныйGUID);
		КонецЦикла;
		
		// ШАГ 2: Запустить новые задания из очереди
		Пока АктивныеЗадания.Количество() < МаксимумОдновременныхЗаданий
			И ИндексОчереди < ОчередьДоговоров.Количество() Цикл
			
			ДоговорДУ = ОчередьДоговоров[ИндексОчереди];
			ТаблицаСделокДоговора = СделкиПоДоговорам[ДоговорДУ];
			
			// Создать адрес временного хранилища для возврата результатов
			АдресХранилищаРезультата = ПоместитьВоВременноеХранилище(Неопределено, Новый УникальныйИдентификатор);
			
			ПараметрыДоговора = Новый Структура;
			ПараметрыДоговора.Вставить("ДоговорДУ", ДоговорДУ);
			ПараметрыДоговора.Вставить("БУ", БУ);
			ПараметрыДоговора.Вставить("ВУ", ВУ);
			ПараметрыДоговора.Вставить("УУ", УУ);
			
			// Создать массив параметров для фонового задания
			ПараметрыФона = Новый Массив;
			ПараметрыФона.Добавить(XML(ТаблицаСделокДоговора)); // Первый параметр - XML-сериализованная таблица
			ПараметрыФона.Добавить(XML(ПараметрыДоговора)); // Второй параметр
			ПараметрыФона.Добавить(АдресХранилищаРезультата); // Третий параметр
			
			// Генерировать уникальный ключ задания (строка)
			КлючФоновогоЗадания = Строка(Новый УникальныйИдентификатор);
			
			Попытка
				ЗапущенноеЗадание = ФоновыеЗадания.Выполнить(
						"ОбработкаЗагрузкиСделок.СоздатьОбъектыПоДоговору",
						ПараметрыФона,
						КлючФоновогоЗадания,
						"Загрузка сделок по договору: " + Строка(ДоговорДУ)
					);
				
				ИдентификаторЗадания = ЗапущенноеЗадание.УникальныйИдентификатор;
				
				ИнформацияОЗадании = Новый Структура;
				ИнформацияОЗадании.Вставить("ДоговорДУ", ДоговорДУ);
				ИнформацияОЗадании.Вставить("АдресХранилищаРезультата", АдресХранилищаРезультата);
				
				АктивныеЗадания.Вставить(ИдентификаторЗадания, ИнформацияОЗадании);
				
			Исключение
				СтруктураОшибки = Новый Структура;
				СтруктураОшибки.Вставить("ДоговорДУ", ДоговорДУ);
				СтруктураОшибки.Вставить("ТекстОшибки", "Ошибка запуска задания: " + ОписаниеОшибки());
				ВсеОшибки.Добавить(СтруктураОшибки);
			КонецПопытки;
			
			ИндексОчереди = ИндексОчереди + 1;
		КонецЦикла;
		
		// ШАГ 3: Пауза перед следующей проверкой
		Если АктивныеЗадания.Количество() > 0 Тогда
			VTB_ОбщийМодуль.ПаузаБСП(0.2); // 0.2 секунды
		КонецЕсли;
		
	КонецЦикла;
	
	// Вывод статистики
	/////////////////////////////////////////////////////////////////////////////////////////////
	ВремяОкончанияФормированияСделок = ТекущаяУниверсальнаяДатаВМиллисекундах();
	ПрошлоВремени = ВремяОкончанияФормированияСделок - ВремяНачалаФормированияСделок;
	ПрошлоВремениСек = ПрошлоВремени / 1000;
	Часов = Цел(ПрошлоВремениСек / 3600);
	Минут = Цел((ПрошлоВремениСек - Часов * 3600) / 60);
	Секунд = ПрошлоВремениСек - Часов * 3600 - Минут * 60;
	
	Сообщить("=== ЗАВЕРШЕНО ОБРАБОТКИ ===");
	Сообщить("Обработано сделок: " + ВсегоСделокОбработано);
	Сообщить("Ошибок: " + ВсегоОшибок);
	Сообщить("Формирование выполнялось - " + Часов + ":" + Минут + ":" + Секунд);
	
	Если ВсеОшибки.Количество() > 0 Тогда
		Сообщить("!! ОБНАРУЖЕНЫ ОШИБКИ: " + ВсеОшибки.Количество() + " !!");
		Для Каждого Ошибка Из ВсеОшибки Цикл
			Попытка
				Сообщить("  - Договор: " + Ошибка.ДоговорДУ + ", Ошибка: " + Ошибка.ТекстОшибки);
			Исключение
				Сообщить("  - Номер сделки: " + Ошибка.НомерСделки + ", Ошибка: " + Ошибка.ТекстОшибки);
			КонецПопытки;
		КонецЦикла;
	Иначе
		Сообщить("Ошибок не обнаружено.");
	КонецЕсли;
	
	// ВАЖНО: Вся логика создания БП перенесена в общий модуль ОбработкаЗагрузкиСделок.СоздатьОбъектыПоДоговору
	// Старая логика удалена и заменена на параллельную обработку через фоновые задания
	
	// Удаление обработанных сделок из списка
	МассивУдаления = Новый Массив;
	
	// Собираем обработанные сделки из результатов фоновых заданий
	// (уже собрано в цикле обработки заданий выше)
	
	Для Каждого ТекСтрока Из МассивУдаления Цикл
		СписокЗагрузки.Удалить(ТекСтрока);
	КонецЦикла;
	
КонецПроцедуры

Функция ПолучитьТекстОшибки(ТекстОшибки)
	ТекстОшибки = ТекстОшибки + Символы.ПС;
	
	МассивСообщений = ПолучитьСообщенияПользователю(Истина);
	Для каждого ТекСообщение из МассивСообщений Цикл
		ТекстОшибки = ТекстОшибки + ТекСообщение.Текст + Символы.ПС;
	Конеццикла;
	
	Возврат ТекстОшибки;
КонецФункции

Функция ТестовыйОтвет(Фабрика, Корень_ТИП)

ФайлПример = ПолучитьИмяВременногоФайла("xml");

Пример = ПолучитьМакет("ПримерОтвета");
Пример.Записать(ФайлПример, КодировкаТекста.UTF8);

Чтение = Новый ЧтениеXML;
Чтение.ОткрытьФайл(ФайлПример);

Корень_ТИП = Фабрика.Тип(ОсновноеПространствоИмен, "Корень");
Корень = Фабрика.ПрочитатьXML(Чтение, Корень_ТИП);

Возврат Корень;

КонецФункции

Функция ОтветЧерезСервис(Определение, Корень)
Прокси = Новый WSПрокси(Определение, Определение.Сервисы[0].URIПространстваИмен, Определение.Сервисы[0].Имя, Определение.Сервисы[0].ТочкиПодключения[0].Имя);
Прокси.GetDeals(Корень);

Возврат Корень;
