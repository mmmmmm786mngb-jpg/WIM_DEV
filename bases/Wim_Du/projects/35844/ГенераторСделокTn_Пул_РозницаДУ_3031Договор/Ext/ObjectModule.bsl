		|	ТорговыеКодыRUB.АналитическийСчетДС КАК АналитическийСчетДСКомиссиБрокера,
		|	ТорговыеКодыRUB.АналитическийСчетДС КАК АналитическийСчетДСКомиссииБиржи
		|ИЗ
		|	Справочник.ТорговыеКоды КАК ТорговыеКоды
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Контрагенты.ДополнительныеРеквизиты КАК КонтрагентыДополнительныеРеквизиты
		|		ПО ТорговыеКоды.Брокер = КонтрагентыДополнительныеРеквизиты.Ссылка
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ТорговыеКоды КАК ТорговыеКодыRUB
		|		ПО (ТорговыеКодыRUB.Брокер = ТорговыеКоды.Брокер)
		|			И (ТорговыеКоды.ТорговыйКод = ТорговыеКодыRUB.ТорговыйКод
		|				ИЛИ ТорговыеКоды.Наименование = ТорговыеКодыRUB.Наименование)
		|			И (НЕ ТорговыеКодыRUB.ПометкаУдаления)
		|			И (ТорговыеКодыRUB.АналитическийСчетДС.МестоХранения.ВалютаДенежныхСредств = &RUB)
		|			И ТорговыеКоды.ДоговорДУ = ТорговыеКодыRUB.ДоговорДУ
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ТорговыеКоды.СписокКодов КАК ТорговыеКодыСписокКодов
		|		ПО (ТорговыеКодыСписокКодов.Ссылка = ТорговыеКоды.Ссылка)
		|ГДЕ
		|	(ТорговыеКоды.ТорговыйКод = &ТорговыйКод
		|			ИЛИ ТорговыеКоды.Наименование = &ТорговыйКод
		|			ИЛИ ТорговыеКодыСписокКодов.ТорговыйКод = &ТорговыйКод)
		|	И КонтрагентыДополнительныеРеквизиты.Свойство = &Свойство
		|	И КонтрагентыДополнительныеРеквизиты.Значение = &Значение
		|	И НЕ ТорговыеКоды.ПометкаУдаления
		|	И ВЫБОР
		|			КОГДА ТорговыеКоды.АналитическийСчетДС.МестоХранения ССЫЛКА Справочник.БанковскиеСчета
		|				ТОГДА ТорговыеКоды.АналитическийСчетДС.МестоХранения.ВалютаДенежныхСредств = &ВалютаДС
		|			ИНАЧЕ ИСТИНА
		|		КОНЕЦ";
	Запрос.УстановитьПараметр("ТорговыйКод", КодКлиента);
	Запрос.УстановитьПараметр("ВалютаДС", ВалютаДС);
	Запрос.УстановитьПараметр("RUB", Справочники.Валюты.RUB);
	
	
	
	//Если КодБиржи = "OTC" и ЗначениеЗаполнено(КодБрокера) Тогда
	//	 Запрос.УстановитьПараметр("Значение", КодБрокера);
	//	 Запрос.УстановитьПараметр("Свойство", ПланыВидовХарактеристик.ДополнительныеРеквизитыИСведения.НайтиПоНаименованию("Counterparty"));
	//Иначе
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Контрагенты.ДополнительныеРеквизиты КАК КонтрагентыДополнительныеРеквизиты", "");
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "ПО ТорговыеКоды.Брокер = КонтрагентыДополнительныеРеквизиты.Ссылка", "");
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "И КонтрагентыДополнительныеРеквизиты.Свойство = &Свойство", "");
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "И КонтрагентыДополнительныеРеквизиты.Значение = &Значение", "");
	//КонецЕсли;
	
	Результат = Запрос.Выполнить();
	Если Результат.Пустой() Тогда Возврат Неопределено; КонецЕсли;
	
	Выборка = Результат.Выбрать();
	Выборка.Следующий();
	Возврат Выборка;
	
	
КонецФункции

Функция ПолучитьМассивКодовЦБ(Знач КодЦБ)
	Перем МассивКодовЦБ;
	Перем ЭтоISIN, Концовка;
	
	КодЦБ = СокрЛП(КодЦБ);
	
	МассивКодовЦБ = Новый Массив();
	МассивКодовЦБ.Добавить(КодЦБ);
	
	ЭтоISIN = СтрДлина(КодЦБ) = 12 И СтрНайти(КодЦБ, " ") = 0 И СтрНайти(КодЦБ, Символы.НПП) = 0; // у ISIN'ов нет пробелов и он длиной 12 символов!
	
	Если НЕ ЭтоISIN Тогда
		Концовка = " USD";
		
		Если СтрЗаканчиваетсяНа(ВРег(КодЦБ), Концовка) Тогда
			// если есть Концовка - выкусываем её
			МассивКодовЦБ.Добавить(СокрП(Лев(КодЦБ, СтрДлина(КодЦБ) - СтрДлина(Концовка))));
		Иначе
			// если нет Концовки - добавляем её
			МассивКодовЦБ.Добавить(КодЦБ + Концовка);
		КонецЕсли;
	КонецЕсли;
	
	Возврат МассивКодовЦБ;
КонецФункции // ПолучитьМассивКодовЦБ()

Функция АктивПоКоду(Знач КодЦБ, Знач Биржа, Знач ВыполнятьПоискИзВнешнейОбработки = Истина, СтатусПоискаАктива = "", СчетчикРекурсии = 0)
	Перем НайденныйАктив;
	Перем Запрос;
	
	СтатусПоискаАктива = "";
	
	НайденныйАктив = СоответствиеАктивов.Получить(КодЦБ);
	Если НайденныйАктив <> Неопределено Тогда
		Возврат НайденныйАктив;
	КонецЕсли;
	
	СчетчикРекурсии = СчетчикРекурсии + 1;
	Если СчетчикРекурсии > 2 Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Запрос = Новый Запрос();
	Запрос.УстановитьПараметр("БиржаЛистинга", Биржа);
	Запрос.УстановитьПараметр("КодЦБ", ПолучитьМассивКодовЦБ(КодЦБ));
