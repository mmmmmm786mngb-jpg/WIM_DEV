		Если Найти(ТекСделка.РежимТоргов, "SPB") > 0 И НЕ ТекСделка.РежимТоргов = "SPBFUT" Тогда
			НоваяСделка.Биржа = Справочники.Биржи.НайтиПоКоду("СПБФБ");
		КонецЕсли;
		// MPazhukov IMAPPS-11989
		
		Если ЭтоВалютнаяСделка Тогда
			КодЦБнаММВБ = ТекСделка.Актив.КодЦБнаММВБ;
			ВалютаБазовая = Лев(КодЦБнаММВБ, 3);
			ВалютаРасчетов = Сред(КодЦБнаММВБ, 4, 3);
			РежимТоргов = Прав(КодЦБнаММВБ, 3);
			
			Если ВалютаРасчетов = "000" И ТекСделка.ВалютаСделки = "RUB" Тогда
				ВалютаРасчетов = ТекСделка.ВалютаСделки;
			КонецЕсли;
			
			СтатусПоискаВалютыБазовой = "Валюта не найдена";
			
			Если НенайденныеВалюты.НайтиСтроки(Новый Структура("Валюта", ВалютаБазовая)).Количество() = 0 Тогда
				ВалютаБазовая = ВалютаПоКоду(ВалютаБазовая, СтатусПоискаВалютыБазовой);
			Иначе
				ВалютаБазовая = Неопределено;
			КонецЕсли;
			
			Если ВалютаБазовая = Неопределено Тогда
				НоваяСтрока = НенайденныеВалюты.Добавить();
				НоваяСтрока.Валюта = ВалютаБазовая;
			Иначе
				НоваяСделка.ВалютаБазовая = ВалютаБазовая;
			КонецЕсли;
			
			СтатусПоискаВалютыРасчетов = "Валюта не найдена";
			
			Если НенайденныеВалюты.НайтиСтроки(Новый Структура("Валюта", ВалютаРасчетов)).Количество() = 0 Тогда
				ВалютаРасчетов = ВалютаПоКоду(ВалютаРасчетов, СтатусПоискаВалютыРасчетов);
			Иначе
				ВалютаРасчетов = Неопределено;
			КонецЕсли;
			
			Если ВалютаРасчетов = Неопределено Тогда
				НоваяСтрока = НенайденныеВалюты.Добавить();
				НоваяСтрока.Валюта = ВалютаРасчетов;
			Иначе
				НоваяСделка.ВалютаРасчетов = ВалютаРасчетов;
			КонецЕсли;
			
			НоваяСделка.ВалютаСделки = ВалютаРасчетов;
			
			// IMAPPS-26362 ++
			// НоваяСделка.СуммаВБазовойВалюте = ТекСделка.Количество * 1000;
			Если ТекСделка.РежимТоргов = "CETS_SU" Тогда
				НоваяСделка.СуммаВБазовойВалюте = ТекСделка.Количество;
			Иначе
				НоваяСделка.СуммаВБазовойВалюте = ТекСделка.Количество * 1000;
			КонецЕсли;
			// IMAPPS-26362 --
			
			НоваяСделка.Сумма = ТекСделка.Сумма;
			Если ВРег(РежимТоргов) = "TOD" Тогда
				НоваяСделка.РежимТоргов = Перечисления.РежимТорговСделкаСВалютой.TOD;
			ИначеЕсли ВРег(РежимТоргов) = "TOM" Тогда
				НоваяСделка.РежимТоргов = Перечисления.РежимТорговСделкаСВалютой.TOM;
				// IMAPPS-29198++
			ИначеЕсли ВРег(РежимТоргов) = "TMS" Тогда
				НоваяСделка.РежимТоргов = Перечисления.РежимТорговСделкаСВалютой.TMS;
				// IMAPPS-29198--
			ИначеЕсли ВРег(РежимТоргов) = "SPT" Тогда
				НоваяСделка.РежимТоргов = Перечисления.РежимТорговСделкаСВалютой.SPT;
			КонецЕсли;
			
			НоваяСделка.СтатусПоискаВалютыБазовой = СтатусПоискаВалютыБазовой;
			НоваяСделка.СтатусПоискаВалютыРасчетов = СтатусПоискаВалютыРасчетов;
			
			НоваяСделка.КодБиржи = ТекСделка.Биржа.Наименование;
			НоваяСделка.КодЦБнаММВБ = ТекСделка.Актив.КодЦБнаММВБ;
			
			Если ОтборПоПулу = 1 Тогда
				Комментарий = СокрЛП(ТекСделка.Комментарий);
				КодКлиента = Лев(Комментарий, СтрДлина(Комментарий) - 1);
			Иначе
				КодКлиента = ТекСделка.КодКлиента;
			КонецЕсли;
			
			ТорговыйКод = ТорговыйКодПоКоду(КодКлиента, ТекСделка.КодБрокера, ТекСделка.РежимТоргов, ВалютаРасчетов);
			Если ТорговыйКод <> Неопределено Тогда
				ЗаполнитьЗначенияСвойств(НоваяСделка, ТорговыйКод);
			КонецЕсли;
			
			ТорговыйКод = ТорговыйКодПоКоду(КодКлиента, ТекСделка.КодБрокера, ТекСделка.РежимТоргов, ВалютаБазовая);
			Если ТорговыйКод <> Неопределено Тогда
				НоваяСделка.АналитическийСчетДСВалюта = ТорговыйКод.АналитическийСчетДС;
			КонецЕсли;
			
			//IMAVIN-97 Брокера определяем по коду
			Если НЕ ЗначениеЗаполнено(НоваяСделка.Брокер) ИЛИ ТекСделка.РежимТоргов = "OTC" Тогда
				НоваяСделка.Брокер = ПолучитьБрокераПоКоду(ТекСделка.КодБрокера);
			КонецЕсли;
			НоваяСделка.КомиссияБрокера = ТекСделка.CmsBroker;
			
			РассчитатьКомиссиюБрокераВалютныеСделки(НоваяСделка, НоваяСделка.СтатусКомиссии);
			
		Иначе
			ОбъектАктива = Неопределено; // TM-3342
			
			СтатусПоискаАктива = "Актив не найден";
			КодЦБнаММВБ = ТекСделка.Актив.КодЦБнаММВБ;
			Если НенайденныеАктивы.НайтиСтроки(Новый Структура("КодЦБнаММВБ, Биржа", КодЦБнаММВБ, Биржа)).Количество() = 0 Тогда
				Актив = АктивПоКоду(КодЦБнаММВБ, Биржа, Истина, СтатусПоискаАктива, 0);
			Иначе
				Актив = Неопределено;
			КонецЕсли;
			
			////////////////////////////////////////////////////НоваяСделка.РежимТоргов = РежимТорговПоID(ТекСделка.РежимТоргов);
			///////////
			РежимТорговИзКеша = КешРежимовТоргов.Получить(ТекСделка.РежимТоргов);
			Если РежимТорговИзКеша <> Неопределено Тогда
				// Берём из кеша — не вызываем функцию
				НоваяСделка.РежимТоргов = РежимТорговИзКеша;
			Иначе
				// Вызываем функцию и сохраняем результат в кеш
				РезультатФункции = РежимТорговПоID(ТекСделка.РежимТоргов);
				КешРежимовТоргов.Вставить(ТекСделка.РежимТоргов, РезультатФункции);
				НоваяСделка.РежимТоргов = РезультатФункции;
			КонецЕсли;			
			///////////
			
			Если Актив = Неопределено Тогда
				НоваяСтрока = НенайденныеАктивы.Добавить();
				НоваяСтрока.КодЦБнаММВБ = КодЦБнаММВБ;
				НоваяСтрока.Биржа = Биржа;
				НоваяСделка.ЭтоСделкаСрочногоРынка = Ложь;
			Иначе
				НоваяСделка.ЭтоСделкаСрочногоРынка = Ложь;
				////////////////////////////////////////////////НоваяСделка.ЭтоСделкаСрочногоРынка = ЭтоСделкаСрочногоРынка(Актив);
				Если СтрНайти(ТекСделка.Комментарий, "HTM") > 0 Тогда
					НоваяСделка.HTM = истина
				КонецЕсли;
				НоваяСделка.Актив = Актив;
				
				Если НоваяСделка.ЭтоСделкаСрочногоРынка Тогда
					//НоваяСделка.Количество = НоваяСделка.Количество * Актив.Объект.Лот;
					НоваяСделка.Цена = НоваяСделка.Цена * Актив.Объект.Лот;
					НоваяСделка.КомиссияБиржи = ТекСделка.komissija_birga;
					НоваяСделка.Биржа = Актив.Объект.БиржаЛистинга;
				КонецЕсли;
				
				ВидАктива = ОбщегоНазначения.ПолучитьЗначениеРеквизита(Актив, "ВидАктива");
				ОбъектАктива = ОбщегоНазначения.ПолучитьЗначениеРеквизита(Актив, "Объект");
				
				// VTB-Borisov  - 17.07.2019 {
				Если НЕ ЗначениеЗаполнено(ВидАктива) Тогда
					//	ОбщегоНазначенияКлиентСервер.СообщитьПользователю();
					ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Внимание! Актив <" + Актив + "> - не указан ВидАктива! Сделка не будет обработана");
					СтатусПоискаАктива = "Актив <" + Актив + "> - не указан ВидАктива.";
					//	Продолжить;
					
				Иначе
					// VTB-Borisov  - 17.07.2019 }
					
					ЭтоСрочныйКонтракт = ВидАктива.ПринадлежитЭлементу(ПланыВидовХарактеристик.ВидыАктивов.СрочныеКонтракты);
					
					Если ЭтоСрочныйКонтракт Тогда
						КотировкаАктива = ОбщегоНазначения.ПолучитьЗначениеРеквизита(ОбъектАктива, "Котировка");
						ТекСделка.ВалютаСделки = Строка(КотировкаАктива);
					Иначе
						ВалютаНоминальнойСтоимости = ОбщегоНазначения.ПолучитьЗначениеРеквизита(ОбъектАктива, "ВалютаНоминальнойСтоимости");
						// ТекСделка.ВалютаСделки = Строка(ВалютаНоминальнойСтоимости);
					КонецЕсли;
				КонецЕсли;
				// TM-3342 }
			КонецЕсли;
			НоваяСделка.СтатусПоискаАктива = СтатусПоискаАктива;
			НоваяСделка.КодБиржи = ТекСделка.Биржа.Наименование;
			НоваяСделка.КодЦБнаММВБ = ТекСделка.Актив.КодЦБнаММВБ;
			////////////////////////////Валюта = Справочники.Валюты.НайтиПоНаименованию(ТекСделка.ВалютаСделки);
			////////////////////////////Если Валюта.Пустая() Тогда
				Валюта = ВалютаRUB;
			////////////////////////////КонецЕсли;
			КурсКратность = МодульВалютногоУчета.ПолучитьКурсВалюты(ВалютаRUB, Валюта, ТекДата); // TM-3342
			НоваяСделка.КурсВалютыСделки = КурсКратность.Курс;
			НоваяСделка.КратностьВалютыСделки = КурсКратность.Кратность;
			НоваяСделка.ВалютаСделки = Валюта;
			
			Если ОтборПоПулу = 1 Тогда
				Комментарий = СокрЛП(ТекСделка.Комментарий);
				КодКлиента = Лев(Комментарий, СтрДлина(Комментарий) - 1);
			Иначе
				КодКлиента = ТекСделка.КодКлиента;
			КонецЕсли;
			
			////////////////////////ТорговыйКод = ТорговыйКодПоКоду(КодКлиента, ТекСделка.КодБрокера, ТекСделка.РежимТоргов, Валюта);
			////////////////////////Если ТорговыйКод <> Неопределено Тогда
			////////////////////////	ЗаполнитьЗначенияСвойств(НоваяСделка, ТорговыйКод);
			////////////////////////КонецЕсли;
			ЗаполнитьЗначенияСвойств(НоваяСделка, ТекСделка.ТорговыйКодПоКодуБезДеталей);
			
			//IMAVIN-97 Брокера определяем по коду
			Если НЕ ЗначениеЗаполнено(НоваяСделка.Брокер) ИЛИ ТекСделка.РежимТоргов = "OTC" Тогда
				НоваяСделка.Брокер = ПолучитьБрокераПоКоду(ТекСделка.КодБрокера);
			КонецЕсли;
			НоваяСделка.КомиссияБрокера = ТекСделка.CmsBroker;
			// ++ IMAPPS-24495 Чижов В.В. 30.01.2024
			Если НоваяСделка.Брокер = БрокрескаяКомпанияПлатформа Тогда
				НоваяСделка.ВалютаКомисcииБрокера = ВалютаRUB;
				// ++ IMAPPS-24575 Чижов В.В. 02.02.2024
			ИначеЕсли НоваяСделка.Брокер = БанкВТБ Тогда
				НоваяСделка.ВалютаКомисcииБрокера = НоваяСделка.ВалютаСделки;
				НоваяСделка.ВалютаКомисcииБиржи = НоваяСделка.ВалютаСделки;
				НоваяСделка.КомиссияБиржи = НоваяСделка.КомиссияБиржи / НоваяСделка.КурсВалютыСделки * НоваяСделка.КратностьВалютыСделки;
				
				// IMAPPS-24661++
				// Для БанкВТБ КомиссияБиржи состоит из двух комиссий полей komissija_birga + komissija_kliring
				// и брокер на своей стороне комиссию пересчитывает в RUB отдельно по каждой комиссии,а потому результаты суммирует
				// у нас было, что общую сумму в валюте пересчитываем, а в итоге имеем расхождение с данными брокера в копейки
				Если НЕ ВалютаRUB = Валюта Тогда
					// IMAPPS-27942 ++
					КомиссияФондовойБиржи = Окр(ТекСделка.komissija_birga / НоваяСделка.КурсВалютыСделки * НоваяСделка.КратностьВалютыСделки, 2);
					КомиссияКлиринга = Окр(ТекСделка.komissija_kliring / НоваяСделка.КурсВалютыСделки * НоваяСделка.КратностьВалютыСделки, 2);
					НоваяСделка.КомиссияБиржи =
					?(КомиссияФондовойБиржи > 0.01, КомиссияФондовойБиржи, 0.01) +
					?(КомиссияКлиринга > 0.01, КомиссияКлиринга, 0.01);
					// IMAPPS-27942 --
				КонецЕсли;
				// IMAPPS-24661--
				
				// -- IMAPPS-24575 Чижов В.В. 02.02.2024
			КонецЕсли;
			// -- IMAPPS-24495 Чижов В.В. 30.01.2024
			
			// TM-3342 {
			Если НЕ НоваяСделка.Актив.Пустая() И НЕ НоваяСделка.Брокер.Пустая() И НЕ ПустаяСтрока(НоваяСделка.ПлатежныеУсловия) Тогда
				ПлатежныеУсловия = Неопределено;
				Если НоваяСделка.ПлатежныеУсловия = "FOP" ИЛИ НоваяСделка.ПлатежныеУсловия = "PREPAYMENT" ИЛИ НоваяСделка.ПлатежныеУсловия = "POSTPAY" Тогда
					ПлатежныеУсловия = FOT;
				ИначеЕсли НоваяСделка.ПлатежныеУсловия = "DVP" Тогда
					ПлатежныеУсловия = DVP;
				КонецЕсли;
				
				InstrumentType = InstrumentType(НоваяСделка.Актив, ОбъектАктива, СписокГруппВидовАктивовДляОпределенияInstrumentType, СписокInstrumentType);
				
				Если ПлатежныеУсловия <> Неопределено И InstrumentType <> Неопределено Тогда
					// MPazhukov IMAPPS-8887 23.08.2019
					//НоваяСделка.РеквизитыДляРасчетовПоЦБ = ДепозитарнаяИнструкцияСсылка(InstrumentType, НоваяСделка.Брокер, ПлатежныеУсловия, СвойствоInstrumentType,НоваяСделка.ДатаСделки);
					Если СтрНайти(ТекСделка.КодКлиента, "_NSD_") Тогда
						НоваяСделка.РеквизитыДляРасчетовПоЦБ = ДепозитарнаяИнструкцияСсылка(InstrumentType, НоваяСделка.Брокер, ПлатежныеУсловия, СвойствоInstrumentType, НоваяСделка.ДатаСделки, ПолучитьНРД());
					Иначе
						НоваяСделка.РеквизитыДляРасчетовПоЦБ = ДепозитарнаяИнструкцияСсылка(InstrumentType, НоваяСделка.Брокер, ПлатежныеУсловия, СвойствоInstrumentType, НоваяСделка.ДатаСделки);
					КонецЕсли;
					// MPazhukov IMAPPS-8887 23.08.2019
				КонецЕсли;
			КонецЕсли;
			
			Если НЕ НоваяСделка.Брокер.Пустая() И НЕ НоваяСделка.Продажа И ТекСделка.РежимТоргов = "OTC" И ПлатежныеУсловия <> DVP Тогда
				НоваяСделка.СчетПолучателя = ПолучитьСчетПолучателя(НоваяСделка.Брокер, НоваяСделка.ВалютаСделки)
			КонецЕсли;
			// MPazhukov IMAPPS-12921
			Если (
				Найти(ТекСделка.РежимТоргов, "EQRD") > 0
				ИЛИ Найти(ТекСделка.РежимТоргов, "EQRP") > 0
				ИЛИ Найти(ТекСделка.РежимТоргов, "EQRE") > 0
				ИЛИ Найти(ТекСделка.РежимТоргов, "EQWP") > 0
				ИЛИ Найти(ТекСделка.РежимТоргов, "EQWD") > 0
				ИЛИ Найти(ТекСделка.РежимТоргов, "EQWE") > 0
				ИЛИ ЭтоРЕПО_КСУ(ТекСделка.РежимТоргов) // IMAPPS-15992
				) Тогда
				// +Artur Mingalev 27.07.2021 IMAPPS-14187 Обороты по коду клиента ТекДоговорДУ вместо ТекСделка.КодКлиента
				НоваяСделка.ОборотПоРЕПО = ОборотыПоРЕПО.Получить(ТекСделка.КодКлиента);
				// -Artur Mingalev 27.07.2021 IMAPPS-14187
			КонецЕсли;
			// MPazhukov IMAPPS-12921
			СтруктураДопСведенияАктивов = ПолучитьИзКэшаДопСведенияАктива(ОбъектАктива);
			СтруктураДопСведенияБрокер = ПолучитьИзКэшаДопСведенияБрокера(НоваяСделка.Брокер);
			Если СтруктураДопСведенияАктивов.НеСчитатьКомиссиюБиржиПоСделкам
				И СтруктураДопСведенияБрокер.НеСчитатьКомиссиюБиржиПоСделкам Тогда
				НоваяСделка.КомиссияБиржи = 0;
			КонецЕсли;
			Если СтруктураДопСведенияАктивов.НеСчитатьКомиссиюБрокераПоСделкам
				И СтруктураДопСведенияБрокер.НеСчитатьКомиссиюБрокераПоСделкам Тогда
				НоваяСделка.КомиссияБрокера = 0;
			Иначе
				// ++ IMAPPS-24575 Чижов В.В. 06.02.2024
				КурсВалютыСделки = НоваяСделка.КурсВалютыСделки;
				Если НоваяСделка.ВалютаСделки = НоваяСделка.ВалютаКомисcииБрокера Тогда
					НоваяСделка.КурсВалютыСделки = 1;
				КонецЕсли;
				// -- IMAPPS-24575 Чижов В.В. 06.02.2024
				//////////////////////////////////////////////РассчитатьКомиссиюБрокера(НоваяСделка, НоваяСделка.СтатусКомиссии);
				// ++ IMAPPS-24575 Чижов В.В. 06.02.2024
				НоваяСделка.КурсВалютыСделки = КурсВалютыСделки;
				// -- IMAPPS-24575 Чижов В.В. 06.02.2024
			КонецЕсли;
			
			// IMAPPS-31762 ++
			Если ДУСКомиссиейБиржи.НайтиПоЗначению(НоваяСделка.ДоговорДУ) <> Неопределено И СББрокер = НоваяСделка.Брокер Тогда
				НоваяСделка.КомиссияБиржи = ТекСделка.TSCommission;
			КонецЕсли;
			// IMAPPS-31762 --
			
		КонецЕсли;
		
	КонецЦикла;
КонецПроцедуры // ПрочитатьНаСервере()

Процедура РассчитатьКомиссиюБрокера(НоваяСделка, ТекстОшибки = "")
Если НоваяСделка.РежимТоргов.Наименование = "OTC" Тогда
Возврат;
