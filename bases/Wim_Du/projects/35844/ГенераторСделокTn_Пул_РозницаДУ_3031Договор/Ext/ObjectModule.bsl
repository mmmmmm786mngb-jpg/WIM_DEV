		СписокИндексовДляПродажи = Новый Массив;
		
		// Добавляем индексы акций для продажи (циклически, если нужно больше чем есть в пуле)
		Для Индекс = 0 По КоличествоПродажАкций - 1 Цикл
			ИндексАктиваВПуле = Индекс % ИндексыАкций.Количество();
			СписокИндексовДляПродажи.Добавить(ИндексыАкций[ИндексАктиваВПуле]);
		КонецЦикла;
		
		// Добавляем индексы облигаций для продажи
		Для Индекс = 0 По КоличествоПродажОблигаций - 1 Цикл
			ИндексАктиваВПуле = Индекс % ИндексыОблигаций.Количество();
			СписокИндексовДляПродажи.Добавить(ИндексыОблигаций[ИндексАктиваВПуле]);
		КонецЦикла;
		
		// Добавляем индексы паев для продажи
		Для Индекс = 0 По КоличествоПродажПаев - 1 Цикл
			ИндексАктиваВПуле = Индекс % ИндексыПаев.Количество();
			СписокИндексовДляПродажи.Добавить(ИндексыПаев[ИндексАктиваВПуле]);
		КонецЦикла;
		
		// Перемешиваем список для случайного порядка продаж (алгоритм Фишера-Йетса)
		КоличествоЭлементов = СписокИндексовДляПродажи.Количество();
		Для Индекс = 0 По КоличествоЭлементов - 1 Цикл
			ОбратныйИндекс = КоличествоЭлементов - 1 - Индекс;
			СлучайныйИндекс = СлучайноеЧисло(0, ОбратныйИндекс);
			ВременноеЗначение = СписокИндексовДляПродажи[СлучайныйИндекс];
			СписокИндексовДляПродажи[СлучайныйИндекс] = СписокИндексовДляПродажи[ОбратныйИндекс];
			СписокИндексовДляПродажи[ОбратныйИндекс] = ВременноеЗначение;
		КонецЦикла;
		
		// Генерируем 70 сделок продажи с пропорциональным распределением   !!! 23 СДЕЛКИ !!!
		Для ИндексСделки = 0 По СписокИндексовДляПродажи.Количество() - 1 Цикл
			
			ИндексАктива = СписокИндексовДляПродажи[ИндексСделки];
			АктивИзПула = ПулАктивов[ИндексАктива];
			
			// Генерируем уникальный номер сделки
			НомерСделки = "";
			Повтор = Истина;
			Пока Повтор Цикл
				СлучайноеЧислоВДиапазоне = СлучайноеЧисло(4000000000, 4100000000);
				НомерСделки = "9" + Формат(СлучайноеЧислоВДиапазоне, "ЧЦ=10; ЧГ=");
				Если УникальныеНомераСделок.Получить(НомерСделки) = Неопределено Тогда
					УникальныеНомераСделок.Вставить(НомерСделки, Истина);
					Повтор = Ложь;
				КонецЕсли;
			КонецЦикла;
			
			НоваяСтрока = ТаблицаСделок.Добавить();
			НоваяСтрока.ДоговорДУ = ДоговорДУ;
			НоваяСтрока.ТорговыйКодПоКодуБезДеталей = ТорговыйКодПоКодуБезДеталей;
			НоваяСтрока.КодКлиента = КодКлиента;
			НоваяСтрока.Актив = АктивИзПула;
			НоваяСтрока.Биржа = СтруктураБиржи;
			НоваяСтрока.ТипСделки = "продажа";
			НоваяСтрока.ДатаСделки = ДатаНачала;
			НоваяСтрока.ВремяСделки = Дата("00010101180000");
			НоваяСтрока.НомерСделки = НомерСделки;
			НоваяСтрока.Количество = 1;
			НоваяСтрока.Цена = 2;
			НоваяСтрока.Сумма = 2;
			НоваяСтрока.НКД = 0;
			НоваяСтрока.КомиссияБиржи = 0;
			НоваяСтрока.КомиссияТС = 0;
			НоваяСтрока.КомиссияБрокера = 0;
			
			// Определяем режим торгов по типу актива
			Если АктивИзПула.ВидАктива = "Акция" Тогда
				НоваяСтрока.РежимТоргов = "TQBR";
			ИначеЕсли АктивИзПула.ВидАктива = "Облигация" Тогда
				НоваяСтрока.РежимТоргов = "TQCB";
			ИначеЕсли АктивИзПула.ВидАктива = "Пай" Тогда
				НоваяСтрока.РежимТоргов = "TQTF_W";
			КонецЕсли;
			
			НоваяСтрока.РежимT_n = "";
			НоваяСтрока.ВалютаСделки = "SUR";
			НоваяСтрока.КурсВалютыСделки = 0;
			НоваяСтрока.КратностьВалютыСделки = 0;
			НоваяСтрока.ДатаРасчетов = ДатаРасчетов;
			НоваяСтрока.ДатаОплаты = ДатаНачала;
			НоваяСтрока.РЕПОСрок = 0;
			НоваяСтрока.РЕПОСтавка = 0;
			НоваяСтрока.РЕПОСумма2 = 0;
			НоваяСтрока.РЕПОЦена2 = 0;
			НоваяСтрока.РЕПОНКД2 = 0;
			НоваяСтрока.РЕПОДатаРасчетов2 = ДатаНачала;
			НоваяСтрока.РЕПОДисконт = 0;
			НоваяСтрока.КодБрокера = "";
			НоваяСтрока.ОТСчерезБрокера = 1;
			НоваяСтрока.Мандата = "";
			НоваяСтрока.ПлатежныеУсловия = "";
			НоваяСтрока.ВидАктива = "ЦБ";
			НоваяСтрока.SecurityID = "0";
			НоваяСтрока.ОтметкаHTM = "";
			НоваяСтрока.Стратегия = "";
			НоваяСтрока.Статус = "";
			НоваяСтрока.FXRate = 0;
			НоваяСтрока.CmsBroker = 0;
			НоваяСтрока.komissija_birga = 0;
			НоваяСтрока.komissija_kliring = 0;
			НоваяСтрока.TSCommission = 0;
			НоваяСтрока.Комментарий = КодКлиента;
			//
			//ПРЕРВАТЬ; // !!! В РАЗРАБОТКЕ !!!
			//
		КонецЦикла;
		
	КонецЦикла;
	
	Возврат ТаблицаСделок;
	
