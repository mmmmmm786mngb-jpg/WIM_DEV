Функция СлучайноеЧисло(НижнийПредел, ВерхнийПредел)
	// Получаем текущее время в миллисекундах (уникальное значение при каждом вызове)
	ТекущееВремяМС = ТекущаяУниверсальнаяДатаВМиллисекундах();
	
	// Преобразуем в целое число для инициализации генератора
	НачальноеЧисло = Цел(ТекущееВремяМС);
	
	// Создаём генератор с инициализацией по текущему времени
	Генератор = Новый ГенераторСлучайныхЧисел(НачальноеЧисло);
	
	// Возвращаем случайное число в заданном диапазоне
	Возврат Генератор.СлучайноеЧисло(НижнийПредел, ВерхнийПредел);
КонецФункции

Функция ПолучитьМассивыАктивов(ДатаНачала) Экспорт
	
	ДатаНачалаПериода = НачалоМесяца(ДобавитьМесяц(ДатаНачала, -1));
	ДатаОкончанияПериода = КонецДня(ДатаНачала);
	
	МассивАкций = Новый Массив;
	МассивОблигаций = Новый Массив;
	МассивПаев = Новый Массив;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ДатаНачалаПериода", ДатаНачалаПериода);
	Запрос.УстановитьПараметр("ДатаОкончанияПериода", ДатаОкончанияПериода);
	
	// Запрос для акций (первые 15)
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 15
	|	СделкиTn.Актив КАК Актив,
	|	ВЫРАЗИТЬ(СделкиTn.Актив.Объект КАК Справочник.Акции).ISIN КАК ISIN
	|ИЗ
	|	БизнесПроцесс.СделкиTn КАК СделкиTn
	|ГДЕ
	|	НЕ СделкиTn.ПометкаУдаления
	|	И СделкиTn.Актив.Объект ССЫЛКА Справочник.Акции
	|	И СделкиTn.Дата >= &ДатаНачалаПериода
	|	И СделкиTn.Дата <= &ДатаОкончанияПериода
	|
	|СГРУППИРОВАТЬ ПО
	|	СделкиTn.Актив,
	|	ВЫРАЗИТЬ(СделкиTn.Актив.Объект КАК Справочник.Акции).ISIN";
	
	РезультатЗапроса = Запрос.Выполнить();
	Выборка = РезультатЗапроса.Выбрать();
	Пока Выборка.Следующий() Цикл
		Если ЗначениеЗаполнено(Выборка.ISIN) Тогда
			СтруктураАктива = Новый Структура;
			СтруктураАктива.Вставить("КодЦБнаММВБ", Выборка.ISIN);
			СтруктураАктива.Вставить("ВидАктива", "Акция");
			МассивАкций.Добавить(СтруктураАктива);
		КонецЕсли;
	КонецЦикла;
	
	// Запрос для облигаций (первые 25)
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ДатаНачалаПериода", ДатаНачалаПериода);
	Запрос.УстановитьПараметр("ДатаОкончанияПериода", ДатаОкончанияПериода);
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 25
	|	СделкиTn.Актив КАК Актив,
	|	ВЫРАЗИТЬ(СделкиTn.Актив.Объект КАК Справочник.Облигации).ISIN КАК ISIN
	|ИЗ
	|	БизнесПроцесс.СделкиTn КАК СделкиTn
	|ГДЕ
	|	НЕ СделкиTn.ПометкаУдаления
	|	И СделкиTn.Актив.Объект ССЫЛКА Справочник.Облигации
	|	И СделкиTn.Дата >= &ДатаНачалаПериода
	|	И СделкиTn.Дата <= &ДатаОкончанияПериода
	|
	|СГРУППИРОВАТЬ ПО
	|	СделкиTn.Актив,
	|	ВЫРАЗИТЬ(СделкиTn.Актив.Объект КАК Справочник.Облигации).ISIN";
	
	РезультатЗапроса = Запрос.Выполнить();
	Выборка = РезультатЗапроса.Выбрать();
	Пока Выборка.Следующий() Цикл
		Если ЗначениеЗаполнено(Выборка.ISIN) Тогда
			СтруктураАктива = Новый Структура;
			СтруктураАктива.Вставить("КодЦБнаММВБ", Выборка.ISIN);
			СтруктураАктива.Вставить("ВидАктива", "Облигация");
			МассивОблигаций.Добавить(СтруктураАктива);
		КонецЕсли;
	КонецЦикла;
	
	// Запрос для паев (первые 10)
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ДатаНачалаПериода", ДатаНачалаПериода);
	Запрос.УстановитьПараметр("ДатаОкончанияПериода", ДатаОкончанияПериода);
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 10
	|	СделкиTn.Актив КАК Актив,
	|	ВЫРАЗИТЬ(СделкиTn.Актив.Объект КАК Справочник.ПаиПИФ).ISIN КАК ISIN
	|ИЗ
	|	БизнесПроцесс.СделкиTn КАК СделкиTn
	|ГДЕ
	|	НЕ СделкиTn.ПометкаУдаления
	|	И СделкиTn.Актив.Объект ССЫЛКА Справочник.ПаиПИФ
	|	И СделкиTn.Дата >= &ДатаНачалаПериода
	|	И СделкиTn.Дата <= &ДатаОкончанияПериода
	|
	|СГРУППИРОВАТЬ ПО
	|	СделкиTn.Актив,
	|	ВЫРАЗИТЬ(СделкиTn.Актив.Объект КАК Справочник.ПаиПИФ).ISIN";
	
	РезультатЗапроса = Запрос.Выполнить();
	Выборка = РезультатЗапроса.Выбрать();
	Пока Выборка.Следующий() Цикл
		Если ЗначениеЗаполнено(Выборка.ISIN) Тогда
			СтруктураАктива = Новый Структура;
			СтруктураАктива.Вставить("КодЦБнаММВБ", Выборка.ISIN);
			СтруктураАктива.Вставить("ВидАктива", "Пай");
			МассивПаев.Добавить(СтруктураАктива);
		КонецЕсли;
	КонецЦикла;
	
	// ДОПОЛНЕНИЕ: если в массиве меньше 10 элементов — добираем из справочника ПаиПИФ
	Если МассивПаев.Количество() < 10 Тогда
		
		НеобходимоеКоличество = 10 - МассивПаев.Количество();
		
		// Собираем уже имеющиеся ISIN, чтобы исключить дубли
		УжеЕстьISIN = Новый СписокЗначений;
		Для Каждого Элемент Из МассивПаев Цикл
			УжеЕстьISIN.Добавить(Элемент.КодЦБнаММВБ);
		КонецЦикла;
		
		// Запрос к справочнику ПаиПИФ: берём НЕ помеченные на удаление, исключая уже имеющиеся ISIN
		ЗапросДополнение = Новый Запрос;
		ЗапросДополнение.Текст = "
		|ВЫБРАТЬ ПЕРВЫЕ " + Строка(НеобходимоеКоличество) + "
		|	ПаиПИФ.ISIN КАК ISIN
		|ИЗ
		|	Справочник.ПаиПИФ КАК ПаиПИФ
		|ГДЕ
		|	НЕ ПаиПИФ.ПометкаУдаления
		|	И ПаиПИФ.ISIN НЕ В (&СписокISIN)
		|	И ПаиПИФ.ISIN <> """"";
		
		ЗапросДополнение.УстановитьПараметр("СписокISIN", УжеЕстьISIN);
		
		РезультатДополнение = ЗапросДополнение.Выполнить();
		ВыборкаДополнение = РезультатДополнение.Выбрать();
		
		Пока ВыборкаДополнение.Следующий() Цикл
			СтруктураАктива = Новый Структура;
			СтруктураАктива.Вставить("КодЦБнаММВБ", ВыборкаДополнение.ISIN);
			СтруктураАктива.Вставить("ВидАктива", "Пай");
			МассивПаев.Добавить(СтруктураАктива);
		КонецЦикла;
		
	КонецЕсли;
	
	Результат = Новый Структура;
	Результат.Вставить("Акции", МассивАкций);
	Результат.Вставить("Облигации", МассивОблигаций);
	Результат.Вставить("Паи", МассивПаев);
	
	Возврат Результат;
	
КонецФункции

Функция ПолучитьСписокДоговоровДУ(ДатаНачала) Экспорт
	
	ДатаНачалаПериода = НачалоМесяца(ДобавитьМесяц(ДатаНачала, -4));
	ДатаОкончанияПериода = КонецДня(ДатаНачала);
	
	МассивДоговоров = Новый Массив;
	
	Запрос = Новый Запрос;
	//////Запрос.УстановитьПараметр("Пул", Справочники.Пул.ПустаяСсылка());
	Запрос.УстановитьПараметр("Пул", Справочники.Пул.НайтиПоНаименованию("Розничное ДУ"));       // !! РОЗНИЦА ДУ !!
	Запрос.УстановитьПараметр("ДатаНачалаПериода", ДатаНачалаПериода);
	Запрос.УстановитьПараметр("ДатаОкончанияПериода", ДатаОкончанияПериода);
	
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 3031
	|	СделкиTn.ДоговорДУ КАК ДоговорДУ,
	|	МАКСИМУМ(ТорговыеКоды.Код) КАК ТорговыеКодыКод
	|ПОМЕСТИТЬ ВТ_Договора
	|ИЗ
	|	БизнесПроцесс.СделкиTn КАК СделкиTn
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ТорговыеКоды КАК ТорговыеКоды
	|		ПО (СделкиTn.ДоговорДУ = ТорговыеКоды.ДоговорДУ)
	|			И (ТорговыеКоды.Наименование <> """")
	|			И (ТорговыеКоды.Брокер <> ЗНАЧЕНИЕ(Справочник.Контрагенты.ПустаяСсылка))
	|			И (ТорговыеКоды.ДоговорБрокера <> ЗНАЧЕНИЕ(Справочник.ДоговорыКонтрагентов.ПустаяСсылка))
	|			И (ТорговыеКоды.АналитическийСчетДС <> ЗНАЧЕНИЕ(Справочник.АналитическиеСчета.ПустаяСсылка))
	|			И (ТорговыеКоды.АналитическийСчетЦБ <> ЗНАЧЕНИЕ(Справочник.АналитическиеСчета.ПустаяСсылка))
	|ГДЕ
	|	НЕ СделкиTn.ПометкаУдаления
	|	И СделкиTn.Дата >= &ДатаНачалаПериода
	|	И СделкиTn.Дата <= &ДатаОкончанияПериода
	|	И СделкиTn.ДоговорДУ.Пул = &Пул
	|	И СделкиTn.ДоговорДУ.ДатаОкончания = ДАТАВРЕМЯ(1, 1, 1)
	|
	|СГРУППИРОВАТЬ ПО
	|	СделкиTn.ДоговорДУ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ ПЕРВЫЕ 1
	//|ВЫБРАТЬ
	|	ВТ_Договора.ДоговорДУ КАК ДоговорДУ,
	|	ТорговыеКоды.Наименование КАК КодКлиента,
	|	ТорговыеКоды.АналитическийСчетДС КАК АналитическийСчетДС,
	|	ТорговыеКоды.АналитическийСчетЦБ КАК АналитическийСчетЦБ,
	|	ТорговыеКоды.Брокер КАК Брокер,
	|	ТорговыеКоды.ДоговорБрокера КАК ДоговорБрокера
	|ИЗ
	|	ВТ_Договора КАК ВТ_Договора
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ТорговыеКоды КАК ТорговыеКоды
	|		ПО ВТ_Договора.ДоговорДУ = ТорговыеКоды.ДоговорДУ
	|			И ВТ_Договора.ТорговыеКодыКод = ТорговыеКоды.Код";
	
	
