		Для Индекс = 0 По КоличествоАктивовВПуле - 1 Цикл
			ТекАктив = ПулАктивов[Индекс];
			Если ТекАктив.ВидАктива = "Акция" Тогда
				ИндексыАкций.Добавить(Индекс);
