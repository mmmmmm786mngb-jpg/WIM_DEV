&НаСервере
Процедура ПрочитатьСделкиРЕПОНаСервере(Отказ = Ложь)
	
	ВремяНачала = ТекущаяУниверсальнаяДатаВМиллисекундах();
	
	ТекОбъект = РеквизитФормыВЗначение("Объект");
	ТекОбъект.ПрочитатьСделкиРЕПО(Отказ);
	ЗначениеВРеквизитФормы(ТекОбъект, "Объект");
	
	ВремяОкончания = ТекущаяУниверсальнаяДатаВМиллисекундах();
	
	ПрошлоВремени = ВремяОкончания - ВремяНачала;
	
	ПрошлоВремениСек = ПрошлоВремени / 1000;
	
	Часов = Цел(ПрошлоВремениСек / 3600);
	Минут = Цел((ПрошлоВремениСек - Часов * 3600) / 60);
	Секунд = ПрошлоВремениСек - Часов * 3600 - Минут * 60;
	Сообщить("Чтение выполнялось - " + Часов + ":" + Минут + ":" + Секунд);
	
	Если Отказ Тогда
		Сообщить("Во время загрузки произошли ошибки", СтатусСообщения.Важное);
	Иначе
		Сообщить("Чтение успешно завершено", СтатусСообщения.Информация);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьПартнераНаСервере()
	
	ТекОбъект = РеквизитФормыВЗначение("Объект");
	ТекОбъект.ОбновитьПартнера(Ложь);
	ЗначениеВРеквизитФормы(ТекОбъект,"Объект");
	
КонецПроцедуры

&НаСервере
Процедура СгенерироватьСделкиНаСервере()
	
	Если Не ЗначениеЗаполнено(Объект.ДатаНачала) Тогда
		ВызватьИсключение "Не заполнена дата начала";
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(Объект.ДатаОкончания) Тогда
		ВызватьИсключение "Не заполнена дата окончания";
	КонецЕсли;
	
	ВремяНачала = ТекущаяУниверсальнаяДатаВМиллисекундах();
	/////////////////////////////////////////////////////////////////////////////////////////////
	ТекОбъект = РеквизитФормыВЗначение("Объект");
	ТаблицаСделок = ТекОбъект.ТаблицаСделокГенерация(Объект.ДатаНачала, Объект.ДатаОкончания);
	ТекОбъект.ПрочитатьНаСервере(ТаблицаСделок, Ложь);
	ЗначениеВРеквизитФормы(ТекОбъект, "Объект");
	/////////////////////////////////////////////////////////////////////////////////////////////
	ВремяОкончания = ТекущаяУниверсальнаяДатаВМиллисекундах();
	
	ПрошлоВремени = ВремяОкончания - ВремяНачала;
	ПрошлоВремениСек = ПрошлоВремени / 1000;
	Часов = Цел(ПрошлоВремениСек / 3600);
	Минут = Цел((ПрошлоВремениСек - Часов * 3600) / 60);
	Секунд = ПрошлоВремениСек - Часов * 3600 - Минут * 60;
	Сообщить("Генерация входных данных выполнялось - " + Часов + ":" + Минут + ":" + Секунд);
	
КонецПроцедуры

&НаСервере
Функция НайтиДопОбработкуПоНаименованию(Наименование)
	
	Если Не ЗначениеЗаполнено(Наименование) Тогда
		Возврат Справочники.ДополнительныеОтчетыИОбработки.ПустаяСсылка();
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ДополнительныеОтчетыИОбработки.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.ДополнительныеОтчетыИОбработки КАК ДополнительныеОтчетыИОбработки
		|ГДЕ
		|	ДополнительныеОтчетыИОбработки.Наименование = &Наименование
		|	И НЕ ДополнительныеОтчетыИОбработки.ЭтоГруппа
		|	И НЕ ДополнительныеОтчетыИОбработки.ПометкаУдаления";
	
	Запрос.УстановитьПараметр("Наименование", Наименование);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда
		Возврат ВыборкаДетальныеЗаписи.Ссылка;
	Иначе
		Возврат Справочники.ДополнительныеОтчетыИОбработки.ПустаяСсылка();
	КонецЕсли;
	
КонецФункции

#КонецОбласти