////////////////////////////////////////////////////////////////////////////////
// Модуль формы внешней обработки "Генератор договоров ДУ"
//
// Назначение:
//   Обработка создаёт несколько копий одного договора ДУ по выбранному шаблону.
//   Удобно для подготовки тестовых данных или массового создания договоров с одинаковой
//   структурой: для каждой копии создаётся новый договор ДУ, копируются счета, торговые коды,
//   документ Учетная политика и сделки поступления. Код нового договора задаётся префиксом
//   и номером (например, ТТ900001, ТТ900002).
//
// Реквизиты формы (Объект):
//   ДоговорДУ_Шаблон          - СправочникСсылка.ДоговорДУ — договор, с которого копируем
//   УчетнаяПолитика_Шаблон    - ДокументСсылка.УчетнаяПолитика (подставляется при смене договора)
//   КоличествоКопий           - Число — сколько копий создать
//   НачальныйНомерКопии       - Число — с какой копии начинать нумерацию (1 = с первой)
//   Префикс                   - Строка — префикс кода новых договоров (например, ТТ)
//   ДатаУстановкиДоговоров    - Дата — дата для создаваемых документов и движений по регистрам
//
// Что делается для каждой копии (последовательно):
//   1. Создание нового ДоговорДУ с кодом Префикс + (900000 + НомерКопии)
//   2. Копирование ДоговоровКонтрагентов и АналитическихСчетов шаблона под новый договор
//   3. Копирование ТорговыеКоды с подстановкой нового договора, счетов ДС/ЦБ и заменой цифр в кодах
//   4. Создание и проведение документа Учетная политика для нового договора
//   5. Копирование документов Сделка (вид Поступление), привязка к новому договору
////////////////////////////////////////////////////////////////////////////////

#Область ОбработчикиСобытийФормы

// Описание: Устанавливает начальные значения реквизитов формы при открытии.
//
// Параметры:
//   Отказ                - Булево           - признак отказа от создания формы
//   СтандартнаяОбработка - Булево           - признак стандартной обработки события
//
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	Объект.Префикс = СгенерироватьСлучайноеСловоИзДвухБукв();
	Объект.ДатаУстановкиДоговоров = НачалоДня(ТекущаяДатаСеанса()) - 1;
КонецПроцедуры

// Описание: При изменении договора-шаблона ищет документ Учетная политика по этому договору
// и подставляет его в реквизит формы УчетнаяПолитика_Шаблон.
//
// Параметры:
//   Элемент - ЭлементУправляемойФормы - поле ввода ДоговорДУ_Шаблон
//
Процедура ДоговорДУ_ШаблонПриИзменении(Элемент)
	ПодставитьУчетнуюПолитикуПоДоговору();
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

// Описание: Запускает копирование договоров ДУ и документов Учетная политика по шаблону.
// Количество копий задается реквизитом КоличествоКопий.
//
// Параметры:
//   Команда - КомандаФормы - команда кнопки КопироватьПоШаблону
//
&НаКлиенте
Процедура КопироватьПоШаблону(Команда)
	ВыполнитьКопированиеНаСервере();
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Описание: Подставляет в реквизит формы УчетнаяПолитика_Шаблон последний по дате проведённый
// документ Учетная политика, найденный по текущему значению ДоговорДУ_Шаблон.
// Если договор не заполнен или документ не найден — реквизит очищается.
//
// Параметры: нет
//
&НаСервере
Процедура ПодставитьУчетнуюПолитикуПоДоговору()
	УчетнаяПолитика_Шаблон = Неопределено;
	Если Не ЗначениеЗаполнено(Объект.ДоговорДУ_Шаблон) Тогда
		Возврат;
	КонецЕсли;
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	УчетнаяПолитика.Ссылка КАК Ссылка
		|ИЗ
		|	Документ.УчетнаяПолитика КАК УчетнаяПолитика
		|ГДЕ
		|	УчетнаяПолитика.ДоговорДУ = &ДоговорДУ
		|	И УчетнаяПолитика.Проведен = ИСТИНА
		|	И УчетнаяПолитика.Дата <= &ТекущаяДата
		|УПОРЯДОЧИТЬ ПО
		|	УчетнаяПолитика.Дата УБЫВ";
	Запрос.УстановитьПараметр("ТекущаяДата", НачалоДня(ТекущаяДатаСеанса()));
	Запрос.УстановитьПараметр("ДоговорДУ", Объект.ДоговорДУ_Шаблон);
	Результат = Запрос.Выполнить();
	Если Не Результат.Пустой() Тогда
		Выборка = Результат.Выбрать();
		Выборка.Следующий();
		УчетнаяПолитика_Шаблон = Выборка.Ссылка;
	КонецЕсли;
КонецПроцедуры

// Описание: Создаёт заданное количество копий договора ДУ по шаблону с копированием
// АналитическихСчетов, ДоговоровКонтрагентов, ТорговыеКоды, документов Учетная политика
// и Сделок (вид операции Поступление). Код нового договора: Префикс + (900000 + НомерКопии).
// В конце выводит итог и время выполнения.
//
// Параметры: нет
//
&НаСервере
Процедура ВыполнитьКопированиеНаСервере()
	ВремяНачала = ТекущаяУниверсальнаяДатаВМиллисекундах();
	
	Если Не ЗначениеЗаполнено(Объект.ДоговорДУ_Шаблон) Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Укажите договор ДУ - шаблон.");
		Возврат;
	КонецЕсли;
	Если Не ЗначениеЗаполнено(Объект.УчетнаяПолитика_Шаблон) Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(
			"Не найден документ Учетная политика по выбранному договору. "
			+ "Укажите шаблон или выберите договор с проведенной учетной политикой.");
		Возврат;
	КонецЕсли;
	ШаблонДоговор = Объект.ДоговорДУ_Шаблон.ПолучитьОбъект();
	Если ШаблонДоговор = Неопределено Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не удалось прочитать объект договора-шаблона.");
		Возврат;
	КонецЕсли;
	ШаблонУчетнаяПолитика = Объект.УчетнаяПолитика_Шаблон.ПолучитьОбъект();
	Если ШаблонУчетнаяПолитика = Неопределено Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не удалось прочитать объект документа Учетная политика - шаблон.");
		Возврат;
	КонецЕсли;
	ДатаУстановки = ?(ЗначениеЗаполнено(Объект.ДатаУстановкиДоговоров),
		НачалоДня(Объект.ДатаУстановкиДоговоров),
		НачалоДня(ТекущаяДатаСеанса()));
	КолКопий = ?(Объект.КоличествоКопий > 0, Объект.КоличествоКопий, 1);
	// Запоминаем код договора-шаблона для замены в наименовании и префиксе новых договоров
	КодШаблона = СокрЛП(ШаблонДоговор.Код);
	СозданоДоговоров = 0;
	СозданоДокументов = 0;
	НачНомер = Объект.НачальныйНомерКопии;
	Для НомерКопии = 1 + (НачНомер - 1) По КолКопий + (НачНомер - 1) Цикл
		Попытка
			НовыйДоговор = СоздатьДоговорДУПоШаблону(ШаблонДоговор, НомерКопии, КодШаблона);
			Если ЗначениеЗаполнено(НовыйДоговор) Тогда
				СозданоДоговоров = СозданоДоговоров + 1;
				СкопироватьАналитическиеСчета(НовыйДоговор, КодШаблона);
				НовыйДокумент = СоздатьУчетнуюПолитикуПоШаблону(ШаблонУчетнаяПолитика, НовыйДоговор, ДатаУстановки);
				Если НовыйДокумент <> Неопределено Тогда
					СозданоДокументов = СозданоДокументов + 1;
				КонецЕсли;
				СкопироватьСделкиПоступления(НовыйДоговор);
			КонецЕсли;
		Исключение
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(
				"Ошибка при создании копии " + НомерКопии + ": " + ОписаниеОшибки());
		КонецПопытки;
	КонецЦикла;
	ОбщегоНазначенияКлиентСервер.СообщитьПользователю(
		"Создано договоров: " + СозданоДоговоров + ", документов Учетная политика: " + СозданоДокументов + ".");
	
	ВремяКонца = ТекущаяУниверсальнаяДатаВМиллисекундах();
	ВремяВыполнения = ВремяКонца - ВремяНачала; // результат в миллисекундах
	// Преобразуем миллисекунды в секунды (1 секунда = 1000 миллисекунд)
	ВремяВыполненияСек = ВремяВыполнения / 1000;
	ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Операция выполнена за " + ВремяВыполненияСек + " с");
	
КонецПроцедуры

// Описание: Создает новый элемент справочника ДоговорДУ по шаблону.
// Код нового договора: Префикс + (900000 + НомерКопии), например ТТ900001.
// Наименование и поле Префикс: код шаблона заменяется новым кодом через СтрЗаменить.
//
// Параметры:
//   ШаблонДоговор - СправочникОбъект.ДоговорДУ - объект договора-шаблона
//   НомерКопии    - Число                       - порядковый номер копии в цикле
//   КодШаблона    - Строка                      - код договора-шаблона для замены в строковых полях
//
// Возвращаемое значение:
//   СправочникСсылка.ДоговорДУ - ссылка на созданный договор
//
&НаСервере
Функция СоздатьДоговорДУПоШаблону(ШаблонДоговор, НомерКопии, КодШаблона)
	НовыйДоговор = Справочники.ДоговорДУ.СоздатьЭлемент();
	ЗаполнитьЗначенияСвойств(НовыйДоговор, ШаблонДоговор, , "Владелец, Ссылка, Код, ПометкаУдаления, Родитель");
	// Новый код: Префикс + (900000 + порядковый номер), например ТТ900001
	НовыйКод = СокрЛП(Объект.Префикс) + Формат(900000 + НомерКопии, "ЧГ=0");
	НовыйДоговор.Код = НовыйКод;
	НовыйДоговор.Наименование = СтрЗаменить(СокрЛП(ШаблонДоговор.Наименование), КодШаблона, НовыйКод);
	Если ЗначениеЗаполнено(ШаблонДоговор.Префикс) Тогда
		НовыйДоговор.Префикс = СтрЗаменить(СокрЛП(ШаблонДоговор.Префикс), КодШаблона, НовыйКод);
	КонецЕсли;
	НовыйДоговор.Записать();
	Возврат НовыйДоговор.Ссылка;
КонецФункции

// Описание: Создает и проводит документ Учетная политика по шаблону для указанного договора ДУ.
//
// Параметры:
//   ШаблонУчетнаяПолитика - ДокументОбъект.УчетнаяПолитика - объект документа-шаблона
//   НовыйДоговор          - СправочникСсылка.ДоговорДУ     - договор для новой учетной политики
//   ДатаУстановки         - Дата                           - дата документа и период для движений по регистрам
//
// Возвращаемое значение:
//   ДокументСсылка.УчетнаяПолитика - ссылка на созданный документ (проведенный или только записанный)
//
&НаСервере
Функция СоздатьУчетнуюПолитикуПоШаблону(ШаблонУчетнаяПолитика, НовыйДоговор, ДатаУстановки)
	НовыйДокумент = Документы.УчетнаяПолитика.СоздатьДокумент();
	ЗаполнитьЗначенияСвойств(НовыйДокумент, ШаблонУчетнаяПолитика, , "Номер, Ссылка");
	НовыйДокумент.ДоговорДУ = НовыйДоговор;
	Для Каждого ТабЧасть Из Метаданные.Документы.УчетнаяПолитика.ТабличныеЧасти Цикл
		НовыйДокумент[ТабЧасть.Имя].Загрузить(ШаблонУчетнаяПолитика[ТабЧасть.Имя].Выгрузить());
	КонецЦикла;
	НовыйДокумент.Записать(РежимЗаписиДокумента.Запись);
	Попытка
		НовыйДокумент.Записать(РежимЗаписиДокумента.Проведение);
	Исключение
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(
			"Документ Учетная политика создан, но не проведен: " + ОписаниеОшибки());
	КонецПопытки;
	Возврат НовыйДокумент.Ссылка;
КонецФункции

// Описание: Копирует документы Сделка с видом операции Поступление по договору-шаблону
// и привязывает копии к новому договору ДУ.
//
// Параметры:
//   НовыйДоговор - СправочникСсылка.ДоговорДУ - договор, к которому привязываются скопированные сделки
//
&НаСервере
Процедура СкопироватьСделкиПоступления(НовыйДоговор)
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ ПЕРВЫЕ 2
		|	Сделка.Ссылка КАК Ссылка
		|ИЗ
		|	Документ.Сделка КАК Сделка
		|ГДЕ
		|	Сделка.Проведен
		|	И Сделка.ВидОперации = &ВидОперацииПриход
		|	И Сделка.ДоговорДУ = &ДоговорДУ
		|УПОРЯДОЧИТЬ ПО
		|	Сделка.Дата";
	Запрос.УстановитьПараметр("ВидОперацииПриход", Перечисления.ВидыОперацийСделка.Поступление);
	Запрос.УстановитьПараметр("ДоговорДУ", Объект.ДоговорДУ_Шаблон);
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		НовыйДокумент = Документы.Сделка.СоздатьДокумент();
		ЗаполнитьЗначенияСвойств(НовыйДокумент, Выборка.Ссылка, , "Номер, Ссылка");
		НовыйДокумент.Дата = Объект.ДатаУстановкиДоговоров;
		НовыйДокумент.ДоговорДУ = НовыйДоговор;
		Для Каждого ТабЧасть Из Метаданные.Документы.Сделка.ТабличныеЧасти Цикл
			НовыйДокумент[ТабЧасть.Имя].Загрузить(Выборка.Ссылка[ТабЧасть.Имя].Выгрузить());
		КонецЦикла;
		Попытка
			НовыйДокумент.Записать(РежимЗаписиДокумента.Проведение);
		Исключение
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(
				"Документ Сделка создан, но не проведен: " + ОписаниеОшибки());
		КонецПопытки;
	КонецЦикла;
КонецПроцедуры

// Описание: Возвращает подстроку, составленную только из цифр переданной строки (кода договора).
// Используется для замены цифровой части кода в реквизитах ТорговыеКоды.
//
// Параметры:
//   СтрокаКода - Строка - строка кода (например, ТТ900001)
//
// Возвращаемое значение:
//   Строка - только цифры (например, 900001)
//
&НаСервере
Функция ИзвлечьЦифрыИзКодаДоговора(СтрокаКода)
	Результат = "";
	Для Поз = 1 По СтрДлина(СтрокаКода) Цикл
		Символ = Сред(СтрокаКода, Поз, 1);
		КодСимвола = КодСимвола(Символ);
		Если КодСимвола >= 48 И КодСимвола <= 57 Тогда
			Результат = Результат + Символ;
		КонецЕсли;
	КонецЦикла;
	Возврат Результат;
КонецФункции

// Описание: Копирует элементы справочника АналитическиеСчета, принадлежащие договору-шаблону,
// привязывая их к новому договору ДУ. Предварительно для каждого уникального ДоговораКонтрагента
// из шаблонных счетов создаётся его копия (с тем же Владельцем-контрагентом, новым ДоговоромДУ),
// после чего строится соответствие старый→новый для подстановки в каждый скопированный счёт.
// Затем копируются элементы ТорговыеКоды с подстановкой нового ДоговораДУ, ДоговорБрокера и
// новых АналитическихСчетов (ДС/ЦБ); в ТорговыйКод и Наименование — замена только цифр кода.
//
// Параметры:
//   НовыйДоговор - СправочникСсылка.ДоговорДУ - новый договор ДУ, к которому привязываются копии
//   КодШаблона   - Строка                      - код договора-шаблона для замены в строковых полях
//
&НаСервере
Процедура СкопироватьАналитическиеСчета(НовыйДоговор, КодШаблона)
	НовыйКод = СокрЛП(НовыйДоговор.Код);
	// Шаг 1: получить все АналитическиеСчета шаблонного договора
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	АналитическиеСчета.Ссылка               КАК Ссылка,
		|	АналитическиеСчета.ДоговорКонтрагента   КАК ДоговорКонтрагента,
		|	АналитическиеСчета.СубъектМестаХранения КАК СубъектМестаХранения
		|ИЗ
		|	Справочник.АналитическиеСчета КАК АналитическиеСчета
		|ГДЕ
		|	АналитическиеСчета.ДоговорДУ = &ДоговорДУШаблон
		|	И АналитическиеСчета.ПометкаУдаления = ЛОЖЬ";
	Запрос.УстановитьПараметр("ДоговорДУШаблон", Объект.ДоговорДУ_Шаблон);
	Выборка = Запрос.Выполнить().Выбрать();
	// Шаг 2: скопировать уникальные ДоговорыКонтрагентов, построить соответствие старый→новый
	СоответствиеДоговоров = Новый Соответствие;
	Пока Выборка.Следующий() Цикл
		СтарыйДК = Выборка.ДоговорКонтрагента;
		Если Не ЗначениеЗаполнено(СтарыйДК) Тогда
			Продолжить;
		КонецЕсли;
		Если СоответствиеДоговоров[СтарыйДК] <> Неопределено Тогда
			Продолжить;
		КонецЕсли;
		ШаблонДК = СтарыйДК.ПолучитьОбъект();
		Если ШаблонДК = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		НовыйДК = Справочники.ДоговорыКонтрагентов.СоздатьЭлемент();
		// Владелец (Контрагент = СубъектМестаХранения счета) копируется как есть
		ЗаполнитьЗначенияСвойств(НовыйДК, ШаблонДК, , "Код, Ссылка, ДоговорДУ");
		НовыйДК.ДоговорДУ        = НовыйДоговор;
		НовыйДК.Наименование     = СтрЗаменить(СокрЛП(ШаблонДК.Наименование), КодШаблона, НовыйКод);
		НовыйДК.НомерДоговора    = СтрЗаменить(СокрЛП(ШаблонДК.НомерДоговора), КодШаблона, НовыйКод);
		НовыйДК.НомерСчетаДЕПО  = СтрЗаменить(СокрЛП(ШаблонДК.НомерСчетаДЕПО), КодШаблона, НовыйКод);
		НовыйДК.НаименованиеРегл = СтрЗаменить(СокрЛП(ШаблонДК.НаименованиеРегл), КодШаблона, НовыйКод);
		НовыйДК.Комментарий      = СтрЗаменить(СокрЛП(ШаблонДК.Комментарий), КодШаблона, НовыйКод);
		Попытка
			НовыйДК.Записать();
			СоответствиеДоговоров[СтарыйДК] = НовыйДК.Ссылка;
		Исключение
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(
				"Ошибка копирования ДоговораКонтрагента " + СтарыйДК + ": " + ОписаниеОшибки());
		КонецПопытки;
	КонецЦикла;
	// Шаг 3: скопировать каждый АналитическийСчет с новым ДоговоромДУ и ДоговоромКонтрагента
	Выборка.Сбросить();
	Пока Выборка.Следующий() Цикл
		ШаблонСчета = Выборка.Ссылка.ПолучитьОбъект();
		Если ШаблонСчета = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		НовыйСчет = Справочники.АналитическиеСчета.СоздатьЭлемент();
		ЗаполнитьЗначенияСвойств(НовыйСчет, ШаблонСчета, , "Код, Ссылка, Родитель, Владелец, ДоговорДУ, ДоговорКонтрагента");
		НовыйСчет.ДоговорДУ          = НовыйДоговор;
		НовыйСчет.ДоговорКонтрагента = СоответствиеДоговоров[ШаблонСчета.ДоговорКонтрагента];
		НовыйСчет.Наименование        = СтрЗаменить(СокрЛП(ШаблонСчета.Наименование), КодШаблона, НовыйКод);
		НовыйСчет.НомерСчета          = СтрЗаменить(СокрЛП(ШаблонСчета.НомерСчета), КодШаблона, НовыйКод);
		НовыйСчет.НаименованиеРаздела = СтрЗаменить(СокрЛП(ШаблонСчета.НаименованиеРаздела), КодШаблона, НовыйКод);
		НовыйСчет.Служебный           = СтрЗаменить(СокрЛП(ШаблонСчета.Служебный), КодШаблона, НовыйКод);
		НовыйСчет.Комментарий         = СтрЗаменить(СокрЛП(ШаблонСчета.Комментарий), КодШаблона, НовыйКод);
		Попытка
			НовыйСчет.Записать();
		Исключение
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(
				"Ошибка копирования АналитическогоСчета " + ШаблонСчета.Ссылка + ": " + ОписаниеОшибки());
		КонецПопытки;
	КонецЦикла;
	// Шаг 4: копирование ТорговыеКоды с подстановкой ДоговорДУ, ДоговорБрокера, АналитическийСчетДС/ЦБ и заменой цифр кода
	ЦифрыШаблона = ИзвлечьЦифрыИзКодаДоговора(КодШаблона);
	ЦифрыНовые   = ИзвлечьЦифрыИзКодаДоговора(НовыйКод);
	ЗапросТК = Новый Запрос;
	ЗапросТК.Текст =
		"ВЫБРАТЬ
		|	ТорговыеКоды.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.ТорговыеКоды КАК ТорговыеКоды
		|ГДЕ
		|	ТорговыеКоды.ДоговорДУ = &ДоговорДУШаблон
		|	И ТорговыеКоды.ПометкаУдаления = ЛОЖЬ";
	ЗапросТК.УстановитьПараметр("ДоговорДУШаблон", Объект.ДоговорДУ_Шаблон);
	ВыборкаТК = ЗапросТК.Выполнить().Выбрать();
	// Получить новые АналитическиеСчета по виду (ДенежныеСредства и ЦенныеБумаги)
	ЗапросАС = Новый Запрос;
	ЗапросАС.Текст =
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	АналитическиеСчета.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.АналитическиеСчета КАК АналитическиеСчета
		|ГДЕ
		|	АналитическиеСчета.ДоговорДУ = &НовыйДоговор
		|	И АналитическиеСчета.ВидАналитическогоСчета = &Вид
		|	И АналитическиеСчета.ПометкаУдаления = ЛОЖЬ";
	ЗапросАС.УстановитьПараметр("НовыйДоговор", НовыйДоговор);
	ЗапросАС.УстановитьПараметр("Вид", Перечисления.ВидыАналитическогоСчета.ДенежныеСредства);
	СчетДС = Неопределено;
	РезультатАС = ЗапросАС.Выполнить();
	Если Не РезультатАС.Пустой() Тогда
		ВыборкаАС = РезультатАС.Выбрать();
		ВыборкаАС.Следующий();
		СчетДС = ВыборкаАС.Ссылка;
	КонецЕсли;
	ЗапросАС.УстановитьПараметр("Вид", Перечисления.ВидыАналитическогоСчета.ЦенныеБумаги);
	СчетЦБ = Неопределено;
	РезультатАС = ЗапросАС.Выполнить();
	Если Не РезультатАС.Пустой() Тогда
		ВыборкаАС = РезультатАС.Выбрать();
		ВыборкаАС.Следующий();
		СчетЦБ = ВыборкаАС.Ссылка;
	КонецЕсли;
	Пока ВыборкаТК.Следующий() Цикл
		ШаблонТК = ВыборкаТК.Ссылка.ПолучитьОбъект();
		Если ШаблонТК = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		НовыйТК = Справочники.ТорговыеКоды.СоздатьЭлемент();
		ЗаполнитьЗначенияСвойств(НовыйТК, ШаблонТК, , "Код, Ссылка, Родитель, Владелец, ДоговорДУ, ДоговорБрокера, АналитическийСчетДС, АналитическийСчетЦБ");
		НовыйТК.ДоговорДУ           = НовыйДоговор;
		НовыйТК.ДоговорБрокера       = СоответствиеДоговоров[ШаблонТК.ДоговорБрокера];
		НовыйТК.АналитическийСчетДС = СчетДС;
		НовыйТК.АналитическийСчетЦБ = СчетЦБ;
		Если ЗначениеЗаполнено(ЦифрыШаблона) Тогда
			НовыйТК.ТорговыйКод  = СтрЗаменить(СокрЛП(ШаблонТК.ТорговыйКод), ЦифрыШаблона, ЦифрыНовые);
			НовыйТК.Наименование = СтрЗаменить(СокрЛП(ШаблонТК.Наименование), ЦифрыШаблона, ЦифрыНовые);
		Иначе
			НовыйТК.ТорговыйКод  = СокрЛП(ШаблонТК.ТорговыйКод);
			НовыйТК.Наименование = СокрЛП(ШаблонТК.Наименование);
		КонецЕсли;
		НовыйТК.СписокКодов.Загрузить(ШаблонТК.СписокКодов.Выгрузить());
		Если ЗначениеЗаполнено(ЦифрыШаблона) Тогда
			Для Каждого СтрокаТК Из НовыйТК.СписокКодов Цикл
				СтрокаТК.ТорговыйКод = СтрЗаменить(СокрЛП(СтрокаТК.ТорговыйКод), ЦифрыШаблона, ЦифрыНовые);
			КонецЦикла;
		КонецЕсли;
		Попытка
			НовыйТК.Записать();
		Исключение
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(
				"Ошибка копирования ТорговогоКода " + ШаблонТК.Ссылка + ": " + ОписаниеОшибки());
		КонецПопытки;
	КонецЦикла;
КонецПроцедуры

// Описание: Возвращает случайное слово из двух заглавных букв (русские А–Я и латинские A–Z).
// Используется для инициализации префикса кода договора при открытии формы.
//
// Параметры: нет
//
// Возвращаемое значение:
//   Строка - две заглавные буквы (например, АБ, КР, XY)
//
&НаСервере
Функция СгенерироватьСлучайноеСловоИзДвухБукв()
	Генератор = Новый ГенераторСлучайныхЧисел();
	Буквы = "АБВГДЕЁЖЗИЙКЛМНОПРСТУФХЦЧШЩЪЫЬЭЮЯABCDEFGHIJKLMNOPQRSTUVWXYZ";
	ДлинаАлфавита = СтрДлина(Буквы);
	ИндексПервойБуквы = Генератор.СлучайноеЧисло(1, ДлинаАлфавита);
	ПерваяБуква = Сред(Буквы, ИндексПервойБуквы, 1);
	ИндексВторойБуквы = Генератор.СлучайноеЧисло(1, ДлинаАлфавита);
	ВтораяБуква = Сред(Буквы, ИндексВторойБуквы, 1);
	Возврат ПерваяБуква + ВтораяБуква;
КонецФункции

#КонецОбласти
