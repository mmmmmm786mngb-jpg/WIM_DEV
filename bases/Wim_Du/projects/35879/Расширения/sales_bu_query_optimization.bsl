// Описание: Оптимизация получения ВТ_ХозрасчетныйОстатки для массового проведения сделок.
// Вместо прямого Остатки(&Период) на МоментВремени() используется расчет:
// 1) Остатки на &ПериодКонецМесяца
// 2) Минус обороты за период (&Период, &ПериодКонецМесяца]
// Реализация выполнена в одном запросе через ОБЪЕДИНИТЬ ВСЕ с отрицательными оборотами,
// затем итоговая СУММА по аналитикам (Счет, ДоговорДУ, Валюта, Субконто1, Субконто2).
// Это снижает нагрузку при массовом проведении, так как чтение идет от итогов месяца,
// а хвост оборотов обычно минимальный.
//
// Важно для встраивания:
// - В ТаблицыПоПродажам_БУ добавить параметр:
//   Запрос.УстановитьПараметр("ПериодКонецМесяца", КонецМесяца(Дата));
// - Параметр Период оставить как есть:
//   Запрос.УстановитьПараметр("Период", МоментВремени());
// - В ТекстЗапросаТаблицыПоПродажамБУ_БезНКД заменить только первый блок,
//   формирующий ВТ_ХозрасчетныйОстатки, на данный текст запроса.
// - Остальные части пакетного запроса (ВТ_ОстаткиТело, ВТ_ОстаткиПереоценка и далее) не менять.
//
Функция ТекстЗапросаВТХозрасчетныйОстаткиОптимизированный()

    Возврат
    "ВЫБРАТЬ
    |	Данные.Счет КАК Счет,
    |	Данные.ДоговорДУ КАК ДоговорДУ,
    |	Данные.Валюта КАК Валюта,
    |	Данные.Субконто1 КАК Субконто1,
    |	Данные.Субконто2 КАК Субконто2,
    |	СУММА(Данные.КоличествоОстаток) КАК КоличествоОстаток,
    |	СУММА(Данные.КоличествоОстатокДт) КАК КоличествоОстатокДт,
    |	СУММА(Данные.СуммаОстаток) КАК СуммаОстаток,
    |	СУММА(Данные.ВалютнаяСуммаОстаток) КАК ВалютнаяСуммаОстаток,
    |	СУММА(Данные.СуммаНУОстаток) КАК СуммаНУОстаток
    |ПОМЕСТИТЬ ВТ_ХозрасчетныйОстатки
    |ИЗ
    |	(ВЫБРАТЬ
    |		ХозрасчетныйОстатки.Счет КАК Счет,
    |		ХозрасчетныйОстатки.ДоговорДУ КАК ДоговорДУ,
    |		ХозрасчетныйОстатки.Валюта КАК Валюта,
    |		ХозрасчетныйОстатки.Субконто1 КАК Субконто1,
    |		ХозрасчетныйОстатки.Субконто2 КАК Субконто2,
    |		ЕСТЬNULL(ХозрасчетныйОстатки.КоличествоОстаток, 0) КАК КоличествоОстаток,
    |		ЕСТЬNULL(ХозрасчетныйОстатки.КоличествоОстатокДт, 0) КАК КоличествоОстатокДт,
    |		ЕСТЬNULL(ХозрасчетныйОстатки.СуммаОстаток, 0) КАК СуммаОстаток,
    |		ЕСТЬNULL(ХозрасчетныйОстатки.ВалютнаяСуммаОстаток, 0) КАК ВалютнаяСуммаОстаток,
    |		ЕСТЬNULL(ХозрасчетныйОстатки.СуммаНУОстатокДт, 0) КАК СуммаНУОстаток
    |	ИЗ
    |		РегистрБухгалтерии.Хозрасчетный.Остатки(
    |				&ПериодКонецМесяца,
    |				Счет В (&СчетаОстатков),
    |				,
    |				ДоговорДУ = &ДоговорДУ
    |					И Субконто1 = &АктивОбъект
    |					И Валюта = &ВалютаЦБ
    |					И ТИПЗНАЧЕНИЯ(Субконто2) <> ТИП(Документ.СделкаРЕПОПерваяНога)) КАК ХозрасчетныйОстатки
    |	
    |	ОБЪЕДИНИТЬ ВСЕ
    |	
    |	ВЫБРАТЬ
    |		ХозрасчетныйОбороты.Счет,
    |		ХозрасчетныйОбороты.ДоговорДУ,
    |		ХозрасчетныйОбороты.Валюта,
    |		ХозрасчетныйОбороты.Субконто1,
    |		ХозрасчетныйОбороты.Субконто2,
    |		-ЕСТЬNULL(ХозрасчетныйОбороты.КоличествоОборот, 0),
    |		-ЕСТЬNULL(ХозрасчетныйОбороты.КоличествоОборотДт, 0),
    |		-ЕСТЬNULL(ХозрасчетныйОбороты.СуммаОборот, 0),
    |		-ЕСТЬNULL(ХозрасчетныйОбороты.ВалютнаяСуммаОборот, 0),
    |		-ЕСТЬNULL(ХозрасчетныйОбороты.СуммаНУОборот, 0)
    |	ИЗ
    |		РегистрБухгалтерии.Хозрасчетный.Обороты(
    |				&Период,
    |				&ПериодКонецМесяца,
    |				,
    |				Счет В (&СчетаОстатков),
    |				,
    |				ДоговорДУ = &ДоговорДУ
    |					И Субконто1 = &АктивОбъект
    |					И Валюта = &ВалютаЦБ
    |					И ТИПЗНАЧЕНИЯ(Субконто2) <> ТИП(Документ.СделкаРЕПОПерваяНога),
    |				,
    |				) КАК ХозрасчетныйОбороты) КАК Данные
    |
    |СГРУППИРОВАТЬ ПО
    |	Данные.Счет,
    |	Данные.ДоговорДУ,
    |	Данные.Валюта,
    |	Данные.Субконто1,
    |	Данные.Субконто2
    |
    |ИНДЕКСИРОВАТЬ ПО
    |	Счет";

КонецФункции
