// Описание: Возвращает оптимизированный текст первого блока пакета
// ТекстЗапросаТаблицыПоПродажамБУ_БезНКД для формирования ВТ_ХозрасчетныйОстатки.
// Оптимизация: остатки берутся на конец месяца из таблицы итогов и
// корректируются на обороты хвоста периода от МоментВремени() документа.
//
// Возвращаемое значение:
// Строка - текст запроса для подстановки в пакетный запрос.
//
// Пример:
// ТекстЗапроса = SalesBUQueryOptimization.ТекстЗапросаВТХозрасчетныйОстаткиОптимизированный();
//
Функция ТекстЗапросаВТХозрасчетныйОстаткиОптимизированный() Экспорт

    Возврат
    "ВЫБРАТЬ
    |    ОстаткиНаКонец.Счет КАК Счет,
    |    ОстаткиНаКонец.ДоговорДУ КАК ДоговорДУ,
    |    ОстаткиНаКонец.Валюта КАК Валюта,
    |    ОстаткиНаКонец.Субконто1 КАК Субконто1,
    |    ОстаткиНаКонец.Субконто2 КАК Субконто2,
    |    ЕСТЬNULL(ОстаткиНаКонец.КоличествоОстаток, 0) КАК КоличествоОстаток,
    |    ЕСТЬNULL(ОстаткиНаКонец.СуммаОстаток, 0) КАК СуммаОстаток,
    |    ЕСТЬNULL(ОстаткиНаКонец.ВалютнаяСуммаОстаток, 0) КАК ВалютнаяСуммаОстаток,
    |    ЕСТЬNULL(ОстаткиНаКонец.СуммаНУОстатокДт, 0) КАК СуммаНУОстаток
    |ПОМЕСТИТЬ ВТ_ХозрасчетныйОстаткиНаКонецМесяца
    |ИЗ
    |    РегистрБухгалтерии.Хозрасчетный.Остатки(
    |            &ПериодКонецМесяца,
    |            Счет В (&СчетаОстатков),
    |            ,
    |            ДоговорДУ = &ДоговорДУ
    |                И Субконто1 = &АктивОбъект
    |                И Валюта = &ВалютаЦБ
    |                И ТИПЗНАЧЕНИЯ(Субконто2) <> ТИП(Документ.СделкаРЕПОПерваяНога)) КАК ОстаткиНаКонец
    |;
    |
    |////////////////////////////////////////////////////////////////////////////////
    |ВЫБРАТЬ
    |    ОборотыХвоста.Счет КАК Счет,
    |    ОборотыХвоста.ДоговорДУ КАК ДоговорДУ,
    |    ОборотыХвоста.Валюта КАК Валюта,
    |    ОборотыХвоста.Субконто1 КАК Субконто1,
    |    ОборотыХвоста.Субконто2 КАК Субконто2,
    |    СУММА(ЕСТЬNULL(ОборотыХвоста.КоличествоОборотДт, 0)) КАК КоличествоОборотДт,
    |    СУММА(ЕСТЬNULL(ОборотыХвоста.КоличествоОборотКт, 0)) КАК КоличествоОборотКт,
    |    СУММА(ЕСТЬNULL(ОборотыХвоста.СуммаОборотДт, 0)) КАК СуммаОборотДт,
    |    СУММА(ЕСТЬNULL(ОборотыХвоста.СуммаОборотКт, 0)) КАК СуммаОборотКт,
    |    СУММА(ЕСТЬNULL(ОборотыХвоста.ВалютнаяСуммаОборотДт, 0)) КАК ВалютнаяСуммаОборотДт,
    |    СУММА(ЕСТЬNULL(ОборотыХвоста.ВалютнаяСуммаОборотКт, 0)) КАК ВалютнаяСуммаОборотКт,
    |    СУММА(ЕСТЬNULL(ОборотыХвоста.СуммаНУОборотДт, 0)) КАК СуммаНУОборотДт,
    |    СУММА(ЕСТЬNULL(ОборотыХвоста.СуммаНУОборотКт, 0)) КАК СуммаНУОборотКт
    |ПОМЕСТИТЬ ВТ_ХозрасчетныйОборотыХвостаМесяца
    |ИЗ
    |    РегистрБухгалтерии.Хозрасчетный.Обороты(
    |            &Период,
    |            &ПериодКонецМесяца,
    |            Счет В (&СчетаОстатков),
    |            ,
    |            ДоговорДУ = &ДоговорДУ
    |                И Субконто1 = &АктивОбъект
    |                И Валюта = &ВалютаЦБ
    |                И ТИПЗНАЧЕНИЯ(Субконто2) <> ТИП(Документ.СделкаРЕПОПерваяНога)) КАК ОборотыХвоста
    |
    |СГРУППИРОВАТЬ ПО
    |    ОборотыХвоста.Счет,
    |    ОборотыХвоста.ДоговорДУ,
    |    ОборотыХвоста.Валюта,
    |    ОборотыХвоста.Субконто1,
    |    ОборотыХвоста.Субконто2
    |;
    |
    |////////////////////////////////////////////////////////////////////////////////
    |ВЫБРАТЬ
    |    ОстаткиНаКонец.Счет КАК Счет,
    |    ОстаткиНаКонец.ДоговорДУ КАК ДоговорДУ,
    |    ОстаткиНаКонец.Валюта КАК Валюта,
    |    ОстаткиНаКонец.Субконто1 КАК Субконто1,
    |    ОстаткиНаКонец.Субконто2 КАК Субконто2
    |ПОМЕСТИТЬ ВТ_КлючиХозрасчетныхОстатков
    |ИЗ
    |    ВТ_ХозрасчетныйОстаткиНаКонецМесяца КАК ОстаткиНаКонец
    |
    |ОБЪЕДИНИТЬ
    |
    |ВЫБРАТЬ
    |    ОборотыХвоста.Счет,
    |    ОборотыХвоста.ДоговорДУ,
    |    ОборотыХвоста.Валюта,
    |    ОборотыХвоста.Субконто1,
    |    ОборотыХвоста.Субконто2
    |ИЗ
    |    ВТ_ХозрасчетныйОборотыХвостаМесяца КАК ОборотыХвоста
    |
    |ИНДЕКСИРОВАТЬ ПО
    |    Счет
    |;
    |
    |////////////////////////////////////////////////////////////////////////////////
    |ВЫБРАТЬ
    |    Ключи.Счет КАК Счет,
    |    Ключи.ДоговорДУ КАК ДоговорДУ,
    |    Ключи.Валюта КАК Валюта,
    |    Ключи.Субконто1 КАК Субконто1,
    |    Ключи.Субконто2 КАК Субконто2,
    |    ЕСТЬNULL(ОстаткиНаКонец.КоличествоОстаток, 0)
    |        - (ЕСТЬNULL(ОборотыХвоста.КоличествоОборотДт, 0) - ЕСТЬNULL(ОборотыХвоста.КоличествоОборотКт, 0))
    |        КАК КоличествоОстаток,
    |    ВЫБОР
    |        КОГДА ЕСТЬNULL(ОстаткиНаКонец.КоличествоОстаток, 0)
    |            - (ЕСТЬNULL(ОборотыХвоста.КоличествоОборотДт, 0) - ЕСТЬNULL(ОборотыХвоста.КоличествоОборотКт, 0)) > 0
    |            ТОГДА ЕСТЬNULL(ОстаткиНаКонец.КоличествоОстаток, 0)
    |                - (ЕСТЬNULL(ОборотыХвоста.КоличествоОборотДт, 0) - ЕСТЬNULL(ОборотыХвоста.КоличествоОборотКт, 0))
    |        ИНАЧЕ 0
    |    КОНЕЦ КАК КоличествоОстатокДт,
    |    ЕСТЬNULL(ОстаткиНаКонец.СуммаОстаток, 0)
    |        - (ЕСТЬNULL(ОборотыХвоста.СуммаОборотДт, 0) - ЕСТЬNULL(ОборотыХвоста.СуммаОборотКт, 0))
    |        КАК СуммаОстаток,
    |    ЕСТЬNULL(ОстаткиНаКонец.ВалютнаяСуммаОстаток, 0)
    |        - (ЕСТЬNULL(ОборотыХвоста.ВалютнаяСуммаОборотДт, 0) - ЕСТЬNULL(ОборотыХвоста.ВалютнаяСуммаОборотКт, 0))
    |        КАК ВалютнаяСуммаОстаток,
    |    ЕСТЬNULL(ОстаткиНаКонец.СуммаНУОстаток, 0)
    |        - (ЕСТЬNULL(ОборотыХвоста.СуммаНУОборотДт, 0) - ЕСТЬNULL(ОборотыХвоста.СуммаНУОборотКт, 0))
    |        КАК СуммаНУОстаток
    |ПОМЕСТИТЬ ВТ_ХозрасчетныйОстатки
    |ИЗ
    |    ВТ_КлючиХозрасчетныхОстатков КАК Ключи
    |        ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ХозрасчетныйОстаткиНаКонецМесяца КАК ОстаткиНаКонец
    |        ПО Ключи.Счет = ОстаткиНаКонец.Счет
    |            И Ключи.ДоговорДУ = ОстаткиНаКонец.ДоговорДУ
    |            И Ключи.Валюта = ОстаткиНаКонец.Валюта
    |            И Ключи.Субконто1 = ОстаткиНаКонец.Субконто1
    |            И Ключи.Субконто2 = ОстаткиНаКонец.Субконто2
    |        ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ХозрасчетныйОборотыХвостаМесяца КАК ОборотыХвоста
    |        ПО Ключи.Счет = ОборотыХвоста.Счет
    |            И Ключи.ДоговорДУ = ОборотыХвоста.ДоговорДУ
    |            И Ключи.Валюта = ОборотыХвоста.Валюта
    |            И Ключи.Субконто1 = ОборотыХвоста.Субконто1
    |            И Ключи.Субконто2 = ОборотыХвоста.Субконто2
    |
    |ИНДЕКСИРОВАТЬ ПО
    |    Счет";

КонецФункции

// Описание: Устанавливает параметры оптимизированного блока запроса.
//
// Параметры:
// Запрос - Запрос - объект запроса, в который нужно добавить параметры.
// ПериодДокумента - Дата - значение МоментВремени() документа.
//
// Возвращаемое значение:
// Нет.
//
// Пример:
// УстановитьПараметрыОптимизированногоЗапроса(Запрос, МоментВремени());
//
Процедура УстановитьПараметрыОптимизированногоЗапроса(Запрос, ПериодДокумента) Экспорт

    Запрос.УстановитьПараметр("Период", ПериодДокумента);
    Запрос.УстановитьПараметр("ПериодКонецМесяца", КонецДня(КонецМесяца(ПериодДокумента)));

КонецПроцедуры
