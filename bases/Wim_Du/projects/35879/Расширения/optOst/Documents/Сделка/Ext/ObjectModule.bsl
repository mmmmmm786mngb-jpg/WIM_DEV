	|		ТОГДА ВЫРАЗИТЬ(ЕСТЬNULL(ВТ_ОстаткиТело.Партия, ВТ_ОстаткиПереоценка.Партия)    КАК Документ.ВводНачальныхОстатовПоНКД).Дата
	|	 КОГДА ТИПЗНАЧЕНИЯ(ЕСТЬNULL(ВТ_ОстаткиТело.Партия, ВТ_ОстаткиПереоценка.Партия)) = ТИП(Документ.СделкаРЕПОВтораяНога)
	|		ТОГДА ВЫРАЗИТЬ(ЕСТЬNULL(ВТ_ОстаткиТело.Партия, ВТ_ОстаткиПереоценка.Партия)    КАК Документ.СделкаРЕПОВтораяНога).Дата
	|	 КОГДА ТИПЗНАЧЕНИЯ(ЕСТЬNULL(ВТ_ОстаткиТело.Партия, ВТ_ОстаткиПереоценка.Партия)) = ТИП(Документ.ПринятиеКУчетуАктивов)
	|		ТОГДА ВЫРАЗИТЬ(ЕСТЬNULL(ВТ_ОстаткиТело.Партия, ВТ_ОстаткиПереоценка.Партия)    КАК Документ.ПринятиеКУчетуАктивов).Дата
	|	 КОГДА ТИПЗНАЧЕНИЯ(ЕСТЬNULL(ВТ_ОстаткиТело.Партия, ВТ_ОстаткиПереоценка.Партия)) = ТИП(Документ.СделкаНаСрочномРынке)
	|		ТОГДА ВЫРАЗИТЬ(ЕСТЬNULL(ВТ_ОстаткиТело.Партия, ВТ_ОстаткиПереоценка.Партия)    КАК Документ.СделкаНаСрочномРынке).Дата
	|	ИНАЧЕ ДАТАВРЕМЯ(1, 1, 1, 0, 0, 0)
	|	КОНЕЦ КАК Дата
	// IMAPPS-35879 --
	
	|ИЗ
	|	ВТ_ОстаткиТело КАК ВТ_ОстаткиТело
	|		ПОЛНОЕ СОЕДИНЕНИЕ ВТ_ОстаткиПереоценка КАК ВТ_ОстаткиПереоценка
	|		ПО ВТ_ОстаткиТело.Субконто1 = ВТ_ОстаткиПереоценка.Субконто1
	|			И ВТ_ОстаткиТело.Партия = ВТ_ОстаткиПереоценка.Партия
	|ГДЕ
	|	ЕСТЬNULL(ВТ_ОстаткиТело.КоличествоОстаток, 0) > 0
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СУММА(ВТ_ОстаткиТело.КоличествоОстаток) КАК КоличествоОстаток,
	|	ВТ_ОстаткиТело.Субконто1 КАК АктивОбъект
	|ИЗ
	|	ВТ_ОстаткиТело КАК ВТ_ОстаткиТело
	|
	|СГРУППИРОВАТЬ ПО
	|	ВТ_ОстаткиТело.Субконто1";

	Если ЭтоОблигация и БУ тогда
		
		НомераТаблиц.Вставить("ЧастичноеСписание", 				НомераТаблиц.Количество());
		
		
		ТекстЗапроса = ТекстЗапроса + ОбщегоНазначенияДУ.ТекстРазделителяЗапросовПакета();
		
		ТекстЧОП = "ВЫБРАТЬ
		|	ВТ_ХозрасчетныйОстатки.Счет КАК Счет,
		|	ВТ_ХозрасчетныйОстатки.Валюта,
		|	ВЫРАЗИТЬ(ВТ_ХозрасчетныйОстатки.Субконто1 КАК Справочник.Облигации) КАК Облигации,
		|	ВТ_ХозрасчетныйОстатки.Субконто2 КАК ПогашениеОблигаций,
		|	ВЫРАЗИТЬ(ВТ_ХозрасчетныйОстатки.Субконто1 КАК Справочник.Облигации).Эмитент КАК Эмитент,
		|	ВТ_ХозрасчетныйОстатки.СуммаОстаток,
		|	ВТ_ХозрасчетныйОстатки.ВалютнаяСуммаОстаток,
		|	ВТ_ХозрасчетныйОстатки.КоличествоОстаток
		|ИЗ
		|	ВТ_ХозрасчетныйОстатки КАК ВТ_ХозрасчетныйОстатки
		|ГДЕ
		|	ВТ_ХозрасчетныйОстатки.Счет = ЗНАЧЕНИЕ(ПланСчетов.Хозрасчетный.ЧПО)";
		
		ТекстЗапроса = ТекстЗапроса + ТекстЧОП;
	Конецесли;
	
	Если НЕ (ВнебиржеваяСделка ИЛИ ЗначениеЗаполнено(ПлановаяПозиция)) И БУ И ФлагПереоценкиСчетовБрокера = Истина Тогда
		
		НомераТаблиц.Вставить("ПереоценкаСчетовБрокера", 				НомераТаблиц.Количество());
		
		
		ТекстЗапроса = ТекстЗапроса + ОбщегоНазначенияДУ.ТекстРазделителяЗапросовПакета();
		
		ТекстПСБ = "ВЫБРАТЬ РАЗЛИЧНЫЕ
		           |	ХозрасчетныйОстатки.Счет КАК Счет,
		           |	ВЫРАЗИТЬ(ХозрасчетныйОстатки.Субконто1 КАК Справочник.Контрагенты) КАК Субконто1,
		           |	ВЫРАЗИТЬ(ХозрасчетныйОстатки.Субконто2 КАК Справочник.ДоговорыКонтрагентов) КАК Субконто2,
		           |	ХозрасчетныйОстатки.Субконто3 КАК Субконто3,
		           |	ХозрасчетныйОстатки.Валюта КАК Валюта,
		           |	ВЫБОР
		           |		КОГДА ХозрасчетныйОстатки.СуммаОстаток < 0
		           |			ТОГДА -1 * ХозрасчетныйОстатки.СуммаОстаток
		           |		ИНАЧЕ ХозрасчетныйОстатки.СуммаОстаток
		           |	КОНЕЦ КАК Сумма,
		           |	ВЫБОР
		           |		КОГДА ХозрасчетныйОстатки.ВалютнаяСуммаОстатокДт <> 0
		           |			ТОГДА ХозрасчетныйОстатки.ВалютнаяСуммаОстатокДт
		           |		ИНАЧЕ ХозрасчетныйОстатки.ВалютнаяСуммаОстатокКт
		           |	КОНЕЦ КАК ВалютнаяСумма,
		           |	ВЫБОР
		           |		КОГДА ХозрасчетныйОстатки.СуммаОстаток < 0
		           |			ТОГДА ЛОЖЬ
		           |		ИНАЧЕ ИСТИНА
		           |	КОНЕЦ КАК РасчетыПоРеализации
		           |ИЗ
		           |	РегистрБухгалтерии.Хозрасчетный.Остатки(
		           |			&Период,
		           |			Счет В (ЗНАЧЕНИЕ(ПланСчетов.Хозрасчетный.РасчетыБрокераПоСделкам), ЗНАЧЕНИЕ(ПланСчетов.Хозрасчетный.РасчетыБрокераПоСделкам55)),
		           |			,
		           |			ДоговорДУ = &ДоговорДУ
		           |				И (ВЫРАЗИТЬ(Субконто1 КАК Справочник.Контрагенты)) = &Контрагент
		           |				И (ВЫРАЗИТЬ(Субконто2 КАК Справочник.ДоговорыКонтрагентов)) = &ДоговорКонтрагента
		           |				И Субконто3 = &ФизическоеМХДС) КАК ХозрасчетныйОстатки";
		
		ТекстЗапроса = ТекстЗапроса + ТекстПСБ;
		
	КонецЕсли;
	
	Возврат ТекстЗапроса;
	
КонецФункции

// IMAPPS-35879 ++
// Описание: Возвращает фрагмент текста запроса для заполнения ВТ_ХозрасчетныйОстатки. IMAPPS-35879.
// Выбор варианта по совпадению месяца даты документа с текущим месяцем: при совпадении — оптимизированный
// (актуальные остатки + обороты), иначе — виртуальная таблица Остатки(&Период).
//
// Параметры:
// МесяцДокументаСовпадаетСТекущим - Булево - Истина, если дата документа в текущем месяце.
//
// Возвращаемое значение:
// Строка - фрагмент запроса до "ИНДЕКСИРОВАТЬ ПО Счет" (без общего хвоста).
//
Функция ПолучитьТекстФрагментаВТ_ХозрасчетныйОстатки(МесяцДокументаСовпадаетСТекущим)
	Если МесяцДокументаСовпадаетСТекущим Тогда
		Возврат "ВЫБРАТЬ
		|	Данные.Счет КАК Счет,
		|	Данные.ДоговорДУ КАК ДоговорДУ,
		|	Данные.Валюта КАК Валюта,
		|	Данные.Субконто1 КАК Субконто1,
		|	Данные.Субконто2 КАК Субконто2,
		|	СУММА(Данные.КоличествоОстаток) КАК КоличествоОстаток,
		|	СУММА(Данные.КоличествоОстатокДт) КАК КоличествоОстатокДт,
		|	СУММА(Данные.СуммаОстаток) КАК СуммаОстаток,
		|	СУММА(Данные.ВалютнаяСуммаОстаток) КАК ВалютнаяСуммаОстаток,
		|	СУММА(Данные.СуммаНУОстаток) КАК СуммаНУОстаток
		|ПОМЕСТИТЬ ВТ_ХозрасчетныйОстатки
		|ИЗ
		|	(ВЫБРАТЬ
		|		ХозрасчетныйОстатки.Счет КАК Счет,
		|		ХозрасчетныйОстатки.ДоговорДУ КАК ДоговорДУ,
		|		ХозрасчетныйОстатки.Валюта КАК Валюта,
		|		ХозрасчетныйОстатки.Субконто1 КАК Субконто1,
		|		ХозрасчетныйОстатки.Субконто2 КАК Субконто2,
		|		ХозрасчетныйОстатки.КоличествоОстаток КАК КоличествоОстаток,
		|		ХозрасчетныйОстатки.КоличествоОстатокДт КАК КоличествоОстатокДт,
		|		ХозрасчетныйОстатки.СуммаОстаток КАК СуммаОстаток,
		|		ХозрасчетныйОстатки.ВалютнаяСуммаОстаток КАК ВалютнаяСуммаОстаток,
		|		ХозрасчетныйОстатки.СуммаНУОстатокДт КАК СуммаНУОстаток
		|	ИЗ
		|		РегистрБухгалтерии.Хозрасчетный.Остатки(
		|				,
		|				Счет В (&СчетаОстатков),
		|				,
		|				ДоговорДУ = &ДоговорДУ
		|					И Субконто1 = &АктивОбъект
		|					И Валюта = &ВалютаЦБ
		|					И ТИПЗНАЧЕНИЯ(Субконто2) <> ТИП(Документ.СделкаРЕПОПерваяНога)) КАК ХозрасчетныйОстатки
		|
		|	ОБЪЕДИНИТЬ ВСЕ
		|
		|	ВЫБРАТЬ
		|		ХозрасчетныйОбороты.Счет,
		|		ХозрасчетныйОбороты.ДоговорДУ,
		|		ХозрасчетныйОбороты.Валюта,
		|		ХозрасчетныйОбороты.Субконто1,
		|		ХозрасчетныйОбороты.Субконто2,
		|		-ХозрасчетныйОбороты.КоличествоОборот,
		|		-ХозрасчетныйОбороты.КоличествоОборотДт,
		|		-ХозрасчетныйОбороты.СуммаОборот,
		|		-ХозрасчетныйОбороты.ВалютнаяСуммаОборот,
		|		-ХозрасчетныйОбороты.СуммаНУОборот
		|	ИЗ
		|		РегистрБухгалтерии.Хозрасчетный.Обороты(
		|				&Период,
		|				,
		|				,
		|				Счет В (&СчетаОстатков),
		|				,
		|				ДоговорДУ = &ДоговорДУ
		|					И Субконто1 = &АктивОбъект
		|					И Валюта = &ВалютаЦБ
		|					И ТИПЗНАЧЕНИЯ(Субконто2) <> ТИП(Документ.СделкаРЕПОПерваяНога),
		|				,
		|				) КАК ХозрасчетныйОбороты) КАК Данные
		|
		|СГРУППИРОВАТЬ ПО
		|	Данные.Счет,
		|	Данные.ДоговорДУ,
		|	Данные.Валюта,
		|	Данные.Субконто1,
		|	Данные.Субконто2
		|";
	Иначе
		Возврат "ВЫБРАТЬ
		|	ХозрасчетныйОстатки.Счет КАК Счет,
		|	ХозрасчетныйОстатки.ДоговорДУ,
		|	ХозрасчетныйОстатки.Валюта,
		|	ХозрасчетныйОстатки.Субконто1,
		|	ХозрасчетныйОстатки.Субконто2,
		|	ЕСТЬNULL(ХозрасчетныйОстатки.КоличествоОстаток, 0) КАК КоличествоОстаток,
		|	ХозрасчетныйОстатки.КоличествоОстатокДт,
		|	ХозрасчетныйОстатки.СуммаОстаток,
		|	ХозрасчетныйОстатки.ВалютнаяСуммаОстаток,
		|	ХозрасчетныйОстатки.СуммаНУОстатокДт КАК СуммаНУОстаток
		|ПОМЕСТИТЬ ВТ_ХозрасчетныйОстатки
		|ИЗ
		|	РегистрБухгалтерии.Хозрасчетный.Остатки(
		|			&Период,
		|			Счет В (&СчетаОстатков),
		|			,
		|			ДоговорДУ = &ДоговорДУ
		|				И Субконто1 = &АктивОбъект
		|				И Валюта = &ВалютаЦБ
		|				И ТИПЗНАЧЕНИЯ(Субконто2) <> ТИП(Документ.СделкаРЕПОПерваяНога)) КАК ХозрасчетныйОстатки";
	КонецЕсли;
КонецФункции
// IMAPPS-35879 --


