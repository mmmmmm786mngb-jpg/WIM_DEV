
&Вместо("ТекстЗапросаТаблицыПоПродажамБУ_БезНКД")
Функция optOst_ТекстЗапросаТаблицыПоПродажамБУ_БезНКД(НомераТаблиц)
	
	НомераТаблиц.Вставить("ВТ_ХозрасчетныйОстатки"         , НомераТаблиц.Количество());
	НомераТаблиц.Вставить("ВТ_ОстаткиТело"                 , НомераТаблиц.Количество());
	НомераТаблиц.Вставить("ВТ_ОстаткиПереоценка"           , НомераТаблиц.Количество());
	НомераТаблиц.Вставить("ВременнаяТаблицаАктивы"		   , НомераТаблиц.Количество());
	НомераТаблиц.Вставить("СписаниеАктивовТаблицаАктивы"   , НомераТаблиц.Количество());
	НомераТаблиц.Вставить("СписаниеАктивовОстатки"         , НомераТаблиц.Количество());
	НомераТаблиц.Вставить("СписаниеАктивовПереоценка"      , НомераТаблиц.Количество());
	НомераТаблиц.Вставить("КоличествоВсего"				   , НомераТаблиц.Количество());
	// IMAPPS-35879 ++
	МесяцДокументаСовпадаетСТекущим = (НачалоМесяца(Дата) = НачалоМесяца(ТекущаяДатаСеанса()));
	ТекстЗапроса = ПолучитьТекстФрагментаВТ_ХозрасчетныйОстатки(МесяцДокументаСовпадаетСТекущим) +
