Функция СправкаРасчет(ПоказателиСправки)
	ТабДокументШапка = Новый ТабличныйДокумент;
	ТабДокументТело  = Новый ТабличныйДокумент;
	ТабДокументПодвал  = Новый ТабличныйДокумент;
	
	Макет = ПолучитьМакет("СправкаРасчет");
	ОбластьЗаголовок  = Макет.ПолучитьОбласть("Заголовок");
	ОбластьЗаголовок1 = Макет.ПолучитьОбласть("Заголовок1");
	// IMAPPS-35720: новый макет содержит дополнительную секцию методики платы за управление.
	ОбластьЗаголовок2 = Макет.ПолучитьОбласть("Заголовок2");
	ОбластьТело       = Макет.ПолучитьОбласть("ТелоРасчета");
	ОбластьПодвал     = Макет.ПолучитьОбласть("Подвал");
	ОбластьПодвал1    = Макет.ПолучитьОбласть("Подвал1");
	// IMAPPS-35720: новый макет содержит дополнительный блок подписей Подвал2.
	ОбластьПодвал2    = Макет.ПолучитьОбласть("Подвал2");
	
	ОбластьЗаголовок.Параметры.ДатаНомерДоговораДУ = "№"+ПоказателиСправки.НомерДоговораДУ+ " от "+Формат(ПоказателиСправки.ДатаДоговораДУ, "ДФ='dd MMMM yyyy'")+"г.";
	ТабДокументШапка.Вывести(ОбластьЗаголовок);
	
	ОбластьЗаголовок1.Параметры.ПериодРасчета = "за период управления с "+ Формат(ПоказателиСправки.НачалоРасчета, "ДФ='dd MMMM yyyy'")+"г." + " по "+Формат(ПоказателиСправки.ОкончаниеРасчета, "ДФ='dd MMMM yyyy'")+"г.";
	ТабДокументТело.Вывести(ОбластьЗаголовок1);
	
	ЗаполнитьЗначенияСвойств(ОбластьТело.Параметры, ПоказателиСправки);
	ТабДокументТело.Вывести(ОбластьТело);
	
	ТекстИтога = "Вознаграждение управляющего за успех за период с "+Формат(ПоказателиСправки.НачалоРасчета, "ДФ=dd.MM.yyyy")+" г. по "+Формат(ПоказателиСправки.ОкончаниеРасчета, "ДФ=dd.MM.yyyy")+" г., НДС не облагается, составило:";
	СуммаИтог = Формат(ПоказателиСправки.П023, "ЧДЦ=2; ЧН=0,00") + " (" + РаботаСКурсамиВалют.СформироватьСуммуПрописью(ОКР(ПоказателиСправки.П023, 2), Константы.ВалютаРегламентированногоУчета.Получить(), ЛОЖЬ) + ")";
	
	ОбластьПодвал1.Параметры.ТекстИтог = ТекстИтога;
	ОбластьПодвал1.Параметры.СуммаИтог = СуммаИтог;
	ТабДокументТело.Вывести(ОбластьПодвал1);
	
	ОбластьПодвал.Параметры.Клиент      = "Клиент: "     +ПоказателиСправки.ДоговорДУ.Клиент.НаименованиеПолное;
	ОбластьПодвал.Параметры.Управляющий = "Управляющий: "+ СокрЛП(ПоказателиСправки.ДоговорДУ.УправляющаяКомпания.НаименованиеПолное)
	+ Символы.ПС + ПолучитьПодписанта(ПоказателиСправки.ДоговорДУ.УправляющаяКомпания);
	ТабДокументПодвал.Вывести(ОбластьПодвал);
	
	// IMAPPS-35720: заполняем и выводим новую секцию "Заголовок2" (плата за управление) из корректного макета.
	Если ОбластьЗаголовок2.Параметры.Свойство("ПериодРасчета") Тогда
		ОбластьЗаголовок2.Параметры.ПериодРасчета = "за период управления с "
			+ Формат(ПоказателиСправки.НачалоРасчета, "ДФ='dd MMMM yyyy'") + "г."
			+ " по " + Формат(ПоказателиСправки.ОкончаниеРасчета, "ДФ='dd MMMM yyyy'") + "г.";
	КонецЕсли;
	Если ОбластьЗаголовок2.Параметры.Свойство("ПлатаЗаУправление") Тогда
		ОбластьЗаголовок2.Параметры.ПлатаЗаУправление = Формат(ПоказателиСправки.П000, "ЧДЦ=2; ЧН=0,00");
	КонецЕсли;
	Если ОбластьЗаголовок2.Параметры.Свойство("П000") Тогда
		// IMAPPS-35720: для совместимости с обновленным макетом дублируем сумму MF и в параметр П000.
		ОбластьЗаголовок2.Параметры.П000 = ПоказателиСправки.П000;
	КонецЕсли;
	ТабДокументПодвал.Вывести(ОбластьЗаголовок2);
	
	// IMAPPS-35720: выводим новый нижний блок подписей "Подвал2".
	ТабДокументПодвал.Вывести(ОбластьПодвал2);
	
	Если ПоказателиСправки.СтруктураСЧА.ТаблицаСЧА_РСА.Количество() > 0 тогда
		ОбластьШапкаРасшифровкаСЧА = Макет.ПолучитьОбласть("ШапкаРасшифровкиСЧА");
        ОбластьСтрокаРасшифровкаСЧА = Макет.ПолучитьОбласть("СтрокаРасшифровкиСЧА");
		ОбластьПодвалСЧА = Макет.ПолучитьОбласть("ПодвалСЧА");

		ТабДокументПодвал.ВывестиГоризонтальныйРазделительСтраниц();
		ОбластьШапкаРасшифровкаСЧА.Параметры.Клиент 		= ПоказателиСправки.ДоговорДУ.Клиент.НаименованиеПолное;
		ОбластьШапкаРасшифровкаСЧА.Параметры.ДатаНач 		= Формат(ПоказателиСправки.НачалоРасчета, "ДФ=dd.MM.yyyy"); 
		ОбластьШапкаРасшифровкаСЧА.Параметры.ДатаКон 		= Формат(ПоказателиСправки.ОкончаниеРасчета, "ДФ=dd.MM.yyyy");  
		ОбластьШапкаРасшифровкаСЧА.Параметры.ВалютаРасчета 	= ОбщегоНазначенияДУ.ВалютаРеглУчета(ПоказателиСправки.ДоговорДУ);
        ТабДокументПодвал.Вывести(ОбластьШапкаРасшифровкаСЧА);
		ИтогоСча = 0;                       
		Для каждого стр из ПоказателиСправки.СтруктураСЧА.ТаблицаСЧА_РСА Цикл
			ОбластьСтрокаРасшифровкаСЧА.Параметры.ДатаСЧА= "Стоимость чистых активов на " + Формат(стр.Дата, "ДФ=dd.MM.yyyy");
			ОбластьСтрокаРасшифровкаСЧА.Параметры.Сумма= стр.СЧА;
			ТабДокументПодвал.Вывести(ОбластьСтрокаРасшифровкаСЧА);

			ИтогоСча = ИтогоСча + стр.СЧА;
		КонецЦикла;
		ОбластьПодвалСЧА.Параметры.СуммаСЧА = ИтогоСча;
		ОбластьПодвалСЧА.Параметры.КоличествоДней = ПоказателиСправки.СтруктураСЧА.КоличествоДней;
		// IMAPPS-35720: в новом макете параметр называется "СЧА".
		ОбластьПодвалСЧА.Параметры.СЧА = Формат(ПоказателиСправки.СтруктураСЧА.СЧА,"ЧДЦ=2");
		ТабДокументПодвал.Вывести(ОбластьПодвалСЧА);

		
	КонецЕсли;

	
	Возврат Новый ХранилищеЗначения(Новый Структура("ШапкаРасчет, ТелоРасчет, ПодвалРасчет, НачалоПериода, ОкончаниеПериода", ТабДокументШапка, ТабДокументТело, ТабДокументПодвал, ПоказателиСправки.НачалоРасчета, ПоказателиСправки.ОкончаниеРасчета)); 
	
КонецФункции

Функция ИнвестиционныйДоход_Базовый(СтруктураПараметров)
	//ДатаНачалаРасчета = НачалоГода(СтруктураПараметров.Дата)-1;
	//ДатаНачалаРасчета = ?(СтруктураПараметров.ДатаНачалаДУ>(ДатаНачалаРасчета), СтруктураПараметров.ДатаНачалаДУ, ДатаНачалаРасчета);
	//
	//ДатаОкончанияРасчета = КонецГода(СтруктураПараметров.Дата);
	//ДатаОкончанияРасчета = ?(ЗначениеЗаполнено(СтруктураПараметров.ДатаОкончанияДУ) и СтруктураПараметров.ДатаОкончанияДУ<ДатаОкончанияРасчета, СтруктураПараметров.ДатаОкончанияДУ, ДатаОкончанияРасчета);
	
	//СтруктураРасчетаБазовойРСА = РасчетБазовойРСА(СтруктураПараметров);
	//Kmusorin  IMAPPS-7198
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗЛИЧНЫЕ ПЕРВЫЕ 1
	|	РегистрБРСАСрезПоследних.Период,
	|	РегистрБРСАСрезПоследних.БРСА
	|ИЗ
	|	РегистрСведений.РегистрБРСА.СрезПоследних(&Период, ДоговорДУ = &ДоговорДУ) КАК РегистрБРСАСрезПоследних";
	
	Запрос.УстановитьПараметр("Период", СтруктураПараметров.ДатаНачалаРасчета);
	Запрос.УстановитьПараметр("ДоговорДУ", СтруктураПараметров.ДоговорДУ);
	
	Выборка = Запрос.Выполнить().Выбрать();
	БазоваяРСА = 0;
	Если Выборка.Следующий() Тогда
		Если НЕ ЗначениеЗаполнено(СтруктураПараметров.ДоговорДУ.ДатаВозобновленияУправления) ИЛИ Выборка.Период > СтруктураПараметров.ДоговорДУ.ДатаВозобновленияУправления Тогда
			БазоваяРСА =РегистрыСведений.РегистрБРСА.ЗначенияБРСА(СтруктураПараметров.ДатаНачалаРасчета, СтруктураПараметров.ДоговорДУ);
		КонецЕсли;
	 
	КонецЕсли; 
	//Kmusorin  IMAPPS-7198	
	//РСА_Начало    = СтруктураРасчетаБазовойРСА.БазоваяРСА;
	РСА_Окончание = РегистрыСведений.РегистрРСА_СЧА.ЗначенияСЧА_РСА(СтруктураПараметров.ДатаОкончанияРасчета, СтруктураПараметров.ДоговорДУ).СЧА;
	
	ПараметрыДСиЦБсИП = Новый Структура;
	//Kmusorin  IMAPPS-7198	
	//ПараметрыДСиЦБсИП.Вставить("ДатаНачала", СтруктураПараметров.ДатаНачалаРасчета+1);
	ПараметрыДСиЦБсИП.Вставить("ДатаНачала", СтруктураПараметров.ДатаНачалаРасчета);
	//Kmusorin  IMAPPS-7198
	
	ПараметрыДСиЦБсИП.Вставить("ДатаОкончания", СтруктураПараметров.ДатаОкончанияРасчета);
	ПараметрыДСиЦБсИП.Вставить("ДоговорДУ", СтруктураПараметров.ДоговорДУ);
	
	
	СтруктураДСиЦБсИП = СуммыДСиЦБсИП(ПараметрыДСиЦБсИП);
	
	ПриростРСА = (РСА_Окончание-БазоваяРСА)+(СтруктураДСиЦБсИП.СуммаИзъятия-СтруктураДСиЦБсИП.СуммаВложения);
	
	СтруктураВозврата = Новый Структура;
	СтруктураВозврата.Вставить("РСА_Начало"   , БазоваяРСА);
	СтруктураВозврата.Вставить("РСА_Окончание", РСА_Окончание);
	СтруктураВозврата.Вставить("СуммаВложения", СтруктураДСиЦБсИП.СуммаВложения);
	СтруктураВозврата.Вставить("СуммаИзъятия" , СтруктураДСиЦБсИП.СуммаИзъятия);
	СтруктураВозврата.Вставить("ПриростРСА"   , ПриростРСА);
	//Показатели расчета базовой
	//СтруктураВозврата.Вставить("БазоваяРСА_Расчетная", СтруктураРасчетаБазовойРСА.БазоваяРСА_Расчетная);
	//СтруктураВозврата.Вставить("РСА_Минус_Управление", СтруктураРасчетаБазовойРСА.РСА_Минус_Управление);
	СтруктураВозврата.Вставить("БазоваяРСА"          , БазоваяРСА);
	Возврат СтруктураВозврата;
КонецФункции

Функция РасчетБРСА(СтруктураПараметров)
	
	// IMAPPS-35720: расчет БРСА выполняется самодостаточно, без зависимости от внешнего состояния.
	РСАКонец = РегистрыСведений.РегистрРСА_СЧА.ЗначенияСЧА_РСА(
		СтруктураПараметров.ДатаОкончанияРасчета,
		СтруктураПараметров.ДоговорДУ
	).СЧА;
	
	ПараметрыДСиЦБсИП = Новый Структура;
	ПараметрыДСиЦБсИП.Вставить("ДатаНачала", СтруктураПараметров.ДатаНачалаРасчета + 1);
	ПараметрыДСиЦБсИП.Вставить("ДатаОкончания", СтруктураПараметров.ДатаОкончанияРасчета);
	ПараметрыДСиЦБсИП.Вставить("ДоговорДУ", СтруктураПараметров.ДоговорДУ);
	СтруктураДСиЦБсИПБРСА = СуммыДСиЦБсИП(ПараметрыДСиЦБсИП);
	
	БРСА_Расчетная = СтруктураПараметров.БРСА_Прошлая + СтруктураДСиЦБсИПБРСА.СуммаВложения - СтруктураДСиЦБсИПБРСА.СуммаИзъятия;
	РСАМинусВознаграждения = РСАКонец - СтруктураПараметров.ВознаграждениеMF - СтруктураПараметров.ВознаграждениеSF;
	
	Возврат Макс(0, БРСА_Расчетная, РСАМинусВознаграждения);
	
КонецФункции


Функция КоличествоМесяцевВПериоде(Период)
	Если Период=Перечисления.Периодичность.Месяц Тогда
		Возврат 1;
	ИначеЕсли Период=Перечисления.Периодичность.Квартал Тогда
		Возврат 3;
	ИначеЕсли Период=Перечисления.Периодичность.Декада Тогда
		Возврат 4;
	ИначеЕсли Период=Перечисления.Периодичность.Полугодие Тогда
		Возврат 6;
	ИначеЕсли Период=Перечисления.Периодичность.Год Тогда
		Возврат 12;
	Иначе
		Возврат 3; //По умолчанию используем период Квартал
	КонецЕсли;
КонецФункции

Функция ГраницыПериодаРасчета(СтруктураПараметров)
	СтруктураВозврата = Новый Структура;
	СтруктураВозврата.Вставить("РасчетнаяДатаНачала", Дата(1, 1, 1));
	СтруктураВозврата.Вставить("РасчетнаяДатаОкончания", Дата(1, 1, 1));
	СтруктураВозврата.Вставить("КоличествоДнейВГоду", 0);
	КоличествоМесяцевВПериоде = КоличествоМесяцевВПериоде(СтруктураПараметров.НастройкиАлгоритма.Периодичность);
	//СтруктураДоговораДУ = ОбщегоНазначения.ПолучитьЗначенияРеквизитов(СтруктураПараметров.ДоговорДУ, "ДатаВводаСредствВДУ, ДатаНачала, ДатаОкончания");
	//Определение начала периода расчета
	
	//Корректировка по типу периода
	Если СтруктураПараметров.НастройкиАлгоритма.ТипПериода="Календарный" Тогда
		//kmusorin IMAPPS-7198		
		//НачальнаяДата    =  НачалоГода(СтруктураПараметров.ДатаДокумента);
		НачальнаяДата = ?(ЗначениеЗаполнено(СтруктураПараметров.СтруктураДоговораДУ.ДатаВозобновленияУправления),СтруктураПараметров.СтруктураДоговораДУ.ДатаВозобновленияУправления,НачалоГода(СтруктураПараметров.ДатаДокумента));
		//kmusorin IMAPPS-7198		
	Иначе //Инвестиционный
		Если СтруктураПараметров.НастройкиАлгоритма.ДатаНачалаРасчета="ДатаПодписанияДоговора" Тогда
			НачальнаяДата = СтруктураПараметров.СтруктураДоговораДУ.ДатаНачала;   
		Иначе
			НачальнаяДата = СтруктураПараметров.СтруктураДоговораДУ.ДатаВводаСредствВДУ; 
		КонецЕсли;
	КонецЕсли;
	
	//НачальнаяДата = ?(ЗначениеЗаполнено(СтруктураПараметров.НастройкиАлгоритма.ДатаНачалаРасчета), СтруктураПараметров.НастройкиАлгоритма.ДатаНачалаРасчета, СтруктураПараметров.ДатаВводаСредствВДУ);
	
	КоличествоМесяцев = ОбщегоНазначенияДУ.КоличествоПериодов(НачальнаяДата, СтруктураПараметров.ДатаДокумента, "Месяц")-1;
	КоличествоКварталов = ОбщегоНазначенияДУ.КоличествоПериодов(НачальнаяДата, СтруктураПараметров.ДатаДокумента, "Квартал");
	//Если День(НачальнаяДата)>День(СтруктураПараметров.ДатаДокумента) Тогда
	//	КоличествоМесяцев=КоличествоМесяцев-1;
	//КонецЕсли;
#Область kmusorin_IMAPPS_7198	
	////kmusorin IMAPPS-7198	
	////ПрошедшиеПериоды  = Цел(КоличествоМесяцев/КоличествоМесяцевВПериоде)*КоличествоМесяцевВПериоде;
	//ПрошедшиеПериоды  = КоличествоКварталов*КоличествоМесяцевВПериоде;
	////РасчетнаяДатаНачала = НачалоДня(ОбщегоНазначенияДУ.ДобавитьКДате(НачальнаяДата, "Месяц", ПрошедшиеПериоды));
	//Если СтруктураПараметров.СтруктураДоговораДУ.ДатаВозобновленияУправления <> Дата(1,1,1) И ПрошедшиеПериоды <= КоличествоМесяцевВПериоде Тогда
	//	
	//	РасчетнаяДатаНачала = НачальнаяДата;
	//	
	//Иначе 
	//	//РасчетнаяДатаНачала = НачалоДня(ОбщегоНазначенияДУ.ДобавитьКДате(НачалоМесяца(НачальнаяДата), "Месяц", ПрошедшиеПериоды));
	//	
	//	РасчетнаяДатаНачала = НачалоДня(НачалоКвартала(СтруктураПараметров.ДатаДокумента));
	//	
	//	//РасчетнаяДатаНачала = НачальнаяДата;
	//	
	//КонецЕсли;	
	////kmusorin IMAPPS-7198
#КонецОбласти

	// MPazhukov IMAPPS-9987
	// Сделаное "kmusorin IMAPPS-7198" закоментировано, смысл не понятен
	ПрошедшиеПериоды  = Цел(КоличествоМесяцев/КоличествоМесяцевВПериоде)*КоличествоМесяцевВПериоде;
	РасчетнаяДатаНачала = НачалоДня(ОбщегоНазначенияДУ.ДобавитьКДате(НачальнаяДата, "Месяц", ПрошедшиеПериоды));
	// MPazhukov IMAPPS-9987
	
	ПрошедшиеПериоды  = КоличествоКварталов*КоличествоМесяцевВПериоде;
	
	// AKudryashov IMAPPS-10791
	Если СтруктураПараметров.СтруктураДоговораДУ.ДатаВозобновленияУправления <> Дата(1,1,1) И ПрошедшиеПериоды <= КоличествоМесяцевВПериоде Тогда
		РасчетнаяДатаНачала = НачальнаяДата;	
	Иначе
		Если СтруктураПараметров.НастройкиАлгоритма.Периодичность = Перечисления.Периодичность.Квартал Тогда 
			РасчетнаяДатаНачала = НачалоДня(НачалоКвартала(СтруктураПараметров.ДатаДокумента));
		КонецЕсли;
	КонецЕсли;	
	// AKudryashov IMAPPS-10791
	
	//Корректировка дат от периода договора
	Если СтруктураПараметров.НастройкиАлгоритма.ДатаНачалаРасчета="ДатаПодписанияДоговора" Тогда
		РасчетнаяДатаНачала = НачалоДня(Макс(РасчетнаяДатаНачала, СтруктураПараметров.СтруктураДоговораДУ.ДатаНачала));   
	Иначе
		РасчетнаяДатаНачала = НачалоДня(Макс(РасчетнаяДатаНачала,СтруктураПараметров.СтруктураДоговораДУ.ДатаВводаСредствВДУ)); 
	КонецЕсли;
	Если ЗначениеЗаполнено(СтруктураПараметров.СтруктураДоговораДУ.ДатаОкончания) Тогда
		РасчетнаяДатаОкончания = КонецДня(Мин(СтруктураПараметров.ДатаДокумента, СтруктураПараметров.СтруктураДоговораДУ.ДатаОкончания));
	Иначе
		РасчетнаяДатаОкончания = КонецДня(СтруктураПараметров.ДатаДокумента);
	КонецЕсли;
	
	//Определение количества дней в расчитываемом году для дальнейших расчетов
	ДельтаЛет = Цел(КоличествоМесяцев/12);
	НачалоРасчетногоГода = ОбщегоНазначенияДУ.ДобавитьКДате(НачальнаяДата, "Год", ДельтаЛет);
	КонецРасчетногоГода  = ОбщегоНазначенияДУ.ДобавитьКДате(НачальнаяДата, "Год", ДельтаЛет+1)-1;
	КоличествоДнейВГоду = ОбщегоНазначенияДУ.КоличествоПериодов(НачалоРасчетногоГода, КонецРасчетногоГода, "День");
	
	//Заполнение структуры возврата
	СтруктураВозврата.РасчетнаяДатаНачала    = РасчетнаяДатаНачала;
	СтруктураВозврата.РасчетнаяДатаОкончания = РасчетнаяДатаОкончания;
	СтруктураВозврата.КоличествоДнейВГоду  = КоличествоДнейВГоду;
	
	Возврат СтруктураВозврата;
КонецФункции

Функция РезультатРасчета(ПользовательскиеНастройки, СтруктураПараметров) Экспорт
	Перем СтруктураВозврата;
	
	//Начальная проверка существования нужных настроек расчета
	Если ПользовательскиеНастройки=Неопределено Тогда
		ОбщегоНазначенияДУКлиентСервер.СообщитьОбОшибке("Отсутствуют настройки алгоритма");
		Возврат Неопределено;
	КонецЕсли;
	
	СтруктураВозврата = Новый Структура(
	"СуммаВознаграждения, СтавкаВознаграждения, БРСА, БРСА_Начальная, СправкаРасчет",
	0,
	0,
	0,
	0,
	Новый ХранилищеЗначения(Новый Структура("ШапкаРасчет, ТелоРасчет, ПодвалРасчет, НачалоПериода, ОкончаниеПериода", Новый ТабличныйДокумент(), Новый ТабличныйДокумент(), Новый ТабличныйДокумент()))
	);
	
	Попытка
		
		//Инициализация параметров для расчета
		ПоказателиСправки = Новый Структура;
		ПоказателиСправки.Вставить("ДатаРасчета", "");
		ПоказателиСправки.Вставить("НачалоРасчета", "");
		ПоказателиСправки.Вставить("ОкончаниеРасчета", "");
		
		ПоказателиСправки.Вставить("ДоговорДУ", "");
		ПоказателиСправки.Вставить("ДатаДоговораДУ", "");
		ПоказателиСправки.Вставить("НомерДоговораДУ", "");
		
		ПоказателиСправки.Вставить("П000", 0);
		ПоказателиСправки.Вставить("П011", 0);
		ПоказателиСправки.Вставить("П012", 0);
		ПоказателиСправки.Вставить("П013", 0);
		ПоказателиСправки.Вставить("П014", 0);
		ПоказателиСправки.Вставить("П015", 0);
		
		ПоказателиСправки.Вставить("П021", 0);
		// IMAPPS-35720: параметр нового макета для строкового представления ставки SF.
		ПоказателиСправки.Вставить("П021Строка", "");
		ПоказателиСправки.Вставить("П022", 0);
		ПоказателиСправки.Вставить("П023", 0);
		// IMAPPS-35720: параметры нового макета для итоговых строк секции SF.
		ПоказателиСправки.Вставить("ВознаграждениеЗаУспех", 0);
		ПоказателиСправки.Вставить("ИтоговоеВознаграждениеЗаУспех", 0);
		
		ПоказателиСправки.Вставить("П031", 0);
		ПоказателиСправки.Вставить("П032", 0);
		ПоказателиСправки.Вставить("П033", 0);  
		
		// IMAPPS-35720: убрана дублирующая инициализация П05.
		ПоказателиСправки.Вставить("П04", 0);
		ПоказателиСправки.Вставить("П05", 0);
		ПоказателиСправки.Вставить("П051", 0);
		ПоказателиСправки.Вставить("П06", 0);
		
		СтруктураПараметровДУ = ОбщегоНазначения.ПолучитьЗначенияРеквизитов(СтруктураПараметров.ДоговорДУ, "ДатаВводаСредствВДУ, ДатаНачала, ДатаОкончания, Код, ДатаПриостановкиУправления, ДатаВозобновленияУправления");   //kmusorin IMAPPS-7198
		ПВХ                   = ПланыВидовХарактеристик.ПараметрыДоговораДУ;
		// IMAPPS-35720: ставка из договора используется как fallback.
		ПроцентВознагражденияПоДоговору = УправлениеПараметрамиДоговораДУ.ПолучитьПараметрДоговораДУ(
			СтруктураПараметров.ДоговорДУ,
			ПВХ.ВеличинаВознагражденияЗаУспех,
			СтруктураПараметров.Дата
		);
		ПроцентВознаграждения = ПроцентВознагражденияПоДоговору;
		
		//Определение границ периода
		СтруктураПараметровПериода = Новый Структура;
		СтруктураПараметровПериода.Вставить("ДатаДокумента"     , СтруктураПараметров.Дата); 
		СтруктураПараметровПериода.Вставить("СтруктураДоговораДУ", СтруктураПараметровДУ);
		СтруктураПараметровПериода.Вставить("НастройкиАлгоритма", ПользовательскиеНастройки.Значения);
		
		СтруктураПериодаРасчета = ГраницыПериодаРасчета(СтруктураПараметровПериода);
		РасчетнаяДатаНачала     = СтруктураПериодаРасчета.РасчетнаяДатаНачала;
		РасчетнаяДатаОкончания  = СтруктураПериодаРасчета.РасчетнаяДатаОкончания;
		ДнейВГоду     = СтруктураПериодаРасчета.КоличествоДнейВГоду;
		// IMAPPS-35720: коэффициент выбирается по СЧА на конец периода (не по П015).
		СЧАНаКонецПериода = РегистрыСведений.РегистрРСА_СЧА.ЗначенияСЧА_РСА(
			РасчетнаяДатаОкончания,
			СтруктураПараметров.ДоговорДУ
		).СЧА;
		ПроцентВознаграждения = ПроцентПоТаблицеКоэффициентов(
			СтруктураПараметровПериода.НастройкиАлгоритма,
			СЧАНаКонецПериода,
			ПроцентВознагражденияПоДоговору
		);
		
		Если РасчетнаяДатаНачала > РасчетнаяДатаОкончания Тогда
			Возврат СтруктураВозврата;  
		КонецЕсли;
			
		// IMAPPS-29983 ++
		//Если СтруктураПараметровПериода.СтруктураДоговораДУ.ДатаПриостановкиУправления = Дата(1,1,1) Тогда
		// IMAPPS-29983 --
			СтруктураПараметровПриростРСА = Новый Структура;
			СтруктураПараметровПриростРСА.Вставить("Дата", СтруктураПараметров.Дата);
			СтруктураПараметровПриростРСА.Вставить("ДоговорДУ", СтруктураПараметров.ДоговорДУ);
			
			СтруктураПараметровПриростРСА.Вставить("ДатаНачалаРасчета"   , РасчетнаяДатаНачала);
			СтруктураПараметровПриростРСА.Вставить("ДатаОкончанияРасчета", РасчетнаяДатаОкончания);
			СтруктураПараметровПриростРСА.Вставить("ДатаНачалаДУ"   , СтруктураПараметровДУ.ДатаНачала);
			СтруктураПараметровПриростРСА.Вставить("ДатаОкончанияДУ", СтруктураПараметровДУ.ДатаОкончания);
			
			СтруктураРасчетаПриростРСА = ИнвестиционныйДоход_Базовый(СтруктураПараметровПриростРСА);
			
			СтруктураПараметровУправление = Новый Структура;
			СтруктураПараметровУправление.Вставить("Дата", СтруктураПараметров.Дата);
			СтруктураПараметровУправление.Вставить("ДоговорДУ", СтруктураПараметров.ДоговорДУ);
			СтруктураПараметровУправление.Вставить("ДатаНачалаДУ", СтруктураПараметровДУ.ДатаНачала);
			// IMAPPS-35720: исправлено единообразие имени переменной структуры параметров ДУ.
			СтруктураПараметровУправление.Вставить("ДатаОкончанияДУ", СтруктураПараметровДУ.ДатаОкончания);
			СтруктураПараметровУправление.Вставить("ДатаНачалаРасчета"   , РасчетнаяДатаНачала);
			СтруктураПараметровУправление.Вставить("ДатаОкончанияРасчета", РасчетнаяДатаОкончания);
			
			СуммаЗаУправление = РасчетСуммыЗаУправление(СтруктураПараметровУправление);
			РачетнаяВеличинаВознаграждения = (СтруктураРасчетаПриростРСА.ПриростРСА-СуммаЗаУправление)*(ПроцентВознаграждения/100);
			ИтоговыйРасчет = ?(СтруктураРасчетаПриростРСА.ПриростРСА>0, Макс(0, РачетнаяВеличинаВознаграждения), 0);
			
			СуммаЗаУправление = Окр(СуммаЗаУправление,2);
			РачетнаяВеличинаВознаграждения = Окр(РачетнаяВеличинаВознаграждения,2);
			ИтоговыйРасчет = Окр(ИтоговыйРасчет,2);
			ИнициализироватьБухгалтерскиеИтоги(СтруктураПараметров.ДоговорДУ, РасчетнаяДатаНачала, РасчетнаяДатаОкончания);	
			
			//Расчет БРСА
			БРСА=0;
			БРСА_Начальная = СтруктураРасчетаПриростРСА.БазоваяРСА;
			РассчитыватьБРСА = Ложь;
			ПользовательскиеНастройки.Значения.Свойство("РассчитыватьБРСА", РассчитыватьБРСА);
			Если Не РассчитыватьБРСА = Неопределено И РассчитыватьБРСА Тогда
				СтруктураПараметровБРСА = Новый Структура;
				// IMAPPS-35720: параметры для РасчетБРСА формируются в отдельной структуре по контракту функции.
				СтруктураПараметровБРСА.Вставить("ДатаНачалаРасчета"   , РасчетнаяДатаНачала);
				СтруктураПараметровБРСА.Вставить("ДатаОкончанияРасчета", РасчетнаяДатаОкончания);
				СтруктураПараметровБРСА.Вставить("ДоговорДУ", СтруктураПараметров.ДоговорДУ);
				СтруктураПараметровБРСА.Вставить("БРСА_Прошлая", СтруктураРасчетаПриростРСА.БазоваяРСА);
				СтруктураПараметровБРСА.Вставить("ВознаграждениеMF", СуммаЗаУправление);
				СтруктураПараметровБРСА.Вставить("ВознаграждениеSF", ИтоговыйРасчет);
				БРСА = РасчетБРСА(СтруктураПараметровБРСА);				
			КонецЕсли;
			
			//Заполнение показателей для справки-расчета
			ПоказателиСправки.ДатаРасчета   = Формат(СтруктураПараметров.Дата, "ДФ=dd.MM.yyyy");
			ПоказателиСправки.НачалоРасчета    = РасчетнаяДатаНачала;
			ПоказателиСправки.ОкончаниеРасчета = РасчетнаяДатаОкончания;
			ПоказателиСправки.ДоговорДУ   = СтруктураПараметров.ДоговорДУ;
			ПоказателиСправки.ДатаДоговораДУ = СтруктураПараметровДУ.ДатаНачала;
			ПоказателиСправки.НомерДоговораДУ = СтруктураПараметровДУ.Код;
			
			ПоказателиСправки.П000 = СуммаЗаУправление;
			ПоказателиСправки.П011 = СтруктураРасчетаПриростРСА.РСА_Начало;
			ПоказателиСправки.П012 = СтруктураРасчетаПриростРСА.РСА_Окончание;
			ПоказателиСправки.П013 = СтруктураРасчетаПриростРСА.СуммаВложения;
			ПоказателиСправки.П014 = СтруктураРасчетаПриростРСА.СуммаИзъятия;
			ПоказателиСправки.П015 = СтруктураРасчетаПриростРСА.ПриростРСА-СуммаЗаУправление;
			
			ПоказателиСправки.П021 = ПроцентВознаграждения;
			// IMAPPS-35720: заполняем строковое представление ставки для нового параметра макета.
			ПоказателиСправки.П021Строка = Формат(ПроцентВознаграждения, "ЧДЦ=2; ЧН=0,00") + "%";
			ПоказателиСправки.П022 = РачетнаяВеличинаВознаграждения;
			ПоказателиСправки.П023 = ИтоговыйРасчет;
			// IMAPPS-35720: поддержка новых параметров макета SF-блока.
			ПоказателиСправки.ВознаграждениеЗаУспех = ПоказателиСправки.П022;
			ПоказателиСправки.ИтоговоеВознаграждениеЗаУспех = ПоказателиСправки.П023;
			
			ПоказателиСправки.П031 = ПоказателиСправки.П011 + ПоказателиСправки.П013 - ПоказателиСправки.П014;
			//ПоказателиСправки.П032 = ПоказателиСправки.П012 - СуммаЗаУправление - ИтоговыйРасчет;
			ПоказателиСправки.П032 = ПоказателиСправки.П012 - ОКР(СуммаЗаУправление, 2) - ИтоговыйРасчет; // VTB
			
			ПоказателиСправки.П033 = ?(ПоказателиСправки.П031>ПоказателиСправки.П032,ПоказателиСправки.П031,ПоказателиСправки.П032);
			
			
			СтруктураСЧА = СреднееСЧА_РСА(СтруктураПараметров.ДоговорДУ, РасчетнаяДатаНачала, РасчетнаяДатаОкончания);	
			ПоказателиСправки.Вставить("СтруктураСЧА",СтруктураСЧА);
			ДоходОтСЧА = СтруктураСЧА.СЧА*0.2/100;
			
			ПоказателиСправки.П04  = ПолучитьРасходы(СтруктураПараметров.ДоговорДУ, РасчетнаяДатаНачала, РасчетнаяДатаОкончания);
           	ПоказателиСправки.П05  = Окр(ДоходОтСЧА,2);
			ПоказателиСправки.П051 = Окр(СтруктураСЧА.СЧА,2);

			ПоказателиСправки.П06 = ?((ПоказателиСправки.П04 - ПоказателиСправки.П05)>0,ПоказателиСправки.П04 - ПоказателиСправки.П05,0); 
			
			СтруктураВозврата.СуммаВознаграждения	 = ИтоговыйРасчет;
			СтруктураВозврата.СправкаРасчет			 = СправкаРасчет(ПоказателиСправки);
			СтруктураВозврата.СтавкаВознаграждения	 = ПроцентВознаграждения;
			СтруктураВозврата.БРСА					 = БРСА;
			СтруктураВозврата.БРСА_Начальная		 = БРСА_Начальная;
			
		
		// IMAPPS-29983 ++
		//КонецЕсли;   
		// IMAPPS-29983 --
		
	Исключение
		Сообщить(ОписаниеОшибки());
	КонецПопытки;
	
	Возврат СтруктураВозврата;
КонецФункции

// IMAPPS-35720:
// Описание: Возвращает ставку SF по таблице коэффициентов на основании СЧА на конец периода.
// Если таблица не заполнена/повреждена, возвращается ПроцентПоУмолчанию (ставка из договора).
// Границы и СЧА сравниваются в одной размерности "рубли".
//
// Параметры:
//   НастройкиАлгоритма - Структура - пользовательские настройки алгоритма (содержит ТаблицаКоэффициентов в XML)
//   СуммаСЧА           - Число    - СЧА на конец периода (в рублях)
//   ПроцентПоУмолчанию - Число    - ставка из договора (fallback при отсутствии/повреждении таблицы)
//
// Возвращаемое значение:
//   Число - ставка вознаграждения за успех в процентах
//
Функция ПроцентПоТаблицеКоэффициентов(НастройкиАлгоритма, СуммаСЧА, ПроцентПоУмолчанию)
	Если ТипЗнч(НастройкиАлгоритма) <> Тип("Структура") Тогда
		Возврат ПроцентПоУмолчанию;
	КонецЕсли;
	
	Если Не НастройкиАлгоритма.Свойство("ТаблицаКоэффициентов") Тогда
		Возврат ПроцентПоУмолчанию;
	КонецЕсли;
	
	Попытка
		ТаблицаКоэффициентов = XMLЗначение(
			Тип("ХранилищеЗначения"),
			НастройкиАлгоритма.ТаблицаКоэффициентов
		).Получить();
	Исключение
		Возврат ПроцентПоУмолчанию;
	КонецПопытки;
	
	Если ТипЗнч(ТаблицаКоэффициентов) <> Тип("ТаблицаЗначений") Тогда
		Возврат ПроцентПоУмолчанию;
	КонецЕсли;
	
	Если ТаблицаКоэффициентов.Количество() = 0 Тогда
		Возврат ПроцентПоУмолчанию;
	КонецЕсли;
	
	// IMAPPS-35720: диапазонная выборка коэффициента по границам Мин/Макс.
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	Данные.Коэффициент КАК Коэффициент
	|ИЗ
	|	&ТЗ КАК Данные
	|ГДЕ
	|	Данные.МинГраница <= &СуммаСЧА
	|	И Данные.МаксГраница >= &СуммаСЧА
	|УПОРЯДОЧИТЬ ПО
	|	Данные.МинГраница УБЫВ";
	Запрос.УстановитьПараметр("ТЗ", ТаблицаКоэффициентов);
	Запрос.УстановитьПараметр("СуммаСЧА", СуммаСЧА);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() И ЗначениеЗаполнено(Выборка.Коэффициент) Тогда
		Возврат Выборка.Коэффициент;
	КонецЕсли;
	
	Возврат ПроцентПоУмолчанию;
КонецФункции

Функция СреднееСЧА_РСА(ДоговорДУ, ДатаНачала, ДатаОкончания, ТипДня ="КалендарныйТип" )
	СтруктураВозврата = Новый Структура;
	СтруктураВозврата.Вставить("СЧА", 0);
	СтруктураВозврата.Вставить("РСА", 0);
	СтруктураВозврата.Вставить("ТаблицаСЧА_РСА", Новый ТаблицаЗначений);
	СтруктураВозврата.Вставить("КоличествоДней", 0);
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ДоговорДУ", ДоговорДУ);
	Запрос.УстановитьПараметр("ДатаНачала", ДатаНачала);
	Запрос.УстановитьПараметр("ДатаОкончания", ДатаОкончания);
	ТекстЗапроса = 
	"ВЫБРАТЬ
	|	КалендарныеГрафики.ДатаГрафика КАК Дата
	|ИЗ
	|	РегистрСведений.КалендарныеГрафики КАК КалендарныеГрафики
	|ГДЕ
	|	КалендарныеГрафики.Календарь = ЗНАЧЕНИЕ(Справочник.Календари.РегламентированныйКалендарь)
	|	И КалендарныеГрафики.ДатаГрафика МЕЖДУ &ДатаНачала И &ДатаОкончания
	|	И КалендарныеГрафики.ДеньВключенВГрафик";
	Если ТипДня="КалендарныйТип" Тогда
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "КалендарныеГрафики.ДеньВключенВГрафик", "ИСТИНА");
	КонецЕсли;
	Запрос.Текст = ТекстЗапроса;
	ТаблицаСЧА_РСА = РегистрыСведений.РегистрРСА_СЧА.ТЗ_СЧА_РСА_НаДаты(Запрос.Выполнить().Выгрузить(), ДоговорДУ);
		
	КоличествоДней = ТаблицаСЧА_РСА.Количество();
	Если НЕ КоличествоДней=0 Тогда
		СтруктураВозврата.СЧА = ТаблицаСЧА_РСА.Итог("СЧА")/КоличествоДней;
		СтруктураВозврата.РСА = ТаблицаСЧА_РСА.Итог("РСА")/КоличествоДней;
		СтруктураВозврата.ТаблицаСЧА_РСА = ТаблицаСЧА_РСА;
		СтруктураВозврата.КоличествоДней = КоличествоДней;
	КонецЕсли;
	
	Возврат СтруктураВозврата;
КонецФункции

Процедура ИнициализироватьБухгалтерскиеИтоги(ДоговорДУ, ДатаНачала, ДатаОкончания)
	
	БухгалтерскиеИтоги = Обработки.БухгалтерскиеИтоги.Создать();
	
	Итоги = "НачальныйОстатокДт, НачальныйОстатокКт,
	|НачальныйыРазвернутыйОстатокДт, НачальныйРазвернутыйОстатокКт,
	|КонечныйОстатокДт, КонечныйОстатокКт, 
	|КонечныйРазвернутыйОстатокДт,КонечныйРазвернутыйОстатокКт,
	|ОборотДт, ОборотКт, КорОборотДт, КорОборотКт";
	
	Ресурсы = "Сумма,Количество";
	
	Группировки = "Счет, КорСчет, Субконто1, Субконто2, Субконто3";
	
	Отбор = Новый Структура;
	Отбор.Вставить("ДоговорДУ", ДоговорДУ);
	
	БухгалтерскиеИтоги.РассчитатьИтоги("Хозрасчетный", Итоги, Ресурсы, Группировки, Новый Граница(НачалоДня(ДатаНачала), ВидГраницы.Включая), Новый Граница(КонецДня(ДатаОкончания), ВидГраницы.Включая), , , , , , Отбор);
	
КонецПроцедуры

Функция ПолучитьРасходы(ДоговорДУ, ДатаНачала, ДатаОкончания)
	
	ДепозитарныеУслуги 		= БухгалтерскиеИтоги.ДО(ПланыСчетов.Хозрасчетный.ДепозитарныеУслуги);
	УслугиБанка 			= БухгалтерскиеИтоги.ДО(ПланыСчетов.Хозрасчетный.УслугиБанка);
	УслугиСпецдепозитария 	= БухгалтерскиеИтоги.ДО(ПланыСчетов.Хозрасчетный.УслугиСпецдепозитария);
	ПрочиеРасходыПрочие 	= БухгалтерскиеИтоги.ДО(ПланыСчетов.Хозрасчетный.ПрочиеРасходыПрочие);
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	
	"ВЫБРАТЬ
	|	ЕСТЬNULL(СУММА(ВЫБОР
	|				КОГДА ДенежныеСредстваУправленческий.СтатьяДДС = &КомиссияБиржи
	|					ТОГДА ДенежныеСредстваУправленческий.Сумма
	|				ИНАЧЕ 0
	|			КОНЕЦ), 0) КАК КомиссияБиржи,
	|	ЕСТЬNULL(СУММА(ВЫБОР
	|				КОГДА ДенежныеСредстваУправленческий.СтатьяДДС В (&КомиссияБрокера, &КомиссияПосредника)
	|					ТОГДА ДенежныеСредстваУправленческий.Сумма
	|				ИНАЧЕ 0
	|			КОНЕЦ), 0) КАК КомиссияБрокера
	|ИЗ
	|	РегистрНакопления.ДенежныеСредстваУправленческий КАК ДенежныеСредстваУправленческий
	|ГДЕ
	|	ДенежныеСредстваУправленческий.Период МЕЖДУ &НачалоПериода И &КонецПериода
	|	И ДенежныеСредстваУправленческий.ДоговорДУ = &ДоговорДУ
	|	И ДенежныеСредстваУправленческий.СтатьяДДС В (&КомиссияБиржи, &КомиссияБрокера, &КомиссияПосредника)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Хозрасчетный.Ссылка КАК Счет
	|ПОМЕСТИТЬ Счета
	|ИЗ
	|	ПланСчетов.Хозрасчетный КАК Хозрасчетный
	|ГДЕ
	|	Хозрасчетный.Ссылка В ИЕРАРХИИ(&СписокСчетов)
	|	И Хозрасчетный.ЗапретитьИспользоватьВПроводках = ЛОЖЬ
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Счет
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ХозрасчетныйОстатки.Счет КАК Счет,
	|	NULL КАК ДатаРегистратора,
	|	ХозрасчетныйОстатки.СуммаОстатокКт КАК Сумма
	|ПОМЕСТИТЬ Остатки
	|ИЗ
	|	РегистрБухгалтерии.Хозрасчетный.Остатки(
	|			&КонецПериодаГраница,
	|			Счет В
	|				(ВЫБРАТЬ
	|					Счета.Счет
	|				ИЗ
	|					Счета КАК Счета),
	|			,
	|			ДоговорДУ = &ДоговорДУ) КАК ХозрасчетныйОстатки
	|ГДЕ
	|	ХозрасчетныйОстатки.Счет <> ЗНАЧЕНИЕ(ПланСчетов.Хозрасчетный.РасчетыПоНачисленномуДоходу)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ХозрасчетныйОстатки.Счет,
	|	ХозрасчетныйОстатки.Субконто3.Дата,
	|	ХозрасчетныйОстатки.СуммаОстатокКт
	|ИЗ
	|	РегистрБухгалтерии.Хозрасчетный.Остатки(&КонецПериодаГраница, Счет = ЗНАЧЕНИЕ(ПланСчетов.Хозрасчетный.РасчетыПоНачисленномуДоходу), , ДоговорДУ = &ДоговорДУ) КАК ХозрасчетныйОстатки
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВЫБОР
	|		КОГДА Счета.Счет = ЗНАЧЕНИЕ(ПланСчетов.Хозрасчетный.РасчетыПоНачисленномуДоходу)
	|			ТОГДА ""Начисление % от средней СЧА""
	|		ИНАЧЕ Счета.Счет.Наименование
	|	КОНЕЦ КАК СчетПредставление,
	|	Остатки.ДатаРегистратора КАК ДатаРегистратора,
	|	ЕСТЬNULL(Остатки.Сумма, 0) КАК Сумма
	|ИЗ
	|	Счета КАК Счета
	|		ЛЕВОЕ СОЕДИНЕНИЕ Остатки КАК Остатки
	|		ПО Счета.Счет = Остатки.Счет
	|ГДЕ
	|	ЕСТЬNULL(Остатки.Сумма, 0) <> 0";
	
	Запрос.УстановитьПараметр("ДоговорДУ", ДоговорДУ);
	Запрос.УстановитьПараметр("КомиссияБиржи", ПредопределенноеЗначение("Справочник.СтатьиДвиженияДенежныхСредств.КомиссияБиржи"));
	Запрос.УстановитьПараметр("КомиссияБрокера", ПредопределенноеЗначение("Справочник.СтатьиДвиженияДенежныхСредств.КомиссияБрокера"));
	Запрос.УстановитьПараметр("КомиссияПосредника", ПредопределенноеЗначение("Справочник.СтатьиДвиженияДенежныхСредств.КомиссияПосредника"));
	Запрос.УстановитьПараметр("НачалоПериода", ДатаНачала);
	Запрос.УстановитьПараметр("КонецПериода", КонецДня(ДатаОкончания));
	Запрос.УстановитьПараметр("КонецПериодаГраница", Новый Граница(КонецДня(ДатаОкончания), ВидГраницы.Включая));
	
	СписокСчетов = Новый Массив;
	СписокСчетов.Добавить(ПланыСчетов.Хозрасчетный.НачисленныеВознаграждения);
	СписокСчетов.Добавить(ПланыСчетов.Хозрасчетный.ОбязательноеСтрахование);
	СписокСчетов.Добавить(ПланыСчетов.Хозрасчетный.ПрочиеВзаиморасчеты);
	СписокСчетов.Добавить(ПланыСчетов.Хозрасчетный.НДФЛ);
	// IMAPPS-13736 ++
	СписокСчетов.Добавить(ПланыСчетов.Хозрасчетный.РасчетыПоНачисленномуДоходу);
	// IMAPPS-13736 --
	
	Запрос.УстановитьПараметр("СписокСчетов", СписокСчетов);
	
	ОбщегоНазначенияДУ.ДобавитьВЛогОтладки(Запрос, "Отчет управляющего ДУ, согласно 482П - Раздел 6.1 - Комиссии");
	
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	
	КомиссияБиржи = 0;
	КомиссияБрокера = 0;
	
	Комиссии = РезультатЗапроса[0].Выгрузить();
	
	Если Комиссии.Количество() > 0 Тогда
		
		КомиссияБиржи = Комиссии[0].КомиссияБиржи;
		КомиссияБрокера = Комиссии[0].КомиссияБрокера;
		
	КонецЕсли; 
	
	//vtb 29.06
	Запрос = новый запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	ХозрасчетныйОбороты.СуммаОборотДт как ИныеКомиссии
	|ИЗ
	|	РегистрБухгалтерии.Хозрасчетный.Обороты(
	|			&НачалоПериода,
	|			&КонецПериода,
	|			,
	|			Счет = ЗНАЧЕНИЕ(ПланСчетов.Хозрасчетный.ПрочиеРасходыПрочие),
	|			,
	|			ДоговорДУ = &ДоговорДУ
	|				И Субконто1 В (&СтатьиРасходов),
	|			,
	|			) КАК ХозрасчетныйОбороты";
	
	СтатьиРасходов = Новый Массив; 	
	СтатьиРасходов.Добавить(ПредопределенноеЗначение("Справочник.СтатьиДоходовИРасходов.ОбязательноеСтрахование"));
	СтатьиРасходов.Добавить(ПредопределенноеЗначение("Справочник.СтатьиДоходовИРасходов.УслугиАудитора"));
	
	Запрос.УстановитьПараметр("ДоговорДУ", ДоговорДУ);
	Запрос.УстановитьПараметр("НачалоПериода", НачалоДня(ДатаНачала));
	Запрос.УстановитьПараметр("КонецПериода", КонецДня(ДатаОкончания));
	Запрос.УстановитьПараметр("СтатьиРасходов", СтатьиРасходов);
	
	
	ПрочиеРасходыПрочие = 0;
	ИныеКомиссии = Запрос.Выполнить().Выгрузить();	
	
	Если ИныеКомиссии.Количество() > 0 Тогда
		ПрочиеРасходыПрочие = ИныеКомиссии[0].ИныеКомиссии;
	КонецЕсли; 
	
	
	ДанныеРаздела = Новый Структура;
	ДанныеРаздела.Вставить("КомиссияБиржи", КомиссияБиржи);
	ДанныеРаздела.Вставить("КомиссияБрокера", КомиссияБрокера);
	ДанныеРаздела.Вставить("ДепозитарныеУслуги", ДепозитарныеУслуги);
	ДанныеРаздела.Вставить("УслугиБанка", УслугиБанка);
	ДанныеРаздела.Вставить("УслугиСпецдепозитария", УслугиСпецдепозитария);
	ДанныеРаздела.Вставить("ПрочиеРасходыПрочие", ПрочиеРасходыПрочие);
	ДанныеРаздела.Вставить("Обязательства", РезультатЗапроса[3].Выгрузить());
	
		ИтогоСумма = 
	ДанныеРаздела.КомиссияБиржи + 
	ДанныеРаздела.КомиссияБрокера + 
	ДанныеРаздела.ДепозитарныеУслуги +
	ДанныеРаздела.УслугиБанка +
	ДанныеРаздела.УслугиСпецдепозитария +
	ДанныеРаздела.ПрочиеРасходыПрочие;

	Возврат ИтогоСумма;
	
КонецФункции


Функция ПолучитьПодписанта(УК)
	Запрос = Новый Запрос();
	Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	КонтактныеЛица.Ссылка
	|ИЗ
	|	Справочник.КонтактныеЛица КАК КонтактныеЛица
	|ГДЕ
	|	КонтактныеЛица.Владелец = &УК
	|	И КонтактныеЛица.ПометкаУдаления = ЛОЖЬ
	|	И КонтактныеЛица.Роль = &Роль";
	Запрос.УстановитьПараметр("УК", УК);
	Запрос.УстановитьПараметр("Роль", Справочники.РолиКонтактныхЛиц.РуководительПодразделения);
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат СокрЛП(Выборка.Ссылка.Должность) + ": " + Выборка.Ссылка.Фамилия + " " + Лев(Выборка.Ссылка.Имя, 1) + "." + Лев(Выборка.Ссылка.Отчество, 1) + ".";
	Иначе
		Возврат "";
	КонецЕсли;
КонецФункции	
