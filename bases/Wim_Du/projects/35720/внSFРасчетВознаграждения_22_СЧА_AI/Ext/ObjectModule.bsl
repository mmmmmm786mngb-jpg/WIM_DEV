Функция СведенияОВнешнейОбработке() Экспорт
	
	Структура = Новый Структура;
	Структура.Вставить("Вид",             "ЗаполнениеОбъекта"); //Перечисления.ВидыДополнительныхОтчетовИОбработок.НачислениеПроцентов.
	// IMAPPS-35720: актуализированное наименование и версия обработки.
	Структура.Вставить("Наименование",    "SF 22 (AI). Расчет вознаграждения за успех: из инвестиционного дохода за период с ограничением от величины СЧА");
	Структура.Вставить("Версия",          "1.00");
	Структура.Вставить("БезопасныйРежим", Истина);
	Структура.Вставить("Информация",      "");
	
	Команды = Новый ТаблицаЗначений;
	Команды.Колонки.Добавить("Идентификатор");
	Команды.Колонки.Добавить("Представление");
	Команды.Колонки.Добавить("Модификатор");
	Команды.Колонки.Добавить("ПоказыватьОповещение");
	Команды.Колонки.Добавить("Использование");
	
	Структура.Вставить("Команды", Команды);
	
	Назначение = Новый Массив;
	Назначение.Добавить("Документ.НачислениеВознаграждения");
	
	Структура.Вставить("Назначение", Назначение);
	
	Возврат Структура;
	
КонецФункции



