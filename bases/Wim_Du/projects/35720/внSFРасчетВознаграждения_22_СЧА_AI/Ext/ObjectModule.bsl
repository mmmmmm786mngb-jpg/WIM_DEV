	//ДатаНачала = НачалоГода(СтруктураПараметров.Дата);
	//ДатаНачала = ?(СтруктураПараметров.ДатаНачалаДУ>(ДатаНачала), СтруктураПараметров.ДатаНачалаДУ, ДатаНачала);
