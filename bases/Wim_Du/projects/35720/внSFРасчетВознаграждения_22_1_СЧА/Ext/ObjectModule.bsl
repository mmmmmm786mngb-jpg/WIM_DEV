Функция СправкаРасчет(ПоказателиСправки)
	ТабДокументШапка = Новый ТабличныйДокумент;
	ТабДокументТело  = Новый ТабличныйДокумент;
	ТабДокументПодвал  = Новый ТабличныйДокумент;
	
	Макет = ПолучитьМакет("СправкаРасчет");
	ОбластьЗаголовок  = Макет.ПолучитьОбласть("Заголовок");
	ОбластьЗаголовок1 = Макет.ПолучитьОбласть("Заголовок1");
	ОбластьТело       = Макет.ПолучитьОбласть("ТелоРасчета");
	ОбластьПодвал     = Макет.ПолучитьОбласть("Подвал2");
	//ОбластьПодвал1    = Макет.ПолучитьОбласть("Подвал1");
	ОбластьЗаголовок2 = Макет.ПолучитьОбласть("Заголовок2");
	
	ОбластьЗаголовок.Параметры.ДатаНомерДоговораДУ = "№"+ПоказателиСправки.НомерДоговораДУ+ " от "+Формат(ПоказателиСправки.ДатаДоговораДУ, "ДФ='dd MMMM yyyy'")+"г.";
	ТабДокументШапка.Вывести(ОбластьЗаголовок);
	
	ОбластьЗаголовок2.Параметры.ПериодРасчета = "за период управления с "+ Формат(ПоказателиСправки.НачалоРасчета, "ДФ='dd MMMM yyyy'")+"г." + " по "+Формат(ПоказателиСправки.ОкончаниеРасчета, "ДФ='dd MMMM yyyy'")+"г.";
	ОбластьЗаголовок2.Параметры.П000 = ПоказателиСправки.П000;
	СуммаПлата = Формат(ПоказателиСправки.П000, "ЧДЦ=2; ЧН=0,00") + " рублей (" + РаботаСКурсамиВалют.СформироватьСуммуПрописью(ОКР(ПоказателиСправки.П000, 2), Константы.ВалютаРегламентированногоУчета.Получить(), ЛОЖЬ) + ")";
	ОбластьЗаголовок2.Параметры.ПлатаЗаУправление = "Плата за управлнеи за период с "+ Формат(ПоказателиСправки.НачалоРасчета, "ДФ='dd MMMM yyyy'")+"г." 
	+ " по "+Формат(ПоказателиСправки.ОкончаниеРасчета, "ДФ='dd MMMM yyyy'")+"г. составила: " + СуммаПлата;
	ТабДокументТело.Вывести(ОбластьЗаголовок2);
	
	ОбластьЗаголовок1.Параметры.ПериодРасчета = "за период управления с "+ Формат(ПоказателиСправки.НачалоРасчета, "ДФ='dd MMMM yyyy'")+"г." + " по "+Формат(ПоказателиСправки.ОкончаниеРасчета, "ДФ='dd MMMM yyyy'")+"г.";
	ТабДокументТело.Вывести(ОбластьЗаголовок1);
	
	//ОбластьПодвал.Параметры.Клиент      = "Клиент: "     +ПоказателиСправки.ДоговорДУ.Клиент.НаименованиеПолное;
