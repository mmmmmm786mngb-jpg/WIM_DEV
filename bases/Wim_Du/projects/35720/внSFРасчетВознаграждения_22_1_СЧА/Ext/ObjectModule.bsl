	КонецПопытки;
	
	Возврат СтруктураВозврата;
КонецФункции

Функция СреднееСЧА_РСА(ДоговорДУ, ДатаНачала, ДатаОкончания, ТипДня ="КалендарныйТип" )
	СтруктураВозврата = Новый Структура;
	СтруктураВозврата.Вставить("СЧА", 0);
	СтруктураВозврата.Вставить("РСА", 0);
	СтруктураВозврата.Вставить("ТаблицаСЧА_РСА", Новый ТаблицаЗначений);
	СтруктураВозврата.Вставить("КоличествоДней", 0);
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ДоговорДУ", ДоговорДУ);
	Запрос.УстановитьПараметр("ДатаНачала", ДатаНачала);
	Запрос.УстановитьПараметр("ДатаОкончания", ДатаОкончания);
	ТекстЗапроса = 
	"ВЫБРАТЬ
	|	КалендарныеГрафики.ДатаГрафика КАК Дата
	|ИЗ
	|	РегистрСведений.КалендарныеГрафики КАК КалендарныеГрафики
	|ГДЕ
	|	КалендарныеГрафики.Календарь = ЗНАЧЕНИЕ(Справочник.Календари.РегламентированныйКалендарь)
	|	И КалендарныеГрафики.ДатаГрафика МЕЖДУ &ДатаНачала И &ДатаОкончания
	|	И КалендарныеГрафики.ДеньВключенВГрафик";
	Если ТипДня="КалендарныйТип" Тогда
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "КалендарныеГрафики.ДеньВключенВГрафик", "ИСТИНА");
	КонецЕсли;
	Запрос.Текст = ТекстЗапроса;
	ТаблицаСЧА_РСА = РегистрыСведений.РегистрРСА_СЧА.ТЗ_СЧА_РСА_НаДаты(Запрос.Выполнить().Выгрузить(), ДоговорДУ);
		
	КоличествоДней = ТаблицаСЧА_РСА.Количество();
	Если НЕ КоличествоДней=0 Тогда
		СтруктураВозврата.СЧА = ТаблицаСЧА_РСА.Итог("СЧА")/КоличествоДней;
		СтруктураВозврата.РСА = ТаблицаСЧА_РСА.Итог("РСА")/КоличествоДней;
		СтруктураВозврата.ТаблицаСЧА_РСА = ТаблицаСЧА_РСА;
		СтруктураВозврата.КоличествоДней = КоличествоДней;
	КонецЕсли;
	
	Возврат СтруктураВозврата;
КонецФункции

Процедура ИнициализироватьБухгалтерскиеИтоги(ДоговорДУ, ДатаНачала, ДатаОкончания)
	
	БухгалтерскиеИтоги = Обработки.БухгалтерскиеИтоги.Создать();
	
	Итоги = "НачальныйОстатокДт, НачальныйОстатокКт,
	|НачальныйыРазвернутыйОстатокДт, НачальныйРазвернутыйОстатокКт,
	|КонечныйОстатокДт, КонечныйОстатокКт, 
	|КонечныйРазвернутыйОстатокДт,КонечныйРазвернутыйОстатокКт,
	|ОборотДт, ОборотКт, КорОборотДт, КорОборотКт";
	
	Ресурсы = "Сумма,Количество";
	
	Группировки = "Счет, КорСчет, Субконто1, Субконто2, Субконто3";
	
	Отбор = Новый Структура;
	Отбор.Вставить("ДоговорДУ", ДоговорДУ);
	
	БухгалтерскиеИтоги.РассчитатьИтоги("Хозрасчетный", Итоги, Ресурсы, Группировки, Новый Граница(НачалоДня(ДатаНачала), ВидГраницы.Включая), Новый Граница(КонецДня(ДатаОкончания), ВидГраницы.Включая), , , , , , Отбор);
	
КонецПроцедуры

Функция ПолучитьРасходы(ДоговорДУ, ДатаНачала, ДатаОкончания)
	
	ДепозитарныеУслуги 		= БухгалтерскиеИтоги.ДО(ПланыСчетов.Хозрасчетный.ДепозитарныеУслуги);
	УслугиБанка 			= БухгалтерскиеИтоги.ДО(ПланыСчетов.Хозрасчетный.УслугиБанка);
	УслугиСпецдепозитария 	= БухгалтерскиеИтоги.ДО(ПланыСчетов.Хозрасчетный.УслугиСпецдепозитария);
	ПрочиеРасходыПрочие 	= БухгалтерскиеИтоги.ДО(ПланыСчетов.Хозрасчетный.ПрочиеРасходыПрочие);
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	
	"ВЫБРАТЬ
	|	ЕСТЬNULL(СУММА(ВЫБОР
	|				КОГДА ДенежныеСредстваУправленческий.СтатьяДДС = &КомиссияБиржи
	|					ТОГДА ДенежныеСредстваУправленческий.Сумма
	|				ИНАЧЕ 0
	|			КОНЕЦ), 0) КАК КомиссияБиржи,
	|	ЕСТЬNULL(СУММА(ВЫБОР
	|				КОГДА ДенежныеСредстваУправленческий.СтатьяДДС В (&КомиссияБрокера, &КомиссияПосредника)
	|					ТОГДА ДенежныеСредстваУправленческий.Сумма
	|				ИНАЧЕ 0
	|			КОНЕЦ), 0) КАК КомиссияБрокера
	|ИЗ
	|	РегистрНакопления.ДенежныеСредстваУправленческий КАК ДенежныеСредстваУправленческий
	|ГДЕ
	|	ДенежныеСредстваУправленческий.Период МЕЖДУ &НачалоПериода И &КонецПериода
	|	И ДенежныеСредстваУправленческий.ДоговорДУ = &ДоговорДУ
	|	И ДенежныеСредстваУправленческий.СтатьяДДС В (&КомиссияБиржи, &КомиссияБрокера, &КомиссияПосредника)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Хозрасчетный.Ссылка КАК Счет
	|ПОМЕСТИТЬ Счета
	|ИЗ
	|	ПланСчетов.Хозрасчетный КАК Хозрасчетный
	|ГДЕ
	|	Хозрасчетный.Ссылка В ИЕРАРХИИ(&СписокСчетов)
	|	И Хозрасчетный.ЗапретитьИспользоватьВПроводках = ЛОЖЬ
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Счет
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ХозрасчетныйОстатки.Счет КАК Счет,
	|	NULL КАК ДатаРегистратора,
	|	ХозрасчетныйОстатки.СуммаОстатокКт КАК Сумма
	|ПОМЕСТИТЬ Остатки
	|ИЗ
	|	РегистрБухгалтерии.Хозрасчетный.Остатки(
	|			&КонецПериодаГраница,
	|			Счет В
	|				(ВЫБРАТЬ
	|					Счета.Счет
	|				ИЗ
	|					Счета КАК Счета),
	|			,
	|			ДоговорДУ = &ДоговорДУ) КАК ХозрасчетныйОстатки
	|ГДЕ
	|	ХозрасчетныйОстатки.Счет <> ЗНАЧЕНИЕ(ПланСчетов.Хозрасчетный.РасчетыПоНачисленномуДоходу)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ХозрасчетныйОстатки.Счет,
	|	ХозрасчетныйОстатки.Субконто3.Дата,
	|	ХозрасчетныйОстатки.СуммаОстатокКт
	|ИЗ
	|	РегистрБухгалтерии.Хозрасчетный.Остатки(&КонецПериодаГраница, Счет = ЗНАЧЕНИЕ(ПланСчетов.Хозрасчетный.РасчетыПоНачисленномуДоходу), , ДоговорДУ = &ДоговорДУ) КАК ХозрасчетныйОстатки
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВЫБОР
	|		КОГДА Счета.Счет = ЗНАЧЕНИЕ(ПланСчетов.Хозрасчетный.РасчетыПоНачисленномуДоходу)
	|			ТОГДА ""Начисление % от средней СЧА""
	|		ИНАЧЕ Счета.Счет.Наименование
	|	КОНЕЦ КАК СчетПредставление,
	|	Остатки.ДатаРегистратора КАК ДатаРегистратора,
	|	ЕСТЬNULL(Остатки.Сумма, 0) КАК Сумма
	|ИЗ
	|	Счета КАК Счета
	|		ЛЕВОЕ СОЕДИНЕНИЕ Остатки КАК Остатки
	|		ПО Счета.Счет = Остатки.Счет
	|ГДЕ
	|	ЕСТЬNULL(Остатки.Сумма, 0) <> 0";
	
	Запрос.УстановитьПараметр("ДоговорДУ", ДоговорДУ);
	Запрос.УстановитьПараметр("КомиссияБиржи", ПредопределенноеЗначение("Справочник.СтатьиДвиженияДенежныхСредств.КомиссияБиржи"));
	Запрос.УстановитьПараметр("КомиссияБрокера", ПредопределенноеЗначение("Справочник.СтатьиДвиженияДенежныхСредств.КомиссияБрокера"));
	Запрос.УстановитьПараметр("КомиссияПосредника", ПредопределенноеЗначение("Справочник.СтатьиДвиженияДенежныхСредств.КомиссияПосредника"));
	Запрос.УстановитьПараметр("НачалоПериода", ДатаНачала);
	Запрос.УстановитьПараметр("КонецПериода", КонецДня(ДатаОкончания));
	Запрос.УстановитьПараметр("КонецПериодаГраница", Новый Граница(КонецДня(ДатаОкончания), ВидГраницы.Включая));
	
	СписокСчетов = Новый Массив;
	СписокСчетов.Добавить(ПланыСчетов.Хозрасчетный.НачисленныеВознаграждения);
	СписокСчетов.Добавить(ПланыСчетов.Хозрасчетный.ОбязательноеСтрахование);
	СписокСчетов.Добавить(ПланыСчетов.Хозрасчетный.ПрочиеВзаиморасчеты);
	СписокСчетов.Добавить(ПланыСчетов.Хозрасчетный.НДФЛ);
	// IMAPPS-13736 ++
	СписокСчетов.Добавить(ПланыСчетов.Хозрасчетный.РасчетыПоНачисленномуДоходу);
	// IMAPPS-13736 --
	
	Запрос.УстановитьПараметр("СписокСчетов", СписокСчетов);
	
	ОбщегоНазначенияДУ.ДобавитьВЛогОтладки(Запрос, "Отчет управляющего ДУ, согласно 482П - Раздел 6.1 - Комиссии");
	
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	
	КомиссияБиржи = 0;
	КомиссияБрокера = 0;
	
	Комиссии = РезультатЗапроса[0].Выгрузить();
	
	Если Комиссии.Количество() > 0 Тогда
		
		КомиссияБиржи = Комиссии[0].КомиссияБиржи;
		КомиссияБрокера = Комиссии[0].КомиссияБрокера;
		
	КонецЕсли; 
	
	//vtb 29.06
	Запрос = новый запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	ХозрасчетныйОбороты.СуммаОборотДт как ИныеКомиссии
	|ИЗ
	|	РегистрБухгалтерии.Хозрасчетный.Обороты(
	|			&НачалоПериода,
	|			&КонецПериода,
	|			,
	|			Счет = ЗНАЧЕНИЕ(ПланСчетов.Хозрасчетный.ПрочиеРасходыПрочие),
	|			,
	|			ДоговорДУ = &ДоговорДУ
	|				И Субконто1 В (&СтатьиРасходов),
	|			,
	|			) КАК ХозрасчетныйОбороты";
	
	СтатьиРасходов = Новый Массив; 	
	СтатьиРасходов.Добавить(ПредопределенноеЗначение("Справочник.СтатьиДоходовИРасходов.ОбязательноеСтрахование"));
	СтатьиРасходов.Добавить(ПредопределенноеЗначение("Справочник.СтатьиДоходовИРасходов.УслугиАудитора"));
	
	Запрос.УстановитьПараметр("ДоговорДУ", ДоговорДУ);
	Запрос.УстановитьПараметр("НачалоПериода", НачалоДня(ДатаНачала));
	Запрос.УстановитьПараметр("КонецПериода", КонецДня(ДатаОкончания));
	Запрос.УстановитьПараметр("СтатьиРасходов", СтатьиРасходов);
	
	
	ПрочиеРасходыПрочие = 0;
	ИныеКомиссии = Запрос.Выполнить().Выгрузить();	
	
	Если ИныеКомиссии.Количество() > 0 Тогда
		ПрочиеРасходыПрочие = ИныеКомиссии[0].ИныеКомиссии;
	КонецЕсли; 
	
	
	ДанныеРаздела = Новый Структура;
	ДанныеРаздела.Вставить("КомиссияБиржи", КомиссияБиржи);
	ДанныеРаздела.Вставить("КомиссияБрокера", КомиссияБрокера);
	ДанныеРаздела.Вставить("ДепозитарныеУслуги", ДепозитарныеУслуги);
	ДанныеРаздела.Вставить("УслугиБанка", УслугиБанка);
	ДанныеРаздела.Вставить("УслугиСпецдепозитария", УслугиСпецдепозитария);
	ДанныеРаздела.Вставить("ПрочиеРасходыПрочие", ПрочиеРасходыПрочие);
	ДанныеРаздела.Вставить("Обязательства", РезультатЗапроса[3].Выгрузить());
	
		ИтогоСумма = 
	ДанныеРаздела.КомиссияБиржи + 
	ДанныеРаздела.КомиссияБрокера + 
	ДанныеРаздела.ДепозитарныеУслуги +
	ДанныеРаздела.УслугиБанка +
	ДанныеРаздела.УслугиСпецдепозитария +
	ДанныеРаздела.ПрочиеРасходыПрочие;

	Возврат ИтогоСумма;
	
КонецФункции


Функция ПолучитьПодписанта(УК)
	Запрос = Новый Запрос();
	Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	КонтактныеЛица.Ссылка
	|ИЗ
	|	Справочник.КонтактныеЛица КАК КонтактныеЛица
	|ГДЕ
	|	КонтактныеЛица.Владелец = &УК
	|	И КонтактныеЛица.ПометкаУдаления = ЛОЖЬ
	|	И КонтактныеЛица.Роль = &Роль";
	Запрос.УстановитьПараметр("УК", УК);
	Запрос.УстановитьПараметр("Роль", Справочники.РолиКонтактныхЛиц.РуководительПодразделения);
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат СокрЛП(Выборка.Ссылка.Должность) + ": " + Выборка.Ссылка.Фамилия + " " + Лев(Выборка.Ссылка.Имя, 1) + "." + Лев(Выборка.Ссылка.Отчество, 1) + ".";
	Иначе
		Возврат "";
	КонецЕсли;
КонецФункции	

// FVasiliev IMAPPS-35828 12.03.2026. 
#Область IMAPPS35828
	
// Функция получает размер вознаграждения
//
// Параметры:
//  ПИФ - фонд
//  Дата - дата
//  МассивПараметровФонда  - массив из параметров, для которых необходимо рассчитать вознаграждения
//  Базис - базис
//  СпособНачисления - способ начисления (значение по-умолчанию: Неопределено)
//
// Возвращаемое значение:
//  РазмерыВознаграждения = соответствие, в которое передаются размеры вознаграждений
//
Функция ПолучитьРазмерВознаграждения(ДоговорДУ, Дата, Базис, ЗначениеПараметраДоговораДУ = Неопределено)  
	
	СоотВознаграждений = Новый Соответствие;
	
	ФиксСумма = Ложь;
	
	ВалютаРеглУчета = ОбщегоНазначенияДУ.ВалютаРеглУчета(ДоговорДУ);
	
	КурсКратностьРегл = МодульВалютногоУчета.ПолучитьКурсВалюты(ВалютаРеглУчета, ВалютаРеглУчета, Дата);
	
	МассивПараметровДоговораДУ = Новый Массив;
	МассивПараметровДоговораДУ.Добавить(ПланыВидовХарактеристик.ПараметрыДоговораДУ.ВеличинаВознагражденияУК);
	
	Для каждого СтрокаМассива из МассивПараметровДоговораДУ Цикл
		СоотВознаграждений.Вставить(СтрокаМассива, 0);
	КонецЦикла;
	
	Для каждого СтрокаМассива из МассивПараметровДоговораДУ Цикл
		Если ЗначениеПараметраДоговораДУ = Неопределено Тогда
			Значение = УправлениеПараметрамиДоговораДУ.ПолучитьПараметрДоговораДУ(ДоговорДУ, СтрокаМассива, Дата);
		Иначе
			Значение = ЗначениеПараметраДоговораДУ;
		КонецЕсли;
		
		// может у нас от старых доков просто число пришло
		Если ТипЗнч(Значение) = Тип("Число") Тогда
			СоотВознаграждений.Вставить(СтрокаМассива,Число(Значение));
			Продолжить;
		КонецЕсли;
		
		МассивИзСтрокЛесенки = УправлениеПараметрамиДоговораДУ.РазобратьЗначениеВознаграждения(Значение);
		
		Для каждого СтрокаЛесенки из МассивИзСтрокЛесенки Цикл
			
			Добавляем = Ложь;
			Прерываем = Ложь;
			
			Если СтрокаЛесенки.ТипСравнения = "<" Тогда
				Если Базис < СтрокаЛесенки.Значение Тогда
					Добавляем = Истина;
					Прерываем = Истина;										
				КонецЕсли;
			ИначеЕсли СтрокаЛесенки.ТипСравнения = ">=" Тогда
				Если Базис >= СтрокаЛесенки.Значение Тогда
					Добавляем = Истина;
					Прерываем = Ложь;		
				КонецЕсли;
			Иначе
				Если Базис > СтрокаЛесенки.Значение Тогда
					Добавляем = Истина;
					Прерываем = Ложь;		
				КонецЕсли;
			КонецЕсли;
			
			Если Добавляем Тогда
				Если СтрокаЛесенки.Суммой Тогда
					
					Если СтрокаЛесенки.Свойство("Валюта") и СтрокаЛесенки.Валюта <> ВалютаРеглУчета Тогда
						КурсКратность = МодульВалютногоУчета.ПолучитьКурсВалюты(ВалютаРеглУчета, СтрокаЛесенки.Валюта, Дата);
						
						СуммаВознаграждения = Окр(МодульВалютногоУчета.ПересчитатьИзВалютыВВалюту(СтрокаЛесенки.РазмерВознаграждения,
						СтрокаЛесенки.Валюта, ВалютаРеглУчета, 
						КурсКратность.Курс, КурсКратностьРегл.Курс,
						КурсКратность.Кратность, КурсКратностьРегл.Кратность), 2);
					Иначе
						СуммаВознаграждения = СтрокаЛесенки.РазмерВознаграждения;
					КонецЕсли;
					
					СоотВознаграждений.Вставить(СтрокаМассива, Новый Структура("РазмерВознаграждения",СуммаВознаграждения));
					
				Иначе
					СоотВознаграждений.Вставить(СтрокаМассива, СтрокаЛесенки.РазмерВознаграждения);
				КонецЕсли;
			КонецЕсли;
			
			Если Прерываем Тогда
				Прервать;
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЦикла;
	
	Возврат СоотВознаграждений;
	
КонецФункции // ПолучитьРазмерВознаграждения()

Функция ПолучитьНачалоПериодаРасчета(Период, Дата)
	
	СтруктураОтвета = Новый Структура("ДатаНачала, ДатаОкончания", Дата(1,1,1), Дата(1,1,1));
	
	Если Период=Перечисления.Периодичность.Месяц Тогда
		
		СтруктураОтвета.ДатаНачала = НачалоМесяца(Дата);
		СтруктураОтвета.ДатаОкончания = КонецМесяца(Дата); 
		Возврат СтруктураОтвета;
		
	ИначеЕсли Период=Перечисления.Периодичность.Квартал Тогда
		
		СтруктураОтвета.ДатаНачала = НачалоКвартала(Дата);
		СтруктураОтвета.ДатаОкончания = КонецКвартала(Дата); 
		Возврат СтруктураОтвета;
		
	ИначеЕсли Период=Перечисления.Периодичность.Декада Тогда
		
		Если Месяц(Дата) >= 9 Тогда
			
			СтруктураОтвета.ДатаНачала = ДобавитьМесяц(НачалоГода(Дата), 9);
			СтруктураОтвета.ДатаОкончания = КонецГода(Дата); 
			Возврат СтруктураОтвета;
			
		ИначеЕсли Месяц(Дата) >= 5 Тогда
			
			СтруктураОтвета.ДатаНачала = ДобавитьМесяц(НачалоГода(Дата), 5);
			СтруктураОтвета.ДатаОкончания = КонецМесяца(ДобавитьМесяц(НачалоГода(Дата), 8)); 
			Возврат СтруктураОтвета;
			
		Иначе
			
			СтруктураОтвета.ДатаНачала = НачалоГода(Дата);
			СтруктураОтвета.ДатаОкончания = КонецМесяца(ДобавитьМесяц(НачалоГода(Дата), 4)); 
			Возврат СтруктураОтвета;			
			
		КонецЕсли;		
		
	ИначеЕсли Период=Перечисления.Периодичность.Полугодие Тогда
		
		Если Месяц(Дата) >= 7 Тогда
			
			СтруктураОтвета.ДатаНачала = ДобавитьМесяц(НачалоГода(Дата), 7);
			СтруктураОтвета.ДатаОкончания = КонецГода(Дата);
			Возврат СтруктураОтвета;		
			
		Иначе
			
			СтруктураОтвета.ДатаНачала = НачалоГода(Дата);
			СтруктураОтвета.ДатаОкончания = КонецМесяца(ДобавитьМесяц(НачалоГода(Дата), 6));
			Возврат СтруктураОтвета;	
			
		КонецЕсли;
	ИначеЕсли Период=Перечисления.Периодичность.Год Тогда
		
		СтруктураОтвета.ДатаНачала = НачалоГода(Дата);
		СтруктураОтвета.ДатаОкончания =КонецГода(Дата);
		Возврат СтруктураОтвета;	

	Иначе
		
				СтруктураОтвета.ДатаНачала = НачалоКвартала(Дата);
		СтруктураОтвета.ДатаОкончания = КонецКвартала(Дата); 
		Возврат СтруктураОтвета;

	КонецЕсли;
	
КонецФункции

Функция ГраницыПериодаРасчетаНачало(СтруктураПараметров)
	СтруктураВозврата = Новый Структура;
	СтруктураВозврата.Вставить("РасчетнаяДатаНачала", Дата(1, 1, 1));
	СтруктураВозврата.Вставить("РасчетнаяДатаОкончания", Дата(1, 1, 1));
	СтруктураВозврата.Вставить("ПредполагаемаяДатаОкончания", Дата(1, 1, 1));
	
	СтурктураРасчета = ПолучитьНачалоПериодаРасчета(СтруктураПараметров.НастройкиАлгоритма.Периодичность, СтруктураПараметров.ДатаДокумента);
	
	РасчетнаяДатаНачала = СтурктураРасчета.ДатаНачала;
	ПредполагаемаяДатаОкончания = СтурктураРасчета.ДатаОкончания;
	
	Если ЗначениеЗаполнено(СтруктураПараметров.СтруктураДоговораДУ.ДатаОкончания) Тогда
		РасчетнаяДатаОкончания = КонецДня(Мин(СтруктураПараметров.ДатаДокумента, СтруктураПараметров.СтруктураДоговораДУ.ДатаОкончания));
	Иначе
		РасчетнаяДатаОкончания = КонецДня(СтруктураПараметров.ДатаДокумента);
	КонецЕсли;
	
	Если РасчетнаяДатаНачала > РасчетнаяДатаОкончания Тогда
		
		//Заполнение структуры возврата
		СтруктураВозврата.РасчетнаяДатаНачала    = РасчетнаяДатаНачала;
		СтруктураВозврата.РасчетнаяДатаОкончания = РасчетнаяДатаНачала;
		СтруктураВозврата.ПредполагаемаяДатаОкончания = РасчетнаяДатаНачала;
		
		
		Возврат СтруктураВозврата;
		
	КонецЕсли;
	
	//Заполнение структуры возврата
	СтруктураВозврата.РасчетнаяДатаНачала    = РасчетнаяДатаНачала;
	СтруктураВозврата.РасчетнаяДатаОкончания = РасчетнаяДатаОкончания;
	СтруктураВозврата.ПредполагаемаяДатаОкончания = ПредполагаемаяДатаОкончания;
	
	
	Возврат СтруктураВозврата;
КонецФункции

Функция  НачалоРасчета(СтруктураПараметров, СтруктураПараметровДУ, ПользовательскиеНастройки, ПВХ)

	//Определение границ периода
	СтруктураПараметровПериода = Новый Структура;
	СтруктураПараметровПериода.Вставить("ДатаДокумента"     , СтруктураПараметров.Дата); 
	СтруктураПараметровПериода.Вставить("СтруктураДоговораДУ", СтруктураПараметровДУ);
	СтруктураПараметровПериода.Вставить("НастройкиАлгоритма", ПользовательскиеНастройки.Значения);
	
	
	СтруктураПериодаРасчета = ГраницыПериодаРасчетаНачало(СтруктураПараметровПериода);
	НачалоПериода = СтруктураПериодаРасчета.РасчетнаяДатаНачала;
	КонецПериода  = СтруктураПериодаРасчета.РасчетнаяДатаОкончания;
    ПредполагаемаяДатаРасчета = СтруктураПериодаРасчета.ПредполагаемаяДатаОкончания;
	
	ВеличинаВознаграждения = УправлениеПараметрамиДоговораДУ.ПолучитьПараметрДоговораДУ(СтруктураПараметров.ДоговорДУ, ПВХ.ВеличинаВознагражденияУК, СтруктураПараметров.Дата);
	
	РазмерыВознаграждения = ПолучитьРазмерВознаграждения(СтруктураПараметров.ДоговорДУ, СтруктураПараметров.Дата, 0, ВеличинаВознаграждения);
	
	Ответ = РазмерыВознаграждения.Получить(ПВХ.ВеличинаВознагражденияУК);
	
	Если ТипЗнч(Ответ) = ТИП("Число") Тогда
		РезультирующаяСумма = Ответ; 
	Иначе
		РезультирующаяСумма	= Ответ.РазмерВознаграждения;
	КонецЕсли;
	ВсегоДней = (ПредполагаемаяДатаРасчета - НачалоПериода) / 60 / 60 / 24;
	ПрошлоДней = (КонецПериода - НачалоПериода) / 60 / 60 / 24;
	
	Если ВсегоДней = 0 Тогда
		РезультирующаяСумма = 0;
	Иначе
		РезультирующаяСумма = РезультирующаяСумма *  ПрошлоДней/ВсегоДней;
	КонецЕсли;
	                                               
	РезультирующаяСумма = Окр(РезультирующаяСумма,2);
	
	Возврат РезультирующаяСумма;

КонецФункции

