Функция ИнвестиционныйДоход_Базовый(СтруктураПараметров)
	//ДатаНачалаРасчета = НачалоГода(СтруктураПараметров.Дата)-1;
	//ДатаНачалаРасчета = ?(СтруктураПараметров.ДатаНачалаДУ>(ДатаНачалаРасчета), СтруктураПараметров.ДатаНачалаДУ, ДатаНачалаРасчета);
	//
	//ДатаОкончанияРасчета = КонецГода(СтруктураПараметров.Дата);
	//ДатаОкончанияРасчета = ?(ЗначениеЗаполнено(СтруктураПараметров.ДатаОкончанияДУ) и СтруктураПараметров.ДатаОкончанияДУ<ДатаОкончанияРасчета, СтруктураПараметров.ДатаОкончанияДУ, ДатаОкончанияРасчета);
	
	//СтруктураРасчетаБазовойРСА = РасчетБазовойРСА(СтруктураПараметров);
	//Kmusorin  IMAPPS-7198
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗЛИЧНЫЕ ПЕРВЫЕ 1
	|	РегистрБРСАСрезПоследних.Период,
	|	РегистрБРСАСрезПоследних.БРСА
	|ИЗ
	|	РегистрСведений.РегистрБРСА.СрезПоследних(&Период, ДоговорДУ = &ДоговорДУ) КАК РегистрБРСАСрезПоследних";
	
	Запрос.УстановитьПараметр("Период", СтруктураПараметров.ДатаНачалаРасчета);
	Запрос.УстановитьПараметр("ДоговорДУ", СтруктураПараметров.ДоговорДУ);
	
	Выборка = Запрос.Выполнить().Выбрать();
	БазоваяРСА = 0;
	Если Выборка.Следующий() Тогда
		Если НЕ ЗначениеЗаполнено(СтруктураПараметров.ДоговорДУ.ДатаВозобновленияУправления) ИЛИ Выборка.Период > СтруктураПараметров.ДоговорДУ.ДатаВозобновленияУправления Тогда
			БазоваяРСА =РегистрыСведений.РегистрБРСА.ЗначенияБРСА(СтруктураПараметров.ДатаНачалаРасчета, СтруктураПараметров.ДоговорДУ);
		КонецЕсли;
	 
	КонецЕсли; 
	//Kmusorin  IMAPPS-7198	
	//РСА_Начало    = СтруктураРасчетаБазовойРСА.БазоваяРСА;
	РСА_Окончание = РегистрыСведений.РегистрРСА_СЧА.ЗначенияСЧА_РСА(СтруктураПараметров.ДатаОкончанияРасчета, СтруктураПараметров.ДоговорДУ).СЧА;
	
	ПараметрыДСиЦБсИП = Новый Структура;
	//Kmusorin  IMAPPS-7198	
	//ПараметрыДСиЦБсИП.Вставить("ДатаНачала", СтруктураПараметров.ДатаНачалаРасчета+1);
	ПараметрыДСиЦБсИП.Вставить("ДатаНачала", СтруктураПараметров.ДатаНачалаРасчета);
	//Kmusorin  IMAPPS-7198
	
	ПараметрыДСиЦБсИП.Вставить("ДатаОкончания", СтруктураПараметров.ДатаОкончанияРасчета);
	ПараметрыДСиЦБсИП.Вставить("ДоговорДУ", СтруктураПараметров.ДоговорДУ);
	
	
	СтруктураДСиЦБсИП = СуммыДСиЦБсИП(ПараметрыДСиЦБсИП);
	
	ПриростРСА = (РСА_Окончание-БазоваяРСА)+(СтруктураДСиЦБсИП.СуммаИзъятия-СтруктураДСиЦБсИП.СуммаВложения);
	
	СтруктураВозврата = Новый Структура;
	СтруктураВозврата.Вставить("РСА_Начало"   , БазоваяРСА);
	СтруктураВозврата.Вставить("РСА_Окончание", РСА_Окончание);
	СтруктураВозврата.Вставить("СуммаВложения", СтруктураДСиЦБсИП.СуммаВложения);
	СтруктураВозврата.Вставить("СуммаИзъятия" , СтруктураДСиЦБсИП.СуммаИзъятия);
	СтруктураВозврата.Вставить("ПриростРСА"   , ПриростРСА);
	//Показатели расчета базовой
	//СтруктураВозврата.Вставить("БазоваяРСА_Расчетная", СтруктураРасчетаБазовойРСА.БазоваяРСА_Расчетная);
	//СтруктураВозврата.Вставить("РСА_Минус_Управление", СтруктураРасчетаБазовойРСА.РСА_Минус_Управление);
	СтруктураВозврата.Вставить("БазоваяРСА"          , БазоваяРСА);
	Возврат СтруктураВозврата;
КонецФункции

Функция РасчетБРСА(СтруктураПараметров)
	
	РСА_конец = РегистрыСведений.РегистрРСА_СЧА.ЗначенияСЧА_РСА(СтруктураПараметров.ДатаОкончанияРасчета, СтруктураПараметров.ДоговорДУ).СЧА;
	
	//Kmusorin  IMAPPS-7198  убрал повторный вызов ф-ции расчета суммы вводов с аналогичными параметрами. Первичный вызов в функции ИнвестиционныйДоход_Базовый	
	//ПараметрыДСиЦБсИП = Новый Структура;
	//ПараметрыДСиЦБсИП.Вставить("ДатаНачала", СтруктураПараметров.ДатаНачалаРасчета+1);
	//ПараметрыДСиЦБсИП.Вставить("ДатаОкончания", СтруктураПараметров.ДатаОкончанияРасчета);
	//ПараметрыДСиЦБсИП.Вставить("ДоговорДУ", СтруктураПараметров.ДоговорДУ);
	
	//СтруктураДСиЦБсИП = СуммыДСиЦБсИП(ПараметрыДСиЦБсИП);
	//Kmusorin  IMAPPS-7198	
	БРСА_Расчетная         = СтруктураПараметров.БРСА_Прошлая+СтруктураДСиЦБсИП.СуммаВложения-СтруктураДСиЦБсИП.СуммаИзъятия;
	РСАМинусВознаграждения = РСА_Конец-СтруктураПараметров.ВознаграждениеMF-СтруктураПараметров.ВознаграждениеSF;
	
	Возврат Макс(0, БРСА_Расчетная, РСАМинусВознаграждения);
	
КонецФункции


Функция КоличествоМесяцевВПериоде(Период)
	Если Период=Перечисления.Периодичность.Месяц Тогда
		Возврат 1;
	ИначеЕсли Период=Перечисления.Периодичность.Квартал Тогда
		Возврат 3;
	ИначеЕсли Период=Перечисления.Периодичность.Декада Тогда
		Возврат 4;
	ИначеЕсли Период=Перечисления.Периодичность.Полугодие Тогда
		Возврат 6;
	ИначеЕсли Период=Перечисления.Периодичность.Год Тогда
		Возврат 12;
	Иначе
		Возврат 3; //По умолчанию используем период Квартал
	КонецЕсли;
КонецФункции

Функция ГраницыПериодаРасчета(СтруктураПараметров)
	СтруктураВозврата = Новый Структура;
	СтруктураВозврата.Вставить("РасчетнаяДатаНачала", Дата(1, 1, 1));
	СтруктураВозврата.Вставить("РасчетнаяДатаОкончания", Дата(1, 1, 1));
	СтруктураВозврата.Вставить("КоличествоДнейВГоду", 0);
	КоличествоМесяцевВПериоде = КоличествоМесяцевВПериоде(СтруктураПараметров.НастройкиАлгоритма.Периодичность);
	//СтруктураДоговораДУ = ОбщегоНазначения.ПолучитьЗначенияРеквизитов(СтруктураПараметров.ДоговорДУ, "ДатаВводаСредствВДУ, ДатаНачала, ДатаОкончания");
	//Определение начала периода расчета
	
	//Корректировка по типу периода
	Если СтруктураПараметров.НастройкиАлгоритма.ТипПериода="Календарный" Тогда
		//kmusorin IMAPPS-7198		
		//НачальнаяДата    =  НачалоГода(СтруктураПараметров.ДатаДокумента);
		НачальнаяДата = ?(ЗначениеЗаполнено(СтруктураПараметров.СтруктураДоговораДУ.ДатаВозобновленияУправления),СтруктураПараметров.СтруктураДоговораДУ.ДатаВозобновленияУправления,НачалоГода(СтруктураПараметров.ДатаДокумента));
		//kmusorin IMAPPS-7198		
	Иначе //Инвестиционный
		Если СтруктураПараметров.НастройкиАлгоритма.ДатаНачалаРасчета="ДатаПодписанияДоговора" Тогда
			НачальнаяДата = СтруктураПараметров.СтруктураДоговораДУ.ДатаНачала;   
		Иначе
			НачальнаяДата = СтруктураПараметров.СтруктураДоговораДУ.ДатаВводаСредствВДУ; 
		КонецЕсли;
	КонецЕсли;
	
	//НачальнаяДата = ?(ЗначениеЗаполнено(СтруктураПараметров.НастройкиАлгоритма.ДатаНачалаРасчета), СтруктураПараметров.НастройкиАлгоритма.ДатаНачалаРасчета, СтруктураПараметров.ДатаВводаСредствВДУ);
	
	КоличествоМесяцев = ОбщегоНазначенияДУ.КоличествоПериодов(НачальнаяДата, СтруктураПараметров.ДатаДокумента, "Месяц")-1;
	КоличествоКварталов = ОбщегоНазначенияДУ.КоличествоПериодов(НачальнаяДата, СтруктураПараметров.ДатаДокумента, "Квартал");
	//Если День(НачальнаяДата)>День(СтруктураПараметров.ДатаДокумента) Тогда
	//	КоличествоМесяцев=КоличествоМесяцев-1;
	//КонецЕсли;
#Область kmusorin_IMAPPS_7198	
	////kmusorin IMAPPS-7198	
	////ПрошедшиеПериоды  = Цел(КоличествоМесяцев/КоличествоМесяцевВПериоде)*КоличествоМесяцевВПериоде;
	//ПрошедшиеПериоды  = КоличествоКварталов*КоличествоМесяцевВПериоде;
	////РасчетнаяДатаНачала = НачалоДня(ОбщегоНазначенияДУ.ДобавитьКДате(НачальнаяДата, "Месяц", ПрошедшиеПериоды));
	//Если СтруктураПараметров.СтруктураДоговораДУ.ДатаВозобновленияУправления <> Дата(1,1,1) И ПрошедшиеПериоды <= КоличествоМесяцевВПериоде Тогда
	//	
	//	РасчетнаяДатаНачала = НачальнаяДата;
	//	
	//Иначе 
	//	//РасчетнаяДатаНачала = НачалоДня(ОбщегоНазначенияДУ.ДобавитьКДате(НачалоМесяца(НачальнаяДата), "Месяц", ПрошедшиеПериоды));
	//	
	//	РасчетнаяДатаНачала = НачалоДня(НачалоКвартала(СтруктураПараметров.ДатаДокумента));
	//	
	//	//РасчетнаяДатаНачала = НачальнаяДата;
	//	
	//КонецЕсли;	
	////kmusorin IMAPPS-7198
#КонецОбласти

	// MPazhukov IMAPPS-9987
	// Сделаное "kmusorin IMAPPS-7198" закоментировано, смысл не понятен
	ПрошедшиеПериоды  = Цел(КоличествоМесяцев/КоличествоМесяцевВПериоде)*КоличествоМесяцевВПериоде;
	РасчетнаяДатаНачала = НачалоДня(ОбщегоНазначенияДУ.ДобавитьКДате(НачальнаяДата, "Месяц", ПрошедшиеПериоды));
	// MPazhukov IMAPPS-9987
	
	ПрошедшиеПериоды  = КоличествоКварталов*КоличествоМесяцевВПериоде;
	
	// AKudryashov IMAPPS-10791
	Если СтруктураПараметров.СтруктураДоговораДУ.ДатаВозобновленияУправления <> Дата(1,1,1) И ПрошедшиеПериоды <= КоличествоМесяцевВПериоде Тогда
		РасчетнаяДатаНачала = НачальнаяДата;	
