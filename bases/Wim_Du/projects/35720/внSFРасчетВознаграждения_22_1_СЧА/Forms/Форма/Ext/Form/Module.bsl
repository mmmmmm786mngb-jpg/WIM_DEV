
&НаСервере
Функция ВыполнитьРасчетНаСервере()
	
	//""
	ЭтаОбработка = РеквизитФормыВЗначение("Объект");
	СтруктураПараметров = Новый Структура;
	СтруктураПараметров.Вставить("ДоговорДУ", ДоговорДУ);
	СтруктураПараметров.Вставить("Дата",Дата);
	
	ПользовательскиеНастройки = ДоговорКонтрагента.НастройкиАлгоритма2.Получить();
	СтруктураОтвета = ЭтаОбработка.РезультатРасчета(ПользовательскиеНастройки, СтруктураПараметров);
	Ответ = СтруктураОтвета.СправкаРасчет.Получить();

	ТабДок = Новый ТабличныйДокумент;
	ТабДок.Вывести(Ответ.ШапкаРасчет); 
	ТабДок.Вывести(Ответ.ТелоРасчет); 
	ТабДок.Вывести(Ответ.ПодвалРасчет);
	Возврат ТабДок;
КонецФункции

&НаКлиенте
Процедура ВыполнитьРасчет(Команда)
	ТабДок = ВыполнитьРасчетНаСервере();
	ТабДок.Показать();
КонецПроцедуры
