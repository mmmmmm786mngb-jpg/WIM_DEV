//Проверка расчета

&НаСервере
Процедура СчитатьНастройки()
	Настройки = Объект.НачислениеВознаграждения.ДоговорКонтрагента.НастройкиАлгоритма.Получить();
	
	Если Настройки.Свойство("Значения") тогда
			
		Настройки.Значения.Свойство("Периодичность"       , Объект.Периодичность);
		Настройки.Значения.Свойство("ДатаНачалаРасчета"   , Объект.ДатаНачалаРасчета);
		Настройки.Значения.Свойство("РассчитыватьБРСА"   , Объект.РассчитыватьБРСА);
		Настройки.Значения.Свойство("ТипПериода"          , Объект.ТипПериода);
		
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура Считать(Команда)
	СчитатьНастройки();
КонецПроцедуры

Процедура ЗаписатьНастройкиСервер()
	ОбъектДоговор = Объект.НачислениеВознаграждения.ДоговорКонтрагента.ПолучитьОбъект();
	ОбъектДоговор.НастройкиАлгоритма = Новый ХранилищеЗначения(Новый Структура("Значения,ЗаголовокНастроек", ПодготовитьСтруктуруХранилища(),Заголовок));
	ОбъектДоговор.Записать();
КонецПроцедуры

&НаКлиенте
Процедура Записать(Команда)
	ЗаписатьНастройкиСервер();
КонецПроцедуры

&НаСервере
Процедура ПроверитьРезультатСервер()
	Настройки = ПодготовитьСтруктуруХранилища();
	СтруктураНастроек = Новый Структура("Значения,ЗаголовокНастроек", ПодготовитьСтруктуруХранилища(), "");
	СтруктураПараметровАлгоритма = ОбщегоНазначения.ПолучитьЗначенияРеквизитов(Объект.НачислениеВознаграждения,"Дата, ДоговорДУ, ВалютаДокумента, Контрагент, ДоговорКонтрагента");
	
	//Определение границ периода
	СтруктураПараметровДУ = ОбщегоНазначения.ПолучитьЗначенияРеквизитов(Объект.НачислениеВознаграждения.ДоговорДУ, "ДатаВводаСредствВДУ, ДатаНачала, ДатаОкончания");
	СтруктураПараметровПериода = Новый Структура;
	СтруктураПараметровПериода.Вставить("ДатаДокумента"     , Объект.НачислениеВознаграждения.Дата); 
	СтруктураПараметровПериода.Вставить("СтруктураДоговораДУ", СтруктураПараметровДУ);
	СтруктураПараметровПериода.Вставить("НастройкиАлгоритма", СтруктураНастроек.Значения);
	СтруктураПериодаРасчета = ГраницыПериодаРасчета(СтруктураПараметровПериода);
    НачалоПериода    = СтруктураПериодаРасчета.РасчетнаяДатаНачала;
	ОкончаниеПериода = СтруктураПериодаРасчета.РасчетнаяДатаОкончания;
	
	//Определение расчета
	Результат = РезультатРасчета(СтруктураНастроек,СтруктураПараметровАлгоритма);	
	
	Объект.СуммаДокумента = Результат.СуммаВознаграждения;
	Объект.СтавкаВознаграждения = Результат.СтавкаВознаграждения;

КонецПроцедуры

&НаКлиенте
Процедура ПроверитьРезультат(Команда)
	ПроверитьРезультатСервер();
КонецПроцедуры



