Функция СформироватьРасшифровкуРасчету(СтруктураПоказателей, НачалоПериода, КонецПериода, ДоговорДУ, ДопДанные)
    Макет = ПолучитьМакет("СправкаРасчет2021");		
	ТабДокументПодвал = Новый ТабличныйДокумент;

	//is	
	Если СтруктураПоказателей.СтруктураСЧА.ТаблицаСЧА_РСА.Количество() > 0 тогда  
	//	Макет = ПолучитьМакет("РасшифровкаСЧА");
		ОбластьШапкаРасшифровкаСЧА = Макет.ПолучитьОбласть("ШапкаРасшифровкиСЧА");
        ОбластьСтрокаРасшифровкаСЧА = Макет.ПолучитьОбласть("СтрокаРасшифровкиСЧА");
		ОбластьПодвалСЧА = Макет.ПолучитьОбласть("ПодвалСЧА");

		ТабДокументПодвал.ВывестиГоризонтальныйРазделительСтраниц();
		ОбластьШапкаРасшифровкаСЧА.Параметры.Клиент 		= СтруктураПоказателей.ДоговорДУ.Клиент.НаименованиеПолное;
		ОбластьШапкаРасшифровкаСЧА.Параметры.ДатаНач 		= Формат(СтруктураПоказателей.ДатаНачала, "ДФ=dd.MM.yyyy"); 
