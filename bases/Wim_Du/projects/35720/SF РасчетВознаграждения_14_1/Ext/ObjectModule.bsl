Функция КоличествоМесяцевВПериоде(Период)
	Если Период=Перечисления.Периодичность.Месяц Тогда
		Возврат 1;
	ИначеЕсли Период=Перечисления.Периодичность.Квартал Тогда
		Возврат 3;
	ИначеЕсли Период=Перечисления.Периодичность.Декада Тогда
		Возврат 4;
	ИначеЕсли Период=Перечисления.Периодичность.Полугодие Тогда
		Возврат 6;
	ИначеЕсли Период=Перечисления.Периодичность.Год Тогда
		Возврат 12;
	Иначе
		Возврат 3; //По умолчанию используем период Квартал
	КонецЕсли;
КонецФункции

Функция ГраницыПериодаРасчета(СтруктураПараметров)
	СтруктураВозврата = Новый Структура;
	СтруктураВозврата.Вставить("РасчетнаяДатаНачала", Дата(1, 1, 1));
	СтруктураВозврата.Вставить("РасчетнаяДатаОкончания", Дата(1, 1, 1));
	СтруктураВозврата.Вставить("КоличествоДнейВГоду", 0);
	КоличествоМесяцевВПериоде = КоличествоМесяцевВПериоде(СтруктураПараметров.НастройкиАлгоритма.Периодичность);
	//СтруктураДоговораДУ = ОбщегоНазначения.ПолучитьЗначенияРеквизитов(СтруктураПараметров.ДоговорДУ, "ДатаВводаСредствВДУ, ДатаНачала, ДатаОкончания");
	//Определение начала периода расчета
	
	//Корректировка по типу периода
	Если СтруктураПараметров.НастройкиАлгоритма.ТипПериода="Календарный" Тогда
		НачальнаяДата    =  НачалоГода(СтруктураПараметров.ДатаДокумента);
	Иначе //Инвестиционный
		Если СтруктураПараметров.НастройкиАлгоритма.ДатаНачалаРасчета="ДатаПодписанияДоговора" Тогда
			НачальнаяДата = СтруктураПараметров.СтруктураДоговораДУ.ДатаНачала;   
		Иначе
			НачальнаяДата = СтруктураПараметров.СтруктураДоговораДУ.ДатаВводаСредствВДУ; 
		КонецЕсли;
	КонецЕсли;
	//НачальнаяДата = ?(ЗначениеЗаполнено(СтруктураПараметров.НастройкиАлгоритма.ДатаНачалаРасчета), СтруктураПараметров.НастройкиАлгоритма.ДатаНачалаРасчета, СтруктураПараметров.ДатаВводаСредствВДУ);
	
	КоличествоМесяцев = ОбщегоНазначенияДУ.КоличествоПериодов(НачальнаяДата, СтруктураПараметров.ДатаДокумента, "Месяц")-1;
	//Если День(НачальнаяДата)>День(СтруктураПараметров.ДатаДокумента) Тогда
	//	КоличествоМесяцев=КоличествоМесяцев-1;
	//КонецЕсли;
	ПрошедшиеПериоды  = Цел(КоличествоМесяцев/КоличествоМесяцевВПериоде)*КоличествоМесяцевВПериоде;
	РасчетнаяДатаНачала = НачалоДня(ОбщегоНазначенияДУ.ДобавитьКДате(НачальнаяДата, "Месяц", ПрошедшиеПериоды));
	//Корректировка дат от периода договора
	Если СтруктураПараметров.НастройкиАлгоритма.ДатаНачалаРасчета="ДатаПодписанияДоговора" Тогда
		РасчетнаяДатаНачала = НачалоДня(Макс(РасчетнаяДатаНачала, СтруктураПараметров.СтруктураДоговораДУ.ДатаНачала));   
	Иначе
		РасчетнаяДатаНачала = НачалоДня(Макс(РасчетнаяДатаНачала,СтруктураПараметров.СтруктураДоговораДУ.ДатаВводаСредствВДУ)); 
	КонецЕсли;
	Если ЗначениеЗаполнено(СтруктураПараметров.СтруктураДоговораДУ.ДатаОкончания) Тогда
		РасчетнаяДатаОкончания = КонецДня(Мин(СтруктураПараметров.ДатаДокумента, СтруктураПараметров.СтруктураДоговораДУ.ДатаОкончания));
	Иначе
		РасчетнаяДатаОкончания = КонецДня(СтруктураПараметров.ДатаДокумента);
	КонецЕсли;
	
	
	//Определение количества дней в расчитываемом году для дальнейших расчетов
	ДельтаЛет = Цел(КоличествоМесяцев/12);
	НачалоРасчетногоГода = ОбщегоНазначенияДУ.ДобавитьКДате(НачальнаяДата, "Год", ДельтаЛет);
	КонецРасчетногоГода  = ОбщегоНазначенияДУ.ДобавитьКДате(НачальнаяДата, "Год", ДельтаЛет+1)-1;
	КоличествоДнейВГоду = ОбщегоНазначенияДУ.КоличествоПериодов(НачалоРасчетногоГода, КонецРасчетногоГода, "День");
	
	//Заполнение структуры возврата
	СтруктураВозврата.РасчетнаяДатаНачала    = РасчетнаяДатаНачала;
	СтруктураВозврата.РасчетнаяДатаОкончания = РасчетнаяДатаОкончания;
	СтруктураВозврата.КоличествоДнейВГоду  = КоличествоДнейВГоду;
	
	Сообщить("СтруктураПараметров.ДатаДокумента: " + СтруктураПараметров.ДатаДокумента);
	Сообщить("НачальнаяДата: " + НачальнаяДата);
	Сообщить("КоличествоМесяцев: " + КоличествоМесяцев);
	Сообщить("ДельтаЛет: " + ДельтаЛет);
	Сообщить("НачалоРасчетногоГода: " + НачалоРасчетногоГода);
	Сообщить("КонецРасчетногоГода: " + КонецРасчетногоГода);
	
	Сообщить("СтруктураВозврата.РасчетнаяДатаНачала: " + СтруктураВозврата.РасчетнаяДатаНачала);
	Сообщить("СтруктураВозврата.РасчетнаяДатаОкончания: " + СтруктураВозврата.РасчетнаяДатаОкончания);
	
	
	Возврат СтруктураВозврата;
КонецФункции

Функция РезультатРасчета(ПользовательскиеНастройки, СтруктураПараметров) Экспорт
	Перем СтруктураВозврата;
	
	//Начальная проверка существования нужных настроек расчета
	Если ПользовательскиеНастройки=Неопределено Тогда
		ОбщегоНазначенияДУКлиентСервер.СообщитьОбОшибке("Отсутствуют настройки алгоритма");
		Возврат Неопределено;
	КонецЕсли;
	
	СтруктураВозврата = Новый Структура(
		"СуммаВознаграждения, СтавкаВознаграждения, БРСА, СправкаРасчет",
		0,
		0,
		0,
		Новый ХранилищеЗначения(Новый Структура("ШапкаРасчет, ТелоРасчет, ПодвалРасчет, НачалоПериода, ОкончаниеПериода", Новый ТабличныйДокумент(), Новый ТабличныйДокумент(), Новый ТабличныйДокумент()))
	);
	
	СтруктураПараметровДУ = ОбщегоНазначения.ПолучитьЗначенияРеквизитов(СтруктураПараметров.ДоговорДУ, "ДатаВводаСредствВДУ, ДатаНачала, ДатаОкончания, Код");
	ПВХ = ПланыВидовХарактеристик.ПараметрыДоговораДУ;
	
	//Определение границ периода
	СтруктураПараметровПериода = Новый Структура;
	СтруктураПараметровПериода.Вставить("ДатаДокумента"     , СтруктураПараметров.Дата); 
	СтруктураПараметровПериода.Вставить("СтруктураДоговораДУ", СтруктураПараметровДУ);
	СтруктураПараметровПериода.Вставить("НастройкиАлгоритма", ПользовательскиеНастройки.Значения);
	
	СтруктураПериодаРасчета = ГраницыПериодаРасчета(СтруктураПараметровПериода);
	НачалоПериода = СтруктураПериодаРасчета.РасчетнаяДатаНачала;
	КонецПериода  = СтруктураПериодаРасчета.РасчетнаяДатаОкончания;
	ДнейВГоду     = СтруктураПериодаРасчета.КоличествоДнейВГоду;
	// DDneprovsky
	КоличествоДнейВРасчетномПериоде = ОбщегоНазначенияДУ.КоличествоПериодов(НачалоПериода, КонецПериода, "День");
	// DDneprovsky
	
		
	Если СтруктураПериодаРасчета.РасчетнаяДатаНачала > СтруктураПериодаРасчета.РасчетнаяДатаОкончания Тогда
		Возврат СтруктураВозврата;  // IMAPPS-7531
	КонецЕсли;
	
	СЧА0 = РегистрыСведений.РегистрРСА_СЧА.ЗначенияСЧА_РСА(НачалоГода(НачалоПериода) - 1, СтруктураПараметров.ДоговорДУ).СЧА;
	СтруктураВыводВыводы = ПолучитьВводыВыводы(СтруктураПараметров.ДоговорДУ, НачалоПериода, КонецПериода);
	СЧА = РегистрыСведений.РегистрРСА_СЧА.ЗначенияСЧА_РСА(КонецПериода, СтруктураПараметров.ДоговорДУ).СЧА;
		
	Базис = СЧА0;
	ВеличинаВознаграждения = УправлениеПараметрамиДоговораДУ.ПолучитьПараметрДоговораДУ(СтруктураПараметров.ДоговорДУ, ПВХ.ВеличинаВознагражденияЗаУспех, СтруктураПараметров.Дата);
	РазмерыВознаграждения = ПолучитьРазмерВознаграждения(СтруктураПараметров.ДоговорДУ, СтруктураПараметров.Дата, Базис, ВеличинаВознаграждения);
	СтруктураПроцент = РазмерыВознаграждения.Получить(ПВХ.ВеличинаВознагражденияЗаУспех);
	
	Если ТипЗнч(СтруктураПроцент) = Тип("Структура") Тогда
		//ЗначениеЛесенки = СтруктураПроцент.РазмерВознаграждения;
		//РезультирующаяСумма = ЗначениеЛесенки;
		Возврат	Неопределено
	КонецЕсли;
	
	ЗначениеЛесенки = СтруктураПроцент;
	СреднееСЧА_РСА = СреднееСЧА_РСА(СтруктураПараметров.ДоговорДУ,НачалоПериода,КонецПериода,"КалендарныйТип");
	//Сообщить("СЧА: " + СреднееСЧА_РСА.СЧА);	
	Если СтруктураПараметровПериода.НастройкиАлгоритма.Свойство("ТаблицаКоэффициентов") Тогда 
	//	Сообщить(СтруктураПараметровПериода.НастройкиАлгоритма.ТаблицаКоэффициентов);
		ТаблицаКоэфициентовХранилище = XMLЗначение(Тип("ХранилищеЗначения"),СтруктураПараметровПериода.НастройкиАлгоритма.ТаблицаКоэффициентов).Получить(); 
		//Для каждого стр из ТаблицаКоэфициентовХранилище Цикл
		//	Сообщить ("Мин " + стр.МинГраница + " макс " + стр.МаксГраница + " Коэф " + стр.Коэффициент)
		//КонецЦикла;
		//ТаблицаКоэффициентов = XMLЗначение(Тип("ХранилищеЗначения"),СтруктураПараметровПериода.НастройкиАлгоритма.ТаблицаКоэффициентов); 
		Сообщить(ТипЗнч(ТаблицаКоэффициентов));
		Запрос = Новый Запрос;
		Запрос.Текст = 
			"ВЫБРАТЬ
			|	ТЗ.МинГраница,
			|	ТЗ.МаксГраница,
			|	ТЗ.Коэффициент
			|ПОМЕСТИТЬ Данные
			|ИЗ
			|	&ТЗ КАК ТЗ
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ
			|	Данные.Коэффициент
			|ИЗ
			|	Данные КАК Данные
			|ГДЕ
			|	Данные.МинГраница <= &СуммаСЧА
			|	И Данные.МаксГраница >= &СуммаСЧА";

			//"ВЫБРАТЬ
			//|	ТЗ.МинГраница,
			//|	ТЗ.МаксГраница,
			//|	ТЗ.Коэффициент
			//|ПОМЕСТИТЬ Данные
			//|ИЗ
			//|	&ТЗ КАК ТЗ
			//|;
			//|
			//|////////////////////////////////////////////////////////////////////////////////
			//|ВЫБРАТЬ
			//|	МАКСИМУМ(Данные.МинГраница) КАК МинГраница
			//|ПОМЕСТИТЬ МаксМинГраница
			//|ИЗ
			//|	Данные КАК Данные
			//|ГДЕ
			//|	Данные.МинГраница <= &СуммаСЧА
			//|	И Данные.МаксГраница >= &СуммаСЧА
			//|;
			//|
			//|////////////////////////////////////////////////////////////////////////////////
			//|ВЫБРАТЬ
			//|	Данные.Коэффициент,
			//|	Данные.МинГраница,
			//|	Данные.МаксГраница
			//|ИЗ
			//|	МаксМинГраница КАК МаксМинГраница
			//|		ПОЛНОЕ СОЕДИНЕНИЕ Данные КАК Данные
			//|		ПО МаксМинГраница.МинГраница = Данные.МинГраница";
		
		Запрос.УстановитьПараметр("СуммаСЧА", СреднееСЧА_РСА.СЧА*1000);
		Запрос.УстановитьПараметр("ТЗ", ТаблицаКоэфициентовХранилище);
		
		РезультатЗапроса = Запрос.Выполнить();
		
		ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
		
		Если  ВыборкаДетальныеЗаписи.Следующий() Тогда
			Сообщить("СЧА: " + СреднееСЧА_РСА.СЧА);    
			//Сообщить ("Мин " + ВыборкаДетальныеЗаписи.МинГраница + " макс " + ВыборкаДетальныеЗаписи.МаксГраница + " Коэф " + ВыборкаДетальныеЗаписи.Коэффициент);
			Процент =  ВыборкаДетальныеЗаписи.Коэффициент;   
			Сообщить("Процент " + Процент); 
		Иначе
			Сообщить("Не заполнена таблица коэфицентов по договору",СтатусСообщения.Важное);
		КонецЕсли;
	Иначе
		Процент = ЗначениеЛесенки;
	КонецЕсли;	
	КлючеваяСтавка = ПолучитьСреднегодовуюКлючевуюСтавку(НачалоПериода, КонецПериода);
		
	МассивДоговоровДУ = Новый Массив;
	МассивДоговоровДУ.Добавить(СтруктураПараметров.ДоговорДУ);
	
	// IMAPPS-7621: коррекция на рабочий день
	НачалоПериодаРД = НачалоПериода;
	Если КалендарныеГрафики.ПолучитьСледующуюРабочуюДату(, НачалоПериода - 24 * 60 * 60, 0) = Неопределено Тогда
		НачалоПериодаРД = КалендарныеГрафики.ПолучитьСледующуюРабочуюДату(, НачалоПериода, -1);
	КонецЕсли;
	
	//ТаблицаTWR = Отчеты.ДоходностьПортфеляMWR_TWR.РасчетДоходностиTWR(НачалоПериодаРД, КонецПериода, МассивДоговоровДУ, Справочники.Валюты.RUB, Ложь); //IMAPPS-8404
	//TWR = Окр(ТаблицаTWR.Итог("ДоходностьTWR"), 2);  // IMAPPS-7621
	
	//TWR = ?(ДнейВГоду = 0, 0, Окр(ТаблицаTWR.Итог("ДоходностьTWR") * 365 / ДнейВГоду, 2));  // IMAPPS-7621
	// DDneprovsky 08.07.2019 IMAPPS-8404
	АлгоритмРасчетаДоходностиTWR_Ссылка = РегистрыСведений.УниверсальныеСопоставления.ПрочитатьПрямоеСопоставление(Перечисления.КонтекстСопоставления.ДоговорДУ, Справочники.ДополнительныеОтчетыИОбработки.ПустаяСсылка(), "SF14_РасчетДоходностиTWR", Ложь); 
	АлгоритмРасчетаДоходностиTWR_Объект = ДополнительныеОтчетыИОбработки.ПолучитьОбъектВнешнейОбработки(АлгоритмРасчетаДоходностиTWR_Ссылка);
	ТаблицаTWR = АлгоритмРасчетаДоходностиTWR_Объект.РасчетДоходностиTWR(СтруктураПараметров.ДоговорДУ, НачалоПериода, КонецПериода);
	ДоходностьTWR = 0;
	Если ТаблицаTWR.Количество() > 0 Тогда
		ДоходностьTWR = ТаблицаTWR[ТаблицаTWR.Количество() - 1].ДоходностьTWR;
	КонецЕсли;
	TWR = ДоходностьTWR;
	// DDneprovsky 08.07.2019 IMAPPS-8404
	
	ПФР = СЧА - СЧА0 - СтруктураВыводВыводы.СуммаВводов + СтруктураВыводВыводы.СуммаВыводов;
	Если ПФР < 0 Тогда
		РезультирующаяСумма = 0;
		ВУ1 = 0;
		ВУ2 = 0;
		БФР = 0;
		РанееНачислено = ПолучитьНачисленноеВознаграждение(СтруктураПараметров.ДоговорДУ, НачалоПериода, КонецПериода);
		
		Если -ПФР < РанееНачислено /2 Тогда
			КВозвр = -ПФР;
		Иначе
		    КВозвр = РанееНачислено /2;
		КонецЕсли;
	Иначе
		Если TWR <= КлючеваяСтавка Тогда
			РезультирующаяСумма = Окр(Процент / 100 * ПФР, 2);
			ВУ1 = РезультирующаяСумма; 
			ВУ2 = 0;
			БФР = 0;
		Иначе
			// MPazhukov IMAPPS-12776
			Если НачалоПериода >= Дата("20210101") Тогда
				Сообщить("TWR > Ключевой ставки");
				Сообщить("СЧА = " + СЧА);
				Сообщить("СЧА0 = " + СЧА0);
				Сообщить("Сумма вводов = " + СтруктураВыводВыводы.ТаблицаВводов.Итог("Сумма"));
				Сообщить("Сумма выводов = " + СтруктураВыводВыводы.ТаблицаВыводов.Итог("Сумма"));
				Сообщить("БФР = (КлючеваяСтавка / 100) * КоличествоДнейВРасчетномПериоде / ДнейВГоду * (СЧА0 + (СуммаВводов - СуммаВыводов) / ДнейВГоду)");
				Сообщить("БФР = (" + КлючеваяСтавка + "/ 100) * " + КоличествоДнейВРасчетномПериоде +" / " + ДнейВГоду + " * (" + СЧА0 + " + (" + СтруктураВыводВыводы.ТаблицаВводов.Итог("Сумма") + " - " + СтруктураВыводВыводы.ТаблицаВыводов.Итог("Сумма") + ") / " + ДнейВГоду + " )");
				
				БФР = Окр((КлючеваяСтавка / 100) * КоличествоДнейВРасчетномПериоде / ДнейВГоду * (СЧА0 + (СтруктураВыводВыводы.ТаблицаВводов.Итог("Сумма") - СтруктураВыводВыводы.ТаблицаВыводов.Итог("Сумма")) / ДнейВГоду), 2);//Базовый Финансовый Результат
				РезультирующаяСумма = Окр(Процент / 100 * БФР + (Процент*10/100 * (ПФР - БФР)), 2);
				Сообщить("ВУ2 = Процент / 100 * БФР + (Процент/100 * (ПФР - БФР)");
				Сообщить("ВУ2 = " + Процент + "/ 100 * " + БФР + "+ ("+Процент*10+"/100 * (" + ПФР +  " - " + БФР + "))");
				ВУ1 = 0;
				ВУ2 = РезультирующаяСумма;
				
				// MPazhukov IMAPPS-10416
				ДопДанные = новый Структура;
