				ДопДанные.Вставить("ВУ2", "ВУ2 = " + Процент + "/ 100 * " + БФР + "+ ("+Процент*10+"/100 * (" + ПФР +  " - " + БФР + "))");    
				// MPazhukov IMAPPS-10416
