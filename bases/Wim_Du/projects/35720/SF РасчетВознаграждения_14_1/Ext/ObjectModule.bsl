Функция ПолучитьПодписанта(Контрагент, Роль = Неопределено)
	
	СписокРолей = Новый Массив;
	
	Если Роль = Неопределено Тогда
		СписокРолей.Добавить(Справочники.РолиКонтактныхЛиц.Руководитель);
	Иначе
		СписокРолей.Добавить(Роль);
	КонецЕсли;
	
	Запрос = Новый Запрос();
	Запрос.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
	               |	КонтактныеЛица.Ссылка,
	               |	КонтактныеЛица.Имя,
	               |	КонтактныеЛица.Фамилия,
	               |	КонтактныеЛица.Отчество,
	               |	КонтактныеЛица.Должность,
	               |	КонтактныеЛица.Основание
	               |ИЗ
	               |	Справочник.КонтактныеЛица КАК КонтактныеЛица
	               |ГДЕ
	               |	КонтактныеЛица.Владелец = &УК
	               |	И КонтактныеЛица.ПометкаУдаления = ЛОЖЬ
	               |	И КонтактныеЛица.Роль В(&СписокРолей)";
	Запрос.УстановитьПараметр("УК", Контрагент);
	Запрос.УстановитьПараметр("СписокРолей", СписокРолей);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
		СтруктураВозвр = Новый Структура;
		СтруктураВозвр.Вставить("ФИО", Лев(Выборка.Имя, 1) + "." + Лев(Выборка.Отчество, 1) + "." + " " + Выборка.Фамилия);
		СтруктураВозвр.Вставить("Должность", Выборка.Должность + ?(ЗначениеЗаполнено(Выборка.Основание), Символы.ПС + "по " + НРег(СокрЛП(Выборка.Основание)), ""));
		Возврат СтруктураВозвр
	Иначе
		Возврат Неопределено
	КонецЕсли;
	
КонецФункции

Функция ПолучитьВводыВыводы(ДоговорДУ, НачалоПериода, КонецПериода)
		
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	НАЧАЛОПЕРИОДА(ВводыВыводыДУ.Период, ДЕНЬ) КАК Период,
	|	СУММА(ВводыВыводыДУ.Сумма) КАК ОборотСумма
	|ИЗ
	|	РегистрНакопления.ВводыВыводыДУ КАК ВводыВыводыДУ
	|ГДЕ
	|	ВводыВыводыДУ.Период МЕЖДУ &ДатаНачала И &ДатаОкончания
	|	И ВводыВыводыДУ.ДоговорДУ = &ДоговорДУ
	|	И ВводыВыводыДУ.Сумма > 0
	|
	|СГРУППИРОВАТЬ ПО
	|	НАЧАЛОПЕРИОДА(ВводыВыводыДУ.Период, ДЕНЬ)
	|
	|УПОРЯДОЧИТЬ ПО
	|	Период
	|ИТОГИ
	|	СУММА(ОборотСумма)
	|ПО
	|	Период ПЕРИОДАМИ(ДЕНЬ, &ДатаНачала, &ДатаОкончания)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	НАЧАЛОПЕРИОДА(ВводыВыводыДУ.Период, ДЕНЬ) КАК Период,
	|	СУММА(-1 * ВводыВыводыДУ.Сумма) КАК ОборотСумма
	|ИЗ
	|	РегистрНакопления.ВводыВыводыДУ КАК ВводыВыводыДУ
	|ГДЕ
	|	ВводыВыводыДУ.Период МЕЖДУ &ДатаНачала И &ДатаОкончания
	|	И ВводыВыводыДУ.ДоговорДУ = &ДоговорДУ
	|	И ВводыВыводыДУ.Сумма < 0
	|
	|СГРУППИРОВАТЬ ПО
	|	НАЧАЛОПЕРИОДА(ВводыВыводыДУ.Период, ДЕНЬ)
	|
	|УПОРЯДОЧИТЬ ПО
	|	Период
	|ИТОГИ
	|	СУММА(ОборотСумма)
	|ПО
	|	Период ПЕРИОДАМИ(ДЕНЬ, &ДатаНачала, &ДатаОкончания)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЕСТЬNULL(СУММА(ВЫБОР
	|				КОГДА ВводыВыводыДУОбороты.СуммаОборот > 0
	|					ТОГДА ВводыВыводыДУОбороты.СуммаОборот
	|				ИНАЧЕ 0
	|			КОНЕЦ), 0) КАК СуммаПриход,
	|	ЕСТЬNULL(СУММА(ВЫБОР
	|				КОГДА ВводыВыводыДУОбороты.СуммаОборот < 0
	|					ТОГДА -ВводыВыводыДУОбороты.СуммаОборот
	|				ИНАЧЕ 0
	|			КОНЕЦ), 0) КАК СуммаРасход
	|ИЗ
	|	РегистрНакопления.ВводыВыводыДУ.Обороты(&ДатаНачала, &ДатаОкончания, Регистратор, ДоговорДУ = &ДоговорДУ) КАК ВводыВыводыДУОбороты";
	
	Запрос.УстановитьПараметр("ДатаНачала", НачалоПериода);
	Запрос.УстановитьПараметр("ДатаОкончания", КонецПериода);
	Запрос.УстановитьПараметр("ДоговорДУ", ДоговорДУ);
	
	Результат = Запрос.ВыполнитьПакет();
	Выборка = Результат[2].Выбрать();
	Выборка.Следующий();
	
	ТаблицаВводов = Новый ТаблицаЗначений();
	ТаблицаВводов.Колонки.Добавить("Период", ОбщегоНазначенияДУКлиентСервер.ПолучитьОписаниеТиповДаты(ЧастиДаты.Дата));
	ТаблицаВводов.Колонки.Добавить("Сумма", ОбщегоНазначенияДУКлиентСервер.ПолучитьОписаниеТиповЧисла(19, 2));
			
	НакопительнаяСумма = 0;
	ВыборкаВводов = Результат[0].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "Период", "ВСЕ");
	Пока ВыборкаВводов.Следующий() Цикл
		НакопительнаяСумма = НакопительнаяСумма + ?(ВыборкаВводов.ОборотСумма = Null, 0, ВыборкаВводов.ОборотСумма);
		
		СтрокаВвод = ТаблицаВводов.Добавить();
		СтрокаВвод.Период	 = ВыборкаВводов.Период;
		СтрокаВвод.Сумма	 = НакопительнаяСумма;
		
	КонецЦикла;
		
	ТаблицаВыводов = Новый ТаблицаЗначений();
	ТаблицаВыводов.Колонки.Добавить("Период", ОбщегоНазначенияДУКлиентСервер.ПолучитьОписаниеТиповДаты(ЧастиДаты.Дата));
	ТаблицаВыводов.Колонки.Добавить("Сумма", ОбщегоНазначенияДУКлиентСервер.ПолучитьОписаниеТиповЧисла(19, 2));
	
	НакопительнаяСумма = 0;
	ВыборкаВыводов = Результат[1].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "Период", "ВСЕ");
	Пока ВыборкаВыводов.Следующий() Цикл
		НакопительнаяСумма = НакопительнаяСумма + ?(ВыборкаВыводов.ОборотСумма = Null, 0, ВыборкаВыводов.ОборотСумма);
		
		СтрокаВыводов = ТаблицаВыводов.Добавить();
		СтрокаВыводов.Период = ВыборкаВыводов.Период;
		СтрокаВыводов.Сумма	 = НакопительнаяСумма;
		
	КонецЦикла;
	
	Возврат Новый Структура("СуммаВводов, СуммаВыводов, ТаблицаВводов, ТаблицаВыводов", Выборка.СуммаПриход, Выборка.СуммаРасход, ТаблицаВводов, ТаблицаВыводов);
КонецФункции

Функция ПолучитьСреднегодовуюКлючевуюСтавку(НачалоПериода, КонецПериода)
		
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	&ДатаНачалаГода КАК Период,
		|	СтавкиРефинансированияСрезПоследних.Ставка
		|ИЗ
		|	РегистрСведений.СтавкиРефинансирования.СрезПоследних(&ДатаНачалаГода, ) КАК СтавкиРефинансированияСрезПоследних
		|
		|ОБЪЕДИНИТЬ
		|
		|ВЫБРАТЬ
		|	СтавкиРефинансирования.Период,
		|	СтавкиРефинансирования.Ставка
		|ИЗ
		|	РегистрСведений.СтавкиРефинансирования КАК СтавкиРефинансирования
		|ГДЕ
		|	СтавкиРефинансирования.Период МЕЖДУ &ДатаНачалаГода И &ДатаОкончания
		|
		|УПОРЯДОЧИТЬ ПО
		|	Период";
	
	Запрос.УстановитьПараметр("ДатаНачалаГода", НачалоГода(НачалоПериода));
	Запрос.УстановитьПараметр("ДатаОкончания", КонецПериода);
	
	ТаблСтавокРефинансирования = Запрос.Выполнить().Выгрузить();
	
	Если ТаблСтавокРефинансирования.Количество() = 0 Тогда
		Возврат 0
	Иначе
		СуммаПроизведение = 0;
		
		ТекДата = ТаблСтавокРефинансирования[0].Период;
		ТекСтавка = ТаблСтавокРефинансирования[0].Ставка;
		
		Для Н = 1 По ТаблСтавокРефинансирования.Количество() - 1 Цикл
			СуммаПроизведение = СуммаПроизведение + (ТаблСтавокРефинансирования[Н].Период - ТекДата) * ТекСтавка;
			ТекДата = ТаблСтавокРефинансирования[Н].Период;
			ТекСтавка = ТаблСтавокРефинансирования[Н].Ставка;
		КонецЦикла;
		
		СуммаПроизведение = СуммаПроизведение + ((КонецПериода + 1) - ТекДата) * ТекСтавка;
		КоличествоДней = ((КонецПериода + 1) - НачалоГода(НачалоПериода));
				
		Возврат Окр(СуммаПроизведение/КоличествоДней, 2);
		
	КонецЕсли;
	
КонецФункции

