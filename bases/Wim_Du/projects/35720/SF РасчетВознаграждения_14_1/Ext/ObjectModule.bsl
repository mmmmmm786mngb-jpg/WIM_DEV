        ТабДокументПодвал.Вывести(ОбластьШапкаРасшифровкаСЧА);
		ИтогоСча = 0;                       
		Для каждого стр из СтруктураПоказателей.СтруктураСЧА.ТаблицаСЧА_РСА Цикл
			ОбластьСтрокаРасшифровкаСЧА.Параметры.ДатаСЧА= "Стоимость чистых активов на " + Формат(стр.Дата, "ДФ=dd.MM.yyyy");
			ОбластьСтрокаРасшифровкаСЧА.Параметры.Сумма= стр.СЧА;
			ТабДокументПодвал.Вывести(ОбластьСтрокаРасшифровкаСЧА);

			ИтогоСча = ИтогоСча + стр.СЧА;
		КонецЦикла;
		ОбластьПодвалСЧА.Параметры.СуммаСЧА = ИтогоСча;
		ОбластьПодвалСЧА.Параметры.КоличествоДней = СтруктураПоказателей.СтруктураСЧА.КоличествоДней;
		ОбластьПодвалСЧА.Параметры.Сча = Формат(СтруктураПоказателей.СтруктураСЧА.СЧА,"ЧДЦ=5");
		ТабДокументПодвал.Вывести(ОбластьПодвалСЧА);

		
	КонецЕсли;

	Возврат ТабДокументПодвал;
	
