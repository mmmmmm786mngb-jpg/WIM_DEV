КонецПроцедуры

// Описание: Формирует и показывает печатную форму таблицы областей
//
// Параметры:
//   Команда - КомандаФормы - команда формы «ПоказатьПечатнуюФормуТаблицы»
//
&НаКлиенте
Процедура ПоказатьПечатнуюФормуТаблицы(Команда)

    ТабличныйДокумент = СформироватьПечатнуюФормуТаблицыНаСервере();
    ТабличныйДокумент.Показать("Печатная форма таблицы областей");

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиОповещений

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Описание: Добавляет одну строку в таблицу областей (для демонстрации при открытии формы)
//
// Параметры:
//   Таблица - ТаблицаЗначений - таблица с колонками НазваниеОбласти, Индекс, КоличествоЖителей
//   НазваниеОбласти - Строка - наименование области
//   Индекс - Строка - условный индекс или код
//   КоличествоЖителей - Число - количество жителей
//
&НаСервере
Процедура ДобавитьСтрокуПримераВТаблицуОбластей(Таблица, НазваниеОбласти, Индекс, КоличествоЖителей)

    НоваяСтрока = Таблица.Добавить();
    НоваяСтрока.НазваниеОбласти = НазваниеОбласти;
    НоваяСтрока.Индекс = Индекс;
    НоваяСтрока.КоличествоЖителей = КоличествоЖителей;

КонецПроцедуры

// Описание: Создает табличный документ по текущим строкам реквизита «ТаблицаОбластей»
//
// Возвращаемое значение:
//   ТабличныйДокумент - печатная форма таблицы областей
//
&НаСервере
Функция СформироватьПечатнуюФормуТаблицыНаСервере()

    ТабДок = Новый ТабличныйДокумент;

    // У ТабличныйДокумент нет метода ВывестиТекст; вывод через области ячеек
    ТабДок.Область(1, 1, 1, 1).Текст = "Таблица областей";

    ТабДок.Область(3, 1, 3, 1).Текст = "Название области";
    ТабДок.Область(3, 2, 3, 2).Текст = "Индекс";
    ТабДок.Область(3, 3, 3, 3).Текст = "Количество жителей";

    НомерСтроки = 4;
    Для Каждого СтрокаТаблицы Из ТаблицаОбластей Цикл
        ТабДок.Область(НомерСтроки, 1, НомерСтроки, 1).Текст = СтрокаТаблицы.НазваниеОбласти;
        ТабДок.Область(НомерСтроки, 2, НомерСтроки, 2).Текст = СтрокаТаблицы.Индекс;
        ТабДок.Область(НомерСтроки, 3, НомерСтроки, 3).Текст = Формат(СтрокаТаблицы.КоличествоЖителей, "ЧГ=0");
        НомерСтроки = НомерСтроки + 1;
    КонецЦикла;

    Возврат ТабДок;

КонецФункции

#КонецОбласти
