#Область ОбработчикиСобытийФормы

// Описание: Заполняет таблицу областей строками-примерами при создании формы на сервере
//
// Параметры:
//   Отказ - Булево - признак отказа открытия формы
//   СтандартнаяОбработка - Булево - признак выполнения стандартной обработки
//
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)

    // Очищаем, чтобы убрать автоматическую пустую строку таблицы (AutoInsertNewRow) и гарантировать примеры
    ТаблицаОбластей.Очистить();

    ДобавитьСтрокуПримераВТаблицуОбластей(ТаблицаОбластей, "Демо область Север", "11", 150000);
    ДобавитьСтрокуПримераВТаблицуОбластей(ТаблицаОбластей, "Демо область Юг", "22", 89000);
    ДобавитьСтрокуПримераВТаблицуОбластей(ТаблицаОбластей, "Демо область Восток", "33", 234000);
    ДобавитьСтрокуПримераВТаблицуОбластей(ТаблицаОбластей, "Демо область Запад", "44", 412000);

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовФормы

#КонецОбласти

#Область ОбработчикиКомандФормы

// Описание: Показывает значение реквизита «ВведеннаяСтрока» в табличном документе по схеме СКД
//
// Параметры:
//   Команда - КомандаФормы - команда формы «ПоказатьВведеннуюСтроку»
//
// Пример:
//   Ввод текста и нажатие кнопки открывает табличный документ с результатом компоновки
//
&НаКлиенте
Процедура ПоказатьВведеннуюСтроку(Команда)

    ТабличныйДокументСКД = СформироватьВведеннуюСтрокуСКДНаСервере(ВведеннаяСтрока);
    ТабличныйДокументСКД.Показать("Введенная строка (СКД)");

КонецПроцедуры

// Описание: Формирует и показывает печатную форму таблицы областей
//
// Параметры:
//   Команда - КомандаФормы - команда формы «ПоказатьПечатнуюФормуТаблицы»
//
&НаКлиенте
Процедура ПоказатьПечатнуюФормуТаблицы(Команда)

    ТабличныйДокумент = СформироватьПечатнуюФормуТаблицыНаСервере();
    ТабличныйДокумент.Показать("Печатная форма таблицы областей");

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиОповещений

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Описание: Добавляет одну строку в таблицу областей (для демонстрации при открытии формы)
//
// Параметры:
//   Таблица - ТаблицаЗначений - таблица с колонками НазваниеОбласти, Индекс, КоличествоЖителей
//   НазваниеОбласти - Строка - наименование области
//   Индекс - Строка - условный индекс или код
//   КоличествоЖителей - Число - количество жителей
//
&НаСервере
Процедура ДобавитьСтрокуПримераВТаблицуОбластей(Таблица, НазваниеОбласти, Индекс, КоличествоЖителей)

    НоваяСтрока = Таблица.Добавить();
    НоваяСтрока.НазваниеОбласти = НазваниеОбласти;
    НоваяСтрока.Индекс = Индекс;
    НоваяСтрока.КоличествоЖителей = КоличествоЖителей;

КонецПроцедуры

// Описание: Создает табличный документ по макету «ПФ_MXL_ТаблицаОбластей11111» и строкам реквизита «ТаблицаОбластей»
//
// Возвращаемое значение:
//   ТабличныйДокумент - печатная форма таблицы областей
//
&НаСервере
Функция СформироватьПечатнуюФормуТаблицыНаСервере()

    ТабДок = Новый ТабличныйДокумент;

    ОбработкаОбъект = РеквизитФормыВЗначение("Объект");
    Макет = ОбработкаОбъект.ПолучитьМакет("ПФ_MXL_ТаблицаОбластей11111");

    ОбластьЗаголовка = Макет.ПолучитьОбласть("ЗаголовокПечати");
    ОбластьЗаголовка.Параметры.ДатаПечати = Формат(ТекущаяДатаСеанса(), "ДЛФ=DD");
    ТабДок.Вывести(ОбластьЗаголовка);

    ОбластьШапки = Макет.ПолучитьОбласть("ШапкаТаблицы");
    ТабДок.Вывести(ОбластьШапки);

    Для Каждого СтрокаТаблицы Из ТаблицаОбластей Цикл
        ОбластьСтроки = Макет.ПолучитьОбласть("СтрокаТаблицы");
        ОбластьСтроки.Параметры.НазваниеОбласти = СтрокаТаблицы.НазваниеОбласти;
        ОбластьСтроки.Параметры.Индекс = СтрокаТаблицы.Индекс;
        ОбластьСтроки.Параметры.КоличествоЖителей = СтрокаТаблицы.КоличествоЖителей;
        ТабДок.Вывести(ОбластьСтроки);
    КонецЦикла;

    Возврат ТабДок;

КонецФункции

// Описание: Формирует табличный документ по макету СКД «СКД_ВведеннаяСтрока11111» с внешним набором «ТаблицаСтроки»
//
// Параметры:
//   ТекстДляВывода - Строка - текст для вывода (реквизит «ВведеннаяСтрока»)
//
// Возвращаемое значение:
//   ТабличныйДокумент - результат компоновки данных
//
&НаСервере
Функция СформироватьВведеннуюСтрокуСКДНаСервере(ТекстДляВывода)

    ОбработкаОбъект = РеквизитФормыВЗначение("Объект");
    СхемаКомпоновкиДанных = ОбработкаОбъект.ПолучитьМакет("СКД_ВведеннаяСтрока11111");

    ТаблицаСтроки = Новый ТаблицаЗначений;
    ТаблицаСтроки.Колонки.Добавить("ТекстВвода", Новый ОписаниеТипов("Строка"));
    СтрокаДанных = ТаблицаСтроки.Добавить();
    СтрокаДанных.ТекстВвода = ТекстДляВывода;

    ВнешниеНаборыДанных = Новый Структура;
    ВнешниеНаборыДанных.Вставить("ТаблицаСтроки", ТаблицаСтроки);

    КомпоновщикНастроек = Новый КомпоновщикНастроекКомпоновкиДанных;
    ИсточникДоступныхНастроек = Новый ИсточникДоступныхНастроекКомпоновкиДанных(СхемаКомпоновкиДанных);
    КомпоновщикНастроек.Инициализировать(ИсточникДоступныхНастроек);
    КомпоновщикНастроек.ЗагрузитьНастройки(СхемаКомпоновкиДанных.НастройкиПоУмолчанию);

    КомпоновщикМакета = Новый КомпоновщикМакетаКомпоновкиДанных;
    МакетКомпоновки = КомпоновщикМакета.Выполнить(
        СхемаКомпоновкиДанных,
        КомпоновщикНастроек.ПолучитьНастройки(),
        Неопределено,
        Неопределено,
        Тип("ГенераторМакетаКомпоновкиДанных"));

    ПроцессорКомпоновки = Новый ПроцессорКомпоновкиДанных;
    ПроцессорКомпоновки.Инициализировать(МакетКомпоновки, ВнешниеНаборыДанных);

    ТабличныйДокументРезультат = Новый ТабличныйДокумент;
    ПроцессорВывода = Новый ПроцессорВыводаРезультатаКомпоновкиДанныхВТабличныйДокумент;
    ПроцессорВывода.УстановитьДокумент(ТабличныйДокументРезультат);
    ПроцессорВывода.Вывести(ПроцессорКомпоновки);

    Возврат ТабличныйДокументРезультат;

КонецФункции

#КонецОбласти
