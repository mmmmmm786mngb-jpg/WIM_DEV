			ПараметрыФоновогоЗадания = Новый Массив;
			ПараметрыФоновогоЗадания.Добавить(ПараметрыЗадания);
			
			Задание = ФоновыеЗадания.Выполнить("ВТБ_МодульФоновыхЗаданий.ПерепровестиСделкиЦБвПотоке"
			, ПараметрыФоновогоЗадания
			, Новый УникальныйИдентификатор
			, НаименованиеЗадания);
			
			МассивЗаданий.Добавить(Задание.УникальныйИдентификатор);
		КонецЦикла;
		//
		ЛогПерепроведенияСделкиЦБ = ОжидатьВыполненияЗаданий(МассивЗаданий);
		
