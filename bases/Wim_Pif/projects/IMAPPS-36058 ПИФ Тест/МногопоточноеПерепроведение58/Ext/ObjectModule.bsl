			НаименованиеЗадания = "№ " + Строка(сч) + " Групповое перепроведение сделок цб за период с " + Формат(НачалоДня(ТекДата), "ДФ=dd.MM.yyyy") + " по " + Формат(КонецДня(ТекДата), "ДФ=dd.MM.yyyy");
			ПараметрыЗадания.Вставить("ТаблицаКлючей", Потоки[Сч].ТаблицаКлючей);
			ПараметрыЗадания.Вставить("Наименование", НаименованиеЗадания);
			// IMAPPS-25828 ++
			// ПараметрыЗадания.Вставить("ВалютныеСделки", ВалютныеСделки);
            Если СделкиСВалютой <> Неопределено Тогда
				ПараметрыЗадания.Вставить("ВалютныеСделки", СделкиСВалютой)
