			Если ПререпроводитьАктивыСВалютой <> Неопределено Тогда
				ПараметрыЗадания.Вставить("АктивыСВалютой", ПререпроводитьАктивыСВалютой)
			КонецЕсли;
			// IMAPPS-25575 --
			
			АдресВХранилище = ПоместитьВоВременноеХранилище(Неопределено, Новый УникальныйИдентификатор());
			ПараметрыЗадания.Вставить("АдресВХранилище", АдресВХранилище);
