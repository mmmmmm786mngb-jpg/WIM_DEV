// Функция СформироватьТекстЗапросаДляРаспределенияСделокСЦБ()
// IMAPPS-25575 ++
// Функция СформироватьТекстЗапросаДляРаспределенияСделокСЦБ(СделкиСВалютой = Неопределено)
Функция СформироватьТекстЗапросаДляРаспределенияСделокСЦБ(СделкиСВалютой = Неопределено, АктивыСВалютой = Неопределено)
// IMAPPS-25575 --
// IMAPPS-25828 --
	ТекстЗапроса = "ВЫБРАТЬ
	               |	Активы.Ссылка КАК Актив,
	               |	Активы.Объект КАК Объект,
	               |	ВЫБОР
	               |		КОГДА Активы.Объект ССЫЛКА Справочник.Акции
	               |			ТОГДА Акции.ВалютаНоминальнойСтоимости
	               |		КОГДА Активы.Объект ССЫЛКА Справочник.ДепозитарныеРасписки
	               |			ТОГДА ДепозитарныеРасписки.ВалютаНоминальнойСтоимости
	               |		КОГДА Активы.Объект ССЫЛКА Справочник.КлиринговыеСертификатыУчастия
	               |			ТОГДА КлиринговыеСертификатыУчастия.ВалютаНоминальнойСтоимости
	               |		КОГДА Активы.Объект ССЫЛКА Справочник.Облигации
	               |			ТОГДА Облигации.ВалютаНоминальнойСтоимости
	               |		КОГДА Активы.Объект ССЫЛКА Справочник.ПаиПИФ
	               |			ТОГДА ПаиПИФ.ВалютаНоминальнойСтоимости
	               |		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.Валюты.ПустаяСсылка)
	               |	КОНЕЦ КАК ВалютаНоминальнойСтоимости
	               |ПОМЕСТИТЬ втАктивы
	               |ИЗ
	               |	Справочник.Активы КАК Активы
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Акции КАК Акции
	               |		ПО Активы.Объект = Акции.Ссылка
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ДепозитарныеРасписки КАК ДепозитарныеРасписки
	               |		ПО Активы.Объект = ДепозитарныеРасписки.Ссылка
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.КлиринговыеСертификатыУчастия КАК КлиринговыеСертификатыУчастия
	               |		ПО Активы.Объект = КлиринговыеСертификатыУчастия.Ссылка
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Облигации КАК Облигации
	               |		ПО Активы.Объект = Облигации.Ссылка
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ПаиПИФ КАК ПаиПИФ
	               |		ПО Активы.Объект = ПаиПИФ.Ссылка
	               |ГДЕ
	               |	НЕ Активы.ПометкаУдаления
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ РАЗЛИЧНЫЕ
	               |	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ СделкаЦБ.Ссылка) КАК КоличествоЗадач,
	               |	СделкаЦБ.ПИФ КАК ПИФ,
	               |	ПРЕДСТАВЛЕНИЕ(СделкаЦБ.ПИФ) КАК ПредставлениеПИФ,
	               |	СделкаЦБ.Актив КАК Актив,
	               |	ПРЕДСТАВЛЕНИЕ(СделкаЦБ.Актив) КАК ПредставлениеАктив
	               |ИЗ
	               |	Документ.СделкаЦБ КАК СделкаЦБ
	               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ втАктивы КАК втАктивы
				   |		ПО СделкаЦБ.Актив = втАктивы.Актив
	               |ГДЕ
	               |	СделкаЦБ.Дата МЕЖДУ НАЧАЛОПЕРИОДА(&ДатаНачала, ДЕНЬ) И КОНЕЦПЕРИОДА(&ДатаОкончания, ДЕНЬ)
	               |	И СделкаЦБ.Проведен
	               |	И ВЫБОР
	               |			КОГДА &ВсеПИФы
	               |				ТОГДА ИСТИНА
	               |			ИНАЧЕ СделкаЦБ.ПИФ В (&ПИФы)
	               |		КОНЕЦ
	               |	И &Условие1
	               |	И &Условие2
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	СделкаЦБ.ПИФ,
	               |	СделкаЦБ.Актив
	               |
	               |УПОРЯДОЧИТЬ ПО
	               |	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ СделкаЦБ.Ссылка) УБЫВ";
	
	// IMAPPS-25828 ++
	// Если Не ВалютныеСделки = Неопределено Тогда  
	//	Если ВалютныеСделки Тогда 
	Если Не СделкиСВалютой = Неопределено Тогда  
		Если СделкиСВалютой Тогда 
	// IMAPPS-25828 --
			ТекстЗапроса = СтрЗаменить(ТекстЗапроса,"&Условие1","НЕ СделкаЦБ.ВалютаДокумента = ЗНАЧЕНИЕ(Справочник.Валюты.RUB)");
		Иначе
			ТекстЗапроса = СтрЗаменить(ТекстЗапроса,"&Условие1","СделкаЦБ.ВалютаДокумента = ЗНАЧЕНИЕ(Справочник.Валюты.RUB)");
		КонецЕсли;	
	Иначе 
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса,"&Условие1","Истина");
	КонецЕсли;
	
	// IMAPPS-25575 ++
	Если Не АктивыСВалютой = Неопределено Тогда  
		Если АктивыСВалютой Тогда 
			ТекстУсловия_2 = "НЕ (втАктивы.ВалютаНоминальнойСтоимости = ЗНАЧЕНИЕ(Справочник.Валюты.RUB)
								| ИЛИ втАктивы.ВалютаНоминальнойСтоимости = ЗНАЧЕНИЕ(Справочник.Валюты.ПустаяСсылка))";
		Иначе
			ТекстУсловия_2 = "(втАктивы.ВалютаНоминальнойСтоимости = ЗНАЧЕНИЕ(Справочник.Валюты.RUB)
								| ИЛИ втАктивы.ВалютаНоминальнойСтоимости = ЗНАЧЕНИЕ(Справочник.Валюты.ПустаяСсылка))";
		КонецЕсли;	
	Иначе 
		ТекстУсловия_2 = "Истина";
	КонецЕсли;
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&Условие2", ТекстУсловия_2);
	// IMAPPS-25575 --
	
	Возврат ТекстЗапроса;
КонецФункции

