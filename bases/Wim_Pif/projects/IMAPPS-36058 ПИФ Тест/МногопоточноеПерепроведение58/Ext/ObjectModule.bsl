		Для Сч = 0 по КоличествоПотоков - 1 Цикл
			Если Потоки[Сч].ТекущаяЗагрузка = 0 Тогда
				Продолжить;
			КонецЕсли;
			
			НаименованиеЗадания = "№ " + Строка(сч) + " Групповое перепроведение документов счета 58 за период с " + Формат(НачалоДня(ТекДата), "ДФ=dd.MM.yyyy") + " по " + Формат(КонецДня(ТекДата), "ДФ=dd.MM.yyyy");
			ПараметрыЗадания.Вставить("ТаблицаКлючей", Потоки[Сч].ТаблицаКлючей);
			ПараметрыЗадания.Вставить("Наименование", НаименованиеЗадания); 
			// IMAPPS-25828 ++
			// ПараметрыЗадания.Вставить("ВалютныеСделки", ВалютныеСделки);
            Если СделкиСВалютой <> Неопределено Тогда
