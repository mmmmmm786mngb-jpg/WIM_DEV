							|	ИЛИ ЕСТЬNULL(втДокументыДляГруппировки.Валюта, ЗНАЧЕНИЕ(Справочник.Валюты.ПустаяСсылка)) = ЗНАЧЕНИЕ(Справочник.Валюты.ПустаяСсылка) 
							|	ИЛИ втДокументыДляГруппировки.Ссылка ССЫЛКА Документ.ПереоценкаАктивов)"
		КонецЕсли;	
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&Условие1", Текст_Условие1);
	// IMAPPS-25828 --
	Иначе 
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса,"&Условие1","Истина");
	КонецЕсли;

	// IMAPPS-25575 ++
	Если Не АктивыСВалютой = Неопределено Тогда  
		Если АктивыСВалютой Тогда 
			ТекстУсловия_2 = "НЕ (ЕСТЬNULL(втАктивы.ВалютаНоминальнойСтоимости, ЗНАЧЕНИЕ(Справочник.Валюты.ПустаяСсылка)) = ЗНАЧЕНИЕ(Справочник.Валюты.RUB)
								| ИЛИ ЕСТЬNULL(втАктивы.ВалютаНоминальнойСтоимости, ЗНАЧЕНИЕ(Справочник.Валюты.ПустаяСсылка)) = ЗНАЧЕНИЕ(Справочник.Валюты.ПустаяСсылка))";
		Иначе
			ТекстУсловия_2 = "(ЕСТЬNULL(втАктивы.ВалютаНоминальнойСтоимости, ЗНАЧЕНИЕ(Справочник.Валюты.ПустаяСсылка)) = ЗНАЧЕНИЕ(Справочник.Валюты.RUB)
								| ИЛИ ЕСТЬNULL(втАктивы.ВалютаНоминальнойСтоимости, ЗНАЧЕНИЕ(Справочник.Валюты.ПустаяСсылка)) = ЗНАЧЕНИЕ(Справочник.Валюты.ПустаяСсылка))";
		КонецЕсли;	
	Иначе 
		ТекстУсловия_2 = "Истина";
	КонецЕсли;
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&Условие2", ТекстУсловия_2);
	// IMAPPS-25575 --
	
	Возврат ТекстЗапроса;
КонецФункции	

Функция ОпределитьНаименееЗагруженныйПоток(Потоки)
	Потоки.Сортировать("ТекущаяЗагрузка ВОЗР");
	Возврат Потоки[0];
КонецФункции

Функция РаспределитьЗадачиПоПотокам(ТекстЗапроса, ГруппировкаПоАктиву = Истина,СделкиПоВалюте = Неопределено)
	Потоки = Новый ТаблицаЗначений;                                                                         
	Потоки.Колонки.Добавить("НомерПотока");
	Потоки.Колонки.Добавить("ТекущаяЗагрузка");
	Потоки.Колонки.Добавить("ТаблицаКлючей");
	
	//Инициализация
	Для Сч = 0 По КоличествоПотоков - 1 Цикл
		НовыйПоток = Потоки.Добавить();
		НовыйПоток.НомерПотока = Сч;
		НовыйПоток.ТекущаяЗагрузка = 0;
		НовыйПоток.ТаблицаКлючей = Новый ТаблицаЗначений;
		НовыйПоток.ТаблицаКлючей.Колонки.Добавить("Пиф", Новый ОписаниеТипов("СправочникСсылка.ПИФ"));
		КвалификаторСтроки = Новый КвалификаторыСтроки(250);
		НовыйПоток.ТаблицаКлючей.Колонки.Добавить("ПредставлениеПИФ", Новый ОписаниеТипов("Строка",,,,КвалификаторСтроки));
		НовыйПоток.ТаблицаКлючей.Колонки.Добавить("Актив", Новый ОписаниеТипов("СправочникСсылка.Активы"));
		НовыйПоток.ТаблицаКлючей.Колонки.Добавить("ПредставлениеАктив", Новый ОписаниеТипов("Строка",,,,КвалификаторСтроки));
	КонецЦикла;
	
	Запрос = Новый Запрос;
	Запрос.Текст = ТекстЗапроса;
	
	Запрос.УстановитьПараметр("ДатаНачала", НачалоДня(ДатаНачала));
	Запрос.УстановитьПараметр("ДатаОкончания", КонецДня(ДатаОкончания));
	Если Фонды.Количество() = 0 Тогда
		Запрос.УстановитьПараметр("ВсеПИФы", Истина);
		Запрос.УстановитьПараметр("ПИФы", Справочники.ПИФ.ПустаяСсылка());
	Иначе
		Запрос.УстановитьПараметр("ВсеПИФы", ЛОЖЬ);
		Запрос.УстановитьПараметр("ПИФы", Фонды.ВыгрузитьКолонку("ПИФ"));
	КонецЕсли;
	
	СписокЗадач = Запрос.Выполнить().Выгрузить();
	// Перебираем задачи-грузы. На каждой итерации цикла ищем наименее загруженный вагон-поток
	// Самые тяжелые задачи-грузы упаковываем в наименее загруженный вагон-поток
	Для Каждого ТекущаяЗадача Из СписокЗадач Цикл
		НаименееЗагруженныйПоток = ОпределитьНаименееЗагруженныйПоток(Потоки);
		НаименееЗагруженныйПоток.ТекущаяЗагрузка = НаименееЗагруженныйПоток.ТекущаяЗагрузка + ТекущаяЗадача.КоличествоЗадач;
		НоваяСтрока = НаименееЗагруженныйПоток.ТаблицаКлючей.Добавить();
		НоваяСтрока.Пиф = ТекущаяЗадача.ПИФ;
		НоваяСтрока.ПредставлениеПИФ = ТекущаяЗадача.ПредставлениеПИФ;
		Если ГруппировкаПоАктиву Тогда
			НоваяСтрока.Актив = ТекущаяЗадача.Актив;
			НоваяСтрока.ПредставлениеАктив = ТекущаяЗадача.ПредставлениеАктив;
		КонецЕсли;	
	КонецЦикла;
	
	Возврат Потоки;
КонецФункции

Функция ОжидатьВыполненияЗаданий(МассивЗаданий)
	ВсеЗаданияВыполнены = Ложь;
	МассивСообщенийИзЗадания = Новый Массив;
	Комментарий = "";
	
	Пока ВсеЗаданияВыполнены = Ложь Цикл
		МассивУдалить = Новый Массив;
		Для Каждого Элемент из МассивЗаданий Цикл
			ТекущееЗадание = ФоновыеЗадания.НайтиПоУникальномуИдентификатору(Элемент);
			Если ТекущееЗадание.Состояние = СостояниеФоновогоЗадания.Активно Тогда
				Продолжить;
			Иначе
				МассивУдалить.Добавить(Элемент);
				СообщенияЗадания = ТекущееЗадание.ПолучитьСообщенияПользователю(Истина);
				тмпСообщенияЗадания = Новый Массив(СообщенияЗадания);
				Для Каждого Элемент Из тмпСообщенияЗадания Цикл
					МассивСообщенийИзЗадания.Добавить(Элемент.Текст);	
				КонецЦикла;
			КонецЕсли;
		КонецЦикла;				
		
		Для Каждого Элемент из МассивУдалить Цикл
			Индекс = МассивЗаданий.Найти(Элемент);
			МассивЗаданий.Удалить(Индекс);	
		КонецЦикла;	
		
		ВсеЗаданияВыполнены = МассивЗаданий.Количество() = 0;
	КонецЦикла;			
	
	Для Каждого Элемент из МассивСообщенийИзЗадания Цикл
		Комментарий = Комментарий + Символы.ПС + Элемент;	
	КонецЦикла;	
	
	Комментарий = Комментарий + Символы.ПС + "Все фоновые задания выполнены";
	Отказ = СтрНайти(Комментарий, "ОШИБКА:") > 0;
	
	Возврат Комментарий;
КонецФункции

