#Область ОбработчикиКомандФормы

// Описание: Запускает удаление БП СделкиTn за выбранный день.
// По умолчанию объекты помечаются на удаление; непосредственное удаление включается флагом на форме.
//
// Параметры:
// Команда - КомандаФормы - команда формы.
//
&НаКлиенте
Процедура ВыполнитьУдаление(Команда)

    Если Не ЗначениеЗаполнено(ДатаУдаления) Тогда
        Сообщить("Заполните дату удаления.", СтатусСообщения.Важное);
        Возврат;
    КонецЕсли;

    Результат = ВыполнитьУдалениеНаСервере(ДатаУдаления, НепосредственноеУдаление, ПИФОтбор);
    ТекстРежима = ?(НепосредственноеУдаление, "фактическое удаление", "пометка на удаление");

    Сообщить(
        "Режим: " + ТекстРежима
        + ". БП: " + Формат(Результат.КоличествоБП, "ЧГ=0")
        + ", задачи: " + Формат(Результат.КоличествоЗадач, "ЧГ=0")
        + ", документы: " + Формат(Результат.КоличествоДокументов, "ЧГ=0")
        + ", ошибки: " + Формат(Результат.КоличествоОшибок, "ЧГ=0")
        + ", ПИФ: " + ?(ЗначениеЗаполнено(ПИФОтбор), Строка(ПИФОтбор), "все"),
        ?(Результат.КоличествоОшибок > 0, СтатусСообщения.Важное, СтатусСообщения.Информация)
    );

    Если ЗначениеЗаполнено(Результат.Протокол) Тогда
        Сообщить(Результат.Протокол);
    КонецЕсли;

КонецПроцедуры

&НаСервере
Функция ВыполнитьУдалениеНаСервере(Знач ДеньУдаления, Знач НепосредственноеУдаление, Знач ПИФОтбор)

    ОбъектОбработки = РеквизитФормыВЗначение("Объект");
    Результат = ОбъектОбработки.ВыполнитьУдалениеЗаДень(ДеньУдаления, НепосредственноеУдаление, ПИФОтбор);
    ЗначениеВРеквизитФормы(ОбъектОбработки, "Объект");

    Возврат Результат;

КонецФункции

&НаКлиенте
Процедура ПоказатьОтчетКУдалению(Команда)

    Если Не ЗначениеЗаполнено(ДатаУдаления) Тогда
        Сообщить("Заполните дату удаления.", СтатусСообщения.Важное);
        Возврат;
    КонецЕсли;

    РезультатОтчета = ПолучитьОтчетКУдалениюНаСервере(ДатаУдаления, ПИФОтбор);

    Сообщить(
        "Отчет к удалению. БП: " + Формат(РезультатОтчета.КоличествоБП, "ЧГ=0")
        + ", ПИФ: " + ?(ЗначениеЗаполнено(ПИФОтбор), Строка(ПИФОтбор), "все"),
        СтатусСообщения.Информация
    );

    Если ЗначениеЗаполнено(РезультатОтчета.Протокол) Тогда
        Сообщить(РезультатОтчета.Протокол);
    КонецЕсли;

    Для Каждого СтрокаОтчета Из РезультатОтчета.ТаблицаОтчета Цикл
        Сообщить(СтрокаОтчета.ВидОбъекта + ": " + Формат(СтрокаОтчета.Количество, "ЧГ=0"));
    КонецЦикла;

КонецПроцедуры

&НаСервере
Функция ПолучитьОтчетКУдалениюНаСервере(Знач ДеньУдаления, Знач ПИФОтбор)

    ОбъектОбработки = РеквизитФормыВЗначение("Объект");
    Результат = ОбъектОбработки.ПолучитьОтчетКУдалениюЗаДень(ДеньУдаления, ПИФОтбор);
    ЗначениеВРеквизитФормы(ОбъектОбработки, "Объект");

    Возврат Результат;

КонецФункции

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)

    ДатаУдаления = ТекущаяДата();
    НепосредственноеУдаление = Ложь;
    ПИФОтбор = Справочники.ПИФ.ПустаяСсылка();

КонецПроцедуры

