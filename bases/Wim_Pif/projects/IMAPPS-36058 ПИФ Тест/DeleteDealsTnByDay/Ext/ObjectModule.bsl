#Область ОписаниеПеременных

Перем ИмяСобытияЖурналаРегистрации;

#КонецОбласти

#Область ПрограммныйИнтерфейс

// Описание: Возвращает описание внешней обработки для механизма ДополнительныеОтчетыИОбработки.
//
// Возвращаемое значение:
// Структура - параметры регистрации обработки и команды запуска формы.
//
Функция СведенияОВнешнейОбработке() Экспорт
	
	МетаОбъект = ЭтотОбъект.Метаданные();
	
	ПараметрыРегистрации = ДополнительныеОтчетыИОбработки.СведенияОВнешнейОбработке();
	ПараметрыРегистрации.Вид = ДополнительныеОтчетыИОбработкиКлиентСервер.ВидОбработкиДополнительнаяОбработка();
	ПараметрыРегистрации.Наименование = МетаОбъект.Синоним;
	ПараметрыРегистрации.Версия = "1.0";
	ПараметрыРегистрации.БезопасныйРежим = Ложь;
	ПараметрыРегистрации.Информация = "Удаление БП СделкиTn за выбранный день и связанных сущностей.";
	
	Команда = ПараметрыРегистрации.Команды.Добавить();
	Команда.Представление = "Открыть";
	Команда.Идентификатор = МетаОбъект.Имя;
	Команда.Использование = ДополнительныеОтчетыИОбработкиКлиентСервер.ВариантЗапускаОткрытиеФормы();
	
	Возврат ПараметрыРегистрации;
	
КонецФункции

// Описание: Выполняет удаление БП СделкиTn за выбранный день, а также связанных задач и документов.
// По умолчанию выполняется пометка на удаление, непосредственное удаление включается флагом.
//
// Параметры:
// ДеньУдаления - Дата - дата, за которую нужно выполнить удаление.
// НепосредственноеУдаление - Булево - Истина: выполнять физическое удаление; Ложь: помечать на удаление.
// ПИФОтбор - СправочникСсылка.ПИФ - если заполнен, удаление выполняется только по указанному ПИФ.
//
// Возвращаемое значение:
// Структура - Протокол, КоличествоБП, КоличествоЗадач, КоличествоДокументов, КоличествоОшибок.
//
Функция ВыполнитьУдалениеЗаДень(Знач ДеньУдаления, Знач НепосредственноеУдаление = Ложь, Знач ПИФОтбор = Неопределено) Экспорт
	
	Статистика = Новый Структура(
	"Протокол,КоличествоБП,КоличествоЗадач,КоличествоДокументов,КоличествоОшибок",
	"",
	0,
	0,
	0,
	0
	);
	
	ИмяСобытияЖурналаРегистрации = "DeleteDealsTnByDay";
	
	Если Не ЗначениеЗаполнено(ДеньУдаления) Тогда
		ДобавитьСтрокуВПротокол(Статистика, "Не заполнена дата удаления.");
		Статистика.КоличествоОшибок = Статистика.КоличествоОшибок + 1;
		Возврат Статистика;
	КонецЕсли;
	
	ДатаНачала = НачалоДня(ДеньУдаления);
	ДатаОкончания = КонецДня(ДеньУдаления);
	
	МассивБизнесПроцессов = ПолучитьСделкиTnЗаПериод(ДатаНачала, ДатаОкончания, ПИФОтбор);
	ДобавитьСтрокуВПротокол(
	Статистика,
	"Найдено БП СделкиTn за период " + Формат(ДатаНачала, "ДФ=yyyy-MM-dd")
	+ ", ПИФ: " + ?(ЗначениеЗаполнено(ПИФОтбор), Строка(ПИФОтбор), "все")
	+ ": " + МассивБизнесПроцессов.Количество()
	);
	
	СоответствиеОбработанных = Новый Соответствие();
	
	Для Каждого СсылкаБП Из МассивБизнесПроцессов Цикл
		ДобавитьСтрокуВПротокол(Статистика, "Обработка БП: " + Строка(СсылкаБП));
		
		Для Каждого СсылкаЗадачи Из ПолучитьЗадачиПоБизнесПроцессу(СсылкаБП) Цикл
			ОбработатьСсылку(СсылкаЗадачи, НепосредственноеУдаление, Статистика, СоответствиеОбработанных);
		КонецЦикла;
		
		Попытка
			ОбъектБП = СсылкаБП.ПолучитьОбъект();
			Для Каждого СвязаннаяСсылка Из ПолучитьСвязанныеСсылкиОбъекта(ОбъектБП, СсылкаБП) Цикл
				ОбработатьСсылку(СвязаннаяСсылка, НепосредственноеУдаление, Статистика, СоответствиеОбработанных);
			КонецЦикла;
		Исключение
			Статистика.КоличествоОшибок = Статистика.КоличествоОшибок + 1;
			ДобавитьСтрокуВПротокол(Статистика, "Ошибка чтения БП: " + ОписаниеОшибки());
		КонецПопытки;
		
		ОбработатьСсылку(СсылкаБП, НепосредственноеУдаление, Статистика, СоответствиеОбработанных);
	КонецЦикла;
	
	ДобавитьСтрокуВПротокол(
	Статистика,
	"Итог: БП=" + Статистика.КоличествоБП
	+ ", Задачи=" + Статистика.КоличествоЗадач
	+ ", Документы=" + Статистика.КоличествоДокументов
	+ ", Ошибки=" + Статистика.КоличествоОшибок
	+ ", НепосредственноеУдаление=" + ?(НепосредственноеУдаление, "Да", "Нет")
	+ ", ПИФ=" + ?(ЗначениеЗаполнено(ПИФОтбор), Строка(ПИФОтбор), "все")
	);
	
	ЗаписьЖурналаРегистрации(
	ИмяСобытияЖурналаРегистрации,
	?(Статистика.КоличествоОшибок > 0, УровеньЖурналаРегистрации.Ошибка, УровеньЖурналаРегистрации.Информация),
	,
	,
	Статистика.Протокол
	);
	
	Возврат Статистика;
	
КонецФункции

// Описание: Формирует отчет о количестве объектов к удалению по видам объектов.
// Отчет учитывает выбранный день и опциональный отбор по ПИФ.
//
// Параметры:
// ДеньУдаления - Дата - дата, за которую строится отчет.
// ПИФОтбор - СправочникСсылка.ПИФ - если заполнен, отчет строится только по указанному ПИФ.
//
// Возвращаемое значение:
// Структура - ТаблицаОтчета (ТаблицаЗначений), Протокол (Строка), КоличествоБП (Число).
//
Функция ПолучитьОтчетКУдалениюЗаДень(Знач ДеньУдаления, Знач ПИФОтбор = Неопределено) Экспорт
	
	ТаблицаОтчета = Новый ТаблицаЗначений;
	ТаблицаОтчета.Колонки.Добавить("ВидОбъекта");
	ТаблицаОтчета.Колонки.Добавить("Количество");
	
	Протокол = "";
	
	Если Не ЗначениеЗаполнено(ДеньУдаления) Тогда
		Возврат Новый Структура("ТаблицаОтчета,Протокол,КоличествоБП", ТаблицаОтчета, "Не заполнена дата отчета.", 0);
	КонецЕсли;
	
	ДатаНачала = НачалоДня(ДеньУдаления);
	ДатаОкончания = КонецДня(ДеньУдаления);
	
	МассивБизнесПроцессов = ПолучитьСделкиTnЗаПериод(ДатаНачала, ДатаОкончания, ПИФОтбор);
	Протокол = "Найдено БП СделкиTn: " + МассивБизнесПроцессов.Количество()
	+ ", ПИФ: " + ?(ЗначениеЗаполнено(ПИФОтбор), Строка(ПИФОтбор), "все");
	
	СоответствиеВидов = Новый Соответствие;
	СоответствиеОбработанных = Новый Соответствие;
	
	Для Каждого СсылкаБП Из МассивБизнесПроцессов Цикл
		УчестьОбъектДляОтчета(СсылкаБП, СоответствиеВидов, СоответствиеОбработанных);
		
		Для Каждого СсылкаЗадачи Из ПолучитьЗадачиПоБизнесПроцессу(СсылкаБП) Цикл
			УчестьОбъектДляОтчета(СсылкаЗадачи, СоответствиеВидов, СоответствиеОбработанных);
		КонецЦикла;
		
		Попытка
			ОбъектБП = СсылкаБП.ПолучитьОбъект();
			Для Каждого СвязаннаяСсылка Из ПолучитьСвязанныеСсылкиОбъекта(ОбъектБП, СсылкаБП) Цикл
				УчестьОбъектДляОтчета(СвязаннаяСсылка, СоответствиеВидов, СоответствиеОбработанных);
			КонецЦикла;
		Исключение
			Протокол = Протокол + Символы.ПС + "Ошибка анализа связей для " + Строка(СсылкаБП) + ": " + ОписаниеОшибки();
		КонецПопытки;
	КонецЦикла;
	
	Для Каждого ПараВида Из СоответствиеВидов Цикл
		НоваяСтрока = ТаблицаОтчета.Добавить();
		НоваяСтрока.ВидОбъекта = ПараВида.Ключ;
		НоваяСтрока.Количество = ПараВида.Значение;
	КонецЦикла;
	
	Возврат Новый Структура("ТаблицаОтчета,Протокол,КоличествоБП", ТаблицаОтчета, Протокол, МассивБизнесПроцессов.Количество());
	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ПолучитьСделкиTnЗаПериод(Знач ДатаНачала, Знач ДатаОкончания, Знач ПИФОтбор = Неопределено)
	
	Результат = Новый Массив;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|    СделкиTn.Ссылка КАК Ссылка
	|ИЗ
	|    БизнесПроцесс.СделкиTn КАК СделкиTn
	|ГДЕ
	|    СделкиTn.Дата МЕЖДУ &ДатаНачала И &ДатаОкончания
	|    И Не СделкиTn.ПометкаУдаления
	|    И (&ИспользоватьОтборПоПИФ = Ложь Или СделкиTn.ПИФ = &ПИФ)";
	Запрос.УстановитьПараметр("ДатаНачала", ДатаНачала);
	Запрос.УстановитьПараметр("ДатаОкончания", ДатаОкончания);
	Запрос.УстановитьПараметр("ИспользоватьОтборПоПИФ", ЗначениеЗаполнено(ПИФОтбор));
	Запрос.УстановитьПараметр("ПИФ", ПИФОтбор);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		Результат.Добавить(Выборка.Ссылка);
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Процедура УчестьОбъектДляОтчета(Знач СсылкаОбъекта, СоответствиеВидов, СоответствиеОбработанных)
	
	Если Не ЗначениеЗаполнено(СсылкаОбъекта) Тогда
		Возврат;
	КонецЕсли;
	Если СоответствиеОбработанных[СсылкаОбъекта] = Истина Тогда
		Возврат;
	КонецЕсли;
	
	СоответствиеОбработанных.Вставить(СсылкаОбъекта, Истина);
	
	ТипСсылки = Строка(ТипЗнч(СсылкаОбъекта));
	Если ЭтоУдаляемаяСсылка(СсылкаОбъекта) Тогда
		Если СоответствиеВидов[ТипСсылки] = Неопределено Тогда
			СоответствиеВидов.Вставить(ТипСсылки, 0);
		КонецЕсли;
		СоответствиеВидов[ТипСсылки] = СоответствиеВидов[ТипСсылки] + 1;
	КонецЕсли;
	
КонецПроцедуры

Функция ПолучитьЗадачиПоБизнесПроцессу(Знач СсылкаБизнесПроцесса)
	
	МассивСсылок = Новый Массив;
	
	Для Каждого МетаЗадача Из Метаданные.Задачи Цикл
		Попытка
			Запрос = Новый Запрос;
			Запрос.Текст =
			"ВЫБРАТЬ
			|    ЗадачаТекущая.Ссылка КАК Ссылка
			|ИЗ
			|    Задача." + МетаЗадача.Имя + " КАК ЗадачаТекущая
			|ГДЕ
			|    ЗадачаТекущая.БизнесПроцесс = &БизнесПроцесс";
			Запрос.УстановитьПараметр("БизнесПроцесс", СсылкаБизнесПроцесса);
			
			Выборка = Запрос.Выполнить().Выбрать();
			Пока Выборка.Следующий() Цикл
				ДобавитьСсылкуЕслиНовая(Выборка.Ссылка, МассивСсылок);
			КонецЦикла;
		Исключение
			// В отдельных конфигурациях у задачи может отсутствовать реквизит БизнесПроцесс.
		КонецПопытки;
	КонецЦикла;
	
	Возврат МассивСсылок;
	
КонецФункции

Функция ПолучитьСвязанныеСсылкиОбъекта(Знач ОбъектБП, Знач СсылкаИсключение)
	
	МассивСсылок = Новый Массив;
	
	Для Каждого МетаРеквизит Из ОбъектБП.Метаданные().Реквизиты Цикл
		ДобавитьСсылкиИзЗначения(ОбъектБП[МетаРеквизит.Имя], МассивСсылок, СсылкаИсключение);
	КонецЦикла;
	
	Для Каждого МетаТабличнаяЧасть Из ОбъектБП.Метаданные().ТабличныеЧасти Цикл
		Для Каждого СтрокаТЧ Из ОбъектБП[МетаТабличнаяЧасть.Имя] Цикл
			Для Каждого МетаРеквизитТЧ Из МетаТабличнаяЧасть.Реквизиты Цикл
				ДобавитьСсылкиИзЗначения(СтрокаТЧ[МетаРеквизитТЧ.Имя], МассивСсылок, СсылкаИсключение);
			КонецЦикла;
		КонецЦикла;
	КонецЦикла;
	
	Возврат МассивСсылок;
	
КонецФункции

Процедура ДобавитьСсылкиИзЗначения(Знач Значение, МассивСсылок, Знач СсылкаИсключение)
	
	Если Не ЗначениеЗаполнено(Значение) Тогда
		Возврат;
	КонецЕсли;
	
	Если ТипЗнч(Значение) = Тип("Массив") Тогда
		Для Каждого Элемент Из Значение Цикл
			ДобавитьСсылкиИзЗначения(Элемент, МассивСсылок, СсылкаИсключение);
		КонецЦикла;
		Возврат;
	КонецЕсли;
	
	Если ЭтоУдаляемаяСсылка(Значение) И Значение <> СсылкаИсключение Тогда
		ДобавитьСсылкуЕслиНовая(Значение, МассивСсылок);
	КонецЕсли;
	
КонецПроцедуры

Функция ЭтоУдаляемаяСсылка(Знач Значение)
	Попытка
		ИмяОбъектаМетаданного = Метаданные.НайтиПоТипу(ТипЗнч(Значение)).ПолноеИмя();
	Исключение
		Возврат Ложь;
	КонецПопытки;
	Возврат ЗначениеЗаполнено(Значение)
	И (
		СтрНайти(ИмяОбъектаМетаданного, "Документ.") > 0
			Или СтрНайти(ИмяОбъектаМетаданного, "Задача.") > 0
			Или СтрНайти(ИмяОбъектаМетаданного, "БизнесПроцесс.") > 0
	);
КонецФункции

Процедура ДобавитьСсылкуЕслиНовая(Знач Ссылка, МассивСсылок)
	
	Если Не ЗначениеЗаполнено(Ссылка) Тогда
		Возврат;
	КонецЕсли;
	
	Если МассивСсылок.Найти(Ссылка) = Неопределено Тогда
		МассивСсылок.Добавить(Ссылка);
	КонецЕсли;
	
КонецПроцедуры

Процедура ОбработатьСсылку(Знач СсылкаУдаления, Знач НепосредственноеУдаление, Статистика, СоответствиеОбработанных)
	
	Если Не ЗначениеЗаполнено(СсылкаУдаления) Тогда
		Возврат;
	КонецЕсли;
	
	Если СоответствиеОбработанных[СсылкаУдаления] = Истина Тогда
		Возврат;
	КонецЕсли;
	СоответствиеОбработанных.Вставить(СсылкаУдаления, Истина);
	
	ТипСсылки = Строка(ТипЗнч(СсылкаУдаления));
	
	Если Не НепосредственноеУдаление Тогда
		Помечено = Ложь;
		ТекстОшибкиПометки = "";
		
		Попытка
			ОбъектУдаления = СсылкаУдаления.Предмет.ПолучитьОбъект();
			ОбъектУдаления.УстановитьПометкуУдаления(Истина);
		Исключение
		КонецПопытки;
		
		Попытка
			ОбъектУдаления = СсылкаУдаления.ПолучитьОбъект();
			ОбъектУдаления.УстановитьПометкуУдаления(Истина);
			Помечено = Истина;
		Исключение
			ТекстОшибкиПометки = ОписаниеОшибки();
		КонецПопытки;
		
		Если Помечено Тогда
			ОбновитьСчетчикиПоТипу(ТипСсылки, Статистика);
			ДобавитьСтрокуВПротокол(Статистика, "Помечено на удаление: " + Строка(СсылкаУдаления));
		Иначе
			Статистика.КоличествоОшибок = Статистика.КоличествоОшибок + 1;
			ДобавитьСтрокуВПротокол(
			Статистика,
			"Ошибка пометки на удаление: " + Строка(СсылкаУдаления) + " | " + ТекстОшибкиПометки
			);
		КонецЕсли;
		Возврат;
	КонецЕсли;
	
	Удалено = Ложь;
	ТекстОшибкиУдаления = "";
	
	
	
	Попытка
		ОбъектУдаления = СсылкаУдаления.Предмет.ПолучитьОбъект();
		ОбъектУдаления.Удалить();
	Исключение
	КонецПопытки;
	
	Попытка
		ОбъектУдаления = СсылкаУдаления.ПолучитьОбъект();
		Попытка
			ОбъектУдаления.Удалить();
			Удалено = Истина;
		Исключение
			ТекстОшибкиУдаления = ОписаниеОшибки();
		КонецПопытки;
		
		Если Не Удалено Тогда
			Попытка
				ОбъектУдаления.УстановитьПометкуУдаления(Истина);
				Удалено = Истина;
			Исключение
				Если ПустаяСтрока(ТекстОшибкиУдаления) Тогда
					ТекстОшибкиУдаления = ОписаниеОшибки();
				Иначе
					ТекстОшибкиУдаления = ТекстОшибкиУдаления + "; " + ОписаниеОшибки();
				КонецЕсли;
			КонецПопытки;
		КонецЕсли;
	Исключение
		ТекстОшибкиУдаления = ОписаниеОшибки();
	КонецПопытки;
	
	Если Удалено Тогда
		
		ИмяОбъектаМетаданного = Метаданные.НайтиПоТипу(ТипЗнч(СсылкаУдаления)).ПолноеИмя();
		ОбновитьСчетчикиПоТипу(ИмяОбъектаМетаданного, Статистика);
		ДобавитьСтрокуВПротокол(Статистика, "Удалено: " + Строка(СсылкаУдаления));
	Иначе
		Статистика.КоличествоОшибок = Статистика.КоличествоОшибок + 1;
		ДобавитьСтрокуВПротокол(
		Статистика,
		"Ошибка удаления: " + Строка(СсылкаУдаления) + " | " + ТекстОшибкиУдаления
		);
	КонецЕсли;
	
КонецПроцедуры

Процедура ОбновитьСчетчикиПоТипу(Знач ТипСсылки, Статистика)
	
	Если СтрНайти(ТипСсылки, "БизнесПроцесс.") > 0 Тогда
		Статистика.КоличествоБП = Статистика.КоличествоБП + 1;
	ИначеЕсли СтрНайти(ТипСсылки, "Задача.") > 0 Тогда
		Статистика.КоличествоЗадач = Статистика.КоличествоЗадач + 1;
	ИначеЕсли СтрНайти(ТипСсылки, "Документ.") > 0 Тогда
		Статистика.КоличествоДокументов = Статистика.КоличествоДокументов + 1;
	КонецЕсли;
	
КонецПроцедуры

Процедура ДобавитьСтрокуВПротокол(Статистика, Знач Текст)
	
	Если ПустаяСтрока(Статистика.Протокол) Тогда
		Статистика.Протокол = Текст;
	Иначе
		Статистика.Протокол = Статистика.Протокол + Символы.ПС + Текст;
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти