Процедура ОтправитьПисьмоОбОшибке(Знач ЗагТекстаОтказа = "", Знач ТекстОтказа = "");
	// IMAPPS-25660 ++
	ДатаОкончанияПроцесса			= ТекущаяДатаСеанса();
	КомментарийЖурналаРегистрации	= "Окончание процесса: " + Формат(ДатаОкончанияПроцесса, "ДФ='yyyy-MM-dd HH:mm:ss'");
	
	Если Не ПустаяСтрока(ИмяСобытияЖурналаРегистрации) Тогда
		ЗаписьЖурналаРегистрации(ИмяСобытияЖурналаРегистрации, УровеньЖурналаРегистрации.Ошибка, , , КомментарийЖурналаРегистрации);
	КонецЕсли;
	// IMAPPS-25660 --
	
	МассивСообщений = ПолучитьСообщенияПользователю();
	Комментарий = ЗагТекстаОтказа + ТекстОтказа; 
	Для Каждого Сообщение ИЗ МассивСообщений Цикл
		Комментарий = Комментарий + Символы.ПС + Сообщение.Текст;
	КонецЦикла;
	
	// Рассылка по электронной почте
	СписокРассылки = Новый Массив;
	УчетнаяЗаписьЭлПочты = Неопределено;
	Если ЗначениеЗаполнено(ЭтотОбъект.Адресаты) Тогда
		СписокРассылки = ЭтотОбъект.Адресаты;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ЭтотОбъект.УчетнаяЗаписьЭлектроннойПочты) Тогда
		УчетнаяЗаписьЭлПочты = ЭтотОбъект.УчетнаяЗаписьЭлектроннойПочты;
	КонецЕсли;
	
	Если СписокРассылки.Количество() > 0 И ЗначениеЗаполнено(УчетнаяЗаписьЭлПочты) Тогда
		
		ПараметрыПисьма = Новый Структура("Кому, Тема, Тело, Вложения, Важность");
		// IMAPPS-25660 ++
		// ПараметрыПисьма.Тема = "{FAIL} " + "Аванкор ПИФ: Фоновое исполнение сделок T+n и РЕПО (" + Формат(ТекущаяДата(), "ДФ=yyyy-MM-dd; ДП=") + ")" + ПропискаРассылки("r55");
		ПараметрыПисьма.Тема = "{FAIL} " + "Аванкор ПИФ: Фоновое исполнение сделок T+n и РЕПО " 
								+ "(" + Формат(ДатаИсполнения, "ДФ=yyyy-MM-dd; ДП=") + ")" + ПропискаРассылки("r55");
		ТелоПисьма = "Старт процесса:" + Формат(ДатаНачалаИсполнения, "ДФ='yyyy-MM-dd HH:mm:ss'") + Символы.ПС
						+ "Окончание процесса:" + Формат(ДатаОкончанияИсполнения, "ДФ='yyyy-MM-dd HH:mm:ss'") + Символы.ПС + Символы.ПС
						+ Комментарий;
		// IMAPPS-25660 --
		ПараметрыПисьма.Важность = ВажностьИнтернетПочтовогоСообщения.Высокая;
		
		Кому = Новый Массив;
		Для Каждого ТекЯщик из СписокРассылки Цикл
			Кому.Добавить(Новый Структура("Адрес, Представление", ТекЯщик.АдресЭлектроннойПочты, ТекЯщик.Представление));
		КонецЦикла;
		
		ПараметрыПисьма.Вложения = Новый Соответствие;
		ПараметрыПисьма.Кому = Кому;
		// IMAPPS-25660 ++
		// ПараметрыПисьма.Тело = Комментарий;
		ПараметрыПисьма.Тело = ТелоПисьма;
		// IMAPPS-25660 --
		
		РаботаСПочтовымиСообщениями.ОтправитьСообщение(УчетнаяЗаписьЭлПочты, ПараметрыПисьма);
		ТекстРассылки = "Рассылка завершена";
			
	КонецЕсли;

КонецПроцедуры
