Процедура ИсполнениеСделокFX(Дата, Отказ, ТекстОтказа, ПараметрыИсполнения)
	
	ПараметрыОтбораЗадач = Новый Структура("Дата, Фонды, СтартоватьТолькоПланПозиции, БизнесПроцессыПоПлановойПозиции"
										   ,Дата, Неопределено, Ложь, Неопределено);
                                           
	СтартоватьТолькоПланПозиции         = ПараметрыОтбораЗадач.СтартоватьТолькоПланПозиции;
	СписокФондов 						= ПараметрыОтбораЗадач.Фонды;
	
	Если ЗначениеЗаполнено(ПараметрыИсполнения) Тогда
		Если ПараметрыИсполнения.Свойство("Фонды") Тогда
			СписокФондов = ПараметрыИсполнения.Фонды;
			ПараметрыОтбораЗадач.Фонды = СписокФондов;
		КонецЕсли;
		
		Если ПараметрыИсполнения.Свойство("СтартоватьТолькоПланПозиции") Тогда
			СтартоватьТолькоПланПозиции = ПараметрыИсполнения.СтартоватьТолькоПланПозиции;
			ПараметрыОтбораЗадач.СтартоватьТолькоПланПозиции = СтартоватьТолькоПланПозиции;
		КонецЕсли;
		
	КонецЕсли; 
	
	ТекстОтказа = "";	
	ТочкаОткрытиеПлановойПозиции = БизнесПроцессы.БиржеваяСделкаСВалютой.ТочкиМаршрута.ОткрытиеПлановойПозиции;
	ЕстьОткрытиеПлановойПозиции = Ложь;
    БизнесПроцессыПоПлановойПозиции = Новый Массив;
    
	ОткрытыеЗадачи = ПолучитьОткрытыеЗадачиПоСделкеFX(ПараметрыОтбораЗадач);
	
	РежимОтладки = ПолныеПрава.РежимОтладки();
    
    Для каждого ТекЗадача Из ОткрытыеЗадачи Цикл
        
        Попытка
            
        ТекОбъект = ТекЗадача.Ссылка.ПолучитьОбъект();
        
        Если ТекЗадача.ТочкаМаршрута = ТочкаОткрытиеПлановойПозиции Тогда
            ЕстьОткрытиеПлановойПозиции = Истина;
            
            Если СтартоватьТолькоПланПозиции Тогда
                БизнесПроцессыПоПлановойПозиции.Добавить(ТекОбъект.БизнесПроцесс);
                
            КонецЕсли; 
        КонецЕсли;
        
        ТекОбъект.СинхронизоватьПредметПоЗадаче = Истина;
        ТекОбъект.ВыполнитьЗадачу();
        
        Если РежимОтладки тогда
            Сообщить(""+ТекЗадача.Регистратор);	
        КонецЕсли;
        
        Исключение
        
        Отказ = Истина;
        ТекстОтказа = ТекстОтказа + Символы.ПС + ОписаниеОшибки();
        
        КонецПопытки;
        
    КонецЦикла;
	
	// Если есть ОткрытиеПлановойПозиции то нужно выбирать задачи повторно.
	Если ЕстьОткрытиеПлановойПозиции Тогда
		
		ПараметрыОтбораЗадач.БизнесПроцессыПоПлановойПозиции = БизнесПроцессыПоПлановойПозиции;
		ПараметрыОтбораЗадач.СтартоватьТолькоПланПозиции = Ложь;
		ОткрытыеЗадачи = ПолучитьОткрытыеЗадачиПоСделкеFX(ПараметрыОтбораЗадач);
		
		Для каждого ТекЗадача Из ОткрытыеЗадачи Цикл
			
			Попытка	
				ТекОбъект = ТекЗадача.Ссылка.ПолучитьОбъект();
				ТекОбъект.СинхронизоватьПредметПоЗадаче = Истина;
				ТекОбъект.ВыполнитьЗадачу();
				
				Если РежимОтладки тогда
					Сообщить(""+ТекЗадача.Регистратор);	
				КонецЕсли;
			Исключение
				Отказ = Истина;
				ТекстОтказа = ТекстОтказа + Символы.ПС + ОписаниеОшибки();
			КонецПопытки;
			
		КонецЦикла;
		
	КонецЕсли;
	
КонецПроцедуры

Функция ПолучитьОткрытыеЗадачиПоСделкеFX(ПараметрыОтбораЗадач)
	
    ТочкаОткрытиеПлановойПозиции = БизнесПроцессы.БиржеваяСделкаСВалютой.ТочкиМаршрута.ОткрытиеПлановойПозиции;
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	ВнебиржеваяСделка.Ссылка КАК Ссылка,
	               |	ВнебиржеваяСделка.Предмет КАК Регистратор,
	               |	ВнебиржеваяСделка.Предмет.Дата,
	               |	ВнебиржеваяСделка.ТочкаМаршрута КАК ТочкаМаршрута
	               |ИЗ
	               |	Задача.ВнебиржеваяСделка КАК ВнебиржеваяСделка
	               |ГДЕ
	               |	ВнебиржеваяСделка.БизнесПроцесс ССЫЛКА БизнесПроцесс.БиржеваяСделкаСВалютой
	               |	И ВнебиржеваяСделка.ПометкаУдаления = ЛОЖЬ
	               |	И ВнебиржеваяСделка.БизнесПроцесс.ПометкаУдаления = ЛОЖЬ
	               |	И ВнебиржеваяСделка.Выполнена = ЛОЖЬ
	               |	И ВнебиржеваяСделка.СрокИсполнения МЕЖДУ &ДатаНачала И &ДатаОкончания
	               |	И &Условие1
	               |	И &Условие2
	               |	И &Условие3
	               |
	               |УПОРЯДОЧИТЬ ПО
	               |	Дата,
	               |	Регистратор";
    
    Если ЗначениеЗаполнено(ПараметрыОтбораЗадач.Фонды) Тогда
        Запрос.Текст = СтрЗаменить(Запрос.Текст, "&Условие1", "ВнебиржеваяСделка.БизнесПроцесс.ПИФ В(&Фонды)");
    Иначе
        Запрос.Текст = СтрЗаменить(Запрос.Текст, "&Условие1", "ИСТИНА");
    КонецЕсли;
    
    Если ПараметрыОтбораЗадач.СтартоватьТолькоПланПозиции = ИСТИНА Тогда
        Запрос.Текст = СтрЗаменить(Запрос.Текст, "&Условие2", "ВнебиржеваяСделка.ТочкаМаршрута.Ссылка = &ТочкаОткрытиеПлановойПозиции");
    Иначе
        Запрос.Текст = СтрЗаменить(Запрос.Текст, "&Условие2", "ИСТИНА");
    КонецЕсли;
    
    Если ЗначениеЗаполнено(ПараметрыОтбораЗадач.БизнесПроцессыПоПлановойПозиции) Тогда
        Запрос.Текст = СтрЗаменить(Запрос.Текст, "&Условие3", "ВнебиржеваяСделка.БизнесПроцесс В(&БизнесПроцессыПоПлановойПозиции)");
    Иначе
        Запрос.Текст = СтрЗаменить(Запрос.Текст, "&Условие3", "ИСТИНА");
    КонецЕсли;
	
	Запрос.УстановитьПараметр("ДатаНачала", НачалоДня(ПараметрыОтбораЗадач.Дата));
	Запрос.УстановитьПараметр("ДатаОкончания", КонецДня(ПараметрыОтбораЗадач.Дата));
    Запрос.УстановитьПараметр("Фонды", ПараметрыОтбораЗадач.Фонды);
    Запрос.УстановитьПараметр("ТочкаОткрытиеПлановойПозиции", ТочкаОткрытиеПлановойПозиции);
    Запрос.УстановитьПараметр("БизнесПроцессыПоПлановойПозиции", ПараметрыОтбораЗадач.БизнесПроцессыПоПлановойПозиции);
    
	Результат = Запрос.Выполнить().Выгрузить();
	
	Возврат Результат;
	
КонецФункции

