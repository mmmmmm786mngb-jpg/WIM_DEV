Функция СохранитьЛогПроведения(Знач ЛогПроведения, Знач ДатаНачала, Знач ДатаОкончания)
	Перем Результат;
	Перем Вложения;
	Перем ПутьКФайлу, ДвоичныеДанные, АдресВложения;
		
	Вложения = Новый Соответствие();
	ТекстовыйДокумент = Новый ТекстовыйДокумент;
	
	ПутьКФайлу = ПолучитьИмяВременногоФайла(".txt");
	Для Каждого СтрокаЛога Из ЛогПроведения Цикл
		ТекстовыйДокумент.ДобавитьСтроку(СтрокаЛога.ПредставлениеСсылки);
		Если НЕ ПустаяСтрока(СтрокаЛога.СтрокаОшибок) Тогда
			ТекстовыйДокумент.ДобавитьСтроку(Символы.ПС + "ОШИБКА: ");
			ТекстовыйДокумент.ДобавитьСтроку(СтрокаЛога.СтрокаОшибок + Символы.ПС);
		КонецЕсли;	
	КонецЦикла;	
	ТекстовыйДокумент.Записать(ПутьКФайлу);
	ДвоичныеДанные = Новый ДвоичныеДанные(ПутьКФайлу);
	АдресВложения = ПоместитьВоВременноеХранилище(ДвоичныеДанные);
	Вложения.Вставить("Лог перепроведения документов за период: с " + Формат(ДатаНачала,"ДФ=yyyy-MM-dd; ДП=") + " по " + Формат(ДатаОкончания,"ДФ=yyyy-MM-dd; ДП=") + ".txt", АдресВложения);
		
	Результат = Новый Структура;
	Результат.Вставить("ПутьКФайлу", ПутьКФайлу);
	Результат.Вставить("Вложения", Вложения);
	Возврат Результат;
КонецФункции


Процедура УстановитьПараметрыПисьмаИОтправитьСообщение(УчетнаяЗаписьЭлПочты, ПараметрыПисьма, ТекстПисьма, СписокРассылки, ЕстьОшибки, ТекстРассылки)
	ПараметрыПисьма.Важность = ?(ЕстьОшибки, ВажностьИнтернетПочтовогоСообщения.Высокая, ВажностьИнтернетПочтовогоСообщения.Обычная);
	Кому = Новый Массив;
	Для Каждого ТекЯщик из СписокРассылки Цикл
		Кому.Добавить(Новый Структура("Адрес, Представление", ТекЯщик.АдресЭлектроннойПочты, ТекЯщик.Представление));
	КонецЦикла;
	
	Если ПараметрыПисьма.Вложения = Неопределено Тогда
		ПараметрыПисьма.Вложения = Новый Соответствие;
	КонецЕсли;	
	ПараметрыПисьма.Кому = Кому;
	ПараметрыПисьма.Тело = ТекстПисьма;
			
	Попытка
		РаботаСПочтовымиСообщениями.ОтправитьСообщение(УчетнаяЗаписьЭлПочты, ПараметрыПисьма);
		ТекстРассылки = "Рассылка завершена";
	Исключение
		ТекстРассылки = "Рассылка не удалась: "; 
		Сообщения = ПолучитьСообщенияПользователю(Истина);
		Для Каждого Элемент из Сообщения Цикл
		  ТекстРассылки = ТекстРассылки + Символы.ПС + Элемент.Текст;
		Конеццикла;
	КонецПопытки;
КонецПроцедуры

