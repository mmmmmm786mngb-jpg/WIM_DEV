Процедура ОбновитьТаблицуФондов(Очищать = Истина) Экспорт
	
	Если Очищать Тогда
		ЭтотОбъект.Фонды.Очистить();
	КонецЕсли; 

	Запрос = Новый Запрос;
	Запрос.Текст = ТекстЗапросаОтборФондов();
	РезультатЗапроса = Запрос.Выполнить();
	Выборка = РезультатЗапроса.Выбрать();
	Выборка.Выбрать();	
	Пока Выборка.Следующий() Цикл
		Если ЭтотОбъект.Фонды.Найти(Выборка.Ссылка, "Фонд") = Неопределено Тогда
			СтрокаТабЧасти = ЭтотОбъект.Фонды.Добавить();
			СтрокаТабЧасти.Фонд = Выборка.Ссылка;
			СтрокаТабЧасти.Использовать = Истина;
		КонецЕсли; 
	КонецЦикла;	
	
