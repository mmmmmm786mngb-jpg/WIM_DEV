Процедура ПрочитатьНастройки(ЗаполнятьПуть = Ложь, НастройкиАлгоритма = Неопределено) Экспорт
    
	Если ЭтотОбъект.НастройкиПрочитаны Тогда
		Возврат;		
	КонецЕсли; 
	
	СтруктураНастроек = НастройкиАлгоритма;
	Если СтруктураНастроек = Неопределено Тогда
		Если ЗначениеЗаполнено(ЭтотОбъект.ПараметрыОбработки) Тогда
			СтруктураНастроек = ЭтотОбъект.ПараметрыОбработки.ДополнительнаяОбработкаСсылка.ХранилищеНастроек.Получить();						
		Иначе
			Если ЗначениеЗаполнено(ЭтотОбъект.СсылкаНаСправочник) Тогда
				СтруктураНастроек = ЭтотОбъект.СсылкаНаСправочник.ХранилищеНастроек.Получить();
			КонецЕсли; 			
		КонецЕсли;		
	КонецЕсли; 
	
	ПолученыНастройки = ТипЗнч(СтруктураНастроек) = Тип("Структура") И 
	СтруктураНастроек.Свойство("Значения") И
	ТипЗнч(СтруктураНастроек.Значения) = Тип("Структура");
	
	Если ПолученыНастройки Тогда 			
		МассивИменНастроек = ИменаНастроек();
		Для каждого ИмяНастройки Из МассивИменНастроек Цикл			
			ЗначениеНастройки = Неопределено;
			Если НЕ СтруктураНастроек.Значения.Свойство(ИмяНастройки, ЗначениеНастройки) Тогда
				Продолжить;				
			КонецЕсли; 
			
			Если ТипЗнч(ЗначениеНастройки) = Тип("ТаблицаЗначений") Тогда
				ЭтотОбъект[ИмяНастройки].Загрузить(ЗначениеНастройки);
			ИначеЕсли ТипЗнч(ЗначениеНастройки) = Тип("Массив") Тогда
				// Не можем конвертнуть массив в таблицу	
			Иначе
				ЭтотОбъект[ИмяНастройки] = ЗначениеНастройки;				
			КонецЕсли; 			
		КонецЦикла; 		
	КонецЕсли;
		
	ЭтотОбъект.НастройкиПрочитаны = Истина;
    
КонецПроцедуры

Функция НастройкиКСохранению() Экспорт
	
	ЗаголовокНастроек = "";
	СтруктураЗначенийНастроек = Новый Структура;
	
	МассивИменНастроек = ИменаНастроек();
	Для каждого ИмяНастройки Из МассивИменНастроек Цикл			
		ЗначениеНастройки = ЭтотОбъект[ИмяНастройки];
		
		МетаТабЧасть = МетаОбъект().ТабличныеЧасти.Найти(ИмяНастройки);
		Если МетаТабЧасть = Неопределено Тогда
			ПредставлениеНастройки = МетаОбъект().Реквизиты[ИмяНастройки].Синоним;
			ЗаголовокНастройки = ПредставлениеНастройки + ": " + СокрЛП(ЗначениеНастройки) + "; ";
		Иначе
			ЗначениеНастройки = ЗначениеНастройки.Выгрузить();	
			КолСтрок = ЗначениеНастройки.Количество();
			Если КолСтрок > 0 Тогда
				ЗаголовокНастройки = МетаТабЧасть.Синоним + " (" + ЗначениеНастройки.Количество() + "); ";				
			КонецЕсли;			
		КонецЕсли; 		
		ПереносСтроки = ?(ЗначениеЗаполнено(ЗаголовокНастроек), Символы.ПС, "");
		ЗаголовокНастроек = ЗаголовокНастроек + ПереносСтроки + ЗаголовокНастройки;
		
		СтруктураЗначенийНастроек.Вставить(ИмяНастройки, ЗначениеНастройки);
	КонецЦикла; 	
	
	СтруктураНастроек = Новый Структура("ЗаголовокНастроек, Значения", ЗаголовокНастроек, СтруктураЗначенийНастроек);	
	Возврат СтруктураНастроек;
    
КонецФункции

