// Описание: Создает новый элемент справочника Активы по данным формы.
//
// Параметры:
// Команда - КомандаФормы - команда формы.
//
&НаКлиенте
Процедура СоздатьАктив(Команда)
    
    Если Не ЗначениеЗаполнено(ВидАктива) Тогда
        Сообщить("Заполните поле ВидАктива.", СтатусСообщения.Важное);
        Возврат;
    КонецЕсли;
    
    Если Не ЗначениеЗаполнено(Объект) Тогда
        Сообщить("Заполните поле Объект.", СтатусСообщения.Важное);
        Возврат;
    КонецЕсли;
    
    Если Не ЗначениеЗаполнено(ВнешнийID) Тогда
        Сообщить("Заполните поле ВнешнийID.", СтатусСообщения.Важное);
        Возврат;
    КонецЕсли;
    
    Если Не ЗначениеЗаполнено(ДатаИзменения) Тогда
        Сообщить("Заполните поле ДатаИзменения.", СтатусСообщения.Важное);
        Возврат;
    КонецЕсли;
    
    Попытка
        СсылкаАктива = СоздатьАктивНаСервере(ВидАктива, Объект, ВнешнийID, ДатаИзменения);
        Сообщить("Актив создан: " + Строка(СсылкаАктива), СтатусСообщения.Обычное);
    Исключение
        Сообщить("Ошибка при создании актива: " + ОписаниеОшибки(), СтатусСообщения.Важное);
    КонецПопытки;
    
КонецПроцедуры

// Описание: Создает и записывает элемент справочника Активы.
//
// Параметры:
// ВидАктиваПараметр - Произвольный - значение реквизита ВидАктива.
// ОбъектПараметр - Произвольный - значение реквизита Объект.
// ВнешнийIDПараметр - Строка - значение реквизита ВнешнийID.
// ДатаИзмененияПараметр - Дата - значение реквизита ДатаИзменения.
//
// Возвращаемое значение:
// СправочникСсылка.Активы - ссылка на созданный элемент.
//
&НаСервере
Функция СоздатьАктивНаСервере(Знач ВидАктиваПараметр, Знач ОбъектПараметр, Знач ВнешнийIDПараметр, Знач ДатаИзмененияПараметр)
    
    НовыйАктив = Справочники.Активы.СоздатьЭлемент();
    НовыйАктив.ВидАктива = ВидАктиваПараметр;
    НовыйАктив.Объект = ОбъектПараметр;
    НовыйАктив.ВнешнийID = ВнешнийIDПараметр;
    НовыйАктив.ДатаИзменения = ДатаИзмененияПараметр;
    НовыйАктив.Записать();
    
    Возврат НовыйАктив.Ссылка;
    
КонецФункции

