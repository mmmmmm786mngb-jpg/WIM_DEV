Функция РежимТорговПоID(BoardId)
	СтруктураРезультата = Новый Структура("Ссылка, Наименование");
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("BoardId", BoardId);
	Запрос.Текст = "ВЫБРАТЬ
	               |	РежимыТоргов.Ссылка КАК Ссылка,
	               |	РежимыТоргов.Наименование КАК Наименование
	               |ИЗ
	               |	Справочник.РежимыТоргов КАК РежимыТоргов
	               |ГДЕ
	               |	РежимыТоргов.BoardId = &BoardId";
				   
	Результат = Запрос.Выполнить();
	Если Результат.Пустой() тогда
		НовыйРежим = Справочники.РежимыТоргов.СоздатьЭлемент();
		НовыйРежим.BoardId = BoardId;
		НовыйРежим.Наименование = BoardId;
		НовыйРежим.Записать();
		ЗаполнитьЗначенияСвойств(СтруктураРезультата, НовыйРежим);
	Иначе
		Выборка = Результат.Выбрать();
		Выборка.Следующий();
		ЗаполнитьЗначенияСвойств(СтруктураРезультата, Выборка);
	КонецЕсли;
	
	Возврат СтруктураРезультата;
КонецФункции

Функция ТорговыйКодПоКоду(КодКлиента, КодБрокера, КодБиржи)  // ИКФ: deprecated
	Перем Запрос;
	
	Запрос = Новый Запрос();
	Запрос.УстановитьПараметр("ЭтоOTC", (КодБиржи = "OTC"));
	Запрос.УстановитьПараметр("ТорговыйКод", КодКлиента);
	Запрос.УстановитьПараметр("Значение", КодБрокера);
	Запрос.УстановитьПараметр("Свойство", ПланыВидовХарактеристик.СвойстваОбъектов.НайтиПоНаименованию("Counterparty")); 
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ТорговыеКоды.Ссылка КАК БрокерскийСчет,
	|	ТорговыеКоды.АналитическийСчетЦБ КАК АналитическийСчетЦБ,
	|	ТорговыеКоды.АналитическийСчетДС КАК АналитическийСчетДС,
	|	ТорговыеКоды.ПИФ КАК ПИФ,
	|	ТорговыеКоды.Брокер КАК Брокер,
	|	ТорговыеКоды.ДоговорБрокера КАК ДоговорБрокера
	|ИЗ
	|	Справочник.ТорговыеКоды КАК ТорговыеКоды
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ЗначенияСвойствОбъектов КАК ЗначенияСвойствОбъектов
	|		ПО ТорговыеКоды.Брокер = ЗначенияСвойствОбъектов.Объект
	|			И (ЗначенияСвойствОбъектов.Свойство = &Свойство)
	|			И (ЗначенияСвойствОбъектов.Значение ПОДОБНО ""%"" + &Значение + ""%"")
	|ГДЕ
	|	ТорговыеКоды.ТорговыйКод = &ТорговыйКод
	|	И НЕ ТорговыеКоды.ПометкаУдаления
	|	И &ЭтоOTC = ИСТИНА
	|
	|ОБЪЕДИНИТЬ
	|
	|ВЫБРАТЬ
	|	ТорговыеКоды.Ссылка,
	|	ТорговыеКоды.АналитическийСчетЦБ,
	|	ТорговыеКоды.АналитическийСчетДС,
	|	ТорговыеКоды.ПИФ,
	|	ТорговыеКоды.Брокер,
	|	ТорговыеКоды.ДоговорБрокера
	|ИЗ
	|	Справочник.ТорговыеКоды КАК ТорговыеКоды
	|ГДЕ
	|	ТорговыеКоды.ТорговыйКод = &ТорговыйКод
	|	И НЕ ТорговыеКоды.ПометкаУдаления
	|	И &ЭтоOTC = ЛОЖЬ";
	
	Результат = Запрос.Выполнить();
	Если Результат.Пустой() тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Выборка = Результат.Выбрать();
	Выборка.Следующий();
	
	Возврат Выборка;
КонецФункции // ТорговыйКодПоКоду()

Функция ПолучитьМассивКодовЦБ(Знач КодЦБ)
	Перем МассивКодовЦБ;
	Перем ЭтоISIN, Концовка;
	
	КодЦБ = СокрЛП(КодЦБ);
	
	МассивКодовЦБ = Новый Массив();
	МассивКодовЦБ.Добавить(КодЦБ);
	
	ЭтоISIN = СтрДлина(КодЦБ) = 12 И СтрНайти(КодЦБ, " ") = 0 И СтрНайти(КодЦБ, Символы.НПП) = 0;  // у ISIN'ов нет пробелов и он длиной 12 символов!
	
	Если НЕ ЭтоISIN Тогда
		Концовка = " USD";
		
		Если СтрЗаканчиваетсяНа(ВРег(КодЦБ), Концовка) Тогда
			// если есть Концовка - выкусываем её
			МассивКодовЦБ.Добавить(СокрП(Лев(КодЦБ, СтрДлина(КодЦБ) - СтрДлина(Концовка))));
		Иначе
			// если нет Концовки - добавляем её
			МассивКодовЦБ.Добавить(КодЦБ + Концовка);
		КонецЕсли;
	КонецЕсли;
	
	Возврат МассивКодовЦБ;
КонецФункции // ПолучитьМассивКодовЦБ()

