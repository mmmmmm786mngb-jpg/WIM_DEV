Процедура ВыполнитьКоманду(ИдентификаторКоманды, ПараметрыВыполненияКоманды) Экспорт
	
	// Реализация логики команды
	Если СтрНайти(ИдентификаторКоманды, "ФоновоеВыполнение") = 0 Тогда Возврат; КонецЕсли;
	
	//DDneprovsky 10.08.2018 IMAPPS-6756 {
	// IMAPPS-25591 ++
	ВалютныеСделки		= Неопределено;
	ПериодЗагрузки_Т0	= Истина;
	// IMAPPS-25591 --
	Если ИдентификаторКоманды = "ФоновоеВыполнениеБиржевые" Тогда
		Режим = 1;
		ВидФоновойЗагрузки = "биржевых";
	ИначеЕсли ИдентификаторКоманды = "ФоновоеВыполнениеВнебиржевые" Тогда
		Режим = 2;
		ВидФоновойЗагрузки = "внебиржевых";
	ИначеЕсли ИдентификаторКоманды = "ФоновоеВыполнениеСделкиFX" Тогда
		Режим = 3;
		ВидФоновойЗагрузки = "FX";
		// IMAPPS-25591 ++
		ПериодЗагрузки_Т0	= Ложь;
		// IMAPPS-25591 --
	// IMAPPS-25591	++
	ИначеЕсли ИдентификаторКоманды = "ФоновоеВыполнениеБиржевые_RUB_Т_0" Тогда
		Режим				= 1;
		ВидФоновойЗагрузки	= "биржевых (рубли)";
		ВалютныеСделки		= Ложь;
	ИначеЕсли ИдентификаторКоманды = "ФоновоеВыполнениеВнебиржевые_RUB_Т_0" Тогда
		Режим				= 2;
		ВидФоновойЗагрузки	= "внебиржевых (рубли)";
		ВалютныеСделки		= Ложь;
	ИначеЕсли ИдентификаторКоманды = "ФоновоеВыполнениеБиржевые_Валюта_Т_1" Тогда
		Режим				= 1;
		ВидФоновойЗагрузки	= "биржевых Т-1 (валюта)";
		ВалютныеСделки		= Истина;
		ПериодЗагрузки_Т0	= Ложь;
	ИначеЕсли ИдентификаторКоманды = "ФоновоеВыполнениеВнебиржевые_Валюта_Т_1" Тогда
		Режим				= 2;
		ВидФоновойЗагрузки	= "внебиржевых Т-1 (валюта)";
		ВалютныеСделки		= Истина;
		ПериодЗагрузки_Т0	= Ложь;
	КонецЕсли;
	// IMAPPS-25591 --
	//} DDneprovsky 10.08.2018 IMAPPS-6756
	
	ПредставлениеНастроек = УстановитьНастройки(ПараметрыВыполненияКоманды);
	
	ДопОбработка = ПараметрыВыполненияКоманды.ДополнительнаяОбработкаСсылка;
	
	Задача = Задачи.ЗадачаИнтеграции.СоздатьЗадачу();
	Задача.Дата 			= ТекущаяДата();
	Задача.ВидОбмена 		= ДопОбработка;
	Задача.ВерсияОбработки 	= ОбщегоНазначения.ПолучитьЗначениеРеквизита(ДопОбработка, "Версия");
	// DDneprovsky 10.08.2018 IMAPPS-6756 {
	Задача.Наименование 	= "Загрузка " + ВидФоновойЗагрузки + " сделок в фоновом режиме";
	//} DDneprovsky 10.08.2018 IMAPPS-6756
	Задача.ПараметрыВыполнения = ПредставлениеНастроек;
	
	Отказ = Ложь;
	ТекстОшибки = "";
	
	Попытка
		// IMAPPS-25591 ++
		// ЗагрузитьОбъекты(Отказ, ТекстОшибки);
		ЗагрузитьОбъекты(ВалютныеСделки, Отказ, ТекстОшибки);
		// IMAPPS-25591 --
		СоздатьОбъекты(Отказ, ТекстОшибки);
	Исключение
		ТекстОшибки = ТекстОшибки + Символы.ПС + ОписаниеОшибки(); 
		Отказ = Истина;
	КонецПопытки;
	Задача.ХранилищеЛога = Новый ХранилищеЗначения(Лог, Новый СжатиеДанных(9));
	
	Задача.Описание 	= "Настройки: "+ ПредставлениеНастроек;
	
	Если Отказ тогда
		Задача.Описание = Задача.Описание + Символы.ПС + "При выполнении были ошибки:" + ТекстОшибки;
		Задача.ЗавершеноСОшибками = Истина;
	Иначе
		Задача.Описание = СокрЛП(Задача.Описание) + "."  + Символы.ПС + "Загрузка успешна.";
	КонецЕсли;
	
	ТекстОписания 		= "Всего " + ВидФоновойЗагрузки + " сделок: " + ВсегоПрочтено + ", из них новых: " + ВсегоНовых + "." + Символы.ПС+"Сделок с ошибками: " + (ВсегоНовых-ВсегоЗагружено) + ". Итого загружено: "+ВсегоЗагружено + ".";
	Задача.Описание 	= Задача.Описание + Символы.ПС + ТекстОписания;
	
	Задача.ДатаИсполнения = ТекущаяДата();
	
	ЕстьОшибки = (ВсегоНовых - ВсегоЗагружено) > 0;
	// Kmusorin https://jira.corp.vtbcapital.internal/browse/IMAPPS-8868 { доп контроль по загруженным сделкам. Если из начитанного не все загрузилось (например из-за отсутствия торгового кода) то в результате будет Warn
	ПрочитаноНоНеЗагружено = (ПрочитаноИзСделкиQuik - ВсегоЗагружено) > 0;
	//} Kmusorin https://jira.corp.vtbcapital.internal/browse/IMAPPS-8868
	
	Если СписокРассылки.Количество()>0 и НЕ ПочтовыйЛогин.Пустая() тогда
		
		ПараметрыПисьма = Новый Структура("Кому, Тема, Тело, Вложения, Важность");
		// Kmusorin https://jira.corp.vtbcapital.internal/browse/IMAPPS-8868 {
		// DDneprovsky 10.08.2018 IMAPPS-6756 {
		ПараметрыПисьма.Тема = ?(Отказ, "{FAIL} ", ?(ЕстьОшибки ИЛИ ПрочитаноНоНеЗагружено, "{WARN} ", "{OK} ")) + "Аванкор ПИФ: Загрузка " + ВидФоновойЗагрузки + " сделок в фоновом режиме. " + ПредставлениеНастроек + ПропискаРассылки("r51" + ?(Режим > 0, "." + Формат(Режим, "ЧДЦ=0; ЧН=; ЧГ="), ""));
		//} DDneprovsky 10.08.2018 IMAPPS-6756
		ПараметрыПисьма.Важность = ?(Отказ ИЛИ ЕстьОшибки ИЛИ ПрочитаноНоНеЗагружено, ВажностьИнтернетПочтовогоСообщения.Высокая, ВажностьИнтернетПочтовогоСообщения.Обычная);
		//} Kmusorin https://jira.corp.vtbcapital.internal/browse/IMAPPS-8868
		Кому = Новый Массив;
		Для Каждого ТекЯщик Из СписокРассылки Цикл
			Кому.Добавить(Новый Структура("Адрес, Представление", ТекЯщик.ПочтовыйЯщик, ТекЯщик.Представление));
		КонецЦикла;
		
		ПараметрыПисьма.Кому = кому;
		
		ПутьКФайлу = ПолучитьИмяВременногоФайла("XLS");
		Лог.Записать(ПутьКФайлу, ТипФайлаТабличногоДокумента.XLS);
		
		//Упаковка в zip
		ПутьКZip = ПолучитьИмяВременногоФайла("zip");
		Упаковка = Новый ЗаписьZipФайла(ПутьКZip);
		Упаковка.Добавить(ПутьКФайлу);
		Упаковка.Записать();
		//
		ДвоичныеДанные = Новый ДвоичныеДанные(ПутьКZip);
		АдресВложения = ПоместитьВоВременноеХранилище(ДвоичныеДанные);
		
		Вложения = Новый Соответствие;
		Вложения.Вставить("Лог.zip",АдресВложения);
		
		ПараметрыПисьма.Вложения = Вложения;
		
		ПараметрыПисьма.Тело =  Задача.Описание;
		Попытка
			РаботаСПочтовымиСообщениями.ОтправитьСообщение(ПочтовыйЛогин, ПараметрыПисьма);
			текстРассылки = "Рассылка завершена";
		Исключение
			текстРассылки = "Рассылка не удалась: "; 
			Сообщения = ПолучитьСообщенияПользователю(Истина);
			Для Каждого Элемент из Сообщения Цикл
				текстРассылки = текстРассылки + Символы.ПС + Элемент.Текст;
			Конеццикла;
		КонецПопытки;
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ТекстОшибкиНеНайденКонтрагент) Тогда
		
		Если СписокРассылкиНеНайденКонтрагент.Количество() > 0 И Не ПочтовыйЛогин.Пустая() Тогда
			
			ПараметрыПисьма = Новый Структура("Кому, Тема, Тело, Вложения, Важность");
			ПараметрыПисьма.Тема = "{WARN} Аванкор ПИФ: Загрузка " + ВидФоновойЗагрузки + " сделок в фоновом режиме. " + ПредставлениеНастроек + " - не найден партнер" + ПропискаРассылки("r51.1" + ?(Режим > 0, "." + Формат(Режим, "ЧДЦ=0; ЧН=; ЧГ="), ""));
			ПараметрыПисьма.Важность = ВажностьИнтернетПочтовогоСообщения.Высокая;
			Кому = Новый Массив;
			Для Каждого ТекЯщик Из СписокРассылкиНеНайденКонтрагент Цикл
				Кому.Добавить(Новый Структура("Адрес, Представление", ТекЯщик.ПочтовыйЯщик, ТекЯщик.Представление));
			КонецЦикла;
			
			ПараметрыПисьма.Кому = Кому;
			ПараметрыПисьма.Тело = ТекстОшибкиНеНайденКонтрагент;
			
			Вложения = Новый Соответствие;
			ПараметрыПисьма.Вложения = Вложения;
			
			Попытка
				РаботаСПочтовымиСообщениями.ОтправитьСообщение(ПочтовыйЛогин, ПараметрыПисьма);
				текстРассылки = "Рассылка завершена";
			Исключение
				текстРассылки = "Рассылка не удалась: "; 
				Сообщения = ПолучитьСообщенияПользователю(Истина);
				Для Каждого Элемент из Сообщения Цикл
					текстРассылки = текстРассылки + Символы.ПС + Элемент.Текст;
				Конеццикла;
			КонецПопытки;
			
		КонецЕсли;
	КонецЕсли;
	
	Задача.Описание = Задача.Описание + Символы.ПС + текстРассылки;
	Задача.ВыполнитьЗадачу();
	
КонецПроцедуры

Функция УстановитьНастройки(ПараметрыВыполненияКоманды)
	// IMAPPS-25591 ++
	//ДатаНачала 		= НачалоДня(ТекущаяДата());
	//ДатаОкончания 	= КонецДня(ТекущаяДата());
	ТекущаяДата	= НачалоДня(ТекущаяДатаСеанса());
	Если ПериодЗагрузки_Т0 Тогда
		ДатаНачала		= НачалоДня(ТекущаяДата);
		ДатаОкончания	= КонецДня(ТекущаяДата);
	Иначе
		ДатаНачала		= НачалоДня(ТекущаяДата - 1);
		ДатаОкончания	= КонецДня(ТекущаяДата - 1);
	КонецЕсли;
	// IMAPPS-25591 --
		
	НастройкиВыполнения = ПараметрыВыполненияКоманды.ПараметрыДополнительнойОбработки;
	Если ТипЗнч(НастройкиВыполнения) <> Тип("Структура") тогда возврат "<Настройки не установлены>"; КонецЕсли;
	
	ЗначенияНастроек = НастройкиВыполнения;
	
	ПредставлениеНастроек = "";
	УстановитьПользовательскиеНастройки(ЗначенияНастроек,ПредставлениеНастроек);
	
	Возврат ПредставлениеНастроек;

КонецФункции

Процедура УстановитьПользовательскиеНастройки(Настройки, ПредставлениеНастроек="") Экспорт
	
	Если Не ЗначениеЗаполнено(Настройки) Тогда Возврат; КонецЕсли;
	
	Если Настройки.Свойство("Значения") Тогда
		ОбработкаЗагрузкиАктивов = Настройки.Значения.ОбработкаЗагрузкиАктивов;
		КомандаЗагрузкиАктивов	= Настройки.Значения.КомандаЗагрузкиАктивов;
		ТестовыйРежим			= Настройки.Значения.ТестовыйРежим;
		
		БУ = Истина;
		ВУ = Настройки.Значения.ВУ;
				
		КомиссияБиржи 	= Настройки.Значения.КомиссияБиржи; 
