		// MPazhukov IMAPPS-10116
		ЦК = Настройки.Значения.ЦК; 
		// MPazhukov IMAPPS-10116	
		
		// MPazhukov IMAPPS-10229
		НовыйВариант = Настройки.Значения.НовыйВариант; 
		// MPazhukov IMAPPS-10229	
		
		Почта = Неопределено;
