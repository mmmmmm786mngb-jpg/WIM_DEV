//DDneprovsky IMAPPS-11514 03.08.2020 при переходе с релиза 2.6.5.2 на 2.6.6.2 вендор удалил этот код из модуля БП сделки Tn
Процедура ЗаполнениеДанныхБрокерскогоСчета(ОбъектСделкаTn)
	
	Если ЗначениеЗаполнено(ОбъектСделкаTn.БрокерскийСчет) Тогда
		
		ЗначенияРеквизитовБрокерскийСчет = ОбщегоНазначения.ПолучитьЗначенияРеквизитов(ОбъектСделкаTn.БрокерскийСчет, "АналитическийСчетЦБ, АналитическийСчетДС, Брокер, ДоговорБрокера, Биржа");
	
		ФизическиеМХИзАналитики = БизнесПроцессыИЗадачиВызовСервера.ФизическиеМХИзАналитики(ОбъектСделкаTn.БрокерскийСчет);
		
		Если ФизическиеМХИзАналитики.Найти(ОбъектСделкаTn.ФизическоеМестоХраненияДС) = Неопределено Тогда
			ЗначенияРеквизитовБрокерскийСчет.Вставить("ФизическоеМестоХранения", ФизическиеМХИзАналитики[0]);	
		Иначе
			ЗначенияРеквизитовБрокерскийСчет.Вставить("ФизическоеМестоХранения", ОбъектСделкаTn.ФизическоеМестоХраненияДС);	
		КонецЕсли; 

		ОбъектСделкаTn.АналитическийСчетДС = ЗначенияРеквизитовБрокерскийСчет.АналитическийСчетДС;
		ОбъектСделкаTn.АналитическийСчетЦБ = ЗначенияРеквизитовБрокерскийСчет.АналитическийСчетЦБ;
		ОбъектСделкаTn.ФизическоеМестоХраненияДС = ЗначенияРеквизитовБрокерскийСчет.ФизическоеМестоХранения;
		ОбъектСделкаTn.Биржа = ЗначенияРеквизитовБрокерскийСчет.Биржа;
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ОбъектСделкаTn.БрокерскийСчетКомиссииБиржи) Тогда
	
		ФизическиеМХИзАналитики = БизнесПроцессыИЗадачиВызовСервера.ФизическиеМХИзАналитики(ОбъектСделкаTn.БрокерскийСчетКомиссииБиржи);
		
		Если ФизическиеМХИзАналитики.Найти(ОбъектСделкаTn.ФизическоеМестоХраненияДСКомиссииБиржи) = Неопределено Тогда
			ОбъектСделкаTn.ФизическоеМестоХраненияДС = ФизическиеМХИзАналитики[0];	
		КонецЕсли; 
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ОбъектСделкаTn.БрокерскийСчетКомиссииБрокера) Тогда
	
