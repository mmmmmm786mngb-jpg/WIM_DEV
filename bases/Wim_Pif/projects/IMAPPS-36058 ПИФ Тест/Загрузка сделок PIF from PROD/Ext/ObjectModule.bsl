Функция DV_BrokerCode(ПИФ)
	КодЦБ = "";
	DV_BrokerCode1 = "";
	DV_BrokerCode2 = "";
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ТорговыеКоды.ТорговыйКод КАК ТорговыйКод
	|ИЗ
	|	Справочник.ТорговыеКоды КАК ТорговыеКоды
	|ГДЕ
	|	НЕ ТорговыеКоды.ПометкаУдаления";
	Если ЗначениеЗаполнено(ПИФ) Тогда 
		Запрос.Текст = Запрос.Текст + " И ТорговыеКоды.ПИФ = &ПИФ";
		Запрос.УстановитьПараметр("ПИФ", ПИФ);
	КонецЕсли;
	
	РезультатЗапроса = Запрос.Выполнить();
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		Если Не ЗначениеЗаполнено(ВыборкаДетальныеЗаписи.ТорговыйКод) Тогда Продолжить; КонецЕсли;
		КодЦБ = КодЦБ + ВыборкаДетальныеЗаписи.ТорговыйКод + ",";
		Если СтрДлина(DV_BrokerCode1) < 7500 Тогда
			DV_BrokerCode1 = DV_BrokerCode1 + ВыборкаДетальныеЗаписи.ТорговыйКод + ",";
		Иначе
			DV_BrokerCode2 = DV_BrokerCode2 + ВыборкаДетальныеЗаписи.ТорговыйКод + ",";
		КонецЕсли;			
	КонецЦикла;
	
	// IMAPPS-7844 -->
	Если Режим = 0 или Режим = 2 Тогда //Режим загрузки 0 - Все сделки, 1- Биржевые, 2 - Внебиржевые, 3 - FX
		МассивКодов = ПолучитьТорговыеКоды_OTC(ПИФ);
		Для Каждого ЗначМас из МассивКодов Цикл
			DV_BrokerCode2 = DV_BrokerCode2 + ЗначМас + ",";
		КонецЦикла;
	КонецЕсли;
	// IMAPPS-7844 <--
	
	Возврат КодЦБ;
КонецФункции

Процедура DV_СоздатьТикетСервер(Объект)
	НовыйТикет = Документы.Тикет.СоздатьДокумент();
	ЗаполнитьЗначенияСвойств(НовыйТикет, Объект);
	НовыйТикет.ВидОперации = Перечисления.ВидыОперацийТикет.Тикет;
	НовыйТикет.ВидСделки = ?(Объект.ВидОперации=Перечисления.ВидОперацииБПВнебиржеваяСделка.Покупка, Перечисления.ВидыСделокТикет.Покупка, Перечисления.ВидыСделокТикет.Продажа);
	НовыйТикет.МестоЗаключенияСделки = "Внебиржевая";
	НовыйТикет.ХарактерПредметаСделки= "Предоплата";
	НовыйТикет.ПИФ = НовыйТикет.ПИФ;	
	НовыйТикет.ТипСделки = "Собственная";
	НовыйТикет.ВключатьВСтоимость = Объект.ВключатьВСтоимостьДопРасходы;
	НовыйТикет.ДопРасходы.Загрузить(Объект.ДопРасходы.Выгрузить());
	
	Если ЗначениеЗаполнено(НовыйТикет.Актив) Тогда 
		НовыйТикет.ВидЦБ   = НовыйТикет.Актив.ВидАктива;
		АктивОбъект = НовыйТикет.Актив.Объект;
		НовыйТикет.Эмитент = ОбщегоНазначения.ПолучитьЗначениеРеквизита(АктивОбъект,"Эмитент");
	КонецЕсли;
	
	НовыйТикет.ИсполнениеПлатежа = Объект.СрокПлатежа;
	НовыйТикет.СрокПлатежа = Объект.ДатаПлатежа;
	НовыйТикет.Ответственный = ПараметрыСеанса.ТекущийПользователь;
	
	ТекстОшибки = "";
	Если ОбязательныеРеквизитыЗаполненыОТС(Объект, ТекстОшибки) Тогда
		НовыйТикет.Записать();
		Объект.Тикет = НовыйТикет.Ссылка;
	КонецЕсли;
КонецПроцедуры

Процедура DV_СоздатьДоговорКонтрагента(Объект)
	
	Если Объект.СделкаЧерезБрокера Тогда Возврат; КонецЕсли;
	Если ЗначениеЗаполнено(Объект.ДоговорКонтрагента) Тогда Возврат; КонецЕсли;
	Если Не ЗначениеЗаполнено(Объект.ПИФ) Тогда Возврат; КонецЕсли;
	Если Не ЗначениеЗаполнено(Объект.Контрагент) Тогда Возврат; КонецЕсли;
	
	НовыйТикет = Справочники.ДоговорыКонтрагентов.СоздатьЭлемент();
	НовыйТикет.Наименование = "№ " + Объект.НомерСделки + " от " + Формат(Объект.Дата,"ДЛФ=DD") + " " + Объект.ВалютаВзаиморасчетов.Наименование;
	НовыйТикет.НаименованиеРегл = НовыйТикет.Наименование;
	НовыйТикет.ПИФ = Объект.ПИФ;
	НовыйТикет.НомерДоговора = Объект.НомерСделки;
	НовыйТикет.ДатаДоговора = Объект.Дата;
	НовыйТикет.ВидДоговора = Перечисления.ВидыДоговоровКонтрагентов.СПокупателем;
	НовыйТикет.РольКонтрагента = Перечисления.РолиДляДоговораКонтрагента.СПоставщиком;
	НовыйТикет.Владелец = Объект.Контрагент;	
	НовыйТикет.ВалютаВзаиморасчетов = Объект.ВалютаВзаиморасчетов;	
	
	ТекстОшибки = "";
	Если ОбязательныеРеквизитыЗаполненыОТС(Объект, ТекстОшибки) Тогда
		НовыйТикет.Записать();
		Объект.ДоговорКонтрагента = НовыйТикет.Ссылка;
	КонецЕсли;
	
КонецПроцедуры

Процедура DV_ЗаполнитьСДДС(Объект)
	
	Если Объект.СделкаЧерезБрокера Тогда Возврат; КонецЕсли;

	СДДС = "Внебиржа " 
		 + ?(Объект.ВидОперации = Перечисления.ВидОперацииБПВнебиржеваяСделка.Продажа, "Продажа_КА ", "Покупка_КА ")
		 + ?(Объект.Контрагент.НеРезидент, "нерезидент_", "резидент_")
		 + ?(ТипЗнч(Объект.Актив.Объект) = Тип("СправочникСсылка.Акции") Или ТипЗнч(Объект.Актив.Объект) = Тип("СправочникСсылка.Облигации"), "эмитент ЦБ ",
		   ?(ТипЗнч(Объект.Актив.Объект) = Тип("СправочникСсылка.ПаиПИФ"), "ПАИ ",
		   ?(ТипЗнч(Объект.Актив.Объект) = Тип("СправочникСсылка.Векселя"), "векселя ","")))
		 + ?(ЗначениеЗаполнено(Объект.Актив.Объект),?(ЗначениеЗаполнено(Объект.Актив.Объект.Эмитент),?(Объект.Актив.Объект.Эмитент.НеРезидент, "нерезидент", "резидент"),""),"");
	 
	Объект.СтатьяДвиженияДенежныхСредств = Справочники.СтатьиДвиженияДенежныхСредств.НайтиПоНаименованию(СДДС);
КонецПроцедуры

