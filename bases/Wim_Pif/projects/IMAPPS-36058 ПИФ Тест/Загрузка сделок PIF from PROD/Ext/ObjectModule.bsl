					ТекСделка.Записать();
					//vns 06.06.2019
					//Если Лев(ТекСтрока.РежимТоргов,3) <> "DMA" Тогда
					Если НЕ(ЭтоDMA) Тогда
						ТекСделка.Старт();
						// DDneprovsky 10.08.2018 IMAPPS-6756 {
						БизнесПроцессы.ВнебиржеваяСделка.ВыполнитьШагБизнесПроцессаАвтоматически(ТекСделка.Ссылка, "УстановкаНастроекБП");
						БизнесПроцессы.ВнебиржеваяСделка.ВыполнитьШагБизнесПроцессаАвтоматически(ТекСделка.Ссылка, "ОткрытиеПлановойПозиции");
						// } DDneprovsky 10.08.2018 IMAPPS-6756 
					КонецЕсли;
					
					// IMDEV-1646 -->
					НаборЗаписей = РегистрыСведений.TranOv_ДопДанныеПоСделке.СоздатьНаборЗаписей();
					НаборЗаписей.Отбор.СделкаСсылка.Установить(ТекСделка.Ссылка); 
					
					НоваяЗапись = НаборЗаписей.Добавить(); 
					НоваяЗапись.СделкаСсылка = ТекСделка.Ссылка; 
					НоваяЗапись.SecurityID = ТекСтрока.SecurityID; 
					НоваяЗапись.Стратегия = ТекСтрока.Стратегия; 
					
					НаборЗаписей.Записать();
					// IMDEV-1646 <--
				Исключение
					Отказ = Истина;
					ТекстОшибки = ПолучитьТекстОшибки("Ошибки проведения: ")  + "" + ОписаниеОшибки();
				КонецПопытки;
			Иначе
				Отказ = Истина;	
			КонецЕсли;
		ИначеЕсли НЕ(ЭтоREPO) THEN
			Если ОбязательныеРеквизитыЗаполненыБП(ТекСделка, ТекстОшибки)  тогда
				Отказ = Ложь;
				Попытка 
					ТекСделка.Записать();
					//vns 06.06.2019
					Если НЕ(ЭтоDMA) Тогда
						ТекСделка.Старт();
					КонецЕсли;
				Исключение
					Отказ = Истина;
					ТекстОшибки = ПолучитьТекстОшибки("Ошибки проведения: ") + "" + ОписаниеОшибки();
				КонецПопытки;
			Иначе
				Отказ = Истина;	
			КонецЕсли;		
		Иначе
			Если ОбязательныеРеквизитыЗаполненыРЕПО(ТекСделка, ТекстОшибки)  тогда
				Отказ = Ложь;
				Попытка 
					ТекСделка.Записать();
					//vns 06.06.2019
					Если НЕ(ЭтоDMA) Тогда
						ТекСделка.Старт();
					КонецЕсли;
				Исключение
					Отказ = Истина;
					ТекстОшибки = ПолучитьТекстОшибки("Ошибки проведения: " + "" + ОписаниеОшибки());
				КонецПопытки;
			Иначе
				Отказ = Истина;	
			КонецЕсли;
		КонецЕсли;//vns 23.09
		
		СтрокаДокументов.Параметры.Заполнить(ТекСтрока);
		СтрокаДокументов.Параметры.ВремяСделки	= ТекСтрока.ДатаСделки; // MTF-2781
		СтрокаДокументов.Параметры.КодЦБнаММВБ	= СтрокаДокументов.Параметры.КодЦБнаММВБ + ?(ТекСтрока.Актив.Пустая(), "", ", " + ТекСтрока.Актив.Наименование) + Символы.ПС;
		СтрокаДокументов.Параметры.КомиссияБрокера	= СтрокаДокументов.Параметры.КомиссияБрокера + Символы.ПС;
		СтрокаДокументов.Параметры.Сделка 		= ?(Отказ, "",ТекСделка.Ссылка);
		СтрокаДокументов.Параметры.ОшибкаСделки	= ?(Отказ, ТекстОшибки, "");
		СтрокаДокументов.Параметры.ЕстьОшибки 	= ?(Отказ, "ДА","");
		
		Если не ЗначениеЗаполнено(ТекСтрока.ПИФ) тогда
			СтрокаДокументов.Параметры.ПИФ = "<???>";
		КонецЕсли;
		
		Лог.Вывести(СтрокаДокументов);
		
		Если Не Отказ тогда
			МассивУдаления.Добавить(ТекСтрока);
			ВсегоЗагружено = ВсегоЗагружено +1;
		КонецЕсли;
		
	КонецЦикла;
	
	Если ТаблицаНеНайденныхКонтрагентов.Количество() > 0 Тогда
		ТаблицаНеНайденныхКонтрагентов.Свернуть("ДатаСделки, КодБрокера");
		
		Для каждого ТекСтрока Из ТаблицаНеНайденныхКонтрагентов Цикл
			СтрокаОшибки = "На дату " + Формат(ТекСтрока.ДатаСделки, "ДФ=dd.MM.yyyy") + " для БП Сделка РЕПО не найден партнер по коду брокера: " + СокрЛП(ТекСтрока.КодБрокера);
			ТекстОшибкиНеНайденКонтрагент = ?(ЗначениеЗаполнено(ТекстОшибкиНеНайденКонтрагент), ТекстОшибкиНеНайденКонтрагент + Символы.ПС + СтрокаОшибки, СтрокаОшибки);
		КонецЦикла;
	КонецЕсли;
	
	Для Каждого ТекСтрока из МассивУдаления Цикл
		СписокЗагрузки.Удалить(ТекСтрока);
	КонецЦикла;
	
КонецПроцедуры	//СоздатьОбъекты

Процедура ПрочитатьСделкиРЕПО(Отказ, ТекстОшибки) Экспорт
	
	Лог = Новый ТабличныйДокумент;
	Лог.ОтображатьГруппировки 	= Ложь;
	Лог.ОтображатьСетку 		= Ложь;
	Лог.ОтображатьЗаголовки 	= Ложь;

	Заголовок = Макет.ПолучитьОбласть("Заголовок");
	Лог.Вывести(Заголовок);
	
	Шапка = Макет.ПолучитьОбласть("Шапка");
	Шапка.Параметры.ДатаНачала 		= ДатаНачала;
	Шапка.Параметры.ДатаОкончания 	= ДатаОкончания;
	Шапка.Параметры.ДатаФормирования = ТекущаяДата();
	Шапка.Параметры.Настройки		= ПредставлениеНастроек;
	Лог.Вывести(Шапка);
	
	Ошибка = Макет.ПолучитьОбласть("Ошибка");
	
	Попытка
		TIBCO_URL = ?(ТестовыйРежим, "http://smsk02ap209u:8889/", "http://amaptibco:8889/");
		
		Определение = Новый WSОпределения(TIBCO_URL,,,, 120);
		Фабрика = Определение.ФабрикаXDTO;
		
		Корень_ТИП	= Фабрика.Тип(ОсновноеПространствоИмен, "Корень");
		Условия_ТИП	= Фабрика.Тип(ОсновноеПространствоИмен, "Условия");
		Корень 		= Фабрика.Создать(Корень_ТИП);
		
		Условия 	= Фабрика.Создать(Условия_ТИП);
		Условия.ДатаС 	= ДатаНачала;
		Условия.ДатаПо 	= ДатаОкончания;
		Условия.База	= DV_BrokerCode(ПИФ);
		Условия.База	= DV_BrokerCode1;
		Условия.База2	= DV_BrokerCode2;
		Корень.Условия = Условия;
		
		Ответ = ОтветЧерезСервис(Определение, Корень);
	Исключение
		ТекстОшибки = "Ошибка подключения: " + ОписаниеОшибки();
		Сообщить(ТекстОшибки);
		Отказ = Истина;
		Ошибка.Параметры.ОписаниеОшибки = ТекстОшибки;
		Лог.Вывести(Ошибка);
	КонецПопытки;
	
	Если Отказ = Истина Тогда Возврат; КонецЕсли;
	
	Если Ответ.Сделки.Количество() = 0 Тогда
		Сообщить("Сделок за указанный период нет");
		Возврат;
	КонецЕсли;
	
	ПрочитатьЗагруженныеСделкиРЕПО(Ответ.Сделки[0].Сделка, Отказ, ТекстОшибки);
	
КонецПроцедуры

Процедура ОбновитьПартнера(Отказ, ТекстОшибки="") Экспорт
	
	Лог.Очистить();
	
	ЗаголовокТаблицы = Макет.ПолучитьОбласть("ЗаголовокТаблицы");
	Лог.Вывести(ЗаголовокТаблицы);
	
	СтрокаДокументов = Макет.ПолучитьОбласть("СтрокаТаблицы");
	
	МассивУдаления = Новый Массив;
	
	ВсегоЗагружено = 0;
	Для Каждого ТекСтрока из СписокЗагрузки Цикл
		
		ПОПЫТКА
			
			ЭтоREPO = (СписокREPO_RUB.НайтиПоЗначению(ТекСтрока.РежимТорговНаименование) <> Неопределено)
				ИЛИ (СписокREPO_USD.НайтиПоЗначению(ТекСтрока.РежимТорговНаименование) <> Неопределено)
				ИЛИ (СписокREPO_EUR.НайтиПоЗначению(ТекСтрока.РежимТорговНаименование) <> Неопределено)
				ИЛИ (СписокREPO_CNY.НайтиПоЗначению(ТекСтрока.РежимТорговНаименование) <> Неопределено);
			
			Если Не ЭтоREPO Или Не ЗначениеЗаполнено(ТекСтрока.КодБрокера) Тогда
				МассивУдаления.Добавить(ТекСтрока);
				Продолжить;
			КонецЕсли;
			
			ТекСделка = СделкаПоНомеру(ТекСтрока.НомерСделки, ТекСтрока.Продажа);
			Если Не ЗначениеЗаполнено(ТекСделка) Тогда
				МассивУдаления.Добавить(ТекСтрока);
				Продолжить;
			КонецЕсли;
			
			ТекСделкаОбъект = ТекСделка.ПолучитьОбъект();
			
			ТекСделкаОбъект.Партнер = ПолучитьКонтрагентаПоКодуБрокера(ТекСтрока.КодБрокера);
			Если Не ЗначениеЗаполнено(ТекСделкаОбъект.Партнер) Тогда
				ТекстОшибки = "На дату " + Формат(ТекСтрока.ДатаСделки, "ДФ=dd.MM.yyyy") + " для БП Сделка РЕПО не найден партнер по коду брокера: " + СокрЛП(ТекСтрока.КодБрокера);
				Отказ = Истина;
			КонецЕсли;
			
		ИСКЛЮЧЕНИЕ
			Отказ = Истина;
			ТекстОшибки = ПолучитьТекстОшибки("Ошибки заполнения реквизитов при создании сделки: ")  + "" + ОписаниеОшибки();
		КОНЕЦПОПЫТКИ;
		Попытка
			ТекСделкаОбъект.ОбменДанными.Загрузка = Истина;
			ТекСделкаОбъект.Записать();
		Исключение
			Отказ = Истина;
			ТекстОшибки = ПолучитьТекстОшибки("Ошибки проведения: " + "" + ОписаниеОшибки());
		КонецПопытки;
		
		СтрокаДокументов.Параметры.Заполнить(ТекСтрока);
		СтрокаДокументов.Параметры.ВремяСделки	= ТекСтрока.ДатаСделки;
		СтрокаДокументов.Параметры.КодЦБнаММВБ	= СтрокаДокументов.Параметры.КодЦБнаММВБ + ?(ТекСтрока.Актив.Пустая(), "", ", " + ТекСтрока.Актив.Наименование) + Символы.ПС;
		СтрокаДокументов.Параметры.КомиссияБрокера	= СтрокаДокументов.Параметры.КомиссияБрокера + Символы.ПС;
		СтрокаДокументов.Параметры.Сделка 		= ?(Отказ, "",ТекСделка.Ссылка);
		СтрокаДокументов.Параметры.ОшибкаСделки	= ?(Отказ, ТекстОшибки, "");
		СтрокаДокументов.Параметры.ЕстьОшибки 	= ?(Отказ, "ДА","");
		
		Если Не ЗначениеЗаполнено(ТекСтрока.ПИФ) тогда
			СтрокаДокументов.Параметры.ПИФ = "<???>";
		КонецЕсли;
		
		Лог.Вывести(СтрокаДокументов);
		
		Если Не Отказ тогда
			МассивУдаления.Добавить(ТекСтрока);
			ВсегоЗагружено = ВсегоЗагружено + 1;
		КонецЕсли;
		
	КонецЦикла;
	
	Для Каждого ТекСтрока из МассивУдаления Цикл
		СписокЗагрузки.Удалить(ТекСтрока);
	КонецЦикла;
	
КонецПроцедуры

Функция ПолучитьТекстОшибки(ТекстОшибки)
	ТекстОшибки = ТекстОшибки + Символы.ПС;
	
	МассивСообщений = ПолучитьСообщенияПользователю(Истина);
	Для каждого ТекСообщение из МассивСообщений Цикл
		ТекстОшибки = ТекстОшибки + ТекСообщение.Текст + Символы.ПС;
	Конеццикла;
	
	Возврат ТекстОшибки;
КонецФункции

Функция ТестовыйОтвет(Фабрика, Корень_ТИП)
	
	ФайлПример = ПолучитьИмяВременногоФайла("xml");
	
	Пример = ПолучитьМакет("ПримерОтвета");
	Пример.Записать(ФайлПример,КодировкаТекста.UTF8 );
	
	Чтение	= Новый ЧтениеXML;
	Чтение.ОткрытьФайл(ФайлПример);
	
	Корень_ТИП  = Фабрика.Тип(ОсновноеПространствоИмен, "Корень");
	Корень 		= Фабрика.ПрочитатьXML(Чтение, Корень_ТИП);
	
	Возврат Корень;
	
КонецФункции

Функция ОтветЧерезСервис(Определение, Корень)
	
	Прокси = Новый WSПрокси(Определение, Определение.Сервисы[0].URIПространстваИмен, Определение.Сервисы[0].Имя, Определение.Сервисы[0].ТочкиПодключения[0].Имя);
	
	Прокси.GetDeals(Корень);
	
	Возврат Корень;
	
КонецФункции

// IMAPPS-25591 ++
// Процедура ПрочитатьНаСервере(Сделки, Отказ = Ложь, ТекстОшибки = "")
Процедура ПрочитатьНаСервере(Сделки, ВалютныеСделки, Отказ = Ложь, ТекстОшибки = "")
// IMAPPS-25591 --
	Перем ИсходныеСделки;
	
	Если Отказ Тогда
		Возврат;
	КонецЕсли;
	
	ЭтотОбъект.СписокЗагрузки.Очистить();
	
	ВсегоПрочтено	= 0;
	ВсегоНовых		= 0;
	
	ИсходныеСделки = Новый ТаблицаЗначений();
	ИсходныеСделки.Колонки.Добавить("НомерСделки", ОбщегоНазначения.ОписаниеТипаСтрока(50));
	ИсходныеСделки.Колонки.Добавить("ЭтоПродажа", Новый ОписаниеТипов("Булево"));
	ИсходныеСделки.Колонки.Добавить("ДатаСделки", ОбщегоНазначения.ОписаниеТипаДата(ЧастиДаты.Дата));
	ИсходныеСделки.Колонки.Добавить("КодВалюты", ОбщегоНазначения.ОписаниеТипаСтрока(10));
	ИсходныеСделки.Колонки.Добавить("КодКлиента", ОбщегоНазначения.ОписаниеТипаСтрока(150));
	ИсходныеСделки.Колонки.Добавить("КодБрокера", ОбщегоНазначения.ОписаниеТипаСтрока(150));
	ИсходныеСделки.Колонки.Добавить("ЭтоOTC", Новый ОписаниеТипов("Булево"));
	
	Для Каждого ТекСделка из Сделки Цикл
		РежимТоргов = ВРег(СокрЛП(ТекСделка.РежимТоргов));
		
		НовСтрока = ИсходныеСделки.Добавить();
		НовСтрока.НомерСделки	 = ТекСделка.НомерСделки;
		НовСтрока.ЭтоПродажа	 = (НРег(СокрЛП(ТекСделка.ТипСделки)) = "продажа");
		НовСтрока.ДатаСделки	 = ТекСделка.ДатаСделки;
		НовСтрока.КодВалюты		 = КодВалютыСделки(ВРег(СокрЛП(ТекСделка.ВалютаСделки)), РежимТоргов);
		НовСтрока.КодКлиента	 = СокрП(ТекСделка.КодКлиента);
		НовСтрока.КодБрокера	 = СокрП(ТекСделка.КодБрокера);
		НовСтрока.ЭтоOTC		 = (РежимТоргов = "OTC");
	КонецЦикла;
	
	СделкиПоНомеру		 = ОтобратьСделкиПоНомеру(ИсходныеСделки.Скопировать(, "НомерСделки, ЭтоПродажа"), ЭтотОбъект.ДатаНачала, ЭтотОбъект.ДатаОкончания);
	КурсыВалютПоСделкам	 = ОтобратьКурсыВалют(ИсходныеСделки.Скопировать(, "КодВалюты, ДатаСделки"));
	РежимыТоргов		 = ОтобратьРежимыТоргов(ИсходныеСделки.Скопировать(, "КодКлиента, КодБрокера, ЭтоOTC"));
	АлгоритмыРасчета	 = ОтобратьАлгоритмыРасчетаКомиссии(ОбщегоНазначенияКлиентСервер.СвернутьМассив(РежимыТоргов.Скопировать(, "ДоговорБрокера").ВыгрузитьКолонку("ДоговорБрокера")));
	
	КешБиржи			 = Новый Соответствие();
	КешПИФ				 = Новый Соответствие();
	КешПИФ				 = Новый Соответствие();
	КешРежимТоргов		 = Новый Соответствие();
	КэшАлгоритмов		 = Новый Соответствие();
	
	Для Каждого ТекСделка из Сделки Цикл
		РежимТоргов	 = ВРег(СокрЛП(ТекСделка.РежимТоргов));
		ЭтоFX		 = (СписокFX.НайтиПоЗначению(РежимТоргов) <> Неопределено);
		ЭтоПродажа	 = (НРег(СокрЛП(ТекСделка.ТипСделки)) = "продажа");
		
		// IMAPPS-25591 ++
		//Если (Режим = 1 И РежимТоргов = "OTC") //установлен режим - загрузка биржевых сделок, пропускаем внебиржу
		//	ИЛИ (Режим = 2 И РежимТоргов <> "OTC")  //установлен режим - загрузка внебиржевых сделок, пропускаем остальное
		//	ИЛИ (Режим = 3 И (НЕ ЭтоFX)) Тогда // сделки FX
		//	Продолжить;
		//КонецЕсли;	
		Если ВалютныеСделки = Неопределено Тогда
			Если Режим = 1 И РежимТоргов = "OTC"			// установлен режим - загрузка биржевых сделок, пропускаем внебиржу
					Или Режим = 2 И РежимТоргов <> "OTC"	// установлен режим - загрузка внебиржевых сделок, пропускаем остальное
					Или Режим = 3 И Не ЭтоFX Тогда			// сделки FX
				Продолжить;
			КонецЕсли;
		Иначе
			ВалютаСделки = КодВалютыСделки(ВРег(СокрЛП(ТекСделка.ВалютаСделки)), РежимТоргов);
			
			Если Режим = 1 Тогда
				Если ЭтоFX
						Или РежимТоргов = "OTC" 
						Или ВалютныеСделки 
							И ВалютаСделки = "RUB"
						Или Не ВалютныеСделки
							И ВалютаСделки <> "RUB" Тогда
					Продолжить;
				КонецЕсли;
			ИначеЕсли Режим = 2 Тогда
				Если ЭтоFX
						Или РежимТоргов <> "OTC"
						Или ВалютныеСделки 
							И ВалютаСделки = "RUB"
						Или Не ВалютныеСделки
							И ВалютаСделки <> "RUB" Тогда
					Продолжить;
				КонецЕсли;
			ИначеЕсли Режим = 3 Тогда
				Если Не ЭтоFX Тогда
					Продолжить;
				КонецЕсли;
			Иначе
				// Режим загрузки все
			КонецЕсли;
		КонецЕсли;
		// IMAPPS-25591 --
		
		// DDneprovsky 10.08.2018 IMAPPS-6756
		Если РежимТоргов = "OTC" И (ТекСделка.Комментарий = "CANCEL"
			ИЛИ СокрЛП(ВРЕГ(ТекСделка.Актив.КодЦБНаММВБ)) = "USD" // Если это внебиржевая сделка и это конвертация - пропускаем
			ИЛИ СокрЛП(ВРЕГ(ТекСделка.Актив.КодЦБНаММВБ)) = "RUB") Тогда
			Продолжить;
		КонецЕсли;
		
		ВсегоПрочтено = ВсегоПрочтено + 1;
		
		Если УжеЕстьСделкаПоНомеру(СделкиПоНомеру, ТекСделка.НомерСделки, ЭтоПродажа) Тогда
			Продолжить;
		КонецЕсли;
		
		ВсегоНовых = ВсегоНовых + 1;
		
		НоваяСделка = СписокЗагрузки.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСделка, ТекСделка);
		НоваяСделка.Продажа = ЭтоПродажа;
		
		ТекВремя 	= ТекСделка.ВремяСделки;
		ТекДата 	= ТекСделка.ДатаСделки;
		НоваяСделка.ДатаСделки = Дата(Год(ТекДата), Месяц(ТекДата), День(ТекДата), Час(ТекВремя), Минута(ТекВремя), Секунда(ТекВремя));
		
		//MTF-3149 -->
		Попытка
			НоваяСделка.ПИФ = ЗначениеИзКешаПоНаименованию(ТекСделка.ПИФ, Справочники.ПИФ, КешПИФ);
		Исключение
		КонецПопытки;
		
		СтруктураРежимаТоргов = ЗначениеИзКешаРежимовТоргов(РежимТоргов, КешРежимТоргов);
		
		НоваяСделка.РежимТоргов				 = СтруктураРежимаТоргов.Ссылка;
		НоваяСделка.РежимТорговНаименование	 = СтруктураРежимаТоргов.Наименование;
		//MTF-3149 <--
		
		//IMDEV-1646 -->
		НоваяСделка.SecurityID = ТекСделка.SecurityID;
		НоваяСделка.Стратегия = ТекСделка.Стратегия;
		//IMDEV-1646 <--
		
		Если КалендарныеГрафики.ЭтоВыходнойДень(ТекСделка.ДатаРасчетов, Календарь) Тогда
			НоваяСделка.ДатаРасчетов = КалендарныеГрафики.ПолучитьСледующуюРабочуюДату(Календарь, ТекСделка.ДатаРасчетов, 1);
		Иначе
			НоваяСделка.ДатаРасчетов = ТекСделка.ДатаРасчетов;
		КонецЕсли;
		
		Биржа = ЗначениеИзКешаПоНаименованию(ТекСделка.Биржа.Наименование, Справочники.Биржи, КешБиржи);
		
		КурсКратность = ПолучитьКурсВалютыСделки(
			КурсыВалютПоСделкам,
			КодВалютыСделки(ВРег(СокрЛП(ТекСделка.ВалютаСделки)), РежимТоргов),
			НачалоДня(ТекДата)
		);
		
		НоваяСделка.КурсВалютыСделки		 = КурсКратность.Курс;
		НоваяСделка.КратностьВалютыСделки	 = КурсКратность.Кратность;
		НоваяСделка.ВалютаСделки			 = КурсКратность.Валюта;
		
		Если НЕ ЭтоFX Тогда		
			НоваяСделка.Цена = ?(НоваяСделка.Количество = 0, 0, НоваяСделка.Сумма / НоваяСделка.Количество);
			НоваяСделка.КотировкаОблигации = 0;
			НоваяСделка.Биржа = Биржа;
		КонецЕсли;
		
		ЭтоОблигация = Ложь;
		СтатусПоискаАктива = "Актив не найден";
		
		Актив = АктивПоКоду(ТекСделка.Актив.КодЦБнаММВБ, Биржа, Истина, СтатусПоискаАктива);
		Если Актив <> Неопределено Тогда
			НоваяСделка.Актив = Актив;
			
			Если НЕ ЗначениеЗаполнено(Актив.ВидАктива) Тогда
				Сообщить("Не указан Вид актива у бумаги '" + СокрЛП(Актив) + "' (" + СокрЛП(ТекСделка.Актив.КодЦБнаММВБ) + ")");
			Иначе
				ЭтоОблигация = Актив.ВидАктива.ПринадлежитЭлементу(ПланыВидовХарактеристик.ВидыАктивов.Облигации);
				Если ЭтоОблигация Тогда
					Облигация = Актив.Объект;
					Номинал = Облигация.НоминальнаяСтоимость;
					Если Номинал = 0 Тогда
						Сообщить("Не определен номинал у облигации " + СокрЛП(Облигация));
					Иначе
						НоваяСделка.КотировкаОблигации = НоваяСделка.Цена / Номинал*100;
					КонецЕсли;
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
		НоваяСделка.СтатусПоискаАктива = СтатусПоискаАктива;
		
		// MPazhukov IMAPPS-10832
		Если (СписокDMA_USD.НайтиПоЗначению(РежимТоргов) <> Неопределено) ИЛИ (СписокDMA_EUR.НайтиПоЗначению(РежимТоргов) <> Неопределено) Тогда
			Если НЕ НоваяСделка.Актив.Пустая() Тогда
				Если Не ЗначениеЗаполнено(НоваяСделка.Актив.ВнешнийID) Тогда
					НоваяСделка.Актив = Справочники.Активы.ПустаяСсылка();
					НоваяСделка.СтатусПоискаАктива = "У Актива не заполнен Внешний ID";	
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
		// MPazhukov IMAPPS-10832
		
		НоваяСделка.КодБиржи	 = ТекСделка.Биржа.Наименование; 
		НоваяСделка.КодЦБнаММВБ	 = ТекСделка.Актив.КодЦБнаММВБ;
		
		Данные_ТорговыйКод = ОпределитьТорговыйКодПоКоду(РежимыТоргов, ТекСделка.КодКлиента, ТекСделка.КодБрокера, РежимТоргов);
		Если Данные_ТорговыйКод <> Неопределено Тогда
			ЗаполнитьЗначенияСвойств(НоваяСделка, Данные_ТорговыйКод);
		КонецЕсли;
		
		РассчитатьКомиссиюБрокераПоАлгоритмам(АлгоритмыРасчета, КурсыВалютПоСделкам, КэшАлгоритмов, НоваяСделка, НоваяСделка.СтатусКомиссии);
	КонецЦикла;
КонецПроцедуры // ПрочитатьНаСервере()

Процедура РассчитатьКомиссиюБрокераПоАлгоритмам(Знач АлгоритмыРасчета = Неопределено, Знач КурсыВалютПоСделкам = Неопределено, Кеш = Неопределено, НоваяСделка, ТекстОшибки = "")
	Перем ПараметрыАлгоритма, ОбработкаАлгоритма;
	Перем Результат;
	
	Если АлгоритмыРасчета = Неопределено ИЛИ КурсыВалютПоСделкам = Неопределено ИЛИ Кеш = Неопределено Тогда  // запасной вариант - уходим на медленный итеративный расчет комиссий
		РассчитатьКомиссиюБрокера(НоваяСделка, ТекстОшибки);
		
		Возврат;
	КонецЕсли;
	
	Если НоваяСделка.ДоговорБрокера.Пустая() тогда
		НоваяСделка.КомиссияБрокера = 0;
		
		ТекстОшибки = "Определить комиссию невозможно";
		Возврат;
		
	ИначеЕсли ВРег(СокрЛП(НоваяСделка.РежимТорговНаименование)) = "SPBFUT"
		ИЛИ ВРег(СокрЛП(НоваяСделка.РежимТорговНаименование)) = "SPBOPT"  //IMAPPS-16573
		Тогда
		НоваяСделка.КомиссияБрокера	 = 0;
		НоваяСделка.КомиссияБиржи	 = 0;  // IMAPPS-14608
		
	Иначе
		НоваяСделка.КомиссияБрокера = 0;
		
		ПараметрыАлгоритма = АлгоритмыРасчета[НоваяСделка.ДоговорБрокера];
		Если ПараметрыАлгоритма = Неопределено Тогда
			Возврат;
		КонецЕсли;
		
		ОбработкаАлгоритма = Кеш[ПараметрыАлгоритма.АлгоритмДоговора];
		Если ОбработкаАлгоритма = Неопределено Тогда
			ОбработкаАлгоритма = ДополнительныеОтчетыИОбработки.ПолучитьОбъектВнешнейОбработки_(ПараметрыАлгоритма.АлгоритмДоговора);
			
			Если ОбработкаАлгоритма = Неопределено Тогда
				Возврат;
			КонецЕсли;
			
			Кеш[ПараметрыАлгоритма.АлгоритмДоговора] = ОбработкаАлгоритма;
		КонецЕсли;
		
		ПараметрыРасчета = Новый Структура(
			"Сумма, НКД, РежимТорговНаименование, РЕПОСрок, КурсВалютыСделки, _СпискиРежимовТоргов_",
			НоваяСделка.Сумма,
			НоваяСделка.НКД,
			НоваяСделка.РежимТорговНаименование,
			НоваяСделка.РЕПОСрок,
			НоваяСделка.КурсВалютыСделки,
			Новый Структура(
				"СписокDMA_USD, СписокDMA_EUR, СписокREPO_RUB, СписокREPO_USD, СписокREPO_EUR, СписокREPO_CNY, СписокFX, СписокСЦК, СписокTQOY", //IMAPPS-22442 NOzhiganov
				СписокDMA_USD.Скопировать(),
				СписокDMA_EUR.Скопировать(),
				СписокREPO_RUB.Скопировать(),
				СписокREPO_USD.Скопировать(),
				СписокREPO_EUR.Скопировать(),
				СписокREPO_CNY.Скопировать(), //IMAPPS-22442 Nozhiganov
				СписокFX.Скопировать(),
				СписокСЦК.Скопировать(),
				СписокTQOY.Скопировать()
			)
		);
		
		Результат = Неопределено;
		Попытка
			Результат = ОбработкаАлгоритма.РезультатРасчета(ПараметрыАлгоритма.НастройкиАлгоритма, ПараметрыРасчета);
		Исключение
			ТекстОшибки = "Алгоритм контрагента: " + СокрЛП(ПараметрыАлгоритма.Владелец) + " по договору: " + СокрЛП(НоваяСделка.ДоговорБрокера) + " не содержит расчета. Описание ошибки: " + ОписаниеОшибки();
			
			ЗаписьЖурналаРегистрации(
				"Дополнительные отчеты и обработки." + Метаданные().Представление(),
				УровеньЖурналаРегистрации.Ошибка,,,
				ТекстОшибки
			);
		КонецПопытки;
		
		Если Результат <> Неопределено тогда
			Если ЗначениеЗаполнено(НоваяСделка.ВалютаСделки) И НоваяСделка.ВалютаСделки <> Справочники.Валюты.RUB Тогда
				КурсКратность = ПолучитьКурсВалютыСделки(
					КурсыВалютПоСделкам,
					НоваяСделка.ВалютаСделки,
					НачалоДня(НоваяСделка.ДатаСделки)
				);
				
				Результат = Окр(ОбщегоНазначения.ПересчитатьИзВалютыВВалюту(Результат, НоваяСделка.ВалютаСделки, Справочники.Валюты.RUB, КурсКратность.Курс, 1, КурсКратность.Кратность, 1, 2), 2);
			КонецЕсли;
			
			НоваяСделка.КомиссияБрокера = Результат;
		КонецЕсли; 
		
		ДатаОплатыКомиссииБрокера = Дата(1, 1, 1);
		Попытка
			ДатаОплатыКомиссииБрокера = ОбработкаАлгоритма.РассчитатьДатуОплатыКомисииБрокера(НоваяСделка.ДатаСделки);
		Исключение
			// нет алгоритма => ДатаОплатыКомиссииБрокера = Дата(1, 1, 1);
			//ТекстОшибки = "Алгоритм контрагента: " + СокрЛП(ПараметрыАлгоритма.Владелец) + " по договору: " + СокрЛП(НоваяСделка.ДоговорБрокера) + ". Описание ошибки: " + ОписаниеОшибки();
            //Сообщить(ТекстОшибки);
		КонецПопытки;
		НоваяСделка.ДатаОплатыКомиссииБрокера = ДатаОплатыКомиссииБрокера;
		
	КонецЕсли;
КонецПроцедуры // РассчитатьКомиссиюБрокераПоАлгоритмам()

Процедура РассчитатьКомиссиюБрокера(НоваяСделка, ТекстОшибки = "")  // ИКФ (deprecated): используется из кнопки на форме - нужно отказаться от этой процедуры в пользу РассчитатьКомиссиюБрокераПоАлгоритмам()
	
	НоваяСделка.КомиссияБрокера = 0;
	
	Если НоваяСделка.ДоговорБрокера.Пустая() тогда
		ТекстОшибки = "Определить комиссию невозможно";
		Возврат;
		
	ИначеЕсли ВРег(СокрЛП(НоваяСделка.РежимТорговНаименование)) = "SPBFUT"
		или ВРег(СокрЛП(НоваяСделка.РежимТорговНаименование)) = "SPBOPT"   //IMAPPS-16573
		Тогда
		НоваяСделка.КомиссияБрокера = 0;
		// IMAPPS-14608 -->
		НоваяСделка.КомиссияБиржи = 0;
		// IMAPPS-14608 <--		
	Иначе
		Результат = Справочники.ДоговорыКонтрагентов.РезультатАлгоритма(НоваяСделка.ДоговорБрокера, НоваяСделка, ,ТекстОшибки);
		Если Результат <> Неопределено тогда
			// DDneprovsky 15.07.2019 IMAPPS-7723
			Если НоваяСделка.ВалютаСделки <> Справочники.Валюты.RUB Тогда
				Курсы = ОбщегоНазначения.ПолучитьКурсВалюты(НоваяСделка.ВалютаСделки, НоваяСделка.ДатаСделки);
				Результат = Окр(ОбщегоНазначения.ПересчитатьИзВалютыВВалюту(Результат, НоваяСделка.ВалютаСделки, Справочники.Валюты.RUB, Курсы.Курс, 1, Курсы.Кратность, 1, 2),2);
			КонецЕсли;	
			// DDneprovsky 15.07.2019 IMAPPS-7723
			НоваяСделка.КомиссияБрокера = Результат;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

Функция ОбязательныеРеквизитыЗаполнены(ТекСделка, ТекстОшибки="")
	
	ТекстОшибки = "Не заполнены обязательные реквизиты:";
	ОшибокНет 	= Истина;
	
	Для каждого ТекРеквизит из ОбязательныеРеквизиты Цикл
		Если НЕ ЗначениеЗаполнено(ТекСделка[ТекРеквизит.Значение]) тогда
			ТекстОшибки = ТекстОшибки + Символы.ПС + " - " + ТекРеквизит.Представление;
			ОшибокНет = Ложь;
		Конецесли;
	Конеццикла;
	
	Возврат ОшибокНет;	
КонецФункции

