Функция ПолучитьТорговыеКоды_OTC(ПИФ)
	
	МассивКодов = Новый Массив;
	Попытка
		ConnectionSQL = Новый COMОбъект("ADODB.Connection");
		 //  Loevets IMAPPS-24707
 		СтруктураПодключения = ОбщегоНазначения.ПолучитьЗначенияРеквизитов(ВнешняяИБ, "ИмяСервера1СПредприятия, ИмяИнформационнойБазыНаСервере1СПредприятия, ИмяПользователя, ПарольПользователя");
		
		ServerName = СтруктураПодключения.ИмяСервера1СПредприятия;
		DSN = СтруктураПодключения.ИмяИнформационнойБазыНаСервере1СПредприятия;
		UID = СтруктураПодключения.ИмяПользователя;
		PWD = СтруктураПодключения.ПарольПользователя;
        //  Loevets IMAPPS-24707

		
		//UID = "rates_view"; 
		//PWD = "DgsFaVqDSZQhORL7NrCm";	
		//DSN = "Quik";
		//ServerName = "AMDBRATES\DBMVTBAM01";
		
		ConnectString = "Provider=SQLOLEDB;" + "Data Source=" +ServerName + ";Initial Catalog=" + DSN + ";UID=" + UID + ";PWD=" + PWD;
		
		ConnectionSQL.ConnectionString = ConnectString;
		ConnectionSQL.ConnectionTimeOut = 15;
		ConnectionSQL.CommandTimeout = 30;
		ConnectionSQL.Open();
	Исключение
		ConnectionSQL = Неопределено;
		Сообщить("Ошибка подключения к серверу ["+ServerName+"]: "+ОписаниеОшибки());
		Отказ = Истина;
		стрОшибки = стрОшибки +Символы.ПС + "Ошибка подключения к серверу ["+ServerName+"]: "+ОписаниеОшибки(); 
		Возврат МассивКодов;
	КонецПопытки;
	
	CommandSQL = Новый COMОбъект("ADODB.Command");
	CommandSQL.ActiveConnection = ConnectionSQL;
	CommandSQL.CommandType = 1;
	
	ТекстКоманды = "SELECT DISTINCT 
	|[Mandate]
	|,[kod_klienta]
	|,[kod_klienta] + '_' + [currency] as torg_code
	|FROM [Quik].[dbo].[SdelkiQuik]
	|where data >= @date1 and data <= @date2  
	|and kod_klienta like @kod_klienta
	|and class_code = 'OTC'  
	|and not Mandate like 'ДУ %'";
	
	Если Не ЗначениеЗаполнено(ПИФ) Тогда
		ТекстКоманды = СтрЗаменить(ТекстКоманды, "and kod_klienta like @kod_klienta", "");
	Иначе
		
		Запрос = Новый Запрос;
		Запрос.Текст = "
		|ВЫБРАТЬ
		|	ЗначенияСвойствОбъектов.Значение КАК Значение
		|ИЗ
		|	РегистрСведений.ЗначенияСвойствОбъектов КАК ЗначенияСвойствОбъектов
		|ГДЕ
		|	(ВЫРАЗИТЬ(ЗначенияСвойствОбъектов.Объект КАК Справочник.ПИФ)) = &ПИФ
		|	И ЗначенияСвойствОбъектов.Свойство = &Свойство
		|";
		НужнСвойство = ПланыВидовХарактеристик.СвойстваОбъектов.ПолучитьСсылку(Новый УникальныйИдентификатор("aa7b3c23-51d0-11ec-80df-005056b100fc"));//Код фонда в Аванкор ФО
		Запрос.Параметры.Вставить("Свойство", НужнСвойство); 
		Запрос.Параметры.Вставить("ПИФ", ПИФ);
		
		РезультатЗапроса = Запрос.Выполнить();
		Если РезультатЗапроса.Пустой() Тогда
			Возврат МассивКодов;
		КонецЕсли;
		Выборка =  РезультатЗапроса.Выбрать();
		Выборка.Следующий();
		ТекстКоманды = СтрЗаменить(ТекстКоманды, "@kod_klienta", "'MD-" + Выборка.Значение + "%'");
	КонецЕсли;
	
	ТекстКоманды = СтрЗаменить(ТекстКоманды, "@date1", "'" + Формат(ДатаНачала, "ДФ=yyyy-MM-dd") + "'");
	ТекстКоманды = СтрЗаменить(ТекстКоманды, "@date2", "'" + Формат(ДатаОкончания, "ДФ=yyyy-MM-dd") + "'");
	
	Попытка
		CommandSQL.CommandText = ТекстКоманды;
		НаборЗаписей = CommandSQL.Execute();
	Исключение
		Сообщить("Ошибка выполнения команды: "+ОписаниеОшибки());
		Сообщить("Текст команды:");
		Сообщить(ТекстКоманды);
		Отказ = Истина;
		стрОшибки = стрОшибки+Символы.ПС + "Ошибка выполнения команды: "+ОписаниеОшибки()+Символы.ПС+ТекстКоманды; 
		Возврат МассивКодов;
	КонецПопытки;
	
	Пока НаборЗаписей.EOF() = 0 Цикл
		
		МассивКодов.Добавить(НаборЗаписей.Fields("torg_code").Value);	
		НаборЗаписей.MoveNext();
		
	КонецЦикла;
	
	Возврат МассивКодов;
	
КонецФункции

Функция ОтобратьСделкиПоНомеру(Знач ИсходныеДанные, Знач ДатаНач, ДатаКон)
	Перем Запрос, СделкиПоНомеру;
	
	Запрос = Новый Запрос();
	Запрос.УстановитьПараметр("ИсходныеДанные", ИсходныеДанные);
	Запрос.УстановитьПараметр("ДатаНач", ДатаНач - 20 * 86400);
	Запрос.УстановитьПараметр("ДатаОкон", КонецДня(ДатаКон));
	Запрос.УстановитьПараметр("ДатаОкон3", КонецДня(ДатаКон) + 3 * 86400);
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ИсходныеДанные.НомерСделки КАК НомерСделки,
	|	ИсходныеДанные.ЭтоПродажа КАК ЭтоПродажа
	|ПОМЕСТИТЬ втИсходныеСделки
	|ИЗ
	|	&ИсходныеДанные КАК ИсходныеДанные
	|ГДЕ
	|	ИсходныеДанные.НомерСделки > """"
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	НомерСделки,
	|	ЭтоПродажа
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	|	ВыборкаВн.НомерСделки КАК НомерСделки,
	|	ВыборкаВн.ЭтоПродажа КАК ЭтоПродажа,
	|	ВЫБОР
	|		КОГДА ВыборкаВн.СделкаЦБ.Ссылка ЕСТЬ НЕ NULL 
	|			ТОГДА ВыборкаВн.СделкаЦБ
	|		КОГДА ВыборкаВн.СделкаTn.Ссылка ЕСТЬ НЕ NULL 
	|			ТОГДА ВыборкаВн.СделкаTn
	|		КОГДА ВыборкаВн.СделкаРЕПО.Ссылка ЕСТЬ НЕ NULL 
	|			ТОГДА ВыборкаВн.СделкаРЕПО
	|		КОГДА ВыборкаВн.СделкаOTC.Ссылка ЕСТЬ НЕ NULL 
	|			ТОГДА ВыборкаВн.СделкаOTC
	|		КОГДА ВыборкаВн.СделкаFX.Ссылка ЕСТЬ НЕ NULL 
	|			ТОГДА ВыборкаВн.СделкаFX
	|		КОГДА ВыборкаВн.СделкаСрочная.Ссылка ЕСТЬ НЕ NULL 
	|			ТОГДА ВыборкаВн.СделкаСрочная
	|		ИНАЧЕ NULL
	|	КОНЕЦ КАК Сделка,
	|	ВЫБОР
	|		КОГДА ВыборкаВн.СделкаЦБ.Ссылка ЕСТЬ НЕ NULL 
	|			ТОГДА ИСТИНА
	|		КОГДА ВыборкаВн.СделкаTn.Ссылка ЕСТЬ НЕ NULL 
	|			ТОГДА ИСТИНА
	|		КОГДА ВыборкаВн.СделкаРЕПО.Ссылка ЕСТЬ НЕ NULL 
	|			ТОГДА ИСТИНА
	|		КОГДА ВыборкаВн.СделкаOTC.Ссылка ЕСТЬ НЕ NULL 
	|			ТОГДА ИСТИНА
	|		КОГДА ВыборкаВн.СделкаFX.Ссылка ЕСТЬ НЕ NULL 
	|			ТОГДА ИСТИНА
	|		КОГДА ВыборкаВн.СделкаСрочная.Ссылка ЕСТЬ НЕ NULL 
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК ЕстьСделка
	|ИЗ
	|	(ВЫБРАТЬ
	|		Выборка.НомерСделки КАК НомерСделки,
	|		Выборка.ЭтоПродажа КАК ЭтоПродажа,
	|		МАКСИМУМ(Выборка.СделкаЦБ) КАК СделкаЦБ,
	|		МАКСИМУМ(Выборка.СделкаTn) КАК СделкаTn,
	|		МАКСИМУМ(Выборка.СделкаРЕПО) КАК СделкаРЕПО,
	|		МАКСИМУМ(Выборка.СделкаOTC) КАК СделкаOTC,
	|		МАКСИМУМ(Выборка.СделкаFX) КАК СделкаFX,
	|		МАКСИМУМ(Выборка.СделкаСрочная) КАК СделкаСрочная
	|	ИЗ
	|		(ВЫБРАТЬ
	|			ИсходныеСделки.НомерСделки КАК НомерСделки,
	|			ИсходныеСделки.ЭтоПродажа КАК ЭтоПродажа,
	|			ВЫБОР
	|				КОГДА НЕ ИсходныеСделки.ЭтоПродажа
	|						И СделкиЦБ.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийСделка.Поступление)
	|					ТОГДА СделкиЦБ.Ссылка
	|				КОГДА ИсходныеСделки.ЭтоПродажа
	|						И СделкиЦБ.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийСделка.Продажа)
	|					ТОГДА СделкиЦБ.Ссылка
	|				ИНАЧЕ ЗНАЧЕНИЕ(Документ.СделкаЦБ.ПустаяСсылка)
	|			КОНЕЦ КАК СделкаЦБ,
	|			ЗНАЧЕНИЕ(БизнесПроцесс.СделкиTn.ПустаяСсылка) КАК СделкаTn,
	|			ЗНАЧЕНИЕ(БизнесПроцесс.СделкиРЕПО.ПустаяСсылка) КАК СделкаРЕПО,
	|			ЗНАЧЕНИЕ(БизнесПроцесс.ВнебиржеваяСделка.ПустаяСсылка) КАК СделкаOTC,
	|			ЗНАЧЕНИЕ(БизнесПроцесс.БиржеваяСделкаСВалютой.ПустаяСсылка) КАК СделкаFX,
	|			ЗНАЧЕНИЕ(Документ.СделкаНаСрочномРынке.ПустаяСсылка) КАК СделкаСрочная
	|		ИЗ
	|			втИсходныеСделки КАК ИсходныеСделки
	|				ЛЕВОЕ СОЕДИНЕНИЕ Документ.СделкаЦБ КАК СделкиЦБ
	|				ПО (СделкиЦБ.НомерВходящегоДокумента = ИсходныеСделки.НомерСделки)
	|					И (СделкиЦБ.Дата >= НАЧАЛОПЕРИОДА(&ДатаНач, ДЕНЬ))
	|					И (СделкиЦБ.Дата < ДОБАВИТЬКДАТЕ(НАЧАЛОПЕРИОДА(&ДатаОкон, ДЕНЬ), ДЕНЬ, 1))
	|					И (НЕ СделкиЦБ.ПометкаУдаления)
	|		
	|		ОБЪЕДИНИТЬ
	|		
	|		ВЫБРАТЬ
	|			ИсходныеСделки.НомерСделки,
	|			ИсходныеСделки.ЭтоПродажа,
	|			ЗНАЧЕНИЕ(Документ.СделкаЦБ.ПустаяСсылка),
	|			ВЫБОР
	|				КОГДА НЕ ИсходныеСделки.ЭтоПродажа
	|						И СделкиTn.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийСделка.Поступление)
	|					ТОГДА СделкиTn.Ссылка
	|				КОГДА ИсходныеСделки.ЭтоПродажа
	|						И СделкиTn.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийСделка.Продажа)
	|					ТОГДА СделкиTn.Ссылка
	|				ИНАЧЕ ЗНАЧЕНИЕ(БизнесПроцесс.СделкиTn.ПустаяСсылка)
	|			КОНЕЦ,
	|			ЗНАЧЕНИЕ(БизнесПроцесс.СделкиРЕПО.ПустаяСсылка),
	|			ЗНАЧЕНИЕ(БизнесПроцесс.ВнебиржеваяСделка.ПустаяСсылка),
	|			ЗНАЧЕНИЕ(БизнесПроцесс.БиржеваяСделкаСВалютой.ПустаяСсылка),
	|			ЗНАЧЕНИЕ(Документ.СделкаНаСрочномРынке.ПустаяСсылка)
	|		ИЗ
	|			втИсходныеСделки КАК ИсходныеСделки
	|				ЛЕВОЕ СОЕДИНЕНИЕ БизнесПроцесс.СделкиTn КАК СделкиTn
	|				ПО (СделкиTn.НомерСделки = ИсходныеСделки.НомерСделки)
	|					И (СделкиTn.Дата >= НАЧАЛОПЕРИОДА(&ДатаНач, ДЕНЬ))
	|					И (СделкиTn.Дата < ДОБАВИТЬКДАТЕ(НАЧАЛОПЕРИОДА(&ДатаОкон, ДЕНЬ), ДЕНЬ, 1))
	|					И (НЕ СделкиTn.ПометкаУдаления)
	|		
	|		ОБЪЕДИНИТЬ
	|		
	|		ВЫБРАТЬ
	|			ИсходныеСделки.НомерСделки,
	|			ИсходныеСделки.ЭтоПродажа,
	|			ЗНАЧЕНИЕ(Документ.СделкаЦБ.ПустаяСсылка),
	|			ЗНАЧЕНИЕ(БизнесПроцесс.СделкиTn.ПустаяСсылка),
	|			СделкиРЕПО.Ссылка,
	|			ЗНАЧЕНИЕ(БизнесПроцесс.ВнебиржеваяСделка.ПустаяСсылка),
	|			ЗНАЧЕНИЕ(БизнесПроцесс.БиржеваяСделкаСВалютой.ПустаяСсылка),
	|			ЗНАЧЕНИЕ(Документ.СделкаНаСрочномРынке.ПустаяСсылка)
	|		ИЗ
	|			втИсходныеСделки КАК ИсходныеСделки
	|				ЛЕВОЕ СОЕДИНЕНИЕ БизнесПроцесс.СделкиРЕПО КАК СделкиРЕПО
	|				ПО (СделкиРЕПО.НомерСделки = ИсходныеСделки.НомерСделки)
	|					И (СделкиРЕПО.Дата >= НАЧАЛОПЕРИОДА(&ДатаНач, ДЕНЬ))
	|					И (СделкиРЕПО.Дата < ДОБАВИТЬКДАТЕ(НАЧАЛОПЕРИОДА(&ДатаОкон, ДЕНЬ), ДЕНЬ, 1))
	|					И (НЕ СделкиРЕПО.ПометкаУдаления)
	|		
	|		ОБЪЕДИНИТЬ
	|		
	|		ВЫБРАТЬ
	|			ИсходныеСделки.НомерСделки,
	|			ИсходныеСделки.ЭтоПродажа,
	|			ЗНАЧЕНИЕ(Документ.СделкаЦБ.ПустаяСсылка),
	|			ЗНАЧЕНИЕ(БизнесПроцесс.СделкиTn.ПустаяСсылка),
	|			ЗНАЧЕНИЕ(БизнесПроцесс.СделкиРЕПО.ПустаяСсылка),
	|			ВЫБОР
	|				КОГДА НЕ ИсходныеСделки.ЭтоПродажа
	|						И СделкиOTC.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидОперацииБПВнебиржеваяСделка.Покупка)
	|					ТОГДА СделкиOTC.Ссылка
	|				КОГДА ИсходныеСделки.ЭтоПродажа
	|						И СделкиOTC.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидОперацииБПВнебиржеваяСделка.Продажа)
	|					ТОГДА СделкиOTC.Ссылка
	|				ИНАЧЕ ЗНАЧЕНИЕ(БизнесПроцесс.ВнебиржеваяСделка.ПустаяСсылка)
	|			КОНЕЦ,
	|			ЗНАЧЕНИЕ(БизнесПроцесс.БиржеваяСделкаСВалютой.ПустаяСсылка),
	|			ЗНАЧЕНИЕ(Документ.СделкаНаСрочномРынке.ПустаяСсылка)
	|		ИЗ
	|			втИсходныеСделки КАК ИсходныеСделки
	|				ЛЕВОЕ СОЕДИНЕНИЕ БизнесПроцесс.ВнебиржеваяСделка КАК СделкиOTC
	|				ПО (СделкиOTC.НомерСделки = ИсходныеСделки.НомерСделки)
	|					И (СделкиOTC.Дата >= НАЧАЛОПЕРИОДА(&ДатаНач, ДЕНЬ))
	|					И (СделкиOTC.Дата < ДОБАВИТЬКДАТЕ(НАЧАЛОПЕРИОДА(&ДатаОкон, ДЕНЬ), ДЕНЬ, 1))
	|					И (НЕ СделкиOTC.ПометкаУдаления)
	|		
	|		ОБЪЕДИНИТЬ
	|		
	|		ВЫБРАТЬ
	|			ИсходныеСделки.НомерСделки,
	|			ИсходныеСделки.ЭтоПродажа,
	|			ЗНАЧЕНИЕ(Документ.СделкаЦБ.ПустаяСсылка),
	|			ЗНАЧЕНИЕ(БизнесПроцесс.СделкиTn.ПустаяСсылка),
	|			ЗНАЧЕНИЕ(БизнесПроцесс.СделкиРЕПО.ПустаяСсылка),
	|			ЗНАЧЕНИЕ(БизнесПроцесс.ВнебиржеваяСделка.ПустаяСсылка),
	|			ВЫБОР
	|				КОГДА НЕ ИсходныеСделки.ЭтоПродажа
	|						И СделкиFX.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийСделкаСВалютой.Покупка)
	|					ТОГДА СделкиFX.Ссылка
	|				КОГДА ИсходныеСделки.ЭтоПродажа
	|						И СделкиFX.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийСделкаСВалютой.Продажа)
	|					ТОГДА СделкиFX.Ссылка
	|				ИНАЧЕ ЗНАЧЕНИЕ(БизнесПроцесс.БиржеваяСделкаСВалютой.ПустаяСсылка)
	|			КОНЕЦ,
	|			ЗНАЧЕНИЕ(Документ.СделкаНаСрочномРынке.ПустаяСсылка)
	|		ИЗ
	|			втИсходныеСделки КАК ИсходныеСделки
	|				ЛЕВОЕ СОЕДИНЕНИЕ БизнесПроцесс.БиржеваяСделкаСВалютой КАК СделкиFX
	|				ПО (СделкиFX.НомерСделки = ИсходныеСделки.НомерСделки)
	|					И (СделкиFX.Дата >= НАЧАЛОПЕРИОДА(&ДатаНач, ДЕНЬ))
	|					И (СделкиFX.Дата < ДОБАВИТЬКДАТЕ(НАЧАЛОПЕРИОДА(&ДатаОкон, ДЕНЬ), ДЕНЬ, 1))
	|					И (НЕ СделкиFX.ПометкаУдаления)
	|		
	|		ОБЪЕДИНИТЬ
	|		
	|		ВЫБРАТЬ
	|			ИсходныеСделки.НомерСделки,
	|			ИсходныеСделки.ЭтоПродажа,
	|			ЗНАЧЕНИЕ(Документ.СделкаЦБ.ПустаяСсылка),
	|			ЗНАЧЕНИЕ(БизнесПроцесс.СделкиTn.ПустаяСсылка),
	|			ЗНАЧЕНИЕ(БизнесПроцесс.СделкиРЕПО.ПустаяСсылка),
	|			ЗНАЧЕНИЕ(БизнесПроцесс.ВнебиржеваяСделка.ПустаяСсылка),
	|			ЗНАЧЕНИЕ(БизнесПроцесс.БиржеваяСделкаСВалютой.ПустаяСсылка),
	|			ВЫБОР
	|				КОГДА НЕ ИсходныеСделки.ЭтоПродажа
	|						И СделкиСрочные.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийСделкаНаСрочномРынке.Покупка)
	|					ТОГДА СделкиСрочные.Ссылка
	|				КОГДА ИсходныеСделки.ЭтоПродажа
	|						И СделкиСрочные.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийСделкаНаСрочномРынке.Продажа)
	|					ТОГДА СделкиСрочные.Ссылка
	|				ИНАЧЕ ЗНАЧЕНИЕ(Документ.СделкаНаСрочномРынке.ПустаяСсылка)
	|			КОНЕЦ
	|		ИЗ
	|			втИсходныеСделки КАК ИсходныеСделки
	|				ЛЕВОЕ СОЕДИНЕНИЕ Документ.СделкаНаСрочномРынке КАК СделкиСрочные
	|				ПО (СделкиСрочные.ВходящийНомер = ИсходныеСделки.НомерСделки)
	|					И (СделкиСрочные.Дата >= НАЧАЛОПЕРИОДА(&ДатаНач, ДЕНЬ))
	|					И (СделкиСрочные.Дата < ДОБАВИТЬКДАТЕ(НАЧАЛОПЕРИОДА(&ДатаОкон3, ДЕНЬ), ДЕНЬ, 1))
	|					И (НЕ СделкиСрочные.ПометкаУдаления)) КАК Выборка
	|	
	|	СГРУППИРОВАТЬ ПО
	|		Выборка.НомерСделки,
	|		Выборка.ЭтоПродажа) КАК ВыборкаВн
	|
	|УПОРЯДОЧИТЬ ПО
	|	НомерСделки,
	|	ЭтоПродажа,
	|	Сделка";
	
	СделкиПоНомеру = Запрос.Выполнить().Выгрузить();
	СделкиПоНомеру.Индексы.Добавить("НомерСделки, ЭтоПродажа");
	
	Возврат СделкиПоНомеру;
КонецФункции // ОтобратьСделкиПоНомеру()

Функция ОтобратьКурсыВалют(Знач ИсходныеДанные)
	Перем Запрос, КурсыВалют;
	
	Запрос = Новый Запрос();
	Запрос.УстановитьПараметр("ИсходныеДанные", ИсходныеДанные);
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ИсходныеДанные.КодВалюты КАК КодВалюты,
	|	ИсходныеДанные.ДатаСделки КАК ДатаСделки
	|ПОМЕСТИТЬ втИсходныеВалюты_0
	|ИЗ
	|	&ИсходныеДанные КАК ИсходныеДанные
	|ГДЕ
	|	ИсходныеДанные.КодВалюты > """"
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	КодВалюты,
	|	ДатаСделки
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ИсходныеВалюты.КодВалюты КАК КодВалюты,
	|	ВЫБОР
	|		КОГДА ЕСТЬNULL(Валюты.Ссылка, ЗНАЧЕНИЕ(Справочник.Валюты.RUB)) = ЗНАЧЕНИЕ(Справочник.Валюты.RUB)
	|			ТОГДА ДАТАВРЕМЯ(1980, 1, 1)
	|		ИНАЧЕ ИсходныеВалюты.ДатаСделки
	|	КОНЕЦ КАК ДатаСделки,
	|	ЕСТЬNULL(Валюты.Ссылка, ЗНАЧЕНИЕ(Справочник.Валюты.RUB)) КАК Валюта
	|ПОМЕСТИТЬ втИсходныеВалюты
	|ИЗ
	|	втИсходныеВалюты_0 КАК ИсходныеВалюты
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Валюты КАК Валюты
	|		ПО (Валюты.Наименование = ИсходныеВалюты.КодВалюты)
	|			И (Валюты.Ссылка <> ЗНАЧЕНИЕ(Справочник.Валюты.RUB))
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	ДатаСделки,
	|	Валюта
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	|	ИсходныеВалюты.КодВалюты КАК КодВалюты,
	|	ИсходныеВалюты.Валюта КАК Валюта,
	|	ИсходныеВалюты.ДатаСделки КАК ДатаСделки,
	|	ЕСТЬNULL(КурсыВалютПоДатам.ДатаКурса, ДАТАВРЕМЯ(1980, 1, 1)) КАК ДатаКурса,
	|	ЕСТЬNULL(КурсыВалютПоДатам.Курс, 1) КАК Курс,
	|	ЕСТЬNULL(КурсыВалютПоДатам.Кратность, 1) КАК Кратность
	|ИЗ
	|	втИсходныеВалюты КАК ИсходныеВалюты
	|		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	|			ВалютыМакс.Валюта КАК Валюта,
	|			ВалютыМакс.ДатаСделки КАК ДатаСделки,
	|			ВалютыМакс.Период КАК ДатаКурса,
	|			КурсыВалют.Курс КАК Курс,
	|			КурсыВалют.Кратность КАК Кратность
	|		ИЗ
	|			(ВЫБРАТЬ
	|				ИсходныеВалютыВн.Валюта КАК Валюта,
	|				ИсходныеВалютыВн.ДатаСделки КАК ДатаСделки,
	|				МАКСИМУМ(КурсыВалютВн.Период) КАК Период
	|			ИЗ
	|				втИсходныеВалюты КАК ИсходныеВалютыВн
	|					ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.КурсыВалют КАК КурсыВалютВн
	|					ПО (КурсыВалютВн.Валюта = ИсходныеВалютыВн.Валюта)
	|						И (КурсыВалютВн.Период <= ИсходныеВалютыВн.ДатаСделки)
	|			
	|			СГРУППИРОВАТЬ ПО
	|				ИсходныеВалютыВн.Валюта,
	|				ИсходныеВалютыВн.ДатаСделки) КАК ВалютыМакс
	|				ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.КурсыВалют КАК КурсыВалют
	|				ПО (КурсыВалют.Валюта = ВалютыМакс.Валюта)
	|					И (КурсыВалют.Период = ВалютыМакс.Период)) КАК КурсыВалютПоДатам
	|		ПО (КурсыВалютПоДатам.Валюта = ИсходныеВалюты.Валюта)
	|			И (КурсыВалютПоДатам.ДатаСделки = ИсходныеВалюты.ДатаСделки)
	|
	|УПОРЯДОЧИТЬ ПО
	|	КодВалюты,
	|	Валюта,
	|	ДатаСделки,
	|	ДатаКурса";
	
	КурсыВалют = Запрос.Выполнить().Выгрузить();
	КурсыВалют.Индексы.Добавить("КодВалюты, ДатаСделки");
	КурсыВалют.Индексы.Добавить("Валюта, ДатаСделки");
	
	Возврат КурсыВалют;
КонецФункции // ОтобратьКурсыВалют()

Функция УжеЕстьСделкаПоНомеру(Знач ТаблицаНайденныхСделок, Знач НомерСделки, Знач ЭтоПродажа)
	Перем Строки;
	
	Строки = ТаблицаНайденныхСделок.НайтиСтроки(Новый Структура("НомерСделки, ЭтоПродажа", НомерСделки, ЭтоПродажа));
	Если Строки.Количество() > 0 Тогда
		Возврат (Истина = Строки[0].ЕстьСделка);
	КонецЕсли;
	
	Возврат Ложь;
КонецФункции // УжеЕстьСделкаПоНомеру()

Функция КодВалютыСделки(Знач ВалютаСделки, Знач РежимТоргов)
	Если (СписокDMA_USD.НайтиПоЗначению(РежимТоргов) <> Неопределено) Тогда  // IMAPPS-10140
		КодВалюты = "USD";
		
	ИначеЕсли (СписокDMA_EUR.НайтиПоЗначению(РежимТоргов) <> Неопределено) Тогда  // IMAPPS-10140
		КодВалюты = "EUR";
	
	ИначеЕсли ЗначениеЗаполнено(ВалютаСделки) И СтрНайти("/RUR/RUB/SUR/", "/" + ВалютаСделки + "/") = 0 Тогда
		КодВалюты = ВалютаСделки;
	
	Иначе
		КодВалюты = "RUB";
	КонецЕсли;
	
	Возврат КодВалюты;
КонецФункции // КодВалютыСделки()

Функция ПолучитьКурсВалютыСделки(Знач КурсыВалютПоСделкам, Знач КодВалютыИлиВалюта, Знач ДатаСделки)
	Перем ОтборСтрок, ТекущаяСтрока, ПолеОтбора;
	
	Если ТипЗнч(КодВалютыИлиВалюта) = Тип("СправочникСсылка.Валюты") Тогда
		ПолеОтбора = "Валюта";
		
		Если КодВалютыИлиВалюта = Справочники.Валюты.RUB Тогда
			Возврат Новый Структура("Валюта, Курс, Кратность", Справочники.Валюты.RUB, 1, 1);
		КонецЕсли;
	Иначе
		ПолеОтбора = "КодВалюты";
		
		Если КодВалютыИлиВалюта = "RUB" Тогда
			Возврат Новый Структура("Валюта, Курс, Кратность", Справочники.Валюты.RUB, 1, 1);
		КонецЕсли;
	КонецЕсли;
	
	ОтборСтрок = КурсыВалютПоСделкам.НайтиСтроки(Новый Структура(ПолеОтбора + ", ДатаСделки", КодВалютыИлиВалюта, ДатаСделки));
	Если ОтборСтрок.Количество() = 0 Тогда
		ВызватьИсключение "Ошибка определения курса валюты (" + КодВалютыИлиВалюта + ", " + Формат(ДатаСделки, "ДФ=dd.MM.yyyy; ДП=") + ")";
	КонецЕсли;
	
	ТекущаяСтрока = ОтборСтрок[0];
	
	Возврат Новый Структура("Валюта, Курс, Кратность", ТекущаяСтрока.Валюта, ТекущаяСтрока.Курс, ТекущаяСтрока.Кратность);
КонецФункции // ПолучитьКурсВалютыСделки()

Функция ЗначениеИзКешаПоНаименованию(Знач Ключ, Знач Менеджер, Кеш)
	Перем Значение;
	
	Значение = Кеш[Ключ];
	Если Значение = Неопределено Тогда
		Значение = Менеджер.НайтиПоНаименованию(Ключ);
		
		Кеш[Ключ] = Значение;
	КонецЕсли;
	
	Возврат Значение;
КонецФункции // ЗначениеИзКешаПоНаименованию()

Функция ЗначениеИзКешаРежимовТоргов(Знач Ключ, Кеш)
	Перем Значение;
	
	Значение = Кеш[Ключ];
	Если Значение = Неопределено Тогда
		Значение = РежимТорговПоID(Ключ);
		
		Кеш[Ключ] = Значение;
	КонецЕсли;
	
	Возврат Значение;
КонецФункции // ЗначениеИзКешаРежимовТоргов()

Функция ОтобратьРежимыТоргов(Знач ИсходныеДанные)
	Перем Запрос, РежимыТоргов;
	
	Запрос = Новый Запрос();
	Запрос.УстановитьПараметр("ИсходныеДанные", ИсходныеДанные);
	Запрос.УстановитьПараметр("ПВХ_Counterparty", ПланыВидовХарактеристик.СвойстваОбъектов.НайтиПоНаименованию("Counterparty"));
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ИсходныеДанные.КодКлиента КАК КодКлиента,
	|	ИсходныеДанные.КодБрокера КАК КодБрокера,
	|	ИсходныеДанные.ЭтоOTC КАК ЭтоOTC
	|ПОМЕСТИТЬ втИсходныеДанные
	|ИЗ
	|	&ИсходныеДанные КАК ИсходныеДанные
	|ГДЕ
	|	ИсходныеДанные.КодКлиента > """"
	|ИНДЕКСИРОВАТЬ ПО КодКлиента, ЭтоOTC, КодБрокера
	|;
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	|	Выборка.БрокерскийСчет КАК БрокерскийСчет,
	|	Выборка.АналитическийСчетЦБ КАК АналитическийСчетЦБ,
	|	Выборка.АналитическийСчетДС КАК АналитическийСчетДС,
	|	Выборка.ПИФ КАК ПИФ,
	|	Выборка.Брокер КАК Брокер,
	|	Выборка.ДоговорБрокера КАК ДоговорБрокера,
	|	Выборка.КодКлиента КАК _КодКлиента_,
	|	Выборка.КодБрокера КАК _КодБрокера_,
	|	Выборка.ЭтоOTC КАК _ЭтоOTC_
	|ИЗ
	|	(ВЫБРАТЬ
	|		ТорговыеКоды.Ссылка КАК БрокерскийСчет,
	|		ТорговыеКоды.АналитическийСчетЦБ КАК АналитическийСчетЦБ,
	|		ТорговыеКоды.АналитическийСчетДС КАК АналитическийСчетДС,
	|		ТорговыеКоды.ПИФ КАК ПИФ,
	|		ТорговыеКоды.Брокер КАК Брокер,
	|		ТорговыеКоды.ДоговорБрокера КАК ДоговорБрокера,
	|		ТорговыеКоды.ТорговыйКод КАК КодКлиента,
	|		ИсходныеДанные.КодБрокера КАК КодБрокера,
	|		ИсходныеДанные.ЭтоOTC КАК ЭтоOTC
	|	ИЗ
	|		Справочник.ТорговыеКоды КАК ТорговыеКоды
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ЗначенияСвойствОбъектов КАК ЗначенияСвойствОбъектов
	|			ПО ТорговыеКоды.Брокер = ЗначенияСвойствОбъектов.Объект
	|				И (ЗначенияСвойствОбъектов.Свойство = &ПВХ_Counterparty)
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ втИсходныеДанные КАК ИсходныеДанные
	|			ПО (ИсходныеДанные.КодКлиента = ТорговыеКоды.ТорговыйКод)
	|				И (ИсходныеДанные.ЭтоOTC)
	|	ГДЕ
	|		1 = 1
	|		И НЕ ТорговыеКоды.ПометкаУдаления
	|		И ЗначенияСвойствОбъектов.Значение ПОДОБНО ""%"" + ИсходныеДанные.КодБрокера + ""%""
	|	
	|	ОБЪЕДИНИТЬ
	|	
	|	ВЫБРАТЬ
	|		ТорговыеКоды.Ссылка,
	|		ТорговыеКоды.АналитическийСчетЦБ,
	|		ТорговыеКоды.АналитическийСчетДС,
	|		ТорговыеКоды.ПИФ,
	|		ТорговыеКоды.Брокер,
	|		ТорговыеКоды.ДоговорБрокера,
	|		ТорговыеКоды.ТорговыйКод,
	|		ИсходныеДанные.КодБрокера,
	|		ИсходныеДанные.ЭтоOTC
	|	ИЗ
	|		Справочник.ТорговыеКоды КАК ТорговыеКоды
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ втИсходныеДанные КАК ИсходныеДанные
	|			ПО (ИсходныеДанные.КодКлиента = ТорговыеКоды.ТорговыйКод)
	|				И (НЕ ИсходныеДанные.ЭтоOTC)
	|	ГДЕ
	|		1 = 1
	|		И НЕ ТорговыеКоды.ПометкаУдаления) КАК Выборка
	|
	|УПОРЯДОЧИТЬ ПО
	|	_КодКлиента_,
	|	_ЭтоOTC_,
	|	_КодБрокера_";
	
	РежимыТоргов = Запрос.Выполнить().Выгрузить();
	РежимыТоргов.Индексы.Добавить("_КодКлиента_, _ЭтоOTC_, _КодБрокера_");
	
	Возврат РежимыТоргов;
КонецФункции // ОтобратьРежимыТоргов()

Функция ОпределитьТорговыйКодПоКоду(Знач РежимыТоргов, Знач КодКлиента, Знач КодБрокера, Знач РежимТоргов)
	Перем ОтборСтрок;
	
	ОтборСтрок = РежимыТоргов.НайтиСтроки(Новый Структура("_КодКлиента_, _КодБрокера_, _ЭтоOTC_", КодКлиента, КодБрокера, (РежимТоргов = "OTC")));
	
	Если ОтборСтрок.Количество() = 0 Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Возврат ОтборСтрок[0];
КонецФункции // ОпределитьТорговыйКодПоКоду()

Функция ОтобратьАлгоритмыРасчетаКомиссии(Знач МассивДоговоров)
	Перем АлгоритмыРасчета;
	Перем РеквизитыДоговора, Алгоритм, Настройки, ВнешнийОбъект;
	
	АлгоритмыРасчета = Новый Соответствие();
	Для Каждого ТекДоговор Из МассивДоговоров Цикл
		Если НЕ ЗначениеЗаполнено(ТекДоговор) ИЛИ ТипЗнч(ТекДоговор) <> Тип("СправочникСсылка.ДоговорыКонтрагентов") Тогда
			Продолжить;
		КонецЕсли;
		
		РеквизитыДоговора	 = ОбщегоНазначения.ПолучитьЗначенияРеквизитов(ТекДоговор, "Владелец, АлгоритмДоговора, НастройкиАлгоритма");
		Алгоритм			 = РеквизитыДоговора.АлгоритмДоговора;
		
		Если Алгоритм.Пустая() Тогда
			Продолжить;
		КонецЕсли;
		
		Настройки = РеквизитыДоговора.НастройкиАлгоритма.Получить();
		
		Если Настройки = Неопределено ИЛИ ТипЗнч(Настройки) <> Тип("Структура") Тогда
			Настройки = ОбщегоНазначения.ПолучитьЗначениеРеквизита(Алгоритм, "ХранилищеНастроек").Получить();
		КонецЕсли;
		
		АлгоритмыРасчета.Вставить(ТекДоговор, Новый Структура("Владелец, АлгоритмДоговора, НастройкиАлгоритма", РеквизитыДоговора.Владелец, Алгоритм, Настройки));
	КонецЦикла;
	
	Возврат АлгоритмыРасчета;
КонецФункции // ОтобратьАлгоритмыРасчетаКомиссии()

Функция ПолучитьСоздатьИнструментПоВалютамИРежимуТоргов(БиржеваяВалюта, ВалютаРасчетов, РежимТоргов)

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	ИнструментыВалютныхСделок.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.ИнструментыВалютныхСделок КАК ИнструментыВалютныхСделок
		|ГДЕ
		|	ИнструментыВалютныхСделок.ВалютаБазовая = &ВалютаБазовая
		|	И ИнструментыВалютныхСделок.ВалютаРасчетов = &ВалютаРасчетов
		|	И ИнструментыВалютныхСделок.РежимТоргов = &РежимТоргов";
	
	Запрос.УстановитьПараметр("ВалютаБазовая", БиржеваяВалюта);
	Запрос.УстановитьПараметр("ВалютаРасчетов", ВалютаРасчетов);
	Запрос.УстановитьПараметр("РежимТоргов", РежимТоргов);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда
		Возврат ВыборкаДетальныеЗаписи.Ссылка;
	Иначе
		НовыйИнструмент = Справочники.ИнструментыВалютныхСделок.СоздатьЭлемент();
		НовыйИнструмент.Наименование = "" + БиржеваяВалюта + "/" + ВалютаРасчетов + " " + РежимТоргов;
		НовыйИнструмент.Идентификатор = НовыйИнструмент.Наименование;
		НовыйИнструмент.РежимТоргов = РежимТоргов;
		НовыйИнструмент.ВалютаБазовая = БиржеваяВалюта;
		НовыйИнструмент.ВалютаРасчетов = ВалютаРасчетов;
		НовыйИнструмент.ИспользоватьВРасчетахПриоритетКурсов = Истина; //IMDEV-4581 RKatunin
		
		Попытка
			НовыйИнструмент.Записать();
			Возврат НовыйИнструмент.Ссылка;
		Исключение
			ТекстОшибки = ТекстОшибки + Символы.ПС + ОписаниеОшибки(); 
			Отказ = Истина;
			Возврат Справочники.ИнструментыВалютныхСделок.ПустаяСсылка();
		КонецПопытки;
		
	КонецЕсли;

КонецФункции

Функция АктуальныеКурсКратность(Валюта, ИспользоватьВРасчетахПриоритетКурсов,Сделка)
	
	Результат = Новый Структура;
	Результат.Вставить("ВалютаПоПриоритету", Справочники.Валюты.ПустаяСсылка());
	Результат.Вставить("Курс", 0);
	Результат.Вставить("Кратность", 0);
	
	КурсКратностьДокумента = КурсВалютыНаДатуДокумента(Валюта,Сделка);
	Если ИспользоватьВРасчетахПриоритетКурсов Тогда
		Результат.ВалютаПоПриоритету = КурсКратностьДокумента.ВалютаПоПриоритету;
		Результат.Курс = КурсКратностьДокумента.Курс;
		Результат.Кратность = КурсКратностьДокумента.Кратность;
	Иначе
		Результат.ВалютаПоПриоритету = Валюта;
		Результат.Курс = КурсКратностьДокумента.КурсСрезНаДату;
		Результат.Кратность = КурсКратностьДокумента.КратностьСрезНаДату;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция КурсВалютыНаДатуДокумента(ВалютаКурса,Сделка) 
		
	Если Не мСтруктураКэшДанных.Свойство("КурсыВалютПоДатеДокумента") Тогда
		КурсыВалютПоДате = ОбщегоНазначения.КурсыВалютПоДате(Сделка.Дата, Сделка.ПИФ, Истина);
		мСтруктураКэшДанных.Вставить("КурсыВалютПоДатеДокумента", КурсыВалютПоДате);		
	КонецЕсли; 
	
	ДанныеПоВалюте = мСтруктураКэшДанных.КурсыВалютПоДатеДокумента.Получить(ВалютаКурса);
	Если ДанныеПоВалюте = Неопределено Тогда
		ДанныеПоВалюте = Новый Структура;
		ДанныеПоВалюте.Вставить("ВалютаПоПриоритету", Справочники.Валюты.ПустаяСсылка());
		ДанныеПоВалюте.Вставить("Курс", 1);
		ДанныеПоВалюте.Вставить("Кратность", 1);
		ДанныеПоВалюте.Вставить("КурсСрезНаДату", 1);
		ДанныеПоВалюте.Вставить("КратностьСрезНаДату", 1);
		
		мСтруктураКэшДанных.КурсыВалютПоДатеДокумента.Вставить(ВалютаКурса, ДанныеПоВалюте);
	КонецЕсли;
		
	ДанныеПоВалюте.Кратность = ?(ДанныеПоВалюте.Кратность = 0, 1, ДанныеПоВалюте.Кратность);
	ДанныеПоВалюте.КратностьСрезНаДату = ?(ДанныеПоВалюте.КратностьСрезНаДату = 0, 1, ДанныеПоВалюте.КратностьСрезНаДату);
		
	Возврат ДанныеПоВалюте;
		
КонецФункции

Функция ПолучитьКонтрагентаПоКодуБрокера(КодБрокера)
	
	Если Не ЗначениеЗаполнено(КодБрокера) Тогда
		Возврат Справочники.Контрагенты.ПустаяСсылка();
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ЗначенияСвойствОбъектов.Объект КАК Ссылка
		|ИЗ
		|	РегистрСведений.ЗначенияСвойствОбъектов КАК ЗначенияСвойствОбъектов
		|ГДЕ
		|	ЗначенияСвойствОбъектов.Свойство = &Свойство_КодКонтрагента
		|	И ЗначенияСвойствОбъектов.Значение = &Значение";
	
	Запрос.УстановитьПараметр("Значение", СокрЛП(КодБрокера));
	Запрос.УстановитьПараметр("Свойство_КодКонтрагента", Свойство_КодКонтрагента);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда
		Возврат ВыборкаДетальныеЗаписи.Ссылка;
	Иначе
		Возврат Справочники.Контрагенты.ПустаяСсылка();
	КонецЕсли;
	
КонецФункции 

