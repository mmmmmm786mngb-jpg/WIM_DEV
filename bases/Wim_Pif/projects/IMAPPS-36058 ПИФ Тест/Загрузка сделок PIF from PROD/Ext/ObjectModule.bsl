	|	ГДЕ
	|		СрочныеКонтракты.КраткийКод В(&КодЦБ)
	|		И СрочныеКонтракты.КраткийКод > """") КАК Бумаги
	|
	|УПОРЯДОЧИТЬ ПО
	|	Бумаги.Приоритет,
	|	Бумага";
	
	Результат = Запрос.Выполнить();
	Если Результат.Пустой() Тогда
		Если ВыполнятьПоискИзВнешнейОбработки И ЗначениеЗаполнено(ЭтотОбъект.ОбработкаЗагрузкиАктивов) И ЗначениеЗаполнено(ЭтотОбъект.КомандаЗагрузкиАктивов) Тогда
			ДополнительныеОтчетыИОбработки.ВыполнитьКомандуОбработкиПоПараметрам(
				ОбработкаЗагрузкиАктивов,
				КомандаЗагрузкиАктивов,
				Новый Структура("Тикер", КодЦБ)
			);
			
			НайденныйАктив = АктивПоКоду(КодЦБ, Биржа, Ложь, СтатусПоискаАктива);
			
			Возврат НайденныйАктив;
		КонецЕсли;
		
		СтатусПоискаАктива = "Актив не найден";
		
		Возврат Неопределено;
	КонецЕсли;
	
	Выборка = Результат.Выбрать();
	Выборка.Следующий();
	
	НайденныйАктив = АктивКлиентСерверный.ПолучитьАктивПоОбъекту(Выборка.Бумага);
	СоответствиеАктивов.Вставить(КодЦБ, НайденныйАктив);
	
	Если НЕ ВыполнятьПоискИзВнешнейОбработки Тогда
		СтатусПоискаАктива = "Актив загружен через web-service";
	КонецЕсли;
	
	Возврат НайденныйАктив;
КонецФункции // АктивПоКоду()

Функция СделкаПоНомеру(Номер, Продажа)
	Запрос = Новый Запрос();
	Запрос.УстановитьПараметр("НомерСделки",Номер);
	Запрос.УстановитьПараметр("ВидОперации",?(Продажа,Перечисления.ВидыОперацийСделка.Продажа,Перечисления.ВидыОперацийСделка.Поступление));
	Запрос.УстановитьПараметр("ВидОперации2",?(Продажа, Перечисления.ВидОперацииБПВнебиржеваяСделка.Продажа, Перечисления.ВидОперацииБПВнебиржеваяСделка.Покупка));
	Запрос.УстановитьПараметр("ВидОперацииСВалютой",?(Продажа, Перечисления.ВидыОперацийСделкаСВалютой.Продажа, Перечисления.ВидыОперацийСделкаСВалютой.Покупка));
	Запрос.УстановитьПараметр("ДатаНач",ДатаНачала - 20 * 86400);
	Запрос.УстановитьПараметр("ДатаОкон",КонецДня(ДатаОкончания));
	Запрос.УстановитьПараметр("ДатаОкон3",КонецДня(ДатаОкончания) + 3 * 86400);
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Сделка.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.СделкаЦБ КАК Сделка
	|ГДЕ
	|	Сделка.НомерВходящегоДокумента = &НомерСделки
	|	И Сделка.ВидОперации = &ВидОперации
	|	И НЕ Сделка.ПометкаУдаления
	|	И Сделка.Дата МЕЖДУ &ДатаНач И &ДатаОкон
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	СделкиTn.Ссылка
	|ИЗ
	|	БизнесПроцесс.СделкиTn КАК СделкиTn
	|ГДЕ
	|	СделкиTn.ВидОперации = &ВидОперации
	|	И СделкиTn.НомерСделки = &НомерСделки
	|	И НЕ СделкиTn.ПометкаУдаления
	|	И СделкиTn.Дата МЕЖДУ &ДатаНач И &ДатаОкон
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	СделкиРЕПО.Ссылка
	|ИЗ
	|	БизнесПроцесс.СделкиРЕПО КАК СделкиРЕПО
	|ГДЕ
	|	СделкиРЕПО.НомерСделки = &НомерСделки
	|	И НЕ СделкиРЕПО.ПометкаУдаления
	|	И СделкиРЕПО.Дата МЕЖДУ &ДатаНач И &ДатаОкон
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ВнебиржеваяСделка.Ссылка
	|ИЗ
	|	БизнесПроцесс.ВнебиржеваяСделка КАК ВнебиржеваяСделка
	|ГДЕ
	|	ВнебиржеваяСделка.ВидОперации = &ВидОперации2
	|	И ВнебиржеваяСделка.НомерСделки = &НомерСделки
	|	И НЕ ВнебиржеваяСделка.ПометкаУдаления
	|	И ВнебиржеваяСделка.Дата МЕЖДУ &ДатаНач И &ДатаОкон
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	БиржеваяСделкаСВалютой.Ссылка
	|ИЗ
	|	БизнесПроцесс.БиржеваяСделкаСВалютой КАК БиржеваяСделкаСВалютой
	|ГДЕ
	|	БиржеваяСделкаСВалютой.ВидОперации = &ВидОперацииСВалютой
	|	И БиржеваяСделкаСВалютой.НомерСделки = &НомерСделки
	|	И НЕ БиржеваяСделкаСВалютой.ПометкаУдаления
	|	И БиржеваяСделкаСВалютой.Дата МЕЖДУ &ДатаНач И &ДатаОкон
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	СделкаНаСрочномРынке.Ссылка
	|ИЗ
	|	Документ.СделкаНаСрочномРынке КАК СделкаНаСрочномРынке
	|ГДЕ
	|	НЕ СделкаНаСрочномРынке.ПометкаУдаления
	|	И СделкаНаСрочномРынке.ВходящийНомер = &НомерСделки
	|	И СделкаНаСрочномРынке.Дата МЕЖДУ &ДатаНач И &ДатаОкон3";
	
	Результат = Запрос.Выполнить();
	Если Результат.Пустой() тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Выборка = Результат.Выбрать();
	Выборка.Следующий();
	
	Возврат Выборка.Ссылка;
КонецФункции // СделкаПоНомеру()

