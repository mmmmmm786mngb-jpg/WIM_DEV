	МАКСИМУМ(ЕСТЬNULL(КодыЗагрузкиRuData.Код, "")) КАК КодЗагрузкиRuData,
	МАКСИМУМ(ЕСТЬNULL(КодыЗагрузкиНДЦ.Код, "")) КАК КодЗагрузкиНДЦ,
	МАКСИМУМ(ЕСТЬNULL(КодыЗагрузкиMICEX.Код, "")) КАК КодЗагрузкиMICEX,
	МАКСИМУМ(ЕСТЬNULL(КодыЗагрузкиRuData.Владелец, ЕСТЬNULL(КодыЗагрузкиНДЦ.Владелец, НЕОПРЕДЕЛЕНО))) КАК ЦБ
ПОМЕСТИТЬ КлючевыеПоляRuData
ИЗ
	ДанныеRuData КАК ДанныеRuData
		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ЦенныеБумаги КАК ЦБ1
			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.КодыЗагрузки КАК КодыЗагрузкиRuData
			ПО ЦБ1.Ссылка = КодыЗагрузкиRuData.Владелец
				И (НЕ КодыЗагрузкиRuData.ПометкаУдаления)
				И (КодыЗагрузкиRuData.Биржа = &amp;КлассификаторRuData)
				И (&amp;ТекущаяДатаСеанса &gt;= КодыЗагрузкиRuData.ДатаНачалаДействия)
				И (КодыЗагрузкиRuData.ДатаОкончанияДействия = ДАТАВРЕМЯ(1, 1, 1)
					ИЛИ &amp;ТекущаяДатаСеанса &lt;= КодыЗагрузкиRuData.ДатаОкончанияДействия)
		ПО (ДанныеRuData.fintoolid = КодыЗагрузкиRuData.Код)
			И (НЕ ЦБ1.ПометкаУдаления)
		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ЦенныеБумаги КАК ЦБ2
			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.КодыЗагрузки КАК КодыЗагрузкиНДЦ
			ПО ЦБ2.Ссылка = КодыЗагрузкиНДЦ.Владелец
				И (НЕ КодыЗагрузкиНДЦ.ПометкаУдаления)
				И (КодыЗагрузкиНДЦ.Биржа = &amp;КлассификаторНДЦ)
				И (&amp;ТекущаяДатаСеанса &gt;= КодыЗагрузкиНДЦ.ДатаНачалаДействия)
				И (КодыЗагрузкиНДЦ.ДатаОкончанияДействия = ДАТАВРЕМЯ(1, 1, 1)
					ИЛИ &amp;ТекущаяДатаСеанса &lt;= КодыЗагрузкиНДЦ.ДатаОкончанияДействия)
		ПО (ДанныеRuData.nrdcode = КодыЗагрузкиНДЦ.Код)
			И (НЕ ЦБ2.ПометкаУдаления)
		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ЦенныеБумаги КАК ЦБ3
			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.КодыЗагрузки КАК КодыЗагрузкиMICEX
			ПО ЦБ3.Ссылка = КодыЗагрузкиMICEX.Владелец
				И (НЕ КодыЗагрузкиMICEX.ПометкаУдаления)
				И (КодыЗагрузкиMICEX.Биржа = &amp;КлассификаторMICEX)
				И (&amp;ТекущаяДатаСеанса &gt;= КодыЗагрузкиMICEX.ДатаНачалаДействия)
				И (КодыЗагрузкиMICEX.ДатаОкончанияДействия = ДАТАВРЕМЯ(1, 1, 1)
					ИЛИ &amp;ТекущаяДатаСеанса &lt;= КодыЗагрузкиMICEX.ДатаОкончанияДействия)
		ПО (ДанныеRuData.moex_code = КодыЗагрузкиMICEX.Код)
			И (НЕ ЦБ3.ПометкаУдаления)

СГРУППИРОВАТЬ ПО
	ДанныеRuData.fintoolid,
	ДанныеRuData.isin,
	ДанныеRuData.nrdcode,
	ДанныеRuData.reg_code,
	ДанныеRuData.fininstid,
	ДанныеRuData.ЭтоRU
