	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ СтрокиКоличествоЦБДепонента КАК СтрокиКоличествоЦБДепонента
	|		ПО СтрокиКОбработке.ЦеннаяБумага = СтрокиКоличествоЦБДепонента.ЦеннаяБумага
	|			И СтрокиКОбработке.Депонент = СтрокиКоличествоЦБДепонента.Депонент
	|			И СтрокиКОбработке.РазделСчета.Владелец = СтрокиКоличествоЦБДепонента.СчетДепо
	|
	|УПОРЯДОЧИТЬ ПО
	|	Клиент,
	|	Субклиент,
	|	W8BEN_W8BENEПредоставленаСубклиентом");
	
	КорпоративноеДействие = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(БизнесПроцесс,"КД");
	 
	ДатаОкончанияПриемаИнструкцийНРД = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(КорпоративноеДействие,"ДатаОкончанияПриемаИнструкцийНРД");
	Если ЗначениеЗаполнено(ДатаОкончанияПриемаИнструкцийНРД) Тогда
		ДатаОкончанияПриемаИнструкцийНРД = НачалоДня(ДатаОкончанияПриемаИнструкцийНРД);
	Иначе 
		СообщениеОбОшибке = "Не указана  ДатаОкончанияПриемаИнструкцийНРД";
		ЗаписьЖурналаРегистрации("Обработка WTRC соббщения",УровеньЖурналаРегистрации.Ошибка,СообщениеОбОшибке,БизнесПроцесс);
		ВызватьИсключение СообщениеОбОшибке;
	КонецЕсли;
	
	Запрос.УстановитьПараметр("АмериканскаяЦБ",АмериканскаяЦБ);
	Запрос.УстановитьПараметр("БизнесПроцес",БизнесПроцесс);
	Запрос.УстановитьПараметр("СтатусПустаяСсылка",Перечисления.СтатусыЗавершенияБПОбработкаWTRCСообщения.ПустаяСсылка());
	Запрос.УстановитьПараметр("СтатусОтправлено",Перечисления.СтатусыЗавершенияБПОбработкаWTRCСообщения.Отправлено);
	Запрос.УстановитьПараметр("СубклиентПустаяСсылка",Справочники.Субклиенты.ПустаяСсылка());
	Запрос.УстановитьПараметр("ТипыСчетовВладельца",БизнесПроцессы.ОбработкаWTRCСообщения.ТипыСчетовВладельца());
	Запрос.УстановитьПараметр("ТипыСчетовДУ",ТипыСчетовДУ());
	Запрос.УстановитьПараметр("ТипыСчетовИНД",ТипыСчетовИНД());
	Запрос.УстановитьПараметр("ТипыСчетовНД",ТипыСчетовНД());
	Запрос.УстановитьПараметр("ВидДокументаW8BEN_W8BENE",Справочники.ВидыДокументовУдостоверяющихПолномочия.ФормаW8BENE_W8BEN);
	Запрос.УстановитьПараметр("ВидДокументаW8IMY",Справочники.ВидыДокументовУдостоверяющихПолномочия.ФормаW8IMY);
	Запрос.УстановитьПараметр("СтатусыЗавершения",СтатусыЗавершения);	
	Запрос.УстановитьПараметр("КД", КорпоративноеДействие);
	Запрос.УстановитьПараметр("УчастиеВКД", Справочники.ВидыОпераций.УчастиеВКД);
	Запрос.УстановитьПараметр("ДатаОкончанияПриемаИнструкцийНРД",ДатаОкончанияПриемаИнструкцийНРД);
	Запрос.УстановитьПараметр("КлассификаторыЗагрузкиКлиенты", Справочники.КлассификаторыЗагрузки.Клиенты);
	Запрос.УстановитьПараметр("ВидыАкцийОбыкновенная",	Перечисления.ВидыАкций.Обыкновенная);
	Запрос.УстановитьПараметр("ДатаСреза",				ТекущаяДата());
	Запрос.УстановитьПараметр("ПустаяВалюта", 			Справочники.Валюты.ПустаяСсылка());
	Запрос.УстановитьПараметр("НДЦ",					Константы.КлассификаторЗагрузкиНДЦ.Получить());
    Запрос.УстановитьПараметр("НаименованиеВалютыПоУмолчанию",Справочники.Валюты.ДолларСША().Наименование);
	Запрос.УстановитьПараметр("ТипФормыW8IMY", Перечисления.ТипыФормW8.ФормаW8IMY);
	Запрос.УстановитьПараметр("ЮрЛицо", Перечисления.ЮрФизЛицо.ЮрЛицо);
	
	Возврат Запрос.Выполнить();
	
КонецФункции

Функция РезультатЗапросаПоДокументуКД(КорпоративноеДействиеСсылка) Экспорт 
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Ссылка",КорпоративноеДействиеСсылка);
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	КорпоративноеДействие_Новый.КДРеференс КАК reference,
		|	ПРЕДСТАВЛЕНИЕ(КорпоративноеДействие_Новый.ЦеннаяБумага1.Эмитент) КАК issuerName,
		|	КорпоративноеДействие_Новый.ДатаОкончанияПриемаИнструкцийВТБКБ КАК deadLineDate
		|ИЗ
		|	Документ.КорпоративноеДействие_Новый КАК КорпоративноеДействие_Новый
		|ГДЕ
		|	КорпоративноеДействие_Новый.Ссылка = &Ссылка";

	Возврат Запрос.Выполнить();

КонецФункции

Функция ПредоставленаФормаW8(БизнесПроцесс, ДанныеКОбработке, СтрокаТабличнойЧасти, ПолучателиСообщений, ДатаПовторнойОтправкиУведомленияW8, Уведомление, ПовторнаяОтправка = Ложь, Тестирование = Ложь) Экспорт
	
	УведомленияКОтправке = Новый Соответствие();
	ТекущаяДата = НачалоДня(ТекущаяДата());	
	Депонент = ДанныеКОбработке.Клиент;
	ДепонентОтправлено = ?(ПолучателиСообщений.Получить(Депонент) = Неопределено,Ложь,Истина); 
	Субклиент = ДанныеКОбработке.Субклиент;
	СубклиентОтправлено = ?(ПолучателиСообщений.Получить(Субклиент) = Неопределено,Ложь,Истина);
	
	СтатусОтправляемогоУведовления = Неопределено;
	Если СтрокаТабличнойЧасти.УведомлениеW8 = Перечисления.СтатусыЗавершенияБПОбработкаWTRCСообщения.ПустаяСсылка() 
		ИЛИ СтрокаТабличнойЧасти.УведомлениеW8 = Перечисления.СтатусыЗавершенияБПОбработкаWTRCСообщения.ОшибкаОтправки Тогда 
		СтатусОтправляемогоУведовления = Перечисления.СтатусыЗавершенияБПОбработкаWTRCСообщения.Отправлено;
	ИначеЕсли СтрокаТабличнойЧасти.УведомлениеW8 = Перечисления.СтатусыЗавершенияБПОбработкаWTRCСообщения.Отправлено 
		И ТекущаяДата = ДатаПовторнойОтправкиУведомленияW8 Тогда
		ПовторнаяОтправка = Истина;
		СтатусОтправляемогоУведовления = Перечисления.СтатусыЗавершенияБПОбработкаWTRCСообщения.ОтправленоПовторно;	
	ИначеЕсли ПовторнаяОтправка Тогда
		СтатусОтправляемогоУведовления = Перечисления.СтатусыЗавершенияБПОбработкаWTRCСообщения.ОтправленоПовторно;
	КонецЕсли;
	
	Если ДанныеКОбработке.ПрямойКлиент Тогда
		Если ДепонентОтправлено Тогда 
			Возврат Ложь;
		КонецЕсли;
		
		Если ДанныеКОбработке.W8BEN_W8BENE Тогда 
			
			СтрокаТабличнойЧасти.ЕстьФормаW8BENE_W8BEN = Истина;
			СтрокаТабличнойЧасти.УведомлениеW8 = Перечисления.СтатусыЗавершенияБПОбработкаWTRCСообщения.Успешно;
			ПолучателиСообщений.Вставить(Депонент,СтрокаТабличнойЧасти.УведомлениеW8);
			
			Возврат Истина;
			
		ИначеЕсли ЗначениеЗаполнено(СтатусОтправляемогоУведовления) Тогда 
			
			Уведомление = WTRCСообщенияQI.УведомлениеПредоставитьФормуW8BEN_W8BENE(БизнесПроцесс, ПовторнаяОтправка);
			ПолучателиСообщений.Вставить(Депонент,СтрокаТабличнойЧасти.УведомлениеW8);
			Возврат Ложь;
			
		КонецЕсли;
		
	ИначеЕсли ДанныеКОбработке.ДУ Тогда
		
		Если ДепонентОтправлено Тогда 
			Возврат Ложь;
		КонецЕсли;
		
		Если ДанныеКОбработке.W8IMY И ДанныеКОбработке.W8BEN_W8BENE Тогда 
			
			СтрокаТабличнойЧасти.ЕстьФормаW8BENE_W8BEN = Истина;
			СтрокаТабличнойЧасти.УведомлениеW8 = Перечисления.СтатусыЗавершенияБПОбработкаWTRCСообщения.Успешно;
			Возврат Истина;
			
		ИначеЕсли ЗначениеЗаполнено(СтатусОтправляемогоУведовления) Тогда
			
			Если ДанныеКОбработке.W8IMY = Ложь Тогда 
				
				Уведомление = WTRCСообщенияQI.УведомлениеПредоставитьФормуW8IMY(БизнесПроцесс, ПовторнаяОтправка);
				
			ИначеЕсли ДанныеКОбработке.W8BEN_W8BENE = Ложь Тогда 
				
				Уведомление = WTRCСообщенияQI.УведомлениеПредоставитьФормуW8BEN_W8BENE(БизнесПроцесс, ПовторнаяОтправка);
				
			КонецЕсли;
			
		КонецЕсли;
		
		Возврат Ложь;
		
	ИначеЕсли ДанныеКОбработке.ИНД ИЛИ ДанныеКОбработке.НД Тогда
		
		Если ДанныеКОбработке.W8IMY И ДанныеКОбработке.W8BEN_W8BENEПредоставленаВсемиСубклиентами Тогда 
			
			СтрокаТабличнойЧасти.ЕстьФормаW8BENE_W8BEN = Истина;
			СтрокаТабличнойЧасти.УведомлениеW8 = Перечисления.СтатусыЗавершенияБПОбработкаWTRCСообщения.Успешно;
			Возврат Истина;
			
		ИначеЕсли ДанныеКОбработке.W8IMY = Ложь Тогда 
			
			Если СтрокаТабличнойЧасти.УведомлениеW8 = Перечисления.СтатусыЗавершенияБПОбработкаWTRCСообщения.ОтправленоПовторно  Тогда 
				Возврат Ложь;
			КонецЕсли;
			
			Если ДепонентОтправлено Тогда
				
				РанееОтправленноеУведомление = ПолучателиСообщений.Получить(Депонент);
				Если НЕ РанееОтправленноеУведомление = Неопределено Тогда 						
					СтрокаТабличнойЧасти.УведомлениеW8 = РанееОтправленноеУведомление;
					Возврат Ложь;
				КонецЕсли;
				
			КонецЕсли;	
			
			Если ЗначениеЗаполнено(СтатусОтправляемогоУведовления) Тогда
				Уведомление = WTRCСообщенияQI.УведомлениеПредоставитьФормуW8IMY(БизнесПроцесс, ПовторнаяОтправка);
				ПолучателиСообщений.Вставить(Депонент,СтрокаТабличнойЧасти.УведомлениеW8);
			КонецЕсли;
			
		ИначеЕсли ДанныеКОбработке.W8BEN_W8BENEПредоставленаВсемиСубклиентами = Ложь Тогда
			
			// Если у НД/ИНД есть форма W8IMY но нет какой либо формы по субклиенту, тогда продолжим выполнение но отправим соответствуюшие уведомления клиентам
			Если СтрокаТабличнойЧасти.УведомлениеW8 = Перечисления.СтатусыЗавершенияБПОбработкаWTRCСообщения.ОтправленоПовторно  Тогда 
				Возврат Истина;
			КонецЕсли;	
			
			Если ДанныеКОбработке.W8BEN_W8BENEПредоставленаСубклиентом Тогда 
				СтрокаТабличнойЧасти.УведомлениеW8 = Перечисления.СтатусыЗавершенияБПОбработкаWTRCСообщения.Успешно;
			Иначе 
				
				Если ДепонентОтправлено Тогда
					
					РанееОтправленноеУведомление = ПолучателиСообщений.Получить(Депонент);
					Если НЕ РанееОтправленноеУведомление = Неопределено Тогда 						
						СтрокаТабличнойЧасти.УведомлениеW8 = РанееОтправленноеУведомление;
						Возврат Истина;
					КонецЕсли;
					
				КонецЕсли;
				
				Если ЗначениеЗаполнено(СтатусОтправляемогоУведовления) Тогда
					
					Уведомление = WTRCСообщенияQI.УведомлениеПредоставитьФормуW8BEN_W8BENE(БизнесПроцесс, ПовторнаяОтправка);
					ПолучателиСообщений.Вставить(Депонент,СтрокаТабличнойЧасти.УведомлениеW8);
					
				КонецЕсли;
			КонецЕсли;
			
			Возврат Истина;
			
		КонецЕсли;
		
		Возврат Ложь;
		
	КонецЕсли;
	
	Возврат Ложь;
	
КонецФункции


