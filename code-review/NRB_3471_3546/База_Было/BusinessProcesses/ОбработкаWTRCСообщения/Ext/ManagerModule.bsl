
Функция ДатаСкорогоОкончанияПриемаИнструкцийНРД(ДатаУведомления) Экспорт
	
	ДеньУведомления = НачалоДня(ДатаУведомления);
	Дата = ОбщегоНазначения.ДобавитьРабочийДень(ДеньУведомления, 3);
	Если Дата = ДеньУведомления Тогда
		Дата = ДеньУведомления + 3*24*3600; // Если календарь не заполнен, используем календарные дни
	Конецесли;
	
	Возврат Дата;
	
КонецФункции

Функция ЗадачаБизнесПроцесса(БизнесПроцессСсылка, ТочкаМаршрута) Экспорт 
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	ОбработкаWTRCСообщения.Ссылка КАК Ссылка
	|ИЗ
	|	Задача.ОбработкаWTRCСообщения КАК ОбработкаWTRCСообщения
	|ГДЕ
	|	ОбработкаWTRCСообщения.БизнесПроцесс = &БизнесПроцесс
	|	И ОбработкаWTRCСообщения.ТочкаМаршрута = &ТочкаМаршрута
	|	И ОбработкаWTRCСообщения.ПометкаУдаления = ЛОЖЬ");
	
	Запрос.УстановитьПараметр("БизнесПроцесс",БизнесПроцессСсылка);
	Запрос.УстановитьПараметр("ТочкаМаршрута",ТочкаМаршрута);
	
	Результат = Запрос.Выполнить();
	
	Если Результат.Пустой() Тогда 
		Возврат Задачи.ОбработкаWTRCСообщения.ПустаяСсылка();
	Иначе
		Выборка = Результат.Выбрать();
		Выборка.Следующий();
		Возврат Выборка.Ссылка;
	КонецЕсли;
	
КонецФункции

Функция СвязанныйДокументРСВ(КорпоративноеДействие) Экспорт 
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	РаскрытиеСпискаВладельцев.Ссылка КАК Ссылка
		|ИЗ
		|	Документ.РаскрытиеСпискаВладельцев КАК РаскрытиеСпискаВладельцев
		|ГДЕ
		|	РаскрытиеСпискаВладельцев.КарточкаКД = &КарточкаКД
		|	И РаскрытиеСпискаВладельцев.ПометкаУдаления = ЛОЖЬ
		|
		|УПОРЯДОЧИТЬ ПО
		|	Ссылка УБЫВ";

	Запрос.УстановитьПараметр("КарточкаКД", КорпоративноеДействие);

	Результат = Запрос.Выполнить();

	ВыборкаДетальныеЗаписи = Результат.Выбрать();

	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		Возврат ВыборкаДетальныеЗаписи.Ссылка;
	КонецЦикла;

	Возврат Документы.РаскрытиеСпискаВладельцев.ПустаяСсылка();	
	
КонецФункции

