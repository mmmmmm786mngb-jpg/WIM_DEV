Функция НеПредоставленныеДокументыПоФормамW8(РазделСчета,ДатаОкончанияПриемаИнструкцийНРД) Экспорт 

	Запрос = Новый Запрос(
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	РазделыСчетаДепо.Владелец.Владелец КАК Депонент,
	|	ВЫБОР
	|		КОГДА РазделыСчетаДепо.Владелец.ТипСчетаДепо В (&ТипыСчетаВладельца)
	|			ТОГДА &ТипСчетаВладельца
	|		КОГДА РазделыСчетаДепо.Владелец.ТипСчетаДепо В (&ТипыСчетаДУ)
	|			ТОГДА &ТипСчетаДУ
	|		КОГДА РазделыСчетаДепо.Владелец.ТипСчетаДепо В (&ТипыСчетаНД)
	|			ТОГДА &ТипСчетаНД
	|	КОНЕЦ КАК ТипСчетаДепо
	|ПОМЕСТИТЬ СчетДепо
	|ИЗ
	|	Справочник.РазделыСчетаДепо КАК РазделыСчетаДепо
	|ГДЕ
	|	РазделыСчетаДепо.Ссылка = &РазделСчета
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Депонент
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Субклиенты.Ссылка КАК Ссылка
	|ПОМЕСТИТЬ Субклиенты
	|ИЗ
	|	Справочник.Субклиенты КАК Субклиенты
	|ГДЕ
	|	Субклиенты.Владелец В
	|			(ВЫБРАТЬ
	|				СчетДепо.Депонент
	|			ИЗ
	|				СчетДепо КАК СчетДепо)
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ПредоставленныеДокументы.Депонент,
	|	СчетДепо.ТипСчетаДепо,
	|	ПредоставленныеДокументы.ВидДокумента,
	|	ПредоставленныеДокументы.СрокДействия,
	|	ВЫБОР
	|		КОГДА ПредоставленныеДокументы.ВидДокумента В (&ВидДокументаW8BEN_W8BENE)
	|			ТОГДА 1
	|		ИНАЧЕ 0
	|	КОНЕЦ КАК W8BEN_W8BENE,
	|	ВЫБОР
	|		КОГДА ПредоставленныеДокументы.ВидДокумента В (&ВидДокументаW8IMY)
	|			ТОГДА 1
	|		ИНАЧЕ 0
	|	КОНЕЦ КАК W8IMY,
	|	0 КАК СубклиентаW8BEN_W8BENE
	|ПОМЕСТИТЬ ПредоставленныеДокументы
	|ИЗ
	|	СчетДепо КАК СчетДепо
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ПредоставленныеДокументы КАК ПредоставленныеДокументы
	|		ПО СчетДепо.Депонент = ПредоставленныеДокументы.Депонент
	|			И (ПредоставленныеДокументы.СрокДействия >= &ДатаОкончанияПриемаИнструкцийНРД)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	СчетДепо.Депонент,
	|	СчетДепо.ТипСчетаДепо,
	|	ПредоставленныеДокументы.ВидДокумента,
	|	ПредоставленныеДокументы.СрокДействия,
	|	0,
	|	0,
	|	ВЫБОР
	|		КОГДА ПредоставленныеДокументы.ВидДокумента В (&ВидДокументаW8BEN_W8BENE)
	|			ТОГДА 1
	|		ИНАЧЕ 0
	|	КОНЕЦ
	|ИЗ
	|	СчетДепо КАК СчетДепо
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ПредоставленныеДокументы КАК ПредоставленныеДокументы
	|		ПО (ПредоставленныеДокументы.СрокДействия >= &ДатаОкончанияПриемаИнструкцийНРД)
	|			И (СчетДепо.Депонент В
	|				(ВЫБРАТЬ
	|					Субклиенты.Ссылка
	|				ИЗ
	|					Субклиенты КАК Субклиенты))
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ПредоставленныеДокументы.Депонент КАК Депонент,
	|	ПредоставленныеДокументы.ТипСчетаДепо КАК ТипСчетаДепо,
	|	СУММА(ПредоставленныеДокументы.W8BEN_W8BENE) КАК W8BEN_W8BENE,
	|	СУММА(ПредоставленныеДокументы.W8IMY) КАК W8IMY,
	|	СУММА(ПредоставленныеДокументы.СубклиентаW8BEN_W8BENE) КАК СубклиентаW8BEN_W8BENE
	|ИЗ
	|	ПредоставленныеДокументы КАК ПредоставленныеДокументы
	|
	|СГРУППИРОВАТЬ ПО
	|	ПредоставленныеДокументы.Депонент,
	|	ПредоставленныеДокументы.ТипСчетаДепо");
	
	Запрос.УстановитьПараметр("РазделСчета",РазделСчета);
	Запрос.УстановитьПараметр("ДатаОкончанияПриемаИнструкцийНРД",ДатаОкончанияПриемаИнструкцийНРД);
	Запрос.УстановитьПараметр("ВидДокументаW8BEN_W8BENE",Справочники.ВидыДокументовУдостоверяющихПолномочия.ФормаW8BENE_W8BEN);
	Запрос.УстановитьПараметр("ВидДокументаW8IMY",Справочники.ВидыДокументовУдостоверяющихПолномочия.ФормаW8IMY);
	
	Запрос.УстановитьПараметр("ТипыСчетаВладельца",ТипыСчетовВладельца());
	Запрос.УстановитьПараметр("ТипыСчетаДУ",ТипыСчетовДУ());
	Запрос.УстановитьПараметр("ТипыСчетаНД",ТипыСчетовНД());
	
	Запрос.УстановитьПараметр("ТипСчетаВладельца",Перечисления.ТипыСчетовДепо.Владельца);
	Запрос.УстановитьПараметр("ТипСчетаДУ",Перечисления.ТипыСчетовДепо.ДоверительногоУправляющего);
	Запрос.УстановитьПараметр("ТипСчетаНД",Перечисления.ТипыСчетовДепо.НоминальногоДержателя);

	ТребуемыеФормы = Новый Структура();	
	
	Результат = Запрос.Выполнить();
	Если Не Результат.Пустой() Тогда 
		
		Выборка = Результат.Выбрать();
		Выборка.Следующий();
		Если Выборка.ТипСчетаДепо = Перечисления.ТипыСчетовДепо.Владельца Тогда 
			Если Выборка.W8BEN_W8BENE = 0 Тогда 
				ТребуемыеФормы.Вставить("ФормаW8BENE_W8BEN",Истина);	
			КонецЕсли;
		ИначеЕсли Выборка.ТипСчетаДепо = Перечисления.ТипыСчетовДепо.ДоверительногоУправляющего Тогда
			Если Выборка.W8BEN_W8BENE = 0 Тогда 
				ТребуемыеФормы.Вставить("ФормаW8BENE_W8BEN",Истина);	
			КонецЕсли;
			Если Выборка.W8IMY = 0 Тогда 
				ТребуемыеФормы.Вставить("ФормаW8IMY",Истина);	
			КонецЕсли;
		ИначеЕсли Выборка.ТипСчетаДепо = Перечисления.ТипыСчетовДепо.НоминальногоДержателя Тогда
			Если Выборка.СубклиентаW8BEN_W8BENE = 0 Тогда 
				ТребуемыеФормы.Вставить("ФормаW8BENE_W8BENСубклиента",Истина);	
			КонецЕсли;
			Если Выборка.W8IMY = 0 Тогда 
				ТребуемыеФормы.Вставить("ФормаW8IMY",Истина);	
			КонецЕсли;
		КонецЕсли;	
	КонецЕсли;
	
	Возврат ТребуемыеФормы;
	
КонецФункции

Функция ДатаСообщенияWTRC(КорпоративноеДействие) Экспорт 
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	ЭтапыКДСрезПервых.Период КАК Период
		|ИЗ
		|	РегистрСведений.ЭтапыКД.СрезПервых КАК ЭтапыКДСрезПервых
		|ГДЕ
		|	ЭтапыКДСрезПервых.КД = &КД
		|
		|УПОРЯДОЧИТЬ ПО
		|	Период";

	Запрос.УстановитьПараметр("КД", КорпоративноеДействие);

	Результат = Запрос.Выполнить();

	ВыборкаДетальныеЗаписи = Результат.Выбрать();

	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		Возврат ВыборкаДетальныеЗаписи.Период;
	КонецЦикла;
	
	Возврат КорпоративноеДействие.Дата;
	
КонецФункции

Функция РезультатОтправкиИнформационногоПисьмаКлиентам(БизнесПроцесс, ДанныеКОбработке, Уведомление, Тестирование = Ложь) Экспорт 
	
	КорпоративноеДействиеСсылка = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(БизнесПроцесс,"КД");
	
	КодКлиента = СокрЛП(ДанныеКОбработке.КодЗагрузки);
	Если Не ЗначениеЗаполнено(КодКлиента) Тогда
		ТекстОшибки = "Не указан код загрузки для депонента " + ДанныеКОбработке.Депонент;
		#Если Клиент Тогда
			ОбщегоНазначения.СообщитьОбОшибке(ТекстОшибки);
		#КонецЕсли
		ИмяСобытия = "Отправка информационного письма в кабинет клиента";
		ЗаписьЖурналаРегистрации(ИмяСобытия, УровеньЖурналаРегистрации.Ошибка,, ДанныеКОбработке.Депонент, ТекстОшибки);
		Возврат Ложь;	
	КонецЕсли;
	
	ТаблицаКлиентов = Новый ТаблицаЗначений();
	ТаблицаКлиентов.Колонки.Добавить("ClientId");
	ТаблицаКлиентов.Колонки.Добавить("Клиент");
	ТаблицаКлиентов.Колонки.Добавить("СчетДепо");
	ТаблицаКлиентов.Колонки.Добавить("РазделСчетаДепо");
	ТаблицаКлиентов.Колонки.Добавить("ЦеннаяБумага");
	ТаблицаКлиентов.Колонки.Добавить("Количество");
    ТаблицаКлиентов.Колонки.Добавить("Тема");
	ТаблицаКлиентов.Колонки.Добавить("Тело");

	НоваяСтрока = ТаблицаКлиентов.Добавить();
	НоваяСтрока.ClientId 		= КодКлиента;
	НоваяСтрока.Клиент			= ДанныеКОбработке.Депонент;
	НоваяСтрока.СчетДепо		= ДанныеКОбработке.СчетДепо;
	НоваяСтрока.РазделСчетаДепо = ДанныеКОбработке.РазделСчета;
	ЗаполнитьЗначенияСвойств(НоваяСтрока,ДанныеКОбработке);
	ЗаполнитьЗначенияСвойств(НоваяСтрока,Уведомление);
	
	ОбработкаВебСервисы = Неопределено;
	Если Тестирование Тогда 
		ОбработкаВебСервисы = Обработки.TEST_ВебСервисы.Создать();
	КонецЕсли;
	
	ДокументУведомление = Документы.УведомлениеКлиентам.СоздатьДокумент();
	ДокументУведомление.УстановитьСсылкуНового(Документы.УведомлениеКлиентам.ПолучитьСсылку());
	ДокументУведомление.УстановитьНовыйНомер();	
	ДокументУведомление.Дата = ТекущаяДата();
	ДокументУведомление.Заполнить(КорпоративноеДействиеСсылка);
	ДокументУведомление.ФормаСообщенияКК = Перечисления.ФормыСообщенийКК.СвободнаяФорма;
	ДокументУведомление.ЗаголовокСообщения = Уведомление.Тема;
	ДокументУведомление.ТелоСообщения = Уведомление.Тело;
	ДокументУведомление.ОтправитьУведомление(ОбработкаВебСервисы, ТаблицаКлиентов);
	
	Если ДокументУведомление.Статус = Перечисления.СтатусыУведомленийКлиентам.Отправлено Тогда
		ДокументУведомление.Записать();	
		Возврат Истина;
	Иначе 
		Возврат Ложь;
	КонецЕсли;
		
КонецФункции

Функция ДанныеКОбработке(АмериканскаяЦБ,БизнесПроцесс) Экспорт
	
	СтатусыЗавершения = Новый Массив();
	СтатусыЗавершения.Добавить(Перечисления.СтатусыЗавершенияБПОбработкаWTRCСообщения.Успешно);
	СтатусыЗавершения.Добавить(Перечисления.СтатусыЗавершенияБПОбработкаWTRCСообщения.НеТребуется);

	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Поручение.Депонент КАК Депонент
	|ПОМЕСТИТЬ Поручения1_10
	|ИЗ
	|	Документ.Поручение КАК Поручение
	|ГДЕ
	|	Поручение.КарточкаКД = &КД
	|	И Поручение.ВидОперацииД = &УчастиеВКД
	|	И НЕ Поручение.ПометкаУдаления
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ОбработкаWTRCСообщенияДепоненты.Ссылка КАК Ссылка,
	|	ОбработкаWTRCСообщенияДепоненты.НомерСтроки КАК НомерСтроки,
	|	ОбработкаWTRCСообщенияДепоненты.ЦеннаяБумага КАК ЦеннаяБумага,
	|	ОбработкаWTRCСообщенияДепоненты.Депонент КАК Депонент,
	|	ВЫБОР
	|		КОГДА ОбработкаWTRCСообщенияДепоненты.РазделСчета.РазделСубклиента
