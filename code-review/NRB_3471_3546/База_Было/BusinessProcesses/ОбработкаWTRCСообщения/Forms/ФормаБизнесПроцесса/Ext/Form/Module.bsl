&НаСервере
Процедура ВыделитьНовыеИзмененныеСтрокиДепонентовПослеФиксации()
	ВыделятьСтрокиДепонентовПослеФиксации(ДобавленныеИзмененныеСтрокиДепонентовПослеФиксации());
КонецПроцедуры

&НаСервере
Функция ДобавленныеИзмененныеСтрокиДепонентовПослеФиксации()
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ДепонентыПослеФиксации.ЦеннаяБумага КАК ЦеннаяБумага,
	|	ДепонентыПослеФиксации.Депонент КАК Депонент,
	|	ДепонентыПослеФиксации.РазделСчета КАК РазделСчета,
	|	ДепонентыПослеФиксации.Количество КАК Количество,
	|	ДепонентыПослеФиксации.ЕстьФормаW8BENE_W8BEN КАК ЕстьФормаW8BENE_W8BEN,
	|	ДепонентыПослеФиксации.ЕстьУсловноеДлящеесяПоручение КАК ЕстьУсловноеДлящеесяПоручение
	|ИЗ
	|	БизнесПроцесс.ОбработкаWTRCСообщения.ДепонентыПослеФиксации КАК ДепонентыПослеФиксации
	|	ЛЕВОЕ СОЕДИНЕНИЕ БизнесПроцесс.ОбработкаWTRCСообщения.Депоненты КАК Депоненты
	|	ПО
	|		ДепонентыПослеФиксации.ЦеннаяБумага = Депоненты.ЦеннаяБумага
	|		И ДепонентыПослеФиксации.Депонент = Депоненты.Депонент
	|		И ДепонентыПослеФиксации.РазделСчета = Депоненты.РазделСчета
	|		И ДепонентыПослеФиксации.Количество = Депоненты.Количество
	|		И ДепонентыПослеФиксации.ЕстьФормаW8BENE_W8BEN = Депоненты.ЕстьФормаW8BENE_W8BEN
	|		И ДепонентыПослеФиксации.ЕстьУсловноеДлящеесяПоручение = Депоненты.ЕстьУсловноеДлящеесяПоручение
	|ГДЕ
	|	ДепонентыПослеФиксации.Ссылка = &БизнесПроцесс
	|	И Депоненты.ЦеннаяБумага ЕСТЬ NULL
	|";
	Запрос.УстановитьПараметр("БизнесПроцесс", Объект.Ссылка);
	Возврат Запрос.Выполнить().Выбрать();
	
КонецФункции

&НаСервере
Процедура ВыделятьСтрокиДепонентовПослеФиксации(ВыборкаСтрок)
	ЖирныйШрифт = Новый Шрифт(,, Истина);
	
	ВыборкаСтрок.Сбросить();
	Пока ВыборкаСтрок.Следующий() Цикл
		ЭлементОформления = УсловноеОформление.Элементы.Добавить();
		ЭлементОформления.Использование = Истина;
		ЭлементОформления.Оформление.УстановитьЗначениеПараметра("Шрифт", ЖирныйШрифт);
		
		ПолеЭлемента = ЭлементОформления.Поля.Элементы.Добавить();
		ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(Элементы.ДепонентыПослеФиксации.Имя);

		ДобавитьЭлементУсловия(ЭлементОформления, ВыборкаСтрок, "ЦеннаяБумага");
		ДобавитьЭлементУсловия(ЭлементОформления, ВыборкаСтрок, "Депонент");
		ДобавитьЭлементУсловия(ЭлементОформления, ВыборкаСтрок, "РазделСчета");
		ДобавитьЭлементУсловия(ЭлементОформления, ВыборкаСтрок, "Количество");
		ДобавитьЭлементУсловия(ЭлементОформления, ВыборкаСтрок, "ЕстьФормаW8BENE_W8BEN");
		ДобавитьЭлементУсловия(ЭлементОформления, ВыборкаСтрок, "ЕстьУсловноеДлящеесяПоручение");
	КонецЦикла;
КонецПроцедуры

&НаСервере
Процедура ДобавитьЭлементУсловия(ЭлементОформления, Строка, ИмяПараметра)
	ЭлементУсловия = ЭлементОформления.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ЭлементУсловия.ЛевоеЗначение	= Новый ПолеКомпоновкиДанных("Объект.ДепонентыПослеФиксации." + ИмяПараметра);
	ЭлементУсловия.ВидСравнения		= ВидСравненияКомпоновкиДанных.Равно;
	ЭлементУсловия.ПравоеЗначение	= Строка[ИмяПараметра];
	ЭлементУсловия.Использование	= Истина;
КонецПроцедуры

&НаСервере
Процедура ОбновитьСтатусыОтправкиЗапросовСубброкера()
	ЗначениеОбъекта = РеквизитФормыВЗначение("Объект");
	ЗначениеОбъекта.ОбновитьСтатусыОтправкиЗапросовСубброкера();
	ЗначениеВРеквизитФормы(ЗначениеОбъекта,"Объект");
КонецПроцедуры 

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	Если ИмяСобытия = "Документ.ЗапросСубброкеруНаРаскрытие.Отправлен" Тогда
		Если Параметр = Объект.КДРеференс Тогда 
			ОбновитьСтатусыОтправкиЗапросовСубброкера();
			Если Не Модифицированность Тогда 
				Записать();	
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

