// ОБРАБОТЧИКИ СОБЫТИЙ

&НаСервере
Процедура ОбновитьКартуМаршрутаНаСервере()
	
	Прочитать();
	ТекущийОбъект = РеквизитФормыВЗначение("Объект");
	КартаМаршрута = ТекущийОбъект.ПолучитьКартуМаршрута();
	
КонецПроцедуры

Процедура ОпределитьТипЦБ()
	
	Если ЗначениеЗаполнено(Объект.ЦеннаяБумага1) Тогда 
		ЦБАмериканская1 = Справочники.ЦенныеБумаги.ЦБПодпадаетПодНалоговоеРегулированиеСША(Объект.ЦеннаяБумага1);
	Иначе 
		Элементы.ЦБАмериканская1.Видимость = Ложь;
	КонецЕсли;
	Элементы.ДепонентыОтправитьУведомлениеW8BEN.Доступность = ЦБАмериканская1;	
	Если ЗначениеЗаполнено(Объект.ЦеннаяБумага2) Тогда 
		ЦБАмериканская2 = Справочники.ЦенныеБумаги.ЦБПодпадаетПодНалоговоеРегулированиеСША(Объект.ЦеннаяБумага2);
	Иначе 
		Элементы.ЦБАмериканская2.Видимость = Ложь;
	КонецЕсли; 	

КонецПроцедуры


&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если ЗначениеЗаполнено(Объект.Ссылка) Тогда 
		ИспользоватьСхемуУведомленийWTRC_QI = WTRCСообщенияQI.ИспользоватьСхемуУведомленийWTRC_QI(Объект.Дата);
	Иначе 
		ИспользоватьСхемуУведомленийWTRC_QI = WTRCСообщенияQI.ИспользоватьСхемуУведомленийWTRC_QI();
	КонецЕсли;
	ЗаблокироватьДанныеДляРедактирования(Объект.Ссылка,,ЭтаФорма.УникальныйИдентификатор);
	ОтметитьДепонентовСПоручениямиНаУчастиеВКД();
	ОбновитьКоличествоЦБНаСчетеМХ();
	ОпределитьТипЦБ();
	УправлениеВидимостью(Объект);
	ВыделитьНовыеИзмененныеСтрокиДепонентовПослеФиксации();
	ОбновитьКартуМаршрутаНаСервере();	
	
КонецПроцедуры

&НаСервере
Процедура ПослеЗаписиНаСервере(ТекущийОбъект, ПараметрыЗаписи)
	УправлениеВидимостью(ТекущийОбъект);
КонецПроцедуры

&НаКлиенте
Процедура ДатаПриИзменении(Элемент)
	
	ОбновитьКоличествоЦБНаСчетеМХ();
	
КонецПроцедуры

&НаКлиенте
Процедура ЦеннаяБумага1ПриИзменении(Элемент)
	
	ОпределитьТипЦБ();
	ОбновитьКоличествоЦБНаСчетеМХ();
	
КонецПроцедуры

&НаКлиенте
Процедура СчетДепоМХПриИзменении(Элемент)
	
	ОбновитьКоличествоЦБНаСчетеМХ();
	
КонецПроцедуры

&НаКлиенте
Процедура ДепонентыПриИзменении(Элемент)

	ОтметитьДепонентовСПоручениямиНаУчастиеВКД();
	
КонецПроцедуры
&НаКлиенте
Процедура КДПриИзменении(Элемент)

	ОтметитьДепонентовСПоручениямиНаУчастиеВКД();
	
КонецПроцедуры

///////////////////////////////////////////////////////////////
// СЛУЖЕБНЫЕ ФУНКЦИИ

&НаСервере
Процедура УправлениеВидимостью(Объект)
		
	Если ИспользоватьСхемуУведомленийWTRC_QI ИЛИ НЕ ЦБАмериканская1 Тогда 
		Элементы.ДепонентыЕстьФормаW8BENE_W8BEN.Видимость = Ложь;
		Элементы.ДепонентыПоручение1_10.Видимость = Ложь;
		Элементы.ДепонентыУведомлениеW8.Видимость = Истина;
		Элементы.ДепонентыУведомление1_10.Видимость = Истина;
		Если ЦБАмериканская1 Тогда 
			Элементы.ДепонентыУведомление1_10.Заголовок = "Уведомление о раскрытии субброкеров 2.13";
		КонецЕсли;
		Если ИспользоватьСхемуУведомленийWTRC_QI Тогда 
			Элементы.ДепонентыЗапросНаРаскрытие.Заголовок = "Документ запроса субброкеру на раскрытие";
		КонецЕсли;
		Элементы.ДепонентыЗапросНаРаскрытие.Видимость = Истина;
		Элементы.ДепонентыРазделСчетаПолучатель.Видимость = Ложь;
	Иначе
		УстановитьВидимостьВОбоихТабЧастяхДепонентов("ЕстьФормаW8BENE_W8BEN", Истина);
		УстановитьВидимостьВОбоихТабЧастяхДепонентов("Поручение1_10", Истина);
		УстановитьВидимостьВОбоихТабЧастяхДепонентов("УведомлениеW8", Ложь);
		УстановитьВидимостьВОбоихТабЧастяхДепонентов("Уведомление1_10", Ложь);
		УстановитьВидимостьВОбоихТабЧастяхДепонентов("ЗапросНаРаскрытие", Ложь);
		УстановитьВидимостьВОбоихТабЧастяхДепонентов("РазделСчетаПолучатель", Истина);
		
		ДатаФиксацииСоВременем = Объект.ДатаФиксации;
		ОбщегоНазначения.СкопироватьВремя(ДатаФиксацииСоВременем, '00010101190000');
		Элементы.СтраницаДепонентыПослеФиксации.Видимость = ЗначениеЗаполнено(Объект.ДатаСообщения)
			И ДатаФиксацииСоВременем > Объект.ДатаСообщения;
		Элементы.ДатаСообщения.Видимость = Объект.ИспользоватьСхемуУсловногоДлящегосяПоручения;
	КонецЕсли;
	
	Если Объект.Стартован Тогда
		ЭтаФорма.ТолькоПросмотр = Истина;
		Элементы.ДепонентыЗаполнитьТаблицуДепонентов.Доступность = Ложь;
		Если Элементы.Найти("ФормаСтартИЗакрыть") <> Неопределено Тогда
			Элементы.ФормаСтартИЗакрыть.Видимость = Ложь;
		КонецЕсли;
		Если Элементы.Найти("ФормаСтарт") <> Неопределено Тогда
			Элементы.ФормаСтарт.Видимость = Ложь;
		КонецЕсли;
		Возврат;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура УстановитьВидимостьВОбоихТабЧастяхДепонентов(ИмяПоляДепонентов, ФлагВидимости)
	Элементы["Депоненты" + ИмяПоляДепонентов].Видимость = ФлагВидимости;
	Элементы["ДепонентыПослеФиксации" + ИмяПоляДепонентов].Видимость = ФлагВидимости;
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьТаблицуДепонентов(Команда)
	ЗаполнитьТаблицуДепонентовНаСервере(Команда.Имя);
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьТаблицуДепонентовНаСервере(ИмяКоманды);
	Если ИмяКоманды = "ЗаполнитьТаблицуДепонентов" Тогда
		ИмяТабЧасти = "Депоненты";
	ИначеЕсли ИмяКоманды = "ЗаполнитьТаблицуДепонентовПослеФиксации" Тогда
		ИмяТабЧасти = "ДепонентыПослеФиксации";
	Иначе
		Возврат;
	КонецЕсли;
	ОбъектБП = РеквизитФормыВЗначение("Объект");
	ОбъектБП.ЗаполнитьТаблицуДепонентов(ИмяТабЧасти);
	ЗначениеВРеквизитФормы(ОбъектБП, "Объект");
	ОтметитьДепонентовСПоручениямиНаУчастиеВКД();
КонецПроцедуры

&НаКлиенте
Процедура РедактироватьТаблицу(Команда)
	
	Если Не ЭтаФорма.ТолькоПросмотр Тогда
		Возврат;
	КонецЕсли;
	
	ИсключенныеЭлементы = Новый Массив;
	ИсключенныеЭлементы.Добавить(Элементы.ДепонентыПоручение1_10);
	
	ЭлементыТЧДепоненты = ЗаполнитьПодчиненныеЭлементыТЧ(Новый Массив, Элементы.Депоненты, ИсключенныеЭлементы);
	ЭтаФорма.ТолькоПросмотр = Ложь;

	Для Каждого Элемент Из Элементы Цикл
		Если Элемент = Элементы.Депоненты 
			ИЛИ ЭлементыТЧДепоненты.Найти(Элемент) <> Неопределено 
			ИЛИ ТипЗнч(Элемент) = Тип("КнопкаФормы") 
            ИЛИ ТипЗнч(Элемент) = Тип("ГруппаФормы") Тогда
		Иначе
			Свойства = Новый Структура("ТолькоПросмотр",Истина);
			ЗаполнитьЗначенияСвойств(Элемент,Свойства);
		КонецЕсли;
	КонецЦикла;
	Элементы.ДепонентыЗаполнитьТаблицуДепонентов.Доступность = Истина;
	
КонецПроцедуры

&НаКлиенте
Функция ЗаполнитьПодчиненныеЭлементыТЧ(ЭлементыТЧ, ТекЭлемент, ИсключенныеЭлементы)
	
	Для Каждого Элемент Из ТекЭлемент.ПодчиненныеЭлементы Цикл
		Если ИсключенныеЭлементы.Найти(Элемент) <> Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		ЭлементыТЧ.Добавить(Элемент);
		Если ТипЗнч(Элемент) = Тип("ГруппаФормы") Тогда
			ЭлементыТЧ = ЗаполнитьПодчиненныеЭлементыТЧ(ЭлементыТЧ, Элемент, ИсключенныеЭлементы)
		КонецЕсли;
	КонецЦикла;
	Возврат ЭлементыТЧ;
	
КонецФункции

&НаСервере
Процедура ОтметитьДепонентовСПоручениямиНаУчастиеВКД()
	
	Если НЕ ЦБАмериканская1 Тогда 
		
		Запрос = Новый Запрос(
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	Поручение.Депонент КАК Депонент
		|ИЗ
		|	Документ.Поручение КАК Поручение
		|ГДЕ
		|	Поручение.КарточкаКД = &КД
		|	И Поручение.ВидОперацииД = &УчастиеВКД
		|	И НЕ Поручение.ПометкаУдаления");
		Запрос.УстановитьПараметр("КД", Объект.КД);
		Запрос.УстановитьПараметр("УчастиеВКД", Справочники.ВидыОпераций.УчастиеВКД);
		СписокДепонентов = Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Депонент");
		
		Для Каждого Строка Из Объект.Депоненты Цикл
			Строка.Поручение1_10 = (СписокДепонентов.Найти(Строка.Депонент) <> Неопределено);
		КонецЦикла;
	
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьКоличествоЦБНаСчетеМХ()
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	ОстаткиЦБОстатки.КоличествоОстаток КАК Количество
	|ИЗ
	|	РегистрНакопления.ОстаткиЦБ.Остатки(
	|			&ДатаОстатков,
	|			СчетДепоМХ = &СчетДепоМХ
	|				И ЦБ В (&ЦенныеБумаги)) КАК ОстаткиЦБОстатки
	|");
	Запрос.УстановитьПараметр("ДатаОстатков", Мин(Объект.ДатаФиксации, ТекущаяДата()));
	Запрос.УстановитьПараметр("СчетДепоМХ", Объект.СчетДепоМХ);
	
	ЦенныеБумаги = Новый Массив;
	Если ЗначениеЗаполнено(Объект.ЦеннаяБумага1) Тогда
		ЦенныеБумаги.Добавить(Объект.ЦеннаяБумага1);
	КонецЕсли;
	Если ЗначениеЗаполнено(Объект.ЦеннаяБумага2) Тогда
		ЦенныеБумаги.Добавить(Объект.ЦеннаяБумага2);
	КонецЕсли;	
	
	Запрос.УстановитьПараметр("ЦенныеБумаги", ЦенныеБумаги);
	Выборка = Запрос.Выполнить().Выбрать();
	КоличествоЦБНаСчете = 0;
	Если Выборка.Следующий() Тогда
		КоличествоЦБНаСчете = Выборка.Количество;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьКартуМаршрута(Команда)
	ОбновитьКартуМаршрутаНаСервере();
КонецПроцедуры

&НаСервереБезКонтекста
Функция ЗадачаБизнесПроцесса(БизнесПроцессСсылка, ТочкаМаршрута)
	Возврат БизнесПроцессы.ОбработкаWTRCСообщения.ЗадачаБизнесПроцесса(БизнесПроцессСсылка, ТочкаМаршрута);	
КонецФункции

&НаСервере
Процедура ВыполнитьЗадачуНаСервере(ТочкаМаршрута)
	
	ЗадачаСсылка = ЗадачаБизнесПроцесса(Объект.Ссылка, ТочкаМаршрута);
	Если ЗначениеЗаполнено(ЗадачаСсылка) Тогда
		
		РазблокироватьДанныеДляРедактирования(Объект.Ссылка,ЭтаФорма.УникальныйИдентификатор);
		ЗадачаОбъект = ЗадачаСсылка.ПолучитьОбъект();
		ЗадачаОбъект.ДополнительныеСвойства.Вставить("ИнтерективныйРежим",Истина);
		Если Параметры.Тестирование Тогда 
			ЗадачаОбъект.ДополнительныеСвойства.Вставить("Тестирование",Истина);
		КонецЕсли;
		ЗадачаОбъект.ВыполнитьЗадачу();
		Прочитать();
		ЗаблокироватьДанныеДляРедактирования(Объект.Ссылка,,ЭтаФорма.УникальныйИдентификатор);
		ОбновитьКартуМаршрутаНаСервере();
		
    КонецЕсли;
	
	
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьЗадачу(Команда)
	
	Если ТипЗнч(Элементы.КартаМаршрута.ТекущийЭлемент) = Тип("ЭлементГрафическойСхемыДействие") Тогда 
	
		ТочкаМаршрута = Элементы.КартаМаршрута.ТекущийЭлемент.Значение;
		ЗадачаСсылка = ЗадачаБизнесПроцесса(Объект.Ссылка, ТочкаМаршрута);
		Если ЗначениеЗаполнено(ЗадачаСсылка) Тогда 
			ОткрытьФорму("Задача.ОбработкаWTRCСообщения.ФормаОбъекта", Новый Структура("Ключ",ЗадачаСсылка));
		Иначе 
			Предупреждение("Для этой точки маршрута задча не найдена");
		КонецЕсли;
	
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ВыполнитьЗадачу(Команда)
	
	Если ТипЗнч(Элементы.КартаМаршрута.ТекущийЭлемент) = Тип("ЭлементГрафическойСхемыДействие") Тогда 
	
		ТочкаМаршрута = Элементы.КартаМаршрута.ТекущийЭлемент.Значение;
		ВыполнитьЗадачуНаСервере(ТочкаМаршрута);
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция  РезультатОтправкиУведомленияW8(ДанныеСтроки)
	
	Если Параметры.Тестирование Тогда 
		ОбработкаВебСервисы = Обработки.TEST_ВебСервисы.Создать();
	Иначе 
		ОбработкаВебСервисы = Неопределено;
	КонецЕсли;
	
	АмериканскаяЦБ = (ЦБАмериканская1 ИЛИ ЦБАмериканская2);
	ПовторнаяОтправка = Истина;
	ТаблицаКОбработке = БизнесПроцессы.ОбработкаWTRCСообщения.ДанныеКОбработке(АмериканскаяЦБ, Объект.Ссылка).Выгрузить();
	
	Отбор = Новый Структура("Клиент, РазделСчетаДепо",ДанныеСтроки.Депонент,ДанныеСтроки.РазделСчета);
	СтрокиДепонента = ТаблицаКОбработке.НайтиСтроки(Отбор);
	
	ПолучателиСообщений = Новый Соответствие();
	ДатаПовторнойОтправкиУведомленияW8 = НачалоДня(ТекущаяДатаСеанса());
	УведомлениеW8 = Неопределено;
	УведомленияКОтправке = Новый Соответствие();

	Для Каждого ДанныеКОбработке Из СтрокиДепонента Цикл
		СтрокаТабличнойЧасти = Объект.Депоненты.НайтиСтроки(Новый Структура("НомерСтроки",ДанныеКОбработке.НомерСтроки))[0];
		БизнесПроцессы.ОбработкаWTRCСообщения.ПредоставленаФормаW8(Объект.Ссылка, ДанныеКОбработке, СтрокаТабличнойЧасти, ПолучателиСообщений, ДатаПовторнойОтправкиУведомленияW8, УведомлениеW8, ПовторнаяОтправка, Параметры.Тестирование);
		Если Не УведомлениеW8 = Неопределено Тогда 
			WTRCСообщенияQI.ДобавитьУведомлениеКОтправке(УведомленияКОтправке, УведомлениеW8, ДанныеКОбработке, СтрокаТабличнойЧасти);	
		КонецЕсли;
		Прервать;	
	КонецЦикла;
	
	Если УведомленияКОтправке.Количество() = 0 Тогда 
		Возврат Ложь;
	Иначе
		
		Для Каждого УведомлениеКОтправке Из УведомленияКОтправке Цикл 
			ПараметрыУведомления = УведомлениеКОтправке.Значение;
			Если WTRCСообщенияQI.РезультатСозданияИОтправкиУведомленияКлиентам(Объект.Ссылка, ПараметрыУведомления, ДанныеКОбработке, ОбработкаВебСервисы)  Тогда
				Если УведомлениеW8.Повторное Тогда 
					СтрокаТабличнойЧасти.УведомлениеW8 = Перечисления.СтатусыЗавершенияБПОбработкаWTRCСообщения.ОтправленоПовторно;
				Иначе 
					СтрокаТабличнойЧасти.УведомлениеW8 = Перечисления.СтатусыЗавершенияБПОбработкаWTRCСообщения.Отправлено;
				КонецЕсли;
				СтрокаТабличнойЧасти.НомерОтправленногоУведомления = УведомлениеW8.НомерУведомления;
			Иначе
				СтрокаТабличнойЧасти.УведомлениеW8 = Перечисления.СтатусыЗавершенияБПОбработкаWTRCСообщения.ОшибкаОтправки;
				Возврат Ложь;
			КонецЕсли;
			
			Записать();
			Возврат Истина;
			
		КонецЦикла;
	КонецЕсли;
	
КонецФункции

&НаКлиенте
Процедура ОтправитьУведомлениеW8(Команда)
		
	Если Модифицированность Тогда 
		Если Вопрос("Перед отправкой уведомления нужно сохранить изменения. Сохранить и продолжить?",РежимДиалогаВопрос.ОКОтмена) = КодВозвратаДиалога.ОК Тогда 
			Записать();
		Иначе 
			Возврат;
		КонецЕсли;
	КонецЕсли;
	
	Если Команда.Имя = "ОтправитьУведомлениеW8" Тогда
		ДанныеТекущейСтроки =  Элементы.Депоненты.ТекущиеДанные;
	ИначеЕсли Команда.Имя = "ОтправитьУведомлениеW8ПослеФиксации" Тогда
		ДанныеТекущейСтроки =  Элементы.ДепонентыПослеФиксации.ТекущиеДанные;
	Иначе
		Возврат;
	КонецЕсли;
	
	Если ДанныеТекущейСтроки.УведомлениеW8 = ПредопределенноеЗначение("Перечисление.СтатусыЗавершенияБПОбработкаWTRCСообщения.Успешно")
		ИЛИ ДанныеТекущейСтроки.УведомлениеW8 = ПредопределенноеЗначение("Перечисление.СтатусыЗавершенияБПОбработкаWTRCСообщения.НеТребуется") Тогда 
		Предупреждение("Отправка уведомления W8 не требуется");
		Возврат;
	КонецЕсли;
	
	ДанныеСтроки = Новый Структура("Депонент, ЦеннаяБумага, РазделСчета, ЦеннаяБумага, Количество");
	ЗаполнитьЗначенияСвойств(ДанныеСтроки, ДанныеТекущейСтроки);
	Если РезультатОтправкиУведомленияW8(ДанныеСтроки) Тогда 
		Предупреждение("Уведомление успешно отправлено");
	ИначеЕсли ДанныеТекущейСтроки.УведомлениеW8 = ПредопределенноеЗначение("Перечисление.СтатусыЗавершенияБПОбработкаWTRCСообщения.Успешно")
		ИЛИ ДанныеТекущейСтроки.УведомлениеW8 = ПредопределенноеЗначение("Перечисление.СтатусыЗавершенияБПОбработкаWTRCСообщения.НеТребуется") Тогда 
		Предупреждение("Отправка уведомления W8 не требуется");
	Иначе
		Предупреждение("Уведомление не отправлено");
	КонецЕсли;

	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	Если Параметры.Тестирование Тогда 
		Элементы.НомерОтправленногоУведомления.Видимость = Истина;
		Элементы.ВыполненаПроверкаОстатков.ТолькоПросмотр = Ложь;
		ЭтаФорма.Доступность = Истина;
		ЭтаФорма.ТолькоПросмотр = Ложь;
		Элементы.ВыполненаПроверкаОстатков.Вид = ВидПоляФормы.ПолеФлажка;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура УведомленияКлиентам(Команда)
	
	Отбор = Новый Структура("ДокументОснование",Объект.КД);
	ПараметрыОткрытия = Новый Структура("Отбор",Отбор);
	ОткрытьФорму("Документ.УведомлениеКлиентам.Форма.ФормаСписка",ПараметрыОткрытия);
	
КонецПроцедуры

&НаКлиенте
Процедура УведомленияОтправленныеВКабинетКлиента(Команда)
	
	ФормаСписка = ПолучитьФорму("РегистрСведений.УведомленияОтправленныеЧерезЛичныйКабинет.ФормаСписка");
	ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(ФормаСписка.Список,"КД.ДокументОснование",
	                                                                        Объект.КД,
																			ВидСравненияКомпоновкиДанных.Равно,
																			Неопределено,
																			Истина);
	ФормаСписка.Открыть();
																			
	
КонецПроцедуры

