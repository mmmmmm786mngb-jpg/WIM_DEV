#Область ЭкспортныеПроцедурыИФункции

// Определяет есть ли у данного контрагента действующие депозитарные или междепозитарные договоры
// Параметры:
//	Клиент - СправочникСсылка.Контрагенты
// Возвращаемое значение:
//	Булево
Функция ЯвляетсяДепонентом(Клиент) Экспорт
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	1 КАК Поле
	|ИЗ
	|	Справочник.ДоговорыКонтрагентов КАК ДоговорыКонтрагентов
	|ГДЕ
	|	ДоговорыКонтрагентов.Владелец = &Клиент
	|	И ДоговорыКонтрагентов.ТипДоговора В (&ТипыДоговоровДепонента)
	|	И (ДоговорыКонтрагентов.ДатаОкончанияДействия = ДАТАВРЕМЯ(1, 1, 1)
	|		ИЛИ ДоговорыКонтрагентов.ДатаОкончанияДействия > &ТекущаяДата)
	|	И НЕ ДоговорыКонтрагентов.ПометкаУдаления
	|";
	Запрос.УстановитьПараметр("Клиент", Клиент);
	Запрос.УстановитьПараметр("ТекущаяДата", НачалоДня(ТекущаяДатаСеанса()) );
	Запрос.УстановитьПараметр("ТипыДоговоровДепонента", ТипыДоговоровДепонента());
	
	Возврат НЕ Запрос.Выполнить().Пустой();
КонецФункции

// (Устаревшая) Возвращает ClientId данного клиента используемый в СУДК
// Параметры:
//	Клиент - СправочникСсылка.Контрагенты
// Возвращаемое значение:
//	Строка
Функция ClientId(Клиент) Экспорт
	ClientId = Неопределено;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	КодыЗагрузкиКлиента.Код КАК ClientId
	|ИЗ
	|	Справочник.КодыЗагрузки КАК КодыЗагрузкиКлиента
	|ГДЕ
	|	КодыЗагрузкиКлиента.Владелец = &Клиент
	|	И НЕ КодыЗагрузкиКлиента.ПометкаУдаления
	|	И КодыЗагрузкиКлиента.Биржа = ЗНАЧЕНИЕ(Справочник.КлассификаторыЗагрузки.Клиенты)
	|	И (КодыЗагрузкиКлиента.ДатаОкончанияДействия = ДАТАВРЕМЯ(1,1,1)
	|		ИЛИ КодыЗагрузкиКлиента.ДатаОкончанияДействия > &ТекущаяДата)
	|";
	Запрос.УстановитьПараметр("Клиент", Клиент);
	Запрос.УстановитьПараметр("ТекущаяДата", ТекущаяДатаСеанса());
	РезультатЗапроса = Запрос.Выполнить();
	Если Не РезультатЗапроса.Пустой() Тогда
		Выборка = РезультатЗапроса.Выбрать();
		Выборка.Следующий();
		ClientId = Выборка.ClientId;
	КонецЕсли;
	
	Возврат ClientId;
КонецФункции

// (Устаревшая) Возвращает клиента по ClientId
// Параметры:
//	ClientId - Строка
// Возвращаемое значение:
//	СправочникСсылка.Контрагенты - или неопределено если не удалось найти клиента
Функция КлиентПоClientId(ClientId) Экспорт
	Клиент = Неопределено;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	КодыЗагрузки.Владелец КАК Клиент
	|ИЗ
	|	Справочник.КодыЗагрузки КАК КодыЗагрузки
	|ГДЕ
	|	КодыЗагрузки.Код = &ClientId
	|	И КодыЗагрузки.Владелец ССЫЛКА Справочник.Контрагенты
	|	И КодыЗагрузки.Биржа = ЗНАЧЕНИЕ(Справочник.КлассификаторыЗагрузки.Клиенты)
	|	И НЕ КодыЗагрузки.ПометкаУдаления
	|	И (КодыЗагрузки.ДатаОкончанияДействия = ДАТАВРЕМЯ(1, 1, 1)
	|			ИЛИ КодыЗагрузки.ДатаОкончанияДействия > &ТекущаяДата)";
	Запрос.УстановитьПараметр("ClientId", ClientId);
	Запрос.УстановитьПараметр("ТекущаяДата", НачалоДня(ТекущаяДатаСеанса()));
	РезультатЗапроса = Запрос.Выполнить();
	Если Не РезультатЗапроса.Пустой() Тогда
		Выборка = РезультатЗапроса.Выбрать();
		Выборка.Следующий();
		Клиент = Выборка.Клиент;
	КонецЕсли;
	
	Возврат Клиент;
КонецФункции

// Возвращает клиента по Коду
// Параметры:
//	Код - Строка
// Возвращаемое значение:
//	Контрагент - СправочникСсылка.Контрагенты - или неопределено, если не удалось найти контрагента
Функция КонтрагентПоКоду(Код) Экспорт
	Контрагент = Неопределено;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	Контрагенты.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.Контрагенты КАК Контрагенты
	|ГДЕ
	|	Контрагенты.Код = &Код";
	Запрос.УстановитьПараметр("Код", Код);
	РезультатЗапроса = Запрос.Выполнить();
	Если Не РезультатЗапроса.Пустой() Тогда
		Выборка = РезультатЗапроса.Выбрать();
		Выборка.Следующий();
		Контрагент = Выборка.Ссылка;
	КонецЕсли;
	
	Возврат Контрагент;
КонецФункции

// Возвращает массив типов договоров депонента
//
// Возвращаемое значение:
//	Массив
Функция ТипыДоговоровДепонента() Экспорт
	ТипыДоговоровДепонента = Новый Массив;
	
	ТипыДоговоровДепонента.Добавить(Перечисления.ТипыДоговоров.Депозитарный);
	ТипыДоговоровДепонента.Добавить(Перечисления.ТипыДоговоров.МежДепозитарный);
	
	Возврат ТипыДоговоровДепонента;
КонецФункции

// Возвращает Контрагента по юр. физ. лицу
//
// Параметры:
//  ЮридическиеФизическиеЛица	 - СправочникСсылка.ЮридическиеЛица, СправочникСсылка.ФизическиеЛица - ссылка на юр. физ. лицо
//  ПриоритетЭмитентов			 - Булево	 - Если найдено несколько контрагентов, то приоритет для того который в папке Эмитенты
// 
// Возвращаемое значение:
//   - СправочникСсылка.Контрагент - Найденный контрагент. Если не найдено - то пустая ссылка.
//
Функция КонтрагентПоЮрФизЛицу(ЮридическиеФизическиеЛица, Знач ПриоритетЭмитентов = Неопределено) Экспорт
	
	Если ПриоритетЭмитентов = Неопределено Тогда
		Если ТипЗнч(ЮридическиеФизическиеЛица) = Тип("СправочникСсылка.ФизическиеЛица") Тогда
			ПриоритетЭмитентов = Ложь;
		Иначе
			ПриоритетЭмитентов = Истина;
		КонецЕсли;
	КонецЕсли;
	
	Контрагент = Справочники.Контрагенты.ПустаяСсылка();
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ВЫБОР
	|		КОГДА Контрагенты.Родитель = &Эмитенты
	|			ТОГДА &ПриоритетЭмитентов
	|		ИНАЧЕ НЕ &ПриоритетЭмитентов
	|	КОНЕЦ КАК Приоритет,
	|	Контрагенты.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.Контрагенты КАК Контрагенты
	|ГДЕ
	|	НЕ Контрагенты.ПометкаУдаления
	|	И Контрагенты.ЮридическиеФизическиеЛица = &ЮридическиеФизическиеЛица
	|
	|УПОРЯДОЧИТЬ ПО
	|	Приоритет УБЫВ";
	
	Запрос.УстановитьПараметр("ПриоритетЭмитентов", ПриоритетЭмитентов);
	Запрос.УстановитьПараметр("ЮридическиеФизическиеЛица", ЮридическиеФизическиеЛица);
	Запрос.УстановитьПараметр("Эмитенты", Справочники.Контрагенты.Эмитенты);
	
	РезультатЗапроса = Запрос.Выполнить();
	Если Не РезультатЗапроса.Пустой() Тогда
		ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
		ВыборкаДетальныеЗаписи.Следующий();
		Контрагент = ВыборкаДетальныеЗаписи.Ссылка;
	КонецЕсли;
	
	Возврат Контрагент;
	
КонецФункции

// Возвращает клиента по CrmContractNumber
// Параметры:
//	CrmContractNumber - Строка - Номер договора из CRM
// Возвращаемое значение:
//	СправочникСсылка.Контрагенты - или неопределено если не удалось найти клиента
Функция КлиентПоCrmContractNumber(CrmContractNumber) Экспорт
	Клиент = Неопределено;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	КодыЗагрузки.Владелец КАК Клиент
	|ИЗ
	|	Справочник.КодыЗагрузки КАК КодыЗагрузки
	|ГДЕ
	|	КодыЗагрузки.Код = &CrmContractNumber
	|	И КодыЗагрузки.Владелец ССЫЛКА Справочник.Контрагенты
	|	И КодыЗагрузки.Биржа = ЗНАЧЕНИЕ(Справочник.КлассификаторыЗагрузки.CrmContractNumber)
	|	И НЕ КодыЗагрузки.ПометкаУдаления
	|	И ВЫБОР
	|			КОГДА КодыЗагрузки.ДатаОкончанияДействия = ДАТАВРЕМЯ(1, 1, 1)
	|				ТОГДА ИСТИНА
	|			КОГДА КодыЗагрузки.ДатаОкончанияДействия > &ТекущаяДата
	|				ТОГДА ИСТИНА
	|			ИНАЧЕ ЛОЖЬ
	|		КОНЕЦ";
	Запрос.УстановитьПараметр("CrmContractNumber", CrmContractNumber);
	Запрос.УстановитьПараметр("ТекущаяДата", НачалоДня(ТекущаяДатаСеанса()));
	РезультатЗапроса = Запрос.Выполнить();
	Если Не РезультатЗапроса.Пустой() Тогда
		Выборка = РезультатЗапроса.Выбрать();
		Выборка.Следующий();
		Клиент = Выборка.Клиент;
	КонецЕсли;
	
	Возврат Клиент;
КонецФункции

// Возвращает признак эмитента по юр. физ. лицу
//
// Параметры:
//  ЮридическиеФизическиеЛица	 - СправочникСсылка.ЮридическиеЛица, СправочникСсылка.ФизическиеЛица - ссылка на юр. физ. лицо
// 
// Возвращаемое значение:
//   - Булево - Истина, если это только эмитент
//
Функция ЯвляетсяЭмитентом(ЮридическиеФизическиеЛица) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	ЕСТЬNULL(МИНИМУМ(Контрагенты.Родитель = &Эмитенты), ЛОЖЬ) КАК ЭтоЛицоЭмитент
	|ИЗ
	|	Справочник.Контрагенты КАК Контрагенты
	|ГДЕ
	|	НЕ Контрагенты.ПометкаУдаления
	|	И Контрагенты.ЮридическиеФизическиеЛица = &ЮридическиеФизическиеЛица";
	
	Запрос.УстановитьПараметр("ЮридическиеФизическиеЛица", ЮридическиеФизическиеЛица);
	Запрос.УстановитьПараметр("Эмитенты", Справочники.Контрагенты.Эмитенты);
	
	РезультатЗапроса = Запрос.Выполнить();
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	ВыборкаДетальныеЗаписи.Следующий();
	Возврат ВыборкаДетальныеЗаписи.ЭтоЛицоЭмитент;
	
КонецФункции

// Функция - Является контрагентом
// Проверяет является ли клиент контрагентом
