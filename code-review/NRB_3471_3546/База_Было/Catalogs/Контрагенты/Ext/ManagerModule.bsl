//  Клиент	 - СправочникСсылка.Контрагенты - Клиент
// 
// Возвращаемое значение:
//   - Булево - Истина, если это Контрагент
//
Функция ЯвляетсяКонтрагентом(Клиент) Экспорт
	
	Возврат Клиент.ПринадлежитЭлементу(Справочники.Контрагенты.НайтиПоКоду("Контрагент"));
	
КонецФункции

// Возвращает Контрагентов по юр. физ. лицу \ лицам
//
// Параметры:
//  ЮридическиеФизическиеЛица	 - Массив, СправочникСсылка.ЮридическиеЛица, СправочникСсылка.ФизическиеЛица - массив\ссылка на юр. физ. лицо
//  КромеКонтрагентов			 - Массив - Контрагенты или группы контрагентов, исключаемые из поиска
// 
// Возвращаемое значение:
//   - Массив - Найденные контрагенты.
//
Функция КонтрагентыПоЮрФизЛицам(ЮридическиеФизическиеЛица, КромеКонтрагентов = Неопределено) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Контрагенты.Ссылка КАК Контрагент
	|ИЗ
	|	Справочник.Контрагенты КАК Контрагенты
	|ГДЕ
	|	НЕ Контрагенты.ПометкаУдаления
	|	И ВЫБОР
	|			КОГДА &ПоВсемКонтрагентам
	|				ТОГДА ИСТИНА
	|			ИНАЧЕ НЕ Контрагенты.Ссылка В ИЕРАРХИИ (&КромеКонтрагентов)
	|		КОНЕЦ
	|	И Контрагенты.ЮридическиеФизическиеЛица В(&ЮридическиеФизическиеЛица)";
	
	Если ЗначениеЗаполнено(КромеКонтрагентов) Тогда
		Запрос.УстановитьПараметр("ПоВсемКонтрагентам", Ложь);
	Иначе
		Запрос.УстановитьПараметр("ПоВсемКонтрагентам", Истина);
	КонецЕсли;
	Запрос.УстановитьПараметр("КромеКонтрагентов", КромеКонтрагентов);
	Если ТипЗнч(ЮридическиеФизическиеЛица) = Тип("Массив") Тогда
		Запрос.УстановитьПараметр("ЮридическиеФизическиеЛица", ЮридическиеФизическиеЛица);
	Иначе
		Запрос.УстановитьПараметр("ЮридическиеФизическиеЛица", ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(ЮридическиеФизическиеЛица));
	КонецЕсли;
	
	Контрагенты = Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Контрагент");
	
	Возврат Контрагенты;
	
КонецФункции

// Функция - Эмитенты ценных бумаг
// Возвращает массив эмитентов передаваемых ценных бумаг
// Параметры:
//  ЦенныеБумаги - Массив, СправочникСсылка.ЦенныеБумаги - Массив ценных бумаг по которым надо определить эмитента
// 
// Возвращаемое значение:
//   - Массив, СправочникСсылка.Контрагенты
//
Функция ЭмитентыЦенныхБумаг(ЦенныеБумаги) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ЦенныеБумаги.Эмитент КАК Эмитент
	|ИЗ
	|	Справочник.ЦенныеБумаги КАК ЦенныеБумаги
	|ГДЕ
	|	ЦенныеБумаги.Ссылка В(&ЦенныеБумаги)";
	Запрос.УстановитьПараметр("ЦенныеБумаги", ЦенныеБумаги);
	
	Возврат Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Эмитент");
	
КонецФункции

// Возвращает клиента по CrmContractNumber
// Параметры:
//	Клиент - СправочникСсылка.Контрагенты
// Возвращаемое значение:
//	Строка - Номер договора из CRM или неопределено если не удалось найти CrmContractNumber
Функция CrmContractNumberПоКлиенту(Клиент) Экспорт
	CrmContractNumber = Неопределено;
	
	Если ЗначениеЗаполнено(Клиент) Тогда
		Запрос = Новый Запрос;
		Запрос.Текст =
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	КодыЗагрузки.Код КАК CrmContractNumber
		|ИЗ
		|	Справочник.КодыЗагрузки КАК КодыЗагрузки
		|ГДЕ
		|	КодыЗагрузки.Владелец = &Клиент
		|	И КодыЗагрузки.Биржа = ЗНАЧЕНИЕ(Справочник.КлассификаторыЗагрузки.CrmContractNumber)
		|	И НЕ КодыЗагрузки.ПометкаУдаления
		|	И ВЫБОР
		|			КОГДА КодыЗагрузки.ДатаОкончанияДействия = ДАТАВРЕМЯ(1, 1, 1)
		|				ТОГДА ИСТИНА
		|			КОГДА КодыЗагрузки.ДатаОкончанияДействия > &ТекущаяДата
		|				ТОГДА ИСТИНА
		|			ИНАЧЕ ЛОЖЬ
		|		КОНЕЦ";
		Запрос.УстановитьПараметр("Клиент", Клиент);
		Запрос.УстановитьПараметр("ТекущаяДата", НачалоДня(ТекущаяДатаСеанса()));
		РезультатЗапроса = Запрос.Выполнить();
		Если Не РезультатЗапроса.Пустой() Тогда
			Выборка = РезультатЗапроса.Выбрать();
			Выборка.Следующий();
			CrmContractNumber = Выборка.CrmContractNumber;
		КонецЕсли;
	КонецЕсли;
	
	Возврат CrmContractNumber;
КонецФункции

// Функция возвращает настройки для отправки отчетов в Kafka по заданному способу отправки
//
// Параметры:
//  СпособОтправкиОтчетов	 - ПеречислениеСсылка.СпособыОтправкиОтчетов - Способ отправки отчетов
// 
// Возвращаемое значение:
//  Структура:
//      * Сущность - Строка - сущность для передачи в Kafka
//      * ВнешнийИсточник - ПланыВидовХарактеристикСсылка.ВнешниеИсточники - топик для передачи в Kafka
//
Функция НастройкиОтправкиОтчетовПоСпособуОтправки(СпособОтправкиОтчетов) Экспорт
	НастройкиОтправкиОтчетов = Новый Структура("Сущность, ВнешнийИсточник");
	Если ЗначениеЗаполнено(СпособОтправкиОтчетов) Тогда
		Если СпособОтправкиОтчетов = Перечисления.СпособыОтправкиОтчетов.EmailКлиента Тогда
			НастройкиОтправкиОтчетов.Сущность = "Email";
			НастройкиОтправкиОтчетов.ВнешнийИсточник = ПланыВидовХарактеристик.ВнешниеИсточники.KafkaEmail;
		ИначеЕсли СпособОтправкиОтчетов = Перечисления.СпособыОтправкиОтчетов.EmailCustody Тогда
			НастройкиОтправкиОтчетов.Сущность = "EmailGen";
			НастройкиОтправкиОтчетов.ВнешнийИсточник = ПланыВидовХарактеристик.ВнешниеИсточники.KafkaEmailGen;
		ИначеЕсли СпособОтправкиОтчетов = Перечисления.СпособыОтправкиОтчетов.МП Тогда
			НастройкиОтправкиОтчетов.Сущность = "Document";
			НастройкиОтправкиОтчетов.ВнешнийИсточник = ПланыВидовХарактеристик.ВнешниеИсточники.KafkaFileExchangeIn;
		Иначе
			ВызватьИсключение "Не удалось определить настройки отправки отчетов по способу отправки!";
		КонецЕсли;
	Иначе
		ВызватьИсключение "Не заполнен ""Способ отправки отчетов""!";
	КонецЕсли;
	Возврат НастройкиОтправкиОтчетов;
КонецФункции

// Функция - Особые условия
//
// Параметры:
//  Контрагент	 - СправочникСсылка.Контрагенты, Массив - Контрагент
//  ВозвращатьМассивКонтрагентов - Булево - Возвращать массив клиентов с ограничениями или просто булево что они есть
// 
// Возвращаемое значение:
//   - Булево, Массив - Истина, если у Контрагента особые условия или Массив Справочник.Контрагенты с особыми условиями
//
Функция ОсобыеУсловия(Контрагент, ВозвращатьМассивКонтрагентов = Ложь) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Контрагенты.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.Контрагенты КАК Контрагенты
	|ГДЕ
	|	Контрагенты.Ссылка В(&Ссылка)
	|	И Контрагенты.ЮридическиеФизическиеЛица.ОсобыеУсловия";
	
	Запрос.УстановитьПараметр("Ссылка", Контрагент);
	Выборка = Запрос.Выполнить().Выбрать();
	
	ОсобыеКонтрагенты = Новый Массив;
	Пока Выборка.Следующий() Цикл
		ОсобыеКонтрагенты.Добавить(Выборка.Ссылка);
	КонецЦикла;
	
	Если ВозвращатьМассивКонтрагентов Тогда
		Возврат ОсобыеКонтрагенты;
	Иначе
		Возврат ОсобыеКонтрагенты.Количество() > 0;
	КонецЕсли;
	
КонецФункции

// Функция возвращает ссылку на группу Контрагенты
// Возвращаемое значение:
//	- СправочникСсылка.Контрагенты
Функция ГруппаКонтрагенты() Экспорт
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	Контрагенты.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.Контрагенты КАК Контрагенты
	|ГДЕ
	|	Контрагенты.ЭтоГруппа
	|	И Контрагенты.Наименование = ""Контрагенты""
	|	И НЕ Контрагенты.ПометкаУдаления";
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		ГруппаКонтрагенты = Выборка.Ссылка;
	Иначе
		ОписаниеОшибки = "В справочнике Депоненты/Контрагенты не удалось найти группу с названием ""Контрагенты""";
		ЗаписьЖурналаРегистрации("Поиск группы ""Контрагенты""", УровеньЖурналаРегистрации.Ошибка, , , ОписаниеОшибки);
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ОписаниеОшибки);
		ГруппаКонтрагенты = Неопределено;
	КонецЕсли;
	
	Возврат ГруппаКонтрагенты;
КонецФункции

#КонецОбласти