//#Область ОписаниеПеременных

&НаСервере
Перем мТекущийОбъектНаСервере;

&НаКлиенте
Перем мФормироватьНаименованиеПолноеАвтоматически;

//#КонецОбласти 

//#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	                                          
	КонтактнаяИнформацияСервер.ПриСозданииНаСервере(ЭтаФорма, "ЮридическиеФизическиеЛица");
	НастроитьЭлементыПриСозданииНаСервере();
	НастроитьФорму();		
		
	ВерсионированиеОбъектов.ПриСозданииНаСервере(ЭтаФорма);	
	КИПоЗакону = РегистрыСведений.РеестрКвалифицированныхИнвесторовПоЗакону.ЕстьКИПОЗакону(Объект.ЮридическиеФизическиеЛица, ТекущаяДата());
	
	ПредЮрФизЛицо = Объект.ЮрФизЛицо;
	
	ЗаполнитьФормуW8();
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	УстановитьФлагФормироватьНаименованиеПолноеАвтоматически();
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаВыбора(ВыбранноеЗначение, ИсточникВыбора)
	Если ТипЗнч(ВыбранноеЗначение) = Тип("Строка") Тогда
		Если ВыбранноеЗначение = "ОбновлениеКонтактнойИнформации" Тогда
			ОбновитьТелефоныКонтактногоЛица();
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	Если ИмяСобытия = "ОбновленыПредоставленныеДокументы" Тогда
		//ПрочитатьНаборЗаписейНаСервере("НаборПредоставленныеДокументы", "Депонент", Объект.Ссылка);
		УстановитьОтборПредоставленныеДокументы(ЭтаФорма);
		//УстановитьОтборСписка(ПредоставленныеДокументы, Объект.Ссылка, "Депонент");
		ЗаполнитьФормуW8();
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура ПриЧтенииНаСервере(ТекущийОбъект)
	ПрочитатьНаборыЗаписейНаСервере(ТекущийОбъект);
	КатегорияРолиКлиентаСогласноУказов81и95 =
		РегистрыСведений.КатегорииРолейКлиентовСогласноУказов81и95.КатегорияРолиКлиента(Объект.Ссылка);
	ОтобразитьНаличиеСчетовТипаC();
КонецПроцедуры

&НаКлиенте
Процедура ПередЗаписью(Отказ, ПараметрыЗаписи)
	Если Не ЗначениеЗаполнено(Объект.ГоловнойКонтрагент) Тогда
		Объект.ГоловнойКонтрагент = Объект.Ссылка;
	КонецЕсли;
	
	ЭтоФизЛицо = Объект.ЮрФизЛицо = ЮрФизЛицо("ФизЛицо");
	Если ЭтоФизЛицо И Не ЗначениеЗаполнено(Объект.ЮридическиеФизическиеЛица) Тогда
		Отказ = Истина;
		Сообщить("Не заполнено поле Физ. лицо"); 
	КонецЕсли; 
	
	// Проверка на заполненость поля - Получатель
	ЭтоБезнал = Объект.ФормаВыплатыДоходов = ЗначениеПеречисления("ФормыВыплатыДоходовПоЦБ", "Безналичная");
	Если ЭтоБезнал И Не ЗначениеЗаполнено(Объект.Получатель) Тогда
		Отказ = Истина;
		Сообщить("Не заполнено поле Получатель при выборе формы выплаты доходов - безналичная"); 
	КонецЕсли; 

КонецПроцедуры

&НаСервере
Процедура ПередЗаписьюНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	
	ДопСвойства = Новый Структура("НеПерезаполнятьРегионДляОтчетов", Истина);
	КонтактнаяИнформацияСервер.ПриЗаписиНаСервере(ЭтотОбъект, ТекущийОбъект, Отказ, ДопСвойства);
	
	ПерезаполнятьРегион = Ложь;
	Если Не ТекущийОбъект.Резидент Тогда
		// Как ни странно это ветка для резидентов т.к. ТекущийОбъект.Резидент означет Нерезидент (по документам) бу-ха-ха
		Для каждого Запись Из НаборКонтактнаяИнформация Цикл
			Если Справочники.КлассификаторРегионов.МожноОпределитьРегионПоКонтактнойИнформации(Запись) Тогда
				ПерезаполнятьРегион = Истина;
				Прервать;
			КонецЕсли;
		КонецЦикла;
	Иначе
		// Это ветка для нерезидентов
		ПерезаполнятьРегион = Истина;
	КонецЕсли;
		
	Если ПерезаполнятьРегион Тогда
		ТекущийОбъект.ДополнительныеСвойства.Вставить("ПерезаполнятьРегионДляОтчетов", Истина);
	КонецЕсли;
	
	Если Объект.Родитель = Справочники.Контрагенты.Депоненты И Не ЗначениеЗаполнено(Объект.СпособОтправкиОтчетов) Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не заполнен ""Способ отправки отчетов""", , , "Объект.СпособОтправкиОтчетов");
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура ПриЗаписиНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	
	ЗаписатьНаборыЗаписейНаСервере(Отказ, ТекущийОбъект);
	
КонецПроцедуры

&НаСервере
Процедура ПослеЗаписиНаСервере(ТекущийОбъект, ПараметрыЗаписи)
	УстановитьДоступностьДинамическихСписков();		
	УстановитьОтборыДинамическихСписков(ЭтаФорма);

КонецПроцедуры

