	Если ДанныеСтроки <> Неопределено Тогда
		ПараметрыЗаполнения = Новый Структура("Период, Лицо, Депонент,ВидДокумента,СрокДействия,"
			+ "ДатаПредоставления,Примечание,ПредоставленнаяФорма");
		ЗаполнитьЗначенияСвойств(ПараметрыЗаполнения, ДанныеСтроки);
		ПараметрыЗаполнения.Депонент = Объект.Ссылка;
		ПараметрыЗаполнения.Лицо = Объект.ЮридическиеФизическиеЛица;
		СтруктураЗаполнения =  Новый Структура("ЗначенияЗаполнения", ПараметрыЗаполнения);
		ОткрытьФорму("РегистрСведений.ПредоставленныеДокументы.ФормаЗаписи", СтруктураЗаполнения, , Новый УникальныйИдентификатор);
	КонецЕсли;
