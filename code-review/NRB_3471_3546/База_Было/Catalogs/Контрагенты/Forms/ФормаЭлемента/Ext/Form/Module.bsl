&НаСервере
Процедура ЗаполнитьФормуW8()
	
	Если ЗначениеЗаполнено(Объект.Ссылка) Тогда
		
		ДанныеПоследнейФормыW8 = Справочники.ФормыW8.ДанныеПоследнейФормыW8(Объект.Ссылка);
		СсылкаНаФормуW8 = ДанныеПоследнейФормыW8.ФормаW8;
		Если ЗначениеЗаполнено(СсылкаНаФормуW8) И ЗначениеЗаполнено(Объект.ЮридическиеФизическиеЛица) Тогда
			
			ФормаW8 = СсылкаНаФормуW8;
			
			Если ДанныеПоследнейФормыW8.ЕстьПересеченияПоСрокамСдругимиФормами Тогда
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ДанныеПоследнейФормыW8.ТекстОшибки);
			КонецЕсли;
			
			Если ЗначениеРеквизитаОбъекта(СсылкаНаФормуW8,"СрокДействия") < ТекущаяДатаСеанса() Тогда
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Текущая форма W8 просрочена!");
			КонецЕсли;
			
			Если ТипЗнч(ФормаW8.Лицо) = Тип("СправочникСсылка.ЮридическиеЛица") Тогда
				Элементы.ГруппаW8.ТекущаяСтраница = Элементы.ГруппаПредоставленнаяФормаW8ЮрЛица;
			Иначе
				Элементы.ГруппаW8.ТекущаяСтраница = Элементы.ГруппаПредоставленнаяФормаW8ФизЛица;
			КонецЕсли;
			
		Иначе
			
			ФормаW8 = Справочники.ФормыW8.ПустаяСсылка();
			
		КонецЕсли;
		
	КонецЕсли;
	
	Элементы.СтраницаW8.Доступность = ЗначениеЗаполнено(ФормаW8);
	
КонецПроцедуры

