&НаСервере
Процедура ЗаписатьНаборыЗаписейНаСервере(Отказ, ТекущийОбъект)	
	ЗначениеОтбора = ТекущийОбъект.Ссылка;
	
	ЗаписатьНаборЗаписейНаСервере("НаборДоверенныеЛица", "Депонент", ЗначениеОтбора, Отказ);	
	ЗаписатьНаборЗаписейНаСервере("НаборСубклиенты", "Объект", ЗначениеОтбора, Отказ);		
КонецПроцедуры

&НаСервере
Процедура ПрочитатьНаборыЗаписейНаСервере(ТекущийОбъект)	
	ЗначениеОтбора = ТекущийОбъект.Ссылка;
	ЗначениеОтбораКИ = ТекущийОбъект.ЮридическиеФизическиеЛица;

	ПрочитатьНаборЗаписейНаСервере("НаборДоверенныеЛица", "Депонент", ЗначениеОтбора);	
	ПрочитатьНаборЗаписейНаСервере("НаборСубклиенты", "Объект", ЗначениеОтбора);		
	НаборРеестрКвалИнвесторов.Параметры.УстановитьЗначениеПараметра("ЮрФизЛицо", ЗначениеОтбораКИ);
	
КонецПроцедуры

&НаСервере
Процедура ЗаписатьНаборЗаписейНаСервере(ИмяЭлемента, ИмяПоля, ЗначениеОтбора, Отказ)
	
	Если Отказ Тогда
		Возврат;		
	КонецЕсли; 
	
	НаборЗначение = РеквизитФормыВЗначение(ИмяЭлемента);
	НаборЗначение.Отбор[ИмяПоля].Установить(ЗначениеОтбора);
	Для каждого ЗаписьНабора Из НаборЗначение Цикл
		ЗаписьНабора[ИмяПоля] = ЗначениеОтбора;		
	КонецЦикла; 
	
	Попытка
		НаборЗначение.Записать();
	Исключение
		МетаНабор = НаборЗначение.Метаданные();
		
		ОписаниеОшибки = ОписаниеОшибки();
		ОбщегоНазначения.СообщитьОбОшибке(ОписаниеОшибки
			, Отказ
			, "Элемент """ + СокрЛП(ЗначениеОтбора) + """ не записан. Не записан набор "+ МетаНабор.Синоним +".");			
	КонецПопытки;
			
КонецПроцедуры

&НаСервере
Процедура ПрочитатьНаборЗаписейНаСервере(ИмяЭлемента, ИмяПоля, ЗначениеОтбора)
	
	Если ЭтоНовый(ЭтаФорма) Тогда
		Возврат;		
	КонецЕсли; 
	
	НаборЗначение = РеквизитФормыВЗначение(ИмяЭлемента);
	НаборЗначение.Отбор[ИмяПоля].Установить(ЗначениеОтбора);
	НаборЗначение.Прочитать();
	ЗначениеВРеквизитФормы(НаборЗначение, ИмяЭлемента);
		
КонецПроцедуры

