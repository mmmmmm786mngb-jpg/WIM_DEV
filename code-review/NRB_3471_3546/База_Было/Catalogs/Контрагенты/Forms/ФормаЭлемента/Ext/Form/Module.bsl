//#Область СлужебныеПроцедурыИФункции

//#Область Сервис

&НаКлиентеНаСервереБезКонтекста
Функция ЭтоНовый(Форма)
	Возврат НЕ ЗначениеЗаполнено(Форма.Объект.Ссылка);	
КонецФункции 

&НаСервереБезКонтекста
Функция ЗначениеРеквизитаОбъекта(Источник, ИмяРеквизита)	
	Результат = Неопределено;
	Если ЗначениеЗаполнено(Источник) Тогда
		Результат = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Источник, ИмяРеквизита);			
	КонецЕсли; 
	Возврат Результат;	
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция ФормаВыплатыДоходов(ИмяЗначенияПеречисления)
	Возврат ЗначениеПеречисления("ФормыВыплатыДоходовПоЦБ", ИмяЗначенияПеречисления);
	
КонецФункции 

&НаКлиентеНаСервереБезКонтекста
Функция ЮрФизЛицо(ИмяЗначенияПеречисления)
	Возврат ЗначениеПеречисления("ЮрФизЛицо", ИмяЗначенияПеречисления);
	
КонецФункции 

&НаКлиентеНаСервереБезКонтекста
Функция ЗначениеПеречисления(ИмяВида, ИмяЗначения)
	ПолноеИмя = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку("Перечисление.%1.%2", ИмяВида, ИмяЗначения);
	Возврат ПредопределенноеЗначение(ПолноеИмя);	
КонецФункции

//#КонецОбласти 

//#Область Диалог

//#Область НастройкиФормы

&НаСервере
Процедура НастроитьЭлементыПриСозданииНаСервере()
	Элементы.ГруппаЮрФизЛицоСтраницы.ОтображениеСтраниц = ОтображениеСтраницФормы.Нет;	
	Элементы.ОПФ.СписокВыбора.Добавить("ЗАО");
	Элементы.ОПФ.СписокВыбора.Добавить("ОАО");	
	
	Если ЭтоНовый(ЭтаФорма) Тогда
		СоздаватьОсновнойДоговор = Истина;
		СоздаватьОсновнойПортфель = Истина;
	КонецЕсли; 	
	
	УстановитьОтборРазделыСчетаДепо(ЭтаФорма);
	УстановитьОтборыДинамическихСписков(ЭтаФорма);
	УстановитьДоступностьДинамическихСписков();
	
КонецПроцедуры 

&НаСервере
Процедура НастроитьФорму()
	НастроитьВидимостьРеквизитов_ДляОтчетов3533(ЭтаФорма);	
	НастроитьПросмотрКонтактнойИнформации();
	НастроитьДиалогПоФлагуСубброкер(ЭтаФорма);
	НастроитьДиалогПоФлагуБлокирован(ЭтаФорма);
	НастроитьДиалогПоРеквизитуЮрФизЛицо(ЭтаФорма);
	НастроитьДиалогПоРеквизитуФормаВыплатыДоходов(ЭтаФорма);
	НастроитьРеквизитыПоДепозитарномуОбслуживанию(ЭтотОбъект);
КонецПроцедуры 

&НаКлиентеНаСервереБезКонтекста
Процедура НастроитьВидимостьРеквизитов_ДляОтчетов3533(Форма)
	
	ОбъектФормы = Форма.Объект;
	ЭлементыФормы = Форма.Элементы;
	
	ГлавныйРодитель	= ГлавныйРодительРекурсивно(ОбъектФормы.Родитель);
	ЭтоЭмитент = ГлавныйРодитель = ПредопределенноеЗначение("Справочник.Контрагенты.Эмитенты");
	
	ВидимостьСекторЭкономики = Истина;
	ЭлементыФормы.СекторЭкономикиИностранногоЭмитента.Видимость = ВидимостьСекторЭкономики;
	
	ВидимостьУКод = НЕ ЭтоЭмитент И Не ОбъектФормы.Резидент И Не ОбъектФормы.Контрагент;
	ЭлементыФормы.ДляОтчетов3533_УКод.Видимость = ВидимостьУКод;
	
КонецПроцедуры 

&НаСервере
Процедура НастроитьПросмотрКонтактнойИнформации()
	// В будущем будет какой-то признак получен ли этот контрагент из Панды или заведен в ДЕПО,
	// если заведен в ДЕПО, то редактировать контактную информацию можно, а если из Панды - нет.
	Элементы.НаборКонтактнаяИнформация.ТолькоПросмотр = Ложь;
КонецПроцедуры
 
&НаКлиентеНаСервереБезКонтекста
Процедура НастроитьДиалогПоФлагуСубброкер(Форма)
	ОбъектФормы = Форма.Объект;
	ЭлементыФормы = Форма.Элементы;
	
	ЭлементыФормы.ФорматЗапросовИРСВ.Видимость = ОбъектФормы.Субброкер;
	ЭлементыФормы.LEI.Видимость = ОбъектФормы.Субброкер;
	ЭлементыФормы.ВнешнийИсточникДляРСВПоСубклиентам.Видимость = ОбъектФормы.Субброкер;
	ЭлементыФормы.СписокСубклиентовСправочник.Видимость = ОбъектФормы.Субброкер;
