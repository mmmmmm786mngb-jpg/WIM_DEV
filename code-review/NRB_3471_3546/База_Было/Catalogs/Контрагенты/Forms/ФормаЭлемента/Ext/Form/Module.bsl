//#Область ОбработчикиСобытийЭлементовТаблицыФормыКонтактныеЛица

&НаКлиенте
Процедура КонтактныеЛицаПриАктивизацииСтроки(Элемент)
	УстановитьСвойстваКнопкиУстановкиОсновногоКонтактногоЛица();
	УстановитьСвойстваКнопкиУстановкиГлавногоБухгалтера();
	УстановитьСвойстваКнопкиУстановкиРуководителя();
КонецПроцедуры

&НаКлиенте
Процедура КонтактныеЛицаПередНачаломДобавления(Элемент, Отказ, Копирование, Родитель, Группа, Параметр)
	Отказ = НЕ РаботаСДиалогамиКлиент.ЗаписатьНовыйОбъектВФорме(ЭтаФорма);
	Если Отказ ИЛИ Копирование Тогда
		Возврат;		
	КонецЕсли; 
	
	ПараметрыЗаполнения = Новый Структура;
	
	Если Объект.ЮрФизЛицо = ЮрФизЛицо("ФизЛицо") Тогда
		ПараметрыЗаполнения.Вставить("ОбъектВладелец", Объект.ЮридическиеФизическиеЛица);
	Иначе
		ПараметрыЗаполнения.Вставить("ОбъектВладелец", Объект.Ссылка);		
	КонецЕсли; 	
	
	ПараметрыЗаполнения.Вставить("ВидКонтактногоЛица", ЗначениеПеречисления("ВидыКонтактныхЛиц", "КонтактноеЛицоКонтрагента"));
	
	ПараметрыОткрытия = Новый Структура;
	ПараметрыОткрытия.Вставить("ЗначенияЗаполнения", ПараметрыЗаполнения);
	
	ОткрытьФорму("Справочник.КонтактныеЛица.ФормаОбъекта", ПараметрыОткрытия, ЭтаФорма);
	
КонецПроцедуры

