&НаСервере
Функция ДанныеОНаличииСчетаТипаC(ДатаДанных)	// BSLLS:LatinAndCyrillicSymbolInWord-off
	
	Результат = Новый Структура();
	Результат.Вставить("Дата", ДатаДанных);
	Результат.Вставить("ФлагАктивности", Ложь);
	Результат.Вставить("СчетДляВыплатыКД", Справочники.БанковскиеСчета.ПустаяСсылка());

	Если Не ЗначениеЗаполнено(Объект.Ссылка) Тогда
		Возврат Результат;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	КлиентыСУчетомНаСчетахТипаC.Период КАК Период,
	|	КлиентыСУчетомНаСчетахТипаC.ФлагАктивности КАК ФлагАктивности,
	|	СчетаДляВыплатыКД.Счет КАК СчетДляВыплатыКД
	|ИЗ
	|	РегистрСведений.КлиентыСУчетомНаСчетахТипаC.СрезПоследних(&ДатаДанных, Клиент = &Клиент) КАК КлиентыСУчетомНаСчетахТипаC
	|	ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СчетаДляВыплатыКД.СрезПоследних(&ДатаДанных, Клиент = &Клиент) КАК СчетаДляВыплатыКД
	|		ПО КлиентыСУчетомНаСчетахТипаC.Клиент = СчетаДляВыплатыКД.Клиент
	|";
	Запрос.УстановитьПараметр("ДатаДанных", ДатаДанных);
	Запрос.УстановитьПараметр("Клиент", Объект.Ссылка);
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Результат.Вставить("Дата", Выборка.Период);
		Результат.Вставить("ФлагАктивности", Выборка.ФлагАктивности);
		Результат.Вставить("СчетДляВыплатыКД", Выборка.СчетДляВыплатыКД);
	КонецЕсли;
	Возврат Результат
	
КонецФункции

