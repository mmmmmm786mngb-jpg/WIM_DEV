// Обработка открытия предоставленного документа, выбранного в списке
//
// Параметры:
// ДанныеСтроки - ДанныеФормыСтруктура - строка выбранного предоставленного документа
// Лицо - СправочникСсылка.ЮридическиеЛица, СправочникСсылка.ФизическиеЛица - Юр/Физ лицо депонента
&НаКлиенте
Процедура ОткрытьТекущуюЗаписьПредоставленныхФорм(ДанныеСтроки, Лицо) Экспорт
	Если ДанныеСтроки <> Неопределено Тогда
		Если ТипЗнч(ДанныеСтроки.ВидДокумента) = Тип("СправочникСсылка.ВидыДокументовУдостоверяющихПолномочия") Тогда
			ПараметрыКлюча = Новый Массив;
			СтруктураПараметровКлюча = Новый Структура("Период,Лицо,ВидДокумента", ДанныеСтроки.Период, Лицо,
			ДанныеСтроки.ВидДокумента);
			Если Не ЭтоФормаW8IMY(ДанныеСтроки.ВидДокумента) Тогда
				СтруктураПараметровКлюча.Вставить("Депонент", Объект.Ссылка);
			КонецЕсли;
			ПараметрыКлюча.Добавить(СтруктураПараметровКлюча);
			КлючЗаписи = Новый("РегистрСведенийКлючЗаписи.ПредоставленныеДокументы", ПараметрыКлюча);
			ОткрытьФорму("РегистрСведений.ПредоставленныеДокументы.ФормаЗаписи", Новый Структура("Ключ", КлючЗаписи));
		Иначе
			Сообщить("Для данной формы нет записи в регистре ""Предоставленные документы""");
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

