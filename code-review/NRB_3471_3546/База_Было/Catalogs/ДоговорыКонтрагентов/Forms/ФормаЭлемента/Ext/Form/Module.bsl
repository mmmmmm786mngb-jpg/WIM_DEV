
////////////////////////////////////////////////////////////////////////////////
// Обработчики событий формы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если Параметры.Ключ.Пустая() Тогда
		Объект.Организация = Константы.ОрганизацияПоУмолчанию.Получить();
		Объект.ТипДоговора = Перечисления.ТипыДоговоров.Депозитарный;
		Объект.ДатаНачалоДействия = ТекущаяДата();
	Иначе
		Установить = Истина;
		ОтборыСписковКлиентСервер.ИзменитьЭлементОтбораСписка(Услуги, "ДоговорКонтрагента", Объект.Ссылка, Установить);
	КонецЕсли;
	
	ДатаСреза = ТекущаяДата();
	УстановитьПараметрыДинамическогоСписка(Услуги, ДатаСреза, Объект.Ссылка);
	
	// СтандартныеПодсистемы.ВерсионированиеОбъектов
	ВерсионированиеОбъектов.ПриСозданииНаСервере(ЭтаФорма);
	// Конец СтандартныеПодсистемы.ВерсионированиеОбъектов
		
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	УправлениеВидимостьюРеквизитов();
	
КонецПроцедуры

&НаСервере
Процедура ПослеЗаписиНаСервере(ТекущийОбъект, ПараметрыЗаписи)
	
	Установить = Истина;
	УстановитьПараметрыДинамическогоСписка(Услуги, ДатаСреза, Объект.Ссылка);
	ОтборыСписковКлиентСервер.ИзменитьЭлементОтбораСписка(Услуги, "ДоговорКонтрагента", Объект.Ссылка, Установить);
	
	РегистрыСведений.РегистрНазначенныхКомиссий.ЗакрытьКомиссииПоДоговору(Объект.Ссылка);
		
КонецПроцедуры

&НаКлиенте
Процедура ПослеЗаписи(ПараметрыЗаписи)
	
	Если ЭтаФорма.ВладелецФормы <> Неопределено Тогда
		ЗакрыватьПриВыборе = Ложь;
		ОповеститьОВыборе(Объект.Ссылка);
	КонецЕсли;
	
КонецПроцедуры

////////////////////////////////////////////////////////////////////////////////
// Обработчики событий элементов шапки формы

&НаКлиенте
Процедура ДатаОкончанияДействияПриИзменении(Элемент)
	
	Если ЗначениеЗаполнено(Объект.ДатаОкончанияДействия) Тогда
		ТекстВопроса = "После установки даты окончания договор будет записан и будут закрыты все активные услуги. Продолжить?";
		Ответ = Вопрос(ТекстВопроса, РежимДиалогаВопрос.ОКОтмена);
		Если Ответ = КодВозвратаДиалога.ОК Тогда
			Записать();	
		Иначе
			Объект.ДатаОкончанияДействия = Дата(1, 1, 1);
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ТипДоговораПриИзменении(Элемент)
	
	УправлениеВидимостьюРеквизитов();	
	
КонецПроцедуры

&НаКлиенте
Процедура УслугиПередНачаломДобавления(Элемент, Отказ, Копирование, Родитель, Группа)
	
	Отказ = ЭлементНеЗаписан();
	
КонецПроцедуры

////////////////////////////////////////////////////////////////////////////////
// Служебные процедуры и функции

&НаКлиентеНаСервереБезКонтекста
Процедура УстановитьПараметрыДинамическогоСписка(Услуги, ДатаСреза, Ссылка)
	
	Услуги.Параметры.УстановитьЗначениеПараметра("ДатаСреза", КонецДня(ДатаСреза));
	Услуги.Параметры.УстановитьЗначениеПараметра("ДоговорКонтрагента", Ссылка);	
	
КонецПроцедуры

&НаКлиенте
Процедура УправлениеВидимостьюРеквизитов()

	Если Объект.ТипДоговора = ПредопределенноеЗначение("Перечисление.ТипыДоговоров.СоглашениеОПопечителе") Тогда
		Элементы.СчетДепо.Видимость		= Истина;
		Элементы.Попечитель.Видимость	= Истина;
	ИначеЕсли Объект.ТипДоговора = ПредопределенноеЗначение("Перечисление.ТипыДоговоров.Депозитарный") Тогда
		Элементы.СчетДепо.Видимость		= Истина;
		Элементы.Попечитель.Видимость	= Ложь;
	Иначе
		Элементы.СчетДепо.Видимость		= Ложь;
		Элементы.Попечитель.Видимость	= Ложь;
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ДатаСрезаПриИзменении(Элемент)
	
	Если Не ЗначениеЗаполнено(ДатаСреза) Тогда
		ДатаСреза = ТекущаяДата();
	КонецЕсли;
											 
	УстановитьПараметрыДинамическогоСписка(Услуги, ДатаСреза, Объект.Ссылка);	
	
КонецПроцедуры
	
&НаКлиенте
Функция ЭлементНеЗаписан()
	
	Если Параметры.Ключ.Пустая() Тогда
		Ответ = Вопрос("Элемент справочника еще не записан. Записать?", РежимДиалогаВопрос.ОКОтмена);
		Если Ответ = КодВозвратаДиалога.ОК Тогда
			Записать();
		КонецЕсли;
		
		Возврат Истина;		
	Иначе		
		Возврат Ложь;
	КонецЕсли;

КонецФункции