&НаКлиенте
Процедура ТипЦБОчистка(Элемент, СтандартнаяОбработка)
	
	Если ТипЗнч(Объект.ВидЦБ)= Тип("ПеречислениеСсылка.ВидыОблигаций") Тогда
		Объект.ПодвидОблигаций	= ПредопределенноеЗначение("Перечисление.ПодвидыОблигаций.ПустаяСсылка");
	КонецЕсли;
	Объект.ВидЦБ = Неопределено;
	Объект.КупоннаяОблигация = Ложь;
	УправлениеРеквизитамиФормыСервер();
	
КонецПроцедуры

&НаСервере
Процедура УправлениеРеквизитамиФормыСервер()
	
	// Установим заголовок по умолчанию для поля "Эмитент"
	ЗаголовокЭмитента	= "Эмитент";
	// Видимость закладки "Купоны"
	ВидимостьКупонов	= Ложь;
	// Определим страницу по ЦБ
	Если Объект.ТипЦБ = Перечисления.ТипыЦБ.Акция Тогда
		Элементы.ГруппаСтраницПоЦБ.ТекущаяСтраница	= Элементы.ГруппаАкции;
	ИначеЕсли Объект.ТипЦБ = Перечисления.ТипыЦБ.Облигация Тогда
		Элементы.ГруппаСтраницПоЦБ.ТекущаяСтраница	= Элементы.ГруппаОблигации;
		Если Объект.КупоннаяОблигация Тогда
			ВидимостьКупонов	= Истина;
		Иначе
			ВидимостьКупонов	= Ложь;
		КонецЕсли;		
	ИначеЕсли Объект.ТипЦБ = Перечисления.ТипыЦБ.Вексель Тогда
		ЗаголовокЭмитента	= "Трассат:";
		Элементы.ГруппаСтраницПоЦБ.ТекущаяСтраница	= Элементы.ГруппаВекселя;
	ИначеЕсли Объект.ТипЦБ = Перечисления.ТипыЦБ.Пай Тогда
		ЗаголовокЭмитента	= "ПИФ:";
		Элементы.ГруппаСтраницПоЦБ.ТекущаяСтраница	= Элементы.ГруппаПаи;
	Иначе
		Элементы.ГруппаСтраницПоЦБ.ТекущаяСтраница	= Элементы.ГруппаАкции;
	КонецЕсли;
	// Установим заголовок поля "Эмитент"
	Элементы.Эмитент.Заголовок	= ЗаголовокЭмитента;
	// Установим видимость некоторых элементов для "Депозитарной расписки"
	Элементы.ГруппаБазовыйАктивКоличествоАкции.Видимость= (Объект.ТипЦБ = Перечисления.ТипыЦБ.ДепозитарнаяРасписка);
	// Обработка "Вида ЦБ"
	Элементы.ПодвидОблигаций.Видимость					= (Объект.ВидЦБ = Перечисления.ВидыОблигаций.Государственная);
	Если НЕ Элементы.ПодвидОблигаций.Видимость Тогда
		Объект.ПодвидОблигаций = Перечисления.ПодвидыОблигаций.ПустаяСсылка();
	КонецЕсли;
	Элементы.ПроцентДисконтВексель.Видимость			= (Объект.ВидЦБ = Перечисления.ВидыВекселей.Процентный);
	Элементы.ДекорацияПроцентДисконтВексель.Видимость	= (Объект.ВидЦБ = Перечисления.ВидыВекселей.Процентный);
	// Обработка изменения "Типа векселя"
	Элементы.УдостоверениеПравообладанияВексель.Доступность = (Объект.ТипВекселя <> Перечисления.ТипыВекселей.Простой);
	// Установим видимость панели купонов
	Элементы.ГруппаКупоны.Видимость						= ВидимостьКупонов;
	Элементы.ГруппаДанныеПоКупонуОблигации.Видимость	= ВидимостьКупонов;
	
	УстановитьВидТипаЦБ();
	
КонецПроцедуры

&НаСервере
Процедура УстановитьВидТипаЦБ()
	
	Если Объект.ТипЦБ = Перечисления.ТипыЦБ.Акция
		ИЛИ Объект.ТипЦБ = Перечисления.ТипыЦБ.КлиринговыйСертификатУчастия Тогда
		НовыйВидЦБ = Перечисления.ВидыАкций.ПустаяСсылка();
	ИначеЕсли Объект.ТипЦБ = Перечисления.ТипыЦБ.Облигация Тогда
		НовыйВидЦБ = Перечисления.ВидыОблигаций.ПустаяСсылка();
	ИначеЕсли Объект.ТипЦБ = Перечисления.ТипыЦБ.Вексель Тогда
		НовыйВидЦБ = Перечисления.ВидыВекселей.ПустаяСсылка();
	ИначеЕсли Объект.ТипЦБ = Перечисления.ТипыЦБ.Пай Тогда
		НовыйВидЦБ = Перечисления.ВидыПаев.ПустаяСсылка();
	ИначеЕсли Объект.ТипЦБ = Перечисления.ТипыЦБ.ДепозитарнаяРасписка Тогда
		НовыйВидЦБ = Перечисления.ВидыДепозитарныхРасписок.ПустаяСсылка();
	Иначе
		НовыйВидЦБ = Неопределено;
	КонецЕсли;
	
	Элементы.ВидЦБАкции.ВыбиратьТип = НовыйВидЦБ = Неопределено;
	
	Если ТипЗнч(Объект.ВидЦБ) <> ТипЗнч(НовыйВидЦБ) Тогда
		Объект.ВидЦБ = НовыйВидЦБ;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура УстановитьНеобходимыеОтборыСервер()
	Если Объект.Ссылка.Пустая() Тогда                                        
		СсылкаОтбора	= Справочники.ЦенныеБумаги.ПолучитьСсылку(Новый УникальныйИдентификатор);
	Иначе
		СсылкаОтбора	= Объект.Ссылка;
	КонецЕсли;	
	// {{ Коды загрузки
	ЭлементыОтбора	= ТабличноеПолеКодыЗагрузки.Отбор.Элементы;
	// Очистим старые отборы
	ЭлементыОтбора.Очистить();
	// Новый отбор
	НовыйОтбор	= ЭлементыОтбора.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	
	НовыйОтбор.ЛевоеЗначение	= Новый ПолеКомпоновкиДанных("Владелец");
	НовыйОтбор.Использование	= Истина;
	НовыйОтбор.ПравоеЗначение	= СсылкаОтбора;
	НовыйОтбор.РежимОтображения	= РежимОтображенияЭлементаНастройкиКомпоновкиДанных.Недоступный;
	
	// {{ Котировки
	ЭлементыОтбора	= ТабличноеПолеКотировки.Отбор.Элементы;
	// Очистим старые отборы
	ЭлементыОтбора.Очистить();
	// Новый отбор
	НовыйОтбор	= ЭлементыОтбора.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	
	НовыйОтбор.ЛевоеЗначение	= Новый ПолеКомпоновкиДанных("ЦеннаяБумага");
	НовыйОтбор.Использование	= Истина;
	НовыйОтбор.ПравоеЗначение	= СсылкаОтбора;
	НовыйОтбор.РежимОтображения	= РежимОтображенияЭлементаНастройкиКомпоновкиДанных.Недоступный;
	
	Если Не КотировкиБиржа.Пустая() Тогда
		НовыйОтбор	= ЭлементыОтбора.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
		
		НовыйОтбор.ЛевоеЗначение	= Новый ПолеКомпоновкиДанных("Биржа");
		НовыйОтбор.Использование	= Истина;
		НовыйОтбор.ПравоеЗначение	= КотировкиБиржа;
		//НовыйОтбор.РежимОтображения	= РежимОтображенияЭлементаНастройкиКомпоновкиДанных.Недоступный;
	КонецЕсли;
	
	Если Не КотировкиРежимТоргов.Пустая() Тогда
		НовыйОтбор	= ЭлементыОтбора.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
		
		НовыйОтбор.ЛевоеЗначение	= Новый ПолеКомпоновкиДанных("РежимТоргов");
		НовыйОтбор.Использование	= Истина;
		НовыйОтбор.ПравоеЗначение	= КотировкиРежимТоргов;
		//НовыйОтбор.РежимОтображения	= РежимОтображенияЭлементаНастройкиКомпоновкиДанных.Недоступный;
	КонецЕсли;
КонецПроцедуры

