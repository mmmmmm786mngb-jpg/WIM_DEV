&НаСервере
Процедура ПослеЗаписиНаСервере(ТекущийОбъект, ПараметрыЗаписи)
	КатегорияЦБРегистр = РегистрыСведений.КатегорияЦБ.СрезПоследних(ДатаАнкеты, Новый Структура("ЦеннаяБумага", Объект.Ссылка));
	Если КатегорияЦБРегистр.Количество() = 1 Тогда
		Если КатегорияЦБРегистр[0].Категория <> КатегорияЦБ Тогда
			МенеджерКатегорияЦБ = РегистрыСведений.КатегорияЦБ.СоздатьМенеджерЗаписи();
			МенеджерКатегорияЦБ.Период			= ДатаАнкеты;
			МенеджерКатегорияЦБ.ЦеннаяБумага	= Объект.Ссылка;
			МенеджерКатегорияЦБ.Категория		= КатегорияЦБ;
			МенеджерКатегорияЦБ.Записать();
		КонецЕсли;
	Иначе
		МенеджерКатегорияЦБ = РегистрыСведений.КатегорияЦБ.СоздатьМенеджерЗаписи();
		МенеджерКатегорияЦБ.Период			= ДатаАнкеты;
		МенеджерКатегорияЦБ.ЦеннаяБумага	= Объект.Ссылка;
		МенеджерКатегорияЦБ.Категория		= КатегорияЦБ;
		МенеджерКатегорияЦБ.Записать();
	КонецЕсли;
	
	НоминалЦБРегистр = РегистрыСведений.НоминалЦБ.СрезПоследних(ДатаАнкеты, Новый Структура("ЦеннаяБумага", Объект.Ссылка));
	Если НоминалЦБРегистр.Количество() = 1 Тогда
		Если НоминалЦБРегистр[0].Сумма <> ЦБНоминал Тогда
			НоминалЦБРегистр = РегистрыСведений.НоминалЦБ.СоздатьМенеджерЗаписи();
			НоминалЦБРегистр.Период			= ДатаАнкеты;
			НоминалЦБРегистр.ЦеннаяБумага	= Объект.Ссылка;
			НоминалЦБРегистр.Сумма			= ЦБНоминал;
			НоминалЦБРегистр.Записать();
		КонецЕсли;
	иначе
		НоминалЦБРегистр = РегистрыСведений.НоминалЦБ.СоздатьМенеджерЗаписи();
		НоминалЦБРегистр.Период			= ДатаАнкеты;
		НоминалЦБРегистр.ЦеннаяБумага	= Объект.Ссылка;
		НоминалЦБРегистр.Сумма			= ЦБНоминал;
		НоминалЦБРегистр.Записать();
	КонецЕсли;
	
	ДатаАнкетыПриИзмененииСервер();
	УправлениеРеквизитамиФормыСервер();
	УстановитьНеобходимыеОтборыСервер();
КонецПроцедуры

&НаКлиенте
Процедура ТабличноеПолеКодыЗагрузкиОбработкаЗаписиНового(НовыйОбъект, Источник, СтандартнаяОбработка)

	РеквизитыКода = ОбщегоНазначения.ПолучитьЗначенияРеквизитов(НовыйОбъект, "ДатаОкончанияДействия,Код");
	Если Не ЗначениеЗаполнено(РеквизитыКода.ДатаОкончанияДействия)
			ИЛИ КонецДня(РеквизитыКода.ДатаОкончанияДействия) >= КонецДня(ТекущаяДата()) Тогда
		Если ЗначениеЗаполнено(Объект.ISIN) И ЗначениеЗаполнено(Объект.ТипЦБ) Тогда
			ПоискДублейЦБ(СокрЛП(РеквизитыКода.Код));
		Иначе
			ОбщегоНазначенияКлиентСервер.СообщитьОшибкиПользователю("Данные для проверки по ISIN и Типу ЦБ не верны!");
		КонецЕсли; 
	КонецЕсли;

КонецПроцедуры

&НаСервере
Процедура ПоискДублейЦБ(КодММВБ)
	
	ОбъектПроверки	= Объект.Ссылка;
	
	Запрос	= Новый Запрос;
	
	Запрос.Текст	= "
	|ВЫБРАТЬ
	|	ЦенныеБумаги.Ссылка	КАК ЦБ
	|	,ТаблицаКодов.КодММВБ
	|ИЗ
	|	Справочник.ЦенныеБумаги КАК ЦенныеБумаги
	|ЛЕВОЕ СОЕДИНЕНИЕ	
	|	(
	|	ВЫБРАТЬ РАЗЛИЧНЫЕ
	|		Владелец,
	|		МАКСИМУМ(ВЫБОР КОГДА Биржа = ЗНАЧЕНИЕ(Справочник.Биржи.MICEX) ТОГДА Код КОНЕЦ) КАК КодММВБ
	|	ИЗ
	|		Справочник.КодыЗагрузки
	|	ГДЕ
	|		ПометкаУдаления = ЛОЖЬ	
	|	И
	|		(ДатаОкончанияДействия = ДАТАВРЕМЯ(1,1,1) ИЛИ ДатаОкончанияДействия >= КОНЕЦПЕРИОДА(&ТекущаяДата, ДЕНЬ))
	|	СГРУППИРОВАТЬ ПО
	|		Владелец
	|	ИМЕЮЩИЕ
	|		МАКСИМУМ(ВЫБОР КОГДА Биржа = ЗНАЧЕНИЕ(Справочник.Биржи.MICEX) ТОГДА Код КОНЕЦ) = &КодММВБ
	|	) КАК ТаблицаКодов
	|ПО
	|	(ТаблицаКодов.Владелец = ЦенныеБумаги.Ссылка)
	|ГДЕ
	|	ЦенныеБумаги.ISIN	= &ISIN
	|И
	|	ЦенныеБумаги.ТипЦБ	= &ТипЦБ
	|"+?(ОбъектПроверки = Неопределено	, "", "И ЦенныеБумаги.Ссылка <> &ТекущаяЦБ")+"
	|"+?(КодММВБ = Неопределено			, "", "И ТаблицаКодов.КодММВБ IS NOT NULL");
	
	Запрос.УстановитьПараметр("ISIN"		, Объект.ISIN);
	Запрос.УстановитьПараметр("ТипЦБ"		, Объект.ТипЦБ);
	Запрос.УстановитьПараметр("ТекущаяЦБ"	, ОбъектПроверки);
	Запрос.УстановитьПараметр("КодММВБ"		, КодММВБ);
	Запрос.УстановитьПараметр("ТекущаяДата"	, ТекущаяДата());
	
	Результат	= Запрос.Выполнить();
	
	Если Не Результат.Пустой() Тогда
		Выборка	= Результат.Выбрать();
		ТекстСообщения	= "Найдены подобные элементы ЦБ:";
		
		Пока Выборка.Следующий() Цикл
			ТекстСообщения	= ТекстСообщения + "
			| - "+Выборка.ЦБ+" - Код 1С: "+СокрЛП(Выборка.ЦБ.Код)+" - ISIN: "+СокрЛП(Выборка.ЦБ.ISIN)+" - Тип: "+Выборка.ЦБ.ТипЦБ+?(КодММВБ = Неопределено, "", " - Код ММВБ: "+КодММВБ);
		КонецЦикла;
		
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
	КонецЕсли;
	
КонецПроцедуры

