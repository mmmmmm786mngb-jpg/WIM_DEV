&НаКлиенте
Процедура КатегорияЦБОткрытие(Элемент, СтандартнаяОбработка)
	Если Не Объект.Ссылка.Пустая() Тогда
		СтандартнаяОбработка = Ложь;
		МенеджерКатегорияЦБ = ПолучитьФорму("РегистрСведений.КатегорияЦБ.Форма.ФормаСписка",, ЭтаФорма);
		МенеджерКатегорияЦБ.Отбор.ЦеннаяБумага.Установить(Объект.Ссылка);
		МенеджерКатегорияЦБ.Отбор.ЦеннаяБумага.ВидСравнения		= ВидСравнения.Равно;
		МенеджерКатегорияЦБ.Отбор.ЦеннаяБумага.Использование	= Истина;
		Если МенеджерКатегорияЦБ.Открыта() Тогда
			МенеджерКатегорияЦБ.Активизировать();
		Иначе
			МенеджерКатегорияЦБ.Открыть();
		КонецЕсли;
	Иначе
		ОбщегоНазначения.СообщитьОбОшибке("'Ценная бумага' не записана - отображение списка категорий не возможно!");
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура ДатаАнкетыПриИзмененииСервер()
	Если Не Объект.Ссылка.Пустая() Тогда
		Попытка
			КатегорияЦБ = РегистрыСведений.КатегорияЦБ.СрезПоследних(ДатаАнкеты, Новый Структура("ЦеннаяБумага",Объект.Ссылка))[0].Категория;
		Исключение
			КатегорияЦБ = Справочники.КатегорииЦБ.ПустаяСсылка();
		КонецПопытки;
		Попытка
			ДанныеНоминалаЦБ= РегистрыСведений.НоминалЦБ.СрезПоследних(ДатаАнкеты, Новый Структура("ЦеннаяБумага",Объект.Ссылка));
			ЦБНоминал		= ДанныеНоминалаЦБ[0].Сумма;
		Исключение
			ЦБНоминал		= 0;
		КонецПопытки;
	Иначе
		КатегорияЦБ = Справочники.КатегорииЦБ.ПустаяСсылка();
		ЦБНоминал	= 0;
	КонецЕсли;
КонецПроцедуры

