&НаКлиенте
Процедура ЦБНоминалОткрытие(Элемент, СтандартнаяОбработка)
	
	СтандартнаяОбработка = ложь;
	
	Если Не Объект.Ссылка.Пустая() Тогда
		МенеджерНоминалЦБ = ПолучитьФорму("РегистрСведений.НоминалЦБ.Форма.ФормаСписка", , ЭтаФорма);
		ОтборНоминаловЭлементы	= МенеджерНоминалЦБ.Список.Отбор.Элементы;
		ОтборНоминаловЭлементы.Очистить();
		
		НовыйОтбор	= ОтборНоминаловЭлементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
		
		НовыйОтбор.ЛевоеЗначение	= Новый ПолеКомпоновкиДанных("ЦеннаяБумага");
		НовыйОтбор.Использование	= Истина;
		НовыйОтбор.ПравоеЗначение	= Объект.Ссылка;
		НовыйОтбор.РежимОтображения	= РежимОтображенияЭлементаНастройкиКомпоновкиДанных.Недоступный;
	
		Если МенеджерНоминалЦБ.Открыта() Тогда
			МенеджерНоминалЦБ.Активизировать();
		Иначе
			МенеджерНоминалЦБ.Открыть();
		КонецЕсли;
	Иначе
		Сообщить("Перед открытием списка номиналов необходимо записать 'Ценную бумагу'!!!");
	КонецЕсли;
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция НоминалЦБ(Дата, ЦеннаяБумага)
	Возврат РегистрыСведений.НоминалЦБ.ПолучитьПоследнее(Дата, Новый Структура("ЦеннаяБумага", ЦеннаяБумага)).Сумма;
КонецФункции

&НаКлиенте
Процедура КупоныДатаПогашенияОбработкаВыбора(Элемент, ВыбранноеЗначение, СтандартнаяОбработка)
	Если ЗначениеЗаполнено(Объект.ДатаПогашения) Тогда
		Если ВыбранноеЗначение > Объект.ДатаПогашения Тогда
			Предупреждение("Дата погашения купона больше даты погашения ЦБ!"); 
			СтандартнаяОбработка = Ложь;
		КонецЕсли; 
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура КупоныДатаПогашенияОкончаниеВводаТекста(Элемент, Текст, ДанныеВыбора, СтандартнаяОбработка)
	
	Если ЗначениеЗаполнено(Объект.ДатаПогашения) И ЗначениеЗаполнено(СтрЗаменить(Текст, ".", "")) Тогда
		Выбраннаядата	= Дата(Прав(Текст,4), Сред(Текст, 4, 2), Лев(Текст, 2));
		Если Выбраннаядата > Объект.ДатаПогашения Тогда
			Предупреждение("Дата погашения купона больше даты погашения ЦБ!"); 
			СтандартнаяОбработка = Ложь;
		КонецЕсли; 
	Иначе
		Предупреждение("Не заполнена дата погашения ЦБ или купона!");
		СтандартнаяОбработка = Ложь;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура Пересчитать(Основание, Данные)
	Если Не Объект.Ссылка.Пустая() Тогда
		Если Данные.СрокОбращения > 0 Тогда
			ЦБНоминалЦБ = НоминалЦБ(Данные.ДатаВыпуска, Объект.Ссылка);
			Если ЦБНоминалЦБ <> 0 Тогда
				Если Основание = "Купон" Тогда
					Данные.Сумма = ОКР(Данные.Купон/Данные.СрокОбращения * ((Данные.ДатаПогашения - Данные.ДатаВыпуска)/86400)* ЦБНоминалЦБ/100,2,1);                     
				ИначеЕсли Основание = "Сумма" Тогда
					Данные.Купон = ОКР(Данные.Сумма * Данные.СрокОбращения * 100 / (((Данные.ДатаПогашения - Данные.ДатаВыпуска)/86400)* ЦБНоминалЦБ),4,1);
				ИначеЕсли Основание = "ДатаПогашения" ИЛИ Основание = "ДатаВыпуска" Тогда
					Данные.Сумма = ОКР(Данные.Купон/Данные.СрокОбращения *  ((Данные.ДатаПогашения - Данные.ДатаВыпуска)/86400)* ЦБНоминалЦБ/100,2,1);
				КонецЕсли;
			Иначе
				Предупреждение("Пересчет не выполнен, введите значение в регистр ""Номинал ЦБ""",60);
			КонецЕсли;
		КонецЕсли;
	Иначе
		Предупреждение("Пересчет не выполнен, запишите ЦБ и введите значение в регистр ""Номинал ЦБ""",60);
	КонецЕсли;	
КонецПроцедуры

&НаКлиенте
Процедура КупоныСуммаПриИзменении(Элемент)
	ТекущиеДанные	= Элемент.Родитель.Текущиеданные;
	Пересчитать("Сумма", ТекущиеДанные);
КонецПроцедуры

&НаКлиенте
Процедура КупоныПриНачалеРедактирования(Элемент, НоваяСтрока, Копирование)
	Если НоваяСтрока Тогда
		Элемент.ТекущиеДанные.СрокОбращения = 365;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура КупоныПриОкончанииРедактирования(Элемент, НоваяСтрока, ОтменаРедактирования)
	ПроверкаДаты	= Элемент.ТекущиеДанные.ДатаПогашения;
	Для каждого СтрокаКупонов Из Объект.Купоны Цикл
		Если СтрокаКупонов.ДатаПогашения = ПроверкаДаты И СтрокаКупонов.НомерСтроки <> Элемент.ТекущиеДанные.НомерСтроки Тогда
			Оболочки.ВыводСообщения("Дата погашения купона в текущей строке совпадает с датой в строке № " + СтрокаКупонов.НомерСтроки+"! Строка не записана!",СтатусСообщения.ОченьВажное);
			ОтменаРедактирования = Истина;
			Объект.Купоны.Удалить(СтрокаКупонов.НомерСтроки-1);
			Возврат;
		КонецЕсли;
	КонецЦикла;
	
	Если ПроверкаДаты > Объект.ДатаПогашения Тогда
		Оболочки.ВыводСообщения("Дата погашения купона больше даты погашения для ЦБ "+Объект.Код+"! Строка не записана!", СтатусСообщения.ОченьВажное);
		ОтменаРедактирования	= Истина;
		Объект.Купоны.Удалить(Элемент.ТекущиеДанные.НомерСтроки-1);
		Возврат;
	КонецЕсли;
КонецПроцедуры

&НаСервереБезКонтекста
Функция ИнтерфаксОтчетОЦеннойБумагеНаСервере(ISIN)
	Возврат Справочники.ЦенныеБумаги.ИнтерфаксОтчетОЦеннойБумаге(ISIN);
КонецФункции

&НаКлиенте
Процедура ПоказатьДанныеRuData(Команда)
	
	ISIN = СокрЛП(Объект.ISIN);
	Если Не ЗначениеЗаполнено(ISIN) Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не указан ISIN", , "Объект.ISIN");
		Возврат;
	КонецЕсли;
	ТабличныйДокумент = ИнтерфаксОтчетОЦеннойБумагеНаСервере(ISIN);
	Если ТабличныйДокумент = Неопределено Тогда
		ПредупреждениеАсинх("Нет актуальных данных или произошла ошибка.", 10);
	Иначе
		ИнтерфаксИмяОтчета = "Отчет о ценной бумаге с ISIN " + ISIN + " из RuData";
		ТабличныйДокумент.Показать(ИнтерфаксИмяОтчета, ИнтерфаксИмяОтчета);
	КонецЕсли;
	
КонецПроцедуры
