&НаКлиенте
Процедура АнкетаВыпускаЦБ(Команда)
	//---
	Если Объект.Ссылка.Пустая() Тогда
		Если Вопрос("Формирование анкеты возможно только для записанной ЦБ!
					|Записать?", РежимДиалогаВопрос.ДаНет) = КодВозвратаДиалога.Да Тогда
			Записать();
		Иначе
			Возврат;
		КонецЕсли;
	КонецЕсли;
	//---
	Форма	= ПолучитьФорму("Отчет.АнкетаВыпускаЦБ.Форма.ФормаОтчета");
	//---
	Форма.Отчет.ВыводитьПечать		= Истина;
	Форма.Отчет.ОтчетПоСписку		= Истина;
	Форма.Отчет.Автоформирование	= Истина;
	Форма.Отчет.ЦенныеБумаги.Добавить(Объект.Ссылка);
	//---
	Форма.Открыть();
КонецПроцедуры

