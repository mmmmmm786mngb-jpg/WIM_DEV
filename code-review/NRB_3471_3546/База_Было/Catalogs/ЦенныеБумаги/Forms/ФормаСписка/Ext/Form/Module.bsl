&НаКлиенте
Процедура ПоказатьДанныеRuData(Команда)
	
	ISINs = Новый Массив;
	Если Элементы.Список.ВыделенныеСтроки.Количество() > 0 Тогда
		Для Каждого Элемент Из Элементы.Список.ВыделенныеСтроки Цикл
			Если Не ЭлементЭтоГруппа(Элемент) Тогда
				ISIN = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Элемент, "ISIN");
				Если ЗначениеЗаполнено(ISIN) Тогда
					ISINs.Добавить(ISIN);
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(ISINs) Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не указан ISIN");
		Возврат;
	КонецЕсли;
	ТабличныйДокумент = ИнтерфаксОтчетОЦеннойБумагеНаСервере(ISINs);
	Если ТабличныйДокумент = Неопределено Тогда
		ПредупреждениеАсинх("Нет актуальных данных или произошла ошибка.", 10);
	Иначе
		ИнтерфаксИмяОтчета = НазваниеОтчетаОЦеннойБумагеНаСервере(ISINs);
		ТабличныйДокумент.Показать(ИнтерфаксИмяОтчета, ИнтерфаксИмяОтчета);
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Функция ЭлементЭтоГруппа(Элемент)
	Возврат Элемент.ЭтоГруппа;
КонецФункции

&НаСервереБезКонтекста
Функция ИнтерфаксОтчетОЦеннойБумагеНаСервере(ISIN)
	Возврат Справочники.ЦенныеБумаги.ИнтерфаксОтчетОЦеннойБумаге(ISIN);
КонецФункции

&НаСервереБезКонтекста
Функция НазваниеОтчетаОЦеннойБумагеНаСервере(ISINs)
	
	ДопустимоеКоличествоЦенныхБумагВЗаголовке = 3;
	Если ISINs.Количество() > ДопустимоеКоличествоЦенныхБумагВЗаголовке Тогда
		КЗаголовку = Новый Массив;
		Для Индекс = 0 По ДопустимоеКоличествоЦенныхБумагВЗаголовке - 1 Цикл
			КЗаголовку.Добавить(ISINs[Индекс]);
		КонецЦикла;
		КоличествоБумаг = " [" + Формат(ISINs.Количество(), "ЧГ=0") + " шт.]";
		ПодвалЗаголовка = " и т.д.";
	Иначе
		КЗаголовку = ISINs;
		КоличествоБумаг = "";
		ПодвалЗаголовка = "";
	КонецЕсли;
	
	ШаблонНазвания = "RuData Отчет о ценных бумагах%1 с ISIN %2%3";
	Название = СтрШаблон(ШаблонНазвания, КоличествоБумаг, СтрСоединить(КЗаголовку , ","), ПодвалЗаголовка);
	
	Возврат Название;
	
КонецФункции

#КонецОбласти
