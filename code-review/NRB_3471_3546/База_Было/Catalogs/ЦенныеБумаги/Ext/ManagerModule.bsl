// Определяет, что это бумага российского эмитента.
//
// Параметры:
//	ЦеннаяБумага - СправочникСсылка.ЦенныеБумаги
//
// Возвращаемое значение:
//	Истина, если бумага российского эмитента, иначе Ложь
Функция ЭтоБумагаРоссийскогоЭмитента(ЦеннаяБумага) Экспорт
	Если ЗначениеЗаполнено(ЦеннаяБумага) И ТипЗнч(ЦеннаяБумага) = Тип("СправочникСсылка.ЦенныеБумаги") Тогда
		ЦБРоссийскихЭмитентов = "DR,DR1,DR2";
		МассивРоссийскихЭмитентов = СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(ЦБРоссийскихЭмитентов);
		Если МассивРоссийскихЭмитентов.Найти(ЦеннаяБумага.ВидЦББанкаРоссии.Код) <> Неопределено Тогда
			Возврат (ЦеннаяБумага.ВидЦБ = Перечисления.ВидыДепозитарныхРасписок.РоссийскаяДепозитарнаяРасписка);
		Иначе
			ЦБИностранныхЭмитентов = "SHS5,SHS51,SHS6,SHS61,SHS7,SHS71,BON5,BON6,BON61,BON7,BON71";
			МассивИноЭмитентов = СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(ЦБИностранныхЭмитентов);
			Возврат (МассивИноЭмитентов.Найти(ЦеннаяБумага.ВидЦББанкаРоссии.Код) = Неопределено);
		КонецЕсли;
	Иначе
		Возврат Ложь;
	КонецЕсли;
КонецФункции

// Возвращает наименование эмитента ценной бумаги.
// Значение зависит от категории финансового инструмента:
// - для акций, облигаций российских эмитентов - наименование эмитента;
// - для паев российских эмитентов - наименование паевого фонда;
// - для всех ЦБ иностранных эмитентов - наименование ценной бумаги.
//
// Параметры:
//	ЦеннаяБумага - СправочникСсылка.ЦенныеБумаги
//
// Возвращаемое значение:
//	строка
Функция НаименованиеЭмитента(ЦеннаяБумага) Экспорт
	Наименование = "";
	Если ЗначениеЗаполнено(ЦеннаяБумага) И ТипЗнч(ЦеннаяБумага) = Тип("СправочникСсылка.ЦенныеБумаги") Тогда
		Если ЭтоБумагаРоссийскогоЭмитента(ЦеннаяБумага) Тогда
			Если ЗначениеЗаполнено(ЦеннаяБумага.Эмитент)
				И ЗначениеЗаполнено(ЦеннаяБумага.Эмитент.ЮридическиеФизическиеЛица)
				И ТипЗнч(ЦеннаяБумага.Эмитент.ЮридическиеФизическиеЛица) = Тип("СправочникСсылка.ЮридическиеЛица")
				И ЗначениеЗаполнено(ЦеннаяБумага.Эмитент.ЮридическиеФизическиеЛица.ПолноеНаименование) Тогда				
				Наименование = СокрЛП(ЦеннаяБумага.Эмитент.ЮридическиеФизическиеЛица.ПолноеНаименование);
			КонецЕсли;
		Иначе
			Если ЗначениеЗаполнено(ЦеннаяБумага.Наименование) Тогда
				Наименование = СокрЛП(ЦеннаяБумага.Наименование);
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	Возврат Наименование;
КонецФункции

// Возвращает русское наименование ценной бумаги.
//
// Параметры:
//	ЦеннаяБумага - СправочникСсылка.ЦенныеБумаги
//
// Возвращаемое значение:
//	строка
Функция РусскоеНаименование(ЦеннаяБумага) Экспорт
	Если ЗначениеЗаполнено(ЦеннаяБумага.НаименованиеВыпуска) Тогда
		РусскоеНаименование = СокрЛП(ЦеннаяБумага.НаименованиеВыпуска);
		
		Если ЦеннаяБумага.ТипЦБ = Перечисления.ТипыЦБ.Облигация И ЗначениеЗаполнено(ЦеннаяБумага.Эмитент) И ЭтоБумагаРоссийскогоЭмитента(ЦеннаяБумага) Тогда
			РусскоеНаименование = РусскоеНаименование + " " + СокрЛП(ЦеннаяБумага.Эмитент.Наименование);
		КонецЕсли;
		
	ИначеЕсли ЗначениеЗаполнено(ЦеннаяБумага.Эмитент)
		И НЕ(ЦеннаяБумага.ТипЦБ = Перечисления.ТипыЦБ.ДепозитарнаяРасписка
				ИЛИ ЦеннаяБумага.ТипЦБ = Перечисления.ТипыЦБ.Пай) Тогда
		РусскоеНаименование = СокрЛП(ЦеннаяБумага.Эмитент.Наименование);
		
	Иначе
		РусскоеНаименование = СокрЛП(ЦеннаяБумага.Наименование);
	КонецЕсли;
	Возврат РусскоеНаименование;
КонецФункции

// Депозитарные расписки, эмитированные в США, выписываются на ЦБ других стран, поэтому исключаются
// из результатов запроса.
// Остальные бумаги, эмитированные в США, подпадают под налоговое регулирование США, они также известны
// как "американские ценные бумаги".
//
// Параметры:
//	ЦеннаяБумага - ссылка на справочник ЦенныеБумаги
//
// Возвращаемое значение:
//	Истина, если бумага подпадает под налоговое регулирование США, иначе Ложь
Функция ЦБПодпадаетПодНалоговоеРегулированиеСША(ЦеннаяБумага) Экспорт
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	ЦенныеБумаги.Ссылка КАК ЦБ
	|ИЗ
	|	Справочник.ЦенныеБумаги КАК ЦенныеБумаги
	|ГДЕ
	|	ЦенныеБумаги.Ссылка = &Ссылка
	|	И НЕ ЦенныеБумаги.ТипЦБ = &ДепозитарнаяРасписка
	|	И (ЦенныеБумаги.СтранаНалогообложения = &США
	|			ИЛИ ВЫРАЗИТЬ(ЦенныеБумаги.Эмитент.ЮридическиеФизическиеЛица КАК Справочник.ЮридическиеЛица).Страна = &США)");
	Запрос.УстановитьПараметр("Ссылка", ЦеннаяБумага);
	Запрос.УстановитьПараметр("США", Справочники.КлассификаторСтранМира.США());
	Запрос.УстановитьПараметр("ДепозитарнаяРасписка", Перечисления.ТипыЦБ.ДепозитарнаяРасписка);
	Возврат НЕ Запрос.Выполнить().Пустой();
КонецФункции

Функция ЦеннаяБумагаПоКодуЗагрузкиНДЦ(КодЗагрузкиНДЦ, ДатаОтбора) Экспорт
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("НДЦ", Константы.КлассификаторЗагрузкиНДЦ.Получить());
	Запрос.УстановитьПараметр("Код", Сокрлп(КодЗагрузкиНДЦ));
	Запрос.УстановитьПараметр("ДатаОтбора", ДатаОтбора);
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	ВЫРАЗИТЬ(КодыЗагрузки.Владелец КАК Справочник.ЦенныеБумаги).Ссылка КАК ЦеннаяБумага
	|ИЗ
	|	Справочник.КодыЗагрузки КАК КодыЗагрузки
	|ГДЕ
	|	ВЫРАЗИТЬ(КодыЗагрузки.Биржа КАК Справочник.КлассификаторыЗагрузки).Ссылка = &НДЦ
	|	И КодыЗагрузки.Код = &Код
	|	И КодыЗагрузки.Владелец ССЫЛКА Справочник.ЦенныеБумаги
	|	И НЕ КодыЗагрузки.ПометкаУдаления	
	|	И (КодыЗагрузки.ДатаОкончанияДействия = ДАТАВРЕМЯ(1,1,1)
	|		ИЛИ КодыЗагрузки.ДатаОкончанияДействия >= КОНЕЦПЕРИОДА(&ДатаОтбора, ДЕНЬ))";
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.ЦеннаяБумага;
	Иначе
		Возврат Справочники.ЦенныеБумаги.ПустаяСсылка();
	КонецЕсли;
КонецФункции

// Возвращает ценную бумагу (или массив ценных бумаг) по ISIN и регистрационному номеру
//
// Параметры:
//  ISIN						 - Строка	 - ISIN
//  НомерРегистрации			 - Строка	 - НомерРегистрации, (если значение Неопределено - исключение сравнения по номеру регистрации)
//  ВернутьВсеНайденныеПоУсловию - Булево	 - Если Истина: вернуть все найденные по условию ценные бумаги в виде массива
// 
// Возвращаемое значение:
//  СправочникСсылка.ЦенныеБумаги, Массив - Ценная бумага согласно приоритета (или массив ценных бумаг если ВернутьВсеНайденныеПоУсловию);
//  										Неопределено если ЦБ найти не удалось
//
Функция ЦеннаяБумагаПоРегНомеруИISIN(ISIN, НомерРегистрации, ВернутьВсеНайденныеПоУсловию = Ложь) Экспорт
	ЦеннаяБумага = Неопределено;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	ЦенныеБумаги.Ссылка КАК ЦеннаяБумага
	|ИЗ
	|	Справочник.ЦенныеБумаги КАК ЦенныеБумаги
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.КодыЗагрузки КАК КодыЗагрузки
	|		ПО (КодыЗагрузки.Владелец = ЦенныеБумаги.Ссылка)
	|			И (НЕ КодыЗагрузки.ПометкаУдаления)
	|			И (КодыЗагрузки.ДатаОкончанияДействия = ДАТАВРЕМЯ(1, 1, 1)
	|				ИЛИ КодыЗагрузки.ДатаОкончанияДействия >= КОНЕЦПЕРИОДА(&ДатаОтбора, ДЕНЬ))
	|			И (КодыЗагрузки.Биржа = ЗНАЧЕНИЕ(Справочник.КлассификаторыЗагрузки.NrdCode))
	|ГДЕ
	|	ЦенныеБумаги.ISIN = &ISIN
	|	И ЦенныеБумаги.НомерРегистрации = &НомерРегистрации
	|	И НЕ ЦенныеБумаги.ПометкаУдаления
	|
	|УПОРЯДОЧИТЬ ПО
	|	ВЫБОР
	|		КОГДА ЦенныеБумаги.ДатаПриемаНаОбслуживание <> ДАТАВРЕМЯ(1, 1, 1)
	|				И ЦенныеБумаги.ДатаСнятияСОбслуживания = ДАТАВРЕМЯ(1, 1, 1)
	|			ТОГДА 0
	|		ИНАЧЕ 1
	|	КОНЕЦ,
	|	ВЫБОР
	|		КОГДА ДЛИНАСТРОКИ(ЕСТЬNULL(КодыЗагрузки.Код, """")) > 0
	|			ТОГДА ВЫБОР
	|					КОГДА СТРНАЙТИ(ЕСТЬNULL(КодыЗагрузки.Код, """"), ""/"") = 0
	|						ТОГДА 0
	|					ИНАЧЕ 1
	|				КОНЕЦ
	|		ИНАЧЕ 2
	|	КОНЕЦ";
	Запрос.УстановитьПараметр("НомерРегистрации", СокрЛП(НомерРегистрации));
	Запрос.УстановитьПараметр("ISIN", СокрЛП(ISIN));
	Запрос.УстановитьПараметр("ДатаОтбора", ТекущаяДатаСеанса());
	
	Если НомерРегистрации = Неопределено Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "И ЦенныеБумаги.НомерРегистрации = &НомерРегистрации", "");
	КонецЕсли;
	Если ВернутьВсеНайденныеПоУсловию Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "ПЕРВЫЕ 1", " ");
	КонецЕсли;
	
	РезультатЗапроса = Запрос.Выполнить();
	Если Не РезультатЗапроса.Пустой() Тогда
		Если ВернутьВсеНайденныеПоУсловию Тогда
			ЦеннаяБумага = РезультатЗапроса.Выгрузить().ВыгрузитьКолонку("ЦеннаяБумага");
		Иначе
			Выборка = РезультатЗапроса.Выбрать();
			Выборка.Следующий();
			ЦеннаяБумага = Выборка.ЦеннаяБумага;
		КонецЕсли;
	КонецЕсли;
	
	Возврат ЦеннаяБумага;
КонецФункции

// Возвращает ценную бумагу по коду системы RuData
//
// Параметры:
//  КодЗагрузки	 - Строка	 - Код ценной бумаги в RuData (fintoolid)
//  ISIN		 - Строка	 - ISIN ценной бумаги
// 
// Возвращаемое значение:
//  СправочникСсылка.ЦенныеБумаги - ЦБ или пустую ссылку если ЦБ найти не удалось
//
Функция ЦеннаяБумагаПоКодуRuData(КодЗагрузки, ISIN) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	ВЫРАЗИТЬ(КодыЗагрузки.Владелец КАК Справочник.ЦенныеБумаги).Ссылка КАК ЦеннаяБумага
	|ИЗ
	|	Справочник.КодыЗагрузки КАК КодыЗагрузки
	|ГДЕ
	|	ВЫРАЗИТЬ(КодыЗагрузки.Биржа КАК Справочник.КлассификаторыЗагрузки).Ссылка = &RuData
	|	И КодыЗагрузки.Код = &Код
	|	И КодыЗагрузки.Владелец ССЫЛКА Справочник.ЦенныеБумаги
	|	И НЕ КодыЗагрузки.ПометкаУдаления";
	
	Запрос.УстановитьПараметр("RuData",	 Справочники.КлассификаторыЗагрузки.RuData);
	Запрос.УстановитьПараметр("Код",	 СокрЛП(КодЗагрузки));
	
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.ЦеннаяБумага;
	ИначеЕсли ЗначениеЗаполнено(ISIN) Тогда
		ЦБпоISIN = ЦеннаяБумагаПоРегНомеруИISIN(ISIN, Неопределено);
		Если ЗначениеЗаполнено(ЦБпоISIN) Тогда
			Возврат ЦБпоISIN;
		Иначе
			Возврат Справочники.ЦенныеБумаги.ПустаяСсылка();
		КонецЕсли;
	Иначе
		Возврат Справочники.ЦенныеБумаги.ПустаяСсылка();
	КонецЕсли;
	
КонецФункции

// Возвращает отчет о ценной бумаге из Интерфакс
//
// Параметры:
//  ISIN - Произвольный	 - Строка \ Массив, либо строка = ISIN ценной бумаги, либо массив строк = ISIN
// 
// Возвращаемое значение:
//  ТабличныйДокумент - Отчет
//
Функция ИнтерфаксОтчетОЦеннойБумаге(ISIN) Экспорт
	
	ВходныеПараметры = Новый Структура;
	Если ТипЗнч(ISIN) = Тип("Строка") Тогда
		ISINs = ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(ISIN);
	Иначе
		ISINs = ISIN;
	КонецЕсли;
	ВходныеПараметры.Вставить("ISINs", ISINs);
	ВходныеПараметры.Вставить("ДатаВремяОбновленияДанных", Дата(1, 1, 1));
	ВходныеПараметры.Вставить("ФильтрСтатусовЦБ", "");	// Что бы фильтрации по умолчанию не было и можно было получить отчет и бумагах
														// в неактуальном статусе тоже.
	ВходныеПараметры.Вставить("ЭтоОтчет", Истина);
	
	ВыходныеПараметры = RuDataAPI.ДанныеДляСозданияОбновленияЦенныхБумаг(ВходныеПараметры);
	Если ЗначениеЗаполнено(ВыходныеПараметры.ТаблицаДанныхЦБ) Тогда
		
		ТабличныйДокумент = ОбщегоНазначения.ДанныеТаблицыЗначенийВТабличныйДокументСКД(ВыходныеПараметры.ТаблицаДанныхЦБ);
		ТабличныйДокумент.ОриентацияСтраницы = ОриентацияСтраницы.Ландшафт;
		Возврат ТабличныйДокумент;
		
	Иначе
		Возврат Неопределено;
	КонецЕсли;
	
КонецФункции

// Возвращает параметры купона: НомерКупона, ДатаВыпуска, ДатаПогашения, Купон(% годовых), Сумма, СрокОбращения
//
// Параметры:
//  ЦеннаяБумага		 - СправочникСсылка.ЦенныеБумаги - Ценная бумага
//  ДатаФиксацииСписка	 - Дата							 - Дата фиксации списка
//  ИмяПараметра		 - Строка						 - Имя выходного параметра
// 
// Возвращаемое значение:
//   - Произвольный - Если указано имя параметра, то возвращает его значение, Иначе - возвращает структуру параметров
//
Функция ПараметрыКупонаПоДатеФиксации(ЦеннаяБумага, ДатаФиксацииСписка, ИмяПараметра = Неопределено) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	ЦенныеБумагиКупоны.НомерКупона КАК НомерКупона,
	|	ЦенныеБумагиКупоны.ДатаВыпуска КАК ДатаВыпуска,
	|	ЦенныеБумагиКупоны.ДатаПогашения КАК ДатаПогашения,
	|	ЦенныеБумагиКупоны.Купон КАК Купон,
	|	ЦенныеБумагиКупоны.Сумма КАК Сумма,
	|	ЦенныеБумагиКупоны.СрокОбращения КАК СрокОбращения
	|ИЗ
	|	Справочник.ЦенныеБумаги.Купоны КАК ЦенныеБумагиКупоны
	|ГДЕ
	|	ЦенныеБумагиКупоны.Ссылка = &Ссылка
	|	И ЦенныеБумагиКупоны.ДатаФиксацииСписка = &ДатаФиксацииСписка";
	
	Запрос.УстановитьПараметр("Ссылка", ЦеннаяБумага);
	Запрос.УстановитьПараметр("ДатаФиксацииСписка", ДатаФиксацииСписка);
	
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() Тогда
		Возврат Неопределено;
	ИначеЕсли ИмяПараметра = Неопределено Тогда
		Параметры = РезультатЗапроса.Выгрузить();
		Возврат ОбщегоНазначения.СтрокаТаблицыЗначенийВСтруктуру(Параметры[0]);
	Иначе
		ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
		ВыборкаДетальныеЗаписи.Следующий();
