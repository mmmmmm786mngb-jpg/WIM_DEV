// Возвращает валюту по коду
//
// Параметры:
//  Код	 - Произвольный - Код валюты строкой или числом
// 
// Возвращаемое значение:
//   - СправочникСсылка.Валюты - Ссылка на валюту
//
Функция ВалютаПоКоду(Знач Код) Экспорт
	
	Код = СтроковыеФункцииКлиентСервер.ДополнитьСтроку(Строка(Код), 3);
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	Валюты.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.Валюты КАК Валюты
	|ГДЕ
	|	НЕ Валюты.ПометкаУдаления
	|	И Валюты.Код = &Код";
	
	Запрос.УстановитьПараметр("Код", Код);
	
	РезультатЗапроса = Запрос.Выполнить();
	Если Не РезультатЗапроса.Пустой() Тогда
		ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
		ВыборкаДетальныеЗаписи.Следующий();
		
		Возврат ВыборкаДетальныеЗаписи.Ссылка;
		
	КонецЕсли;
	
	Возврат Справочники.Валюты.ПустаяСсылка();
	
КонецФункции

// Возвращает массив валют, курсы которых загружаются с API Интерфакс.
//
// Параметры:
//  ИсключаяБазовыеВалюты	 - Булево	 - Признак исключения валюты Валюты регламентированного учета
//  РеквизитСортировки		 - Строка	 - Имя реквизита сортировки
// 
// Возвращаемое значение:
//   - Массив - Валюты
//
Функция ЗагружаемыеВалюты(ИсключаяБазовыеВалюты = Истина, РеквизитСортировки = "НаименованиеПолное") Экспорт
	
	Запрос = Новый Запрос;
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Валюты.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.Валюты КАК Валюты
	|ГДЕ
	|	НЕ Валюты.ПометкаУдаления
	|	И ВЫБОР
	|			КОГДА &ВсеВалюты
	|				ТОГДА ИСТИНА
	|			ИНАЧЕ НЕ Валюты.Ссылка В (&БазовыеВалюты)
	|		КОНЕЦ
	|
	|УПОРЯДОЧИТЬ ПО
	|	&РеквизитСортировки";
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "&РеквизитСортировки", "Валюты." + РеквизитСортировки);
	
	Запрос.УстановитьПараметр("ВсеВалюты", Не ИсключаяБазовыеВалюты);
	Запрос.УстановитьПараметр("БазовыеВалюты", ПолучитьСписокБазовыхВалют());
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() Тогда
		Возврат Новый Массив;
	Иначе
		Возврат РезультатЗапроса.Выгрузить().ВыгрузитьКолонку("Ссылка");
	КонецЕсли;
	
КонецФункции

// Возвращает массив базовых валют.
// 
// Возвращаемое значение:
//   - Массив - Валюты
//
Функция ПолучитьСписокБазовыхВалют() Экспорт
	
	СписокВалют	= Новый Массив;
	СписокВалют.Добавить(ОбщегоНазначенияПовтИсп.ЗначениеКонстанты("ВалютаРегламентированногоУчета"));
	
	Возврат СписокВалют;
	
КонецФункции

// Возвращает кеш валют с курсом
//
// Параметры:
//  Период	 - Дата	 - Дата на которую определяется курс валюты
// 
// Возвращаемое значение:
//   - Соответствие - соотвествие Названия валюты и Структуры {ссылка \ курс}
//
Функция КешВалют(Период) Экспорт
	
	Кеш = Новый Соответствие;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Период", Период);
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Валюты.Ссылка КАК Ссылка,
	|	ВЫБОР
	|		КОГДА ЕСТЬNULL(КурсыВалют.Кратность, 0) = 0
	|			ТОГДА 1
	|		ИНАЧЕ КурсыВалют.Курс / КурсыВалют.Кратность
	|	КОНЕЦ КАК Курс,
	|	ВРЕГ(СОКРЛП(ВЫРАЗИТЬ(Валюты.Наименование КАК СТРОКА))) КАК Наименование
	|ИЗ
	|	Справочник.Валюты КАК Валюты
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.КурсыВалют.СрезПоследних(&Период, ) КАК КурсыВалют
	|		ПО Валюты.Ссылка = КурсыВалют.Валюта
	|ГДЕ
	|	НЕ Валюты.ПометкаУдаления";
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		КешЗначение = Новый Структура("Валюта, Курс", ВыборкаДетальныеЗаписи.Ссылка, ВыборкаДетальныеЗаписи.Курс);
		Кеш.Вставить(ВыборкаДетальныеЗаписи.Наименование, КешЗначение);
	КонецЦикла;
	КешЗначение = Новый Структура("Валюта, Курс", ОбщегоНазначенияПовтИсп.ЗначениеКонстанты("ВалютаРегламентированногоУчета"), 1);
	Кеш.Вставить("RUB", КешЗначение);
	Кеш.Вставить("RUR", КешЗначение);
	
	Возврат Кеш;
	
КонецФункции

#КонецОбласти
