
#Область ПрограммныйИнтерфейс

// Возвращает ссылку на валюту Рубль
// 
// Возвращаемое значение:
//   - СправочникСсылка.Валюты - Валюта рубль
//
Функция Рубль() Экспорт
	ВалютаРубль = ОбщегоНазначенияПовтИсп.ЗначениеКонстанты("ВалютаРегламентированногоУчета");
	Если ЗначениеЗаполнено(ВалютаРубль) Тогда
		Возврат ВалютаРубль;
	Иначе
		Возврат НайтиПоКоду("643");
	КонецЕсли;
КонецФункции

// Возвращает представление валюты
//
// Параметры:
//  Валюта	 - СправочникСсылка.Валюты	 - Валюта
//  Подробно - Булево					 - Представление с полным наименованием
// 
// Возвращаемое значение:
//   - Строка - Представление валюты
//
Функция ПредставлениеВалюты(Валюта, Подробно = Ложь) Экспорт
	Если ЗначениеЗаполнено(Валюта) И ТипЗнч(Валюта) = Тип("СправочникСсылка.Валюты") Тогда
		
		Если Валюта = Рубль() Тогда
			Представление = "RUB";
		Иначе
			Представление = СокрЛП(Валюта.Наименование);
		КонецЕсли;
		
		Если Подробно Тогда
			Представление = Представление + " [" + СокрЛП(Валюта.НаименованиеПолное) + "]";
		КонецЕсли;
		
		Возврат Представление;
	Иначе
		Возврат СокрЛП(Валюта);
	КонецЕсли;
КонецФункции

