// Возвращает виды КД РСВ, которые необходимо отражать в журналах входящих и исходящих
// 
// Возвращаемое значение:
//  Массив - виды КД
//
Функция ВидыКДРСВДляЖурналовВходящихИсходящих() Экспорт
	
	ВидыКД = Новый Массив;
	ВидыКД.Добавить(НайтиПоКоду("DSCL"));
	ВидыКД.Добавить(НайтиПоКоду("OTHR"));
	
	Возврат ВидыКД;
	
КонецФункции

// Возвращает истину если тип вида корпоративного действия Доходы.
//
// Параметры:
//  ВидКорпоративногоДействия	 - СправочникСсылка.ВидыКорпоративныхДействий, Строка, 	 - ссылка на элемент справочника или код вида корпоративного действия
// 
// Возвращаемое значение:
//  Булево 
//
Функция ЭтоКорпоративноедействиеДоходы(ВидКорпоративногоДействия) Экспорт
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	ВидыКорпоративныхДействий.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.ВидыКорпоративныхДействий КАК ВидыКорпоративныхДействий
	|ГДЕ
	|	ВидыКорпоративныхДействий.ТипКорпоративныхДействий = &ТипКорпоративныхДействийДоход
	|	И НЕ ВидыКорпоративныхДействий.ПометкаУдаления
	|	И &УсловиеОтбора");
	
	Если ТипЗнч(ВидКорпоративногоДействия) = Тип("Строка") Тогда 
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеОтбора", "ВидыКорпоративныхДействий.Код = &УсловиеОтбора");
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеОтбора", "ВидыКорпоративныхДействий.Ссылка = &УсловиеОтбора");
	КонецЕсли;
	
	Запрос.УстановитьПараметр("ТипКорпоративныхДействийДоход", Перечисления.ТипыКорпоративныхДействий.Доход);
	Запрос.УстановитьПараметр("УсловиеОтбора", ВидКорпоративногоДействия);
	
	Результат = Запрос.Выполнить();
	Возврат Не Результат.Пустой();
	
КонецФункции
