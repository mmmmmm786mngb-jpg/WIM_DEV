
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	мВалютаРегламентированногоУчета = Константы.ВалютаРегламентированногоУчета.Получить();
	
	Если НЕ ЗначениеЗаполнено(Объект.Ссылка) Тогда
		Если ОбщегоНазначения.ЗначениеНеЗаполнено(Объект.ВидСчета) Тогда
			Объект.ВидСчета = Элементы.ВидСчета.СписокВыбора[0];
		КонецЕсли;
		
		Если ОбщегоНазначения.ЗначениеНеЗаполнено(Объект.ВалютаДенежныхСредств) Тогда
			Объект.ВалютаДенежныхСредств = мВалютаРегламентированногоУчета;
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПередЗаписью(Отказ, ПараметрыЗаписи)
	
	Если ЗначениеЗаполнено(Объект.НомерСчета) И ЗначениеЗаполнено(Объект.Банк) И Не ЗначениеЗаполнено(Объект.ТипНазначения) Тогда
		ТекстСообщения = НСтр("ru = 'Поле ""Тип счета"" не заполнено'");
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения, , "Объект.ТипНазначения", , Отказ);
	КонецЕсли;
	
	Если Не СтроковыеФункцииКлиентСервер.ТолькоЦифрыВСтроке(СокрЛП(Объект.НомерСчета))
			И Вопрос("В составе номера банковского счета присутствуют не только цифры. 
		|Возможно, номер указан неправильно. Записать?", РежимДиалогаВопрос.ДаНет) = КодВозвратаДиалога.Нет Тогда
		
		Отказ = Истина;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПослеЗаписи(ПараметрыЗаписи)
	
	Если ВладелецФормы <> Неопределено Тогда
	
		ОповеститьОВыборе(Объект.Ссылка);
	
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	ЗаполнитьТекстКорреспондента();
	УстановитьВидимость(ЭтотОбъект);
	ЗакрыватьПриВыборе = Ложь;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовФормы

&НаКлиенте
Процедура БанкДляРасчетовПриИзменении(Элемент)
	ЗаполнитьТекстКорреспондента();
КонецПроцедуры

&НаКлиенте
Процедура БанкПриИзменении(Элемент)
	ЗаполнитьТекстКорреспондента();
КонецПроцедуры

&НаКлиенте
Процедура НомерСчетаПриИзменении(Элемент)
	ЗаполнитьТекстКорреспондента();
КонецПроцедуры

&НаКлиенте
Процедура ВалютаДенежныхСредствПриИзменении(Элемент)
	УстановитьВидимость(ЭтотОбъект);
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиентеНаСервереБезКонтекста
Процедура УстановитьВидимость(Форма)
	
	ЭлементыФормы = Форма.Элементы;
	Объект = Форма.Объект;

	Если (ОбщегоНазначения.ЗначениеНеЗаполнено(Объект.ВалютаДенежныхСредств))
	 ИЛИ (Объект.ВалютаДенежныхСредств = Форма.мВалютаРегламентированногоУчета) Тогда
		ЭлементыФормы.НомерИДатаРазрешения.Видимость = Ложь;
		
	Иначе
		ЭлементыФормы.НомерИДатаРазрешения.Видимость = Истина;
		
	КонецЕсли;
	
КонецПроцедуры // УстановитьВидимость()

&НаСервереБезКонтекста
Функция ЗначениеРеквизитаНаСервере(Источник, ИмяРеквизита)
	Перем Результат;
	Если Источник <> Неопределено Тогда
		Результат = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Источник, ИмяРеквизита);
		
	КонецЕсли; 
	
	Возврат Результат;
	
КонецФункции

&НаКлиенте
Процедура ЗаполнитьТекстКорреспондента()
	
	Если НЕ ПравоНаИзменениеДоступноНаСервере() Тогда
		Возврат;
	КонецЕсли;
	
	мВладелец = Объект.Владелец;
	Если ОбщегоНазначения.ЗначениеНеЗаполнено(мВладелец) Тогда
		Возврат;
	КонецЕсли;

	СтрКорреспондента = СокрЛП(ОбщегоНазначения.ЗначениеРеквизитаОбъекта(мВладелец, "НаименованиеПолное"));

	Если НЕ Объект.БанкДляРасчетов.Пустая() Тогда
		СтрКорреспондента = СтрКорреспондента + " р/с " + Объект.НомерСчета
			+ " в " + Объект.Банк + " " + ЗначениеРеквизитаНаСервере(Объект.Банк, "Город");
	КонецЕсли;

	Объект.ТекстКорреспондента = СтрКорреспондента;
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ПравоНаИзменениеДоступноНаСервере()
	
	Результат = ОбщегоНазначенияВызовСервера.ПравоНаИзменениеДоступно(Метаданные.Справочники.БанковскиеСчета);
	Возврат Результат;
	
КонецФункции

#КонецОбласти