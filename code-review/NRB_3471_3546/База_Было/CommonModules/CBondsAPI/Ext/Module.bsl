Функция ТаблицаКотировокОблигаций(ПараметрыЗагрузки)
	
	Постфикс = "tradings_new";
	
	МассивФильтров = Новый Массив;
	
	ЭтоЧисловойФильтр = Истина;
	ФильтрWSDL = ФильтрШаблонWSDL(ЭтоЧисловойФильтр, "date", "le", ПараметрыЗагрузки.ДатаОкончания);
	МассивФильтров.Добавить(ФильтрWSDL);
	
	ЭтоЧисловойФильтр = Истина;
	ФильтрWSDL = ФильтрШаблонWSDL(ЭтоЧисловойФильтр, "date", "ge", ПараметрыЗагрузки.ДатаНачала);
	МассивФильтров.Добавить(ФильтрWSDL);
	
	Если ЗначениеЗаполнено(ПараметрыЗагрузки.СписокИдентификаторовПлощадок) Тогда
		ЭтоЧисловойФильтр = Истина;
		ФильтрWSDL = ФильтрШаблонWSDL(ЭтоЧисловойФильтр,
			"trading_ground_id", "in", "![CDATA[;" + ПараметрыЗагрузки.СписокИдентификаторовПлощадок + ";]]");
		МассивФильтров.Добавить(ФильтрWSDL);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ПараметрыЗагрузки.СписокISIN) Тогда
		ЭтоЧисловойФильтр = Ложь;
		ФильтрWSDL = ФильтрШаблонWSDL(ЭтоЧисловойФильтр, "isin_code", "in", "![CDATA[;" + ПараметрыЗагрузки.СписокISIN + ";]]");
		МассивФильтров.Добавить(ФильтрWSDL);
	КонецЕсли;
	
	ДополнительныеПараметры = Новый Структура;
	ДополнительныеПараметры.Вставить("Постфикс", Постфикс);
	ДополнительныеПараметры.Вставить("ПараметрыЖурналаРегистрации", ПараметрыЗагрузки.ПараметрыЖурналаРегистрации);
	
	ТаблицаДанныхИзCBonds = ТаблицаДанныхИзCBonds(ПараметрыЗагрузки.ПараметрыПодключения, ДополнительныеПараметры,
		ПараметрыЗагрузки.Отказ, ПараметрыЗагрузки.ТекстОтказа,
		МассивФильтров, ПараметрыЗагрузки.ИдентификаторыПолей, ПараметрыЗагрузки.ЛогПолученныхДанных);
	
	Если ТаблицаДанныхИзCBonds = Неопределено Тогда
		Возврат Новый ТаблицаЗначений;
	КонецЕсли;
	
	Возврат ТаблицаДанныхИзCBonds;
	
КонецФункции

