
#Область ПрограммныйИнтерфейс

// Функция - Подключение инициализировать
//
// Параметры:
//  Соединение			 - WSОпределения - Установленное соединение
//  ПараметрыПодключения - Структура	 - Параметры подключения, см. тело
//  Отказ				 - Булево		 - Признак отказа
//  ТекстОтказа			 - Строка		 - Описание ошибки
// 
// Возвращаемое значение:
//   - Булево - Статус подключения
//
Функция ПодключениеИнициализировать(Соединение, ПараметрыПодключения, Отказ, ТекстОтказа) Экспорт
	
	Если Не ПараметрыПодключенияWSDL(ПараметрыПодключения, Отказ, ТекстОтказа) Тогда
		Возврат Ложь;
	КонецЕсли;
	ПараметрыПодключения.Вставить("WSОпределение", Соединение);
	Возврат WSОпределениеИнициализировать(ПараметрыПодключения, Отказ, ТекстОтказа);
	
КонецФункции

// BSLLS:LatinAndCyrillicSymbolInWord-off

// Метод /services/wsdl/get_trading_grounds. Получить иерархию торговых площадок/источников, используемых Cbonds.
//
// Параметры:
//  Отказ				 - Булево			 - Признак отказа
//  ТекстОтказа			 - Строка			 - Описание ошибки
//  ЛогПолученныхДанных	 - ТекстовыйДокумент - Логирование
// 
// Возвращаемое значение:
//   - ТаблицаЗначенй - Таблица торговых площадок Cbonds, см. описание метода get_trading_grounds
//
Функция ДанныеМетода_get_trading_grounds(Отказ, ТекстОтказа, ЛогПолученныхДанных = Неопределено) Экспорт
	
	Постфикс = "trading_grounds";
	
	ТаблицаТорговыхПлощадок = Новый Массив;
	
	Если Отказ Тогда
		Возврат ТаблицаТорговыхПлощадок;
	КонецЕсли;
	
	Соединение = Неопределено;
	ПараметрыПодключения = "";
	Если Не ПодключениеИнициализировать(Соединение, ПараметрыПодключения, Отказ, ТекстОтказа) Тогда
		Возврат ТаблицаТорговыхПлощадок;
	КонецЕсли;
	
	ПараметрыЖурналаРегистрации =
		Новый Структура("ОставитьЗаписьВЖурналеРегистрацииВызовов, Комментарий", Истина, "Запрос площадок");
	ДополнительныеПараметры = Новый Структура;
	ДополнительныеПараметры.Вставить("Постфикс", Постфикс);
	ДополнительныеПараметры.Вставить("ПараметрыЖурналаРегистрации", ПараметрыЖурналаРегистрации);
	
	ТаблицаТорговыхПлощадок = ТаблицаДанныхИзCBonds(ПараметрыПодключения, ДополнительныеПараметры,
		Отказ, ТекстОтказа, , Новый Массив, ЛогПолученныхДанных);
	ТаблицаТорговыхПлощадок.Колонки.Добавить("id_parent", ОбщегоНазначения.ОписаниеТипаЧисло(1));
	
	Возврат ОбщегоНазначения.ТаблицаЗначенийВМассив(ТаблицаТорговыхПлощадок);
	
КонецФункции

// Метод /services/wsdl/get_tradings_new. Итоги торгов облигациями и еврооблигациями.
//
// Параметры:
//  ВходящиеПараметры						 - Структура - Входящие параметры
//  Отказ									 - Булево	 - Признак отказа
//  ТекстОтказа								 - Строка	 - Описание ошибки
//  ЛогПолученныхДанных						 - ТекстовыйДокумент - Логирование
//  Соединение								 - WSОпределения	 - Установленное соединение
//  ОставитьЗаписьВЖурналеРегистрацииВызовов - Булево			 - Делать запись в журнале регистрации вызовов
//  Комментарий								 - Строка			 - Комментарий в журнале регистрации вызовов
// 
// Возвращаемое значение:
//   - Массив - Массив структур котировок Cbonds, см. описание метода get_tradings_new
//
Функция ДанныеМетода_get_tradings_new(ВходящиеПараметры,
	Отказ,
	ТекстОтказа,
	ЛогПолученныхДанных,
	Соединение,
	ОставитьЗаписьВЖурналеРегистрацииВызовов = Истина,
	Комментарий = "") Экспорт
	
	Результат = Новый Массив;
	Если Отказ Тогда
		Возврат Результат;
	КонецЕсли;
	
	ПараметрыПодключения = "";
	Если Не ПодключениеИнициализировать(Соединение, ПараметрыПодключения, Отказ, ТекстОтказа) Тогда
		Возврат Результат;
	Иначе
		Соединение = ПараметрыПодключения.WSОпределение;
	КонецЕсли;
	
	ПараметрыЖурналаРегистрации =
		Новый Структура("ОставитьЗаписьВЖурналеРегистрацииВызовов, Комментарий", ОставитьЗаписьВЖурналеРегистрацииВызовов, Комментарий);
	
	ПараметрыЗагрузки = ПараметрыЗагрузкиКотировок();
	
	ПараметрыЗагрузки.ПараметрыПодключения			 = ПараметрыПодключения;
	
	ПараметрыЗагрузки.ДатаНачала					 = ВходящиеПараметры.ДатаНачала;
	ПараметрыЗагрузки.ДатаОкончания 				 = ВходящиеПараметры.ДатаОкончания;
	ПараметрыЗагрузки.СписокИдентификаторовПлощадок	 = СтрСоединить(ВходящиеПараметры.МассивИдентификаторовПлощадок, ";");
	ПараметрыЗагрузки.СписокISIN					 = СтрСоединить(ВходящиеПараметры.МассивISIN, ";");
	ПараметрыЗагрузки.ИдентификаторыПолей			 = ВходящиеПараметры.МассивИдентификаторовПолей;
	
	// Сохраняем полученные даные в логе
	Если ТипЗнч(ЛогПолученныхДанных) = Тип("ТекстовыйДокумент") Тогда
		ЛогПолученныхДанных.ДобавитьСтроку("Параметры запроса:");
		ЛогПолученныхДанных.ДобавитьСтроку(" -- Дата:		 " + ВходящиеПараметры.ДатаНачала);
		ЛогПолученныхДанных.ДобавитьСтроку(" -- Площадки:	 " + ПараметрыЗагрузки.СписокИдентификаторовПлощадок);
		ЛогПолученныхДанных.ДобавитьСтроку(" -- Поля:		 " + СтрСоединить(ВходящиеПараметры.МассивИдентификаторовПолей, ";"));
		ЛогПолученныхДанных.ДобавитьСтроку(" -- ISIN:		 " + ПараметрыЗагрузки.СписокISIN);
		ЛогПолученныхДанных.ДобавитьСтроку("Тело ответа:");
	КонецЕсли;
	
	ПараметрыЗагрузки.ЛогПолученныхДанных 			 = ЛогПолученныхДанных;
	ПараметрыЗагрузки.ТекстОтказа					 = ТекстОтказа;
	ПараметрыЗагрузки.Отказ							 = Отказ;
	
	ПараметрыЗагрузки.ПараметрыЖурналаРегистрации	 = ПараметрыЖурналаРегистрации;
	
	Если ТестированиеVanessa.ЭтоТест() Тогда
		ТаблицаКотировок = ИмитацияОтветаМетода_get_tradings_new(ПараметрыЗагрузки);
	Иначе
		ТаблицаКотировок = ТаблицаКотировокОблигаций(ПараметрыЗагрузки);
	КонецЕсли;
	
	ЛогПолученныхДанных	 = ПараметрыЗагрузки.ЛогПолученныхДанных;
	ТекстОтказа			 = ПараметрыЗагрузки.ТекстОтказа;
	Отказ				 = ПараметрыЗагрузки.Отказ; // BSLLS:UsingCancelParameter-off
	
	Возврат ОбщегоНазначения.ТаблицаЗначенийВМассив(ТаблицаКотировок);
	
КонецФункции

