Функция ПараметрыВнешнегоИсточника(Отказ, ТекстОтказа) Экспорт
	
	СтруктураНастроек = Новый Структура;
	
	Источник = ПланыВидовХарактеристик.ВнешниеИсточники.ЗагрузкаИзВнешнейAPICBonds;
	
	Если ТестированиеVanessa.ЭтоТест() Тогда
		Настройка = Неопределено;
	Иначе
		Настройка = ВнешниеДанные.ПолучитьПараметрыВнешнегоИсточника(Источник).Настройка;
		Если Не ЗначениеЗаполнено(Настройка) Тогда
			Отказ = Истина;
			ТекстОтказа = "Не определен внешний источник " + Источник;
			Возврат СтруктураНастроек;
		КонецЕсли;
	КонецЕсли;
	
	СтруктураНастроек = Новый Структура;
	
	Если ЗначениеЗаполнено(Настройка) Тогда
		СтруктураНастроек.Вставить("HTTPСервисАдресСервера"								, Настройка.HTTPСервисАдресСервера);
		СтруктураНастроек.Вставить("HTTPСервисПорт"										, Настройка.HTTPСервисПорт);
		СтруктураНастроек.Вставить("HTTPСервисТаймаут"									, Настройка.HTTPСервисТаймаут);
		СтруктураНастроек.Вставить("HTTPСервисЗащищенноеСоединение"						, Настройка.HTTPСервисЗащищенноеСоединение);
		СтруктураНастроек.Вставить("HTTPСервисПользователь"								, Настройка.HTTPСервисПользователь);
		СтруктураНастроек.Вставить("HTTPСервисПароль"									, Настройка.HTTPСервисПароль);
		СтруктураНастроек.Вставить("HTTPСервисАдресРесурсаАутентификации"				, Настройка.HTTPСервисАдресРесурсаАутентификации);
		СтруктураНастроек.Вставить("HTTPСервисАдресРесурса"								, Настройка.HTTPСервисАдресРесурса);
	Иначе
		СтруктураНастроек.Вставить("HTTPСервисАдресСервера"								, "ws2.cbonds.info");
		СтруктураНастроек.Вставить("HTTPСервисПорт"										, 443);
		СтруктураНастроек.Вставить("HTTPСервисТаймаут"									, 300);
		СтруктураНастроек.Вставить("HTTPСервисЗащищенноеСоединение"						, Истина);
		СтруктураНастроек.Вставить("HTTPСервисПользователь"								, "");
		СтруктураНастроек.Вставить("HTTPСервисПароль"									, "");
		СтруктураНастроек.Вставить("HTTPСервисАдресРесурсаАутентификации"				, "");
		СтруктураНастроек.Вставить("HTTPСервисАдресРесурса"								, "/services/wsdl");
	КонецЕсли;
	
	СтруктураНастроек.Вставить("ПроксиСерверАдрес",			 ОбщегоНазначенияПовтИсп.ЗначениеГлобальногоПараметра("ПроксиСерверАдрес"));
	СтруктураНастроек.Вставить("ПроксиСерверПорт",			 ОбщегоНазначенияПовтИсп.ЗначениеГлобальногоПараметра("ПроксиСерверПорт", 3128));
	СтруктураНастроек.Вставить("ПроксиСерверИспользовать",
		ОбщегоНазначенияПовтИсп.ЗначениеГлобальногоПараметра("ПроксиСерверИспользовать", Ложь));
	
	СтруктураНастроек.Вставить("ИмяИсточника",				 Источник.Наименование);
	
	Возврат СтруктураНастроек;
	
КонецФункции

Функция ПараметрыПодключенияWSDL(ПараметрыПодключения, Отказ, ТекстОтказа)
	
	НастройкиСоединения = ПараметрыВнешнегоИсточника(Отказ, ТекстОтказа);
	Если Отказ Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Если НастройкиСоединения.ПроксиСерверИспользовать И Не ТестированиеVanessa.ЭтоТест() Тогда
		ПроксиСервер = Новый ИнтернетПрокси;
		ПроксиСервер.Установить("https", НастройкиСоединения.ПроксиСерверАдрес, НастройкиСоединения.ПроксиСерверПорт);
	Иначе
		ПроксиСервер = Неопределено;
	КонецЕсли;
	
	Если НастройкиСоединения.Свойство("HTTPСервисАдресСервера") И ЗначениеЗаполнено(НастройкиСоединения.HTTPСервисАдресСервера) Тогда
		HTTPСервисАдресСервера = НастройкиСоединения.HTTPСервисАдресСервера;
	Иначе
		HTTPСервисАдресСервера = "ws.cbonds.info";
	КонецЕсли;
	
	ПараметрыПодключения = Новый Структура;
	ПараметрыПодключения.Вставить("Сервер"					, HTTPСервисАдресСервера);
	ПараметрыПодключения.Вставить("Порт"					, НастройкиСоединения.HTTPСервисПорт);
	ПараметрыПодключения.Вставить("Таймаут"					, НастройкиСоединения.HTTPСервисТаймаут);
	ПараметрыПодключения.Вставить("ЗащищенноеСоединение"	, Новый ЗащищенноеСоединениеOpenSSL(Неопределено, Неопределено));
	ПараметрыПодключения.Вставить("Прокси"					, ПроксиСервер);
	ПараметрыПодключения.Вставить("Логин"					, НастройкиСоединения.HTTPСервисПользователь);
	ПараметрыПодключения.Вставить("Пароль"					, НастройкиСоединения.HTTPСервисПароль);
	
	Возврат Истина;
	
КонецФункции

Функция WSОпределениеИнициализировать(ПараметрыПодключения, Отказ, ТекстОтказа)
	
	ПервоеПодключение = Ложь;
	URL = "https://" + ПараметрыПодключения.Сервер + "/services/wsdl?login";
	ОписаниеВызова = РегистрыСведений.ЖурналРегистрацииВызовов.НовоеОписаниеВызова(
		"URL = " + URL,
		"ОбщийМодуль.CBondsAPI." + "API_AccountLogin");
	
	Попытка
		СтрокаПодключения = СтрШаблон("https://%1/services/wsdl?login=%2&password=%3",
			ПараметрыПодключения.Сервер, ПараметрыПодключения.Логин, ПараметрыПодключения.Пароль);
			
		УстановленоСоединение = ПараметрыПодключения.Свойство("WSОпределение") И ПараметрыПодключения.WSОпределение <> Неопределено
			Или ТестированиеVanessa.ЭтоТест();
		Если Не УстановленоСоединение Тогда
			ПараметрыПодключения.WSОпределение = Новый WSОпределения(СтрокаПодключения,
				ПараметрыПодключения.Логин, ПараметрыПодключения.Пароль,
				ПараметрыПодключения.Прокси, ПараметрыПодключения.Таймаут, ПараметрыПодключения.ЗащищенноеСоединение);
			ПервоеПодключение = Истина;
		КонецЕсли;
	Исключение
		Отказ = Истина;
		ТекстОшибки = ОбработкаОшибок.КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
		ТекстОтказа = НСтр("ru='Ошибка соединения с CBonds. Техническая информация: '") + ТекстОшибки;
		РегистрыСведений.ЖурналРегистрацииВызовов.ЗафиксироватьНачало(ОписаниеВызова);
		РегистрыСведений.ЖурналРегистрацииВызовов.ЗафиксироватьОшибку(ОписаниеВызова, ТекстОтказа);
		Возврат Ложь;
	КонецПопытки;
	Если ПервоеПодключение Тогда
		РегистрыСведений.ЖурналРегистрацииВызовов.ЗафиксироватьНачало(ОписаниеВызова);
		РегистрыСведений.ЖурналРегистрацииВызовов.ЗафиксироватьОкончание(ОписаниеВызова);
	КонецЕсли;
	
	Возврат Истина;
	
КонецФункции

#КонецОбласти

#Область ПолучениеДанныхCBonds

Функция НовыеПараметрыWSDL(Постфикс, ФильтрWSDL, ИдентификаторыПолей)
	
	ПараметрыWSDL = Новый Структура();
	ПараметрыWSDL.Вставить("Постфикс"				, Постфикс);
	ПараметрыWSDL.Вставить("ФильтрWSDL"				, ФильтрWSDL);
	ПараметрыWSDL.Вставить("ИдентификаторыПолей"	, ИдентификаторыПолей);
	
	Возврат ПараметрыWSDL;
	
КонецФункции

Функция ТаблицаДанныхИзCBonds(ПараметрыПодключения, ДополнительныеПараметры, Отказ, ТекстОтказа,
	ФильтрWSDL = Неопределено, ИдентификаторыПолей = Неопределено,
	ЛогПолученныхДанных = Неопределено)
	
	ПараметрыWSDL = НовыеПараметрыWSDL(ДополнительныеПараметры.Постфикс, ФильтрWSDL, ИдентификаторыПолей);
	QuantityData = Неопределено;
	ДанныеCBonds = ДанныеCBondsAPI(ПараметрыПодключения, ПараметрыWSDL, Отказ, ТекстОтказа, QuantityData, ЛогПолученныхДанных,
		ДополнительныеПараметры.ПараметрыЖурналаРегистрации);
	Если ДанныеCBonds = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	ДанныеCBondsItem = ДанныеCBonds.Items.Item;
	Если ДанныеCBondsItem.Количество() = 0 Тогда
		ТекстОтказа = НСтр("ru='Нет данных по методу " + ДополнительныеПараметры.Постфикс + "'");
		Возврат Неопределено;
	КонецЕсли;
	
	ТаблицаДанныхИзCBonds = НоваяТаблицаДанныхИзCBonds(ДанныеCBonds);
	
	ДанныеCBondsAPIПостранично(ПараметрыПодключения, ПараметрыWSDL, ТаблицаДанныхИзCBonds, ДанныеCBonds, Отказ, ТекстОтказа,
		ЛогПолученныхДанных);
	
	Возврат ТаблицаДанныхИзCBonds;
	
КонецФункции

Функция НоваяТаблицаДанныхИзCBonds(ДанныеCBonds)
	
	ТаблицаДанныхИзCBonds = Новый ТаблицаЗначений;
	Для Каждого Свойство Из ДанныеCBonds.Items.Item[0].Свойства() Цикл
		ТаблицаДанныхИзCBonds.Колонки.Добавить(Свойство.Имя);
	КонецЦикла;
	
	Возврат ТаблицаДанныхИзCBonds;
	
КонецФункции

Функция ДанныеCBondsAPI(ПараметрыПодключения, ПараметрыWSDL, Отказ, ТекстОтказа, QuantityData, ЛогПолученныхДанных,
	ПараметрыЖурналаРегистрации = Неопределено)
	
	ПаузаВСекундах = 61;
	МиниПаузаВСекундах = 2;
	КоличествоПопытокОтправкиЗапросаНаСервер = 3;
	ДанныеCBonds = Неопределено;
	СтрокаXML = "";
	
	Прокси = НовыйПрокси(ПараметрыПодключения, "CbondsDatabaseSoap_" + ПараметрыWSDL.Постфикс, Отказ, ТекстОтказа);
	
	Если Отказ Тогда
		Возврат ДанныеCBonds;
	КонецЕсли;
	
	ПараметрФункции = "";
	Если QuantityData = Неопределено Тогда
		QuantityData = QuantityDataШаблон();
	КонецЕсли;
	Если Не ПараметрФункцииПолучен(ПараметрыПодключения, ПараметрФункции, Прокси, ПараметрыWSDL, Отказ, ТекстОтказа, QuantityData) Тогда
		Прокси = Неопределено;
		Возврат ДанныеCBonds;
	КонецЕсли;
	
	ОставитьЗаписьВЖурналеРегистрацииВызовов = Ложь;
	Комментарий								 = "";
	URL										 = "";
	ОписаниеВызова = НовоеОписаниеВызова(ПараметрыПодключения, ПараметрыWSDL, ПараметрыЖурналаРегистрации,
		ОставитьЗаписьВЖурналеРегистрацииВызовов, Комментарий, URL);
	
	Для НомерПопытки = 1 По КоличествоПопытокОтправкиЗапросаНаСервер Цикл // BSLLS:UnusedLocalVariable-off
		
		Попытка
			
			Выполнить("ДанныеCBonds = Прокси.get_" + ПараметрыWSDL.Постфикс + "(ПараметрФункции)"); // BSLLS:ExecuteExternalCodeInCommonModule-off
			СтрокаXML = СериализованныйОбъект(Прокси, ДанныеCBonds.Items);
			КоличествоСтрокДанных = ДанныеCBonds.Items.Item.Количество();
			Если КоличествоСтрокДанных = 0 Тогда
				ОбщегоНазначенияВызовСервера.Пауза(МиниПаузаВСекундах);
			КонецЕсли;
			Прервать;
			
		Исключение
			ТекстОтказа = СтрШаблон("При получении данных с web-сервиса по функции get_%1 возникла ошибка. Техническая информация: %2",
					ПараметрыWSDL.Постфикс, ОписаниеОшибки());
			// Проверка, если была ошибка по количеству запросов в минуту, то делаем задержку на минуту и выполняем повторно
			Если СтрНайти(ТекстОтказа, "Код ошибки: 900000") > 0 Тогда
				ОбщегоНазначенияВызовСервера.Пауза(ПаузаВСекундах);
			Иначе
				Прокси = Неопределено;
				Отказ = Истина;
				ЗафиксироватьОшибку(ОписаниеВызова, ТекстОтказа, Комментарий, URL);
				Возврат ДанныеCBonds;
			КонецЕсли;
		КонецПопытки;
		
	КонецЦикла;
	ТекстОтказа	 = "";
	Прокси		 = Неопределено;
	
	ЗафиксироватьОкончание(ОписаниеВызова, ОставитьЗаписьВЖурналеРегистрацииВызовов, Комментарий, СтрокаXML,
		ЛогПолученныхДанных);
	
	Возврат ДанныеCBonds;
	
КонецФункции

Функция НовоеОписаниеВызова(ПараметрыПодключения, ПараметрыWSDL, ПараметрыЖурналаРегистрации,
	ОставитьЗаписьВЖурналеРегистрацииВызовов, Комментарий, URL)
	
	Если ПараметрыЖурналаРегистрации = Неопределено Тогда
		ОставитьЗаписьВЖурналеРегистрацииВызовов = Ложь;
		Комментарий = "";
	Иначе
		ОставитьЗаписьВЖурналеРегистрацииВызовов = ПараметрыЖурналаРегистрации.ОставитьЗаписьВЖурналеРегистрацииВызовов;
		Комментарий								 = ПараметрыЖурналаРегистрации.Комментарий;
	КонецЕсли;
	
	URL = "https://" + ПараметрыПодключения.Сервер + "/" + ПараметрыWSDL.Постфикс;
	Если ОставитьЗаписьВЖурналеРегистрацииВызовов Тогда
		ОписаниеВызова = РегистрыСведений.ЖурналРегистрацииВызовов.НовоеОписаниеВызова(
			"URL = " + URL,
			"ОбщийМодуль.CBondsAPI.ДанныеCBondsAPI");
		РегистрыСведений.ЖурналРегистрацииВызовов.ЗафиксироватьНачало(ОписаниеВызова);
	Иначе
		ОписаниеВызова = Неопределено;
	КонецЕсли;
	
	Возврат ОписаниеВызова;
	
КонецФункции

Процедура ЗафиксироватьОшибку(ОписаниеВызова, ТекстОтказа, Комментарий, URL)
	
	Если ОписаниеВызова = Неопределено Тогда
		ОписаниеВызова = РегистрыСведений.ЖурналРегистрацииВызовов.НовоеОписаниеВызова(
			"URL = " + URL,
			"ОбщийМодуль.CBondsAPI.ДанныеCBondsAPI");
		РегистрыСведений.ЖурналРегистрацииВызовов.ЗафиксироватьНачало(ОписаниеВызова);
	КонецЕсли;
	РегистрыСведений.ЖурналРегистрацииВызовов.ЗафиксироватьОшибку(ОписаниеВызова, ТекстОтказа, Комментарий);
	
КонецПроцедуры

Процедура ЗафиксироватьОкончание(ОписаниеВызова, ОставитьЗаписьВЖурналеРегистрацииВызовов, Комментарий, СтрокаXML,
	ЛогПолученныхДанных)
	
	Если ОставитьЗаписьВЖурналеРегистрацииВызовов Тогда
		РегистрыСведений.ЖурналРегистрацииВызовов.ЗафиксироватьОкончание(ОписаниеВызова, Комментарий);
	КонецЕсли;
	
	Если ТипЗнч(ЛогПолученныхДанных) = Тип("ТекстовыйДокумент") Тогда
		ЛогПолученныхДанных.ДобавитьСтроку(СтрокаXML);
	КонецЕсли;
	
КонецПроцедуры

Функция СериализованныйОбъект(Прокси, ОбъектXDTO)
	
	ЗаписьXML = Новый ЗаписьXML;
	ЗаписьXML.УстановитьСтроку();
	Прокси.ФабрикаXDTO.ЗаписатьXML(ЗаписьXML, ОбъектXDTO);
	СтрокаXML = СтрЗаменить(ЗаписьXML.Закрыть(), Символы.ПС, "");
	Возврат СтрокаXML;
	
КонецФункции

// BSLLS:LatinAndCyrillicSymbolInWord-off

Процедура ДанныеCBondsAPIПостранично(ПараметрыПодключения, ПараметрыWSDL, ТаблицаДанныхИзCBonds, ДанныеCBonds, Отказ, ТекстОтказа,
	ЛогПолученныхДанных)
	
	ДанныеCBondsItem = ДанныеCBonds.Items.Item;
	
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(ДанныеCBondsItem, ТаблицаДанныхИзCBonds);
	
	Пока ДанныеCBonds.Offset + ДанныеCBonds.Limit < ДанныеCBonds.Total Цикл
		
		QuantityData = QuantityDataШаблон(ДанныеCBonds.Limit, ДанныеCBonds.Offset + ДанныеCBonds.Limit);
		ДанныеCBonds = ДанныеCBondsAPI(ПараметрыПодключения, ПараметрыWSDL, Отказ, ТекстОтказа, QuantityData, ЛогПолученныхДанных);
		
		Если ДанныеCBonds = Неопределено Тогда
			Возврат;
		КонецЕсли;
		
		ДанныеCBondsItem = ДанныеCBonds.Items.Item;
		ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(ДанныеCBondsItem, ТаблицаДанныхИзCBonds);
		
	КонецЦикла;
	
КонецПроцедуры

Функция НовыйПараметр(ПараметрыПодключения, Прокси, ИмяПараметра, Отказ, ТекстОтказа)
	
	ТипWSПараметра = ПараметрыПодключения.WSОпределение.ФабрикаXDTO.Пакеты.Получить(
		СтрШаблон("https://%1/", ПараметрыПодключения.Сервер)).Получить(ИмяПараметра);
	
	Возврат Прокси.ФабрикаXDTO.Создать(ТипWSПараметра);
	
КонецФункции

// BSLLS:LatinAndCyrillicSymbolInWord-on

Функция НовыйПрокси(ПараметрыПодключения, ИмяТочкиПодключения, Отказ, ТекстОтказа)
	
	Попытка
		Прокси = Новый WSПрокси(ПараметрыПодключения.WSОпределение,
			СтрШаблон("https://%1/", ПараметрыПодключения.Сервер), "CbondsDatabaseWsdl",
				ИмяТочкиПодключения, ПараметрыПодключения.Прокси, ПараметрыПодключения.Таймаут);
		Прокси.Пользователь	 = ПараметрыПодключения.Логин;
		Прокси.Пароль		 = ПараметрыПодключения.Пароль;
	Исключение
		Отказ = Истина;
		ТекстОтказа = НСтр("ru='Не удалось подключиться к серверу CBonds. Информация :'") + ОписаниеОшибки();
		Возврат Неопределено;
	КонецПопытки;
	
	Возврат Прокси;
	
КонецФункции

Функция ПараметрФункцииПолучен(ПараметрыПодключения, ИсходящийПараметрФункции, Прокси, ПараметрыWSDL, Отказ, ТекстОтказа, QuantityData)
	
	ИсходящийПараметрФункции = НовыйПараметр(ПараметрыПодключения, Прокси, "RequestMessage_" + ПараметрыWSDL.Постфикс, Отказ, ТекстОтказа);
	Если Отказ Тогда
		Возврат Ложь;
	КонецЕсли;
	
	ИсходящийПараметрФункции.AuthData = НовыйПараметр(ПараметрыПодключения, Прокси, "AuthData", Отказ, ТекстОтказа);
	Если Отказ Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Если ПараметрыWSDL.ИдентификаторыПолей.Количество() > 0
		И ИсходящийПараметрФункции.Свойства().Получить("ResponseItemFields") <> Неопределено Тогда
		ИсходящийПараметрФункции.ResponseItemFields =
			НовыйПараметр(ПараметрыПодключения, Прокси, "ArrayOfResponseItemFields_" + ПараметрыWSDL.Постфикс, Отказ, ТекстОтказа);
		Для Каждого ФильтрПоля Из ПараметрыWSDL.ИдентификаторыПолей Цикл
			ФильтрПоляПараметр = НовыйПараметр(ПараметрыПодключения, Прокси, "ResponseItemField_" + ПараметрыWSDL.Постфикс, Отказ, ТекстОтказа);
			ФильтрПоляПараметр.ItemField = ФильтрПоля;
			ИсходящийПараметрФункции.ResponseItemFields.ResponseItemField.Добавить(ФильтрПоляПараметр);
		КонецЦикла;
	КонецЕсли;
	
	ИсходящийПараметрФункции.AuthData.login = ПараметрыПодключения.Логин;
	ИсходящийПараметрФункции.AuthData.password = ПараметрыПодключения.Пароль;
	
	Если ЗначениеЗаполнено(QuantityData) И ИсходящийПараметрФункции.Свойства().Получить("QuantityData") <> Неопределено Тогда
		ИсходящийПараметрФункции.QuantityData = НовыйПараметр(ПараметрыПодключения, Прокси, "QuantityData", Отказ, ТекстОтказа);
		ЗаполнитьЗначенияСвойств(ИсходящийПараметрФункции.QuantityData, QuantityData);
	КонецЕсли;
	
	Если ТипЗнч(ПараметрыWSDL.ФильтрWSDL) = Тип("Структура") Тогда
		Фильтр = Новый Массив;
		Фильтр.Добавить(ПараметрыWSDL.ФильтрWSDL);
	ИначеЕсли  ТипЗнч(ПараметрыWSDL.ФильтрWSDL) = Тип("Массив") Тогда
		Фильтр = ПараметрыWSDL.ФильтрWSDL;
	Иначе
		Возврат Истина;
	КонецЕсли;
	
	Если ИсходящийПараметрФункции.Свойства().Получить("Filters") <> Неопределено Тогда
		
		ИсходящийПараметрФункции.Filters =
			НовыйПараметр(ПараметрыПодключения, Прокси, "ArrayOfFilters_" + ПараметрыWSDL.Постфикс, Отказ, ТекстОтказа);
		
		УстановитьПараметрФункцииFilters(ПараметрыПодключения, ИсходящийПараметрФункции, Прокси, ПараметрыWSDL, Отказ, ТекстОтказа, Фильтр);
		
	КонецЕсли;
	
	Возврат Истина;
	
КонецФункции

Процедура УстановитьПараметрФункцииFilters(ПараметрыПодключения, ИсходящийПараметрФункции, Прокси, ПараметрыWSDL, Отказ, ТекстОтказа,
	Фильтр)
	
	Для Каждого ФильтрЭлемент Из Фильтр Цикл
		
		Если ФильтрЭлемент.Числовой Тогда
			ФильтрПараметр = НовыйПараметр(ПараметрыПодключения, Прокси, "NumericFilter_" + ПараметрыWSDL.Постфикс, Отказ, ТекстОтказа);
		Иначе
			ФильтрПараметр = НовыйПараметр(ПараметрыПодключения, Прокси, "StringFilter_" + ПараметрыWSDL.Постфикс, Отказ, ТекстОтказа);
		КонецЕсли;
		
		ФильтрПараметр.FilterField = ФильтрЭлемент.FilterField;
		ФильтрПараметр.FilterOperator = ФильтрЭлемент.FilterOperator;
		ФильтрПараметр.FilterValue = ФильтрЭлемент.FilterValue;
		
		Если ФильтрЭлемент.Числовой Тогда
			Если ИсходящийПараметрФункции.Filters.Свойства().Получить("NumericFilter") <> Неопределено Тогда
				ИсходящийПараметрФункции.Filters.NumericFilter.Добавить(ФильтрПараметр);
			Иначе
				Отказ = Истина;
				ТекстОшибки = "Не удалось получить данные из Cbonds по функции CbondsDatabaseSoap_%1.
				| Не найден параметр NumericFilter для отбора по %2.
				| Не хватает прав учетной записи";
				ТекстОтказа = СтрШаблон(ТекстОшибки, ПараметрыWSDL.Постфикс, ФильтрЭлемент.FilterField);
				Возврат;
			КонецЕсли;
		Иначе
			Если ИсходящийПараметрФункции.Filters.Свойства().Получить("StringFilter") <> Неопределено Тогда
				ИсходящийПараметрФункции.Filters.StringFilter.Добавить(ФильтрПараметр);
			Иначе
				Отказ = Истина;
				ТекстОшибки = "Не удалось получить данные из Cbonds по функции CbondsDatabaseSoap_%1.
				| Не найден параметр StringFilter для отбора по %2.
				| Не хватает прав учетной записи";
				ТекстОтказа = СтрШаблон(ТекстОшибки, ПараметрыWSDL.Постфикс, ФильтрЭлемент.FilterField);
				Возврат;
			КонецЕсли;
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

Функция ФильтрШаблонWSDL(Числовой, FilterField, FilterOperator, FilterValue)
	
	ФильтрШаблон = Новый Структура;
	ФильтрШаблон.Вставить("Числовой",		 Числовой);
	ФильтрШаблон.Вставить("FilterField",	 FilterField);
	ФильтрШаблон.Вставить("FilterOperator",	 FilterOperator);
	ФильтрШаблон.Вставить("FilterValue",	 FilterValue);
	
	Возврат ФильтрШаблон;
	
КонецФункции

Функция QuantityDataШаблон(Limit = 1000, Offset = 0)
	
	Возврат Новый Структура("Limit, Offset", Limit, Offset);
	
КонецФункции

Функция ПараметрыЗагрузкиКотировок()
	
	ПараметрыЗагрузки = Новый Структура;
	ПараметрыЗагрузки.Вставить("ПараметрыПодключения");
	ПараметрыЗагрузки.Вставить("ДатаНачала");
	ПараметрыЗагрузки.Вставить("ДатаОкончания");
	ПараметрыЗагрузки.Вставить("СписокИдентификаторовПлощадок");
