#Область ПрограммныйИнтерфейс

// Процедура - Производит расчет рыночных цен, возвращая таблицу результата расчета
//
// Параметры:
//  ВходящиеПараметры		 - Структура - Входящие параметры
//  ----.*МетодикаРасчета					 - ПеречислениеСсылка.МетодикиРасчетаРыночныхЦен
//  ----.*ДатаРасчета						 - Дата	 - Дата на которую расчитываются рыночные цены ЦБ (для 481 отчета)
//  ---- *ПоОстаткам						 - Булево	 - Фильтр: Только по ценным бугам на остатке
//  ---- *ISINs								 - Строка	 - Фильтр: Только по ценным бумагам с указанными ISIN
//  ---- *ЗапросЦеныПоследнейСделкиПоISIN	 - Булево	 - Принудительно полученить цену последней цены сделки
//  ---- *БезЗапросаЦеныПоследнейСделки		 - Булево	 - Не запрашивать (в BQ) цену последней цены сделки
//  Отказ					 - Булево	 - Признак отказа
//  ТекстОтказа				 - Строка	 - Описание ошибки
//  ОтправлятьУведомление	 - Булево	 - Признак отправки результатов расчета на почту
// 
// Возвращаемое значение:
//   - ТаблицаЗначений - Таблица результата
//
Функция РассчитатьРыночныеЦены(ВходящиеПараметры, Отказ, ТекстОтказа, ОтправлятьУведомление = Ложь) Экспорт
	ВремяНачалаФормирования = ОценкаПроизводительности.НачатьЗамерВремени();
	
	ПоОстаткам						 = ВходящиеПараметры.ПоОстаткам;
	ISINs							 = ВходящиеПараметры.ISINs;
	
	СквозныеПараметры = Новый Структура;
	СквозныеПараметры.Вставить("ДатаРасчета", ВходящиеПараметры.ДатаРасчета);
	СквозныеПараметры.Вставить("КалендарныхДнейДляВыборкиКотировок", 90);
	СквозныеПараметры.Вставить("ПоОстаткам", ПоОстаткам);
	СквозныеПараметры.Вставить("ISINs", ISINs);
	СквозныеПараметры.Вставить("ЗапросЦеныПоследнейСделкиПоISIN", ВходящиеПараметры.ЗапросЦеныПоследнейСделкиПоISIN);
	СквозныеПараметры.Вставить("БезЗапросаЦеныПоследнейСделки", ВходящиеПараметры.БезЗапросаЦеныПоследнейСделки);
	Регламент = ПоОстаткам И Не ЗначениеЗаполнено(ISINs);
	СквозныеПараметры.Вставить("Регламент", Регламент);
	СквозныеПараметры.Вставить("МетодикаРасчета", ВходящиеПараметры.МетодикаРасчета);
	ПараметрыМетода = "ПоОстаткам=" + ПоОстаткам + ";" + "ISINs=" + ISINs;
	СквозныеПараметры.Вставить("ПараметрыМетода", ПараметрыМетода);
	
	РезультатыРасчета = РасчетРыночныхЦенОбщее.НовыеРезультатыРасчета();
	РассчитатьРыночныеЦеныНаДату(СквозныеПараметры, Отказ, ТекстОтказа, РезультатыРасчета);
	
	Если ОтправлятьУведомление Тогда
		ОкончательныйРасчет = РасчетРыночныхЦенОбщее.ЕстьОкончательныйРасчет(РезультатыРасчета);
		Если ОкончательныйРасчет Тогда
			ПериодСтрокой = Формат(СквозныеПараметры.ДатаРасчета, "ДФ=""дд.ММ.гггг""");
			ВнешнийИсточник = ПланыВидовХарактеристик.ВнешниеИсточники.РассылкаУведомленийОРасчетеРыночныхЦенЦенныхБумаг;
			РасчетРыночныхЦенОбщее.ОтправитьУведомлениеОРасчетеРыночныхЦен(ВнешнийИсточник, СквозныеПараметры.МетодикаРасчета, 
				ПериодСтрокой, РезультатыРасчета);
		КонецЕсли;
	КонецЕсли;
	
	ОценкаПроизводительности.ЗакончитьЗамерВремени("РасчетРыночныхЦен_481", ВремяНачалаФормирования);
	Возврат РезультатыРасчета;
КонецФункции

#КонецОбласти


#Область СлужебныеПроцедурыИФункции

// Процедура - Рассчитать рыночные цены на дату
//
// Параметры:
//  СквозныеПараметры	 - Структура	 - Входные параметры
//  Отказ				 - Булево		 - Признак отказа
//  ТекстОтказа			 - Строка		 - Описание ошибки
//  РезультатыРасчета	 - ТаблицаЗначений	 - см. Функция НовыеРезультатыРасчета
//
Процедура РассчитатьРыночныеЦеныНаДату(СквозныеПараметры, Отказ, ТекстОтказа, РезультатыРасчета)
	НовыйРезультатРасчета = РезультатыРасчета.Добавить();
	НовыйРезультатРасчета.ДатаРасчета = Формат(СквозныеПараметры.ДатаРасчета, "ДЛФ=D");
	НовыйРезультатРасчета.Комментарий = СквозныеПараметры.ПараметрыМетода;
	
	СостояниеРасчета = РегистрыСведений.СостоянияРасчетаРыночныхЦенЦенныхБумаг.ПолучитьСостояние(СквозныеПараметры);
	СквозныеПараметры.Вставить("ИдентификаторЗапросаBQ", СостояниеРасчета.ИдентификаторЗапросаBQ);
	СквозныеПараметры.Вставить("ИдентификаторЗапросаDiasoft", СостояниеРасчета.ИдентификаторЗапросаDiasoft);
	СквозныеПараметры.Вставить("ПолученОтветBQ", СостояниеРасчета.ПолученОтветBQ);
	СквозныеПараметры.Вставить("ПолученОтветDiasoft", СостояниеРасчета.ПолученОтветDiasoft);
	
	НачатьТранзакцию();
	Попытка
		НовыйРезультатРасчета.СостояниеБыло = СостояниеРасчета.Состояние;
		ПервичныйРасчет =
			СостояниеРасчета.Состояние = Перечисления.СостоянияРасчетаРыночныхЦен.ПустаяСсылка()
			Или СостояниеРасчета.Состояние = Перечисления.СостоянияРасчетаРыночныхЦен.ОшибкаРасчета
			Или СостояниеРасчета.Состояние = Перечисления.СостоянияРасчетаРыночныхЦен.РасчетЗавершен;
		СквозныеПараметры.Вставить("ПервичныйРасчет", ПервичныйРасчет);
		ОкончательныйРасчет = (СостояниеРасчета.Состояние = Перечисления.СостоянияРасчетаРыночныхЦен.ДанныеПолучены);
		СквозныеПараметры.Вставить("ОкончательныйРасчет", ОкончательныйРасчет);
		
		Если СквозныеПараметры.ПервичныйРасчет Или СквозныеПараметры.ОкончательныйРасчет Тогда
			
			СостояниеСтало = Перечисления.СостоянияРасчетаРыночныхЦен.НачалоРасчета;
			Комментарий = "";
			РегистрыСведений.СостоянияРасчетаРыночныхЦенЦенныхБумаг.УстановитьСостояние(СквозныеПараметры, СостояниеСтало, Комментарий);
			РассчитатьИЗаписатьРыночныеЦены(СквозныеПараметры, Отказ, ТекстОтказа, НовыйРезультатРасчета, СостояниеСтало);
			
			Если Не Отказ Тогда
				РегистрыСведений.СостоянияРасчетаРыночныхЦенЦенныхБумаг.УстановитьСостояние(СквозныеПараметры,
					СостояниеСтало, НовыйРезультатРасчета.Комментарий);
				НовыйРезультатРасчета.СостояниеСтало = СостояниеСтало;
			Иначе
				НовыйРезультатРасчета.Комментарий = ТекстОтказа;
			КонецЕсли;
		КонецЕсли;
		
		РасчетРыночныхЦенОбщее.СформироватьВидРасчетаСтрокой(СквозныеПараметры, НовыйРезультатРасчета);
		
		Если Отказ Тогда
			ВызватьИсключение ТекстОтказа;
		КонецЕсли;
		
		ЗафиксироватьТранзакцию();
	Исключение
		ОтменитьТранзакцию();
		
		ТекстОшибки = ОбработкаОшибок.КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
		НовыйРезультатРасчета.ТекстОтказа = ТекстОшибки;
		Отказ = Истина;
		ТекстОтказа = ТекстОшибки + Символы.ПС + ТекстОтказа;
		
		РасчетРыночныхЦенОбщее.СформироватьВидРасчетаСтрокой(СквозныеПараметры, НовыйРезультатРасчета);
		СостояниеСтало = Перечисления.СостоянияРасчетаРыночныхЦен.ОшибкаРасчета;
		РегистрыСведений.СостоянияРасчетаРыночныхЦенЦенныхБумаг.УстановитьСостояние(СквозныеПараметры, СостояниеСтало, ТекстОшибки);
		НовыйРезультатРасчета.СостояниеСтало = СостояниеСтало;
		
	КонецПопытки;
	НовыйРезультатРасчета.Отказ = Отказ;
	
КонецПроцедуры

Процедура РассчитатьИЗаписатьРыночныеЦены(СквозныеПараметры, Отказ, ТекстОтказа, НовыйРезультатРасчета, СостояниеСтало)
	
	РезультатыПакета = ПакетныйЗапросРасчетаРыночныхЦенЦенныхБумаг(СквозныеПараметры);
	ИндексПоследнегоЗапроса = РезультатыПакета.Количество() - 1;
	ИндексВторогоЗапросаСКонца = ИндексПоследнегоЗапроса - 1;
	РезультатыЗапросаРыночныеЦены = РезультатыПакета[ИндексВторогоЗапросаСКонца];
	РезультатыЗапросаЦенныеБумаги = РезультатыПакета[ИндексПоследнегоЗапроса];
	РасчетРыночныхЦенЦенныхБумаг = РезультатыЗапросаРыночныеЦены.Выгрузить();
	// Из-за проблем с округлениями и разрядностью в SQL ЦенуЦБ (в валюте ЦБ) рассчитываем при обработке результатов запроса
	// а не в нем самом
	РасчетРыночныхЦенОбщее.РассчитатьЦеныВВалютеЦБ(РасчетРыночныхЦенЦенныхБумаг);
	
	СостояниеСтало = Перечисления.СостоянияРасчетаРыночныхЦен.РасчетЗавершен;
	Если СквозныеПараметры.ПервичныйРасчет Тогда
		ЦенныеБумагиКЗапросу = РезультатыЗапросаЦенныеБумаги.Выгрузить();
		НеобходимоЗапроситьВнешниеСистемы = ЗначениеЗаполнено(ЦенныеБумагиКЗапросу)
											И Не СквозныеПараметры.БезЗапросаЦеныПоследнейСделки
											И Не ТестированиеVanessa.ЭтоТест();
		Если НеобходимоЗапроситьВнешниеСистемы Тогда
			ISINs = ОбщегоНазначения.ВыгрузитьКолонку(ЦенныеБумагиКЗапросу, "ISIN", Истина, Истина);
			НовыйРезультатРасчета.Количество = ЦенныеБумагиКЗапросу.Количество();
			НовыйРезультатРасчета.Комментарий = СтрСоединить(ISINs, ", ");
			Попытка
				СквозныеПараметры.ИдентификаторЗапросаBQ = ПолучениеЦеныПоследнейСделки.ЗапросBQ(СквозныеПараметры, ЦенныеБумагиКЗапросу);
				СквозныеПараметры.ИдентификаторЗапросаDiasoft = ПолучениеЦеныПоследнейСделки.ЗапросDiasoft(СквозныеПараметры, ЦенныеБумагиКЗапросу);
				СостояниеСтало = Перечисления.СостоянияРасчетаРыночныхЦен.ПолучениеДанных;
			Исключение
				СостояниеСтало =  Перечисления.СостоянияРасчетаРыночныхЦен.ОшибкаРасчета;
				Отказ = Истина;
				ТекстОтказа = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
			КонецПопытки;
		Иначе
			СквозныеПараметры.ПервичныйРасчет = Ложь;
			СквозныеПараметры.ОкончательныйРасчет = Истина;
		КонецЕсли;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(РасчетРыночныхЦенЦенныхБумаг) Тогда
		Если СостояниеСтало = Перечисления.СостоянияРасчетаРыночныхЦен.РасчетЗавершен Тогда
			ISINs = ОбщегоНазначения.ВыгрузитьКолонку(РасчетРыночныхЦенЦенныхБумаг, "ISIN", Истина, Истина);
			НовыйРезультатРасчета.Количество = РасчетРыночныхЦенЦенныхБумаг.Количество();
			НовыйРезультатРасчета.Комментарий = СтрСоединить(ISINs, ", ");
		КонецЕсли;
		РасчетРыночныхЦенОбщее.ЗаписатьРыночныеЦены(СквозныеПараметры, РасчетРыночныхЦенЦенныхБумаг);
	Иначе
		НовыйРезультатРасчета.Комментарий = "Нет данных для расчета";
	КонецЕсли;
	
КонецПроцедуры

// Функция выполняет пакетный запрос для получения данных, необходимых для расчета рыночных цен ЦБ
// и возвращает его результаты.
// Параметры:
//  СквозныеПараметры		 - Структура - Входящие параметры, включая:
//  ----.*ДатаРасчета						 - Дата
//  ---- *КалендарныхДнейДляВыборкиКотировок - Число
//  ---- *ПоОстаткам						 - Булево	 - Фильтр: Только по ценным бугам на остатке
//  ---- *ISINs								 - Строка	 - Фильтр: Только по ценным бумагам с указанными ISIN
//  ---- *ЗапросЦеныПоследнейСделкиПоISIN - Булево
// Возвращаемое значение:
//   - Массив - Массив результатов выполнения запросов
//
// BSLLS:MethodSize-off
Функция ПакетныйЗапросРасчетаРыночныхЦенЦенныхБумаг(СквозныеПараметры)
	Запрос = Новый Запрос;
	
	Запрос.УстановитьПараметр("МетодикаРасчета", СквозныеПараметры.МетодикаРасчета);
	ПериодОстатков = КонецДня(СквозныеПараметры.ДатаРасчета) + 1;
	Запрос.УстановитьПараметр("ПериодОстатков", ПериодОстатков);
	Запрос.УстановитьПараметр("ПоОстаткам", СквозныеПараметры.ПоОстаткам);
	Если ЗначениеЗаполнено(СквозныеПараметры.ISINs) Тогда
		Запрос.УстановитьПараметр("ПоВсемISIN", Ложь);
		Запрос.УстановитьПараметр("ISIN", СтрРазделить(СквозныеПараметры.ISINs, ",", Ложь));
	Иначе
		Запрос.УстановитьПараметр("ПоВсемISIN", Истина);
		Запрос.УстановитьПараметр("ISIN", "");
	КонецЕсли;
	
	ДеньТ = НачалоДня(СквозныеПараметры.ДатаРасчета);
	НачалоПериодаВыборкиКотировок = ДеньТ - ОбщегоНазначенияПовтИсп.СекундВСутках(СквозныеПараметры.КалендарныхДнейДляВыборкиКотировок);
	Запрос.УстановитьПараметр("ДеньТ", ДеньТ);
	Запрос.УстановитьПараметр("НачалоПериодаВыборкиКотировок", НачалоПериодаВыборкиКотировок);
	Если ОбщегоНазначения.РабочийДень(ДеньТ) Тогда
		ПоследнийРабочийДеньПериода = ДеньТ;
	Иначе
		ПоследнийРабочийДеньПериода = ОбщегоНазначения.ПредыдущийРабочийДень(ДеньТ);
	КонецЕсли;
	Запрос.УстановитьПараметр("ПоследнийРабочийДеньПериода", ПоследнийРабочийДеньПериода);
	Запрос.УстановитьПараметр("ТекущаяДата", ТекущаяДатаСеанса());
	Запрос.УстановитьПараметр("ЗапросЦеныПоследнейСделкиПоISIN", СквозныеПараметры.ЗапросЦеныПоследнейСделкиПоISIN);
	
	ТипыЦБСКотировкамиНРД = Перечисления.ТипыЦБ.ВсеТипыДепозитарныхРасписок();
	ТипыЦБСКотировкамиНРД.Добавить(Перечисления.ТипыЦБ.Акция);
	ТипыЦБСКотировкамиНРД.Добавить(Перечисления.ТипыЦБ.Пай);
	Запрос.УстановитьПараметр("ТипыЦБСКотировкамиНРД", ТипыЦБСКотировкамиНРД);
	Запрос.УстановитьПараметр("ТипыДепозитарныхРасписок", Перечисления.ТипыЦБ.ВсеТипыДепозитарныхРасписок());
	Запрос.УстановитьПараметр("Рубль", Справочники.Валюты.Рубль());

	
	// При добавлении в запрос временных таблиц - учесть, что результаты последних двух запросов пакета используются
	// в процедуре РассчитатьИЗаписатьРыночныеЦены, они должны оставаться последними.
	Запрос.Текст =
	"/////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
	|//						ПОДГОТОВКА СПИСКА ЦЕННЫХ БУМАГ ДЛЯ КОТОРЫХ НУЖНО ОПРЕДЕЛИТЬ КОТИРОВКИ						//
	|/////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ОстаткиЦБОстатки.ЦБ КАК ЦБ
	|ПОМЕСТИТЬ ВТ_РегистрНакопленияОстаткиЦБОстатки
	|ИЗ
	|	РегистрНакопления.ОстаткиЦБ.Остатки(
	|			&ПериодОстатков,
	|			ВЫБОР
	|				КОГДА &ПоВсемISIN
	|					ТОГДА ИСТИНА
	|				ИНАЧЕ ЦБ.ISIN В (&ISIN)
	|			КОНЕЦ) КАК ОстаткиЦБОстатки
	|
	|СГРУППИРОВАТЬ ПО
	|	ОстаткиЦБОстатки.ЦБ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЦенныеБумаги.Ссылка КАК ЦеннаяБумага,
	|	ЦенныеБумаги.ТипЦБ КАК ТипЦБ, 
	|	ВЫБОР
	|		КОГДА ЦенныеБумаги.ТипЦБ В (&ТипыДепозитарныхРасписок)
	|				И НЕ ЦенныеБумаги.БазовыйАктив = ЗНАЧЕНИЕ(Справочник.ЦенныеБумаги.ПустаяСсылка)
	|			ТОГДА ЦенныеБумаги.БазовыйАктив.ВалютаНоминала
	|		ИНАЧЕ ЦенныеБумаги.ВалютаНоминала
