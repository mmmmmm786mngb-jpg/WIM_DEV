Функция Уведомление1_10(НомерУведомления)
	
	НомераУведомлений = СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок("6,7,8,10");
	Если НомераУведомлений.Найти(Строка(НомерУведомления)) = Неопределено Тогда 
		Возврат Ложь;
	Иначе 
		Возврат Истина;
	КонецЕсли;
	
КонецФункции

