Функция Issuer_РСВ_FCDR(ДанныеДляЗаполненияXML, ПространствоИмен)
	Результат = НовыйОбъектСхемыFCDR("legal_entity_details_t", ПространствоИмен);
	
	Результат.legal_entity_name = ДанныеДляЗаполненияXML.ПолноеНаименованиеЮрЛицо;
	Результат.legal_entity_id = НовыйОбъектСхемыFCDR("organization_id_t", ПространствоИмен);
	organization_document_t = НовыйОбъектСхемыFCDR("organization_document_t", ПространствоИмен);
	СтрокаOrganization_id = Результат.legal_entity_id.organization_id.Добавить(organization_document_t);
	Если ЗначениеЗаполнено(ДанныеДляЗаполненияXML.ЭмитентОГРН) Тогда
		СтрокаOrganization_id.organization_code_type = "OGRN";
		СтрокаOrganization_id.org_doc_num = НовыйОбъектСхемыFCDR("document_details_choice_t", ПространствоИмен);
		СтрокаOrganization_id.org_doc_num.doc_num = ДанныеДляЗаполненияXML.ЭмитентОГРН;
	ИначеЕсли ЗначениеЗаполнено(ДанныеДляЗаполненияXML.ЭмитентИнн) Тогда
		СтрокаOrganization_id.organization_code_type = "OTHR";
		СтрокаOrganization_id.narrative = "INN";
		СтрокаOrganization_id.org_doc_num = НовыйОбъектСхемыFCDR("document_details_choice_t", ПространствоИмен);
		СтрокаOrganization_id.org_doc_num.doc_num = ДанныеДляЗаполненияXML.ЭмитентИнн;
	Иначе
		СтрокаOrganization_id.organization_code_type = "OGRN";
		СтрокаOrganization_id.org_doc_num = НовыйОбъектСхемыFCDR("document_details_choice_t", ПространствоИмен);
		СтрокаOrganization_id.org_doc_num.doc_num = "UKWN";
	КонецЕсли;
	
	Возврат Результат;
КонецФункции

