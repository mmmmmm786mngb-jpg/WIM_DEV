	Подпись = Документы.УведомлениеКлиентам.ПодписьСообщения(ДанныеЗаполнения.Дата);
	Подпись = СтрЗаменить(Подпись, "<p>", "");
	Подпись = СокрЛП(СтрЗаменить(Подпись, "</p>", ""));
	ReplaceFields.Вставить("Подпись", Подпись);
	
	Data.Вставить("ReplaceFields", ReplaceFields);
	Тело = РаботаСJSON.ТекстСообщенияJSON(MessageInfo, Data);
	
	Результат = Новый Структура;
	Результат.Вставить("Тема", Тема);
	Результат.Вставить("Тело", Тело);
	Результат.Вставить("РаскрытиеСпискаВладельцев", Истина);
	Результат.Вставить("НомерУведомления", 49602);
	Результат.Вставить("ФормаСообщенияКК", Перечисления.ФормыСообщенийКК.ЗапросСубброкеруНаРаскрытиеДобровольное);
	Результат.Вставить("Повторное", Ложь);
	Результат.Вставить("Уведомление1_10", Ложь);
	Результат.Вставить("Уведомление2_13", Ложь);
	Результат.Вставить("УведомлениеW8", Ложь);
	Возврат Результат;
	
