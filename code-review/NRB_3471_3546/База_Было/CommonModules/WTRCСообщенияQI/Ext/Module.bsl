	MessageInfo.Вставить("SystemSource", "Depo");
	MessageInfo.Вставить("ParentMessageId", Неопределено);
	MessageInfo.Вставить("ActionType", "INS");
	
	Data = Новый Структура();
	Data.Вставить("NotificationType", "Client");
	Data.Вставить("CrmClientId", Неопределено);
	Data.Вставить("Email", Неопределено);
	Data.Вставить("MailTemplateId", Неопределено);
