// Возвращает данные уведомления субброкеру (запрос субброкеру на раскрытие владельцев)
//
// Параметры:
//  РаскрытиеСпискаВладельцевСсылка	 - ДокументСсылка.РаскрытиеСпискаВладельцев	 - Документ РСВ
//  ЦеннаяБумага					 - СправочникСсылка.ЦенныеБумаги - Ценная бумага (ЦБ1 или ЦБ2). Для обязательного КД
// 
// Возвращаемое значение:
//	Неопределено
//  или Структура - 
//		* Тема - Строка
//		* Тело - Строка
//		* РаскрытиеСпискаВладельцев - Булево
//		* НомерУведомления - Число
//		* ФормаСообщенияКК - ПеречислениеСсылка.ФормыСообщенийКК
//		* Повторное - Булево
//		* Уведомление1_10 - Булево
//		* Уведомление2_13 - Булево
//		* УведомлениеW8 - Булево
//
Функция УведомлениеЗапросСубброкеруНаРаскрытие(РаскрытиеСпискаВладельцевСсылка, ЦеннаяБумага) Экспорт
	
	
	ОбязательныеВидыКД = Новый Массив();
	ОбязательныеВидыКД.Добавить(Справочники.ВидыКорпоративныхДействий.НайтиПоКоду("DVCA"));
	ОбязательныеВидыКД.Добавить(Справочники.ВидыКорпоративныхДействий.НайтиПоКоду("INTR"));
	ОбязательныеВидыКД.Добавить(Справочники.ВидыКорпоративныхДействий.НайтиПоКоду("MCAL"));
	ОбязательныеВидыКД.Добавить(Справочники.ВидыКорпоративныхДействий.НайтиПоКоду("PRED"));
	ОбязательныеВидыКД.Добавить(Справочники.ВидыКорпоративныхДействий.НайтиПоКоду("CAPG"));
	ОбязательныеВидыКД.Добавить(Справочники.ВидыКорпоративныхДействий.НайтиПоКоду("MEET"));
	ОбязательныеВидыКД.Добавить(Справочники.ВидыКорпоративныхДействий.НайтиПоКоду("XMET"));
	ОбязательныеВидыКД.Добавить(Справочники.ВидыКорпоративныхДействий.НайтиПоКоду("BMET"));
	ОбязательныеВидыКД.Добавить(Справочники.ВидыКорпоративныхДействий.НайтиПоКоду("OMET"));
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	РаскрытиеСпискаВладельцев.Ссылка,
	|	РаскрытиеСпискаВладельцев.ВидКорпоративногоДействия,
	|	ВЫБОР
	|		КОГДА ВЫРАЗИТЬ(РаскрытиеСпискаВладельцев.Эмитент.ЮридическиеФизическиеЛица КАК Справочник.ЮридическиеЛица).Страна = &РФ
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК РоссийскаяЦБ
	|ПОМЕСТИТЬ РСВ
	|ИЗ
	|	Документ.РаскрытиеСпискаВладельцев КАК РаскрытиеСпискаВладельцев
	|ГДЕ
	|	РаскрытиеСпискаВладельцев.Ссылка = &РаскрытиеСпискаВладельцевСсылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВЫБОР
	|		КОГДА РСВ.РоссийскаяЦБ
	|				И РСВ.ВидКорпоративногоДействия = &DSCL
	|			ТОГДА &УведомлениеДляОбязательныхКД
	|		КОГДА РСВ.ВидКорпоративногоДействия В (&ОбязательныеВидыКД)
	|			ТОГДА &УведомлениеДляОбязательныхКД
	|		КОГДА НЕ РСВ.РоссийскаяЦБ
	|				И РСВ.ВидКорпоративногоДействия = &DSCL
	|			ТОГДА &УведомлениеДляДобровольных
	|		КОГДА РСВ.ВидКорпоративногоДействия = &TREC
	|			ТОГДА &УведомлениеДляДобровольных
	|		ИНАЧЕ НЕОПРЕДЕЛЕНО
	|	КОНЕЦ КАК ТипУведомления,
	|	ВЫБОР
	|		КОГДА РСВ.Ссылка.СвязанныйРеференсКД1 <> """"
	|			ТОГДА РСВ.Ссылка.СвязанныйВидКД1.Наименование
	|		ИНАЧЕ РСВ.Ссылка.ВидКорпоративногоДействия.Наименование
	|	КОНЕЦ КАК ТипКД,
	|	ВЫБОР
	|		КОГДА РСВ.Ссылка.СвязанныйРеференсКД1 <> """"
	|			ТОГДА РСВ.Ссылка.СвязанныйРеференсКД1
	|		ИНАЧЕ РСВ.Ссылка.КДРеференс
	|	КОНЕЦ КАК РеференсКД,
	|	ЕСТЬNULL(ЦенныеБумаги.Наименование, """") КАК НаименованиеЦБ,
	|	ЕСТЬNULL(ЦенныеБумаги.ISIN, """") КАК ISIN,
	|	ЕСТЬNULL(РСВ.Ссылка.ДатаОкончанияПриемаИнструкцийВТБКБ, ДАТАВРЕМЯ(1, 1, 1, 0, 0, 0)) КАК ДатаОкончанияПриемаИнструкцийВТБКБ,
	|	ЕСТЬNULL(РСВ.ВидКорпоративногоДействия.Наименование, """") КАК НаименованиеКД,
	|	ЕСТЬNULL(РСВ.Ссылка.Эмитент.Наименование, """") КАК НаименованиеЭмитента,
	|	ЕСТЬNULL(РСВ.Ссылка.ЦеннаяБумага1.ТипЦБ, """") КАК ТипЦБ1,
	|	ЕСТЬNULL(РСВ.Ссылка.ЦеннаяБумага1.ISIN, """") КАК ISIN1,
	|	ЕСТЬNULL(РСВ.Ссылка.ЦеннаяБумага2.ТипЦБ, """") КАК ТипЦБ2,
	|	ЕСТЬNULL(РСВ.Ссылка.ЦеннаяБумага2.ISIN, """") КАК ISIN2,
	|	ЕСТЬNULL(РСВ.Ссылка.ДатаКДПлан, ДАТАВРЕМЯ(1, 1, 1, 0, 0, 0)) КАК ДатаКДПлан,
	|	ЕСТЬNULL(РСВ.Ссылка.ДатаФиксации, ДАТАВРЕМЯ(1, 1, 1, 0, 0, 0)) КАК ДатаФиксации,
	|	РСВ.Ссылка.Дата КАК Дата
	|ИЗ
	|	РСВ КАК РСВ
	|	ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ЦенныеБумаги КАК ЦенныеБумаги
	|	ПО ЦенныеБумаги.Ссылка = &ЦеннаяБумага
	|");
	
	Запрос.УстановитьПараметр("РФ", Справочники.КлассификаторСтранМира.РОССИЯ);
	Запрос.УстановитьПараметр("РаскрытиеСпискаВладельцевСсылка", РаскрытиеСпискаВладельцевСсылка);
	Запрос.УстановитьПараметр("DSCL", Справочники.ВидыКорпоративныхДействий.НайтиПоКоду("DSCL"));
	Запрос.УстановитьПараметр("TREC", Справочники.ВидыКорпоративныхДействий.НайтиПоКоду("TREC"));
	Запрос.УстановитьПараметр("ОбязательныеВидыКД", ОбязательныеВидыКД);
	Запрос.УстановитьПараметр("УведомлениеДляДобровольных", Перечисления.ТипыКорпоративныхДействий.Добровольное);
	Запрос.УстановитьПараметр("УведомлениеДляОбязательныхКД", Перечисления.ТипыКорпоративныхДействий.Обязательное);
	Запрос.УстановитьПараметр("ЦеннаяБумага", ЦеннаяБумага);
	
	ДанныеЗаполнения = Запрос.Выполнить().Выгрузить()[0];
	Если ДанныеЗаполнения.ТипУведомления = Перечисления.ТипыКорпоративныхДействий.Добровольное Тогда 
		Возврат УведомлениеЗапросСубброкеруНаРаскрытиеДобровольное(РаскрытиеСпискаВладельцевСсылка, ДанныеЗаполнения);
	ИначеЕсли  ДанныеЗаполнения.ТипУведомления = Перечисления.ТипыКорпоративныхДействий.Обязательное Тогда 
		Возврат УведомлениеЗапросСубброкеруНаРаскрытиеОбязательное(РаскрытиеСпискаВладельцевСсылка, ДанныеЗаполнения);
	Иначе
		Возврат Неопределено;
	КонецЕсли;
	
КонецФункции 

Функция ИспользоватьСхемуУведомленийWTRC_QI(ДатаПроверки = Неопределено) Экспорт
	Если ДатаПроверки = Неопределено Тогда 
		ДатаПроверки = ТекущаяДатаСеанса();
	КонецЕсли;
	ДатаВводаСхемыУведомленийWTRC_QI = Константы.ДатаВводаСхемыУведомленийWTRC_QI.Получить();	
	Возврат (ЗначениеЗаполнено(ДатаВводаСхемыУведомленийWTRC_QI) = Истина И  ДатаПроверки >= ДатаВводаСхемыУведомленийWTRC_QI);
КонецФункции

Функция ИспользоватьРегистрациюЗапросовСубброкера(ДатаПроверки = Неопределено) Экспорт
	Если ДатаПроверки = Неопределено Тогда 
		ДатаПроверки = ТекущаяДатаСеанса();
	КонецЕсли;
	ДатаРегистрацииЗапросовСубброкера = Константы.ДатаРегистрацииЗапросовСубброкера.Получить();	
	Возврат (ЗначениеЗаполнено(ДатаРегистрацииЗапросовСубброкера) = Истина И  ДатаПроверки >= ДатаРегистрацииЗапросовСубброкера);
КонецФункции


// Функции создания Уведомлений клиентам
Функция ТаблицаКлиентов() Экспорт 
		
	КолонкиТаблицыКлиентов = 	"Клиент, Договор, СчетДепо, РазделСчетаДепо, ЦеннаяБумага, Количество,
								|Unit, Isin, SecName, SecType, SecCode, ClientId, GosRegNumber, NominalValue, NominalCurrency, 
								|StakeToParticipate, DepoAccountFrom, DepoSectionFrom, DepoAccountTo, DepoSectionTo, СтрокаТабличнойЧасти, Тема, Тело";
	ИменаКолонок = СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(КолонкиТаблицыКлиентов);	
	ТаблицаКлиентов = Новый ТаблицаЗначений();
	Для Каждого ИмяКолонки Из ИменаКолонок Цикл 
		ТаблицаКлиентов.Колонки.Добавить(СокрЛП(ИмяКолонки));
	КонецЦикла;
    Возврат ТаблицаКлиентов; 
	
КонецФункции

Процедура ДобавитьУведомлениеКОтправке(УведомленияКОтправке, Уведомление, ДанныеКОбработке, СтрокаТабличнойЧасти = Неопределено) Экспорт 
	
	ПараметрыУведомления = УведомленияКОтправке.Получить(Уведомление.НомерУведомления);
	Если ПараметрыУведомления = Неопределено Тогда 
		ПараметрыУведомления = Новый Структура("Уведомление, ТаблицаКлиентов, КодСубброкера", Уведомление, ТаблицаКлиентов(), ДанныеКОбработке.ДепонентКод);
	КонецЕсли;
	
	НоваяСтрока = ПараметрыУведомления.ТаблицаКлиентов.Добавить();
	ЗаполнитьЗначенияСвойств(НоваяСтрока, ДанныеКОбработке);
	ЗаполнитьЗначенияСвойств(НоваяСтрока, Уведомление);
	НоваяСтрока.СтрокаТабличнойЧасти = СтрокаТабличнойЧасти;
	УведомленияКОтправке.Вставить(Уведомление.НомерУведомления, ПараметрыУведомления);
	
КонецПроцедуры
		
// Создает, заполняет и отправляет документ УведомлениеКлиентам по данным бизнес процесса ОбработкаWTRCСообщения
//
// Параметры:
//  БизнесПроцессСсылка	 - 									 - БизнесПроцессСсылка.ОбработкаWTRCСообщения
//  ПараметрыУведомления - Структура						 - Структура с описанием параметров уведомления
//  ДанныеКОбработке	 - ВыборкаИзРезультатаЗапроса		 - 
//  ОбработкаВебСервисы	 - ОбработкаОбъект.TEST_ВебСервисы	 - 
// 
// Возвращаемое значение:
//  Булево - результат создания и отправки уведомления
//
Функция РезультатСозданияИОтправкиУведомленияКлиентам(БизнесПроцессСсылка, ПараметрыУведомления, ДанныеКОбработке, ОбработкаВебСервисы = Неопределено) Экспорт 
	
	Уведомление = ПараметрыУведомления.Уведомление;
	УведомлениеКлиентам = Документы.УведомлениеКлиентам.УведомлениеПоТексту(БизнесПроцессСсылка, Уведомление.ФормаСообщенияКК, Уведомление.Тело); 
	Если УведомлениеКлиентам = Неопределено Тогда 
	
		Попытка	
			Уведомление = ПараметрыУведомления.Уведомление;
			ТаблицаКлиентов = ПараметрыУведомления.ТаблицаКлиентов;
			
			ДокументУведомление = Документы.УведомлениеКлиентам.СоздатьДокумент();
			ДокументУведомление.УстановитьСсылкуНового(Документы.УведомлениеКлиентам.ПолучитьСсылку());
			ДокументУведомление.УстановитьНовыйНомер();	
			ДокументУведомление.Дата = ТекущаяДата();
			ДокументУведомление.Заполнить(БизнесПроцессСсылка);
			ДокументУведомление.ЗаголовокСообщения = Уведомление.Тема;
			ДокументУведомление.ТелоСообщения = Уведомление.Тело;
			ДокументУведомление.ФормаСообщенияКК = Уведомление.ФормаСообщенияКК;
			Если ТипЗнч(БизнесПроцессСсылка) = Тип("ДокументСсылка.ЗапросСубброкеруНаРаскрытие") Тогда
				ДокументУведомление.ДокументОснование = БизнесПроцессСсылка;
				ДокументУведомление.Статус = Перечисления.СтатусыУведомленийКлиентам.Отправлено;
			Иначе
				ДокументУведомление.ОтправитьУведомление(ОбработкаВебСервисы, ПараметрыУведомления);
			КонецЕсли;
			
			Если ДокументУведомление.Статус = Перечисления.СтатусыУведомленийКлиентам.Отправлено Тогда
				ДокументУведомление.Записать();
				Возврат Истина;
			Иначе
				ЗаписьЖурналаРегистрации("Отправка уведомления в КК", УровеньЖурналаРегистрации.Предупреждение,,БизнесПроцессСсылка, "Не удалось отправить уведомление в КК");
				Возврат Ложь;
			КонецЕсли;
		Исключение
			ЗаписьЖурналаРегистрации("Отправка уведомления в КК", УровеньЖурналаРегистрации.Ошибка,,БизнесПроцессСсылка, ОписаниеОшибки());
			Возврат Ложь;
		КонецПопытки;
		
	ИначеЕсли Уведомление.ФормаСообщенияКК = Перечисления.ФормыСообщенийКК.SendEmailToClients Тогда 
		
		Возврат ДокументУведомление.РезультатОтправкиВЛКSendEmailToClients(ПараметрыУведомления, ОбработкаВебСервисы);
		
	ИначеЕсли Уведомление.ФормаСообщенияКК = Перечисления.ФормыСообщенийКК.CreateCorporateActionWtrc Тогда 
		
		// В связи с тем что в настоящее время на стороне веб сервиса не внесены соответсвующие изменения, в кабинет клиента данные отправляем через SendEmailToClients.
		// Отправка запроса на раскрытие реализована через Excel файл
		Возврат ДокументУведомление.РезультатОтправкиВЛКSendEmailToClients(ПараметрыУведомления, ОбработкаВебСервисы);
		//Возврат ВебСервисыСервер.РезультатДобавленияКлиентаВСуществующееКорпоративноеДействиеWTRC(
		//ПараметрыУведомления, Строка(УведомлениеКлиентам.УникальныйИдентификатор()));
	Иначе 
		
		ВызватьИсключение "Неожиданный значение формы сообщения клиента, доотправка возможно только для SendEmailToClients, CreateCorporateActionWtrc";
	
	КонецЕсли;
	
КонецФункции

// Общие функции
Функция НалоговаяСтавкаОбязательна(ВидКорпоративногоДействияСсылка) Экспорт 
	
	Возврат ВидКорпоративногоДействияСсылка.ТипКорпоративныхДействий = Перечисления.ТипыКорпоративныхДействий.Доход;
	
КонецФункции

Функция УказаниеРазделаСчетаДепоОбязательно(ВидКорпоративногоДействияСсылка) Экспорт
	
	Реквизиты = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ВидКорпоративногоДействияСсылка,"Код, ТипКорпоративныхДействий");
	Собрания = СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок("MEET,XMET,BMET,OMET,DISCL");
	
	Если Реквизиты.ТипКорпоративныхДействий = Перечисления.ТипыКорпоративныхДействий.Доход 
		ИЛИ Не Собрания.Найти(Реквизиты.Код) = Неопределено Тогда 
		Возврат Истина;
	Иначе 
		Возврат Ложь;
	КонецЕсли;
	
КонецФункции

Функция ТребуетсяЗапросСубброкеруНаРаскрытие(ВидКорпоративногоДействияСсылка) Экспорт 

	КодыВидовКД = СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок("DSCL,DVCA,INTR,MCAL,PRED,CAPG,MEET,XMET,BMET,OMET");
	Возврат Не КодыВидовКД.Найти(ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ВидКорпоративногоДействияСсылка,"Код")) = Неопределено;
	
КонецФункции 

Функция ИспользоватьРегистрациюЗапросовСубброкераДляДокумента(ДокументСсылка) Экспорт 
	
	ДокументПоискаСсылка = Неопределено;
	Если ТипЗнч(ДокументСсылка) = Тип("ДокументСсылка.КорпоративноеДействие_Новый") Тогда 
		ДокументПоискаСсылка = ДокументСсылка;
	ИначеЕсли ТипЗнч(ДокументСсылка) = Тип("ДокументСсылка.РаскрытиеСпискаВладельцев") Тогда
		// Если передан РСВ не DSCL то смотрим дату по КД иначе смотрим по РСВ
		Реквизиты = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ДокументСсылка, Новый Структура("КодВидаКД, КД","ВидКорпоративногоДействия.Код","КарточкаКД"));
		Если Реквизиты.КодВидаКД = "DSCL" Тогда 
			ДокументПоискаСсылка = ДокументСсылка;
		Иначе
			ДокументПоискаСсылка = Реквизиты.КД;
		КонецЕсли;
	Иначе
		ВызватьИсключение "Не верный параметр номер 1, ожидается ДокументСсылка.КорпоративноеДействие_Новый, ДокументСсылка.РаскрытиеСпискаВладельцев"; 
	КонецЕсли;
	
	ДатаПроверки = ТекущаяДатаСеанса();
	Запрос = Новый Запрос(
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	МИНИМУМ(ЭтапыКД.Период) КАК Период,
	|	ЭтапыКД.КД КАК КД
	|ИЗ
	|	РегистрСведений.ЭтапыКД КАК ЭтапыКД
	|ГДЕ
	|	ЭтапыКД.КД = &ДокументПоиска
	|
	|СГРУППИРОВАТЬ ПО
	|	ЭтапыКД.КД");
	
	Запрос.УстановитьПараметр("ДокументПоиска", ДокументПоискаСсылка);
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл 
		ДатаПроверки = Выборка.Период;	
	КонецЦикла;
	
	Возврат ИспользоватьРегистрациюЗапросовСубброкера(ДатаПроверки);
		
КонецФункции

Функция ИспользоватьСхемуУведомленийWTRC_QIДляДокумента(ДокументСсылка) Экспорт
	
	ДокументПоискаСсылка = Неопределено;
	Если ТипЗнч(ДокументСсылка) = Тип("ДокументСсылка.КорпоративноеДействие_Новый") Тогда 
		ДокументПоискаСсылка = ДокументСсылка;
	ИначеЕсли ТипЗнч(ДокументСсылка) = Тип("ДокументСсылка.РаскрытиеСпискаВладельцев") Тогда
		ДокументПоискаСсылка = ОбщегоНазначения.ЗначениеРеквизитаОбъекта("ДокументСсылка", "КарточкаКД");
	Иначе
		ВызватьИсключение "Не верный параметр номер 1, ожидается ДокументСсылка.КорпоративноеДействие_Новый, ДокументСсылка.РаскрытиеСпискаВладельцев"; 
	КонецЕсли;
	
	ДатаПроверки = ТекущаяДатаСеанса();
	Запрос = Новый Запрос(
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	МИНИМУМ(ЭтапыКД.Период) КАК Период,
	|	ЭтапыКД.КД КАК КД
	|ИЗ
	|	РегистрСведений.ЭтапыКД КАК ЭтапыКД
	|ГДЕ
	|	ЭтапыКД.КД = &ДокументПоиска
	|
	|СГРУППИРОВАТЬ ПО
	|	ЭтапыКД.КД");
	
	Запрос.УстановитьПараметр("ДокументПоиска", ДокументПоискаСсылка);
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл 
		ДатаПроверки = Выборка.Период;	
	КонецЦикла;
	
	Возврат ИспользоватьСхемуУведомленийWTRC_QI(ДатаПроверки);
	
КонецФункции

// Функция - Клиенты для регистрации отправленных уведомлений
// Принимает таблицу значений или массив строк таблицы значений, возвращает таблицу клиентов(без суббклиентов) для отправки уведомлений
// Параметры:
//  ИсходнаяТаблицаКлиентов	 - ТаблицаЗначений, Массив из строк ТаблицыЗначений	
// 
// Возвращаемое значение:
//  ТаблицаЗначений -  
//
Функция КлиентыДляРегистрацииОтправленныхУведомлений(ИсходнаяТаблицаКлиентов) Экспорт 
	ТаблицаКлиентов = Новый ТаблицаЗначений();
	ТаблицаКлиентов.Колонки.Добавить("Клиент");
	ТаблицаКлиентов.Колонки.Добавить("Договор");
	ТаблицаКлиентов.Колонки.Добавить("СчетДепо");
	ТаблицаКлиентов.Колонки.Добавить("ЦеннаяБумага");
	ТаблицаКлиентов.Колонки.Добавить("Количество");
	ТаблицаКлиентов.Колонки.Добавить("MessageId");
	Для Каждого СтрокаТаблицы Из ИсходнаяТаблицаКлиентов Цикл 
		ЗаполнитьЗначенияСвойств(ТаблицаКлиентов.Добавить(), СтрокаТаблицы);	
	КонецЦикла;
	ТаблицаКлиентов.Свернуть("Клиент, Договор, СчетДепо, ЦеннаяБумага, MessageId", "Количество");
	Возврат ТаблицаКлиентов;
КонецФункции

// Возвращает пустую таблицу значений с типизированными колонками для
//  субклиентов общих разделов
// 
// Возвращаемое значение:
//  Таблица значений - таблица субклиентов
//
Функция НоваяТаблицаСубклиентовОбщихРазделов()
	
	СубклиентыОбщиеРазделы = Новый ТаблицаЗначений;
	СубклиентыОбщиеРазделы.Колонки.Добавить("РСВ", Новый ОписаниеТипов("ДокументСсылка.РаскрытиеСпискаВладельцев"));
	СубклиентыОбщиеРазделы.Колонки.Добавить("Клиент", Новый ОписаниеТипов("СправочникСсылка.Контрагенты"));
	СубклиентыОбщиеРазделы.Колонки.Добавить("СчетДепо", Новый ОписаниеТипов("СправочникСсылка.СчетаДепо"));
	СубклиентыОбщиеРазделы.Колонки.Добавить("СчетДепоМХ", Новый ОписаниеТипов("СправочникСсылка.СчетаДепоМХ"));
	СубклиентыОбщиеРазделы.Колонки.Добавить("РазделСчетаДепо", Новый ОписаниеТипов("СправочникСсылка.РазделыСчетаДепо"));
	СубклиентыОбщиеРазделы.Колонки.Добавить("РазделСчетаДепоМХ", Новый ОписаниеТипов("СправочникСсылка.РазделыСчетаДепоМХ"));
	СубклиентыОбщиеРазделы.Колонки.Добавить("Количество", Метаданные.ОпределяемыеТипы.КоличествоЦБ.Тип);
	СубклиентыОбщиеРазделы.Колонки.Добавить("W8BENE_W8BEN", Новый ОписаниеТипов("СправочникСсылка.ФормыW8"));
	СубклиентыОбщиеРазделы.Колонки.Добавить("W8IMY", Новый ОписаниеТипов("СправочникСсылка.ФормыW8"));
	СубклиентыОбщиеРазделы.Колонки.Добавить("НалоговаяСтавка", Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(4,2)));
	СубклиентыОбщиеРазделы.Колонки.Добавить("СтатусПоГлаве4", Новый ОписаниеТипов("Строка",,Новый КвалификаторыСтроки(10)));
	СубклиентыОбщиеРазделы.Колонки.Добавить("Субклиент", Новый ОписаниеТипов("Строка,СправочникСсылка.Субклиенты",,Новый КвалификаторыСтроки(255)));
	СубклиентыОбщиеРазделы.Колонки.Добавить("Поручение", Новый ОписаниеТипов("ДокументСсылка.Поручение"));
	Возврат СубклиентыОбщиеРазделы;
	
КонецФункции

Функция ТекстЗапросаДанныеВыплатПоЦБАмерикиОпределениеРСВ()
	
	Возврат
	"ВЫБРАТЬ
	|	ПоручениеКлиента.Ссылка КАК Поручение,
	|	ПоручениеЦенныеБумагиСписываемые.ЦеннаяБумага КАК ЦеннаяБумага,
	|	ПоручениеЦенныеБумагиСписываемые.СчетДепо КАК СчетДепо,
	|	ПоручениеЦенныеБумагиСписываемые.РазделСчетаДепо КАК РазделСчетаДепо,
	|	ПоручениеЦенныеБумагиСписываемые.СчетДепоМХ КАК СчетДепоМХ,
	|	ПоручениеЦенныеБумагиСписываемые.РазделСчетаДепоМХ КАК РазделСчетаДепоМХ,
	|	ПоручениеЦенныеБумагиСписываемые.Сумма КАК Сумма,
	|	ПоручениеЦенныеБумагиСписываемые.СуммаНалога КАК СуммаНалога,
	|	ПоручениеЦенныеБумагиСписываемые.СуммаКВыплатеПоИПД КАК СуммаКВыплатеПоИПД,
	|	ПоручениеКлиента.КарточкаКД КАК КорпоративноеДействие,
	|	ПОДСТРОКА(ПоручениеКлиента.КарточкаКД.КДРеференс, 0, 6) КАК КДРеференсСвязанный,
	|	ПоручениеЦенныеБумагиСписываемые.Количество КАК Количество,
	|	ПоручениеЦенныеБумагиСписываемые.СтавкаНалога КАК СтавкаНалога,
	|	ПоручениеКлиента.СтатусПоГлаве4 КАК СтатусПоГлаве4,
	|	ПоручениеЦенныеБумагиСписываемые.СчетДепо.Владелец КАК Контрагент,
	|	ПоручениеЦенныеБумагиСписываемые.СчетДепо.Владелец.Субброкер КАК ЭтоСубброкер,
	|	ПоручениеЦенныеБумагиСписываемые.СчетДепо.Владелец.УправляющаяКомпания КАК ЭтоУправляющаяКомпания,
	|	ПоручениеКлиента.КарточкаКД.ВидКД КАК ВидКД,
