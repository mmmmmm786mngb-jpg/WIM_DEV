	Запрос.УстановитьПараметр("ДатаСреза",	ДатаФиксации);
	Запрос.УстановитьПараметр("Россия",		Справочники.КлассификаторСтранМира.РОССИЯ);
	Запрос.УстановитьПараметр("НДЦ",		Константы.КлассификаторЗагрузкиНДЦ.Получить());
	Запрос.УстановитьПараметр("Адрес",					Перечисления.ТипыКонтактнойИнформации.Адрес);
	Запрос.УстановитьПараметр("МестоГосРегистрации",	Справочники.ВидыКонтактнойИнформации.ЮрАдресЮрЛица);
	Запрос.УстановитьПараметр("МестоЖительства",		Справочники.ВидыКонтактнойИнформации.ЮрАдресФизЛица);
	Запрос.УстановитьПараметр("ФактическийАдресЮрЛица",	Справочники.ВидыКонтактнойИнформации.ФактАдресЮрЛица);
	Запрос.УстановитьПараметр("МестоПребывания",		Справочники.ВидыКонтактнойИнформации.ФактАдресФизЛица);
	
	Запрос.УстановитьПараметр("ПредставлениеСтатусаНалоговогоРезидентаРФ",		"Налоговый резидент РФ");
	Запрос.УстановитьПараметр("ПредставлениеСтатусаНалоговогоНерезидентаРФ",	"Налоговый нерезидент РФ");
	
	// Замена значений параметров запроса
	Если ПредставлениеЗначений <> Неопределено Тогда
		Для Каждого КлючИЗначение Из Запрос.Параметры Цикл
			НайденноеЗначение = "";
			Если ПредставлениеЗначений.Свойство(КлючИЗначение.Ключ, НайденноеЗначение) Тогда
				Запрос.УстановитьПараметр(КлючИЗначение.Ключ, НайденноеЗначение);
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	Данные = Запрос.Выполнить().Выгрузить();
	
	Данные.Колонки.Добавить("КодКлиента");
	Данные.Колонки.Добавить("ЗаявленнаяНалоговаяСтавка");
	Для Каждого Строка Из Данные Цикл
		Строка.КодКлиента = СокрЛП(Строка.КодСубброкера) + "_" + СокрЛП(Строка.КодСубклиента);
		Если Строка.ЗаполнятьЗаявленнуюНалоговуюСтавку Тогда
			Строка.ЗаявленнаяНалоговаяСтавка = Строка(Строка.ЗаявленнаяНалоговаяСтавкаЧисло) + "%";
		Иначе
			Строка.ЗаявленнаяНалоговаяСтавка = "";
		КонецЕсли;		
		Если ОбщегоНазначения.ТолькоЦифрыВСтроке(Строка.АдресМестонахожденияРегистрацииСтрана) Тогда
			Строка.АдресМестонахожденияРегистрацииСтрана = "РОССИЯ";
		Иначе
			Строка.АдресМестонахожденияРегистрацииИндекс = "";
		КонецЕсли;
		Если ОбщегоНазначения.ТолькоЦифрыВСтроке(Строка.АдресПочтовыйСтрана) Тогда
			Строка.АдресПочтовыйСтрана = "РОССИЯ";
		Иначе
			Строка.АдресПочтовыйИндекс = "";
		КонецЕсли;
	КонецЦикла;
	
	Возврат Данные;
	
КонецФункции

Функция ФайлРасшифровкиЗапросаНаРаскрытиеПоСубклиентамЦБНеСША(ДанныеПоСубброкеру, ИспользоватьРегистрациюЗапросовСубброкера = Ложь) Экспорт
	
	ИмяМакета = "ЗапросНаРаскрытиеПоСубклиентам";
	Если Не ИспользоватьРегистрациюЗапросовСубброкера Тогда 
		ИмяМакета = "ЗапросНаРаскрытиеПоСубклиентам_БезДокументовЗапросов";	
	КонецЕсли;
	
	ЦБПодпадаетПодНалоговоеРегулировениеСША = Ложь;
	Возврат ФайлРасшифровкиЗапросаНаРаскрытиеПоСубклиентам(ДанныеПоСубброкеру, ИмяМакета,
				ЦБПодпадаетПодНалоговоеРегулировениеСША);
	
КонецФункции

Функция ФайлРасшифровкиЗапросаНаРаскрытиеПоСубклиентамЦБСША(ДанныеПоСубброкеру, ИспользоватьРегистрациюЗапросовСубброкера = Ложь) Экспорт
	
	ИмяМакета = "ЗапросНаРаскрытиеПоСубклиентамЦБСША";
	Если Не ИспользоватьРегистрациюЗапросовСубброкера Тогда 
		ИмяМакета = "ЗапросНаРаскрытиеПоСубклиентамЦБСША_БезДокументовЗапросов";	
	КонецЕсли;
	ЦБПодпадаетПодНалоговоеРегулировениеСША = Истина;	
	Возврат ФайлРасшифровкиЗапросаНаРаскрытиеПоСубклиентам(ДанныеПоСубброкеру, ИмяМакета,
				ЦБПодпадаетПодНалоговоеРегулировениеСША);
	
КонецФункции

// Возвращает имя временного XLSX-файла расшифровки запроса субброкера на раскрытие
//
// Параметры:
//  ДанныеПоСубброкеру	 - ТаблицаЗначений, Массив строк ТаблицыЗначений - данные о субклиентах для вывода в файл
//  ИспользоватьРегистрациюЗапросовСубброкераИЗагрузкуОтветовСубброкера	 - Булево	 - указывает, следует ли при
//		формировании файла использовать макет, предполагающий загрузку в документ ОтветСубброкераНаРаскрытие
// 
// Возвращаемое значение:
//  Строка  - Имя сформированного файла
//
Функция ФайлРасшифровкиЗапросаСубброкераНаРаскрытие(ДанныеПоСубброкеру, ИспользоватьРегистрациюЗапросовСубброкераИЗагрузкуОтветовСубброкера = Ложь) Экспорт
	
	ИмяМакета = "ЗапросСубброкераНаРаскрытие";
	Если Не ИспользоватьРегистрациюЗапросовСубброкераИЗагрузкуОтветовСубброкера Тогда 
		ИмяМакета = "ЗапросНаРаскрытиеПоСубклиентам_БезДокументовЗапросов";	
	КонецЕсли;
	ЦБПодпадаетПодНалоговоеРегулировениеСША = Ложь;
	ВыводитьНалоги = Истина;
	Возврат ФайлРасшифровкиЗапросаНаРаскрытиеПоСубклиентам(ДанныеПоСубброкеру, ИмяМакета,
				ЦБПодпадаетПодНалоговоеРегулировениеСША, ВыводитьНалоги);
	
КонецФункции

// формирует xml-файл расшифровки запроса на раскрытие и возвращает его имя
//
// Параметры:
//  ДанныеЗаполнения	 - выборка из запроса - данные заполнения уведомлений и запросов к отправке
// 
// Возвращаемое значение:
//  Строка  - Имя сформированного файла
Функция ФайлРасшифровкиЗапросаСубброкераНаРаскрытиеXML(ДанныеЗаполнения) Экспорт

	ДанныеДляЗаполненияXML = ДанныеДляЗаполненияЗапросаСубброкераНаРаскрытиеXML(ДанныеЗаполнения);
	Если ДанныеДляЗаполненияXML = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	ПространствоИмен = "FCDR_2017_02(2019v3)";
	
	ТипРаскрытие = ФабрикаXDTO.Пакеты.Получить(ПространствоИмен).КорневыеСвойства.Получить("DISCLOSURE_REQUEST").Тип;
	РаскрытиеXDTO = ФабрикаXDTO.Создать(ТипРаскрытие);
	РаскрытиеXDTO.version	= "FCDR_17_02";
	РаскрытиеXDTO.header = Header_РСВ_FCDR(ДанныеДляЗаполненияXML, ПространствоИмен);
	
	РаскрытиеXDTO.message_function = "NEWM";
	РаскрытиеXDTO.corporate_action_reference = Сorporate_action_reference_РСВ_FCDR(ДанныеДляЗаполненияXML, ПространствоИмен);
	РаскрытиеXDTO.issuer.Добавить(Issuer_РСВ_FCDR(ДанныеДляЗаполненияXML, ПространствоИмен));
	Если ЗначениеЗаполнено(ДанныеДляЗаполненияXML.ПайНаименованиеВыпуска) Тогда
		РаскрытиеXDTO.issuer.Добавить(IssuerПай_РСВ_FCDR(ДанныеДляЗаполненияXML, ПространствоИмен));
	КонецЕсли;
	РаскрытиеXDTO.initiator_request = НовыйОбъектСхемыFCDR("initiator_request_type_t", ПространствоИмен);
	РаскрытиеXDTO.initiator_request.initiator_request_type_code = ДанныеДляЗаполненияXML.РСВИнициаторЗапроса;
	
	СтрокаBasis_of_request = РаскрытиеXDTO.basis_of_request.Добавить(НовыйОбъектСхемыFCDR("laws_in_place_t", ПространствоИмен));
	СтрокаBasis_of_request.laws_in_place_code = ДанныеДляЗаполненияXML.РСВКодОснованияЗапроса;
	
	Если ДанныеДляЗаполненияXML.РСВКодОснованияЗапроса = "OTHR" 
		Или ЗначениеЗаполнено(ДанныеДляЗаполненияXML.РСВДополнительноеОписаниеОснованияЗапроса) Тогда
		СтрокаBasis_of_request.narrative = ДанныеДляЗаполненияXML.РСВДополнительноеОписаниеОснованияЗапроса;
	КонецЕсли;

	Если ЗначениеЗаполнено(ДанныеДляЗаполненияXML.РСВПодзаконныйАкт) Тогда
		СтрокаBasis_of_request.subordinate_legislation.Добавить(ДанныеДляЗаполненияXML.РСВПодзаконныйАкт);
	КонецЕсли;
	
	РаскрытиеXDTO.information_indicator = НовыйОбъектСхемыFCDR("information_type_V02_t", ПространствоИмен);
	РаскрытиеXDTO.information_indicator.information_type_code = ДанныеДляЗаполненияXML.РСВТипСписка;
	РаскрытиеXDTO.information_indicator.request_bank_details = ?(ДанныеДляЗаполненияXML.РСВБанковскиеРеквизиты, "Yes", "No");
	РаскрытиеXDTO.information_indicator.disclosure_template = ДанныеДляЗаполненияXML.РСВШаблонFCDR_2017_02;
	
	РаскрытиеXDTO.record_date = ДанныеДляЗаполненияXML.ДатаСпискаЛиц;
	РаскрытиеXDTO.response_deadline = ДанныеДляЗаполненияXML.ДатаОкончанияПриемаИнструкцийВТБКБ;
	ТипRegistered_shareholders = РаскрытиеXDTO.Свойства().Получить("Registered_shareholders").Тип;
	СтрокаRegistered_shareholders = РаскрытиеXDTO.registered_shareholders.Добавить(ФабрикаXDTO.Создать(ТипRegistered_shareholders));
	СтрокаRegistered_shareholders.account_dtls = НовыйОбъектСхемыFCDR("account_dtls_v04_t", ПространствоИмен);
	СтрокаRegistered_shareholders.account_dtls.account_id = НовыйОбъектСхемыFCDR("id_V02_t", ПространствоИмен);
	СтрокаRegistered_shareholders.account_dtls.account_id.id = СокрЛП(ДанныеДляЗаполненияXML.СчетДЕПОПредставление);
	СтрокаRegistered_shareholders.account_dtls.account_type = НовыйОбъектСхемыFCDR("account_type_V02_t", ПространствоИмен);
	Если ДанныеДляЗаполненияXML.Резидент Тогда
		КодТипаДержателя = "02";
	Иначе
		КодТипаДержателя = "20";
	КонецЕсли;
	
	СтрокаRegistered_shareholders.account_dtls.account_type.account_type_code = КодТипаДержателя;
	СтрокаRegistered_shareholders.account_holder = НовыйОбъектСхемыFCDR("party_id_name_V03_t", ПространствоИмен);
	Строкаaccount_holder_id = СтрокаRegistered_shareholders.account_holder.id.Добавить(НовыйОбъектСхемыFCDR("id_V02_t", ПространствоИмен));
	Строкаaccount_holder_id.id = СокрЛП(ДанныеДляЗаполненияXML.КлиентКод);
	СтрокаRegistered_shareholders.account_holder.name = СокрЛП(ДанныеДляЗаполненияXML.КлиентНаименование);
	
	security_balance_t_v03 = НовыйОбъектСхемыFCDR("security_balance_t_v03", ПространствоИмен);
	Строкаsecurity_balance = СтрокаRegistered_shareholders.security_balance.Добавить(security_balance_t_v03);
	Строкаsecurity_balance.security = НовыйОбъектСхемыFCDR("security_info_V3_t", ПространствоИмен);
	Строкаsecurity_balance.security.security_classification = ДанныеДляЗаполненияXML.ТипЦБ;
	Если ЗначениеЗаполнено(ДанныеДляЗаполненияXML.ВидЦБАкция) Тогда
		Строкаsecurity_balance.security.security_category = ДанныеДляЗаполненияXML.ВидЦБАкция;
	КонецЕсли;
	Если ЗначениеЗаполнено(ДанныеДляЗаполненияXML.ВалютаНоминалаНаименованиеДляОтчетов) Тогда
		Строкаsecurity_balance.security.nominal_value = НовыйОбъектСхемыFCDR("currency_and_amount_t", ПространствоИмен);
		Строкаsecurity_balance.security.nominal_value.ccy_code = ДанныеДляЗаполненияXML.ВалютаНоминалаНаименованиеДляОтчетов;
		ДанныеНоминалаЦБ = РегистрыСведений.НоминалЦБ.СрезПоследних(, Новый Структура("ЦеннаяБумага", ДанныеДляЗаполненияXML.ЦБ));
		Если ДанныеНоминалаЦБ.Количество() > 0 Тогда
			ЦБНоминал = ДанныеНоминалаЦБ[0].Сумма;
		Иначе
			ЦБНоминал = 0;
		КонецЕсли;
		Строкаsecurity_balance.security.nominal_value.amount = ЦБНоминал;
		
	КонецЕсли;
	Если ЗначениеЗаполнено(ДанныеДляЗаполненияXML.НомерРегистрации) Тогда
		Строкаsecurity_balance.security.state_reg_num = ДанныеДляЗаполненияXML.НомерРегистрации;
	КонецЕсли;
	Если ЗначениеЗаполнено(ДанныеДляЗаполненияXML.ISIN) Тогда
		Строкаsecurity_balance.security.ISIN_identifier = ДанныеДляЗаполненияXML.ISIN;
	КонецЕсли;
	Если ЗначениеЗаполнено(ДанныеДляЗаполненияXML.ЦБКод) Тогда
		Строкаsecurity_balance.security.proprietary_security_code = НовыйОбъектСхемыFCDR("id_V02_t", ПространствоИмен);
		Строкаsecurity_balance.security.proprietary_security_code.id = ДанныеДляЗаполненияXML.КодНДЦ;
		Строкаsecurity_balance.security.proprietary_security_code.issuer = "NSDR";
	КонецЕсли;
	Строкаsecurity_balance.total = НовыйОбъектСхемыFCDR("quantity_choice_t", ПространствоИмен);
	КоличествоЦБ = ДанныеДляЗаполненияXML.ЗапросСубброкеруНаРаскрытие.ДанныеСубброкера.Итог("Количество");
	ТипQty_units = Строкаsecurity_balance.total.свойства().получить("qty_units").Тип;
	Строкаsecurity_balance.total.qty_units = ФабрикаXDTO.Создать(ТипQty_units);
	Строкаsecurity_balance.total.qty_units.units = КоличествоЦБ;
	СтрокаContacts = РаскрытиеXDTO.contacts.Добавить(НовыйОбъектСхемыFCDR("party_contacts_t_v02", ПространствоИмен));
	СтрокаPhone_or_fax = СтрокаContacts.phone_or_fax.Добавить(НовыйОбъектСхемыFCDR("phone_V02_t", ПространствоИмен));
	ОтборТелефонаОрганизации = Новый Структура("Объект,Тип,Вид", ДанныеДляЗаполненияXML.Организация,
	Перечисления.ТипыКонтактнойИнформации.Телефон, Справочники.ВидыКонтактнойИнформации.ТелефонОрганизации);
	ДанныеНомерТелефона = РегистрыСведений.КонтактнаяИнформация.СрезПоследних(, ОтборТелефонаОрганизации);
	Если ДанныеНомерТелефона.Количество() > 0 Тогда
		НомерТелефона = ДанныеНомерТелефона[0].Представление;
	Иначе
		НомерТелефона = "";
	КонецЕсли;
	СтрокаPhone_or_fax.phone_num = НомерТелефона;
	
	ТекстДокумента = ПереработанныйТекстДокумента(ДанныеДляЗаполненияXML, РаскрытиеXDTO);
	
	ИмяФайла = ПолучитьИмяВременногоФайла("xml");
	ТекстXML = Новый ЗаписьТекста(ИмяФайла, КодировкаТекста.Системная);
	ТекстXML.Записать(ТекстДокумента);
	ТекстXML.Закрыть();
	
	Возврат ИмяФайла;
	
КонецФункции

Функция ДанныеДляЗаполненияЗапросаСубброкераНаРаскрытиеXML(ДанныеЗаполнения)
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ЗапросСубброкеруНаРаскрытие.КодLEI КАК КлиентLEI,
	|	ЗапросСубброкеруНаРаскрытие.Клиент.Наименование КАК КлиентНаименование,
	|	РаскрытиеСпискаВладельцев.Номер КАК РСВНомер,
	|	РаскрытиеСпискаВладельцев.Дата КАК РСВДата,
	|	РаскрытиеСпискаВладельцев.Организация.Наименование КАК ОрганизацияНаименование,
	|	РаскрытиеСпискаВладельцев.Организация.LEI КАК ОрганизацияLEI,
	|	ЗапросСубброкеруНаРаскрытие.РеференсКД КАК РеференсКД,
	|	РаскрытиеСпискаВладельцев.Эмитент.НаименованиеПолное КАК ЭмитентПредставление,
	|	РаскрытиеСпискаВладельцев.Эмитент.ЮридическиеФизическиеЛица.ОГРН КАК ЭмитентОГРН,
	|	РаскрытиеСпискаВладельцев.Эмитент.ЮридическиеФизическиеЛица.ИНН КАК ЭмитентИНН,
	|	РаскрытиеСпискаВладельцев.Эмитент.ЮридическиеФизическиеЛица.ПолноеНаименование КАК ПолноеНаименованиеЮрЛицо,
	|	ВЫБОР
	|		КОГДА РаскрытиеСпискаВладельцев.ЦеннаяБумага1.ТипЦБ = ЗНАЧЕНИЕ(Перечисление.ТипыЦБ.Пай)
	|			ТОГДА РаскрытиеСпискаВладельцев.ЦеннаяБумага1.НаименованиеВыпуска
	|		ИНАЧЕ """"
	|	КОНЕЦ КАК ПайНаименованиеВыпуска,
	|	ВЫБОР
	|		КОГДА РаскрытиеСпискаВладельцев.ЦеннаяБумага1.ТипЦБ = ЗНАЧЕНИЕ(Перечисление.ТипыЦБ.Пай)
	|			ТОГДА РаскрытиеСпискаВладельцев.ЦеннаяБумага1.НомерРегистрации
	|		ИНАЧЕ """"
	|	КОНЕЦ КАК ПайНомерРегистрации,
	|	ЗапросСубброкеруНаРаскрытие.ДатаСпискаЛиц КАК ДатаСпискаЛиц,
	|	РаскрытиеСпискаВладельцев.ДатаОкончанияПриемаИнструкцийВТБКБ КАК ДатаОкончанияПриемаИнструкцийВТБКБ,
	|	ПРЕДСТАВЛЕНИЕ(ЗапросСубброкеруНаРаскрытие.СчетДЕПО) КАК СчетДЕПОПредставление,
	|	ВЫБОР
	|		КОГДА РаскрытиеСпискаВладельцев.Эмитент.ЮридическиеФизическиеЛица.Страна = ЗНАЧЕНИЕ(Справочник.Классификаторстранмира.Россия)
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК Резидент,
	|	ВЫБОР
	|		КОГДА РаскрытиеСпискаВладельцев.ЦеннаяБумага1.ТипЦБ = ЗНАЧЕНИЕ(Перечисление.ТипыЦБ.Облигация)
	|			ТОГДА ""BOND""
	|		КОГДА РаскрытиеСпискаВладельцев.ЦеннаяБумага1.ТипЦБ = ЗНАЧЕНИЕ(Перечисление.ТипыЦБ.Акция)
	|			ТОГДА ""SHAR""
	|		КОГДА РаскрытиеСпискаВладельцев.ЦеннаяБумага1.ТипЦБ = ЗНАЧЕНИЕ(Перечисление.ТипыЦБ.Пай)
	|			ТОГДА ""MFUN""
	|		КОГДА РаскрытиеСпискаВладельцев.ЦеннаяБумага1.ТипЦБ = ЗНАЧЕНИЕ(Перечисление.ТипыЦБ.ДепозитарнаяРасписка)
	|				И РаскрытиеСпискаВладельцев.ЦеннаяБумага1.ВидЦБ = ЗНАЧЕНИЕ(Перечисление.ВидыДепозитарныхРасписок.РоссийскаяДепозитарнаяРасписка)
	|			ТОГДА ""RDRP""
	|		КОГДА РаскрытиеСпискаВладельцев.ЦеннаяБумага1.ТипЦБ = ЗНАЧЕНИЕ(Перечисление.ТипыЦБ.КлиринговыйСертификатУчастия)
	|			ТОГДА ""MPPC""
	|	КОНЕЦ КАК ТипЦБ,
	|	ВЫБОР
	|		КОГДА РаскрытиеСпискаВладельцев.ЦеннаяБумага1.ТипЦБ = ЗНАЧЕНИЕ(Перечисление.ТипыЦБ.Акция)
	|				И РаскрытиеСпискаВладельцев.ЦеннаяБумага1.ВидЦБ = ЗНАЧЕНИЕ(Перечисление.ВидыАкций.Обыкновенная)
	|			ТОГДА ""ORDN""
	|		КОГДА РаскрытиеСпискаВладельцев.ЦеннаяБумага1.ТипЦБ = ЗНАЧЕНИЕ(Перечисление.ТипыЦБ.Акция)
	|				И РаскрытиеСпискаВладельцев.ЦеннаяБумага1.ВидЦБ = ЗНАЧЕНИЕ(Перечисление.ВидыАкций.Привилегированная)
	|			ТОГДА ""PREF""
	|	КОНЕЦ КАК ВидЦБАкция,
	|	РаскрытиеСпискаВладельцев.ЦеннаяБумага1.ВалютаНоминала.НаименованиеДляОтчетов КАК ВалютаНоминалаНаименованиеДляОтчетов,
	|	РаскрытиеСпискаВладельцев.ЦеннаяБумага1 КАК ЦБ,
	|	РаскрытиеСпискаВладельцев.ЦеннаяБумага1.НомерРегистрации КАК НомерРегистрации,
	|	РаскрытиеСпискаВладельцев.ЦеннаяБумага1.ISIN КАК ISIN,
	|	РаскрытиеСпискаВладельцев.ЦеннаяБумага1.Код КАК ЦБКод,
	|	ЗапросСубброкеруНаРаскрытие.Ссылка КАК ЗапросСубброкеруНаРаскрытие,
	|	РаскрытиеСпискаВладельцев.Организация КАК Организация,
	|	РаскрытиеСпискаВладельцев.Комментарий КАК РСВКомментарий,
	|	РаскрытиеСпискаВладельцев.ИнициаторЗапроса.Код КАК РСВИнициаторЗапроса,
	|	РаскрытиеСпискаВладельцев.КодОснованияЗапроса.Код КАК РСВКодОснованияЗапроса,
	|	РаскрытиеСпискаВладельцев.ДополнительноеОписаниеОснованияЗапроса КАК РСВДополнительноеОписаниеОснованияЗапроса,
	|	РаскрытиеСпискаВладельцев.ПодзаконныйАкт КАК РСВПодзаконныйАкт,
	|	РаскрытиеСпискаВладельцев.ТипСписка.Код КАК РСВТипСписка,
	|	РаскрытиеСпискаВладельцев.ПредоставитьБанковскиеРеквизиты КАК РСВБанковскиеРеквизиты,
	|	РаскрытиеСпискаВладельцев.ШаблонFCDR_2017_02 КАК РСВШаблонFCDR_2017_02,
	|	ЗапросСубброкеруНаРаскрытие.Номер КАК ЗапросНомер,
	|	ЗапросСубброкеруНаРаскрытие.Дата КАК ЗапросДата,
	|	ВЫБОР
	|		КОГДА ЗапросСубброкеруНаРаскрытие.ВидКД.ТипКорпоративныхДействий = ЗНАЧЕНИЕ(Перечисление.ТипыКорпоративныхДействий.Доход)
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК ЭтоДоход,
	|	ЗапросСубброкеруНаРаскрытие.Клиент.Код КАК КлиентКод,
	|	КодыЗагрузки.Код КАК КодНДЦ
	|ИЗ
	|	Документ.ЗапросСубброкеруНаРаскрытие КАК ЗапросСубброкеруНаРаскрытие
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.РаскрытиеСпискаВладельцев КАК РаскрытиеСпискаВладельцев
	|			ЛЕВОЕ СОЕДИНЕНИЕ Справочник.КодыЗагрузки КАК КодыЗагрузки
	|			ПО (КодыЗагрузки.Биржа = &НДЦ)
	|				И РаскрытиеСпискаВладельцев.ЦеннаяБумага1 = КодыЗагрузки.Владелец
	|		ПО ЗапросСубброкеруНаРаскрытие.РСВ = РаскрытиеСпискаВладельцев.Ссылка
	|ГДЕ
	|	ЗапросСубброкеруНаРаскрытие.Ссылка = &Ссылка";
	Запрос.УстановитьПараметр("НДЦ", Константы.КлассификаторЗагрузкиНДЦ.Получить());
	Запрос.УстановитьПараметр("Ссылка", ДанныеЗаполнения.ЗапросСубброкеруСсылка);
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка;
	Иначе
		Возврат Неопределено;
	КонецЕсли;
	
КонецФункции

Функция Header_РСВ_FCDR(ДанныеДляЗаполненияXML, ПространствоИмен)
	Результат = НовыйОбъектСхемыFCDR("header_t", ПространствоИмен);
	
	НомерРаскрытия = "ZS" + ДанныеДляЗаполненияXML.ЗапросНомер;
	
	Результат.doc_num = НомерРаскрытия;
	Результат.doc_date = Новый_date_or_datetime_t(ПространствоИмен, ДанныеДляЗаполненияXML.ЗапросДата);
	
	РегистрационныеДанные = НовыйРегистрационныеДанныеДля_party_identification2_V02_t(ДанныеДляЗаполненияXML.ОрганизацияLEI, "OTHR", "LEIC");
	Результат.from = Новый_party_identification2_V02_t(РегистрационныеДанные,
		ДанныеДляЗаполненияXML.ОрганизацияНаименование, ПространствоИмен);
	
	РегистрационныеДанные = НовыйРегистрационныеДанныеДля_party_identification2_V02_t(ДанныеДляЗаполненияXML.КлиентLEI, "OTHR", "LEIC");
	Результат.to = Новый_party_identification2_V02_t(РегистрационныеДанные, ДанныеДляЗаполненияXML.КлиентНаименование, ПространствоИмен);
	Возврат Результат;
КонецФункции

Функция Новый_party_identification2_V02_t(РегистрационныеДанные, Наименование = Неопределено, ПространствоИмен)
	
	Результат = НовыйОбъектСхемыFCDR("party_identification2_V02_t", ПространствоИмен);
	
	Результат.id_2.Добавить(Новый_id_type_V02_t(РегистрационныеДанные, ПространствоИмен));
	Результат.name = Наименование;

	Возврат Результат;
КонецФункции

Функция Новый_id_type_V02_t(РегистрационныеДанные, ПространствоИмен)
	
	Результат = НовыйОбъектСхемыFCDR("id_type_V02_t", ПространствоИмен);
	
	Результат.id = СокрЛП(РегистрационныеДанные.Идентификатор);
	Результат.id_type = РегистрационныеДанные.ТипИдентификатора;
	Результат.narrative = РегистрационныеДанные.ОписаниеТипаИдентификатораПрочее;

	Возврат Результат;
КонецФункции

Функция Новый_date_or_datetime_t(ПространствоИмен, Дата = Неопределено, ВключаяВремя = Ложь)
	Результат = НовыйОбъектСхемыFCDR("date_or_datetime_t", ПространствоИмен);
	
	Если ВключаяВремя Тогда
		Результат.datetime = Дата;
	Иначе
		Результат.date = Дата;
	КонецЕсли;
	
	Возврат Результат;
КонецФункции

Функция НовыйРегистрационныеДанныеДля_party_identification2_V02_t(Идентификатор, ТипИдентификатора,
		ОписаниеТипаИдентификатораПрочее = Неопределено)
