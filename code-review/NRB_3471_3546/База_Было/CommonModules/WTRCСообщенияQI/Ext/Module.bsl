	Если ЗначениеЗаполнено(ДанныеЗаполнения.ТипЦБ2) Тогда 
		ТипЦБ = ТипЦБ + СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(" / %1 %2", ДанныеЗаполнения.ТипЦБ2, ДанныеЗаполнения.ISIN2);
	КонецЕсли;
	ReplaceFields.Вставить("ХарактеристикиЦБ", ТипЦБ);
	ReplaceFields.Вставить("КДРеференс", ДанныеЗаполнения.РеференсКД);
	ReplaceFields.Вставить("ДатаКДПлан", ДанныеЗаполнения.ДатаКДПлан);
	ReplaceFields.Вставить("ДатаФиксации", ДанныеЗаполнения.ДатаФиксации);
