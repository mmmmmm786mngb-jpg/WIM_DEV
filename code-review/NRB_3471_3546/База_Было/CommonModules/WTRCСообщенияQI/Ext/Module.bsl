Функция add_info_РСВ_FCDR(ДанныеДляЗаполненияXML)
	
	ТекстДляДобавления = "";
	СтрокиКомментария = СтрРазделить(ДанныеДляЗаполненияXML.РСВКомментарий, Символы.ПС, Ложь);
	Если ДанныеДляЗаполненияXML.ЭтоДоход Тогда
		ТекстДляДобавления = "<text>
		|Документы, дающие основания владельцам ценных бумаг на льготное налогообложение доходов, просим предоставить"
			+ "не позднее указанного срока приема раскрытия списка владельцев
		|</text>" + Символы.ПС;
	КонецЕсли;
	Для Каждого СтрокаКомментария Из СтрокиКомментария Цикл
		Если СтрНайти(СтрокаКомментария, "text: ") > 0 Тогда
			СтрокаКомментария = СокрЛП(СтрЗаменить(СтрокаКомментария, "text: ", ""));
			ТекстДляДобавления = ТекстДляДобавления + "<text>" + СтрокаКомментария + "</text>";
		ИначеЕсли СтрНайти(СтрокаКомментария, "Ext/FormCode: ") > 0 Тогда
			СтрокаКомментария = СокрЛП(СтрЗаменить(СтрокаКомментария, "Ext/FormCode: ", ""));
			ТекстДляДобавления = ТекстДляДобавления + "<Ext><FormCode>" + СтрокаКомментария + "</FormCode></Ext>";
		ИначеЕсли СтрНайти(СтрокаКомментария, "XtnsnDt/response_deadline_time: ") > 0 Тогда
			СтрокаКомментария = СокрЛП(СтрЗаменить(СтрокаКомментария, "XtnsnDt/response_deadline_time: ", ""));
			ТекстДляДобавления = ТекстДляДобавления + "<XtnsnDt><response_deadline_time>" + СтрокаКомментария + "</response_deadline_time>";
		ИначеЕсли СтрНайти(СтрокаКомментария, "XtnsnDt/disclosure_currency: ") > 0 Тогда
			СтрокаКомментария = СокрЛП(СтрЗаменить(СтрокаКомментария, "XtnsnDt/disclosure_currency: ", ""));
			ТекстДляДобавления = ТекстДляДобавления + "<disclosure_currency>" + СтрокаКомментария + "</disclosure_currency></XtnsnDt>";
		КонецЕсли;
	КонецЦикла;
	
	Возврат ТекстДляДобавления;
	
КонецФункции

Функция ПереработанныйТекстДокумента(ДанныеДляЗаполненияXML, РаскрытиеXDTO)
	
	ЗаписьXML = Новый ЗаписьXML;
	ЗаписьXML.УстановитьСтроку("Windows-1251");
	ЗаписьXML.ЗаписатьОбъявлениеXML();
	
	ТекстДляДобавления = add_info_РСВ_FCDR(ДанныеДляЗаполненияXML);
	
	ФабрикаXDTO.ЗаписатьXML(ЗаписьXML, РаскрытиеXDTO, "DISCLOSURE_REQUEST");
	ТекстДокумента = ЗаписьXML.Закрыть();
	ТекстДокумента = СтрЗаменить(ТекстДокумента, "<DISCLOSURE_REQUEST xmlns=""FCDR_2017_02(2019v3)"" xmlns:xs=""http://www.w3.org/2001/"
		 + "XMLSchema""xmlns:xsi=""http://www.w3.org/2001/XMLSchema-instance"">", "<DISCLOSURE_REQUEST>");
	ТекстДокумента = СтрЗаменить(ТекстДокумента, "xmlns="""" xmlns:d2p1=""FCDR_2017_02(2019v3)""", "");
	ТекстДокумента = СтрЗаменить(ТекстДокумента, "d2p1:", "");
	ТекстДокумента = СтрЗаменить(ТекстДокумента, "xsi:type=""xs:string""", "");
	ТекстДокумента = СтрЗаменить(ТекстДокумента, "xmlns=""""", "");
	Если ЗначениеЗаполнено(ТекстДляДобавления) Тогда
		ТекстДляДобавления = "<add_info>" + ТекстДляДобавления + "</add_info>
		|</DISCLOSURE_REQUEST>";
		ТекстДокумента = СтрЗаменить(ТекстДокумента, "</DISCLOSURE_REQUEST>", ТекстДляДобавления);
	КонецЕсли;
	
	Возврат ТекстДокумента;
	
КонецФункции

//----------------------------------------------------------------------------------------
// Функции формирования временных таблиц для отчетов 1042 и 1042S

// Создает и заполняет временную таблицу втДанныеВыплатПоЦБСШАИРаскрытий в переданном Менеджере временных таблиц
//
// Параметры:
//  МВТ				 - Менеджер временных таблиц - в него помещается временная таблица
//  ДатаНачала		 - Дата - начало периода за который собираются выплаты
//  ДатаОкончания	 - Дата - конец периода за который собираются выплаты
//
Процедура ПодготовитьВТДанныеВыплатПоЦБАмерикиОпределениеРСВ(МВТ, ДатаНачала, ДатаОкончания) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МВТ;
	Запрос.Текст = ТекстЗапросаДанныеВыплатПоЦБАмерикиОпределениеРСВ();
	Запрос.УстановитьПараметр("ДатаНачала", ДатаНачала);
	Запрос.УстановитьПараметр("ДатаОкончания", ДатаОкончания);
	Запрос.УстановитьПараметр("DVCA", Справочники.ВидыКорпоративныхДействий.DVCA());
	Запрос.УстановитьПараметр("INTR", Справочники.ВидыКорпоративныхДействий.INTR());
	Запрос.УстановитьПараметр("MCAL", Справочники.ВидыКорпоративныхДействий.MCAL());
	Запрос.УстановитьПараметр("CAPG", Справочники.ВидыКорпоративныхДействий.CAPG());
	Запрос.УстановитьПараметр("WTRC", Справочники.ВидыКорпоративныхДействий.WTRC());
	Запрос.УстановитьПараметр("США", Справочники.КлассификаторСтранМира.США());
	Запрос.УстановитьПараметр("Исполнено", Перечисления.СтатусыПоручений.Исполнено);
	Запрос.УстановитьПараметр("ДепозитарнаяРасписка", Перечисления.ТипыЦБ.ДепозитарнаяРасписка);
	Запрос.УстановитьПараметр("ВидДокументаW8BENE_W8BEN", Справочники.ВидыДокументовУдостоверяющихПолномочия.ФормаW8BENE_W8BEN);
	Запрос.УстановитьПараметр("ТипФормыW8IMY", Перечисления.ТипыФормW8.ФормаW8IMY);
	Запрос.УстановитьПараметр("РСВПустаяСсылка", Документы.РаскрытиеСпискаВладельцев.ПустаяСсылка());
	Запрос.УстановитьПараметр("ДатаВводаQI", ОбщегоНазначения.ДобавитьРабочийДень(Константы.ДатаВводаСхемыУведомленийWTRC_QI.Получить(), 1));
	Запрос.Выполнить();
	
КонецПроцедуры

// Возвращает таблицу значений по субклиентам общих разделов по выплатам, определенным в МВТ
//
// Параметры:
//  МВТ	 - Менеджер временных таблиц - Менеджер в котором определена ВТ "втДанныеВыплатПоЦБСШАИРаскрытий"
// 
// Возвращаемое значение:
//  Таблица значений - данные субклиентов общих разделов по выплатам из ВТ
//
Функция ТаблицаСубклиентовОбщихРазделовПоДаннымВыплатЦБАмерики(МВТ) Экспорт
	
	ДанныеСубклиентовОбщиеРазделы = НоваяТаблицаСубклиентовОбщихРазделов();
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МВТ;
	Запрос.Текст = ТекстЗапросаВыборкаРаскрытийОбщихРазделовСубброкеров();
	ВыборкаРСВ = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	Пока ВыборкаРСВ.Следующий() Цикл
		Если Не ЗначениеЗаполнено(ВыборкаРСВ.РСВ) Тогда
			ДанныеРСВ = Неопределено;
		ИначеЕсли ВыборкаРСВ.РСВ.СводноеРаскрытие.Количество() > 0 Тогда
			ДанныеРСВ = ВыборкаРСВ.РСВ.СводноеРаскрытие.Выгрузить();
		Иначе
			РСВОбъект = ВыборкаРСВ.РСВ.ПолучитьОбъект();
			ДанныеРСВ = РСВОбъект.ВыборкаДанныхЗаполненияСводногоРСВ().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		КонецЕсли;
		ВыборкаРСВДетальныеЗаписи = ВыборкаРСВ.Выбрать();
		Пока ВыборкаРСВДетальныеЗаписи.Следующий() Цикл
			Строки = Новый Массив;
			Если ТипЗнч(ДанныеРСВ) = Тип("ТаблицаЗначений") Тогда
				Отбор = Новый Структура;
				Отбор.Вставить("РазделСчетаДепоМХ", ВыборкаРСВДетальныеЗаписи.РазделСчетаДепоМХ);
				Отбор.Вставить("НалоговаяСтавка", ВыборкаРСВДетальныеЗаписи.СтавкаНалога);
				Отбор.Вставить("СтатусПоГлаве4", ВыборкаРСВДетальныеЗаписи.СтатусПоГлаве4);
				Отбор.Вставить("РазделСчетаДепо", ВыборкаРСВДетальныеЗаписи.РазделСчетаДепо);
				Строки = ДанныеРСВ.НайтиСтроки(Отбор);
				Если Строки.Количество() > 0 Тогда
					Для Каждого Строка Из Строки Цикл
						Если Не ЗначениеЗаполнено(Строка.СчетДепоМХ) Тогда // У итоговых записей этот реквизит должен быть пуст
							Продолжить;
						КонецЕсли;
						НоваяСтрока = ДанныеСубклиентовОбщиеРазделы.Добавить();
						НоваяСтрока.РСВ = ВыборкаРСВДетальныеЗаписи.РСВ;
						НоваяСтрока.Поручение = ВыборкаРСВДетальныеЗаписи.Поручение;
						НоваяСтрока.Клиент = Строка.Клиент;
						НоваяСтрока.СчетДепо = Строка.СчетДепо;
						НоваяСтрока.СчетДепоМХ = Строка.СчетДепоМХ;
						НоваяСтрока.РазделСчетаДепо = Строка.РазделСчетаДепо;
						НоваяСтрока.РазделСчетаДепоМХ = Строка.РазделСчетаДепоМХ;
						НоваяСтрока.Количество = Строка.КоличествоЦБ;
						НоваяСтрока.W8BENE_W8BEN = Строка.W8BENE_W8NEN;
						НоваяСтрока.W8IMY = Строка.W8IMY;
						НоваяСтрока.НалоговаяСтавка = Строка.НалоговаяСтавка;
						НоваяСтрока.СтатусПоГлаве4 = Строка.СтатусПоГлаве4;
						НоваяСтрока.Субклиент = Строка.Субклиент;
					КонецЦикла;
				КонецЕсли;
				Продолжить;
			ИначеЕсли ДанныеРСВ = Неопределено Тогда
				НоваяСтрока = ДанныеСубклиентовОбщиеРазделы.Добавить();
				НоваяСтрока.Поручение = ВыборкаРСВДетальныеЗаписи.Поручение;
				НоваяСтрока.Клиент = ВыборкаРСВДетальныеЗаписи.Контрагент;
				НоваяСтрока.СчетДепо = ВыборкаРСВДетальныеЗаписи.СчетДепо;
				НоваяСтрока.СчетДепоМХ = ВыборкаРСВДетальныеЗаписи.СчетДепоМХ;
				НоваяСтрока.РазделСчетаДепо = ВыборкаРСВДетальныеЗаписи.РазделСчетаДепо;
				НоваяСтрока.РазделСчетаДепоМХ = ВыборкаРСВДетальныеЗаписи.РазделСчетаДепоМХ;
				НоваяСтрока.Количество = ВыборкаРСВДетальныеЗаписи.Количество;
				НоваяСтрока.НалоговаяСтавка = ВыборкаРСВДетальныеЗаписи.СтавкаНалога;
				НоваяСтрока.СтатусПоГлаве4 = ВыборкаРСВДетальныеЗаписи.СтатусПоГлаве4;
				Продолжить;
			КонецЕсли;
			ДанныеРСВ.Сбросить();
			Пока ДанныеРСВ.Следующий() Цикл
				Если ДанныеРСВ.РазделСчетаДепоМХ <> ВыборкаРСВДетальныеЗаписи.РазделСчетаДепоМХ Тогда
					Продолжить;
				КонецЕсли;
				ВыборкаНалоговаяСтавка = ДанныеРСВ.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
				Пока ВыборкаНалоговаяСтавка.Следующий() Цикл
					Если ВыборкаНалоговаяСтавка.НалоговаяСтавка <> ВыборкаРСВДетальныеЗаписи.СтавкаНалога Тогда
						Продолжить;
					КонецЕсли;
					ВыборкаСтатусПоГлаве4 = ВыборкаНалоговаяСтавка.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
					Пока ВыборкаСтатусПоГлаве4.Следующий() Цикл
						Если ВыборкаСтатусПоГлаве4.СтатусПоГлаве4 <> ВыборкаРСВДетальныеЗаписи.СтатусПоГлаве4 Тогда
							Продолжить;
						КонецЕсли;
						ВыборкаДетальныеЗаписи = ВыборкаСтатусПоГлаве4.Выбрать();
						Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
							Если ВыборкаДетальныеЗаписи.РазделСчетаДепо <> ВыборкаРСВДетальныеЗаписи.РазделСчетаДепо Тогда
								Продолжить;
							КонецЕсли; 							
							НоваяСтрока = ДанныеСубклиентовОбщиеРазделы.Добавить();
							НоваяСтрока.РСВ = ВыборкаРСВДетальныеЗаписи.РСВ;
							НоваяСтрока.Поручение = ВыборкаРСВДетальныеЗаписи.Поручение;
							НоваяСтрока.Клиент = ВыборкаДетальныеЗаписи.Клиент;
							НоваяСтрока.СчетДепо = ВыборкаДетальныеЗаписи.СчетДепо;
							НоваяСтрока.СчетДепоМХ = ВыборкаДетальныеЗаписи.СчетДепоМХ;
							НоваяСтрока.РазделСчетаДепо = ВыборкаДетальныеЗаписи.РазделСчетаДепо;
							НоваяСтрока.РазделСчетаДепоМХ = ВыборкаДетальныеЗаписи.РазделСчетаДепоМХ;
							НоваяСтрока.Количество = ВыборкаДетальныеЗаписи.КоличествоЦБ;
							НоваяСтрока.W8BENE_W8BEN = ВыборкаДетальныеЗаписи.W8BENE_W8NEN;
							НоваяСтрока.W8IMY = ВыборкаДетальныеЗаписи.W8IMY;
							НоваяСтрока.НалоговаяСтавка = ВыборкаДетальныеЗаписи.НалоговаяСтавка;
							НоваяСтрока.СтатусПоГлаве4 = ВыборкаДетальныеЗаписи.СтатусПоГлаве4;
							НоваяСтрока.Субклиент = ВыборкаДетальныеЗаписи.Субклиент;
						КонецЦикла;
					КонецЦикла;
				КонецЦикла;
			КонецЦикла;
		КонецЦикла;
	КонецЦикла;
	Возврат ДанныеСубклиентовОбщиеРазделы;
	
КонецФункции

// Создает и заполняет временную таблицу втДанныеВыплатПоЦБСШАИРаскрытий в переданном Менеджере временных таблиц
//
// Параметры:
//  МВТ								 - Менеджер временных таблиц - в него помещается временная таблица
//  ДанныеСубклиентовОбщиеРазделы	 - Таблица значений - данные по субклиентам общих разделов из выплат
//  ТекстОшибок						 - Строка(необязательный) - текст ошибок при подготовке ВТ
//
Процедура ПодготовитьВТДетальныеЗаписиПоВыплатамИФормамW8(МВТ, ДанныеСубклиентовОбщиеРазделы, ТекстОшибок = "") Экспорт
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МВТ;
	Организация = ОбщегоНазначенияПовтИсп.ОрганизацияПоУмолчанию();
	ЮЛВТБКБ = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Организация, "ЮридическоеЛицо");
	Запрос.Текст = ТекстЗапросаДетальныеЗаписиПоВыплатамИФормамW8();
	Запрос.УстановитьПараметр("ДанныеСубклиентовОбщиеРазделы",ДанныеСубклиентовОбщиеРазделы);
	Запрос.УстановитьПараметр("ТипФормыW8BEN", Перечисления.ТипыФормW8.ФормаW8BEN);
	Запрос.УстановитьПараметр("ТипФормыW8BENE", Перечисления.ТипыФормW8.ФормаW8BENE);
	Запрос.УстановитьПараметр("ТипФормыW8IMY", Перечисления.ТипыФормW8.ФормаW8IMY);
	Запрос.УстановитьПараметр("W8BENE_W8BEN", Справочники.ВидыДокументовУдостоверяющихПолномочия.ФормаW8BENE_W8BEN);
	Запрос.УстановитьПараметр("ЮЛВТБКБ", ЮЛВТБКБ);
	Запрос.УстановитьПараметр("INDV", Справочники.СтатусыUSTAXCODEгл4.НайтиПоКодуНРД("INDV"));
	Запрос.УстановитьПараметр("ТекстINDV", "INDV");
	Запрос.УстановитьПараметр("QI_EIN", QI_EINПоУмолчанию());
	
	Запрос.УстановитьПараметр("",);
	ВыборкаОшибки = Запрос.Выполнить().Выбрать();
	ТекстОшибок = "";
	Пока ВыборкаОшибки.Следующий() Цикл
		ТекстОшибок = "На дату " +Формат(ВыборкаОшибки.ДатаФиксации, "ДФ=dd.MM.yyyy") + " по клиенту "
			+ СокрЛП(ВыборкаОшибки.КодКонтрагента) + " " + ВыборкаОшибки.Контрагент;
		Если ЗначениеЗаполнено(ВыборкаОшибки.Субклиент) Тогда
			ТекстОшибок = ТекстОшибок + " " + ВыборкаОшибки.Субклиент;
		КонецЕсли;
		ТекстОшибок = ТекстОшибок + " отсутствуют формы:";
		Если Не ЗначениеЗаполнено(ВыборкаОшибки.W8BENE_W8BEN) Тогда
			ТекстОшибок = ТекстОшибок + "W8BEN/W8BENE;";
		КонецЕсли;
		Если Не ЗначениеЗаполнено(ВыборкаОшибки.W8IMY) И Не ВыборкаОшибки.ЭтоПрямойКлиент Тогда
			ТекстОшибок = ТекстОшибок + "W8IMY;";
		КонецЕсли;
		Если Не ЗначениеЗаполнено(ВыборкаОшибки.W8IMYДляВТБКБ) Тогда
			ТекстОшибок = ТекстОшибок + "W8IMY для ВТБКБ;";
		КонецЕсли;
		ТекстОшибок = ТекстОшибок+Символы.ПС;
	КонецЦикла;
	
КонецПроцедуры


