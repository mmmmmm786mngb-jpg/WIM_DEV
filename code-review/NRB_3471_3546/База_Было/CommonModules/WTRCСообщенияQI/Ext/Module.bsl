// Возвращает имя временного XLSX-файла расшифровки запроса на раскрытие по субклиентам
//
// Параметры:
//  ДанныеПоСубброкеру						 - ТаблицаЗначений	 - данные по субклиентам для заполнения файла
//  ИмяМакета								 - Строка	 - имя макета документа РаскрытиеСпискаВладельцев
//  ЦБПодпадаетПодНалоговоеРегулировениеСША	 - Булево	 - регулирует вывод налоговых колонок
//  ВыводитьНалоги							 - Булево	 - включает вывод налоговых колонок независимо от вида КД
// 
// Возвращаемое значение:
//  Строка - имя временного файла XLSX
//
Функция ФайлРасшифровкиЗапросаНаРаскрытиеПоСубклиентам(Знач ДанныеПоСубброкеру, ИмяМакета,
	ЦБПодпадаетПодНалоговоеРегулировениеСША, ВыводитьНалоги = Ложь) Экспорт 
	
	ТаблицаДанныхСубброкера = ТаблицаДанныхСубброкера();
	Для Каждого Строка Из ДанныеПоСубброкеру Цикл 
		ЗаполнитьЗначенияСвойств(ТаблицаДанныхСубброкера.Добавить(), Строка);	
	КонецЦикла;
	
	ТаблицаДанныхСубброкера.Сортировать("КодСубклиента Убыв");
		
	ТабличныйДокумент = Новый ТабличныйДокумент;
	Макет = Документы.РаскрытиеСпискаВладельцев.ПолучитьМакет(ИмяМакета);
	
	ОбластьШапки = Макет.ПолучитьОбласть("Шапка");
	ОбластьШапки.Параметры.Заполнить(ТаблицаДанныхСубброкера[0]);
	ТабличныйДокумент.Вывести(ОбластьШапки);
	
	ОбластьШапкиТаблицыОсновная = Макет.ПолучитьОбласть("ШапкаТаблицы|Основной");
	ТабличныйДокумент.Вывести(ОбластьШапкиТаблицыОсновная);
	
	Если НЕ ЦБПодпадаетПодНалоговоеРегулировениеСША Тогда
		Если ТаблицаДанныхСубброкера[0].ВидКДВыплатаДоходов ИЛИ ВыводитьНалоги Тогда
			ОбластьНалоги = Макет.ПолучитьОбласть("ШапкаТаблицы|Налоги");
			ТабличныйДокумент.Присоединить(ОбластьНалоги);
		КонецЕсли;
	КонецЕсли;
	
	Если Макет.Области.Найти("Хвост") <> Неопределено Тогда 
		ОбластьХвост = Макет.ПолучитьОбласть("ШапкаТаблицы|Хвост");
		ТабличныйДокумент.Присоединить(ОбластьХвост);
	КонецЕсли;
	
	ПараметрыКолонок = ПараметрыКолонокФайлаРасшифровкиЗапросаНаРаскрытие(ТаблицаДанныхСубброкера[0].ЦеннаяБумага,
		ТаблицаДанныхСубброкера[0].КодТипаКД); 
	Для Каждого Область Из ТабличныйДокумент.Области Цикл
		ПараметрКолонки = Неопределено;
		Если ПараметрыКолонок.Свойство(Область.Имя, ПараметрКолонки) Тогда
			Если ПараметрКолонки.Обязательная Тогда
				НалоговыеКолонки = СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(
					"СтатусНалогоплательщика,НаличиеНалоговыхЛьгот,НалоговаяСтавка");
				Если НалоговыеКолонки.Найти(Область.Имя) = Неопределено Тогда
					Область.Текст = "Обязательно";
				Иначе
					Область.Текст = "Обязательно при раскрытии для выплаты дохода";
				КонецЕсли;
			Иначе
				Область.Текст = "Желательно";
			КонецЕсли;
			
			Если ПараметрКолонки.ДоступныеЗначения <> Неопределено Тогда
				ДанныеКолонки = ТаблицаДанныхСубброкера.ВыгрузитьКолонку(Область.Имя);
				ДанныеКолонкиСКодами = Новый Массив();
				Для Каждого Значение Из ДанныеКолонки Цикл 
					Если ПараметрКолонки.ДоступныеЗначения.Получить(Значение) = Неопределено Тогда 
						Для Каждого ЗначениеСоотвествия Из ПараметрКолонки.ДоступныеЗначения Цикл
							Если ЗначениеСоотвествия.Значение = Значение Тогда
								Значение = ЗначениеСоотвествия.Ключ;
								Прервать;
							КонецЕсли;
						КонецЦикла;
					КонецЕсли;
					ДанныеКолонкиСКодами.Добавить(Значение);
				КонецЦикла;
				ТаблицаДанныхСубброкера.ЗагрузитьКолонку(ДанныеКолонкиСКодами,Область.Имя);
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
	Если ТаблицаДанныхСубброкера[0].ВыводитьСтрокиТаблицы Тогда	
		Для Каждого Строка Из ТаблицаДанныхСубброкера Цикл
			
			ОбластьОсновной	= Макет.ПолучитьОбласть("Строка|Основной");
			Если НЕ ЦБПодпадаетПодНалоговоеРегулировениеСША Тогда
				ОбластьНалоги	= Макет.ПолучитьОбласть("Строка|Налоги");
			КонецЕсли;
			
			Если Не ЗначениеЗаполнено(Строка.КодСубклиента) Тогда 
				ДанныеЗаполнения = Новый Структура("ВидКДВыплатаДоходов, Количество, РазделСчетаДепо, КодНРД, ISIN, LEIКодСубброкера");
				ЗаполнитьЗначенияСвойств(ДанныеЗаполнения, Строка);
			Иначе
				ДанныеЗаполнения = ОбщегоНазначения.СтрокаТаблицыЗначенийВСтруктуру(Строка);
			КонецЕсли;
						
			ОбластьОсновной.Параметры.Заполнить(ДанныеЗаполнения);
						
			ТабличныйДокумент.Вывести(ОбластьОсновной);
			
			Если НЕ ЦБПодпадаетПодНалоговоеРегулировениеСША Тогда
				Если ДанныеЗаполнения.ВидКДВыплатаДоходов ИЛИ ВыводитьНалоги Тогда
					ОбластьНалоги.Параметры.Заполнить(ДанныеЗаполнения);
					ТабличныйДокумент.Присоединить(ОбластьНалоги);
				КонецЕсли;			
			КонецЕсли;
			
			Если Макет.Области.Найти("Хвост") <> Неопределено Тогда 
				ОбластьХвост	= Макет.ПолучитьОбласть("Строка|Хвост");
				ОбластьХвост.Параметры.Заполнить(ДанныеЗаполнения);
				ТабличныйДокумент.Присоединить(ОбластьХвост);
			КонецЕсли;
			
		КонецЦикла;
	КонецЕсли;
	
	Если Макет.Области.Найти("Легенда") <> Неопределено Тогда 
		Организация = Константы.ОрганизацияПоУмолчанию.Получить();
		ЮрЛицо = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Организация, "ЮридическоеЛицо");
		НаименованиеЮЛОрганизации = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ЮрЛицо, "Наименование");
		
		ОбластьЛегенда = Макет.ПолучитьОбласть("Легенда");
		ОбластьЛегенда.Параметры.НаименованиеЮЛОрганизации = НаименованиеЮЛОрганизации;
		ТабличныйДокумент.Вывести(ОбластьЛегенда);
	КонецЕсли;
		
	ИмяФайла = ПолучитьИмяВременногоФайла();
	ТабличныйДокумент.Записать(ИмяФайла, ТипФайлаТабличногоДокумента.XLSX);
	Возврат ИмяФайла;
КонецФункции

Функция ФайлЗапросаНаРаскрытиеПоСубклиентамПриложение2_5(ДанныеПоСубброкеру, ЗапросНаРаскрытиеСсылка = Неопределено) Экспорт 
	ИтогоКоличествоПоСубброкеру = 0;
	Для Каждого Строка Из ДанныеПоСубброкеру Цикл
		ИтогоКоличествоПоСубброкеру = ИтогоКоличествоПоСубброкеру + Строка.Количество;
	КонецЦикла;
	
	ТабличныйДокумент = Новый ТабличныйДокумент;
	Макет = Документы.РаскрытиеСпискаВладельцев.ПолучитьМакет("Макет_2_5_2022");
	Область = Макет.ПолучитьОбласть("Документ");
	Область.Параметры.Заполнить(ДанныеПоСубброкеру[0]);
	Область.Параметры.ИтогоКоличествоПоСубброкеру = ИтогоКоличествоПоСубброкеру;
	Если ТипЗнч(ЗапросНаРаскрытиеСсылка) = Тип("ДокументСсылка.ЗапросСубброкеруНаРаскрытие") Тогда
		Область.Параметры.НомерДокументаРаскрытия = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ЗапросНаРаскрытиеСсылка,"Номер");	
	КонецЕсли;
	ТабличныйДокумент.Вывести(Область);
	
	ИмяФайла = ПолучитьИмяВременногоФайла();
	ТабличныйДокумент.Записать(ИмяФайла, ТипФайлаТабличногоДокумента.PDF);
	Возврат ИмяФайла;
КонецФункции


// Функции формирования уведомлений документа "Запрос субброкеру на раскрытие"

