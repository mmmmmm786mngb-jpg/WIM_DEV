// Функции формирования файла запроса на раскрытие

Функция ДоступныеЗначенияТипыСчета() Экспорт 
	
	ДоступныеЗначения = Новый Соответствие();
	ДоступныеЗначения.Вставить("01", "01 - Счет владельца");		
	ДоступныеЗначения.Вставить("02", "02 - Счет номинального держателя");		
	ДоступныеЗначения.Вставить("03", "03 - Счет ДУ (доверительного управляющего)");		
	ДоступныеЗначения.Вставить("04", "04 - Счет залогодержателя");		
	ДоступныеЗначения.Вставить("05", "05 - Эмиссионный счет эмитента (для размещения ценных бумаг)");		
	ДоступныеЗначения.Вставить("06", "06 - Лицевой счет эмитента (для выкупа-погашения ценных бумаг)");		
	ДоступныеЗначения.Вставить("07", "07 - Счет ""Ценные бумаги неустановленных лиц""");		
	Возврат ДоступныеЗначения;
	
КонецФункции

Функция ДоступныеЗначенияСтраны() Экспорт 
	
	ДоступныеЗначения = Новый Соответствие();
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	КлассификаторСтранМира.КодАльфа2 КАК КодАльфа2,
	|	КлассификаторСтранМира.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.КлассификаторСтранМира КАК КлассификаторСтранМира
	|ГДЕ
	|	НЕ КлассификаторСтранМира.ПометкаУдаления");
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл 
		Если Не ПустаяСтрока(Выборка.КодАльфа2) Тогда 
			ДоступныеЗначения.Вставить(СокрЛП(Выборка.КодАльфа2), Выборка.Ссылка);	
		КонецЕсли;
	КонецЦикла;
	Возврат ДоступныеЗначения;
	
КонецФункции

Функция ДоступныеЗначенияПризнакЮлФл() Экспорт 
	
	ДоступныеЗначения = Новый Соответствие();
	ДоступныеЗначения.Вставить("LEGL", Перечисления.ЮрФизЛицо.ЮрЛицо);		
	ДоступныеЗначения.Вставить("INDV", Перечисления.ЮрФизЛицо.ФизЛицо);			
	Возврат ДоступныеЗначения;
		
КонецФункции

Функция ДоступныеЗначенияРегистрационныеДокументы() Экспорт 
	
	ДоступныеЗначения = Новый Соответствие();
	КодыИМНС = СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок("21,10,12,00,11,22,01,23,02,13,03,14,04,26,05,27,06,28,07,29,09,91,30,31");
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	ДокументыУдостоверяющиеЛичность.Ссылка КАК Ссылка,
	|	ДокументыУдостоверяющиеЛичность.КодИМНС КАК КодИМНС
	|ИЗ
	|	Справочник.ДокументыУдостоверяющиеЛичность КАК ДокументыУдостоверяющиеЛичность
	|ГДЕ
	|	НЕ ДокументыУдостоверяющиеЛичность.ПометкаУдаления
	|	И ДокументыУдостоверяющиеЛичность.КодИМНС В(&КодыИМНС)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ДокументыЮридическихЛиц.Ссылка,
	|	ДокументыЮридическихЛиц.Код
	|ИЗ
	|	Справочник.ДокументыЮридическихЛиц КАК ДокументыЮридическихЛиц");
	Запрос.УстановитьПараметр("КодыИМНС",КодыИМНС);
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл 
		ДоступныеЗначения.Вставить(СокрЛП(Выборка.КодИМНС), Выборка.Ссылка);	
	КонецЦикла;
	Возврат ДоступныеЗначения;
	
КонецФункции

Функция ДоступныеЗначенияСтатусНалогоплательщика() Экспорт 
	
	ДоступныеЗначения = Новый Соответствие();
	ДоступныеЗначения.Вставить("1", "Налоговый резидент РФ");		
	ДоступныеЗначения.Вставить("2", "Налоговый нерезидент РФ");			
	Возврат ДоступныеЗначения;
	
КонецФункции

Функция ПараметрыКолонки(Обязательная = Истина, ДоступныеЗначения = Неопределено, ТипЗначения = Неопределено)
	Если ТипЗначения = Неопределено Тогда 
		ТипЗначения = Тип("Строка");	
	КонецЕсли;
	Возврат Новый Структура("Обязательная, ДоступныеЗначения, НомерКолонки, Ключевая, ТипЗначения",Обязательная, ДоступныеЗначения, Неопределено, Ложь, ТипЗначения);
КонецФункции

// Функция - Параметры колонок файла расшифровки запроса на раскрытие
// Возвращает структуру с описанием параметров колонок Excel файла раскрытия(обязательность заполнения, допустимые значения)
// Параметры:
//  ЦеннаяБумагаСсылка			 - СправочникСсылка.ЦеннаяБумага
//  ВидКорпоративногоДействия	 - 	Строка, СправочникСсылка.ВидыКорпоративныхДействий - Код вида корпоративного действия или элемент справочника ВидыКорпоративныхДействий
// 
// Возвращаемое значение:
// Структура  - параметры колонок
//
Функция ПараметрыКолонокФайлаРасшифровкиЗапросаНаРаскрытие(ЦеннаяБумагаСсылка, ВидКорпоративногоДействия) Экспорт 
	
	ОбязательноЗаполнение = Истина;
	ОбязательноЗаполнениеКодаКлиента = Ложь;
	ОбязательноЗаполнениеНомераСчетаДепоКлиента = Истина;
	ОбязательноЗаполнениеИндекса = Ложь;
	ОбязательноЗаполнениеСерииДокумента = Ложь;
	ОбязательноЗаполнениеДатыРожденияФЛ = Истина;
	ОбязательноЗаполнениеГражданствоФЛ = Ложь;
	ОбязательноЗаполнениеКодаЗагрузки = Истина;
	ОбязательноЗаполнениеНалогов = Справочники.ВидыКорпоративныхДействий.ЭтоКорпоративноедействиеДоходы(ВидКорпоративногоДействия);

	Если ТипЗнч(ВидКорпоративногоДействия) = Тип("СправочникСсылка.ВидыКорпоративныхДействий") Тогда 
		КодВидаКД = ВРег(ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ВидКорпоративногоДействия, "Код"));
	Иначе 
		КодВидаКД = ВидКорпоративногоДействия;
	КонецЕсли;
		
	Если КодВидаКД = "WTRC" Тогда
		ОбязательноЗаполнениеКодаКлиента = Истина;
		ОбязательноЗаполнениеНомераСчетаДепоКлиента = Ложь;
		ОбязательноЗаполнениеКодаЗагрузки = Ложь;
	КонецЕсли;
	
	Колонки = Новый Структура();
	Колонки.Вставить("КодКлиента",ПараметрыКолонки(ОбязательноЗаполнениеКодаКлиента));
	Колонки.Вставить("НомерСчетаДепоКлиента",ПараметрыКолонки(ОбязательноЗаполнениеНомераСчетаДепоКлиента));
	Колонки.Вставить("РазделСчетаДепо",ПараметрыКолонки());
	Колонки.Вставить("ТипСчета",ПараметрыКолонки(ОбязательноЗаполнение, ДоступныеЗначенияТипыСчета()));
	Колонки.Вставить("ПолноеНаименованиеЛица",ПараметрыКолонки(ОбязательноЗаполнение));
	Колонки.Вставить("АдресМестонахожденияРегистрацииСтрана",ПараметрыКолонки(ОбязательноЗаполнение, ДоступныеЗначенияСтраны()));	
	Колонки.Вставить("АдресМестонахожденияРегистрацииИндекс",ПараметрыКолонки(ОбязательноЗаполнениеИндекса));	
	Колонки.Вставить("АдресМестонахожденияРегистрацииАдрес",ПараметрыКолонки());	
	Колонки.Вставить("ПризнакЮЛФЛ",ПараметрыКолонки(ОбязательноЗаполнение, ДоступныеЗначенияПризнакЮлФл()));
	Колонки.Вставить("ДокументВладельцаТип",ПараметрыКолонки(ОбязательноЗаполнение, ДоступныеЗначенияРегистрационныеДокументы()));
	Колонки.Вставить("ДокументВладельцаНомер",ПараметрыКолонки());
	Колонки.Вставить("ДокументВладельцаСерия",ПараметрыКолонки(ОбязательноЗаполнениеСерииДокумента));
	Колонки.Вставить("ДокументВладельцаДатаВыдачи",ПараметрыКолонки(Истина,,Тип("Дата")));
	Колонки.Вставить("ДокументВладельцаОрганВыдачи",ПараметрыКолонки());
	Колонки.Вставить("ДатаРожденияФЛ", ПараметрыКолонки(ОбязательноЗаполнениеДатыРожденияФЛ,,Тип("Дата")));
	Колонки.Вставить("ГражданствоФЛ", ПараметрыКолонки(ОбязательноЗаполнениеГражданствоФЛ, ДоступныеЗначенияСтраны()));
	Колонки.Вставить("ПолноеНаименованиеЮЛФЛСубклиента", ПараметрыКолонки(ОбязательноЗаполнение));
	Колонки.Вставить("АдресПочтовыйСтрана",ПараметрыКолонки(ОбязательноЗаполнение, ДоступныеЗначенияСтраны()));
	Колонки.Вставить("АдресПочтовыйИндекс",ПараметрыКолонки(ОбязательноЗаполнениеИндекса));
	Колонки.Вставить("АдресПочтовыйАдрес",ПараметрыКолонки());
	Колонки.Вставить("СтатусНалогоплательщика",ПараметрыКолонки(ОбязательноЗаполнениеНалогов, ДоступныеЗначенияСтатусНалогоплательщика()));
	Колонки.Вставить("НаличиеНалоговыхЛьгот",ПараметрыКолонки(ОбязательноЗаполнениеНалогов));
	Колонки.Вставить("НалоговаяСтавка",ПараметрыКолонки(ОбязательноЗаполнениеНалогов,, Тип("Число")));	
	Колонки.Вставить("LEIКодСубброкера",ПараметрыКолонки());
	Колонки.Вставить("ISIN", ПараметрыКолонки());
	Колонки.Вставить("КодЗагрузкиЦБ",ПараметрыКолонки(ОбязательноЗаполнениеКодаЗагрузки));
	Колонки.Вставить("Количество",ПараметрыКолонки(,,Тип("Число")));

	Если КодВидаКД = "WTRC" И Справочники.ЦенныеБумаги.ЦБПодпадаетПодНалоговоеРегулированиеСША(ЦеннаяБумагаСсылка) Тогда
		Колонки.КодКлиента.Ключевая = Истина;
		Для Каждого Колонка Из Колонки Цикл 
			Колонка.Значение.Обязательная = Ложь;
		КонецЦикла;
		Колонки.ПолноеНаименованиеЮЛФЛСубклиента.Обязательная = Истина;
		Колонки.КодКлиента.Обязательная = Истина;
		Колонки.Количество.Обязательная = Истина;
		Колонки.ISIN.Обязательная = Истина;
		Колонки.РазделСчетаДепо.Обязательная = Истина;
	Иначе 
		Колонки.НомерСчетаДепоКлиента.Ключевая = Истина
	КонецЕсли;

	Возврат Колонки;
	
КонецФункции

Процедура ДобавитьИсточникДляРаскрытияИзБизнесПроцесса(МВТ, БизнесПроцессСсылка) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МВТ;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Депоненты.Депонент КАК Субброкер,
	|	Депоненты.РазделСчета.Владелец КАК СчетДепо,
	|	Депоненты.РазделСчета КАК РазделСчетаДепо,
	|	Депоненты.Ссылка.КДРеференс КАК КДРеференс,
	|	Депоненты.Ссылка.КД.ВидКД.Наименование КАК ТипКД,
	|	Депоненты.Ссылка.КД.ВидКД.Код КАК КодТипаКД,
	|	ИСТИНА КАК ВидКДВыплатаДоходов,
	|	&ПустойДоходНДФЛ КАК КодДоходовНДФЛ,
	|	ЛОЖЬ КАК ЗаполнятьЗаявленнуюНалоговуюСтавку,
	|	Депоненты.Ссылка.ДатаФиксации КАК ДатаФиксации,
	|	Депоненты.Ссылка.ЦеннаяБумага1 КАК ЦеннаяБумага,
	|	Депоненты.Ссылка.ЦеннаяБумага1.НаименованиеВыпуска КАК НаименованиеВыпуска, 
	|	Депоненты.РазделСчета.Субклиент КАК Субклиент,
	|	""01"" КАК ТипСчета,
	|	Депоненты.Количество КАК Количество,
	|	Депоненты.Ссылка.Дата КАК ДатаДокументаРаскрытия,
	|	Депоненты.Ссылка.Дата КАК ДатаДокументаЗапроса,
	|	Депоненты.Ссылка.КД.Организация КАК Организация,
	|	Депоненты.Ссылка.КД.Организация.Наименование КАК НаименованиеЮЛОрганизации,
	|	Депоненты.Ссылка.КД.ДатаОкончанияПриемаИнструкцийВТБКБ КАК ДатаОкончанияПриемаИнструкцийВТБКБ,
	|	ВЫБОР
	|		КОГДА Депоненты.РазделСчета.Владелец.ТипСчетаДепо В (&ТипСчетаДЕПОНДИНД)
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК ВыводитьСтрокиТаблицы
	|ПОМЕСТИТЬ втИсточникДляРаскрытия
	|ИЗ
	|	БизнесПроцесс.ОбработкаWTRCСообщения.Депоненты КАК Депоненты
	|ГДЕ
	|	Депоненты.Ссылка = &БизнесПроцессСсылка
	|	И Депоненты.РазделСчета.Владелец.ТипСчетаДепо В(&ТипСчетаДЕПОНДИНД)";
	Запрос.УстановитьПараметр("БизнесПроцессСсылка",	БизнесПроцессСсылка);
	Запрос.УстановитьПараметр("ПустойДоходНДФЛ",	Справочники.ДоходыНДФЛ.ПустаяСсылка());
	Запрос.УстановитьПараметр("ТипСчетаДЕПОНДИНД",	БизнесПроцессы.ОбработкаWTRCСообщения.ТипыСчетовНДИНД());

	Запрос.Выполнить();
	
КонецПроцедуры

Функция ДанныеДляЗаполненияЗапросовНаРаскрытиеПоСубклиентам(МВТ, ДатаФиксации,
	ПредставлениеЗначений = Неопределено) Экспорт
		
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МВТ;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Источник.Субброкер КАК Субброкер,
	|	Источник.Субброкер.ВнешнийИсточникДляРСВПоСубклиентам КАК ВнешнийИсточник,
	|	ВЫРАЗИТЬ(Источник.Субброкер.ЮридическиеФизическиеЛица.ПолноеНаименование КАК СТРОКА(255)) КАК ПолноеНаименованиеЮЛСубброкера,
	|	Источник.Субброкер.LEI КАК LEIКодСубброкера,
	|	Источник.СчетДепо.Код КАК КодСчетаДепоСубброкера,
	|	Источник.СчетДепо КАК СчетДепо,
	|	Источник.КДРеференс КАК КДРеференс,
	|	Источник.ТипКД КАК ТипКД,
	|	Источник.КодТипаКД КАК КодТипаКД,
	|	Источник.ВидКДВыплатаДоходов КАК ВидКДВыплатаДоходов,
	|	Источник.ЗаполнятьЗаявленнуюНалоговуюСтавку КАК ЗаполнятьЗаявленнуюНалоговуюСтавку,
	|	Источник.ДатаФиксации КАК ДатаФиксации,
	|	Источник.ЦеннаяБумага КАК ЦеннаяБумага,
	|	ВЫРАЗИТЬ(ВЫРАЗИТЬ(Источник.ЦеннаяБумага.Эмитент.ЮридическиеФизическиеЛица КАК Справочник.ЮридическиеЛица).ПолноеНаименование КАК СТРОКА(255)) КАК ПолноеНаименованиеЭмитента,
	|	Источник.ЦеннаяБумага.ISIN КАК ISIN,
	|	Источник.ЦеннаяБумага.НомерРегистрации КАК ГосРегНомерВыпуска,
	|	Источник.Субброкер.Код КАК КодСубброкера,
	|	Источник.Субклиент.Код КАК КодСубклиента,
	|	Источник.Субклиент КАК Субклиент,
	|	Источник.ТипСчета КАК ТипСчета,
	|	ВЫБОР
	|		КОГДА Источник.Субклиент.ЮридическиеФизическиеЛица ССЫЛКА Справочник.ЮридическиеЛица
	|			ТОГДА ВЫРАЗИТЬ(ВЫРАЗИТЬ(Источник.Субклиент.ЮридическиеФизическиеЛица КАК Справочник.ЮридическиеЛица).ПолноеНаименование КАК СТРОКА(255))
	|		КОГДА Источник.Субклиент.ЮридическиеФизическиеЛица ССЫЛКА Справочник.ФизическиеЛица
	|			ТОГДА ВЫРАЗИТЬ(Источник.Субклиент.ЮридическиеФизическиеЛица КАК Справочник.ФизическиеЛица).Наименование
	|	КОНЕЦ КАК ПолноеНаименованиеЮЛФЛСубклиента,
	|	ВЫБОР
	|		КОГДА Источник.Субклиент.ЮридическиеФизическиеЛица ССЫЛКА Справочник.ЮридическиеЛица
	|			ТОГДА &ЮрЛицо
	|		КОГДА Источник.Субклиент.ЮридическиеФизическиеЛица ССЫЛКА Справочник.ФизическиеЛица
	|			ТОГДА &ФизЛицо
	|	КОНЕЦ КАК ПризнакЮЛФЛ,
	|	Источник.Субклиент.ЮридическиеФизическиеЛица.ДатаРождения КАК ДатаРожденияФЛ,
	|	ЕСТЬNULL(ГражданствоФизЛиц.Страна, ЗНАЧЕНИЕ(Справочник.КлассификаторСтранМира.ПустаяСсылка)) КАК ГражданствоФЛ,
	|	ВЫБОР
	|		КОГДА Источник.Субклиент.ЮридическиеФизическиеЛица ССЫЛКА Справочник.ЮридическиеЛица
	|					И НЕ Источник.Субклиент.ЮридическиеФизическиеЛица.НеРезидент
	|				ИЛИ Источник.Субклиент.ЮридическиеФизическиеЛица ССЫЛКА Справочник.ФизическиеЛица
	|					И ГражданствоФизЛиц.Страна = &Россия
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК НалоговыйРезидентРФ,
	|	ЕСТЬNULL(КодыЗагрузкиЦБ.Код, """") КАК КодНРД,
	|	Источник.Количество КАК Количество,
	|	ВЫБОР
	|		КОГДА Источник.Субклиент.ЮридическиеФизическиеЛица ССЫЛКА Справочник.ЮридическиеЛица
	|			ТОГДА ЕСТЬNULL(КонтактыРегистрацииЮрЛиц.Поле1, """")
	|		КОГДА Источник.Субклиент.ЮридическиеФизическиеЛица ССЫЛКА Справочник.ФизическиеЛица
	|			ТОГДА ЕСТЬNULL(КонтактыРегистрацииФизЛиц.Поле1, """")
	|		ИНАЧЕ """"
	|	КОНЕЦ КАК АдресМестонахожденияРегистрацииСтрана,
	|	ВЫБОР
	|		КОГДА Источник.Субклиент.ЮридическиеФизическиеЛица ССЫЛКА Справочник.ЮридическиеЛица
	|			ТОГДА ЕСТЬNULL(КонтактыРегистрацииЮрЛиц.Представление, """")
	|		КОГДА Источник.Субклиент.ЮридическиеФизическиеЛица ССЫЛКА Справочник.ФизическиеЛица
	|			ТОГДА ЕСТЬNULL(КонтактыРегистрацииФизЛиц.Представление, """")
	|		ИНАЧЕ """"
	|	КОНЕЦ КАК АдресМестонахожденияРегистрацииАдрес,
	|	ВЫБОР
	|		КОГДА Источник.Субклиент.ЮридическиеФизическиеЛица ССЫЛКА Справочник.ЮридическиеЛица
	|			ТОГДА ЕСТЬNULL(КонтактыПочтовыеЮрЛиц.Поле1, """")
	|		КОГДА Источник.Субклиент.ЮридическиеФизическиеЛица ССЫЛКА Справочник.ФизическиеЛица
	|			ТОГДА ЕСТЬNULL(КонтактыПочтовыеФизЛиц.Поле1, """")
	|		ИНАЧЕ """"
	|	КОНЕЦ КАК АдресПочтовыйСтрана,
	|	ВЫБОР
	|		КОГДА Источник.Субклиент.ЮридическиеФизическиеЛица ССЫЛКА Справочник.ЮридическиеЛица
	|			ТОГДА ЕСТЬNULL(КонтактыПочтовыеЮрЛиц.Представление, """")
	|		КОГДА Источник.Субклиент.ЮридическиеФизическиеЛица ССЫЛКА Справочник.ФизическиеЛица
	|			ТОГДА ЕСТЬNULL(КонтактыПочтовыеФизЛиц.Представление, """")
	|		ИНАЧЕ """"
	|	КОНЕЦ КАК АдресПочтовыйАдрес,
	|	ВЫБОР
	|		КОГДА Источник.Субклиент.ЮридическиеФизическиеЛица ССЫЛКА Справочник.ЮридическиеЛица
	|			ТОГДА &REGN
	|		КОГДА Источник.Субклиент.ЮридическиеФизическиеЛица ССЫЛКА Справочник.ФизическиеЛица
	|			ТОГДА ПаспортФизЛиц.ДокументВид.Ссылка
	|		ИНАЧЕ &ПустаяСтрока4
	|	КОНЕЦ КАК ДокументВладельцаТип,
	|	ВЫБОР
	|		КОГДА Источник.Субклиент.ЮридическиеФизическиеЛица ССЫЛКА Справочник.ЮридическиеЛица
	|			ТОГДА Источник.Субклиент.ЮридическиеФизическиеЛица.РегНомер
	|		КОГДА Источник.Субклиент.ЮридическиеФизическиеЛица ССЫЛКА Справочник.ФизическиеЛица
	|			ТОГДА ЕСТЬNULL(ПаспортФизЛиц.ДокументНомер, """")
	|		ИНАЧЕ """"
	|	КОНЕЦ КАК ДокументВладельцаНомер,
	|	ВЫБОР
	|		КОГДА Источник.Субклиент.ЮридическиеФизическиеЛица ССЫЛКА Справочник.ЮридическиеЛица
	|			ТОГДА """"
	|		КОГДА Источник.Субклиент.ЮридическиеФизическиеЛица ССЫЛКА Справочник.ФизическиеЛица
	|			ТОГДА ЕСТЬNULL(ПаспортФизЛиц.ДокументСерия, """")
	|		ИНАЧЕ """"
	|	КОНЕЦ КАК ДокументВладельцаСерия,
