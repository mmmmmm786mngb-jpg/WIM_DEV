Функция КешСоединения(Сессия)
	
	Если Сессия.Свойство("СлужебныеДанные") Тогда
		Для Каждого Пул Из Сессия.СлужебныеДанные.ПулСоединений Цикл
			Возврат Пул.Значение;
		КонецЦикла;
	КонецЕсли;
	
	Возврат Неопределено;
	
КонецФункции

Функция HTTPЗапросМетодPOST_V2(Токен, АдресСервиса, ПараметрыURLЗапроса, ЛогПолученныхДанных = Неопределено)
	
	ЗаголовкиЗапроса	= Новый Соответствие;
	ЗаголовкиЗапроса.Вставить("Accept", 		"application/json");
	ЗаголовкиЗапроса.Вставить("Authorization", 	Токен);
	ЗаголовкиЗапроса.Вставить("Content-Type", 	"application/json");
	
	ЗапросМетодPOST = Новый HTTPЗапрос;
	ЗапросМетодPOST.АдресРесурса = АдресСервиса;
	ЗапросМетодPOST.Заголовки = ЗаголовкиЗапроса;
	
	ТелоЗапроса = Новый ЗаписьJSON;
	ТелоЗапроса.УстановитьСтроку();
	
	ТелоЗапроса.ЗаписатьНачалоОбъекта();
	
	Для Каждого ТекПараметр Из ПараметрыURLЗапроса Цикл
		
		ТелоЗапроса.ЗаписатьИмяСвойства(ТекПараметр.Ключ);
		
		Если ТипЗнч(ТекПараметр.Значение) = Тип("Массив") Тогда
			
			ТелоЗапроса.ЗаписатьНачалоМассива();
			
			Для Каждого ТекЗначение Из ТекПараметр.Значение Цикл
				Если ТипЗнч(ТекЗначение) = Тип("Структура")  Тогда
					ДобавитьВТелоЗапросаТипСтруктура(ТелоЗапроса, ТекЗначение);
				Иначе
					ТелоЗапроса.ЗаписатьЗначение(ТекЗначение);
				КонецЕсли;
			КонецЦикла;
			
			ТелоЗапроса.ЗаписатьКонецМассива();
			
		ИначеЕсли ТипЗнч(ТекПараметр.Значение) = Тип("Дата") Тогда
			ТелоЗапроса.ЗаписатьЗначение(XMLСтрока(НачалоДня(ТекПараметр.Значение)) + ".0000000Z");
			
		ИначеЕсли ТипЗнч(ТекПараметр.Значение) = Тип("Структура")  Тогда
			ДобавитьВТелоЗапросаТипСтруктура(ТелоЗапроса, ТекПараметр.Значение);
		Иначе
			ТелоЗапроса.ЗаписатьЗначение(ТекПараметр.Значение);
		КонецЕсли;
		
	КонецЦикла;
	
	ТелоЗапроса.ЗаписатьКонецОбъекта();
	СтрокаТелоЗапроса = ТелоЗапроса.Закрыть();
	
	// Сохраняем полученные даные в логе
	Если ТипЗнч(ЛогПолученныхДанных) = Тип("ТекстовыйДокумент") Тогда
		ЛогПолученныхДанных.ДобавитьСтроку("Тело запроса:");
		ЛогПолученныхДанных.ДобавитьСтроку(СтрокаТелоЗапроса);
	КонецЕсли;
	
	ЗапросМетодPOST.УстановитьТелоИзСтроки(СтрокаТелоЗапроса, "UTF-8", ИспользованиеByteOrderMark.НеИспользовать);
	
	Возврат ЗапросМетодPOST;
	
КонецФункции

Процедура ДобавитьВТелоЗапросаТипСтруктура(ТелоЗапроса, ТекЗначение)

	ТелоЗапроса.ЗаписатьНачалоОбъекта();
	Для Каждого ТекЗначениеСтруктуры Из ТекЗначение Цикл
		ТелоЗапроса.ЗаписатьИмяСвойства(ТекЗначениеСтруктуры.Ключ);
		ТелоЗапроса.ЗаписатьЗначение(ТекЗначениеСтруктуры.Значение);
	КонецЦикла;
	ТелоЗапроса.ЗаписатьКонецОбъекта();

КонецПроцедуры

Функция КодыСостоянияHTTP()
	
	КодыСостояния = Новый Соответствие;
	Для Каждого Описание Из КоннекторHTTP.КодыСостоянияHTTP() Цикл
		КодыСостояния.Вставить(Описание.Значение, Описание.Ключ);
	КонецЦикла;
	
	Возврат КодыСостояния;
	
КонецФункции

Функция ОписаниеПоКодуОтвета(КодОтвета)
	
	СписокКодовОтвета = КодыСостоянияHTTP();
	Описание = Строка(КодОтвета) + " - ";
	
	НайденноеОписание = СписокКодовОтвета[КодОтвета];
	
	Если НайденноеОписание <> Неопределено Тогда
		Описание = Описание + НайденноеОписание;
	КонецЕсли;
	
	Возврат Описание;
	
КонецФункции

Процедура ДобавитьТекстКСообщению(Сообщение, ДобавляемыйТекст)
	
	Если  ЗначениеЗаполнено(Сообщение) Тогда
		Сообщение = Сообщение + Символы.ПС + ДобавляемыйТекст;
	Иначе
		Сообщение = ДобавляемыйТекст;
	КонецЕсли;
	
КонецПроцедуры

Процедура ДобавитьОбщиеПараметрыURLЗапроса(ПараметрыURLЗапроса, ВхПараметры, СвойстваМетода = "")
	
	ИмяПараметраPageNum = "pageNum";
	ИмяПараметраPageSize = "pageSize";
	
	Если ВхПараметры.Свойство(ИмяПараметраPageNum) = Ложь И СтрНайти(СвойстваМетода, ИмяПараметраPageNum) > 0 Тогда
		ПараметрыURLЗапроса.Вставить(ИмяПараметраPageNum, 1);
	КонецЕсли;
	
	Если ВхПараметры.Свойство(ИмяПараметраPageSize) = Ложь И СтрНайти(СвойстваМетода, ИмяПараметраPageSize) > 0 Тогда
		ПараметрыURLЗапроса.Вставить(ИмяПараметраPageSize, 300);
	КонецЕсли;
	
	Если СтрНайти(СвойстваМетода, "count") > 0 Тогда
		ПараметрыURLЗапроса.Вставить("count", 100000);
	КонецЕсли;
	
КонецПроцедуры

