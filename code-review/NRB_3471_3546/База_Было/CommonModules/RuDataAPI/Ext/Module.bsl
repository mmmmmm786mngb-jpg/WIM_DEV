Функция InfoSecurities_Фильтр(ВходныеПараметры)
	ОператорAND = " AND ";
	Условие = "";
	
	Если СвойствоЗаполнено(ВходныеПараметры, "ДатаВремяОбновленияДанных") Тогда
		Условие = " update_date > #" + XMLСтрока(ВходныеПараметры.ДатаВремяОбновленияДанных) + ".0000000Z#";
	КонецЕсли;
		
	Если СвойствоЗаполнено(ВходныеПараметры, "fintoolids") Тогда
		FintoolidsСтрокой = СтрокаДляФильтраRuData(ВходныеПараметры.fintoolids, Истина);
		Условие = Условие + ?(ПустаяСтрока(Условие), "", ОператорAND) + " fintoolid IN ( " + FintoolidsСтрокой + ")";
	Иначе
		Если Не ВходныеПараметры.Свойство("fintoolids") И СвойствоЗаполнено(ВходныеПараметры, "ISINs") Тогда
			ISINsСтрокой = СтрокаДляФильтраRuData(ВходныеПараметры.ISINs);
			Условие = Условие + ?(ПустаяСтрока(Условие), "", ОператорAND) + " isin IN ( " + ISINsСтрокой + ")";
			// Пустые ISIN тоже принимаем, в противном случае будет условие: Иначе Условие = Условие + " isin IS NOT NULL AND ";
		КонецЕсли;
	КонецЕсли;
	
	Если СвойствоЗаполнено(ВходныеПараметры, "ФильтрСтатусовЦБ") Тогда
		ФильтрСтатусовЦБ = ВходныеПараметры.ФильтрСтатусовЦБ;
	Иначе
		ФильтрСтатусовЦБ = Неопределено;
	КонецЕсли;
	ОбновитьБумагиВНеактуальномСтатусе = ВходныеПараметры.Свойство("ОбновитьБумагиВНеактуальномСтатусе") 
											И ВходныеПараметры.ОбновитьБумагиВНеактуальномСтатусе;
	Если Не ОбновитьБумагиВНеактуальномСтатусе И ФильтрСтатусовЦБ <> "" Тогда
		Если ФильтрСтатусовЦБ = Неопределено Тогда
			ФильтрСтатусовЦБ = ФильтрПоАктуальнымСтатусамЦБ();
		КонецЕсли;
		Условие = Условие + ?(ПустаяСтрока(Условие), "", ОператорAND) + " status_name IN (" + ФильтрСтатусовЦБ + " ) ";
	КонецЕсли;
	
	Возврат Условие;
КонецФункции

