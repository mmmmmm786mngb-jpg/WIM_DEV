// Возвращает таблицу с подвидом облигаций
//
// Параметры:
//  ОписаниеОшибки	 - Строка	 - Описание ошибки (если есть)
//  Сессия			 - Строка	 - Кеш сессии HTTP
//  ВходныеПараметры - Структура - Структура входных параметров (может быть неопределено)
//    Обязательные поля:
//     * fintoolids					 - Массив	 - массив fintoolid (обязательное поле - идентификатор ЦБ в RuData),
//     * filterOnlySpecifiedCategory - Строка	 - строка фильтрации по категории, например: ""id_category in (450, 540, 541)"
//     * onlyFintoolsWithCategory	 - Булево
// Возвращаемое значение:
//   - ТаблицаЗначений - Таблица с данными
Функция InfoFintoolCategoryValue(ОписаниеОшибки, Сессия = Неопределено, ВходныеПараметры = Неопределено) Экспорт
	ТаблицаCategoryValue = Неопределено;
	
	ОписаниеОшибки = "";
	НастройкиСоединения = ПараметрыИсточника();
	
	НомерПачки = 0;
	Если ЗначениеЗаполнено(НастройкиСоединения) Тогда
		ОграничениеПоКоличествуЦБ = 100; // Ограничения RuData по объему запрашиваемых данных
		//
		fintoolids = Новый Массив;
		//
		ПоследнийИндекс = ВходныеПараметры.fintoolids.ВГраница();
		Для Индекс = 0 По ПоследнийИндекс Цикл
			fintoolids.Добавить(ВходныеПараметры.fintoolids[Индекс]);
			Группировать = (Индекс + 1) % ОграничениеПоКоличествуЦБ;
			Если Группировать = 0 Или Индекс = ПоследнийИндекс Тогда
				НомерПачки = НомерПачки + 1;
				
				ВходящиеИдентификаторы = НовыеВходящиеИдентификаторы();
				ВходящиеИдентификаторы.fintoolids = fintoolids;
				
				ВходныеПараметрыГруппа = НовыеВходныеПараметрыГруппы(НомерПачки, Дата(1, 1, 1), ВходящиеИдентификаторы);
				ВходныеПараметрыГруппа.Вставить("filterOnlySpecifiedCategory", ВходныеПараметры.filterOnlySpecifiedCategory);
				ВходныеПараметрыГруппа.Вставить("onlyFintoolsWithCategory"	, ВходныеПараметры.onlyFintoolsWithCategory);
				
				ВременнаяТаблица = ТаблицаДанныхМетода("FintoolCategoryValue", НастройкиСоединения, ОписаниеОшибки, Сессия, ВходныеПараметрыГруппа);
				//
				fintoolids = Новый Массив;
				//
				Если ЗначениеЗаполнено(ВременнаяТаблица) Тогда
					ТаблицаCategoryValue = КонкатенацияТаблицЗначений(ТаблицаCategoryValue, ВременнаяТаблица);
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	Возврат ТаблицаCategoryValue;
КонецФункции

