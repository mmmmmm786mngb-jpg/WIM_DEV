//    Обязательные поля:
//     * fintoolids					 - Массив	 - массив fintoolid (обязательное поле - идентификатор ЦБ в RuData),
//													может быть пустым, тогда отбора по fintoolid не будет
//     * ДатаВремяОбновленияДанных	 - Дата		 - дата \ время начала выборки обновлений (пустая дата - по всем датам изменений)
// 
// Возвращаемое значение:
//   - ТаблицаЗначений - Таблица с данными (см. https://docs.efir-net.ru/dh2/#/Bond/Amortizations)
Функция BondAmortizations(ОписаниеОшибки, Сессия = Неопределено, ВходныеПараметры = Неопределено) Экспорт
	ИмяFintoolids = "fintoolids";
	Если ВходныеПараметры = Неопределено Тогда
		ВходныеПараметры = Новый Структура;
		ВходныеПараметры.Вставить(ИмяFintoolids, Новый Массив);
		ВходныеПараметры.Вставить("ДатаВремяОбновленияДанных", ДАТА(1, 1, 1));
	КонецЕсли;
	
	ТаблицаBondAmortizations = Неопределено;
	ОписаниеОшибки = "";
	НуженОтборПоFintoolids = ЗначениеЗаполнено(ВходныеПараметры.fintoolids);
	НастройкиСоединения = ПараметрыИсточника();
	НомерПачки = 0;
	Если ЗначениеЗаполнено(НастройкиСоединения) Тогда
		ОграничениеПоКоличествуЦБ = 100; // Ограничения RuData по объему запрашиваемых данных
		fintoolids = Новый Массив; 
		ПоследнийИндекс = ПоследнийИндексДляЦикла(ВходныеПараметры, ИмяFintoolids);
		Для Индекс = 0 По ПоследнийИндекс Цикл
			Если НуженОтборПоFintoolids Тогда
				fintoolids.Добавить(ВходныеПараметры.fintoolids[Индекс]);
			КонецЕсли;
			Группировать = (Индекс + 1) % ОграничениеПоКоличествуЦБ;
			Если Группировать = 0 Или Индекс = ПоследнийИндекс Тогда
				НомерПачки = НомерПачки + 1;
				
				ВходящиеИдентификаторы = НовыеВходящиеИдентификаторы();
				ВходящиеИдентификаторы.Вставить(ИмяFintoolids, fintoolids);
				ВходныеПараметрыГруппа = НовыеВходныеПараметрыГруппы(НомерПачки, ВходныеПараметры.ДатаВремяОбновленияДанных, ВходящиеИдентификаторы);
				ВременнаяТаблица =
					ТаблицаДанныхМетода("BondAmortizations", НастройкиСоединения, ОписаниеОшибки, Сессия, ВходныеПараметрыГруппа);
				
				fintoolids = Новый Массив;
				
				Если ЗначениеЗаполнено(ВременнаяТаблица) Тогда
					ТаблицаBondAmortizations = КонкатенацияТаблицЗначений(ТаблицаBondAmortizations, ВременнаяТаблица);
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	Возврат ТаблицаBondAmortizations;
КонецФункции

// Возвращает данные (реквизиты) для создания и \ или обновления ЦБ в справочнике 1С
//
// Параметры:
//  ВходныеПараметры - Структура - Структура входных параметров (может быть неопределено)
//    Обязательные поля:
//     * ISINs						 - Массив	 - массив isin (пустой массив - по всем ЦБ)
//     * ДатаВремяОбновленияДанных	 - Дата		 - дата \ время начала выборки обновлений (пустая дата - по всем датам изменений)
//    Необязательные поля:
//     * ОбновитьБумагиВНеактуальномСтатусе - Булево - если Истина, то будут загружаться бумаги во всех статусах, но бумаги в
//  												неактуальных статусах будут загружаться только если бумага в справочнике ЦБ
//  												есть и и ее статус изменился
//     * ОбновитьЭмитентовВсехЗагружаемыхЦБ - Булево - если Истина, то будут загружаться эмитенты всех загружаемых ЦБ,
//  												Если же Ложь, то только эмитенты новых ЦБ (то есть ЦБ, которых еще не было
//  												в справочнике ЦБ и эмитенты тех загружаемых ЦБ у которых не был известен 
//  												эмитент (юридическое лицо).
//     * ЭтоОтчет - Булево - если Истина, то данные будут использованы для построения отчета, не нужно подгружать эмитентов ЦБ
//  												даже если указана дата \ время начала выборки обновлений (ДатаВремяОбновленияДанных)
// Возвращаемое значение:
//   - ТаблицаЗначений - Таблица с колонками, соответствующими реквизитам справочника ЦенныеБумаги
//
Функция ДанныеДляСозданияОбновленияЦенныхБумаг(Знач ВходныеПараметры) Экспорт
	
	ВремяНачалаФормирования = ОценкаПроизводительности.НачатьЗамерВремени();
	
	ТаблицаДанныхЦБ				 = Новый ТаблицаЗначений;
	ТаблицаДанныхЭмитентов		 = Новый ТаблицаЗначений;
	ТаблицаDictionaryCountries	 = Новый ТаблицаЗначений;
	ТаблицаInfoCurrencies		 = Новый ТаблицаЗначений;
	
	
	ИмяПараметраПериод = "ДатаВремяОбновленияДанных";
	
	ОписаниеОшибки = "";
	Сессия = Неопределено;
	
	ТаблицаЭмитентовЗагружаемыхЦБ = Неопределено;
		
	ОбщегоНазначенияКлиентСервер.ДобавитьЭлементСтруктурыПриОтсутствии(ВходныеПараметры, "ОбновитьЭмитентовВсехЗагружаемыхЦБ", Ложь);
	ОбщегоНазначенияКлиентСервер.ДобавитьЭлементСтруктурыПриОтсутствии(ВходныеПараметры, "ОбновитьБумагиВНеактуальномСтатусе", Ложь);
	
	ПолучитьInfoSecurities = Истина;
	
	ВходныеПараметрыInfoSecurities = Новый Структура;
	ОбщегоНазначенияКлиентСервер.ДополнитьСтруктуру(ВходныеПараметрыInfoSecurities, ВходныеПараметры, Ложь);
	Если СвойствоЗаполнено(ВходныеПараметры, ИмяПараметраПериод) Тогда
		fintoolids = FintoolidsПоВсемИзменениям(ВходныеПараметры, ОписаниеОшибки, Сессия);
		ПолучитьInfoSecurities = ЗначениеЗаполнено(fintoolids);
		ВходныеПараметрыInfoSecurities[ИмяПараметраПериод] = ДАТА(1, 1, 1);
		ВходныеПараметрыInfoSecurities.Вставить("fintoolids", fintoolids);
	КонецЕсли;
	
	ТаблицаInfoSecurities = Неопределено;
	Если ПолучитьInfoSecurities Тогда
		ТаблицаInfoSecurities = ДанныеЦенныхБумагПоПараметрам(ВходныеПараметрыInfoSecurities, ОписаниеОшибки, Сессия);
	КонецЕсли;
	
	БылаОшибкаПодключения = Не ОписаниеОшибки = "";
	
	Если ЗначениеЗаполнено(ТаблицаInfoSecurities) Тогда
		
		ВходныеПараметрыDictionaryCountries = Новый Структура;
		ОписаниеОшибки = "";
		Сессия = Неопределено;
		ТаблицаDictionaryCountries = DictionaryCountries(ОписаниеОшибки, Сессия, ВходныеПараметрыDictionaryCountries);
		
		ВходныеПараметрыInfoCurrencies = Новый Структура;
		ОписаниеОшибки = "";
		Сессия = Неопределено;
		ТаблицаInfoCurrencies = InfoCurrencies(ОписаниеОшибки, Сессия, ВходныеПараметрыInfoCurrencies);
		
		ТаблицаInfoFintoolReferenceData =
			ТаблицаСозданияОбновленияЦенныхБумаг("InfoFintoolReferenceData", ИмяПараметраПериод, ТаблицаInfoSecurities);
		
		ТаблицаNsdCommonData =
			ТаблицаСозданияОбновленияЦенныхБумаг("NsdCommonData", ИмяПараметраПериод, ТаблицаInfoSecurities);
			
		ТаблицаДопущенныхКТоргамЦБ = ЦБДопущенныеКТоргамВРФ(ТаблицаInfoSecurities);
		
		ТаблицаДанныхЦБ = СтатикаЦенныхБумаг(ТаблицаInfoSecurities, ТаблицаInfoFintoolReferenceData, ТаблицаNsdCommonData, 
												ТаблицаДопущенныхКТоргамЦБ, ВходныеПараметры);
		ЗаполнитьПодвидГосОблигаций(ОписаниеОшибки, Сессия, ТаблицаДанныхЦБ);
												
		ВходныеПараметрыДляПолученияЭмитентов = Новый Структура;
		ВходныеПараметрыДляПолученияЭмитентов.Вставить("ОбновитьЭмитентовВсехЗагружаемыхЦБ", ВходныеПараметры.ОбновитьЭмитентовВсехЗагружаемыхЦБ);
		ТаблицаЭмитентовЗагружаемыхЦБ = ТаблицаЭмитентовЗагружаемыхЦБ(ТаблицаДанныхЦБ, ВходныеПараметрыДляПолученияЭмитентов);
	КонецЕсли;
	
	ВходныеПараметрыДляПолученияЭмитентов = Новый Структура;
	ВходныеПараметрыДляПолученияЭмитентов.Вставить(ИмяПараметраПериод, ВходныеПараметры.ДатаВремяОбновленияДанных);
	
	ТаблицаИзменившихсяЭмитентов =  ТаблицаИзменившихсяЭмитентов(ВходныеПараметры);
	ТаблицаДанныхЭмитентов = СтатикаЭмитентов(ТаблицаЭмитентовЗагружаемыхЦБ, ТаблицаИзменившихсяЭмитентов);
	
	ВесЗамера = ТаблицаДанныхЦБ.Количество() + ТаблицаДанныхЭмитентов.Количество();
	ОценкаПроизводительности.ЗакончитьЗамерВремени("RudataAPI.ПолучениеДанныхИзAPI", ВремяНачалаФормирования, ВесЗамера);
	
	ВыходныеПараметры = Новый Структура;
	Если БылаОшибкаПодключения Тогда
		ВыходныеПараметры.Вставить("ТаблицаДанныхЦБ", Неопределено);
		ВыходныеПараметры.Вставить("ТаблицаДанныхЭмитентов", Неопределено);
		ВыходныеПараметры.Вставить("ТаблицаСтран", Неопределено);
		ВыходныеПараметры.Вставить("ТаблицаВалют", Неопределено);
	Иначе
		ВыходныеПараметры.Вставить("ТаблицаДанныхЦБ", ТаблицаДанныхЦБ);
		ВыходныеПараметры.Вставить("ТаблицаДанныхЭмитентов", ТаблицаДанныхЭмитентов);
		ВыходныеПараметры.Вставить("ТаблицаСтран", ТаблицаDictionaryCountries);
		ВыходныеПараметры.Вставить("ТаблицаВалют", ТаблицаInfoCurrencies);
	КонецЕсли;
	
	Возврат ВыходныеПараметры;
	
КонецФункции

// Процедура - Создание обновление ценных бумаг и эмитентов
//
// Параметры:
//  ВходныеПараметры - Структура - Структура входных параметров (может быть неопределено)
//  Обязательные поля:
//  * ISINs						 - Массив	 - массив isin (пустой массив - по всем ЦБ)
//  * ДатаВремяОбновленияДанных	 - Дата		 - дата \ время начала выборки обновлений (пустая дата - по всем датам изменений)
//  Необязательные поля:
//  * ОбновитьБумагиВНеактуальномСтатусе - Булево - Если Истина, то будут загружаться бумаги во всех статусах, но бумаги в
//  												неактуальных статусах будут загружаться только если бумага в справочнике ЦБ
//  												есть и и ее статус изменился
//  * ОбновитьЭмитентовВсехЗагружаемыхЦБ - Булево - Если Истина, то будут загружаться эмитенты всех загружаемых ЦБ,
//  												Если же Ложь, то только эмитенты новых ЦБ (то есть ЦБ, которых еще не было
//  												в справочнике ЦБ и эмитенты тех загружаемых ЦБ у которых не был известен 
//  												эмитент (юридическое лицо).
//  * СоздатьОбновитьТолькоЭмитентов	 - Булево - Если истина то в базу будут созданы или обновлены только эмитенты
//  												(юридические лица). ЦБ в процессе будут читаться из RuData, но на конечном
//  												этапе создание/обновление ЦБ производится не будет.
//  * ФильтрСтатусовЦБ					 - Строка - Список статусов ЦБ которые нужно загружать в формате фильтра для запросов RuData,
//  												(через запятую в одинарных кавычках. Например: 'Погашен', 'Приостановлен'). Если
//  												передается пустая строка ("") - это означает что фильтр по статусам устанавливать
//  												не нужно. Если поле отсутствует или значение равно неопредлено устанваливается
//  												фильтр по умолчанию - см. функцию ФильтрПоАктуальнымСтатусамЦБ().
// 
// Возвращаемое значение:
//   - Булево - статус завершения
//
Функция СозданиеОбновлениеЦенныхБумагИЭмитентов(ВходныеПараметры) Экспорт
	
	ИмяСобытия = "RuDataAPI";
	
	ТаблицаОшибок = Новый ТаблицаЗначений;

	Попытка
		ВыходныеПараметры = ДанныеДляСозданияОбновленияЦенныхБумаг(ВходныеПараметры);
		
		Если ВыходныеПараметры.ТаблицаДанныхЦБ = Неопределено Тогда
			ТекстОшибки = "Нет подключения к RuDataAPI, см. журнал регистрации вызовов";
			ЗаписьЖурналаРегистрации(ИмяСобытия, УровеньЖурналаРегистрации.Ошибка, , , ТекстОшибки);
			Возврат Ложь;
		КонецЕсли;
		Если Не ЗначениеЗаполнено(ВыходныеПараметры.ТаблицаДанныхЦБ) Тогда
			ШаблонТекстаОшибки = "Нет данных о ЦБ в RuDataAPI по заданным параметрам: ДатаС = [%1] ISINs = [%2]";
			ТекстОшибки = СтрШаблон(ШаблонТекстаОшибки,
				?(ЗначениеЗаполнено(ВходныеПараметры.ДатаВремяОбновленияДанных), ВходныеПараметры.ДатаВремяОбновленияДанных, "Без учета периода"),
				?(ЗначениеЗаполнено(ВходныеПараметры.ISINs), СтрСоединить(ВходныеПараметры.ISINs), "По всем ЦБ"));
			ЗаписьЖурналаРегистрации(ИмяСобытия, УровеньЖурналаРегистрации.Предупреждение, , , ТекстОшибки);
		КонецЕсли;
		
		ВидОбъекта = Перечисления.ВидыОбъектовКонтактнойИнформации.ЮридическиеЛица;
		ТипАдрес = Перечисления.ТипыКонтактнойИнформации.Адрес;
		ТипТелефон = Перечисления.ТипыКонтактнойИнформации.Телефон;
		ТипАдресЭлектроннойПочты = Перечисления.ТипыКонтактнойИнформации.АдресЭлектроннойПочты;
		ПараметрыКИ = Новый Структура;
		ПараметрыКИ.Вставить("Период"					, Дата("20000101"));
		ПараметрыКИ.Вставить("ВидОбъекта"				, ВидОбъекта);
		ПараметрыКИ.Вставить("ТипАдрес"					, ТипАдрес);
		ПараметрыКИ.Вставить("ТипТелефон"				, ТипТелефон);
		ПараметрыКИ.Вставить("ТипАдресЭлектроннойПочты"	, ТипАдресЭлектроннойПочты);
		ПараметрыКИ.Вставить("ВидЮридическийАдрес", КонтактнаяИнформация.ВидыКонтактнойИнформации(ВидОбъекта, ТипАдрес, "Юридический")[0]);
		ПараметрыКИ.Вставить("ВидФактическийАдрес", КонтактнаяИнформация.ВидыКонтактнойИнформации(ВидОбъекта, ТипАдрес, "Фактический")[0]);
		ПараметрыКИ.Вставить("ВидТелефон", КонтактнаяИнформация.ВидыКонтактнойИнформации(ВидОбъекта, ТипТелефон, "Телефон")[0]);
		ПараметрыКИ.Вставить("ВидАдресЭлектроннойПочты",
		КонтактнаяИнформация.ВидыКонтактнойИнформации(ВидОбъекта, ТипАдресЭлектроннойПочты, "mail")[0]);
		
		ВремяНачалаФормирования = ОценкаПроизводительности.НачатьЗамерВремени();
		КоличествоЭмитентов = ВыходныеПараметры.ТаблицаДанныхЭмитентов.Количество();
		
		Если КоличествоЭмитентов > 0 Тогда
			КредитныеОрганизации = ЭмитентыКредитныеОрганизации();
			КодыРегистрации = ЭмитентыКодыРегистрации();
		КонецЕсли;
		
		Для Каждого ДанныеЮрЛица Из ВыходныеПараметры.ТаблицаДанныхЭмитентов Цикл
			
			СоздатьОбновитьЮрлицоЭмитента(ДанныеЮрЛица, ПараметрыКИ, КредитныеОрганизации, КодыРегистрации);
			
		КонецЦикла;
		ОценкаПроизводительности.ЗакончитьЗамерВремени("RudataAPI.СозданиеОбновлениеЮрлицЭмитентов", ВремяНачалаФормирования, // BSLLS:Typo-off
			КоличествоЭмитентов);
		
		Если (ВходныеПараметры.Свойство("СоздатьОбновитьТолькоЭмитентов") И ВходныеПараметры.СоздатьОбновитьТолькоЭмитентов)
				Или Не ЗначениеЗаполнено(ВыходныеПараметры.ТаблицаДанныхЦБ) Тогда
				MarketData.ИзменитьПризнакЭмитентаМеждународнаяКомпанияПоДаннымRuData();
				Если Не ВходныеПараметры.Свойство("СоздатьОбновитьТолькоЭмитентов") Или Не ВходныеПараметры.СоздатьОбновитьТолькоЭмитентов Тогда
					ЗагрузитьНКД(ВходныеПараметры.ДатаВремяОбновленияДанных, ВходныеПараметры.ISINs);
					ЗагрузитьДанныеПоОбращаемостиЦБ(ВходныеПараметры.ДатаВремяОбновленияДанных, ВходныеПараметры.ISINs);
				КонецЕсли;
			Возврат Истина;
		КонецЕсли;
		
		
		ПараметрыКИ = Новый Структура;
		ПараметрыКИ.Вставить("Период"					, НачалоДня(ТекущаяДатаСеанса()));
		
		ВремяНачалаФормирования = ОценкаПроизводительности.НачатьЗамерВремени();
		
		FintoolidAmortisedmty = Новый Массив;
		
		КупонныеОблигации = Новый ТаблицаЗначений; 
		КупонныеОблигации.Колонки.Добавить("fintoolid"		, Новый ОписаниеТипов("Число"));
		КупонныеОблигации.Колонки.Добавить("isin"			, Новый ОписаниеТипов("Строка"));
		КупонныеОблигации.Колонки.Добавить("ЦеннаяБумага"	, Новый ОписаниеТипов("СправочникСсылка.ЦенныеБумаги"));
		
		ПараметрыОпределения = Новый Структура;
		
		Для Каждого ДанныеЦБ Из ВыходныеПараметры.ТаблицаДанныхЦБ Цикл
			
			ПараметрыОпределения.Вставить("ДанныеЦБ" , ДанныеЦБ);
		
			ЦеннаяБумага = СоздатьОбновитьЦеннуюБумагу(ДанныеЦБ, ПараметрыКИ, ТаблицаОшибок, ВыходныеПараметры);
			
			ПараметрыОпределения.Вставить("ЦеннаяБумага", ЦеннаяБумага);
			
			ОпределитьЦенныеБумагиДляДополнительныхЗапросов(ПараметрыОпределения, FintoolidAmortisedmty, КупонныеОблигации);
			
		КонецЦикла;
		
		ОценкаПроизводительности.ЗакончитьЗамерВремени("RudataAPI.СозданиеОбновлениеЦенныхБумаг", ВремяНачалаФормирования,
			ВыходныеПараметры.ТаблицаДанныхЦБ.Количество());
		
		Если Не ВходныеПараметры.Свойство("СоздатьОбновитьТолькоЭмитентов") Или Не ВходныеПараметры.СоздатьОбновитьТолькоЭмитентов Тогда
			
			СозданиеОбновлениеОстаточнойАмортизацииЦенныхБумаг(FintoolidAmortisedmty);
			
			СозданиеОбновлениеИндексацииНоминалаЦенныхБумаг();
			
			СозданиеОбновлениеКупоновЦенныхБумаг(КупонныеОблигации);
			
			ЗагрузитьНКД(ВходныеПараметры.ДатаВремяОбновленияДанных, ВходныеПараметры.ISINs);
			
			ЗагрузитьДанныеПоОбращаемостиЦБ(ВходныеПараметры.ДатаВремяОбновленияДанных, ВходныеПараметры.ISINs);
			
		КонецЕсли;
		
		КоличествоОшибок = ТаблицаОшибок.Количество();
		
		Если НеобходимоОтправитьПисьмоОРезультатахЗагрузкиСтатики(ВходныеПараметры, КоличествоОшибок) Тогда
			
			ВремяНачалаФормирования = ОценкаПроизводительности.НачатьЗамерВремени();
			
			ОтправитьУведомлениеОбОшибкахЗагрузкиЦБизRuDataAPI(ТаблицаОшибок, "Загрузка завершена.");
			
			ОценкаПроизводительности.ЗакончитьЗамерВремени("RudataAPI.УведомлениеОбОшибкахЗагрузки", ВремяНачалаФормирования,
				КоличествоОшибок);
			
		КонецЕсли;
		
	Исключение
		
		ТекстОшибки = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		
		ОтправитьУведомлениеОбОшибкахЗагрузкиЦБизRuDataAPI(ТаблицаОшибок, ТекстОшибки);
		
		ЗаписьЖурналаРегистрации(ИмяСобытия, УровеньЖурналаРегистрации.Ошибка, , , ТекстОшибки);
		
		Возврат Ложь;
		
	КонецПопытки;
	
	MarketData.ИзменитьПризнакЭмитентаМеждународнаяКомпанияПоДаннымRuData();
	Возврат Истина;
	
КонецФункции

// Процедура - Создать обновить код загрузки
//
// Параметры:
//  Владелец						 - СправочникСсылка	 - Владелец кода загрузки
//  КлассификаторЗагрузки			 - СправочникСсылка	 - КлассификаторыЗагрузки
//  Код								 - Строка			 - Код загрузки
//  ТолькоСоздать					 - Булево			 - Истина - создавать, не проверяя есть ли такой код
//  ДатаНачалаДействия				 - Дата				 - ДатаНачалаДействия
//  ДатаОкончанияДействия			 - Дата				 - ДатаОкончанияДействия
//  УчестьДатуДействияКодаЗагрузки	 - Булево			 - Признак того, что при поиске кода загрузки учитывать дату окончания действия
//
Процедура СоздатьОбновитьКодЗагрузки(Владелец, КлассификаторЗагрузки, Код, ТолькоСоздать,
	ДатаНачалаДействия = Неопределено, ДатаОкончанияДействия = Неопределено, УчестьДатуДействияКодаЗагрузки = Ложь) Экспорт
	
	Создаем = Истина;
	
	Если Не ТолькоСоздать Тогда
		Запрос = Новый Запрос;
		Запрос.Текст =
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	КодыЗагрузки.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.КодыЗагрузки КАК КодыЗагрузки
		|ГДЕ
		|	КодыЗагрузки.Владелец = &Владелец
		|	И КодыЗагрузки.Биржа = &КлассификаторЗагрузки
		|	И КодыЗагрузки.Код = &Код
		|	И НЕ КодыЗагрузки.ПометкаУдаления
		|	И ВЫБОР
		|			КОГДА НЕ &УчестьДатуДействияКодаЗагрузки
		|				ТОГДА ИСТИНА
		|			КОГДА КодыЗагрузки.ДатаОкончанияДействия = ДАТАВРЕМЯ(1, 1, 1)
		|				ТОГДА ИСТИНА
		|			ИНАЧЕ КодыЗагрузки.ДатаОкончанияДействия > НАЧАЛОПЕРИОДА(&Период, ДЕНЬ)
		|		КОНЕЦ";
		Запрос.УстановитьПараметр("Владелец", Владелец);
		Запрос.УстановитьПараметр("КлассификаторЗагрузки", КлассификаторЗагрузки);
		Запрос.УстановитьПараметр("Код", Код);
		Запрос.УстановитьПараметр("Период", ТекущаяДатаСеанса());
		Запрос.УстановитьПараметр("УчестьДатуДействияКодаЗагрузки", УчестьДатуДействияКодаЗагрузки);
		Результат = Запрос.Выполнить();
		Создаем = Результат.Пустой();
	КонецЕсли;
	
	Если Создаем Тогда
		
		КодЗагрузки = Справочники.КодыЗагрузки.СоздатьЭлемент();
		КодЗагрузки.ДополнительныеСвойства.Вставить("КомментарийДляИсторииДанных", "ЗагрузкаСтатикиИзAPIRuData");
		КодЗагрузки.Владелец = Владелец;
		КодЗагрузки.Биржа = КлассификаторЗагрузки;
		КодЗагрузки.Код = Код;
		Если ЗначениеЗаполнено(ДатаНачалаДействия) Тогда
			КодЗагрузки.ДатаНачалаДействия = ДатаНачалаДействия;
		КонецЕсли;
		Если ЗначениеЗаполнено(ДатаОкончанияДействия) Тогда
			КодЗагрузки.ДатаОкончанияДействия = ДатаОкончанияДействия;
		КонецЕсли;
		КодЗагрузки.Записать();
		
	КонецЕсли;
	
КонецПроцедуры

// Возвращает признак прекращения действия прочих кодов загрузки (и прекращает их действие)
//
// Параметры:
//  Владелец				 - СправочникСсылка	 - Владелец кода загрузки
//  КлассификаторЗагрузки	 - СправочникСсылка	 - КлассификаторыЗагрузки
//  ТекущийКод				 - Строка			 - Проверяемый код загрузки
//  ДатаОкончанияДействия	 - Дата				 - ДатаОкончанияДействия
// 
// Возвращаемое значение:
//   - Булево - Истина, если предыдущий код загрузки прекратил свое действие
//
Функция ПрекратитьДействиеПрочихКодовЗагрузки(Владелец, КлассификаторЗагрузки, ТекущийКод, ДатаОкончанияДействия) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	КодыЗагрузки.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.КодыЗагрузки КАК КодыЗагрузки
	|ГДЕ
	|	КодыЗагрузки.Владелец = &Владелец
	|	И КодыЗагрузки.Биржа = &КлассификаторЗагрузки
	|	И КодыЗагрузки.Код <> &Код
	|	И НЕ КодыЗагрузки.ПометкаУдаления
	|	И КодыЗагрузки.ДатаНачалаДействия <= &ДатаОкончанияДействия
	|	И КодыЗагрузки.ДатаОкончанияДействия = ДАТАВРЕМЯ(1, 1, 1, 0, 0, 0)";
	Запрос.УстановитьПараметр("Владелец", Владелец);
	Запрос.УстановитьПараметр("КлассификаторЗагрузки", КлассификаторЗагрузки);
	Запрос.УстановитьПараметр("Код", ТекущийКод);
	Запрос.УстановитьПараметр("ДатаОкончанияДействия", ДатаОкончанияДействия);
	Результат = Запрос.Выполнить();
	ПрекратитьДействие = Не Результат.Пустой();
	Если ПрекратитьДействие Тогда
		Выборка = Результат.Выбрать();
		Выборка.Следующий();
		КодЗагрузки = Выборка.Ссылка.ПолучитьОбъект();
		КодЗагрузки.ДатаОкончанияДействия = ДатаОкончанияДействия;
		КодЗагрузки.ОбменДанными.Загрузка = Истина;
		КодЗагрузки.Записать();
		Возврат Истина;
	КонецЕсли;
	Возврат Ложь;
	
КонецФункции

// Процедура для вызова из регламентного задания ЗагрузкаСтатикиПогашенныхЦБНаОстатках
Процедура ВыполнитьОбновлениеПогашенныхЦБ() Экспорт

	СписокISIN = СписокПогашенныхЦБСОстатками();
	Если СписокISIN.Количество() Тогда
		ЗагрузитьЦБЭмитенты(СписокISIN);
	КонецЕсли;

КонецПроцедуры

// Процедура - Создание обновление остаточной амортизации ценных бумаг
//
// Параметры:
//  FintoolidAmortisedmty	 - Массив	 - Массив параметров {isin, fintoolid, ЦеннаяБумага}
//
Процедура СозданиеОбновлениеОстаточнойАмортизацииЦенныхБумаг(FintoolidAmortisedmty) Экспорт
	
	ВремяНачалаФормирования = ОценкаПроизводительности.НачатьЗамерВремени();
	
	Если Не ЗначениеЗаполнено(FintoolidAmortisedmty) Или ТестированиеVanessa.ЭтоТест() Тогда
		Возврат;
	КонецЕсли;
	
	Соединение	 = Неопределено;
	Токен		 = Неопределено;
	Сессия		 = Неопределено;
	ЛогПолученныхДанных = Неопределено;
	ОставитьЗаписьВЖурналеРегистрацииВызовов			 = Ложь;
	ДопустимыйТекстОтказа = "позднее даты";
	
	СлужебныйВызов = Ложь;
	Отказ		 = Ложь;
	ТекстОтказа	 = "";
	ПодключитьсяКСервису(Соединение, Токен, Отказ, ТекстОтказа, СлужебныйВызов, Сессия);
	Если Отказ Тогда
		Возврат;
	КонецЕсли;
	
	ПараметрыМетода = Новый Структура();
	ПараметрыМетода.Вставить("count", 9999999);
	
	Для Каждого ПараметрыАмортизацииЦБ Из FintoolidAmortisedmty Цикл 
		
		ПараметрыМетода.Вставить("Fintoolid", ПараметрыАмортизацииЦБ.Fintoolid);
		
		ДополнительныйКомментарийВЖурналеРегистрацииВызовов = "";
		Отказ			 = Ложь;
		ТекстОтказа		 = "";
		ПолученныеДанные =
			RuDataAPI.ДанныеМетода_V2_Bond_Amortizations(ПараметрыМетода, Отказ, ТекстОтказа,
				ЛогПолученныхДанных, Сессия, ОставитьЗаписьВЖурналеРегистрацииВызовов, ДополнительныйКомментарийВЖурналеРегистрацииВызовов);
		Если Отказ Или ЗначениеЗаполнено(ТекстОтказа) Тогда
			ВызватьИсключение ТекстОтказа;
		КонецЕсли;
		
		Для Каждого СтрокаДанных Из ПолученныеДанные Цикл
			
			ПараметрыМетода.Вставить("id",				 ПараметрыАмортизацииЦБ.isin);
			ПараметрыМетода.Вставить("date",			 СтрокаДанных.mty_date);
			ПараметрыМетода.Вставить("isCloseRegister",	 Истина);
			ПараметрыМетода.Вставить("isPercent",		 Ложь);
			
			ДатаИзмененияОстаточногоНоминала = ОбщегоНазначенияКлиентСервер.ПолучитьДатуИзJSON(СтрокаДанных.mty_date);
			
			ШаблонКомментария = "ISIN: [%1], на дату номинала: [%2]";
			ДополнительныйКомментарийВЖурналеРегистрацииВызовов = СтрШаблон(ШаблонКомментария, ПараметрыМетода.id, ПараметрыМетода.date);
			Отказ			 = Ложь;
			ТекстОтказа		 = "";
			ОстаточныйНоминал =
				RuDataAPI.ДанныеМетода_V2_Info_ResidualFaceValue(ПараметрыМетода, Отказ, ТекстОтказа,
					ЛогПолученныхДанных, Сессия, ОставитьЗаписьВЖурналеРегистрацииВызовов, ДополнительныйКомментарийВЖурналеРегистрацииВызовов);
			
			ОбновитьОстаточныйНоминал = Не Отказ И (Не ЗначениеЗаполнено(ТекстОтказа) Или СтрНайти(ТекстОтказа, ДопустимыйТекстОтказа) > 0);
			Если ОбновитьОстаточныйНоминал Тогда
				ОбновитьОстаточныйНоминалЦеннойБумаги(ПараметрыАмортизацииЦБ.ЦеннаяБумага, ДатаИзмененияОстаточногоНоминала, ОстаточныйНоминал);
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЦикла;
	
	Отказ			 = Ложь;
	ТекстОтказа		 = "";
	ВыйтиИзСервиса(Соединение, Отказ, ТекстОтказа);
	
	ОценкаПроизводительности.ЗакончитьЗамерВремени("RudataAPI.СозданиеОбновлениеОстаточнойАмортизацииЦенныхБумаг", ВремяНачалаФормирования,
		FintoolidAmortisedmty.Количество());
	
КонецПроцедуры

// Процедура - Создание обновление индексации номинала  ценных бумаг
//
Процедура СозданиеОбновлениеИндексацииНоминалаЦенныхБумаг() Экспорт
	
	Если ТестированиеVanessa.ЭтоТест() Тогда
		Возврат;
	КонецЕсли;
	
	ВремяНачалаФормирования = ОценкаПроизводительности.НачатьЗамерВремени();
	
	ИндексируемыеНоминалы = ИндексируемыеНоминалыЦенныхБумаг();
	КомментарийЗамера = "[" + ИндексируемыеНоминалы.Количество() + "] - строк данных получено";
	ВесЗамера = 0;
	Для Каждого ИндексируемыйНоминал Из ИндексируемыеНоминалы Цикл
		НоминалНовый = ИндексируемыйНоминал.currentfacevalue_nrd;
		Если НоминалНовый <> ИндексируемыйНоминал.facevalue Тогда
			КодЗагрузкиRuData = Формат(ИндексируемыйНоминал.fintoolid, "ЧГ=0");
			НоминалТекущий = РегистрыСведений.НоминалЦБ.НоминалЦеннойБумагиПоКодуRuData(КодЗагрузкиRuData);
			Если НоминалТекущий <> 0 И НоминалНовый <> НоминалТекущий Тогда
				РегистрыСведений.НоминалЦБ.УстановитьНоминалЦеннойБумагиПоКодуRuData(НоминалНовый, КодЗагрузкиRuData);
				ВесЗамера = ВесЗамера + 1;
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
	ОценкаПроизводительности.ЗакончитьЗамерВремени("RudataAPI.СозданиеОбновлениеИндексацииНоминалаЦенныхБумаг",
		ВремяНачалаФормирования, ВесЗамера, КомментарийЗамера);
	
КонецПроцедуры

// Процедура - Создание обновление купонов ценных бумаг
//
// Параметры:
//  КупонныеОблигации	 - ТаблицаЗначений	 - Таблица с колонками {fintoolid, isin, ЦеннаяБумага}
//
Процедура СозданиеОбновлениеКупоновЦенныхБумаг(КупонныеОблигации) Экспорт
	
	Если Не ЗначениеЗаполнено(КупонныеОблигации) Или ТестированиеVanessa.ЭтоТест() Тогда
		Возврат;
	КонецЕсли;
	
	ВремяНачалаФормирования = ОценкаПроизводительности.НачатьЗамерВремени();
	
	ИмяПараметраПериод = "ДатаВремяОбновленияДанных";
	ВходныеПараметры = Новый Структура();
	ВходныеПараметры.Вставить("eventTypes", ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве("CPN"));
	
	ТаблицаBondTimeTableCPN =
		ТаблицаСозданияОбновленияЦенныхБумаг("BondTimeTable", ИмяПараметраПериод, КупонныеОблигации, ВходныеПараметры);
	
	ПолученыДанные = ЗначениеЗаполнено(ТаблицаBondTimeTableCPN);
	Если ПолученыДанные Тогда
		ВесЗамера = ТаблицаBondTimeTableCPN.Количество();
	Иначе
		ВесЗамера = 0;
	КонецЕсли;
	
	ОценкаПроизводительности.ЗакончитьЗамерВремени("RudataAPI.ПолучениеКупоновЦенныхБумаг", ВремяНачалаФормирования, ВесЗамера);
	
	ВремяНачалаФормирования = ОценкаПроизводительности.НачатьЗамерВремени();
	
	Если ПолученыДанные Тогда
		ТаблицаBondTimeTableCPN.Индексы.Добавить("fintoolid");
		ЗаполнитьКупоныЦенныхБумаг(ТаблицаBondTimeTableCPN, КупонныеОблигации);
	КонецЕсли;
	
	ВесЗамера = КупонныеОблигации.Количество();
	
	ОценкаПроизводительности.ЗакончитьЗамерВремени("RudataAPI.ЗаполнениеКупоновЦенныхБумаг", ВремяНачалаФормирования, ВесЗамера);
	
КонецПроцедуры

// Функция возвращает статусы ЦБ, которые считаются актуальными
//
// Возвращаемое значение:
//	- Массив - Массив строк с названиями статусов актуальных бумаг
Функция СтатусыАктуальныхЦБ() Экспорт
	Статусы = Новый Массив;
	Статусы.Добавить("В обращении");
	Статусы.Добавить("Дефолт");
	Статусы.Добавить("Размещается");
	
	Возврат Статусы;
КонецФункции

// Функция возвращает статусы ЦБ, которые считаются актуальными в формате фильтра для запросов RuData,
// например: "'В обращении', 'Дефолт', 'Размещается'"
// Возвращаемое значение:
//   - Строка - в формате фильтра для запросов RuData
Функция ФильтрПоАктуальнымСтатусамЦБ() Экспорт
	СтрокаДляФильтра = "";
	Статусы = СтатусыАктуальныхЦБ();
	Для Каждого Статус Из Статусы Цикл
		Если Не ПустаяСтрока(СтрокаДляФильтра) Тогда
			СтрокаДляФильтра = СтрокаДляФильтра + ", ";
		КонецЕсли;
		СтрокаДляФильтра = СтрокаДляФильтра + "'" + Статус + "'";
	КонецЦикла;
	
	Возврат СтрокаДляФильтра;
КонецФункции

// Процедура - Обновить остаточный номинал ценной бумаги
//
// Параметры:
//  ЦеннаяБумага					 - СправочникСсылка.ЦенныеБумаги - Ценная бумага
//  ДатаИзмененияОстаточногоНоминала - Дата							 - Дата начала действия остаточного номинала
//  ОстаточныйНоминал				 - Число						 - Остаточный номинал
//
Процедура ОбновитьОстаточныйНоминалЦеннойБумаги(ЦеннаяБумага, ДатаИзмененияОстаточногоНоминала, ОстаточныйНоминал) Экспорт
	
	Если ЗначениеЗаполнено(ДатаИзмененияОстаточногоНоминала) И ТипЗнч(ДатаИзмененияОстаточногоНоминала) = Тип("Дата") Тогда
		НаборЗаписей = РегистрыСведений.НоминалЦБ.СоздатьНаборЗаписей();
		НаборЗаписей.Отбор.Период.Установить(ДатаИзмененияОстаточногоНоминала);
		НаборЗаписей.Отбор.ЦеннаяБумага.Установить(ЦеннаяБумага);
		
		НовЗапись = НаборЗаписей.Добавить();
		НовЗапись.Период		 = ДатаИзмененияОстаточногоНоминала;
		НовЗапись.ЦеннаяБумага	 = ЦеннаяБумага;
		НовЗапись.Сумма			 = ОстаточныйНоминал;
		НаборЗаписей.Записать();
	КонецЕсли;
	
КонецПроцедуры

// Процедура - Загрузить НКД
//
// Параметры:
//  Дата - Дата - Дата на которую требуется загрузить НКД
//  Isins - Массив - Массив ISIN ценных бумаг
//
Процедура ЗагрузитьНКД(Дата = Неопределено, Isins = Неопределено) Экспорт
	НачалоДняТекущаяДатаСеанса = НачалоДня(ТекущаяДатаСеанса());
	Если ЗначениеЗаполнено(Дата) Тогда
		ТекущаяДата = НачалоДня(Дата);
	Иначе
		ТекущаяДата = НачалоДняТекущаяДатаСеанса;
	КонецЕсли;
	Сутки = ОбщегоНазначенияПовтИсп.СекундВСутках();
	Пока ТекущаяДата < НачалоДняТекущаяДатаСеанса Цикл
		ОсновнойАлгоритмЗагрузкиНКД(ТекущаяДата, Isins);
		ТекущаяДата = ТекущаяДата + Сутки;
	КонецЦикла;
	ОсновнойАлгоритмЗагрузкиНКД(НачалоДняТекущаяДатаСеанса, Isins);
	
КонецПроцедуры

// Процедура загружает данные по обращаемости ЦБ с учетом заданных параметров
//
// Параметры:
//  ДатаВремяОбновленияДанных - Дата - Дата на которую загружается обращаемость
//  Isins - Строка - Строка со списоком Isins
//
Процедура ЗагрузитьДанныеПоОбращаемостиЦБ(ДатаВремяОбновленияДанных, Isins) Экспорт
	
	Сутки = ОбщегоНазначенияПовтИсп.СекундВСутках();
	
	Если ЗначениеЗаполнено(ДатаВремяОбновленияДанных) Тогда
		Если НачалоДня(ДатаВремяОбновленияДанных) = НачалоДня(ТекущаяДатаСеанса()) Тогда
			ДатаНачалаОбработки = НачалоДня(ДатаВремяОбновленияДанных) - Сутки ;
		Иначе
			ДатаНачалаОбработки = НачалоДня(ДатаВремяОбновленияДанных);
		КонецЕсли;
		НачалоДняТекущаяДатаСеанса = НачалоДня(ТекущаяДатаСеанса()) - Сутки;
	Иначе
		ДатаНачалаОбработки = НачалоДня(ТекущаяДатаСеанса()) - Сутки;
		НачалоДняТекущаяДатаСеанса = ДатаНачалаОбработки;
	КонецЕсли;
	
	Соединение = Неопределено;
	Токен = Неопределено;
	Сессия = Неопределено;
	
	СлужебныйВызов = Ложь;
	Отказ = Ложь;
	ТекстОтказа = "";
	ПодключитьсяКСервису(Соединение, Токен, Отказ, ТекстОтказа, СлужебныйВызов, Сессия);
	
	Если Не Отказ Тогда
		ПараметрыСессии = Новый Структура();
		ПараметрыСессии.Вставить("Отказ", Отказ);
		ПараметрыСессии.Вставить("ТекстОтказа", ТекстОтказа);
		ПараметрыСессии.Вставить("Сессия", Сессия);
		
		Пока ДатаНачалаОбработки <= НачалоДняТекущаяДатаСеанса Цикл
			ЗагрузитьДанныеПоОбращаемостиЦБНаДату(ПараметрыСессии, ДатаНачалаОбработки, Isins);
			ДатаНачалаОбработки = ДатаНачалаОбработки + Сутки;
		КонецЦикла;  
	КонецЕсли;
	
КонецПроцедуры

