Функция ПараметрыИсточника()
	
	Источник = ПланыВидовХарактеристик.ВнешниеИсточники.ЗагрузкаИзВнешнейAPIRuData;
	
	Если ТестированиеVanessa.ЭтоТест() Тогда
		Настройка = Неопределено;
	Иначе
		Настройка = ВнешниеДанные.ПолучитьПараметрыВнешнегоИсточника(Источник).Настройка;
	КонецЕсли;
	
	СтруктураНастроек = Новый Структура;
	
	Если ЗначениеЗаполнено(Настройка) Тогда
		СтруктураНастроек.Вставить("HTTPСервисАдресСервера"								, Настройка.HTTPСервисАдресСервера);
		СтруктураНастроек.Вставить("HTTPСервисПорт"										, Настройка.HTTPСервисПорт);
		СтруктураНастроек.Вставить("HTTPСервисТаймаут"									, Настройка.HTTPСервисТаймаут);
		СтруктураНастроек.Вставить("HTTPСервисЗащищенноеСоединение"						, Настройка.HTTPСервисЗащищенноеСоединение);
		СтруктураНастроек.Вставить("HTTPСервисПользователь"								, Настройка.HTTPСервисПользователь);
		СтруктураНастроек.Вставить("HTTPСервисПароль"									, Настройка.HTTPСервисПароль);
		СтруктураНастроек.Вставить("HTTPСервисАдресРесурсаАутентификации"				, Настройка.HTTPСервисАдресРесурсаАутентификации);
		СтруктураНастроек.Вставить("HTTPСервисАдресРесурса"								, Настройка.HTTPСервисАдресРесурса);
	Иначе
		СтруктураНастроек.Вставить("HTTPСервисАдресСервера"								, "ServerRuDataAPI");
		СтруктураНастроек.Вставить("HTTPСервисПорт"										, 0);
		СтруктураНастроек.Вставить("HTTPСервисТаймаут"									, 0);
		СтруктураНастроек.Вставить("HTTPСервисЗащищенноеСоединение"						, Истина);
		СтруктураНастроек.Вставить("HTTPСервисПользователь"								, "");
		СтруктураНастроек.Вставить("HTTPСервисПароль"									, "");
		СтруктураНастроек.Вставить("HTTPСервисАдресРесурсаАутентификации"				, "/v2/Account/Login");
		СтруктураНастроек.Вставить("HTTPСервисАдресРесурса"								, "/v2");
	КонецЕсли;
	
	СтруктураНастроек.Вставить("ПроксиСерверАдрес",			 ОбщегоНазначенияПовтИсп.ЗначениеГлобальногоПараметра("ПроксиСерверАдрес"));
	СтруктураНастроек.Вставить("ПроксиСерверПорт",			 ОбщегоНазначенияПовтИсп.ЗначениеГлобальногоПараметра("ПроксиСерверПорт", 3128));
	СтруктураНастроек.Вставить("ПроксиСерверИспользовать",
		ОбщегоНазначенияПовтИсп.ЗначениеГлобальногоПараметра("ПроксиСерверИспользовать", Ложь));
	
	СтруктураНастроек.Вставить("ИмяИсточника"										, Источник.Наименование);
	
	Возврат СтруктураНастроек;
	
КонецФункции

Функция API_ВыполнитьЗапрос(ИмяМетода, ВходныеПараметры, НастройкиСоединения, URL, СтруктураДляJSON, ДополнительныеПараметры, Сессия)
	
	ОписаниеВызова = РегистрыСведений.ЖурналРегистрацииВызовов.НовоеОписаниеВызова(
		"URL = " + URL,
		"ОбщийМодуль.RuDataAPI." + "API_" + ИмяМетода + ".Page" + ВходныеПараметры.НомерПачки);
	РегистрыСведений.ЖурналРегистрацииВызовов.ЗафиксироватьНачало(ОписаниеВызова);
	
	Комментарий = "";
	Если ВходныеПараметры.Свойство("Комментарий") Тогда
		Комментарий = ВходныеПараметры.Комментарий;
	КонецЕсли;
	
	Accept = "Accept";
	Если Сессия = Неопределено И ДополнительныеПараметры.Свойство("Заголовки") Тогда
		Заголовки = Неопределено;
		ЕстьЗаголовки = ДополнительныеПараметры.Свойство("Заголовки", Заголовки);
		Если ЕстьЗаголовки И Не Заголовки = Неопределено И Заголовки.Получить(Accept) <> Неопределено Тогда
			Сессия = КоннекторHTTP.СоздатьСессию();
			Сессия.Заголовки.Вставить(Accept, ДополнительныеПараметры.Заголовки[Accept]);
		КонецЕсли;
	КонецЕсли;
	
	Попытка
		Если ТестированиеVanessa.ЭтоТест() Тогда
			СтруктураВозвратаПоУмолчанию = Новый Массив;
			HTTPОтвет = ИмитаторHTTP(URL, СтруктураДляJSON, СтруктураВозвратаПоУмолчанию);
		Иначе
			HTTPОтвет = КоннекторHTTP.PostJson(URL, СтруктураДляJSON, ДополнительныеПараметры, Сессия);
		КонецЕсли;
	Исключение
		ОписаниеОшибки = ОбработкаОшибок.КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
	КонецПопытки;
	
	ИмяСобытия = НастройкиСоединения.ИмяИсточника + ": " + ИмяМетода;
	Если ЗначениеЗаполнено(ОписаниеОшибки) Тогда
		ОписаниеОшибки = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку("Событие '%1'; подробности: '%2'",
			ИмяСобытия,
			ОписаниеОшибки);
		РегистрыСведений.ЖурналРегистрацииВызовов.ЗафиксироватьОшибку(ОписаниеВызова, ОписаниеОшибки, Комментарий);
		Возврат Неопределено;
	КонецЕсли;
	
	Если Не HTTPОтвет = Неопределено Тогда
		Попытка
			ОписаниеОшибки = HTTPОтвет.Error;
			Если ЗначениеЗаполнено(ОписаниеОшибки) Тогда
				ОписаниеОшибки = "{Ошибку возвратил RuData}: " + ОписаниеОшибки;
				ОписаниеОшибки = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку("Событие '%1'; подробности: '%2'",
					ИмяСобытия,
					ОписаниеОшибки);
				РегистрыСведений.ЖурналРегистрацииВызовов.ЗафиксироватьОшибку(ОписаниеВызова, ОписаниеОшибки, Комментарий);
				Возврат Неопределено;
			КонецЕсли;
		Исключение
			ОписаниеОшибки = "";
		КонецПопытки;
	КонецЕсли;
	
	РегистрыСведений.ЖурналРегистрацииВызовов.ЗафиксироватьОкончание(ОписаниеВызова, Комментарий);
	Возврат HTTPОтвет;
	
КонецФункции

Функция API_AccountLogin(НастройкиСоединения, ОписаниеОшибки, Сессия)
	
	ИмяМетода = "AccountLogin";
	
	URL = "https://" + НастройкиСоединения.HTTPСервисАдресСервера + НастройкиСоединения.HTTPСервисАдресРесурсаАутентификации;
	
	СтруктураДляJSON = Новый Структура();
	СтруктураДляJSON.Вставить("Login", НастройкиСоединения.HTTPСервисПользователь);
	СтруктураДляJSON.Вставить("Password", НастройкиСоединения.HTTPСервисПароль);
	
	Заголовки = Новый Соответствие();
	Заголовки.Вставить("Accept", "*/*");
	Заголовки.Вставить("Content-Type", "application/json-patch+json");
	
	ДополнительныеПараметры = Новый Структура();
	ДополнительныеПараметры.Вставить("Заголовки", Заголовки);
	Если НастройкиСоединения.ПроксиСерверИспользовать Тогда
		ПроксиСервер = Новый ИнтернетПрокси;
		ПроксиСервер.Установить("https", НастройкиСоединения.ПроксиСерверАдрес, НастройкиСоединения.ПроксиСерверПорт);
		ДополнительныеПараметры.Вставить("Прокси", ПроксиСервер);
	КонецЕсли;
	
	// --> ЖурналРегистрацииВызовов
	ОписаниеВызова = РегистрыСведений.ЖурналРегистрацииВызовов.НовоеОписаниеВызова(
		"URL = " + URL,
		"ОбщийМодуль.RuDataAPI." + "API_AccountLogin");
	РегистрыСведений.ЖурналРегистрацииВызовов.ЗафиксироватьНачало(ОписаниеВызова);
	// <--
	
	Попытка
		Если ТестированиеVanessa.ЭтоТест() Тогда
			СтруктураВозвратаПоУмолчанию = Новый Соответствие;
			СтруктураВозвратаПоУмолчанию.Вставить("token", "Vanessa");
			HTTPОтвет = ТестированиеVanessa.ТестовыеДанные("RuDataAPI.API_AccountLogin", СтруктураВозвратаПоУмолчанию);
		Иначе
			HTTPОтвет = КоннекторHTTP.PostJson(URL, СтруктураДляJSON, ДополнительныеПараметры, Сессия);
		КонецЕсли;
	Исключение
		ОписаниеОшибки = ОбработкаОшибок.КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
	КонецПопытки;
	
	ИмяСобытия = НастройкиСоединения.ИмяИсточника + ": " + ИмяМетода;
	Если ЗначениеЗаполнено(ОписаниеОшибки) Тогда // Описание ошибки
		ОписаниеОшибки = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку("Событие '%1'; подробности: '%2'",
			ИмяСобытия,
			ОписаниеОшибки);
		РегистрыСведений.ЖурналРегистрацииВызовов.ЗафиксироватьОшибку(ОписаниеВызова, ОписаниеОшибки); // <--> ЖурналРегистрацииВызовов
		Возврат "";
	КонецЕсли;
	
	Токен = HTTPОтвет["token"];
	
	Если Токен = Неопределено Тогда
		ОписаниеОшибки = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку("Событие '%1'; Ошибка '%2'; подробности: '%3'",
			ИмяСобытия,
			"Токен не может быть возвращен",
			"Неопределенная ошибка");
		РегистрыСведений.ЖурналРегистрацииВызовов.ЗафиксироватьОшибку(ОписаниеВызова, ОписаниеОшибки); // <--> ЖурналРегистрацииВызовов
		Возврат "";
	КонецЕсли;
	
	РегистрыСведений.ЖурналРегистрацииВызовов.ЗафиксироватьОкончание(ОписаниеВызова);
	Возврат "Bearer " + Токен;
	
КонецФункции

// BSLLS:CognitiveComplexity-off
// BSLLS:CyclomaticComplexity-off
// BSLLS:NestedStatements-off
Функция API_ПолучитьОтветМетода(ИмяМетода, ПутьКМетоду, ВходныеПараметры, НастройкиСоединения, ОписаниеОшибки, Сессия)
	// Поддерживаемые методы RuData API:
	//	 DictionaryCountries		 - https://docs.efir-net.ru/dh2/#/Dictionary/Countries
	//	 InfoCurrencies				 - https://docs.efir-net.ru/dh2/#/Info/Currencies
	//	 InfoSecurities				 - https://docs.efir-net.ru/dh2/#/Info/Securities
	//	 InfoFintoolReferenceData	 - https://docs.efir-net.ru/dh2/#/Info/FintoolReferenceData
	//	 NsdCommonData				 - https://docs.efir-net.ru/dh2/#/Nsd/CommonData
	//	 EmitentList				 - https://docs.efir-net.ru/dh2/#/Info/Emitent/List
	//	 BondTimeTable				 - https://docs.efir-net.ru/dh2/#/Bond/TimeTable
	//	 BondAmortizations			 - https://docs.efir-net.ru/dh2/#/Bond/Amortizations 
	//									(не путать с https://docs.efir-net.ru/dh2/#/Bond/_fintoolId__Amortizations)
	//	 InfoEmitentCategoryValue	 - https://docs.efir-net.ru/dh2/#/Info/emitent-category-value
	//	 InfoEmitentClassification	 - https://docs.efir-net.ru/dh2/#/Info/EmitentClassification
	//	 InfoFintoolClassification	 - https://docs.efir-net.ru/dh2/#/Info/FintoolClassification
	//	 InfoFintoolReferenceData_nominaltype	 - https://docs.efir-net.ru/dh2/#/Info/FintoolReferenceData
	//	 InfoFintoolCategoryValue	 - https://docs.efir-net.ru/dh2/#/Info/fintool-category-value
	
	Таймаут = 30; // Таймаут по-умолчанию ожидания ответа от RuData API = 30 секунд
	
	ИмяПараметраFilter		 = "filter";
	ИмяПараметраFields		 = "fields";
	ИмяПараметраPageNum		 = "pageNum";
	ИмяПараметраPageSize	 = "pageSize";
	
	Токен = ТокенАвторизации();
	Если Не ЗначениеЗаполнено(Токен) Тогда // нет возможности дальше продолжать
		Возврат Неопределено;
	КонецЕсли;
	
	URL = "https://" + НастройкиСоединения.HTTPСервисАдресСервера + НастройкиСоединения.HTTPСервисАдресРесурса + ПутьКМетоду;
	
	СтруктураДляJSON = Новый Структура();
	Если ИмяМетода = "InfoSecurities" Тогда
		Если ВходныеПараметры.Свойство("ФильтрСтатусовЦБ") И ЗначениеЗаполнено(ВходныеПараметры.ФильтрСтатусовЦБ) Тогда
			ФильтрСтатусовЦБ = ВходныеПараметры.ФильтрСтатусовЦБ;
		Иначе
			ФильтрСтатусовЦБ = Неопределено;
		КонецЕсли;
		filter = InfoSecurities_Фильтр(ВходныеПараметры);
		СтруктураДляJSON.Вставить(ИмяПараметраFilter, filter);
		СтруктураДляJSON.Вставить(ИмяПараметраPageNum, ВходныеПараметры.pageNum);
		СтруктураДляJSON.Вставить(ИмяПараметраPageSize, ВходныеПараметры.pageSize);	
		ВходныеПараметры.Вставить("Комментарий", filter);
	КонецЕсли;
	Если ИмяМетода = "InfoFintoolReferenceData" Тогда
		filter = InfoFintoolReferenceData_Фильтр(ВходныеПараметры.ДатаВремяОбновленияДанных, ВходныеПараметры.fintoolids);
		СтруктураДляJSON.Вставить(ИмяПараметраFilter, filter);
		pager = Новый Структура;
		pager.Вставить("page", ВходныеПараметры.pageNum);
		pager.Вставить("size", ВходныеПараметры.pageSize);
		СтруктураДляJSON.Вставить("pager", pager);
		ТолькоFintoolid = ВходныеПараметры.Свойство("ТолькоFintoolid") И ВходныеПараметры.ТолькоFintoolid;
		fields = InfoFintoolReferenceDataРеквизиты(ТолькоFintoolid);
		СтруктураДляJSON.Вставить(ИмяПараметраFields, fields);
		sort = Новый Структура;
		sort.Вставить("field", "fintoolid");
		sort.Вставить("ascending", Истина);
		СтруктураДляJSON.Вставить("sort", sort);
	КонецЕсли;
	Если ИмяМетода = "NsdCommonData" Тогда
		filter = NsdCommonData_Фильтр(ВходныеПараметры);
		СтруктураДляJSON.Вставить(ИмяПараметраFilter, filter);
		СтруктураДляJSON.Вставить(ИмяПараметраPageNum, ВходныеПараметры.pageNum);
		СтруктураДляJSON.Вставить(ИмяПараметраPageSize, ВходныеПараметры.pageSize);
	КонецЕсли;
	Если ИмяМетода = "EmitentList" Тогда
		filter = EmitentList_Фильтр(ВходныеПараметры.ДатаВремяОбновленияДанных, ВходныеПараметры.fininstids);
		СтруктураДляJSON.Вставить(ИмяПараметраFilter, filter);
		СтруктураДляJSON.Вставить("inn_as_string", Истина);
		СтруктураДляJSON.Вставить(ИмяПараметраPageNum, ВходныеПараметры.pageNum);
		СтруктураДляJSON.Вставить(ИмяПараметраPageSize, ВходныеПараметры.pageSize);
	КонецЕсли;
	Если ИмяМетода = "InfoCurrencies" Тогда
		filter = "iso_number is not null";
		МаксимальноеКоличествоСтран = 300;
		СтруктураДляJSON.Вставить(ИмяПараметраFilter, filter);
		СтруктураДляJSON.Вставить(ИмяПараметраPageNum, 1);
		СтруктураДляJSON.Вставить(ИмяПараметраPageSize, МаксимальноеКоличествоСтран);
		СтруктураДляJSON.Вставить("withKKV", False);
	КонецЕсли;
	Если ИмяМетода = "BondTimeTable" Тогда
		Таймаут = 60; // Увеличим таймаут, так как pageSize = 1000 элементов вместо 100
		СтруктураДляJSON.Вставить("ids", ВходныеПараметры.ids);
		СтруктураДляJSON.Вставить("eventTypes", ВходныеПараметры.eventTypes);
		fields = BondTimeTableРеквизиты();
		СтруктураДляJSON.Вставить(ИмяПараметраFields, fields);
		СтруктураДляJSON.Вставить("isShowDefault", Ложь);
		СтруктураДляJSON.Вставить("sortDesc", Ложь);
		СтруктураДляJSON.Вставить(ИмяПараметраPageNum, ВходныеПараметры.pageNum);
		СтруктураДляJSON.Вставить(ИмяПараметраPageSize, ВходныеПараметры.pageSize);
	КонецЕсли;
	Если ИмяМетода = "BondAmortizations" Тогда
		МаксимальноеКоличествоЗаписей = 100;
		filter = BondAmortizations_Фильтр(ВходныеПараметры);
		СтруктураДляJSON.Вставить(ИмяПараметраFilter, filter);
		СтруктураДляJSON.Вставить(ИмяПараметраPageNum, ВходныеПараметры.pageNum);
		СтруктураДляJSON.Вставить(ИмяПараметраPageSize, МаксимальноеКоличествоЗаписей);
	КонецЕсли;
	Если ИмяМетода = "InfoEmitentCategoryValue" Тогда
		МаксимальноеКоличествоЗаписей = 100;
		СтруктураДляJSON.Вставить("filterCategory", ВходныеПараметры.filter);
		СтруктураДляJSON.Вставить(ИмяПараметраPageNum, ВходныеПараметры.НомерПачки);
		СтруктураДляJSON.Вставить(ИмяПараметраPageSize, МаксимальноеКоличествоЗаписей);
		СтруктураДляJSON.Вставить("onlyEmitentsWithCategory", Истина);
	КонецЕсли;
	Если ИмяМетода = "InfoEmitentClassification" Тогда
		МаксимальноеКоличествоЗаписей = 100;
		СтруктураДляJSON.Вставить(ИмяПараметраFilter, ВходныеПараметры.filter);
		СтруктураДляJSON.Вставить(ИмяПараметраPageNum, ВходныеПараметры.НомерПачки);
		СтруктураДляJSON.Вставить(ИмяПараметраPageSize, МаксимальноеКоличествоЗаписей);
		СтруктураДляJSON.Вставить("dateFrom", "2000-01-01");
		СтруктураДляJSON.Вставить("dateTo", Формат(ВходныеПараметры.ДатаВремяОбновленияДанных, "ДФ=yyyy-MM-dd"));
	КонецЕсли;
	Если ИмяМетода = "InfoFintoolClassification" Тогда
		МаксимальноеКоличествоЗаписей = 100;
		filter = InfoFintoolClassification_Фильтр(ВходныеПараметры);
		СтруктураДляJSON.Вставить(ИмяПараметраFilter, filter);
		СтруктураДляJSON.Вставить(ИмяПараметраPageNum, ВходныеПараметры.PageNum);
		СтруктураДляJSON.Вставить(ИмяПараметраPageSize, МаксимальноеКоличествоЗаписей);
		СтруктураДляJSON.Вставить("dateFrom", "1900-01-01");
		СтруктураДляJSON.Вставить("dateTo", "2050-01-01");
	КонецЕсли;
	Если ИмяМетода = "InfoFintoolReferenceData_nominaltype" Тогда
		МаксимальноеКоличествоЗаписей = 100;
		СтруктураДляJSON.Вставить(ИмяПараметраFilter, ВходныеПараметры.filter);
		СтруктураДляJSON.Вставить(ИмяПараметраFields, ВходныеПараметры.fields);
		pager = Новый Структура;
		pager.Вставить("page", ВходныеПараметры.НомерПачки);
		pager.Вставить("size", МаксимальноеКоличествоЗаписей);
		СтруктураДляJSON.Вставить("pager", pager);
	КонецЕсли;
	Если ИмяМетода = "InfoFintoolCategoryValue" Тогда
		МаксимальноеКоличествоЗаписей = 100;
		СтруктураДляJSON.Вставить("fintoolIds", ВходныеПараметры.fintoolids);
		СтруктураДляJSON.Вставить("filterOnlySpecifiedCategory", ВходныеПараметры.filterOnlySpecifiedCategory);
		СтруктураДляJSON.Вставить("onlyFintoolsWithCategory", ВходныеПараметры.onlyFintoolsWithCategory);
		СтруктураДляJSON.Вставить(ИмяПараметраPageNum, ВходныеПараметры.pageNum);
		СтруктураДляJSON.Вставить(ИмяПараметраPageSize, ВходныеПараметры.pageSize);
	КонецЕсли;
	
	Заголовки = Новый Соответствие();
	ЭтоМетодJSON = ИмяМетода = "DictionaryCountries"
		Или ИмяМетода = "InfoCurrencies"
		Или ИмяМетода = "BondTimeTable"
		Или ИмяМетода = "BondAmortizations"
		Или ИмяМетода = "InfoEmitentCategoryValue"
		Или ИмяМетода = "InfoEmitentClassification"
		Или ИмяМетода = "InfoFintoolClassification"
		Или ИмяМетода = "InfoFintoolCategoryValue";
		
	Если ЭтоМетодJSON Тогда
		Заголовки.Вставить("Accept", "application/json");
		Заголовки.Вставить("Content-Type", "application/json");
	Иначе
		Заголовки.Вставить("Accept", "*/*");
		Заголовки.Вставить("Content-Type", "application/json-patch+json");
	КонецЕсли;
	Заголовки.Вставить("Authorization", Токен);
	
	ДополнительныеПараметры = Новый Структура();
	ДополнительныеПараметры.Вставить("Заголовки", Заголовки);
	ДополнительныеПараметры.Вставить("Таймаут", Таймаут);
	ДополнительныеПараметры.Вставить("ПараметрыПреобразованияJSON", Новый Структура("ПрочитатьВСоответствие", Ложь));
	Если НастройкиСоединения.ПроксиСерверИспользовать Тогда
		ПроксиСервер = Новый ИнтернетПрокси;
		ПроксиСервер.Установить("https", НастройкиСоединения.ПроксиСерверАдрес, НастройкиСоединения.ПроксиСерверПорт);
		ДополнительныеПараметры.Вставить("Прокси", ПроксиСервер);
	КонецЕсли;
	
	HTTPОтвет = API_ВыполнитьЗапрос(ИмяМетода, ВходныеПараметры, НастройкиСоединения, URL, СтруктураДляJSON, ДополнительныеПараметры, Сессия);
	
	Возврат HTTPОтвет;
	
КонецФункции
// BSLLS:LatinAndCyrillicSymbolInWord-off

#Область ЗагрузкаКотировок_МетодыAPI_ВспомогательныеПроцедуры

Функция ПолучитьДанныеИзСервиса_V2(АдресСервиса, ПараметрыURLЗапроса, Отказ, ТекстОтказа, ЛогПолученныхДанных, // BSLLS:NumberOfParams-off
	СлужебныйВызов, Сессия = Неопределено, ОставитьЗаписьВЖурналеРегистрацииВызовов = Истина, Комментарий = "")
	Перем СчетчикЗапросов;
	Перем ДатаНачалаСерииЗапросов;
	
	Перем Соединение;
	Перем Токен;
	
	ПолученныеДанные			 = Новый Массив;
	ПолученныеДанныеНеопределено = Новый Массив;
	
	Число100					 = 100;
	МаксимальноеЧислоЗапросов	 = 5;
	КодОтвета400				 = 400;
	КодОтвета403				 = 403;
	КодОтветаУспех				 = 200;
	
	Если ПараметрыURLЗапроса.Свойство("dateFrom") Тогда
		Комментарий = ПараметрыURLЗапроса.dateFrom + ?(Комментарий = "", "", "; " + Комментарий);
	КонецЕсли;
	
	// --> ЖурналРегистрацииВызовов
	Если ОставитьЗаписьВЖурналеРегистрацииВызовов Тогда
		ОписаниеВызова = РегистрыСведений.ЖурналРегистрацииВызовов.НовоеОписаниеВызова(
			"URL = " + АдресСервиса,
			"ОбщийМодуль.RuDataAPI.ПолучитьДанныеИзСервиса_V2");
		РегистрыСведений.ЖурналРегистрацииВызовов.ЗафиксироватьНачало(ОписаниеВызова);
	Иначе
		ОписаниеВызова = Неопределено;
	КонецЕсли;
	// <--
	
	Если Сессия = Неопределено Тогда
		ПодключитьсяКСервису(Соединение, Токен, Отказ, ТекстОтказа, СлужебныйВызов, Сессия);
	Иначе
		Токен = ПараметрыСеанса.ТокенRuDataAPI;
		Соединение = КешСоединения(Сессия);
	КонецЕсли;
	
	Если Отказ Тогда
		ПолучитьДанныеИзСервиса_V2_ЗафиксироватьОшибку(ОписаниеВызова, ТекстОтказа, Комментарий, АдресСервиса);
		Возврат ПолученныеДанныеНеопределено;
	КонецЕсли;
	
	ПолучениеДанных = Истина;
	ПолученоСтрок = 0;
	counter = 0;
	Если ПараметрыURLЗапроса.Свойство("pageNum") = Истина Тогда
		pageNum = ПараметрыURLЗапроса.pageNum;
	Иначе
		pageNum = 1;
	КонецЕсли;
	Страницы = ПараметрыURLЗапроса.Свойство("pageNum") = Истина И ПараметрыURLЗапроса.Свойство("pageSize") = Истина;
	
	Пока ПолучениеДанных = Истина И pageNum < Число100 Цикл
		
		// ASP-108335 Проверка, что бы не было больше 5 запросов в секунду.
		Если Не ЗначениеЗаполнено(ДатаНачалаСерииЗапросов) Или Не ЗначениеЗаполнено(СчетчикЗапросов) Тогда
			ДатаНачалаСерииЗапросов = ТекущаяДатаСеанса();
			СчетчикЗапросов = 0;
		КонецЕсли;
		
		Если СчетчикЗапросов = МаксимальноеЧислоЗапросов Тогда
			КонДата = ДатаНачалаСерииЗапросов + 1;
			Пока ТекущаяДатаСеанса() < КонДата Цикл
				ВременнаяПеременная = 1; // BSLLS:UnusedLocalVariable-off
			КонецЦикла;
			СчетчикЗапросов = 1;
		Иначе
			СчетчикЗапросов = СчетчикЗапросов + 1;
		КонецЕсли;
		// }
		
		Если Страницы Тогда
			ПараметрыURLЗапроса.pageNum = pageNum;
		КонецЕсли;
		
		// Получаем данные из сервиса
		КодСостояния = 0;
		СтрокаОтвета = "";
		
		Попытка
			Ответ = Соединение.ОтправитьДляОбработки(
				HTTPЗапросМетодPOST_V2(Токен, АдресСервиса, ПараметрыURLЗапроса, ЛогПолученныхДанных));
			Если Ответ.КодСостояния = КодОтвета403 Тогда // Если токен просрочен, пробуем переподключиться.
				
				ВыйтиИзСервиса(Соединение, Отказ, ТекстОтказа);
				Сессия = Неопределено;
				ПодключитьсяКСервису(Соединение, Токен, Отказ, ТекстОтказа, СлужебныйВызов, Сессия);
				Если Отказ Тогда
					ПолучитьДанныеИзСервиса_V2_ЗафиксироватьОшибку(ОписаниеВызова, ТекстОтказа, Комментарий, АдресСервиса);
					Возврат ПолученныеДанныеНеопределено;
				КонецЕсли;
				
				Ответ = Соединение.ОтправитьДляОбработки(
					HTTPЗапросМетодPOST_V2(Токен, АдресСервиса, ПараметрыURLЗапроса, ЛогПолученныхДанных));
			КонецЕсли;
			
			// Получаем строку с ответом
			Если ТипЗнч(Ответ) = Тип("HTTPОтвет") Тогда
				КодСостояния	= Ответ.КодСостояния;
				СтрокаОтвета	= Ответ.ПолучитьТелоКакСтроку();
			ИначеЕсли ТипЗнч(Ответ) = Тип("ТекстовыйДокумент") Тогда
				СтрокаОтвета	= Ответ.ПолучитьТекст();
			Иначе
				СтрокаОтвета	= "";
			КонецЕсли;
			
		Исключение
			ТекстОтказа = СтрШаблон(
				НСтр("ru='Не удалось получить данные из сервиса %1. Техническая информация: %2'"), АдресСервиса, ОписаниеОшибки());
			Отказ 	= Истина;
			ПолучитьДанныеИзСервиса_V2_ЗафиксироватьОшибку(ОписаниеВызова, ТекстОтказа, Комментарий, АдресСервиса);
			Возврат ПолученныеДанные;
		КонецПопытки;
		
		// Сохраняем полученные даные в логе
		Если ТипЗнч(ЛогПолученныхДанных) = Тип("ТекстовыйДокумент") Тогда
			ЛогПолученныхДанных.ДобавитьСтроку("Ответ:");
			СтрокаЛога = СтрЗаменить(СтрокаОтвета, "}", "}" + Символы.ПС);
			ЛогПолученныхДанных.ДобавитьСтроку(СтрокаЛога);
		КонецЕсли;
		
		Если КодСостояния = КодОтвета400 И СтрНайти(СтрокаОтвета, "Нет данных по инструменту") > 0 Тогда
			ПолучитьДанныеИзСервиса_V2_ЗафиксироватьОшибку(ОписаниеВызова,
				"Нет данных по инструменту", Комментарий, АдресСервиса);
			Возврат ПолученныеДанные;
		КонецЕсли;
		
		Если Не Ответ.КодСостояния = КодОтветаУспех Тогда
			ТекстОтказа = СтрШаблон(НСтр("ru='Не удалось получить данные из сервиса %1. Код ошибки: %2.'"),
				АдресСервиса, ОписаниеПоКодуОтвета(Ответ.КодСостояния));
			Отказ 	= Истина;
			ПолучитьДанныеИзСервиса_V2_ЗафиксироватьОшибку(ОписаниеВызова, ТекстОтказа, Комментарий, АдресСервиса);
			Возврат ПолученныеДанные;
		КонецЕсли;
		
		Если ЗначениеЗаполнено(СтрокаОтвета) Тогда
			
			Попытка
				ЧтениеJSON = Новый ЧтениеJSON;
				ЧтениеJSON.УстановитьСтроку(СтрокаОтвета);
				мПолученныеДанные = ПрочитатьJSON(ЧтениеJSON);
				ЧтениеJSON.Закрыть();
			Исключение
				ТекстОтказа = СтрШаблон(НСтр("ru='Не удалось получить данные из сервиса %1. Техническая информация: %2'"),
					АдресСервиса, ОписаниеОшибки());
				Отказ 	= Истина;
				ПолучитьДанныеИзСервиса_V2_ЗафиксироватьОшибку(ОписаниеВызова, ТекстОтказа, Комментарий, АдресСервиса);
				Возврат ПолученныеДанные;
			КонецПопытки;
			
			Если ТипЗнч(мПолученныеДанные) = Тип("Структура") Тогда
				
				ПолученныеДанные.Добавить(мПолученныеДанные);
				ПолученоСтрок = ПолученоСтрок + 1;
				Если Страницы И counter = 0 И мПолученныеДанные.Свойство("counter") Тогда
					counter = мПолученныеДанные.counter;
				КонецЕсли;
				
			ИначеЕсли ТипЗнч(мПолученныеДанные) = Тип("Массив") Тогда
				
				Для Каждого Значение Из мПолученныеДанные Цикл
					ПолученныеДанные.Добавить(Значение);
					ПолученоСтрок = ПолученоСтрок + 1;
					Если Страницы И counter = 0 И Значение.Свойство("counter") Тогда
						counter = Значение.counter;
					КонецЕсли;
				КонецЦикла;
				
			ИначеЕсли ТипЗнч(мПолученныеДанные) = Тип("Соответствие") Тогда
				ПолученныеДанные.Добавить(мПолученныеДанные);
			Иначе
				ТекстОтказа = СтрШаблон(НСтр("ru='Не удалось получить данные из сервиса %1. Тип данных: %2 не поддерживается'"),
					АдресСервиса, ТипЗнч(мПолученныеДанные));
				Отказ 	= Истина;
				ПолучитьДанныеИзСервиса_V2_ЗафиксироватьОшибку(ОписаниеВызова, ТекстОтказа, Комментарий, АдресСервиса);
				Возврат ПолученныеДанные;
			КонецЕсли;
			
		КонецЕсли;
		
		Если Страницы И counter > ПолученоСтрок Тогда
			ПолучениеДанных = Истина;
		Иначе
			ПолучениеДанных = Ложь;
		КонецЕсли;
		
		pageNum = pageNum + 1;
		
	КонецЦикла;
	
	Если ОставитьЗаписьВЖурналеРегистрацииВызовов Тогда
		РегистрыСведений.ЖурналРегистрацииВызовов.ЗафиксироватьОкончание(ОписаниеВызова, Комментарий);
	КонецЕсли;
	
	Возврат ПолученныеДанные;
	
КонецФункции

Процедура ПолучитьДанныеИзСервиса_V2_ЗафиксироватьОшибку(ОписаниеВызова, ТекстОтказа, Комментарий, АдресСервиса)
	
	Если ОписаниеВызова = Неопределено Тогда
		ОписаниеВызова = РегистрыСведений.ЖурналРегистрацииВызовов.НовоеОписаниеВызова(
			"URL = " + АдресСервиса,
			"ОбщийМодуль.RuDataAPI.ПолучитьДанныеИзСервиса_V2");
		РегистрыСведений.ЖурналРегистрацииВызовов.ЗафиксироватьНачало(ОписаниеВызова);
	КонецЕсли;
	РегистрыСведений.ЖурналРегистрацииВызовов.ЗафиксироватьОшибку(ОписаниеВызова, ТекстОтказа, Комментарий);
	
КонецПроцедуры

