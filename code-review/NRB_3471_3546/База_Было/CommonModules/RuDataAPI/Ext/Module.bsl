Функция НовыеВходныеПараметрыГруппы(НомерПачки, ДатаВремяОбновленияДанных, ВходящиеИдентификаторы, 
									ФильтрСтатусовЦБ = Неопределено, ИгнорируемыйКлюч = Неопределено)
	
	fintoolids 	= ВходящиеИдентификаторы.fintoolids;
	nrdcodes 	= ВходящиеИдентификаторы.nrdcodes;
	fininstids 	= ВходящиеИдентификаторы.fininstids;
	isins 		= ВходящиеИдентификаторы.isins;
	ids 		= ВходящиеИдентификаторы.ids;
	
	МаксимальноеКоличествоСтраниц = ОбщегоНазначенияПовтИсп.ЗначениеГлобальногоПараметра("101.МаксимальноеКоличествоСтраниц", 10000);
	ЧисловыеРеквизиты = ЧисловыеРеквизитыТаблицRuDataAPI();
	
	Параметры = Новый Структура;
	ВставитьЭлементСтруктуры(Параметры, ИгнорируемыйКлюч, "НомерПачки"					, НомерПачки);
	ВставитьЭлементСтруктуры(Параметры, ИгнорируемыйКлюч, "ДатаВремяОбновленияДанных"	, ДатаВремяОбновленияДанных);
	ВставитьЭлементСтруктуры(Параметры, ИгнорируемыйКлюч, "МаксимальноеКоличествоСтраниц", МаксимальноеКоличествоСтраниц);
	ВставитьЭлементСтруктуры(Параметры, ИгнорируемыйКлюч, "ЧисловыеРеквизиты"			, ЧисловыеРеквизиты);
	ВставитьЭлементСтруктуры(Параметры, ИгнорируемыйКлюч, "fintoolids"					, ?(Не ЗначениеЗаполнено(fintoolids), 	Новый Массив, fintoolids));
	ВставитьЭлементСтруктуры(Параметры, ИгнорируемыйКлюч, "nrdcodes"						, ?(Не ЗначениеЗаполнено(nrdcodes), 	Новый Массив, nrdcodes));
	ВставитьЭлементСтруктуры(Параметры, ИгнорируемыйКлюч, "fininstids"					, ?(Не ЗначениеЗаполнено(fininstids), 	Новый Массив, fininstids));
	ВставитьЭлементСтруктуры(Параметры, ИгнорируемыйКлюч, "isins"						, ?(Не ЗначениеЗаполнено(isins), 		Новый Массив, isins));
	ВставитьЭлементСтруктуры(Параметры, ИгнорируемыйКлюч, "ids"							, ?(Не ЗначениеЗаполнено(ids), 			Новый Массив, ids));
	ВставитьЭлементСтруктуры(Параметры, ИгнорируемыйКлюч, "ФильтрСтатусовЦБ"				, ФильтрСтатусовЦБ);
	
	Возврат Параметры;
КонецФункции

Процедура ВставитьЭлементСтруктуры(Структура, ИгнорируемыйКлюч, Ключ, Значение)
	Если Ключ <> ИгнорируемыйКлюч Тогда
		Структура.Вставить(Ключ, Значение);
	КонецЕсли;
КонецПроцедуры

Функция НовыеВходящиеИдентификаторы()
	Возврат Новый Структура("fintoolids, nrdcodes, fininstids, isins, ids");
КонецФункции

Функция ПоследнийИндексДляЦикла(Параметры, ИмяПараметраСМассивом, ПолучитьВсеБезФильтра = Ложь)
	ВерхняяГраница = Параметры[ИмяПараметраСМассивом].ВГраница();
	Если ЗначениеЗаполнено(Параметры.ДатаВремяОбновленияДанных) Или ПолучитьВсеБезФильтра Тогда
		ПоследнийИндекс = Макс(ВерхняяГраница, 0);	// Чтобы была хоть одна итерация
	Иначе
		ПоследнийИндекс = ВерхняяГраница;
	КонецЕсли;
	
	Возврат ПоследнийИндекс;
КонецФункции

