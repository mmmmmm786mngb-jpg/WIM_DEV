Функция ТаблицаДанныхМетода(ИмяМетода, НастройкиСоединения, ОписаниеОшибки, Сессия, ВходныеПараметры)
	
	ТаблицаДанных = Неопределено;
	
	ИмяМетодаInfoFintoolClassification	 = "InfoFintoolClassification";
	ИмяМетодаInfoFintoolReferenceData	 = "InfoFintoolReferenceData";
	ИмяМетодаNsdCommonData				 = "NsdCommonData";
	ИмяМетодаEmitentList				 = "EmitentList";
	ИмяМетодаInfoSecuritiesWithCodes	 = "InfoSecurities";
	ИмяМетодаBondAmortizations 			 = "BondAmortizations";
	ИмяМетодаBondTimeTable				 = "BondTimeTable";
	ИмяМетодаFintoolCategoryValue		 = "FintoolCategoryValue";
	
	ИмяПараметраFintoolids = "fintoolids";
	
	ВходныеПараметрыГруппа = Новый Структура;
	ВходныеПараметрыГруппа.Вставить("НомерПачки"				, "");
	ВходныеПараметрыГруппа.Вставить("pageNum"					, 0);
	ВходныеПараметрыГруппа.Вставить("pageSize"					, 100);
	ВходныеПараметрыГруппа.Вставить("ДатаВремяОбновленияДанных"	, ВходныеПараметры.ДатаВремяОбновленияДанных);
	
	Если ИмяМетода = ИмяМетодаInfoFintoolClassification Тогда
		ВходныеПараметрыГруппа.Вставить(ИмяПараметраFintoolids		, ВходныеПараметры.fintoolids);
		ВходныеПараметрыГруппа.Вставить("filter"					, ВходныеПараметры.filter);
	КонецЕсли;
	Если ИмяМетода = ИмяМетодаInfoFintoolReferenceData Тогда
		ВходныеПараметрыГруппа.Вставить(ИмяПараметраFintoolids		, ВходныеПараметры.fintoolids);
		ОбщегоНазначенияКлиентСервер.ДополнитьСтруктуруВыборочно(ВходныеПараметрыГруппа, ВходныеПараметры, "ТолькоFintoolid");
	КонецЕсли;
	Если ИмяМетода = ИмяМетодаNsdCommonData Тогда
		ВходныеПараметрыГруппа.Вставить("nrdcodes"					, ВходныеПараметры.nrdcodes);
		ОбщегоНазначенияКлиентСервер.ДополнитьСтруктуруВыборочно(ВходныеПараметрыГруппа, ВходныеПараметры, "filter");
	КонецЕсли;
	Если ИмяМетода = ИмяМетодаEmitentList Тогда
		ВходныеПараметрыГруппа.Вставить("fininstids"				, ВходныеПараметры.fininstids);
	КонецЕсли;
	Если ИмяМетода = ИмяМетодаInfoSecuritiesWithCodes Тогда
		ОбщегоНазначенияКлиентСервер.ДополнитьСтруктуруВыборочно(ВходныеПараметрыГруппа, ВходныеПараметры, "isins");
		ОбщегоНазначенияКлиентСервер.ДополнитьСтруктуруВыборочно(ВходныеПараметрыГруппа, ВходныеПараметры, "fintoolids");
		ВходныеПараметрыГруппа.Вставить("ФильтрСтатусовЦБ"			, ВходныеПараметры.ФильтрСтатусовЦБ);
		ВходныеПараметрыГруппа.Вставить("ОбновитьБумагиВНеактуальномСтатусе" , ВходныеПараметры.ОбновитьБумагиВНеактуальномСтатусе);
	КонецЕсли;
	Если ИмяМетода = ИмяМетодаBondAmortizations Тогда
		ВходныеПараметрыГруппа.Вставить(ИмяПараметраFintoolids		, ВходныеПараметры.fintoolids);
	КонецЕсли;
	Если ИмяМетода = ИмяМетодаBondTimeTable Тогда
		ВходныеПараметрыГруппа.Вставить("ids"						, ВходныеПараметры.ids);
		ВходныеПараметрыГруппа.Вставить("eventTypes"				, ВходныеПараметры.eventTypes);
		ВходныеПараметрыГруппа.Вставить("pageSize"					, 1000);
	КонецЕсли;
	Если ИмяМетода = ИмяМетодаFintoolCategoryValue Тогда
		ВходныеПараметрыГруппа.Вставить("fintoolIds" 				, ВходныеПараметры.fintoolIds);
		ВходныеПараметрыГруппа.Вставить("filterOnlySpecifiedCategory", ВходныеПараметры.filterOnlySpecifiedCategory);
		ВходныеПараметрыГруппа.Вставить("onlyFintoolsWithCategory"	, ВходныеПараметры.onlyFintoolsWithCategory);
	КонецЕсли;
	
	Для НомерСтраницы = 1 По ВходныеПараметры.МаксимальноеКоличествоСтраниц Цикл
		ВходныеПараметрыГруппа.НомерПачки = "" + ВходныеПараметры.НомерПачки + "_" + НомерСтраницы;
		ВходныеПараметрыГруппа.pageNum = НомерСтраницы;
		Если ИмяМетода = ИмяМетодаInfoFintoolClassification Тогда
			
			Результат = API_ПолучитьОтветМетода(ИмяМетодаInfoFintoolClassification, "/Info/FintoolClassification",
				ВходныеПараметрыГруппа, НастройкиСоединения, ОписаниеОшибки, Сессия);
				
		КонецЕсли;
		Если ИмяМетода = ИмяМетодаInfoFintoolReferenceData Тогда
			
			Результат = API_ПолучитьОтветМетода(ИмяМетодаInfoFintoolReferenceData, "/Info/FintoolReferenceData",
				ВходныеПараметрыГруппа, НастройкиСоединения, ОписаниеОшибки, Сессия);
			
		КонецЕсли;
		Если ИмяМетода = ИмяМетодаNsdCommonData Тогда
			
			Результат = API_ПолучитьОтветМетода(ИмяМетодаNsdCommonData, "/Nsd/CommonData",
				ВходныеПараметрыГруппа, НастройкиСоединения, ОписаниеОшибки, Сессия);
			
		КонецЕсли;
		Если ИмяМетода = ИмяМетодаEmitentList Тогда
			
			Результат = API_ПолучитьОтветМетода(ИмяМетодаEmitentList, "/Emitent/List",
				ВходныеПараметрыГруппа, НастройкиСоединения, ОписаниеОшибки, Сессия);
			
		КонецЕсли;
		Если ИмяМетода = ИмяМетодаInfoSecuritiesWithCodes Тогда
			
			Результат = API_ПолучитьОтветМетода("InfoSecurities", "/Info/Securities",
				ВходныеПараметрыГруппа, НастройкиСоединения, ОписаниеОшибки, Сессия);
			
		КонецЕсли;
		Если ИмяМетода = ИмяМетодаBondAmortizations Тогда
			
			Результат = API_ПолучитьОтветМетода(ИмяМетодаBondAmortizations, "/Bond/Amortizations",
				ВходныеПараметрыГруппа, НастройкиСоединения, ОписаниеОшибки, Сессия);
				
		КонецЕсли;	
		Если ИмяМетода = ИмяМетодаBondTimeTable Тогда
			
			Результат = API_ПолучитьОтветМетода(ИмяМетодаBondTimeTable, "/Bond/TimeTable",
				ВходныеПараметрыГруппа, НастройкиСоединения, ОписаниеОшибки, Сессия);
			
			Если ТипЗнч(Результат) = Тип("Структура") И Результат.Свойство("timeTableFields") Тогда
				Результат = Результат.timeTableFields;
			Иначе
				Результат = Новый Массив;
			КонецЕсли;
			
		КонецЕсли;
		
		Если ИмяМетода = ИмяМетодаFintoolCategoryValue Тогда
			Результат = API_ПолучитьОтветМетода("InfoFintoolCategoryValue", "/Info/fintool-category-value",
				ВходныеПараметрыГруппа, НастройкиСоединения, ОписаниеОшибки, Сессия);
		КонецЕсли;
			
		Если Не ЗначениеЗаполнено(Результат) Тогда
			Прервать;
		КонецЕсли;
		ВременнаяТаблица = ПреобразоватьМассивВТаблицуЗначений(Результат, ВходныеПараметры.ЧисловыеРеквизиты);
		ДополнитьИмитаторТаблицыДанныхМетода(ИмяМетода, ВременнаяТаблица);
		ТаблицаДанных = КонкатенацияТаблицЗначений(ТаблицаДанных, ВременнаяТаблица);
	КонецЦикла;
	
	Возврат ТаблицаДанных;
	
КонецФункции
// BSLLS:CognitiveComplexity-on

Функция ТаблицаСозданияОбновленияЦенныхБумаг(ИмяТаблицы, ИмяПараметраПериод, ТаблицаВходныхДанных, ВходныеПараметры = Неопределено)
	
	РезультирующаяТаблица = Неопределено;
	ТолькоУникальныеЗначения = Истина;
	ТолькоЗаполненныеЗначения = Истина;
	
	Если ИмяТаблицы = "BondTimeTable" Тогда
		ЦенныеБумаги = ТаблицаВходныхДанных.Скопировать();
		ids = ОбщегоНазначения.ВыгрузитьКолонку(ЦенныеБумаги, "isin", ТолькоУникальныеЗначения, ТолькоЗаполненныеЗначения);
		ВходныеПараметры.Вставить("ids", ids);
		ВходныеПараметры.Вставить(ИмяПараметраПериод, Дата(1, 1, 1));
		ОписаниеОшибки = "";
		Сессия = Неопределено;
		РезультирующаяТаблица = BondTimeTable(ОписаниеОшибки, Сессия, ВходныеПараметры);
	КонецЕсли;
	
	Если ИмяТаблицы = "InfoFintoolReferenceData" Тогда
		ВходныеПараметры = Новый Структура;
		ЦенныеБумаги = ТаблицаВходныхДанных.Скопировать();
		fintoolids = ОбщегоНазначения.ВыгрузитьКолонку(ЦенныеБумаги, "fintoolid", ТолькоУникальныеЗначения, ТолькоЗаполненныеЗначения);
		ВходныеПараметры.Вставить("fintoolids", fintoolids);
		ВходныеПараметры.Вставить(ИмяПараметраПериод, Дата(1, 1, 1));
		ОписаниеОшибки = "";
		Сессия = Неопределено;
		РезультирующаяТаблица = InfoFintoolReferenceData(ОписаниеОшибки, Сессия, ВходныеПараметры);
		
		Если Не ЗначениеЗаполнено(РезультирующаяТаблица) Тогда // Получим таблицу
			ВходныеПараметры = Новый Структура;
			fintoolids = Новый Массив;
			КодПоУмолчаниюRuData = "158150";
			fintoolids.Добавить(КодПоУмолчаниюRuData);
			ВходныеПараметры.Вставить("fintoolids", fintoolids);
			ВходныеПараметры.Вставить(ИмяПараметраПериод, Дата(1, 1, 1));
			ОписаниеОшибки = "";
			Сессия = Неопределено;
			РезультирующаяТаблица = InfoFintoolReferenceData(ОписаниеОшибки, Сессия, ВходныеПараметры);
		КонецЕсли;
	КонецЕсли;
	
	Если ИмяТаблицы = "NsdCommonData" Тогда
		ВходныеПараметры = Новый Структура;
		ЦенныеБумаги = ТаблицаВходныхДанных.Скопировать();
		nrdcodes = ОбщегоНазначения.ВыгрузитьКолонку(ЦенныеБумаги, "nrdcode", ТолькоУникальныеЗначения, ТолькоЗаполненныеЗначения);
		ВходныеПараметры.Вставить("nrdcodes", nrdcodes);
		ВходныеПараметры.Вставить(ИмяПараметраПериод, Дата(1, 1, 1));
		ОписаниеОшибки = "";
		Сессия = Неопределено;
		РезультирующаяТаблица = NsdCommonData(ОписаниеОшибки, Сессия, ВходныеПараметры);
		
		Если Не ЗначениеЗаполнено(РезультирующаяТаблица) Тогда // Получим таблицу
			ВходныеПараметры = Новый Структура;
			КодПоУмолчаниюNDC = "RU000A102RB2";
			nrdcodes = Новый Массив;
			nrdcodes.Добавить(КодПоУмолчаниюNDC);
			ВходныеПараметры.Вставить("nrdcodes", nrdcodes);
			ВходныеПараметры.Вставить(ИмяПараметраПериод, Дата(1, 1, 1));
			ОписаниеОшибки = "";
			Сессия = Неопределено;
			РезультирующаяТаблица = NsdCommonData(ОписаниеОшибки, Сессия, ВходныеПараметры);
		КонецЕсли;
	КонецЕсли;
	
	Возврат РезультирующаяТаблица;
	
КонецФункции

Функция ТаблицаЭмитентовЗагружаемыхЦБ(ТаблицаЗагружаемыхЦБ, ВходныеПараметры = Неопределено)

	Если ВходныеПараметры = Неопределено Тогда
		ВходныеПараметры = Новый Структура;
	КонецЕсли;
	
	// Отбираем id (fininstid) всех новых ЦБ (которых раньше не было в справочнике ЦБ)
	fininstids = Новый Массив;
	ПараметрыОтбора = Новый Структура("ЭтоНоваяЦБ", Истина);
	ЦБДляПоискаЭмитентов = ТаблицаЗагружаемыхЦБ.НайтиСтроки(ПараметрыОтбора);
	Для Каждого ЦБДляПоиска Из ЦБДляПоискаЭмитентов Цикл
		Если ЗначениеЗаполнено(ЦБДляПоиска.fininstid) И fininstids.Найти(ЦБДляПоиска.fininstid) = Неопределено Тогда
			fininstids.Добавить(ЦБДляПоиска.fininstid);
		КонецЕсли;
	КонецЦикла;
	
	// В зависимости от входных параметров отбираем id (fininstid) всех не новых загружаемых ЦБ, или только тех,
	// для которых раньше не был указан эмитент (юридическое лицо контрагента)
	Если ВходныеПараметры.Свойство("ОбновитьЭмитентовВсехЗагружаемыхЦБ") И ВходныеПараметры.ОбновитьЭмитентовВсехЗагружаемыхЦБ Тогда
		ПараметрыОтбора = Новый Структура("ЭтоНоваяЦБ", Ложь);
	Иначе
		ПараметрыОтбора = Новый Структура("ЭтоНоваяЦБ, БезЭмитента", Ложь, Истина);
	КонецЕсли;
	ЦБДляПоискаЭмитентов = ТаблицаЗагружаемыхЦБ.НайтиСтроки(ПараметрыОтбора);
	Для Каждого ЦБДляПоиска Из ЦБДляПоискаЭмитентов Цикл
		Если ЗначениеЗаполнено(ЦБДляПоиска.fininstid) И fininstids.Найти(ЦБДляПоиска.fininstid) = Неопределено Тогда
			fininstids.Добавить(ЦБДляПоиска.fininstid);
		КонецЕсли;
	КонецЦикла;
	
	ВходныеПараметры.Вставить("fininstids", fininstids);
	ВходныеПараметры.Вставить("ДатаВремяОбновленияДанных", Дата(1, 1, 1));
	ОписаниеОшибки = "";
	Сессия = Неопределено;
	ТаблицаЭмитентовЗагружаемыхЦБ = EmitentList(ОписаниеОшибки, Сессия, ВходныеПараметры);
	
	Возврат ТаблицаЭмитентовЗагружаемыхЦБ;
КонецФункции

Функция ТаблицаИзменившихсяЭмитентов(ВходныеПараметры = Неопределено)
	
	Если ВходныеПараметры = Неопределено Тогда
		ВходныеПараметры = Новый Структура;
	КонецЕсли;
	
	ТаблицаИзменившихсяЭмитентов = Неопределено;
	ЭтоОтчет = ВходныеПараметры.Свойство("ЭтоОтчет") И ВходныеПараметры.ЭтоОтчет;
	
	Если Не ЭтоОтчет И СвойствоЗаполнено(ВходныеПараметры, "ДатаВремяОбновленияДанных") Тогда
		ОписаниеОшибки = "";
		Сессия = Неопределено;
		НастройкиСоединения = ПараметрыИсточника();
		Если ЗначениеЗаполнено(НастройкиСоединения) Тогда
			ВходящиеИдентификаторы = НовыеВходящиеИдентификаторы();
			ВходящиеИдентификаторы.Вставить("fininstids", Неопределено);
			ВходныеПараметрыГруппа = НовыеВходныеПараметрыГруппы(1, ВходныеПараметры.ДатаВремяОбновленияДанных, ВходящиеИдентификаторы);
			ТаблицаИзменившихсяЭмитентов = ТаблицаДанныхМетода("EmitentList", НастройкиСоединения, ОписаниеОшибки, Сессия, ВходныеПараметрыГруппа);
		КонецЕсли;
	КонецЕсли;
	
	Возврат ТаблицаИзменившихсяЭмитентов;
КонецФункции
 
// Возвращает таблицу создания Эмитентов
//
// Параметры:
//  ТаблицаЭмитентовЗагружаемыхЦБ - ТаблицаЗначений	 - Таблица с данными (см. https://docs.efir-net.ru/dh2/#/Info/Securities) 
//  													или Неопределено
//  ТаблицаИзменившихсяЭмитентов - ТаблицаЗначений	 - таблица с данными того же формата что и у предыдущего параметра или Неопределено
// 
// Возвращаемое значение:
//   - ТаблицаЗначений - Таблица с объединенными данными по новым Эмитентам
//
Функция СтатикаЭмитентов(ТаблицаЭмитентовЗагружаемыхЦБ, ТаблицаИзменившихсяЭмитентов)
	
	ТаблицаСтатики = Новый ТаблицаЗначений;
	
	Если Не ЗначениеЗаполнено(ТаблицаЭмитентовЗагружаемыхЦБ) И Не ЗначениеЗаполнено(ТаблицаИзменившихсяЭмитентов) Тогда
		Возврат ТаблицаСтатики;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(ТаблицаЭмитентовЗагружаемыхЦБ) Тогда
		ТаблицаЭмитентовЗагружаемыхЦБ = ТаблицаИзменившихсяЭмитентов.СкопироватьКолонки();
	КонецЕсли;
	Если Не ЗначениеЗаполнено(ТаблицаИзменившихсяЭмитентов) Тогда
		ТаблицаИзменившихсяЭмитентов = ТаблицаЭмитентовЗагружаемыхЦБ.СкопироватьКолонки();
	КонецЕсли;
	
	ТекстЗапроса = "";
	ВыбратьПоместить = " ВЫБРАТЬ * ПОМЕСТИТЬ ";
	
	ТекстЗапроса = ТекстЗапроса
	+ ВыбратьПоместить + " ВТ_ТаблицаЭмитентовЗагружаемыхЦБ " + "
	|ИЗ
	|	&ТаблицаЭмитентовЗагружаемыхЦБ КАК ТаблицаЭмитентовЗагружаемыхЦБ; ";
	ТекстЗапроса = ТекстЗапроса
	+ ВыбратьПоместить + " ВТ_ТаблицаИзменившихсяЭмитентов " + "
	|ИЗ
	|	&ТаблицаИзменившихсяЭмитентов КАК ТаблицаИзменившихсяЭмитентов";
	
	Запрос = Новый Запрос;
	МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("ТаблицаЭмитентовЗагружаемыхЦБ", ТаблицаЭмитентовЗагружаемыхЦБ);
	Запрос.УстановитьПараметр("ТаблицаИзменившихсяЭмитентов", ТаблицаИзменившихсяЭмитентов);
	Запрос.Текст = ТекстЗапроса;
	Запрос.Выполнить();
	
	СхемаRuDataAPI = ПолучитьОбщийМакет("СтатикаЭмитентыRuDataAPI");
	
	КомпоновщикНастроекНастройки = Новый КомпоновщикНастроекКомпоновкиДанных;
	КомпоновщикНастроекНастройки.Инициализировать(Новый ИсточникДоступныхНастроекКомпоновкиДанных(СхемаRuDataAPI));
	КомпоновщикНастроекНастройки.ЗагрузитьНастройки(СхемаRuDataAPI.НастройкиПоУмолчанию); 
	
	ПараметрыДанных = КомпоновщикНастроекНастройки.Настройки.ПараметрыДанных;
	ПараметрыДанных.УстановитьЗначениеПараметра("ЭтоПервоначальнаяЗагрузка", Ложь);
	ПараметрыДанных.УстановитьЗначениеПараметра("ТекущаяДатаСеанса", НачалоДня(ТекущаяДатаСеанса()));
	ПараметрыДанных.УстановитьЗначениеПараметра("КлассификаторНДЦ", Справочники.КлассификаторыЗагрузки.НДЦ());
	ПараметрыДанных.УстановитьЗначениеПараметра("КлассификаторRuData", Справочники.КлассификаторыЗагрузки.RuData);
	ПараметрыДанных.УстановитьЗначениеПараметра("СтатусыАктуальныхЦБ", СтатусыАктуальныхЦБ());
	
	КомпоновщикМакета = Новый КомпоновщикМакетаКомпоновкиДанных;
	МакетКомпоновкиДанных = КомпоновщикМакета.Выполнить(СхемаRuDataAPI, КомпоновщикНастроекНастройки.Настройки, , ,
		Тип("ГенераторМакетаКомпоновкиДанныхДляКоллекцииЗначений"));
	
	ПроцессорКомпоновкиДанных = Новый ПроцессорКомпоновкиДанных;
	ПроцессорКомпоновкиДанных.Инициализировать(МакетКомпоновкиДанных, , , Истина, , МенеджерВременныхТаблиц);
	ПроцессорВывода = Новый ПроцессорВыводаРезультатаКомпоновкиДанныхВКоллекциюЗначений;
	
	ПроцессорВывода.УстановитьОбъект(ТаблицаСтатики);
	ПроцессорВывода.Вывести(ПроцессорКомпоновкиДанных);
	
	Возврат ТаблицаСтатики;
	
КонецФункции

// Возвращает таблицу обновления ЦБ
//
// Параметры:
//  ТаблицаInfoSecurities			 - ТаблицаЗначений	 - Таблица с данными (см. https://docs.efir-net.ru/dh2/#/Info/Securities)
//  ТаблицаInfoFintoolReferenceData	 - ТаблицаЗначений	 - Таблица с данными (см. https://docs.efir-net.ru/dh2/#/Info/FintoolReferenceData)
//  ТаблицаNsdCommonData			 - ТаблицаЗначений	 - Таблица с данными (см. https://docs.efir-net.ru/dh2/#/Nsd/CommonData)
//  ТаблицаДопущенныхКТоргамЦБ		 - ТаблицаЗначений	 - Таблица с единственной колонкой fintoolid (см.
//															https://docs.efir-net.ru/dh2/#/Info/FintoolClassification)
//  ВходныеПараметры				 - Структура
// 
// Возвращаемое значение:
//   - ТаблицаЗначений - Таблица с объединенными данными по ЦБ
//
Функция СтатикаЦенныхБумаг(ТаблицаInfoSecurities, ТаблицаInfoFintoolReferenceData, ТаблицаNsdCommonData,
							ТаблицаДопущенныхКТоргамЦБ, ВходныеПараметры)
	
	ТаблицаСтатики = Новый ТаблицаЗначений;
	
	Если Не ЗначениеЗаполнено(ТаблицаInfoSecurities)
			Или Не ЗначениеЗаполнено(ТаблицаInfoFintoolReferenceData)
			Или Не ЗначениеЗаполнено(ТаблицаNsdCommonData) Тогда
		Возврат ТаблицаСтатики;
	КонецЕсли;
	
	ТекстЗапроса = "";
	ВыбратьПоместить = " ВЫБРАТЬ * ПОМЕСТИТЬ ";
	
	ТекстЗапроса = ТекстЗапроса
	+ ВыбратьПоместить + " InfoSecurities " + "
	|ИЗ
	|	&ТаблицаInfoSecurities КАК ТаблицаInfoSecurities; ";
	ТекстЗапроса = ТекстЗапроса
	+ ВыбратьПоместить + " InfoFintoolReferenceData " + "
	|ИЗ
	|	&ТаблицаInfoFintoolReferenceData КАК ТаблицаInfoFintoolReferenceData; ";
	ТекстЗапроса = ТекстЗапроса
	+ ВыбратьПоместить + " NsdCommonData " + "
	|ИЗ
	|	&ТаблицаNsdCommonData КАК ТаблицаNsdCommonData; ";
	ТекстЗапроса = ТекстЗапроса
	+ ВыбратьПоместить + " ТаблицаДопущенныхКТоргамЦБ " + "
	|ИЗ
	|	&ТаблицаДопущенныхКТоргамЦБ КАК ТаблицаДопущенныхКТоргамЦБ ";
	
	Запрос = Новый Запрос;
	МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	
	// В платформе 1C (на момент написания этого кода использовалась платформа 8.3.21.1674) в СКД присутствует
	// ограничение: не более 9 знаков после запятой у числовых значений. Значения с большей разрядностью округляются
	// до 9 знаков. Поэтому пришлось пойти на такой способ обхода этого ограничения: предварительно преобразовать
	// число, представляющее номинал ЦБ, в строку. А после получения результата из СКД - преобразовать обратно строку
	// в число.
	ТаблицаInfoSecurities.Колонки.Добавить("facevalue_строка", ОбщегоНазначения.ОписаниеТипаСтрока(40));
	Для каждого Строка Из ТаблицаInfoSecurities Цикл
		Если ЗначениеЗаполнено(Строка.facevalue) Тогда
			Строка.facevalue_строка = Формат(Строка.facevalue, "ЧГ=");
		КонецЕсли;
	КонецЦикла;
	
	Запрос.УстановитьПараметр("ТаблицаInfoSecurities", ТаблицаInfoSecurities);
	Запрос.УстановитьПараметр("ТаблицаInfoFintoolReferenceData", ТаблицаInfoFintoolReferenceData);
	Запрос.УстановитьПараметр("ТаблицаNsdCommonData", ТаблицаNsdCommonData);
	Запрос.УстановитьПараметр("ТаблицаДопущенныхКТоргамЦБ", ТаблицаДопущенныхКТоргамЦБ);
	
	Запрос.Текст = ТекстЗапроса;
	Запрос.Выполнить();
	
	СхемаRuDataAPI = ПолучитьОбщийМакет("СтатикаЦБRuDataAPI");
	
	КомпоновщикНастроекНастройки = Новый КомпоновщикНастроекКомпоновкиДанных;
	КомпоновщикНастроекНастройки.Инициализировать(Новый ИсточникДоступныхНастроекКомпоновкиДанных(СхемаRuDataAPI));
	КомпоновщикНастроекНастройки.ЗагрузитьНастройки(СхемаRuDataAPI.НастройкиПоУмолчанию); 
	
	ПараметрыДанных = КомпоновщикНастроекНастройки.Настройки.ПараметрыДанных;
	ПараметрыДанных.УстановитьЗначениеПараметра("ЭтоПервоначальнаяЗагрузка", Ложь);
	ПараметрыДанных.УстановитьЗначениеПараметра("ТекущаяДатаСеанса", НачалоДня(ТекущаяДатаСеанса()));
	ПараметрыДанных.УстановитьЗначениеПараметра("КлассификаторНДЦ", Справочники.КлассификаторыЗагрузки.НДЦ());
	ПараметрыДанных.УстановитьЗначениеПараметра("КлассификаторRuData", Справочники.КлассификаторыЗагрузки.RuData);
	ПараметрыДанных.УстановитьЗначениеПараметра("КлассификаторMICEX", Справочники.Биржи.MICEX);
	ПараметрыДанных.УстановитьЗначениеПараметра("ОбновитьБумагиВНеактуальномСтатусе", ВходныеПараметры.ОбновитьБумагиВНеактуальномСтатусе);
	ПараметрыДанных.УстановитьЗначениеПараметра("СтатусыАктуальныхЦБ", СтатусыАктуальныхЦБ());
	
	КомпоновщикМакета = Новый КомпоновщикМакетаКомпоновкиДанных;
	МакетКомпоновкиДанных = КомпоновщикМакета.Выполнить(СхемаRuDataAPI, КомпоновщикНастроекНастройки.Настройки, , ,
		Тип("ГенераторМакетаКомпоновкиДанныхДляКоллекцииЗначений"));
	
	ПроцессорКомпоновкиДанных = Новый ПроцессорКомпоновкиДанных;
	ПроцессорКомпоновкиДанных.Инициализировать(МакетКомпоновкиДанных, , , Истина, , МенеджерВременныхТаблиц);
	ПроцессорВывода = Новый ПроцессорВыводаРезультатаКомпоновкиДанныхВКоллекциюЗначений;
	
	ПроцессорВывода.УстановитьОбъект(ТаблицаСтатики);
	ПроцессорВывода.Вывести(ПроцессорКомпоновкиДанных);
	
	// Обратное преобразование номинала ЦБ из строки в число
	ТаблицаСтатики.Колонки.Добавить("facevalue", ОбщегоНазначения.ОписаниеТипаЧисло(32, 20));
	Для каждого Строка Из ТаблицаСтатики Цикл
		Если ЗначениеЗаполнено(Строка.facevalue_строка) Тогда
			Строка.facevalue = Число(Строка.facevalue_строка);
		КонецЕсли;
	КонецЦикла;
	
	Возврат ТаблицаСтатики;
	
КонецФункции

Функция FintoolidsПоВсемИзменениям(ВходныеПараметры, ОписаниеОшибки, Сессия = Неопределено)
	ТолькоУникальныеЗначения = Истина;
	ТолькоЗаполненныеЗначения = Истина;
	ИмяКолонкиFintoolid = "fintoolid";
	
	// Получим fintoolids/nrdcodes соответствующие ISINs если заданы ISINs (фильтр по статусам учитываем, фильтр по дате - нет)
	// Списоки fintoolid/nrdcodes нужны для фильтрации по заданым ISIN в остальных таблицах
	Если СвойствоЗаполнено(ВходныеПараметры, "ISINs") Тогда
		Параметры = Новый Структура;
		ОбщегоНазначенияКлиентСервер.ДополнитьСтруктуру(Параметры, ВходныеПараметры);
		Параметры.ДатаВремяОбновленияДанных = ДАТА(1, 1, 1);
		ЦБПоISINs = ДанныеЦенныхБумагПоПараметрам(Параметры, ОписаниеОшибки, Сессия);
		FintoolidsOnISINs = ОбщегоНазначения.ВыгрузитьКолонку(ЦБПоISINs, ИмяКолонкиFintoolid,
																ТолькоУникальныеЗначения, ТолькоЗаполненныеЗначения);
		NrdcodesOnISINs = ОбщегоНазначения.ВыгрузитьКолонку(ЦБПоISINs, "nrdcode", ТолькоУникальныеЗначения, ТолькоЗаполненныеЗначения);
		Если FintoolidsOnISINs.Количество() = 0 Тогда
			Возврат Неопределено;
		КонецЕсли;
	Иначе
		FintoolidsOnISINs = Новый Массив;
		NrdcodesOnISINs = Новый Массив;
	КонецЕсли;
	
	// Получим fintoolids с использованием всех стандартных фильтров по InfoSecurities
	Параметры = ПараметрыДляПоискаИзменений(ВходныеПараметры.ДатаВремяОбновленияДанных, FintoolidsOnISINs);
	ОбщегоНазначенияКлиентСервер.ДополнитьСтруктуру(Параметры, ВходныеПараметры, Ложь);
	ТЗInfoSecurities = ДанныеЦенныхБумагПоПараметрам(Параметры, ОписаниеОшибки, Сессия);
	Если ЗначениеЗаполнено(ТЗInfoSecurities) Тогда
		Fintoolids = ОбщегоНазначения.ВыгрузитьКолонку(ТЗInfoSecurities, ИмяКолонкиFintoolid,
															ТолькоУникальныеЗначения, ТолькоЗаполненныеЗначения);
	Иначе
		Fintoolids = Новый Массив;
	КонецЕсли;
	
	// Получим fintoolids из таблицы Info\FintoolReferenceData с использованием фильтров по дате обновления и FintoolidsOnISINs
	Параметры = ПараметрыДляПоискаИзменений(ВходныеПараметры.ДатаВремяОбновленияДанных, FintoolidsOnISINs);
	Параметры.Вставить("ТолькоFintoolid", Истина);
	ТЗFintoolReferenceData = InfoFintoolReferenceData(ОписаниеОшибки, Сессия, Параметры);
	ДополнитьМассивFintoolids(Fintoolids, ТЗFintoolReferenceData, ИмяКолонкиFintoolid);
	
	// Получим fintoolids из таблицы Nsd\CommonData с использованием фильтров по дате обновления и NrdcodesOnISINs
	Параметры = ПараметрыДляПоискаИзменений(ВходныеПараметры.ДатаВремяОбновленияДанных, FintoolidsOnISINs, NrdcodesOnISINs);
	Параметры.Вставить("filter", "fintoolid IS NOT NULL");
	ТЗNsdCommonData = NsdCommonData(ОписаниеОшибки, Сессия, Параметры);
	ДополнитьМассивFintoolids(Fintoolids, ТЗNsdCommonData, ИмяКолонкиFintoolid);
	
	// Получим fintoolids из таблицы Bond\Amortizations с использованием фильтров по дате обновления и FintoolidsOnISINs
	Параметры = ПараметрыДляПоискаИзменений(ВходныеПараметры.ДатаВремяОбновленияДанных, FintoolidsOnISINs);
	ТЗBondAmortizations = BondAmortizations(ОписаниеОшибки, Сессия, Параметры);
	ДополнитьМассивFintoolids(Fintoolids, ТЗBondAmortizations, "id_fintool");
	
	Возврат Fintoolids;
КонецФункции

Процедура ДополнитьМассивFintoolids(Fintoolids, ТаблицаЗначений, ИмяКолонкиСFintoolid)
	Если ЗначениеЗаполнено(ТаблицаЗначений) Тогда
		FintoolidsFromTable = ТаблицаЗначений.ВыгрузитьКолонку(ИмяКолонкиСFintoolid);
		ЧисловыеРеквизиты = ЧисловыеРеквизитыТаблицRuDataAPI();
		Если ЧисловыеРеквизиты.НайтиПоЗначению(ИмяКолонкиСFintoolid) <> Неопределено Тогда // Преобразуем число в строку
			МаксИндекс = FintoolidsFromTable.Количество() - 1;
			Для Индекс = 0 По МаксИндекс Цикл
				FintoolidsFromTable[Индекс] = Формат(FintoolidsFromTable[Индекс], "ЧН=0; ЧГ=");
			КонецЦикла;
		КонецЕсли;
		ТолькоУникальныеЗначения = Истина;
		ОбщегоНазначенияКлиентСервер.ДополнитьМассив(Fintoolids, FintoolidsFromTable, ТолькоУникальныеЗначения);
	КонецЕсли;
КонецПроцедуры

Функция ПараметрыДляПоискаИзменений(ДатаВремяОбновленияДанных, FintoolidsOnISINs, NrdcodesOnISINs = Неопределено)
	Параметры = Новый Структура;
	Параметры.Вставить("fintoolids", FintoolidsOnISINs);
	Параметры.Вставить("ДатаВремяОбновленияДанных", ДатаВремяОбновленияДанных);
	Если NrdcodesOnISINs <> Неопределено Тогда
		Параметры.Вставить("nrdcodes", NrdcodesOnISINs);
	КонецЕсли;
	
	Возврат Параметры;
КонецФункции

Процедура ОсновнойАлгоритмЗагрузкиНКД(ТекущаяДата, Isins)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	КурсыВалют.Валюта.Наименование КАК ВалютаНаименование,
	|	КурсыВалют.Курс КАК Курс
	|ИЗ
	|	РегистрСведений.КурсыВалют КАК КурсыВалют
	|ГДЕ
	|	КурсыВалют.Период = &Дата";
	Запрос.УстановитьПараметр("Дата", НачалоДня(ТекущаяДата));
	Выборка = Запрос.Выполнить().Выбрать();
	КурсыВалют = Новый Структура;
	Пока Выборка.Следующий() Цикл
		КурсыВалют.Вставить(Выборка.ВалютаНаименование, Выборка.Курс);
	КонецЦикла;
	КурсыВалют.Вставить("RUB", 1);
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	КодыЗагрузки.Код КАК Код,
	|	ЦенныеБумаги.Ссылка КАК ЦБ,
	|	ЦенныеБумаги.ДатаПогашения КАК ДатаПогашения,
	|	ЦенныеБумаги.ISIN КАК ISIN
	|ПОМЕСТИТЬ ЦенныеБумаги
	|ИЗ
	|	Справочник.КодыЗагрузки КАК КодыЗагрузки
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ЦенныеБумаги КАК ЦенныеБумаги
	|		ПО КодыЗагрузки.Владелец = ЦенныеБумаги.Ссылка
	|			И (КодыЗагрузки.Биржа = ЗНАЧЕНИЕ(Справочник.КлассификаторыЗагрузки.Rudata))
	|			И (ЦенныеБумаги.КупоннаяОблигация)
	|			И (НЕ ЦенныеБумаги.ПометкаУдаления)
	|			И (ЦенныеБумаги.ISIN В (&Isins))
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	МАКСИМУМ(ЦенныеБумагиКупоны.ДатаПогашения) КАК ДатаПогашения,
	|	ЦенныеБумагиКупоны.Ссылка КАК ЦБ
	|ПОМЕСТИТЬ Купоны
	|ИЗ
	|	ЦенныеБумаги КАК ЦенныеБумаги
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ЦенныеБумаги.Купоны КАК ЦенныеБумагиКупоны
	|		ПО ЦенныеБумаги.ЦБ = ЦенныеБумагиКупоны.Ссылка
	|
	|СГРУППИРОВАТЬ ПО
	|	ЦенныеБумагиКупоны.Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	МАКСИМУМ(ЦенныеБумагиКупоны.ДатаПогашения) КАК ДатаПогашения,
	|	ЦенныеБумагиКупоны.Ссылка КАК ЦБ,
	|	ЦенныеБумагиКупоны.Сумма КАК Сумма
	|ПОМЕСТИТЬ КупоныСтоимость
	|ИЗ
	|	ЦенныеБумаги КАК ЦенныеБумаги
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ЦенныеБумаги.Купоны КАК ЦенныеБумагиКупоны
	|		ПО ЦенныеБумаги.ЦБ = ЦенныеБумагиКупоны.Ссылка
	|			И (ЦенныеБумагиКупоны.ДатаПогашения = &ДатаПогашения)
	|
	|СГРУППИРОВАТЬ ПО
	|	ЦенныеБумагиКупоны.Ссылка,
	|	ЦенныеБумагиКупоны.Сумма
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЦенныеБумаги.Код КАК Код,
	|	ЦенныеБумаги.ЦБ КАК ЦБ,
	|	ЕСТЬNULL(КупоныСтоимость.Сумма, 0) КАК Сумма,
	|	ЦенныеБумаги.ISIN КАК ISIN
	|ИЗ
	|	ЦенныеБумаги КАК ЦенныеБумаги
	|		ЛЕВОЕ СОЕДИНЕНИЕ Купоны КАК Купоны
	|		ПО ЦенныеБумаги.ЦБ = Купоны.ЦБ
	|		ЛЕВОЕ СОЕДИНЕНИЕ КупоныСтоимость КАК КупоныСтоимость
	|		ПО ЦенныеБумаги.ЦБ = КупоныСтоимость.ЦБ
	|ГДЕ
	|	ВЫБОР
	|			КОГДА ЦенныеБумаги.ДатаПогашения <> ДАТАВРЕМЯ(1, 1, 1)
	|				ТОГДА ЦенныеБумаги.ДатаПогашения >= &ДатаПогашения
	|			ИНАЧЕ ЕСТЬNULL(Купоны.ДатаПогашения, ДАТАВРЕМЯ(1, 1, 1)) >= &ДатаПогашения
	|		КОНЕЦ";
	Если ЗначениеЗаполнено(Isins) Тогда
		Запрос.УстановитьПараметр("Isins", Isins);
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "И (ЦенныеБумаги.ISIN В (&Isins))", "");
	КонецЕсли;
	Запрос.УстановитьПараметр("ДатаПогашения", НачалоДня(ТекущаяДата));
	СписокБумаг = Новый Массив;
	КодРуДатаЦБ = Новый Соответствие;
	СтоимостьКупона = Новый Соответствие;
	МаксимальноеКоличествоЗаписей = 100;
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		
		ОписаниеТипа = Новый ОписаниеТипов("Число");
		КодЦБ = ОписаниеТипа.ПривестиЗначение(Выборка.Код);
		Если КодЦБ = 0 Тогда
			Продолжить;
		КонецЕсли;
		
		КодРуДатаЦБ.Вставить(Число(Выборка.Код), Выборка.ЦБ);
		СтоимостьКупона.Вставить(Число(Выборка.Код), Выборка.Сумма);
		СписокБумаг.Добавить(Выборка.Код);
		
		Если СписокБумаг.Количество() = МаксимальноеКоличествоЗаписей Тогда
			ОбработатьПолученныеНКД(СписокБумаг, СтоимостьКупона, КурсыВалют, ТекущаяДата, КодРуДатаЦБ);
			СписокБумаг.Очистить();
			КодРудатаЦБ.Очистить();
			СтоимостьКупона.Очистить();
		КонецЕсли;
	КонецЦикла;
	Если СписокБумаг.Количество() > 0 Тогда 
		ОбработатьПолученныеНКД(СписокБумаг, СтоимостьКупона, КурсыВалют, ТекущаяДата, КодРуДатаЦБ);
	КонецЕсли;

КонецПроцедуры

Процедура ОбработатьПолученныеНКД(СписокБумаг, СтоимостьКупона, КурсыВалют, ТекущаяДата, КодРуДатаЦБ)
	
	HTTPОтвет = ДанныеМетодаЗагрузитьНКД(СписокБумаг, ТекущаяДата);
	Если Не ЗначениеЗаполнено(HTTPОтвет) Тогда
		Возврат;
	КонецЕсли;
	ИнтерфаксРуДата = Справочники.ИнформационноАналитическиеСистемы.Интерфакс;
	Для Каждого Ответ Из HTTPОтвет Цикл
		
		Стоимость = Ответ.accruedInterest;
		Если Не ЗначениеЗаполнено(Стоимость) Тогда
			Стоимость = СтоимостьКупона[Ответ.fintoolId];
		КонецЕсли;
		
		Если Стоимость = 0 Тогда
			Продолжить;
		КонецЕсли;
		
		НаборЗаписей = РегистрыСведений.НКД.СоздатьНаборЗаписей();
		НаборЗаписей.Отбор.Период.Установить(ТекущаяДата);
		НаборЗаписей.Отбор.Биржа.Установить(ИнтерфаксРуДата);
		НаборЗаписей.Отбор.ЦеннаяБумага.Установить(КодРудатаЦБ[Ответ.fintoolId]);
		НоваяЗапись = НаборЗаписей.Добавить();
		НоваяЗапись.Период = ТекущаяДата;
		НоваяЗапись.Биржа = ИнтерфаксРуДата;
		НоваяЗапись.ЦеннаяБумага = КодРудатаЦБ[Ответ.fintoolId];
		НоваяЗапись.AccInt = Стоимость;
		Попытка
			НоваяЗапись.Nkd = Стоимость * КурсыВалют[Ответ.accruedInterestCurrency];
		Исключение
			НоваяЗапись.Nkd = 0;
		КонецПопытки;
		НаборЗаписей.Записать();
		
	КонецЦикла;
	
КонецПроцедуры

Функция ПолучитьОбращаемостьСпискаЦБИзRuDataПоFintoolid(ПараметрыСессии, Дата, МассивИД, ТекстОтказа = Неопределено)
	
	ЛогПолученныхДанных = Неопределено;
	ОставитьЗаписьВЖурналеРегистрацииВызовов = Ложь;
	
	Отказ = ПараметрыСессии.Отказ;
	ТекстОтказа = ПараметрыСессии.ТекстОтказа;
	Сессия = ПараметрыСессии.Сессия;
	
	ПараметрыМетода = Новый Структура();
	ПараметрыМетода.Вставить("date", Формат(Дата, "ДФ=""гггг-ММ-дд"""));
	ПараметрыМетода.Вставить("fintoolIdList", МассивИД);
	params = Новый Массив;
	params.Добавить("ISNEGOTIABILITY");
	ПараметрыМетода.Вставить("params", params);
	
	ПризнакиОбращаемости = ДанныеМетода_V2_Risk_FintoolsRiskGroupParams(ПараметрыМетода, Отказ, ТекстОтказа,
		ЛогПолученныхДанных, Сессия, ОставитьЗаписьВЖурналеРегистрацииВызовов);
		
	Если Отказ Тогда
		Возврат Неопределено;
	Иначе
		Возврат ПризнакиОбращаемости;
	КонецЕсли;
	
КонецФункции

Процедура ЗагрузитьДанныеПоОбращаемостиЦБНаДату(ПараметрыСессии, Дата, Isins)
	
	ТекстЗапроса =
	"ВЫБРАТЬ
	|	ЦенныеБумаги.Ссылка КАК ЦеннаяБумага,
	|	ЦенныеБумаги.ISIN КАК ISIN,
	|	АВТОНОМЕРЗАПИСИ() КАК НомерСтроки
	|ПОМЕСТИТЬ ЦенныеБумаги
	|ИЗ
	|	Справочник.ЦенныеБумаги КАК ЦенныеБумаги
	|ГДЕ
	|	НЕ ЦенныеБумаги.ПометкаУдаления
	|	И ЦенныеБумаги.ISIN <> """"
	|	И &ОтборПоЦБ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЦенныеБумаги.ЦеннаяБумага КАК ЦеннаяБумага,
	|	ЦенныеБумаги.ISIN КАК ISIN,
	|	ОбращаемостьЦБСрезПоследних.МестоОбращаемости КАК МестоОбращаемостиСтарое,
	|	КодыЗагрузки.Код КАК КодРуДата,
	|	ВЫРАЗИТЬ((ЦенныеБумаги.НомерСтроки + 49) / 100 КАК ЧИСЛО(10, 0)) КАК Группировка
	|ИЗ
	|	ЦенныеБумаги КАК ЦенныеБумаги
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ОбращаемостьЦБ.СрезПоследних(&Дата, 1 = 1) КАК ОбращаемостьЦБСрезПоследних
	|		ПО ЦенныеБумаги.ЦеннаяБумага = ОбращаемостьЦБСрезПоследних.ЦеннаяБумага
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.КодыЗагрузки КАК КодыЗагрузки
	|		ПО ЦенныеБумаги.ЦеннаяБумага = КодыЗагрузки.Владелец
	|ГДЕ
	|	ВЫРАЗИТЬ(КодыЗагрузки.Биржа КАК Справочник.КлассификаторыЗагрузки).Ссылка = &RuData
	|	И КодыЗагрузки.ПометкаУдаления = ЛОЖЬ
	|	И ВЫБОР
	|			КОГДА КодыЗагрузки.ДатаНачалаДействия <= &Дата
	|				ТОГДА ИСТИНА
	|			КОГДА КодыЗагрузки.ДатаНачалаДействия = ДАТАВРЕМЯ(1, 1, 1)
	|				ТОГДА ИСТИНА
	|			ИНАЧЕ ЛОЖЬ
	|		КОНЕЦ
	|	И ВЫБОР
	|			КОГДА КодыЗагрузки.ДатаОкончанияДействия > &Дата
	|				ТОГДА ИСТИНА
	|			КОГДА КодыЗагрузки.ДатаНачалаДействия = ДАТАВРЕМЯ(1, 1, 1)
	|				ТОГДА ИСТИНА
	|			ИНАЧЕ ЛОЖЬ
	|		КОНЕЦ
	|
	|УПОРЯДОЧИТЬ ПО
	|	Группировка,
	|	КодРуДата
	|ИТОГИ
	|	КОЛИЧЕСТВО(ЦеннаяБумага)
	|ПО
	|	Группировка";
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Дата", Дата);
	Запрос.УстановитьПараметр("RuData",	 Справочники.КлассификаторыЗагрузки.RuData);
	Если ЗначениеЗаполнено(Isins) Тогда
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "И &ОтборПоЦБ", "И ЦенныеБумаги.ISIN В (&ISIN)");
		Запрос.УстановитьПараметр("ISIN", Isins);
	Иначе
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "И &ОтборПоЦБ", "");
	КонецЕсли;

	Запрос.Текст = ТекстЗапроса;
	Выборка = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	Пока Выборка.Следующий() Цикл
		ВыборкаДетали = Выборка.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам); 
		МассивКодовРуДата = Новый Массив();
		ДанныеЗапроса = Новый Соответствие;
		
		Пока ВыборкаДетали.Следующий() Цикл
			КодРуДаты = СокрЛП(ВыборкаДетали.КодРуДата);
			МассивКодовРуДата.Добавить(КодРуДаты);
			СтруктураЦБ = Новый Структура;
			СтруктураЦБ.Вставить("ЦеннаяБумага", ВыборкаДетали.ЦеннаяБумага);
			СтруктураЦБ.Вставить("МестоОбращаемостиСтарое", ВыборкаДетали.МестоОбращаемостиСтарое);
			ДанныеЗапроса.Вставить(КодРуДаты, СтруктураЦБ);
		КонецЦикла;
		
		ПризнакиОбращаемостиЦБ = ПолучитьОбращаемостьСпискаЦБИзRuDataПоFintoolid(ПараметрыСессии, Дата, МассивКодовРуДата);
		Если ПризнакиОбращаемостиЦБ = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		Для Каждого стр Из ПризнакиОбращаемостиЦБ Цикл
			ПризнакОбращаемостиЦБ = стр.params[0].param;
			МестоОбращаемостиЦБНовое = Перечисления.МестаОбращаемостиЦБ.МестоОбращаемостиЦБ(ПризнакОбращаемостиЦБ);
			
			КодРуДаты = СокрЛП(СтрЗаменить(стр.fintoolId, Символы.НПП, ""));
			КодРуДаты = СокрЛП(СтрЗаменить(КодРуДаты, ",", ""));
			строкаЦБ = ДанныеЗапроса.Получить(КодРуДаты);
			
			Если строкаЦБ = Неопределено Тогда
				Комментарий = "Не найдена ЦБ для установки признака обращаемости по fintoolId: [" + стр.fintoolId + "]";
				ЗаписьЖурналаРегистрации("RuData", УровеньЖурналаРегистрации.Ошибка, , , Комментарий);
				Продолжить;
			КонецЕсли;
			
			МестоОбращаемостиСтарое = строкаЦБ.МестоОбращаемостиСтарое;
			ЦеннаяБумага = строкаЦБ.ЦеннаяБумага;
			УстановитьПризнакОбращаемостиЦБ(ПараметрыСессии, Дата, ЦеннаяБумага, МестоОбращаемостиСтарое, МестоОбращаемостиЦБНовое);
		КонецЦикла;
	КонецЦикла;
	
КонецПроцедуры

