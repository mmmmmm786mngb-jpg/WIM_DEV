Функция СтранаПоКодуИнтерфакс(ТаблицаСтран, ИмяРеквизитаКодСтраны, ЗначениеКодаСтраны)
	
	Страна = Справочники.КлассификаторСтранМира.ПустаяСсылка();
	Если ЗначениеЗаполнено(ТаблицаСтран) И ЗначениеЗаполнено(ЗначениеКодаСтраны) Тогда
		ПараметрыОтбораСтран = Новый Структура(ИмяРеквизитаКодСтраны, ЗначениеКодаСтраны);
		НайденыСтраны = ТаблицаСтран.НайтиСтроки(ПараметрыОтбораСтран);
		Если НайденыСтраны.Количество() > 0 Тогда
			НайденаСтрана = НайденыСтраны[0];
			Если ЗначениеЗаполнено(НайденаСтрана.Страна1С) Тогда
				Страна = НайденаСтрана.Страна1С;
			Иначе
				КодСтраны1С = НайденаСтрана.code_rus;
				КодСтраныСтрокой = Строка(КодСтраны1С);
				КодСтраныСтрокойПоФормату = СтроковыеФункцииКлиентСервер.ДополнитьСтроку(КодСтраныСтрокой, 3);
				Страна = Справочники.КлассификаторСтранМира.НайтиПоКоду(КодСтраныСтрокойПоФормату); // BSLLS:UsingFindElementByString-off
				НайденаСтрана.Страна1С = Страна;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	Возврат Страна;
	
КонецФункции

Функция ЭтоГособлигация(КодВидаЦББанкаРоссии)
	Возврат КодВидаЦББанкаРоссии = "BON1" Или КодВидаЦББанкаРоссии = "BON2";
КонецФункции

Процедура ЗаполнитьПодвидОблигаций(ЦБ, ДанныеЦБ, ВидЦББанкаРоссииRD)
	Если ЗначениеЗаполнено(ДанныеЦБ.ПодвидОблигации) Тогда
		ЦБ.ПодвидОблигаций = ДанныеЦБ.ПодвидОблигации;
	КонецЕсли;
	Если Не ЗначениеЗаполнено(ЦБ.ПодвидОблигаций) Тогда
		Если СтрНайти(ДанныеЦБ.securitytype, "Муни") > 0 Тогда // BSLLS:Typo-off
			ЦБ.ПодвидОблигаций = Перечисления.ПодвидыОблигаций.Муниципальная;
		ИначеЕсли ВидЦББанкаРоссииRD = "BON1" Тогда
			ЦБ.ПодвидОблигаций = Перечисления.ПодвидыОблигаций.РФ;
		ИначеЕсли ВидЦББанкаРоссииRD = "BON2" Тогда
			ЦБ.ПодвидОблигаций = Перечисления.ПодвидыОблигаций.СубъектовРФ;
		Иначе
			ЦБ.ПодвидОблигаций = Перечисления.ПодвидыОблигаций.ПустаяСсылка();
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

#КонецОбласти

Функция НеобходимоОтправитьПисьмоОРезультатахЗагрузкиСтатики(ВходныеПараметры, КоличествоОшибок)
	
	ОтсутствуютISIN = Не ВходныеПараметры.Свойство("ISINs") Или ВходныеПараметры.Свойство("ISINs") И ВходныеПараметры.ISINs.Количество() = 0;
	
	ПричинаОтправки_НаличиеISIN = Не ОтсутствуютISIN;
	ПричинаОтправки_ЕжедневноеОбновление = ОтсутствуютISIN
		И ЗначениеЗаполнено(ВходныеПараметры.ДатаВремяОбновленияДанных) И КоличествоОшибок > 0;
	
	НеобходимоОтправитьПисьмо = ПричинаОтправки_НаличиеISIN Или ПричинаОтправки_ЕжедневноеОбновление;
	
	Возврат НеобходимоОтправитьПисьмо;
	
КонецФункции

Процедура ЗаполнитьКупоныЦенныхБумаг(ТаблицаBondTimeTableCPN, КупонныеОблигации)
	
	Для Каждого КупоннаяОблигация Из КупонныеОблигации Цикл
		ПараметрыПоиска = Новый Структура("fintoolid", КупоннаяОблигация.fintoolid);
		КупонныеПараметры = ТаблицаBondTimeTableCPN.НайтиСтроки(ПараметрыПоиска);
		Если КупонныеПараметры.Количество() > 0 Тогда
			ЦеннаяБумага = КупоннаяОблигация.ЦеннаяБумага.ПолучитьОбъект();
			ЦеннаяБумага.Купоны.Очистить();
			Для Каждого КупонныйПараметр Из КупонныеПараметры Цикл
				НовыйКупон = ЦеннаяБумага.Купоны.Добавить();
				НовыйКупон.НомерКупона			 = КупонныйПараметр.eventID;
				НовыйКупон.Комментарий			 = КупонныйПараметр.note;
				НовыйКупон.Сумма				 = КупонныйПараметр.pay1Bond_frac;
				НовыйКупон.Купон				 = КупонныйПараметр.couponRate;
				НовыйКупон.Ставка				 = КупонныйПараметр.value;
				НовыйКупон.ДатаВыпуска			 = ОбщегоНазначенияКлиентСервер.ПолучитьДатуИзJSON(КупонныйПараметр.beginPeriod, Ложь);
				НовыйКупон.ДатаПогашения		 = ОбщегоНазначенияКлиентСервер.ПолучитьДатуИзJSON(КупонныйПараметр.endPeriod, Ложь);
				НовыйКупон.СрокОбращения		 = ДеньГода(КонецГода(НовыйКупон.ДатаПогашения));
				НовыйКупон.ДатаФиксацииСписка	 = ОбщегоНазначенияКлиентСервер.ПолучитьДатуИзJSON(КупонныйПараметр.fixdate, Ложь);
			КонецЦикла;
			ЦеннаяБумага.ОбменДанными.Загрузка = Истина;
			ЦеннаяБумага.Записать();
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

Процедура ОпределитьЦенныеБумагиДляДополнительныхЗапросов(ПараметрыОпределения, FintoolidAmortisedmty, КупонныеОблигации)
	
	ЦеннаяБумага = ПараметрыОпределения.ЦеннаяБумага;
	ДанныеЦБ	 = ПараметрыОпределения.ДанныеЦБ;
	
	Если ЗначениеЗаполнено(ДанныеЦБ.isin) Тогда
		АмортизационнаяЦБ = ЭтоАмортизируемыйНоминал(ДанныеЦБ);
		Если АмортизационнаяЦБ И ЗначениеЗаполнено(ДанныеЦБ.fintoolid) Тогда
			ПараметрыАмортизацииЦБ = Новый Структура("isin, fintoolid, ЦеннаяБумага");
			ЗаполнитьЗначенияСвойств(ПараметрыАмортизацииЦБ, ДанныеЦБ);
			ПараметрыАмортизацииЦБ.ЦеннаяБумага = ЦеннаяБумага;
			FintoolidAmortisedmty.Добавить(ПараметрыАмортизацииЦБ);
		КонецЕсли;
		
		Если ЦеннаяБумага.КупоннаяОблигация Тогда
			НоваяКупоннаяОблигация = КупонныеОблигации.Добавить();
			НоваяКупоннаяОблигация.fintoolid	 = ДанныеЦБ.fintoolid;
			НоваяКупоннаяОблигация.isin			 = ДанныеЦБ.isin;
			НоваяКупоннаяОблигация.ЦеннаяБумага	 = ЦеннаяБумага;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

