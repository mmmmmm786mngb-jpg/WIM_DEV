#Область ОбработкаОшибок

// Процедура - Добавить уведомление об ошибках загрузки ц биз ru data API
//
// Параметры:
//  ТаблицаОшибок			 - ТаблицаЗначений				 - Таблица произвольного формата с сообщениями об ошибках
//  КлючеваяКолонкаСсылка	 - СправочникСсылка.ЦенныеБумаги - ЦБ
//  ЭтоНовый				 - Булево						 - Признак нового элемента справочника
//  Ошибки					 - Структура					 - Ключ = "ИмяКолонки", Значение = "ТекстСообщения"
//
Процедура ДобавитьУведомлениеОбОшибкахЗагрузкиЦБизRuDataAPI(ТаблицаОшибок, КлючеваяКолонкаСсылка, ЭтоНовый, Ошибки) // BSLLS:Typo-off
	
	Если Ошибки.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	ИмяКлючевойКолонки = "ЦеннаяБумага";
	ТипКлючевойКолонки = Новый ОписаниеТипов("СправочникСсылка.ЦенныеБумаги");
	
	Если ТаблицаОшибок.Колонки.Найти(ИмяКлючевойКолонки) = Неопределено Тогда
		ТаблицаОшибок.Колонки.Добавить("КлючеваяКолонкаКод");
		ТаблицаОшибок.Колонки.Добавить(ИмяКлючевойКолонки, ТипКлючевойКолонки);
		ТаблицаОшибок.Колонки.Добавить("КлючеваяКолонкаISIN");
		ТаблицаОшибок.Колонки.Добавить("Новая");
	КонецЕсли;
	
	ПараметрыОтбора = Новый Структура(ИмяКлючевойКолонки, КлючеваяКолонкаСсылка);
	СтрокиОшибок = ТаблицаОшибок.НайтиСтроки(ПараметрыОтбора);
	Если СтрокиОшибок.Количество() = 0 Тогда
		СтрокаОшибки = ТаблицаОшибок.Добавить();
		СтрокаОшибки.КлючеваяКолонкаКод = КлючеваяКолонкаСсылка.Код;
		СтрокаОшибки.ЦеннаяБумага = КлючеваяКолонкаСсылка;
		СтрокаОшибки.КлючеваяКолонкаISIN = КлючеваяКолонкаСсылка.ISIN;
		СтрокаОшибки.Новая = ?(ЭтоНовый = Истина, "Да", "");
	Иначе
		СтрокаОшибки = СтрокиОшибок.Получить(0);
	КонецЕсли;
	
	Для Каждого Элемент Из Ошибки Цикл
		Если ТаблицаОшибок.Колонки.Найти(Элемент.Ключ) = Неопределено Тогда
			ТаблицаОшибок.Колонки.Добавить(Элемент.Ключ);
		КонецЕсли;
	КонецЦикла;
	
	Для Каждого Элемент Из Ошибки Цикл
		СтрокаОшибки[Элемент.Ключ] = Элемент.Значение;
	КонецЦикла;
	
КонецПроцедуры

Процедура ОтправитьУведомлениеОбОшибкахЗагрузкиЦБизRuDataAPI(ТаблицаОшибок, ТекстПисьмаПредопределенный = "") // BSLLS:Typo-off
	
	Если ТестированиеVanessa.ЭтоТест() Тогда
		Возврат;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(ТаблицаОшибок) И Не ЗначениеЗаполнено(ТекстПисьмаПредопределенный) Тогда
		Возврат;
	КонецЕсли;
	
	ВнешнийИсточник = ПланыВидовХарактеристик.ВнешниеИсточники.РассылкаУведомленийОбОшибкахЗагрузкиЦБизAPIRuData;
	НастройкиОбмена = ВнешниеДанные.ПолучитьПараметрыВнешнегоИсточника(ВнешнийИсточник).Настройка;
	Если НастройкиОбмена = Неопределено Тогда
		ТекстОшибки = "Не заданы параметры внешнего источника """ + Строка(ВнешнийИсточник) + """";
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстОшибки);
		ИмяСобытия = "RuDataAPI";
		ЗаписьЖурналаРегистрации(ИмяСобытия, УровеньЖурналаРегистрации.Ошибка, , , ТекстОшибки);
		Возврат;
	КонецЕсли;
	
	ТемаПисьма = "Уведомление об ошибках загрузки ЦБ из RuDataAPI";
	
	ТекстПисьма = "";
	Если ЗначениеЗаполнено(ТекстПисьмаПредопределенный) Тогда
		ТекстПисьма = "" + Символы.ПС + ТекстПисьмаПредопределенный + Символы.ПС + Символы.ПС;
	КонецЕсли;
	ТекстПисьма = ТекстПисьма + ТекстУведомленияОбОшибкахЗагрузкиЦБизRuDataAPI(ТаблицаОшибок);
	
	ПараметрыУведомления = Новый Соответствие;
	ПараметрыУведомления.Вставить("Вложения",			Неопределено);
	ПараметрыУведомления.Вставить("НастройкиОбмена",	НастройкиОбмена);
	ПараметрыУведомления.Вставить("Кодировка",			"UTF-8");
	ПараметрыУведомления.Вставить("ТемаПисьма",			ТемаПисьма);
	ПараметрыУведомления.Вставить("ТекстПисьма",		ТекстПисьма);
	ПараметрыУведомления.Вставить("ТипТекстаПисьма",	ТипТекстаПочтовогоСообщения.HTML);
	ПараметрыУведомления.Вставить("Важность",			ВажностьИнтернетПочтовогоСообщения.Обычная);
	
	РегистрыСведений.УведомленияКОтправке.ДобавитьУведомлениеКотправке(ПараметрыУведомления);
	
КонецПроцедуры

Функция ТекстУведомленияОбОшибкахЗагрузкиЦБизRuDataAPI(ТаблицаОшибок) // BSLLS:Typo-off
	
	ПС = "<br>";		// Тег HTML означает перевод строки
	ВклBold = "<b>";	// Тег HTML означает включить жирный шрифт
	ОтклBold = "</b>";	// Тег HTML означает отключить жирный шрифт
	
	ТекстЗаголовка = "Уведомления об ошибках загрузки ЦБ из RuDataAPI:" + ПС + Символы.ПС;
	Текст = "<html><BODY>" + Символы.ПС
			+ ТекстЗаголовка + ПС + Символы.ПС;
	
	ПараметрыТрансформацииВHTML = Новый Структура;
	ПараметрыТрансформацииВHTML.Вставить("ПунктПорядкуИспользуется", Истина);
	ПараметрыТрансформацииВHTML.Вставить("ЦветШапки", "eadbaf");
	ПараметрыТрансформацииВHTML.Вставить("ШиринаТаблицы", "1500");
	
	ПараметрыТрансформацииВHTML.Вставить("Заголовок1", "Код 1С");
	ПараметрыТрансформацииВHTML.Вставить("Ширина1", "100");
	
	ПараметрыТрансформацииВHTML.Вставить("Заголовок2", "Ценная бумага");
	ПараметрыТрансформацииВHTML.Вставить("Ширина2", "250");
	ПараметрыТрансформацииВHTML.Вставить("Положение2", "right");
	
	ПараметрыТрансформацииВHTML.Вставить("Заголовок3", "ISIN");
	
	ПараметрыТрансформацииВHTML.Вставить("Заголовок4", "Новая");
	
	Если ТаблицаОшибок.Количество() > 0 Тогда
		ТаблицаОшибокHTML = ОбщегоНазначения.ТаблицаЗначенийВТаблицуHTML(ТаблицаОшибок, ПараметрыТрансформацииВHTML);
		Текст = Текст + ВклBold + ПС + ТаблицаОшибокHTML + ОтклBold + ПС + Символы.ПС;
	КонецЕсли;
	
	Текст = Текст + "</BODY></html>";
	
	Возврат Текст;
КонецФункции

#КонецОбласти

#Область ПогашенныеЦБ

Процедура ЗагрузитьЦБЭмитенты(ISINs)
	
	ФильтрСтатусовЦБ = "'Погашен'";
	ДатаНачала = Дата(1, 1, 1);
	
	ВходныеПараметры = Новый Структура;
	ВходныеПараметры.Вставить("ISINs", ISINs);
	ВходныеПараметры.Вставить("ДатаВремяОбновленияДанных", ДатаНачала);
	ВходныеПараметры.Вставить("ОбновитьЭмитентовВсехЗагружаемыхЦБ", Истина);
	ВходныеПараметры.Вставить("ФильтрСтатусовЦБ", ФильтрСтатусовЦБ);
	
	ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Начало: " + ТекущаяДатаСеанса());
	УспешноеСозданиеОбновлениеЦенныхБумагИЭмитентов = RuDataAPI.СозданиеОбновлениеЦенныхБумагИЭмитентов(ВходныеПараметры);
	ОбщегоНазначенияКлиентСервер.СообщитьПользователю(
		"Завершение: ?успех = [" + УспешноеСозданиеОбновлениеЦенныхБумагИЭмитентов + "] " + ТекущаяДатаСеанса());
	
КонецПроцедуры

Функция СписокПогашенныхЦБСОстатками()
	
	СписокISIN = Новый Массив;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ОстаткиЦБОстатки.ЦБ.ISIN КАК ISIN
		|ИЗ
		|	РегистрНакопления.ОстаткиЦБ.Остатки(
		|			&ДатаОстатков,
		|			ЦБ.ДатаПогашения <= &ДатаОстатков
		|				И ЦБ.ДатаПогашения > &ПустаяДата
		|				И НЕ ЦБ.Дефолтная
		|				И НЕ ЦБ.ПометкаУдаления) КАК ОстаткиЦБОстатки
		|ГДЕ
		|	ОстаткиЦБОстатки.ЦБ.ISIN <> &ПустаяСтрока
		|
		|СГРУППИРОВАТЬ ПО
		|	ОстаткиЦБОстатки.ЦБ.ISIN";
	
	Запрос.УстановитьПараметр("ДатаОстатков", ТекущаяДатаСеанса());
	Запрос.УстановитьПараметр("ПустаяДата", Дата(1, 1, 1));
	Запрос.УстановитьПараметр("ПустаяСтрока", "");
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Если Не РезультатЗапроса.Пустой() Тогда 
		СписокISIN = Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("ISIN");
	КонецЕсли;
	
	Возврат СписокISIN;

КонецФункции

#КонецОбласти

Процедура ЗаполнитьПодвидГосОблигаций(ОписаниеОшибки, Сессия, ТаблицаДанныхЦБ)
	Если Не ЗначениеЗаполнено(ТаблицаДанныхЦБ) Тогда
		Возврат;
	КонецЕсли;
	
	// Отберем fintoolids гособлигаций в массив и отдельно запомним соответствия fintoolid и номера строки таблицы с данными ЦБ
	FintoolidsГосОблигаций = Новый Массив;
	СоответствиеНомераСтрокиИFintoolid = Новый Соответствие;
	Для Каждого ДанныеЦБ Из ТаблицаДанныхЦБ Цикл
		КодВидаЦББанкаРФ = КодВидаЦББанкаРоссии(ДанныеЦБ);
		Если ЭтоГособлигация(КодВидаЦББанкаРФ) Тогда
			FintoolidsГосОблигаций.Добавить(ДанныеЦБ.fintoolid);
			СоответствиеНомераСтрокиИFintoolid.Вставить(ДанныеЦБ.fintoolid, ТаблицаДанныхЦБ.Индекс(ДанныеЦБ));
		КонецЕсли;
	КонецЦикла;
	
	// Получим для списка найденных гособлигаций данные о категориях ЦБ из RuData
	ВходныеПараметры = Новый Структура;
	ВходныеПараметры.Вставить("fintoolids", FintoolidsГосОблигаций);
	ВходныеПараметры.Вставить("filterOnlySpecifiedCategory", "id_category in (450, 540, 541)");
	ВходныеПараметры.Вставить("onlyFintoolsWithCategory", Истина);
	ТаблицаCategoryValue = InfoFintoolCategoryValue(ОписаниеОшибки, Сессия, ВходныеПараметры);
	Если Не ЗначениеЗаполнено(ТаблицаCategoryValue) Тогда
		Возврат;
	КонецЕсли;
	
	// Заполним данные о подвиде облигаций в таблице данных ЦБ
	КодОблигацийРФ = 450;
	КодОблигацийСубъектовРФ = 540;
	КодМуниципальныхОблигаций = 541;
	Для Каждого СтрокаТЗ Из ТаблицаCategoryValue Цикл
		Если СтрокаТЗ.categories.Количество() > 0 Тогда
			fintoolid = СтрокаТЗ.fintoolid;
			id_Category = СтрокаТЗ.categories[0].id_Category;
			Индекс = СоответствиеНомераСтрокиИFintoolid.Получить(fintoolid);
			ДанныеЦБ = ТаблицаДанныхЦБ[Индекс];
			Если id_Category = КодОблигацийРФ Тогда
				ДанныеЦБ.ПодвидОблигации = Перечисления.ПодвидыОблигаций.РФ;
			ИначеЕсли id_Category = КодОблигацийСубъектовРФ Тогда
				ДанныеЦБ.ПодвидОблигации = Перечисления.ПодвидыОблигаций.СубъектовРФ;
			ИначеЕсли id_Category = КодМуниципальныхОблигаций Тогда
				ДанныеЦБ.ПодвидОблигации = Перечисления.ПодвидыОблигаций.Муниципальная;
			Иначе
				ДанныеЦБ.ПодвидОблигации = Перечисления.ПодвидыОблигаций.ПустаяСсылка();
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

Функция КодВидаЦББанкаРоссии(ДанныеЦБ)
	КодВидаЦББанкаРоссии = ?(ЗначениеЗаполнено(ДанныеЦБ.sec_type_br_code3), ДанныеЦБ.sec_type_br_code3, ДанныеЦБ.sec_type_br_code2);
	
	Возврат КодВидаЦББанкаРоссии;
КонецФункции

