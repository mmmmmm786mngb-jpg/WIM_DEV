#Область СозданиеОбновлениеСправочников

Процедура СоздатьЗаписьКонтактнаяИнформация(Данные, Знач Период)
	
	Если Не ЗначениеЗаполнено(Период) Тогда
		Период = НачалоДня(ТекущаяДатаСеанса());
	КонецЕсли;
	
	НаборКонтактнаяИнформация = РегистрыСведений.КонтактнаяИнформация.СоздатьНаборЗаписей();
	НаборКонтактнаяИнформация.Отбор.Объект.Установить(Данные.Объект, Истина);
	НаборКонтактнаяИнформация.Отбор.Тип.Установить(Данные.Тип, Истина);
	НаборКонтактнаяИнформация.Отбор.Вид.Установить(Данные.Вид, Истина);
	
	Запись = НаборКонтактнаяИнформация.Добавить();
	ЗаполнитьЗначенияСвойств(Запись, Данные);
	Запись.Период = Период;
	Если Данные.Тип = Перечисления.ТипыКонтактнойИнформации.Адрес Тогда
		СтранаАдреса = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Данные.Объект, "Страна");
		Если СтранаАдреса = Справочники.КлассификаторСтранМира.РОССИЯ Тогда
			ДлинаИндекса = 6;
			Запись.ЭтоРоссийскийАдрес = Истина;
			Индекс = СокрЛП(Лев(Данные.Представление, ДлинаИндекса));
			Если СтрДлина(Индекс) = ДлинаИндекса И ОбщегоНазначенияКлиентСервер.ЭтоЧисло(Индекс) Тогда
				Запись.Поле1 = Индекс;
			Иначе
				Запись.Поле1 = "";
			КонецЕсли; 
		Иначе
			Запись.ЭтоРоссийскийАдрес = Ложь;
			Запись.Поле1 = СтранаАдреса;
		КонецЕсли;
	КонецЕсли;
	
	Попытка
		НаборКонтактнаяИнформация.ОбменДанными.Загрузка = Истина;
		НаборКонтактнаяИнформация.Записать();
	Исключение
		ТекстОшибки = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		ЗаписьЖурналаРегистрации("RuDataAPI.СоздатьЗаписьКонтактнаяИнформация", УровеньЖурналаРегистрации.Предупреждение, , , ТекстОшибки);
	КонецПопытки;
	
КонецПроцедуры

// BSLLS:CognitiveComplexity-off
// BSLLS:CyclomaticComplexity-off

Процедура СоздатьОбновитьЮрлицоЭмитента(ДанныеЮрЛица, ПараметрыКИ, КредитныеОрганизации, КодыРегистрации)
	
	КодСтраныРоссия = 643;
	ГраничнаяДатаПервичнойРегистрации = Дата("20020701");
	
	Если ЗначениеЗаполнено(ДанныеЮрЛица.ЮрЛицо) Тогда
		ЮрЛицо = ДанныеЮрЛица.ЮрЛицо.ПолучитьОбъект();
		Если ЮрЛицо.Заблокирован() = Истина Тогда
			Возврат;
		Иначе
			ЮрЛицо.Заблокировать();
		КонецЕсли;
		ЭмитентСсылка = Справочники.Контрагенты.КонтрагентПоЮрФизЛицу(ЮрЛицо.Ссылка);
	Иначе
		ЮрЛицо = Справочники.ЮридическиеЛица.СоздатьЭлемент();
		ЮрЛицо.Код = "RuDataE" + СтроковыеФункцииКлиентСервер.ДополнитьСтроку(ДанныеЮрЛица.fininstid, 13);
		ЭмитентСсылка = Неопределено;
	КонецЕсли;
	
	// Наименование юр. лица
	Если ЗначениеЗаполнено(ДанныеЮрЛица.shortname_rus_nrd) Тогда
		ЮрЛицо.Наименование = ДанныеЮрЛица.shortname_rus_nrd;
	Иначе
		Если ЗначениеЗаполнено(ДанныеЮрЛица.shortname_rus) Тогда 
			ЮрЛицо.Наименование = ДанныеЮрЛица.shortname_rus;
		КонецЕсли;
	КонецЕсли;
	Если ДанныеЮрЛица.country_oksm = КодСтраныРоссия Тогда
		ЮрЛицо.НеРезидент = ЮрЛицо.МеждународнаяКомпания;
		Если ЗначениеЗаполнено(ДанныеЮрЛица.fullname_rus_nrd) Тогда
			ЮрЛицо.ПолноеНаименование = ДанныеЮрЛица.fullname_rus_nrd;
		Иначе
			Если ЗначениеЗаполнено(ДанныеЮрЛица.fullname_rus) Тогда 
				ЮрЛицо.ПолноеНаименование = ДанныеЮрЛица.fullname_rus;
			КонецЕсли;
		КонецЕсли;
	Иначе
		ЮрЛицо.НеРезидент = Истина;
		Если ЗначениеЗаполнено(ДанныеЮрЛица.fullname_eng_nrd) Тогда
			ЮрЛицо.ПолноеНаименование = ДанныеЮрЛица.fullname_eng_nrd;
		Иначе
			Если ЗначениеЗаполнено(ДанныеЮрЛица.shortname_eng) Тогда 
				ЮрЛицо.ПолноеНаименование = ДанныеЮрЛица.shortname_eng;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	Если ЗначениеЗаполнено(ДанныеЮрЛица.fullname_eng_nrd) Тогда
		ЮрЛицо.ПолноеНаименованиеНаАнглийскомЯзыке = ДанныеЮрЛица.fullname_eng_nrd;
	Иначе
		Если ЗначениеЗаполнено(ДанныеЮрЛица.fullname_rus) Тогда 
			ЮрЛицо.ПолноеНаименованиеНаАнглийскомЯзыке = ОбщегоНазначенияКлиентСервер.Транслит(ДанныеЮрЛица.fullname_rus);
		КонецЕсли;
	КонецЕсли;
	
	// ИНН юр. лица
	Если ЗначениеЗаполнено(ДанныеЮрЛица.inn_fle) Тогда
		ЮрЛицо.ИНН = ДанныеЮрЛица.inn_fle;
	Иначе
		Если ЗначениеЗаполнено(ДанныеЮрЛица.inn) Тогда
			Если ДанныеЮрЛица.inn <> ДанныеЮрЛица.tin Тогда
				ЮрЛицо.ИНН = ДанныеЮрЛица.inn;
			Иначе
				ЮрЛицо.ИНН = "";
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	// Прочие поля юр. лица
	ЮрЛицо.TIN		  = ?(ЗначениеЗаполнено(ДанныеЮрЛица.tin), ДанныеЮрЛица.tin, ЮрЛицо.TIN);
	ЮрЛицо.КПП		  = ?(ЗначениеЗаполнено(ДанныеЮрЛица.kpp), ДанныеЮрЛица.kpp, ЮрЛицо.КПП);
	ЮрЛицо.КодПоОКПО  = ?(ЗначениеЗаполнено(ДанныеЮрЛица.okpo), ДанныеЮрЛица.okpo, ЮрЛицо.КодПоОКПО);
	ЮрЛицо.ОГРН		  = ?(ЗначениеЗаполнено(ДанныеЮрЛица.ogrn), ДанныеЮрЛица.ogrn, ЮрЛицо.ОГРН);
	
	ЮрЛицо.РегистрирующийОрган = ?(ЗначениеЗаполнено(ДанныеЮрЛица.state_reg_name), ДанныеЮрЛица.state_reg_name, ЮрЛицо.РегистрирующийОрган);
	Если Не ЗначениеЗаполнено(ЮрЛицо.РегистрирующийОрган) Тогда
		ЮрЛицо.РегистрирующийОрган = ДанныеЮрЛица.egrul_organ_name;
	КонецЕсли;
	ЮрЛицо.ОКОПФ		 = ?(ЗначениеЗаполнено(ДанныеЮрЛица.okopf), ДанныеЮрЛица.okopf, ЮрЛицо.ОКОПФ);
	ЮрЛицо.ОКОГУ		 = ?(ЗначениеЗаполнено(ДанныеЮрЛица.okogu), ДанныеЮрЛица.okogu, ЮрЛицо.ОКОГУ);
	ЮрЛицо.КодПоОКВЭД	 = ?(ЗначениеЗаполнено(ДанныеЮрЛица.okved), ДанныеЮрЛица.okved, ЮрЛицо.КодПоОКВЭД);
	Если ЗначениеЗаполнено(ДанныеЮрЛица.country_oksm) Тогда
		КодСтраныСтрокой = Строка(ДанныеЮрЛица.country_oksm);
		КодСтраныСтрокойПоФормату = СтроковыеФункцииКлиентСервер.ДополнитьСтроку(КодСтраныСтрокой, 3);
		ЮрЛицо.Страна = Справочники.КлассификаторСтранМира.НайтиПоКоду(КодСтраныСтрокойПоФормату); // BSLLS:UsingFindElementByString-off
	КонецЕсли;
	ЮрЛицо.ДатаГосРегистрации		 = ?(ЗначениеЗаполнено(ДанныеЮрЛица.state_reg_date), ДанныеЮрЛица.state_reg_date, ЮрЛицо.ДатаГосРегистрации);
	Если Не ЗначениеЗаполнено(ЮрЛицо.ДатаГосРегистрации) Тогда
		Если ЗначениеЗаполнено(ДанныеЮрЛица.reg_date) Тогда
			ЮрЛицо.ДатаГосРегистрации = ДанныеЮрЛица.reg_date;
		Иначе
			ЮрЛицо.ДатаГосРегистрации = ДанныеЮрЛица.primary_reg_date;
		КонецЕсли;
	КонецЕсли;
	Если ДанныеЮрЛица.country_oksm = КодСтраныРоссия Тогда
		ЮрЛицоРегНомер = "";
		Если ЗначениеЗаполнено(КодыРегистрации) Тогда
			ПараметрыПоискаКодаРегистрации = Новый Структура("fininstid", ДанныеЮрЛица.fininstid);
			НайденыКодыРегистрации = КодыРегистрации.НайтиСтроки(ПараметрыПоискаКодаРегистрации);
			Если НайденыКодыРегистрации.Количество() = 1 Тогда
				ЮрЛицоРегНомер = НайденыКодыРегистрации[0].code;
			КонецЕсли;
		КонецЕсли;
		Если ЗначениеЗаполнено(ЮрЛицоРегНомер) Тогда
			ЮрЛицо.РегНомер = ЮрЛицоРегНомер;
		Иначе
			НомерПервичнойРегистрации =
				?(ЗначениеЗаполнено(ДанныеЮрЛица.state_reg_number), ДанныеЮрЛица.state_reg_number, ДанныеЮрЛица.state_reg_num);
			ЕстьДатаНомерПервичнойРегистрации = ЗначениеЗаполнено(ДанныеЮрЛица.state_reg_date)
				И ДанныеЮрЛица.state_reg_date < ГраничнаяДатаПервичнойРегистрации И ЗначениеЗаполнено(НомерПервичнойРегистрации);
			Если ЕстьДатаНомерПервичнойРегистрации Тогда
				ЮрЛицо.РегНомер = НомерПервичнойРегистрации;
			Иначе
				ЮрЛицо.РегНомер = ?(ЗначениеЗаполнено(ДанныеЮрЛица.reg_code), ДанныеЮрЛица.reg_code, ЮрЛицо.РегНомер);
			КонецЕсли;
		КонецЕсли;
	Иначе
		ЮрЛицо.РегНомер = ?(ЗначениеЗаполнено(ДанныеЮрЛица.reg_code), ДанныеЮрЛица.reg_code, ЮрЛицо.РегНомер);
	КонецЕсли;
	ЮрЛицо.ДатаВнесенияВЕГРЮЛ		 = ?(ЗначениеЗаполнено(ДанныеЮрЛица.egrul_date), ДанныеЮрЛица.egrul_date, ЮрЛицо.ДатаВнесенияВЕГРЮЛ);
	ЭтоКредитнаяОрганизация = ЗначениеЗаполнено(ДанныеЮрЛица.credit_cmp) И ДанныеЮрЛица.credit_cmp = "1"
		Или КредитныеОрганизации.Найти(ДанныеЮрЛица.fininstid) <> Неопределено;
	ЮрЛицо.КредитнаяОрганизация = ЭтоКредитнаяОрганизация;
	
	ЮрЛицо.ОбменДанными.Загрузка = Истина;
	ЮрЛицо.Записать();
	ЮрЛицоСсылка = ЮрЛицо.Ссылка;
	
	// Коды загрузки LEI юр. лица
	СоздаемКодЗагрузки = Ложь;
	Если ЗначениеЗаполнено(ДанныеЮрЛица.lei_code) Тогда
		СоздатьОбновитьКодЗагрузки(ЮрЛицоСсылка, Справочники.КлассификаторыЗагрузки.LEI_Code, ДанныеЮрЛица.lei_code, СоздаемКодЗагрузки);
	КонецЕсли;
	// Коды загрузки юр. лица
	СоздаемКодЗагрузки = Истина;
	Если ЗначениеЗаполнено(ДанныеЮрЛица.fininstid) И Не ЗначениеЗаполнено(ДанныеЮрЛица.КодЗагрузкиRuData) Тогда
		СоздатьОбновитьКодЗагрузки(ЮрЛицоСсылка, Справочники.КлассификаторыЗагрузки.RuData, ДанныеЮрЛица.fininstid, СоздаемКодЗагрузки);
	КонецЕсли;
	Если ЗначениеЗаполнено(ДанныеЮрЛица.issuer_nrd) И Не ЗначениеЗаполнено(ДанныеЮрЛица.КодЗагрузкиНДЦ) Тогда
		СоздатьОбновитьКодЗагрузки(ЮрЛицоСсылка, Справочники.КлассификаторыЗагрузки.НДЦ(), ДанныеЮрЛица.issuer_nrd, СоздаемКодЗагрузки);
	КонецЕсли;
	
	// Регистры сведений связанные с юр. лицом
	ЕстьЮридическийАдрес = Ложь;
	ИмяРеквизитаСтруктурыОбъект			 = "Объект";
	ИмяРеквизитаСтруктурыТип			 = "Тип";
	ИмяРеквизитаСтруктурыВид			 = "Вид";
	ИмяРеквизитаСтруктурыПредставление	 = "Представление";
	Если ЗначениеЗаполнено(ДанныеЮрЛица.post_address) Тогда
		Данные = Новый Структура;
		Данные.Вставить(ИмяРеквизитаСтруктурыОбъект			, ЮрЛицоСсылка);
		Данные.Вставить(ИмяРеквизитаСтруктурыТип			, ПараметрыКИ.ТипАдрес);
		Данные.Вставить(ИмяРеквизитаСтруктурыВид			, ПараметрыКИ.ВидФактическийАдрес);
		Данные.Вставить(ИмяРеквизитаСтруктурыПредставление	, ДанныеЮрЛица.post_address);
		СоздатьЗаписьКонтактнаяИнформация(Данные, ПараметрыКИ.Период);
	КонецЕсли;
	Если ЗначениеЗаполнено(ДанныеЮрЛица.legal_address) Тогда
		ЕстьЮридическийАдрес = Истина;
		Данные = Новый Структура;
		Данные.Вставить(ИмяРеквизитаСтруктурыОбъект			, ЮрЛицоСсылка);
		Данные.Вставить(ИмяРеквизитаСтруктурыТип			, ПараметрыКИ.ТипАдрес);
		Данные.Вставить(ИмяРеквизитаСтруктурыВид			, ПараметрыКИ.ВидЮридическийАдрес);
		Данные.Вставить(ИмяРеквизитаСтруктурыПредставление	, ДанныеЮрЛица.legal_address);
		СоздатьЗаписьКонтактнаяИнформация(Данные, ПараметрыКИ.Период);
	КонецЕсли;
	Если ЗначениеЗаполнено(ДанныеЮрЛица.e_mail) Тогда
		Данные = Новый Структура;
		Данные.Вставить(ИмяРеквизитаСтруктурыОбъект			, ЮрЛицоСсылка);
		Данные.Вставить(ИмяРеквизитаСтруктурыТип			, ПараметрыКИ.ТипАдресЭлектроннойПочты);
		Данные.Вставить(ИмяРеквизитаСтруктурыВид			, ПараметрыКИ.ВидАдресЭлектроннойПочты);
		Данные.Вставить(ИмяРеквизитаСтруктурыПредставление	, ДанныеЮрЛица.e_mail);
		СоздатьЗаписьКонтактнаяИнформация(Данные, ПараметрыКИ.Период);
	КонецЕсли;
	Если ЗначениеЗаполнено(ДанныеЮрЛица.phone) Тогда
		Данные = Новый Структура;
		Данные.Вставить(ИмяРеквизитаСтруктурыОбъект			, ЮрЛицоСсылка);
		Данные.Вставить(ИмяРеквизитаСтруктурыТип			, ПараметрыКИ.ТипТелефон);
		Данные.Вставить(ИмяРеквизитаСтруктурыВид			, ПараметрыКИ.ВидТелефон);
		Данные.Вставить(ИмяРеквизитаСтруктурыПредставление	, ДанныеЮрЛица.phone);
		СоздатьЗаписьКонтактнаяИнформация(Данные, ПараметрыКИ.Период);
	КонецЕсли;
	
	// Данные Эмитента
	Если ЗначениеЗаполнено(ЭмитентСсылка) Тогда
		Эмитент = ЭмитентСсылка.ПолучитьОбъект();
		Если Эмитент.Заблокирован() = Истина Тогда
			Возврат;
		Иначе
			Эмитент.Заблокировать();
		КонецЕсли;
	Иначе
		Эмитент = Справочники.Контрагенты.СоздатьЭлемент();
		Эмитент.Код = "RuDataE" + СтроковыеФункцииКлиентСервер.ДополнитьСтроку(ДанныеЮрЛица.fininstid, 13);
		Эмитент.Родитель = Справочники.Контрагенты.Эмитенты;
	КонецЕсли;
	
	Эмитент.ЮрФизЛицо = Перечисления.ЮрФизЛицо.ЮрЛицо;
	Эмитент.ЮридическиеФизическиеЛица = ЮрЛицоСсылка;
	Эмитент.Контрагент = Истина;
	Эмитент.Наименование		 = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ЮрЛицоСсылка, "Наименование");
	Если ДанныеЮрЛица.country_oksm = КодСтраныРоссия Тогда
		Эмитент.ИНН 				 = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ЮрЛицоСсылка, "ИНН");
	Иначе
		Если Не ЗначениеЗаполнено(Эмитент.СекторЭкономикиИностранногоЭмитента) Тогда
			СекторЭкономикиИностранногоЭмитента
				= Справочники.КлассификаторСекторовЭкономикиДляИностранныхЭмитентов.НайтиПоКоду(ДанныеЮрЛица.sector4212u);
			Если ЗначениеЗаполнено(СекторЭкономикиИностранногоЭмитента) Тогда
				Эмитент.СекторЭкономикиИностранногоЭмитента = СекторЭкономикиИностранногоЭмитента;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	Эмитент.КПП					 = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ЮрЛицоСсылка, "КПП");
	Эмитент.КодПоОКПО			 = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ЮрЛицоСсылка, "КодПоОКПО");
	Эмитент.ОКВЭД				 = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ЮрЛицоСсылка, "КодПоОКВЭД");
	Эмитент.ОГРН				 = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ЮрЛицоСсылка, "ОГРН");
	Эмитент.НаименованиеПолное	 = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ЮрЛицоСсылка, "ПолноеНаименование");
	Эмитент.TIN					 = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ЮрЛицоСсылка, "TIN");
	// Важно, что реквизит Резидент в справочнике контрагентов, как это ни парадоксально, означает
	// "Нерезидент по документам", а в справочнике Юрлиц реквизит с аналогичным значением называется
	// правильно - НеРезидент. Живите теперь с этим, если не знали раньше
	Эмитент.Резидент			 = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ЮрЛицоСсылка, "НеРезидент");
	Если Эмитент.Резидент И Не Эмитент.РегионДляОтчетовРучнойВвод Тогда
		Эмитент.РегионДляОтчетов = Неопределено;
	КонецЕсли;
	
	Эмитент.ОбменДанными.Загрузка = Истина;
	Попытка
		Эмитент.Записать();
		Если ЕстьЮридическийАдрес Тогда
			Справочники.КлассификаторРегионов.УстановитьРегионДляКонтрагентов(ЮрЛицоСсылка);
		КонецЕсли;
	Исключение
		ТекстОшибки = "Эмитент [" + Эмитент.Наименование + "] :" + ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		ЗаписьЖурналаРегистрации("RuDataAPI.СоздатьЗаписьЭмитента", УровеньЖурналаРегистрации.Предупреждение, , , ТекстОшибки);
	КонецПопытки;
	
КонецПроцедуры

// BSLLS:MethodSize-off

Функция СоздатьОбновитьЦеннуюБумагу(ДанныеЦБ, ПараметрыКИ, ТаблицаОшибок, ВыходныеПараметры)
	
	Ошибки = Новый Структура;
	
	ДатаНачалаУчета = Дата("20000101");
	
	ТаблицаСтран = ВыходныеПараметры.ТаблицаСтран;
	ТаблицаВалют = ВыходныеПараметры.ТаблицаВалют;
	
	Если ЗначениеЗаполнено(ДанныеЦБ.ЦБ) Тогда
		ЦБ = ДанныеЦБ.ЦБ.ПолучитьОбъект();
		Если ЦБ.Заблокирован() = Истина Тогда
			Ошибки.Вставить("ЦБ_Объект", "Был блокирован");
			ДобавитьУведомлениеОбОшибкахЗагрузкиЦБизRuDataAPI(ТаблицаОшибок, ЦБ.Ссылка, ДанныеЦБ.ЭтоНоваяЦБ, Ошибки);
			Возврат ЦБ.Ссылка;
		Иначе
			ЦБ.Заблокировать();
		КонецЕсли;
	Иначе
		ЦБ = Справочники.ЦенныеБумаги.СоздатьЭлемент();
		Если ЗначениеЗаполнено(ДанныеЦБ.nrdcode) Тогда
			ЦБ.Код = СокрЛП(ДанныеЦБ.nrdcode);
		Иначе
			ЦБ.Код = "RuData" + СтроковыеФункцииКлиентСервер.ДополнитьСтроку(ДанныеЦБ.fintoolid, 14);
		КонецЕсли;
	КонецЕсли;
	
	ЦБ.Дефолтная = ДанныеЦБ.status_name = "Дефолт" Или ДанныеЦБ.havedefault = 1;
	Если ЦБ.Дефолтная И Не ЗначениеЗаполнено(ЦБ.ДатаДефолта) Тогда
		Если ЗначениеЗаполнено(ДанныеЦБ.update_date) Тогда
			ЦБ.ДатаДефолта = ДанныеЦБ.update_date;
		Иначе
			ЦБ.ДатаДефолта = ПараметрыКИ.Период;
		КонецЕсли;
	КонецЕсли;
	Если Не ЦБ.Дефолтная И ЗначениеЗаполнено(ЦБ.ДатаДефолта) Тогда
		ЦБ.ДатаДефолта = Дата(1, 1, 1);
	КонецЕсли;
	
	ЭмитентRuData = ЭмитентЦБ(ДанныеЦБ.fininstid);
	Если ЗначениеЗаполнено(ЭмитентRuData) Тогда
		ЦБ.Эмитент = ЭмитентRuData;
	КонецЕсли;
	Если Не ЗначениеЗаполнено(ЦБ.Эмитент) Тогда
		Ошибки.Вставить("Эмитент", "fininstid = [" + ДанныеЦБ.fininstid + "]");
	КонецЕсли;
	
	ЦБ.ПолноеНаименование = ДанныеЦБ.ПолноеНаименование;
	ЦБ.ISIN = ДанныеЦБ.isin;
	ЦБ.CFI = ДанныеЦБ.cfi;
	
	НФИДоИзменения = ЦБ.НФИ;
	Если Не ЗначениеЗаполнено(ЦБ.CFI) И Не MarketData.ЭтоЦБRu(ЦБ.ISIN) Тогда
		ЦБ.НФИ = 1;
	Иначе
		ЦБ.НФИ = 0;
	КонецЕсли;
	СменилосьНФИ = Не ДанныеЦБ.ЭтоНоваяЦБ И НФИДоИзменения <> ЦБ.НФИ;
	
	ЦБ.ТипВыпуска = ДанныеЦБ.securitytype;
	ЦБ.ТипНоминала = ДанныеЦБ.nominaltype;
	ЦБ.ИндексируемыйНоминал = ЭтоИндексируемыйНоминал(ДанныеЦБ);
	ЦБ.АмортизационнаяЦБ = ЭтоАмортизируемыйНоминал(ДанныеЦБ);
	ЦБ.ДатаГосРег = ДанныеЦБ.regdate;
	Если Не ЗначениеЗаполнено(ЦБ.НомерРегистрации) Тогда
		ЦБ.НомерРегистрации = ДанныеЦБ.reg_code;
	КонецЕсли;
	ЦБ.ДатаПогашения = ДанныеЦБ.endmty_date;
	ЦБ.ДатаРазмещения = ДанныеЦБ.begdistdate;
	ЦБ.ДляКвалифицированныхИнвесторов = ЗначениеЗаполнено(ДанныеЦБ.isqualified_nrd);
	ЦБ.ДокументарнаяБездокументарная = СтрНайти(ДанныеЦБ.secformnamerus_nrd, "Бездокументарная") = 0;
	ЦБ.ФормаВыпуска = ?(ЦБ.ДокументарнаяБездокументарная,
		Перечисления.ФормаВыпускаЦБ.Документарная,
		Перечисления.ФормаВыпускаЦБ.Бездокументарная);
	ЦБ.ДополнительныеСведения = ДанныеЦБ.note;
	ЦБ.Дробная = СтрНайти(ДанныеЦБ.securitykind, "Дробная") > 0;
	ЦБ.Знаменатель = ДанныеЦБ.shqty;
	ЦБ.Числитель = ДанныеЦБ.drqty;
	// BSLLS:Typo-off
	ЦБ.ИменнаяНаПредьявителя = СтрНайти(ДанныеЦБ.secformnamerus_nrd, "именная") > 0;
	ЦБ.УдостоверениеПравообладания = ?(ЦБ.ИменнаяНаПредьявителя,
		Перечисления.ФормаУдостоверенияПравообладания.Именные,
		Перечисления.ФормаУдостоверенияПравообладания.НаПредъявителя);
	// BSLLS:Typo-on
	ЦБ.ОбъемРазмещения = ДанныеЦБ.summarketvol;
	ЦБ.РазрядностьНКД = ДанныеЦБ.numdecimals;
	ЦБ.СтавкаНалога = ДанныеЦБ.tax_rate;
	
	Если ЗначениеЗаполнено(ДанныеЦБ.base_asset_fintoolid) Тогда
		ЦББазовыйАктив = Справочники.ЦенныеБумаги.ЦеннаяБумагаПоКодуRuData(ДанныеЦБ.base_asset_fintoolid, ДанныеЦБ.isincodebase_nrd);
		Если ЗначениеЗаполнено(ЦББазовыйАктив) Тогда
			ЦБ.БазовыйАктив = ЦББазовыйАктив;
		КонецЕсли;
	КонецЕсли;
	Если ЦБ.Знаменатель <> 0 И ЦБ.Числитель <> 0 Тогда
		ЦБ.КоличествоБазовогоАктива = ЦБ.Числитель / ЦБ.Знаменатель;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(ЦБ.ТипЦБ) Или СменилосьНФИ Тогда
		Если ДанныеЦБ.fintooltype = "Акция" Тогда
			ЦБ.ТипЦБ = Перечисления.ТипыЦБ.Акция;
		ИначеЕсли ДанныеЦБ.fintooltype = "Депозитарная расписка" Тогда
			ЦБ.ТипЦБ = Перечисления.ТипыЦБ.ДепозитарнаяРасписка;
		ИначеЕсли ДанныеЦБ.fintooltype = "Облигация" Тогда
			ЦБ.ТипЦБ = Перечисления.ТипыЦБ.Облигация;
		ИначеЕсли ДанныеЦБ.fintooltype = "Ипотечный сертификат" Тогда
			ЦБ.ТипЦБ = Перечисления.ТипыЦБ.Пай;
		ИначеЕсли ДанныеЦБ.fintooltype = "Фонд" Тогда
			Если СтрНайти(ДанныеЦБ.securitytype, "КСУ") > 0 Тогда
				ЦБ.ТипЦБ = Перечисления.ТипыЦБ.КлиринговыйСертификатУчастия;
			Иначе
				ЦБ.ТипЦБ = Перечисления.ТипыЦБ.Пай;
			КонецЕсли;
		Иначе
			Ошибки.Вставить("ТипЦБ", "fintooltype = [" + ДанныеЦБ.fintooltype + "] ;securitytype = [" + ДанныеЦБ.securitytype + "]");
		КонецЕсли;
	КонецЕсли;
	
	ЦБ.ВидВыпуска = ДанныеЦБ.securitykind2;
	
	ЦБ.НазваниеРеальногоЭмитента = ДанныеЦБ.borrowername;
	ИмяРеквизитаКодСтраны = "code2_eng";
	ЦБ.СтранаРеальногоЭмитента = СтранаПоКодуИнтерфакс(ТаблицаСтран, ИмяРеквизитаКодСтраны, ДанныеЦБ.borrowercountry);
	ЦБ.СтранаНахожденияАктивовРеальногоЭмитента = СтранаПоКодуИнтерфакс(ТаблицаСтран, ИмяРеквизитаКодСтраны, ДанныеЦБ.original_country);
	ЦБ.Страна = СтранаПоКодуИнтерфакс(ТаблицаСтран, ИмяРеквизитаКодСтраны, ДанныеЦБ.country);
	ЦБ.БазисРасчетаНКД = ДанныеЦБ.basis;
	ЦБ.СтатусRuData = ДанныеЦБ.status_name;
	ЦБ.ЦБДопущенаКТоргамВРФ = ДанныеЦБ.ЦБДопущенаКТоргамВРФ;
	// BSLLS:Typo-off
	ЦБ.КвазироссийскаяЦБ = (ЦБ.СтранаРеальногоЭмитента = Справочники.КлассификаторСтранМира.РОССИЯ
								Или ЦБ.СтранаНахожденияАктивовРеальногоЭмитента = Справочники.КлассификаторСтранМира.РОССИЯ)
		И Справочники.КлассификаторСтранМира.СтранаЭмитента(ЦБ.Эмитент) <> Справочники.КлассификаторСтранМира.РОССИЯ;
	// BSLLS:Typo-on
	
	Если ЦБ.ТипЦБ = Перечисления.ТипыЦБ.ДепозитарнаяРасписка Тогда
		ЦБ.Наименование = ?(ЗначениеЗаполнено(ДанныеЦБ.fullname_rus), ДанныеЦБ.fullname_rus, ДанныеЦБ.shortname_rus);
	ИначеЕсли ЦБ.ТипЦБ = Перечисления.ТипыЦБ.Пай Тогда
		Если ЗначениеЗаполнено(ДанныеЦБ.fullname_nrd) Тогда
			ЦБ.Наименование = ДанныеЦБ.fullname_nrd;
		Иначе
			ЦБ.Наименование = ?(ЗначениеЗаполнено(ДанныеЦБ.shortname_rus), ДанныеЦБ.shortname_rus, ДанныеЦБ.issuername_nrd);
		КонецЕсли;
	ИначеЕсли ЦБ.ТипЦБ = Перечисления.ТипыЦБ.КлиринговыйСертификатУчастия Тогда
		Если ЗначениеЗаполнено(ДанныеЦБ.sectypenamerus_nrd2) Тогда
			ЦБ.Наименование = ДанныеЦБ.sectypenamerus_nrd2;
		Иначе
			ЦБ.Наименование = ?(ЗначениеЗаполнено(ДанныеЦБ.shortname_rus), ДанныеЦБ.shortname_rus, ДанныеЦБ.issuername_nrd);
		КонецЕсли;
	Иначе
		ЦБ.Наименование = ?(ЗначениеЗаполнено(ДанныеЦБ.issuername_nrd), ДанныеЦБ.issuername_nrd, ДанныеЦБ.shortname_rus);
	КонецЕсли;
	ЦБ.АнглийскоеНаименование
		= ?(ЗначениеЗаполнено(ДанныеЦБ.fullname_en_nrd), ДанныеЦБ.fullname_en_nrd, ОбщегоНазначенияКлиентСервер.Транслит(ЦБ.Наименование));
	
	ВидЦББанкаРоссииRD = КодВидаЦББанкаРоссии(ДанныеЦБ);
	Если ЦБ.НФИ Тогда
		ЦБ.ВидЦББанкаРоссии = Справочники.ВидыЦББанкаРоссии.НайтиПоКоду("OTHER"); // BSLLS:UsingFindElementByString-off
	ИначеЕсли ЦБ.ТипЦБ = Перечисления.ТипыЦБ.КлиринговыйСертификатУчастия Тогда
		ЦБ.ВидЦББанкаРоссии = Справочники.ВидыЦББанкаРоссии.НайтиПоКоду("KSU"); // BSLLS:UsingFindElementByString-off
	Иначе
		ЦБ.ВидЦББанкаРоссии = Справочники.ВидыЦББанкаРоссии.НайтиПоКоду(ВидЦББанкаРоссииRD); // BSLLS:UsingFindElementByString-off
	КонецЕсли;
	Если Не ЗначениеЗаполнено(ЦБ.ВидЦББанкаРоссии) Тогда
		Ошибки.Вставить("ВидЦББанкаРоссии", "sec_type_br_code = [" + ВидЦББанкаРоссииRD + "]");
	КонецЕсли;
	
	// BSLLS:IfElseIfEndsWithElse-off
	Если ЦБ.ТипЦБ = Перечисления.ТипыЦБ.Акция Тогда
		ВидЦБПолучен = Истина;
		Если ДанныеЦБ.securitytype = "Обыкн-ая" Тогда // BSLLS:Typo-off
			ЦБ.ВидЦБ = Перечисления.ВидыАкций.Обыкновенная;
		ИначеЕсли ДанныеЦБ.securitytype = "Привилег-ая" Тогда // BSLLS:Typo-off
			ЦБ.ВидЦБ = Перечисления.ВидыАкций.Привилегированная;
		Иначе
			Если ДанныеЦБ.share_category_name_nrd = "обыкновенные" Тогда
				ЦБ.ВидЦБ = Перечисления.ВидыАкций.Обыкновенная;
			ИначеЕсли ДанныеЦБ.securitytype = "привилегированные" Тогда
				ЦБ.ВидЦБ = Перечисления.ВидыАкций.Привилегированная;
			Иначе
				ВидЦБПолучен = Ложь;
			КонецЕсли;
		КонецЕсли;
		Если Не ВидЦБПолучен И Не ЗначениеЗаполнено(ЦБ.ВидЦБ) Тогда
			Если СтрНайти(ДанныеЦБ.fullname_rus, "обыкн") Тогда // BSLLS:Typo-off
				ЦБ.ВидЦБ = Перечисления.ВидыАкций.Обыкновенная;
			ИначеЕсли СтрНайти(ДанныеЦБ.fullname_rus, "привилег") Тогда // BSLLS:Typo-off
				ЦБ.ВидЦБ = Перечисления.ВидыАкций.Привилегированная;
			Иначе
				Ошибки.Вставить("ВидЦБ_Акции", "securitytype = [" + ДанныеЦБ.securitytype + "]");
			КонецЕсли;
		КонецЕсли;
	ИначеЕсли ЦБ.ТипЦБ = Перечисления.ТипыЦБ.Облигация Тогда
		Если ЭтоГособлигация(ВидЦББанкаРоссииRD) Тогда
			ЦБ.ВидЦБ = Перечисления.ВидыОблигаций.Государственная;
		ИначеЕсли ЭтоВидКорпоративнойОблигации(ВидЦББанкаРоссииRD) Тогда
			ЦБ.ВидЦБ = Перечисления.ВидыОблигаций.Корпоративная;
		Иначе
			ЦБ.ВидЦБ = Перечисления.ВидыОблигаций.ПустаяСсылка();
		КонецЕсли;
	ИначеЕсли ЦБ.ТипЦБ = Перечисления.ТипыЦБ.Пай Тогда
		ВидЦБПайRD = ?(ЗначениеЗаполнено(ДанныеЦБ.sectypenamerus_nrd3), ДанныеЦБ.sectypenamerus_nrd3, ДанныеЦБ.securitytype);
		Попытка
			ЦБ.ВидЦБ = Перечисления.ВидыПаев[ВидЦБПайRD];
		Исключение
			Если ВидЦБПайRD = "ETF" Тогда
				ЦБ.ВидЦБ = Перечисления.ВидыПаев.Биржевой;
			ИначеЕсли ВидЦБПайRD = "REIT" Тогда
				ЦБ.ВидЦБ = Перечисления.ВидыПаев.ПайАкцияИнвестиционногоФонда;
			Иначе
				Ошибки.Вставить("ВидЦБ_Паи",
				"sectypenamerus_nrd3 = [" + ДанныеЦБ.sectypenamerus_nrd3 + "] ;securitytype = [" + ДанныеЦБ.securitytype + "]");
			КонецЕсли;
		КонецПопытки;
	ИначеЕсли ЦБ.ТипЦБ = Перечисления.ТипыЦБ.ДепозитарнаяРасписка Тогда
		ВидЦБДРRD = ?(ЗначениеЗаполнено(ДанныеЦБ.securitytype), ДанныеЦБ.securitytype, ДанныеЦБ.dr_category_mn);
		Если ВидЦБДРRD = "ADR" Тогда
			ЦБ.ВидЦБ = Перечисления.ВидыДепозитарныхРасписок.АмериканскаяДепозитарнаяРасписка;
		ИначеЕсли ВидЦБДРRD = "GDR" Тогда
			ЦБ.ВидЦБ = Перечисления.ВидыДепозитарныхРасписок.ГлобальнаяДепозитарнаяРасписка;
		ИначеЕсли ВидЦБДРRD = "EDR" Тогда
			ЦБ.ВидЦБ = Перечисления.ВидыДепозитарныхРасписок.ЕвропейскаяДепозитарнаяРасписка;
		ИначеЕсли ВидЦБДРRD = "RDR" Тогда
			ЦБ.ВидЦБ = Перечисления.ВидыДепозитарныхРасписок.РоссийскаяДепозитарнаяРасписка;
		Иначе
			Ошибки.Вставить("ВидЦБ_ДР", "securitytype = [" + ВидЦБДРRD + "]");
		КонецЕсли;
	КонецЕсли;
	// BSLLS:IfElseIfEndsWithElse-on
	
	Если ЗначениеЗаполнено(ДанныеЦБ.facevalue_currency) Тогда
		
		ЦБВалютаНоминала = ПолучитьСоздатьВалюту(ДанныеЦБ.facevalue_currency, ТаблицаВалют);
		Если ЗначениеЗаполнено(ЦБВалютаНоминала) Тогда
			ЦБ.ВалютаНоминала = ЦБВалютаНоминала;
		КонецЕсли;
		
		Если ЦБ.ВалютаНоминала.Пустая() Тогда
			Ошибки.Вставить("ВалютаНоминала", "facevalue_currency = [" + ДанныеЦБ.facevalue_currency + "]");
		КонецЕсли;
	КонецЕсли;
	
	Если ЦБ.ТипЦБ = Перечисления.ТипыЦБ.Облигация Тогда
		Если ЦБ.ВидЦБ = Перечисления.ВидыОблигаций.Государственная Тогда
			ЗаполнитьПодвидОблигаций(ЦБ, ДанныеЦБ, ВидЦББанкаРоссииRD);
		Иначе
			ЦБ.ПодвидОблигаций = Перечисления.ПодвидыОблигаций.ПустаяСсылка();
		КонецЕсли;
		
		Если MarketData.ЭтоЦБRu(ЦБ.ISIN) Тогда
			ЦБ.ПроцентКупона = ДанныеЦБ.couponrate;
		КонецЕсли;
		Если ЗначениеЗаполнено(ДанныеЦБ.coupons_per_year) Тогда
			ЦБ.КупоннаяОблигация = Истина;
		КонецЕсли;
		Если ЦБ.КупоннаяОблигация И ЦБ.ВалютаНоминала.Пустая() Тогда
			ЦБ.ВалютаКупона = Константы.ВалютаРегламентированногоУчета.Получить();
		Иначе
			ЦБ.ВалютаКупона = ЦБ.ВалютаНоминала;
		КонецЕсли;
		Если ДанныеЦБ.coupons_per_year = 0 Тогда
			ЦБ.ПериодПогашенияКупона = Перечисления.ВариантыНачисленияКомиссий.ПустаяСсылка();
		ИначеЕсли ДанныеЦБ.coupons_per_year = 12 Тогда // BSLLS:MagicNumber-off
			ЦБ.ПериодПогашенияКупона = Перечисления.ВариантыНачисленияКомиссий.Месяц;
		ИначеЕсли ДанныеЦБ.coupons_per_year = 1 Тогда
			ЦБ.ПериодПогашенияКупона = Перечисления.ВариантыНачисленияКомиссий.Год;
		ИначеЕсли ДанныеЦБ.coupons_per_year = 2 Тогда // BSLLS:MagicNumber-off
			ЦБ.ПериодПогашенияКупона = Перечисления.ВариантыНачисленияКомиссий.Полугодие;
		ИначеЕсли ДанныеЦБ.coupons_per_year = 3 Или ДанныеЦБ.coupons_per_year = 4 Тогда // BSLLS:MagicNumber-off
			ЦБ.ПериодПогашенияКупона = Перечисления.ВариантыНачисленияКомиссий.Квартал;
		Иначе
			ЦБ.ПериодПогашенияКупона = Перечисления.ВариантыНачисленияКомиссий.ПроизвольнаяПериодичность;
		КонецЕсли;
		ЦБ.КупоновВГод = ДанныеЦБ.coupons_per_year;
	КонецЕсли;
	
	Если ЦБ.ТипЦБ = Перечисления.ТипыЦБ.КлиринговыйСертификатУчастия Тогда
		ЦБ.Выпуск = ДанныеЦБ.sectypenamerus_nrd2;
	КонецЕсли;
	ЦБ.НаименованиеВыпуска = ?(ЗначениеЗаполнено(ДанныеЦБ.fullname_nrd), ДанныеЦБ.fullname_nrd, ДанныеЦБ.fullname_rus);
	
	Если ЦБ.НФИ Тогда
		ЦБ.Родитель = Справочники.ЦенныеБумаги.НИФИ;
	ИначеЕсли ЦБ.ТипЦБ = Перечисления.ТипыЦБ.Акция Тогда
		ЦБ.Родитель = Справочники.ЦенныеБумаги.Акции;
	ИначеЕсли ЦБ.ТипЦБ = Перечисления.ТипыЦБ.Пай Тогда
		ЦБ.Родитель = Справочники.ЦенныеБумаги.Паи;
	ИначеЕсли ЦБ.ТипЦБ = Перечисления.ТипыЦБ.Облигация И Не ЗначениеЗаполнено(ЦБ.ВидЦБ) Тогда
		ЦБ.Родитель = Справочники.ЦенныеБумаги.Облигации;
	ИначеЕсли ЦБ.ТипЦБ = Перечисления.ТипыЦБ.Облигация И ЦБ.ВидЦБ = Перечисления.ВидыОблигаций.Государственная
			И Не ЗначениеЗаполнено(ЦБ.ПодвидОблигаций) Тогда
		ЦБ.Родитель = Справочники.ЦенныеБумаги.Государственные;
	ИначеЕсли ЦБ.ТипЦБ = Перечисления.ТипыЦБ.Облигация И ЦБ.ВидЦБ = Перечисления.ВидыОблигаций.Государственная
			И ЦБ.ПодвидОблигаций = Перечисления.ПодвидыОблигаций.Муниципальная Тогда
		ЦБ.Родитель = Справочники.ЦенныеБумаги.Муниципальные;
	ИначеЕсли ЦБ.ТипЦБ = Перечисления.ТипыЦБ.Облигация И ЦБ.ВидЦБ = Перечисления.ВидыОблигаций.Государственная
			И ЦБ.ПодвидОблигаций = Перечисления.ПодвидыОблигаций.РФ Тогда
		ЦБ.Родитель = Справочники.ЦенныеБумаги.РФ;
	ИначеЕсли ЦБ.ТипЦБ = Перечисления.ТипыЦБ.Облигация И ЦБ.ВидЦБ = Перечисления.ВидыОблигаций.Государственная
			И ЦБ.ПодвидОблигаций = Перечисления.ПодвидыОблигаций.СубъектовРФ Тогда
		ЦБ.Родитель = Справочники.ЦенныеБумаги.СубъектовРФ;
	ИначеЕсли ЦБ.ТипЦБ = Перечисления.ТипыЦБ.Облигация И ЦБ.ВидЦБ = Перечисления.ВидыОблигаций.Корпоративная Тогда
		ЦБ.Родитель = Справочники.ЦенныеБумаги.Корпоративные;
	ИначеЕсли ЦБ.ТипЦБ = Перечисления.ТипыЦБ.КлиринговыйСертификатУчастия Тогда
		ЦБ.Родитель = Справочники.ЦенныеБумаги.КСУ;
	ИначеЕсли ЦБ.ТипЦБ = Перечисления.ТипыЦБ.ДепозитарнаяРасписка Тогда
		ЦБ.Родитель = Справочники.ЦенныеБумаги.ДепозитарныеРасписки;
	Иначе
		ЦБ.Родитель = Справочники.ЦенныеБумаги.Прочее;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(ЦБ.СтранаНалогообложения) Тогда
		ЦБ.СтранаНалогообложения = СтранаПоКодуИнтерфакс(ТаблицаСтран, "shortname_rus", ДанныеЦБ.tax_country_name);
		Если Не ЗначениеЗаполнено(ЦБ.СтранаНалогообложения) Тогда
			ЦБ.СтранаНалогообложения = СтранаПоКодуИнтерфакс(ТаблицаСтран, "fullname_eng", ДанныеЦБ.tax_country_name_en);
		КонецЕсли;
	КонецЕсли;
	Если ЦБ.МестаХранения.Количество() = 0 И ЗначениеЗаполнено(ДанныеЦБ.depositary_nrd) Тогда
		МестоХранения = МестоХраненияЦБ(ДанныеЦБ.depositary_nrd);
		Если ЗначениеЗаполнено(МестоХранения) Тогда
			НовоеМестоХранения = ЦБ.МестаХранения.Добавить();
			НовоеМестоХранения.МестоХранения = МестоХранения;
			НовоеМестоХранения.КодХранения = ДанныеЦБ.nrdcode;
			НовоеМестоХранения.ОсновноеМестоХранения = Истина;
		КонецЕсли;
	КонецЕсли;
	
	ЦБ.ОбменДанными.Загрузка = Истина;
	ЦБ.Записать();
	ЦБСсылка = ЦБ.Ссылка;
	
	ЦБСсылкаТипЦБ				 = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ЦБСсылка, "ТипЦБ");
	ЦБСсылкаISIN				 = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ЦБСсылка, "ISIN");
	ЦБСсылкаЗаморожена			 = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ЦБСсылка, "Заморожена");
	ЦБСсылкаРодитель			 = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ЦБСсылка, "Родитель");
	ЦБСсылкаДатаГосРег			 = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ЦБСсылка, "ДатаГосРег");
	ЦБСсылкаДатаРазмещения		 = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ЦБСсылка, "ДатаРазмещения");
	ЦБСсылкаАмортизационнаяЦБ	 = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ЦБСсылка, "АмортизационнаяЦБ");
	ЦБСсылкаИндексируемыйНоминал = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ЦБСсылка, "ИндексируемыйНоминал");
	
	СоздаемКодЗагрузки = Истина;
	Если ЗначениеЗаполнено(ДанныеЦБ.fintoolid) И Не ЗначениеЗаполнено(ДанныеЦБ.КодЗагрузкиRuData) Тогда
		СоздатьОбновитьКодЗагрузки(ЦБСсылка, Справочники.КлассификаторыЗагрузки.RuData, ДанныеЦБ.fintoolid, СоздаемКодЗагрузки);
	КонецЕсли;
	// --> Закрыть старый код загрузки НРД
	НеобходимоЗакрытьСтарыйКодЗагрузкиНРД = ЗначениеЗаполнено(ДанныеЦБ.nrdcode) И ЗначениеЗаполнено(ДанныеЦБ.nrd_date_from);
	Если НеобходимоЗакрытьСтарыйКодЗагрузкиНРД Тогда
		ПрекратитьДействиеПрочихКодовЗагрузки(ЦБСсылка,
			Справочники.КлассификаторыЗагрузки.НДЦ(), ДанныеЦБ.nrdcode, ДанныеЦБ.nrd_date_from - 1);
	КонецЕсли;
	// <-- 
	Если ЗначениеЗаполнено(ДанныеЦБ.nrdcode) И Не ЗначениеЗаполнено(ДанныеЦБ.КодЗагрузкиНДЦ) Тогда
		УчестьДатуДействияКодаЗагрузки = Истина;
		СоздатьОбновитьКодЗагрузки(ЦБСсылка, Справочники.КлассификаторыЗагрузки.НДЦ(), ДанныеЦБ.nrdcode, СоздаемКодЗагрузки,
			ДанныеЦБ.nrd_date_from, ДанныеЦБ.nrd_date_to, УчестьДатуДействияКодаЗагрузки);
	КонецЕсли;
	Если ЗначениеЗаполнено(ДанныеЦБ.moex_code) И Не ЗначениеЗаполнено(ДанныеЦБ.КодЗагрузкиMICEX) Тогда
		СоздатьОбновитьКодЗагрузки(ЦБСсылка, Справочники.Биржи.MICEX, ДанныеЦБ.moex_code, СоздаемКодЗагрузки);
	КонецЕсли;
	
	// Регистры сведений связанные с ЦБ
	Если ЗначениеЗаполнено(ДанныеЦБ.facevalue) Тогда
		
		ПериодНоминалаЭтоДатаНачалаДействияКодаНРД = Не ДанныеЦБ.ЭтоНоваяЦБ И Не ЦБСсылкаАмортизационнаяЦБ И Не ЦБСсылкаИндексируемыйНоминал
			И ЗначениеЗаполнено(ДанныеЦБ.nrdcode) И ЗначениеЗаполнено(ДанныеЦБ.nrd_date_from);
		
		Если ЦБСсылкаАмортизационнаяЦБ Тогда
			НаборЗаписейНоминала = РегистрыСведений.НоминалЦБ.СоздатьНаборЗаписей();
			НаборЗаписейНоминала.Отбор.ЦеннаяБумага.Установить(ЦБСсылка);
			НаборЗаписейНоминала.Записать();
		КонецЕсли;
		
		МенеджерНоминала = РегистрыСведений.НоминалЦБ.СоздатьМенеджерЗаписи();
		Если ПериодНоминалаЭтоДатаНачалаДействияКодаНРД Тогда
			ПериодНоминала = ДанныеЦБ.nrd_date_from;
		ИначеЕсли ЗначениеЗаполнено(ЦБСсылкаДатаГосРег) Тогда
			ПериодНоминала = ЦБСсылкаДатаГосРег;
		ИначеЕсли ЗначениеЗаполнено(ЦБСсылкаДатаРазмещения) Тогда
			ПериодНоминала = ЦБСсылкаДатаРазмещения;
		Иначе
			ПериодНоминала = ДатаНачалаУчета;
		КонецЕсли;
		МенеджерНоминала.Период = ПериодНоминала;
		МенеджерНоминала.ЦеннаяБумага = ЦБСсылка;
		МенеджерНоминала.Сумма = ДанныеЦБ.facevalue;
		МенеджерНоминала.Записать();
		
		Если Не ЗначениеЗаполнено(ЦБСсылкаДатаГосРег) Тогда
			ОтборЗаписи = Новый Структура;
			ОтборЗаписи.Вставить("ЦеннаяБумага", ЦБСсылка);
			НоминалНаНачало = РегистрыСведений.НоминалЦБ.ПолучитьПоследнее(ДатаНачалаУчета, ОтборЗаписи);
			Если Не ЗначениеЗаполнено(НоминалНаНачало.Сумма) Тогда
				МенеджерНоминала = РегистрыСведений.НоминалЦБ.СоздатьМенеджерЗаписи();
				МенеджерНоминала.Период = ДатаНачалаУчета;
				МенеджерНоминала.ЦеннаяБумага = ЦБСсылка;
				МенеджерНоминала.Сумма = ДанныеЦБ.facevalue;
				МенеджерНоминала.Записать();
			КонецЕсли;
		КонецЕсли;
	Иначе
		Если ЦБСсылкаТипЦБ = Перечисления.ТипыЦБ.Облигация Тогда
			Ошибки.Вставить("Номинал", "facevalue = [" + ДанныеЦБ.facevalue + "]");
		КонецЕсли;
	КонецЕсли;
	
	УровеньЛистинга = ДанныеЦБ.micexlist_nrd;
	Если ЦБСсылкаТипЦБ = Перечисления.ТипыЦБ.Пай Или ЦБСсылкаТипЦБ = Перечисления.ТипыЦБ.ДепозитарнаяРасписка Тогда
		КатегорияЛистинга = Справочники.КатегорииЦБ.А05370;
	ИначеЕсли ЦБСсылкаТипЦБ = Перечисления.ТипыЦБ.Акция Или ЦБСсылкаТипЦБ = Перечисления.ТипыЦБ.КлиринговыйСертификатУчастия Тогда
		Если ЗначениеЗаполнено(ЦБСсылкаISIN) И Не MarketData.ЭтоЦБRu(ЦБСсылкаISIN) Тогда
			КатегорияЛистинга = Справочники.КатегорииЦБ.А05370;
		ИначеЕсли ЦБСсылкаЗаморожена Или Не ЗначениеЗаполнено(УровеньЛистинга) Тогда
			КатегорияЛистинга = Справочники.КатегорииЦБ.ПустаяСсылка();
		ИначеЕсли УровеньЛистинга = "Первый уровень листинга" Тогда
			КатегорияЛистинга = Справочники.КатегорииЦБ.А05390;
		ИначеЕсли УровеньЛистинга = "Второй уровень листинга"
			Или УровеньЛистинга = "Третий уровень листинга" Тогда
			КатегорияЛистинга = Справочники.КатегорииЦБ.А05330;
		Иначе
			КатегорияЛистинга = Неопределено;
		КонецЕсли;
	ИначеЕсли ЦБСсылкаТипЦБ = Перечисления.ТипыЦБ.Облигация Тогда
		Если ЗначениеЗаполнено(ЦБСсылкаISIN) И Не MarketData.ЭтоЦБRu(ЦБСсылкаISIN) Тогда
			КатегорияЛистинга = Справочники.КатегорииЦБ.А05370;
		ИначеЕсли ЦБСсылкаЗаморожена Тогда
			КатегорияЛистинга = Справочники.КатегорииЦБ.ПустаяСсылка(); // BSLLS:IfElseDuplicatedCodeBlock-off
		ИначеЕсли ЦБСсылкаРодитель = Справочники.ЦенныеБумаги.РФ Тогда
			КатегорияЛистинга = Справочники.КатегорииЦБ.А05310;
		ИначеЕсли ЦБСсылкаРодитель = Справочники.ЦенныеБумаги.СубъектовРФ Тогда
			КатегорияЛистинга = Справочники.КатегорииЦБ.А05320;
		ИначеЕсли Не ЗначениеЗаполнено(УровеньЛистинга) Тогда
			КатегорияЛистинга = Справочники.КатегорииЦБ.ПустаяСсылка(); // BSLLS:IfElseDuplicatedCodeBlock-off
		ИначеЕсли УровеньЛистинга = "Первый уровень листинга" Тогда
			КатегорияЛистинга = Справочники.КатегорииЦБ.А05380;
		ИначеЕсли УровеньЛистинга = "Второй уровень листинга"
			Или УровеньЛистинга = "Третий уровень листинга" Тогда
			КатегорияЛистинга = Справочники.КатегорииЦБ.А05350;
		Иначе
			КатегорияЛистинга = Неопределено;
		КонецЕсли;
	Иначе
		КатегорияЛистинга = Неопределено;
	КонецЕсли;
	Если ЗначениеЗаполнено(КатегорияЛистинга) Тогда
		МенеджерКатегорияЦБ = РегистрыСведений.КатегорияЦБ.СоздатьМенеджерЗаписи();
		Если ЗначениеЗаполнено(ЦБСсылкаДатаГосРег) Тогда
			МенеджерКатегорияЦБ.Период = ЦБСсылкаДатаГосРег;
		ИначеЕсли ЗначениеЗаполнено(ДанныеЦБ.update_date) Тогда
			МенеджерКатегорияЦБ.Период = ДанныеЦБ.update_date;
		Иначе
			МенеджерКатегорияЦБ.Период = ПараметрыКИ.Период;
		КонецЕсли;
		МенеджерКатегорияЦБ.ЦеннаяБумага = ЦБСсылка;
		МенеджерКатегорияЦБ.Категория = КатегорияЛистинга;
		МенеджерКатегорияЦБ.Записать();
		
		Если Не ЗначениеЗаполнено(ЦБСсылкаДатаГосРег) Тогда
			ОтборЗаписи = Новый Структура;
			ОтборЗаписи.Вставить("ЦеннаяБумага", ЦБСсылка);
			КатегорияЦБНаНачало = РегистрыСведений.КатегорияЦБ.ПолучитьПоследнее(ДатаНачалаУчета, ОтборЗаписи);
			Если Не ЗначениеЗаполнено(КатегорияЦБНаНачало.Категория) Тогда
				МенеджерКатегорияЦБ = РегистрыСведений.КатегорияЦБ.СоздатьМенеджерЗаписи();
				МенеджерКатегорияЦБ.Период = ДатаНачалаУчета;
				МенеджерКатегорияЦБ.ЦеннаяБумага = ЦБСсылка;
				МенеджерКатегорияЦБ.Категория = КатегорияЛистинга;
				МенеджерКатегорияЦБ.Записать();
			КонецЕсли;
		КонецЕсли;
		
	КонецЕсли;
	
	ДобавитьУведомлениеОбОшибкахЗагрузкиЦБизRuDataAPI(ТаблицаОшибок, ЦБСсылка, ДанныеЦБ.ЭтоНоваяЦБ, Ошибки);
	
	Возврат ЦБСсылка;
	
КонецФункции

// BSLLS:CognitiveComplexity-on
// BSLLS:CyclomaticComplexity-on
// BSLLS:MethodSize-on

Функция ЭтоАмортизируемыйНоминал(ДанныеЦБ)
	
	Если ЗначениеЗаполнено(ДанныеЦБ.amortisedmty) Тогда
		ЭтоАмортизируемыйНоминал = Истина;
	ИначеЕсли ЗначениеЗаполнено(ДанныеЦБ.nominaltype) Тогда
		ТипыНоминалаАмортизируемые
			= ОбщегоНазначенияПовтИсп.ЗначениеГлобальногоПараметра("101.RuData_ТипыНоминалаАмортизируемые", "'Неопределено'");
		ЭтоАмортизируемыйНоминал = СтрНайти(ТипыНоминалаАмортизируемые, ДанныеЦБ.nominaltype) > 0;
	Иначе
		ЭтоАмортизируемыйНоминал = Ложь;
	КонецЕсли;
	
	Возврат ЭтоАмортизируемыйНоминал;
	
КонецФункции

Функция ЭтоИндексируемыйНоминал(ДанныеЦБ)
	
	Если ЗначениеЗаполнено(ДанныеЦБ.nominaltype) Тогда
		ТипыНоминалаИндексируемые
			= ОбщегоНазначенияПовтИсп.ЗначениеГлобальногоПараметра("101.RuData_ТипыНоминалаИндексируемые", "'Неопределено'");
		ЭтоИндексируемыйНоминал = СтрНайти(ТипыНоминалаИндексируемые, ДанныеЦБ.nominaltype) > 0;
	Иначе
		ЭтоИндексируемыйНоминал = Ложь;
	КонецЕсли;
	
	Возврат ЭтоИндексируемыйНоминал;
	
КонецФункции

Функция ПолучитьСоздатьВалюту(facevalue_currency, ТаблицаВалют)
	
	ЦБВалютаНоминала = Справочники.Валюты.НайтиПоНаименованию(facevalue_currency, Истина); // BSLLS:UsingFindElementByString-off
	Если Не ЗначениеЗаполнено(ЦБВалютаНоминала) И facevalue_currency = "RUB" Тогда
		ЦБВалютаНоминала = Справочники.Валюты.НайтиПоНаименованию("SUR", Истина); // BSLLS:UsingFindElementByString-off
	КонецЕсли;
	Если Не ЗначениеЗаполнено(ЦБВалютаНоминала) И facevalue_currency = "CNH" Тогда
		ЦБВалютаНоминала = Справочники.Валюты.НайтиПоНаименованию("CNY", Истина); // BSLLS:UsingFindElementByString-off
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(ЦБВалютаНоминала) Тогда
		ПараметрыПоискаВалюты = Новый Структура("code", facevalue_currency);
		НайденыВалюты = ТаблицаВалют.НайтиСтроки(ПараметрыПоискаВалюты);
		Если НайденыВалюты.Количество() > 0 Тогда
			ЦБВалютаНоминала = СоздатьВалюту(НайденыВалюты[0]);
		КонецЕсли;
	КонецЕсли;
	
	Возврат ЦБВалютаНоминала;
	
КонецФункции

Функция СоздатьВалюту(ПараметрыСоздания)
	
	Валюта = Справочники.Валюты.СоздатьЭлемент();
	Валюта.Код					= СтроковыеФункцииКлиентСервер.ДополнитьСтроку(Строка(ПараметрыСоздания.iso_number), 3);
	Валюта.Наименование			= СокрЛП(ПараметрыСоздания.Code);
	Валюта.НаименованиеПолное	= СокрЛП(ПараметрыСоздания.full_name_rus);
	Валюта.НаименованиеДляОтчетов = Валюта.Наименование;
	Валюта.Записать();
	ОбщегоНазначения.ПроверитьКорректностьКурсаНа01_01_1980(Валюта.Ссылка);
	
	Возврат Валюта.Ссылка;
	
КонецФункции

Функция ЭтоВидКорпоративнойОблигации(КодВидаКорпоративнойОблигации)
	
	Возврат КодВидаКорпоративнойОблигации = "BON3"
		Или КодВидаКорпоративнойОблигации = "BON4"
		Или КодВидаКорпоративнойОблигации = "BON5"
		Или КодВидаКорпоративнойОблигации = "BON6"
		Или КодВидаКорпоративнойОблигации = "BON7";
	
КонецФункции

Функция ЭмитентЦБ(КодЗагрузки)
	
	Если Не ЗначениеЗаполнено(КодЗагрузки) Тогда
		Возврат Справочники.Контрагенты.ПустаяСсылка();
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	ВЫРАЗИТЬ(КодыЗагрузки.Владелец КАК Справочник.ЮридическиеЛица).Ссылка КАК ЮрЛицо
	|ИЗ
	|	Справочник.КодыЗагрузки КАК КодыЗагрузки
	|ГДЕ
	|	ВЫРАЗИТЬ(КодыЗагрузки.Биржа КАК Справочник.КлассификаторыЗагрузки).Ссылка = &RuData
	|	И КодыЗагрузки.Код = &Код
	|	И КодыЗагрузки.Владелец ССЫЛКА Справочник.ЮридическиеЛица
	|	И НЕ КодыЗагрузки.ПометкаУдаления";
	
	Запрос.УстановитьПараметр("RuData",	 Справочники.КлассификаторыЗагрузки.RuData);
	Запрос.УстановитьПараметр("Код",	 СокрЛП(КодЗагрузки));
	
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		ЮрЛицо = Выборка.ЮрЛицо;
	Иначе
		ЮрЛицо = Неопределено;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ЮрЛицо) Тогда
		Возврат Справочники.Контрагенты.КонтрагентПоЮрФизЛицу(ЮрЛицо);
	Иначе
		Возврат Справочники.Контрагенты.ПустаяСсылка();
	КонецЕсли;
	
КонецФункции

Функция МестоХраненияЦБ(КодЗагрузки)
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	ВЫРАЗИТЬ(КодыЗагрузки.Владелец КАК Справочник.ЮридическиеЛица).Ссылка КАК ЮрЛицо
	|ИЗ
	|	Справочник.КодыЗагрузки КАК КодыЗагрузки
	|ГДЕ
	|	ВЫРАЗИТЬ(КодыЗагрузки.Биржа КАК Справочник.КлассификаторыЗагрузки).Ссылка = &НДЦ
	|	И КодыЗагрузки.Код = &Код
	|	И КодыЗагрузки.Владелец ССЫЛКА Справочник.ЮридическиеЛица
	|	И НЕ КодыЗагрузки.ПометкаУдаления";
	
	Запрос.УстановитьПараметр("НДЦ",	 Справочники.КлассификаторыЗагрузки.НДЦ());
	Запрос.УстановитьПараметр("Код",	 СокрЛП(КодЗагрузки));
	
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.ЮрЛицо;
	Иначе
		Возврат Неопределено;
	КонецЕсли;
	
КонецФункции

Функция ЭмитентыКредитныеОрганизации()
	
	ОписаниеОшибки = "";
	Сессия = Неопределено;
	СквозныеПараметры = Новый Структура;
	СквозныеПараметры.Вставить("ДатаВремяОбновленияДанных", ТекущаяДатаСеанса());
	СквозныеПараметры.Вставить("filter", "id_category = 757");
	ТаблицаКредитныхОрганизаций = RuDataAPI.InfoEmitentCategoryValue(ОписаниеОшибки, Сессия, СквозныеПараметры);
	Если ОписаниеОшибки = "" И ЗначениеЗаполнено(ТаблицаКредитныхОрганизаций) Тогда
		КредитныеОрганизации = ТаблицаКредитныхОрганизаций.ВыгрузитьКолонку("Fininstid");
	Иначе
		КредитныеОрганизации = Новый Массив;
	КонецЕсли;
	
	Возврат КредитныеОрганизации;
	
