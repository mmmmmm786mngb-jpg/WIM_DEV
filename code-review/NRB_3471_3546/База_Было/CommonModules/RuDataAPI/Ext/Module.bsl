#Область СлужебныйПрограммныйИнтерфейс

// Экспортные функции данного модуля вызываются главным образом из обработки СервисыMarketDataAPI, синоним
// "Загрузка данных из сервисов MarketData [API]"

// Подключает источник RuData API, записывает Токен авторизации в параметры сеанса
//
// Параметры:
//  ОписаниеОшибки	 - Строка	 - Описание ошибки (если есть)
//  СлужебныйВызов	 - Булево	 - Признак вызова из служебной процедуры (по - умолчанию)
//  Сессия			 - Структура - Кеш соединения
// 
// Возвращаемое значение:
//   - HTTPСоединение- HTTP Соединение
//
Функция Подключить(ОписаниеОшибки, СлужебныйВызов = Истина, Сессия = Неопределено) Экспорт
	
	ОписаниеОшибки = "";
	
	НастройкиСоединения = ПараметрыИсточника();
	
	Если ЗначениеЗаполнено(НастройкиСоединения) Тогда
		
		ПараметрыСеанса.ТокенRuDataAPI = API_AccountLogin(НастройкиСоединения, ОписаниеОшибки, Сессия);
		
	Иначе
		
		ПараметрыСеанса.ТокенRuDataAPI = "";
		
		ОписаниеОшибки = "Не заполнены настройки для подключения внешнего источника RuDataAPI.";
		
	КонецЕсли;
	
	Если Не СлужебныйВызов И ЗначениеЗаполнено(ОписаниеОшибки) Тогда
		
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ОписаниеОшибки);
		
	КонецЕсли;
	
	Если ОписаниеОшибки = "" И Не ТестированиеVanessa.ЭтоТест() Тогда
		Для Каждого Пул Из Сессия.СлужебныеДанные.ПулСоединений Цикл
			Возврат Пул.Значение;
		КонецЦикла;
		ОписаниеОшибки = "Нет HTTP Соединения";
		Возврат Неопределено;
	Иначе
		Возврат Неопределено;
	КонецЕсли;
	
КонецФункции

// Возвращает таблицу Info \ Securities
//
// Параметры:
//  ВходныеПараметры - Структура - Структура входных параметров (может быть неопределено)
//    Обязательные поля:
//     * ДатаВремяОбновленияДанных	 - Дата		 - дата \ время начала выборки обновлений (пустая дата - по всем датам изменений)
//    Необязательные поля:
//     * fintoolids					 - Массив	 - массив fintoolid (пустой массив - отбор по fintoolid не нужен)
//     * ISINs						 - Массив	 - массив isin (пустой массив - по всем ЦБ), если присутствуют и fintoolids и ISINs,
//  ОписаниеОшибки	 - Строка	 - Описание ошибки (если есть)
//  Сессия			 - Строка	 - Кеш сессии HTTP
//													то ISINs - игнорируется (даже если fintoolids - пустой массив).
// Возвращаемое значение:
//   - ТаблицаЗначений - Таблица с данными (см. https://docs.efir-net.ru/dh2/#/Info/Securities)
//
Функция ДанныеЦенныхБумагПоПараметрам(ВходныеПараметры, ОписаниеОшибки, Сессия = Неопределено) Экспорт
	ОбщегоНазначенияКлиентСервер.ДобавитьЭлементСтруктурыПриОтсутствии(ВходныеПараметры, "ОбновитьБумагиВНеактуальномСтатусе", Ложь);
	ОписаниеОшибки = "";
	
	ЕстьСвойствоFintoolids = ВходныеПараметры.Свойство("fintoolids");
	
	Если ЕстьСвойствоFintoolids И ЗначениеЗаполнено(ВходныеПараметры.fintoolids) Тогда
		ТаблицаInfoSecurities = InfoSecuritiesWithCodes(ВходныеПараметры, "fintoolids", ОписаниеОшибки, Сессия);
	ИначеЕсли Не ЕстьСвойствоFintoolids И СвойствоЗаполнено(ВходныеПараметры, "ISINs") Тогда
		ТаблицаInfoSecurities = InfoSecuritiesWithCodes(ВходныеПараметры, "isins", ОписаниеОшибки, Сессия);
	Иначе
		ТаблицаInfoSecurities = InfoSecurities(ОписаниеОшибки, Сессия, ВходныеПараметры);
	КонецЕсли;
	
	Возврат ТаблицаInfoSecurities;
КонецФункции

// Возвращает таблицу Info \ Securities
//
// Параметры:
//  ОписаниеОшибки	 - Строка	 - Описание ошибки (если есть)
//  Сессия			 - Строка	 - Кеш сессии HTTP
//  ВходныеПараметры - Структура - Структура входных параметров (может быть неопределено)
//    Обязательные поля:
//     * ISINs						 - Массив	 - массив isin (пустой массив - по всем ЦБ)
//     * ДатаВремяОбновленияДанных	 - Дата		 - дата \ время начала выборки обновлений (пустая дата - по всем датам изменений)
// 
// Возвращаемое значение:
//   - ТаблицаЗначений - Таблица с данными (см. https://docs.efir-net.ru/dh2/#/Info/Securities)
//
Функция InfoSecurities(ОписаниеОшибки, Сессия = Неопределено, ВходныеПараметры = Неопределено) Экспорт
	
	ТаблицаSecurities = Неопределено;
	
	МаксимальноеКоличествоСтраниц = ОбщегоНазначенияПовтИсп.ЗначениеГлобальногоПараметра("101.МаксимальноеКоличествоСтраниц", 10000);
	
	ОписаниеОшибки = "";
	
	ЧисловыеРеквизиты = ЧисловыеРеквизитыТаблицRuDataAPI();
	
	НастройкиСоединения = ПараметрыИсточника();
	
	Если ЗначениеЗаполнено(НастройкиСоединения) Тогда
		
		Если ВходныеПараметры = Неопределено Тогда
			ВходныеПараметры = Новый Структура;
			ВходныеПараметры.Вставить("ISINs"						, Новый Массив);
			ВходныеПараметры.Вставить("ДатаВремяОбновленияДанных"	,
				ОбщегоНазначенияПовтИсп.ЗначениеГлобальногоПараметра("101.RuData_ДатаВремяПоследнегоОбновленияДанных", Дата(1, 1, 1)));
			ВходныеПараметры.Вставить("ФильтрСтатусовЦБ"			, Неопределено);
		КонецЕсли;
		ВходныеПараметры.Вставить("НомерПачки"						, 0);
		ВходныеПараметры.Вставить("pageNum"							, "");
		ВходныеПараметры.Вставить("pageSize"						, 100);
		ОбщегоНазначенияКлиентСервер.ДобавитьЭлементСтруктурыПриОтсутствии(ВходныеПараметры, "ОбновитьБумагиВНеактуальномСтатусе", Ложь);
		
		Для НомерСтраницы = 1 По МаксимальноеКоличествоСтраниц Цикл
			ВходныеПараметры.НомерПачки = "" + НомерСтраницы;
			ВходныеПараметры.pageNum = НомерСтраницы;
			
			Результат = API_ПолучитьОтветМетода("InfoSecurities", "/Info/Securities",
				ВходныеПараметры, НастройкиСоединения, ОписаниеОшибки, Сессия);
			
			Если Не ЗначениеЗаполнено(Результат) Тогда
				Прервать;
			КонецЕсли;
			ВременнаяТаблица = ПреобразоватьМассивВТаблицуЗначений(Результат, ЧисловыеРеквизиты);
			ТаблицаSecurities = КонкатенацияТаблицЗначений(ТаблицаSecurities, ВременнаяТаблица);
		КонецЦикла;
		
	КонецЕсли;
	
	Возврат ТаблицаSecurities;
	
КонецФункции

// Возвращает таблицу Info \ Securities, ранее называлась InfoSecuritiesWithISINs
//
// Параметры:
//  ВходныеПараметры - Структура - Структура входных параметров (может быть неопределено)
//    Обязательные поля:
//     * ISINs						 - Массив	 - массив isin, обязателен, если параметр ВидКодов = "isins"
//     * fintoolids					 - fintoolids	 - массив fintoolid (коды RuData), обязателен, если параметр ВидКодов = "fintoolids"
//     * ДатаВремяОбновленияДанных	 - Дата		 - дата \ время начала выборки обновлений (пустая дата - по всем датам изменений)
//  ВидКодов		 - Строка	 - "isins" или "fintoolids", если значение не задано, то "isins"
//  ОписаниеОшибки	 - Строка	 - Описание ошибки (если есть)
//  Сессия			 - Строка	 - Кеш сессии HTTP
// 
// Возвращаемое значение:
//   - ТаблицаЗначений - Таблица с данными (см. https://docs.efir-net.ru/dh2/#/Info/Securities)
//
Функция InfoSecuritiesWithCodes(ВходныеПараметры, Знач ВидКодов, ОписаниеОшибки, Сессия = Неопределено) Экспорт
	ВидКодовISINs = "isins";
	Если Не ЗначениеЗаполнено(ВидКодов) Тогда
		ВидКодов = ВидКодовISINs;
	КонецЕсли;
	
	КлючНенужногоЭлемента = ?(ВидКодов = ВидКодовISINs, "fintoolids", ВидКодовISINs);
	
	ТаблицаSecurities = Неопределено;
	ОписаниеОшибки = "";
	НастройкиСоединения = ПараметрыИсточника();
	НомерПачки = 0;
	Если ЗначениеЗаполнено(НастройкиСоединения) Тогда
		ОграничениеПоКоличествуЦБ = 100; // Ограничения RuData по объему запрашиваемых данных
		//
		КодыЦБДляТекущейПачки = Новый Массив;
		//
		ФильтрСтатусовЦБ = "";
		ВходныеПараметры.Свойство("ФильтрСтатусовЦБ", ФильтрСтатусовЦБ);
		
		ИмяПоляСМассивом = ?(ВидКодов = ВидКодовISINs, "ISINs", ВидКодов);
		ВсеКодыЦБДляОтбора = ВходныеПараметры[ИмяПоляСМассивом];
		ПоследнийИндекс = ВсеКодыЦБДляОтбора.ВГраница();
		Для Индекс = 0 По ПоследнийИндекс Цикл
			КодыЦБДляТекущейПачки.Добавить(ВсеКодыЦБДляОтбора[Индекс]);
			Группировать = (Индекс + 1) % ОграничениеПоКоличествуЦБ;
			Если Группировать = 0 Или Индекс = ПоследнийИндекс Тогда
				НомерПачки = НомерПачки + 1;
				ВходящиеИдентификаторы = НовыеВходящиеИдентификаторы();
				ВходящиеИдентификаторы.Вставить(ВидКодов, КодыЦБДляТекущейПачки);
				ВходныеПараметрыГруппа = НовыеВходныеПараметрыГруппы(НомерПачки, ВходныеПараметры.ДатаВремяОбновленияДанных,
					ВходящиеИдентификаторы, ФильтрСтатусовЦБ, КлючНенужногоЭлемента);
				ОбщегоНазначенияКлиентСервер.ДобавитьЭлементСтруктуры(ВходныеПараметрыГруппа, ВходныеПараметры,
																		"ОбновитьБумагиВНеактуальномСтатусе", Ложь);
				ВременнаяТаблица =
					ТаблицаДанныхМетода("InfoSecurities", НастройкиСоединения, ОписаниеОшибки, Сессия, ВходныеПараметрыГруппа);
				//
				КодыЦБДляТекущейПачки = Новый Массив;
				//
				Если ЗначениеЗаполнено(ВременнаяТаблица) Тогда
					ТаблицаSecurities = КонкатенацияТаблицЗначений(ТаблицаSecurities, ВременнаяТаблица);
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;
		
	КонецЕсли;
	
	Возврат ТаблицаSecurities;
КонецФункции

// Возвращает таблицу Info \ FintoolReferenceData
//
// Параметры:
//  ОписаниеОшибки	 - Строка	 - Описание ошибки (если есть)
//  Сессия			 - Строка	 - Кеш сессии HTTP
//  ВходныеПараметры - Структура - Структура входных параметров (может быть неопределено)
//    Обязательные поля:
//     * fintoolids					 - Массив	 - массив fintoolid (обязательное поле - идентификатор ЦБ в RuData)
//     * ДатаВремяОбновленияДанных	 - Дата		 - дата \ время начала выборки обновлений (пустая дата - по всем датам изменений)
// 
// Возвращаемое значение:
//   - ТаблицаЗначений - Таблица с данными (см. https://docs.efir-net.ru/dh2/#/Info/FintoolReferenceData)
//
Функция InfoFintoolReferenceData(ОписаниеОшибки, Сессия = Неопределено, ВходныеПараметры = Неопределено) Экспорт
	ИмяFintoolids = "fintoolids";
	
	Если ВходныеПараметры = Неопределено Тогда
		ВходныеПараметры = Новый Структура;
		ВходныеПараметры.Вставить(ИмяFintoolids, Новый Массив);
		ВходныеПараметры.Вставить("ДатаВремяОбновленияДанных", ДАТА(1, 1, 1));
	КонецЕсли;
	
	ТаблицаFintoolReferenceData = Неопределено;
	ОписаниеОшибки = "";
	НуженОтборПоFintoolids = ЗначениеЗаполнено(ВходныеПараметры.fintoolids);
	НастройкиСоединения = ПараметрыИсточника();
	НомерПачки = 0;
	Если ЗначениеЗаполнено(НастройкиСоединения) Тогда
		ОграничениеПоКоличествуЦБ = 100; // Ограничения RuData по объему запрашиваемых данных
		fintoolids = Новый Массив;
		ПоследнийИндекс = ПоследнийИндексДляЦикла(ВходныеПараметры, ИмяFintoolids);
		Для Индекс = 0 По ПоследнийИндекс Цикл
			Если НуженОтборПоFintoolids Тогда
				fintoolids.Добавить(ВходныеПараметры.fintoolids[Индекс]);
			КонецЕсли;
			Группировать = (Индекс + 1) % ОграничениеПоКоличествуЦБ;
			Если Группировать = 0 Или Индекс = ПоследнийИндекс Тогда
				НомерПачки = НомерПачки + 1;
				
				ВходящиеИдентификаторы = НовыеВходящиеИдентификаторы();
				ВходящиеИдентификаторы.Вставить(ИмяFintoolids, fintoolids);
				ВходныеПараметрыГруппа = НовыеВходныеПараметрыГруппы(НомерПачки, ВходныеПараметры.ДатаВремяОбновленияДанных, ВходящиеИдентификаторы);
				ОбщегоНазначенияКлиентСервер.ДополнитьСтруктуруВыборочно(ВходныеПараметрыГруппа, ВходныеПараметры, "ТолькоFintoolid");
				ВременнаяТаблица =
					ТаблицаДанныхМетода("InfoFintoolReferenceData", НастройкиСоединения, ОписаниеОшибки, Сессия, ВходныеПараметрыГруппа);
				
				fintoolids = Новый Массив;
				
				Если ЗначениеЗаполнено(ВременнаяТаблица) Тогда
					ТаблицаFintoolReferenceData = КонкатенацияТаблицЗначений(ТаблицаFintoolReferenceData, ВременнаяТаблица);
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	Возврат ТаблицаFintoolReferenceData;
КонецФункции

// Возвращает таблицу Nsd \ CommonData
//
// Параметры:
//  ОписаниеОшибки	 - Строка	 - Описание ошибки (если есть)
//  Сессия			 - Строка	 - Кеш сессии HTTP
//  ВходныеПараметры - Структура - Структура входных параметров (может быть неопределено)
//    Обязательные поля:
//     * nrdcodes					 - Массив	 - массив nrdcodes (обязательное поле - идентификатор ЦБ в НРД)
//     * ДатаВремяОбновленияДанных	 - Дата		 - дата \ время начала выборки обновлений (пустая дата - по всем датам изменений)
// 
// Возвращаемое значение:
//   - ТаблицаЗначений - Таблица с данными (см. https://docs.efir-net.ru/dh2/#/Nsd/CommonData)
//
Функция NsdCommonData(ОписаниеОшибки, Сессия = Неопределено, ВходныеПараметры = Неопределено) Экспорт
	
	ТаблицаCommonData = Неопределено;	
	ОписаниеОшибки = "";
	НуженОтборПоNrdcodes = ЗначениеЗаполнено(ВходныеПараметры.nrdcodes);
	
	НастройкиСоединения = ПараметрыИсточника();
	
	НомерПачки = 0;
	Если ЗначениеЗаполнено(НастройкиСоединения) Тогда
		ОграничениеПоКоличествуЦБ = 100; // Ограничения RuData по объему запрашиваемых данных
		//
		nrdcodes = Новый Массив;
		//
		ПоследнийИндекс = ПоследнийИндексДляЦикла(ВходныеПараметры, "nrdcodes");
		Для Индекс = 0 По ПоследнийИндекс Цикл
			Если НуженОтборПоNrdcodes Тогда
				nrdcodes.Добавить(ВходныеПараметры.nrdcodes[Индекс]);
			КонецЕсли;
			Группировать = (Индекс + 1) % ОграничениеПоКоличествуЦБ;
			Если Группировать = 0 Или Индекс = ПоследнийИндекс Тогда
				НомерПачки = НомерПачки + 1;
				
				ВходящиеИдентификаторы = НовыеВходящиеИдентификаторы();
				ВходящиеИдентификаторы.Вставить("nrdcodes", nrdcodes);
				ВходныеПараметрыГруппа = НовыеВходныеПараметрыГруппы(НомерПачки, ВходныеПараметры.ДатаВремяОбновленияДанных,
					ВходящиеИдентификаторы); 
				ОбщегоНазначенияКлиентСервер.ДополнитьСтруктуруВыборочно(ВходныеПараметрыГруппа, ВходныеПараметры, "filter");
				
				ВременнаяТаблица =
					ТаблицаДанныхМетода("NsdCommonData", НастройкиСоединения, ОписаниеОшибки, Сессия, ВходныеПараметрыГруппа);
				//
				nrdcodes = Новый Массив;
				//
				Если ЗначениеЗаполнено(ВременнаяТаблица) Тогда
					ТаблицаCommonData = КонкатенацияТаблицЗначений(ТаблицаCommonData, ВременнаяТаблица);
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;
		
	КонецЕсли;
	
	Возврат ТаблицаCommonData;
	
КонецФункции

// Возвращает таблицу Emitent \ List
//
// Параметры:
//  ОписаниеОшибки	 - Строка	 - Описание ошибки (если есть)
//  Сессия			 - Строка	 - Кеш сессии HTTP
//  ВходныеПараметры - Структура - Структура входных параметров (может быть неопределено)
//    Обязательные поля:
//     * fininstids					 - Массив	 - массив fininstid (обязательное поле - идентификатор Эмитента в RuData)
//     * ДатаВремяОбновленияДанных	 - Дата		 - дата \ время начала выборки обновлений (пустая дата - по всем датам изменений)
// 
// Возвращаемое значение:
//   - ТаблицаЗначений - Таблица с данными (см. https://docs.efir-net.ru/dh2/#/Emitent/List)
//
Функция EmitentList(ОписаниеОшибки, Сессия = Неопределено, ВходныеПараметры = Неопределено) Экспорт
	
	ТаблицаEmitentList = Неопределено;
	
