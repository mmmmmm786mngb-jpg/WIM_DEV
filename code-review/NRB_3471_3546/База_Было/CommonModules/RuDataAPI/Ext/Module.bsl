Функция ЭмитентыКодыРегистрации()
	
	ОписаниеОшибки = "";
	Сессия = Неопределено;
	СквозныеПараметры = Новый Структура;
	СквозныеПараметры.Вставить("ДатаВремяОбновленияДанных", ТекущаяДатаСеанса());
	СквозныеПараметры.Вставить("filter", "id_code = 1");
	КодыРегистрации = RuDataAPI.InfoEmitentClassification(ОписаниеОшибки, Сессия, СквозныеПараметры);
	Если ОписаниеОшибки <> "" Или Не ЗначениеЗаполнено(КодыРегистрации) Тогда
		КодыРегистрации = Новый ТаблицаЗначений;
	КонецЕсли;
	
	Возврат КодыРегистрации;
	
КонецФункции

Функция ЦБДопущенныеКТоргамВРФ(ТаблицаInfoSecurities)
	ОписаниеОшибки = "";
	Сессия = Неопределено;
	
	ТекстФильтра = "id_code in (23, 37) and (up_to_date is null or up_to_date > 'текущая дата')";
	ТекстФильтра = СтрЗаменить(ТекстФильтра, "текущая дата", Формат(ТекущаяДатаСеанса(), "ДФ=dd-MM-yyyy") );
	fintoolids = ТаблицаInfoSecurities.ВыгрузитьКолонку("fintoolid");
	
	СквозныеПараметры = Новый Структура;
	СквозныеПараметры.Вставить("filter", ТекстФильтра);
	СквозныеПараметры.Вставить("fintoolids", fintoolids);
	
	// На самом деле ДатаВремяОбновленияДанных в InfoFintoolClassification не используется, там нет возможности фильтровать
	// по времени изменений, но этот параметр нужен для работы ряда используемых универсальных процедур "по дороге вниз".
	СквозныеПараметры.Вставить("ДатаВремяОбновленияДанных", ДАТА(1, 1, 1));
	
	КлассификацияЦБ = InfoFintoolClassification(ОписаниеОшибки, Сессия, СквозныеПараметры);
	
	ДопущенныеКТоргамЦБ = Новый ТаблицаЗначений;
	ДопущенныеКТоргамЦБ.Колонки.Добавить("fintoolid", ОбщегоНазначения.ОписаниеТипаСтрока(10));
	Если ОписаниеОшибки = "" И ЗначениеЗаполнено(КлассификацияЦБ) Тогда
		Для каждого ТекСтрока Из КлассификацияЦБ Цикл
			НовСтрока = ДопущенныеКТоргамЦБ.Добавить();
			НовСтрока.fintoolid = ТекСтрока.fintoolid;
		КонецЦикла;
	КонецЕсли;
	
	Возврат ДопущенныеКТоргамЦБ;
КонецФункции

