Функция InfoFintoolReferenceDataРеквизитыИИхТипы(ТолькоFintoolid)
	ИменаИТипыРеквизитов = Новый ТаблицаЗначений;
	ИменаИТипыРеквизитов.Колонки.Добавить("Имя");
	
	// Тип используется только при тестировании Ванесса для добавления тех колонок которых не оказалось в тестовых
	// данных (файл vsFintoolReferenceData.txt). Это нужно для того, чтобы при очередной доработке, когда мы добавляем
	// очередной реквизит, получаемый из RuData не пересоздовать каждый раз vsFintoolReferenceData.txt в тестах.
	ИменаИТипыРеквизитов.Колонки.Добавить("Тип");
	
	ДобавитьИнформациюОРеквизите(ИменаИТипыРеквизитов, "fintoolid");
	Если ТолькоFintoolid Тогда
		Возврат ИменаИТипыРеквизитов;
	КонецЕсли;
	
	ДобавитьИнформациюОРеквизите(ИменаИТипыРеквизитов, "base_asset_fintoolid");
	ДобавитьИнформациюОРеквизите(ИменаИТипыРеквизитов, "isincode");
