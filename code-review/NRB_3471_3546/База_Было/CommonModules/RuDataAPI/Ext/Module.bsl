// Процедура - Подключиться к сервису
//
// Параметры:
//  Соединение		 - HTTPСоединение	 - Соединение
//  Токен			 - Строка			 - Токен
//  Отказ			 - Булево			 - Отказ
//  ТекстОтказа		 - Строка			 - Описание ошибки
//  СлужебныйВызов	 - Булево			 - Признак служебного вызова
//  Сессия			 - Структура		 - Кеш
//
Процедура ПодключитьсяКСервису(Соединение,
	Токен,
	Отказ,
	ТекстОтказа,
	СлужебныйВызов = Ложь, Сессия = Неопределено) Экспорт
	
	ТекстОтказа = "";
	Соединение = Подключить(ТекстОтказа, СлужебныйВызов, Сессия);
	Если ЗначениеЗаполнено(ТекстОтказа) Тогда
		Отказ = Истина;
	Иначе
		Токен = ПараметрыСеанса.ТокенRuDataAPI;
	КонецЕсли;
	
КонецПроцедуры

// Процедура - Выйти из сервиса
//
// Параметры:
//  Соединение		 - HTTPСоединение	 - Соединение
//  Отказ		 - Булево	 - Отказ
//  ТекстОтказа	 - Строка	 - Описание ошибки
//
Процедура ВыйтиИзСервиса(Соединение, Отказ, ТекстОтказа) Экспорт
	
	Если Соединение = Неопределено Или ТестированиеVanessa.ЭтоТест() Тогда
		Возврат;
	КонецЕсли;
	
	ЗаголовкиЗапроса	= Новый Соответствие;
	ЗаголовкиЗапроса.Вставить("Content-Type",	 "application/json");
	ЗаголовкиЗапроса.Вставить("Authorization",	 ПараметрыСеанса.ТокенRuDataAPI);
	ЗаголовкиЗапроса.Вставить("Accept",			 "application/json");
	
	ЗапросОтключения = Новый HTTPЗапрос;
	ЗапросОтключения.АдресРесурса = "/v2/Account/Logoff";
	ЗапросОтключения.Заголовки = ЗаголовкиЗапроса;
	
	// Обрабатываем ответ
	КодУспешногоОтвета = 200;
	Ответ = Соединение.ОтправитьДляОбработки(ЗапросОтключения);
	Если Не Ответ.КодСостояния = КодУспешногоОтвета Тогда
		Отказ = Истина;
		ТекстСообщения = НСтр("ru='Не удалось корректно завершить выход из сервиса. Код ошибки: '") + Ответ.КодСостояния;
		ДобавитьТекстКСообщению(ТекстОтказа, ТекстСообщения);
	КонецЕсли;
	
	Соединение = Неопределено;
	ПараметрыСеанса.ТокенRuDataAPI = "";
	
КонецПроцедуры

