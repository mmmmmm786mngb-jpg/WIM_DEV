#Область Тестирование

Функция ИмитаторHTTP(URL, СтруктураДляJSON, СтруктураВозвратаПоУмолчанию)
	
	ЭтоSecurities			 = СтрНайти(URL, "Securities") > 0			 И СтруктураДляJSON.pageNum = 1;
	ЭтоFintoolReferenceData	 = СтрНайти(URL, "FintoolReferenceData") > 0 И СтруктураДляJSON.pager.page = 1;
	ЭтоCommonData			 = СтрНайти(URL, "CommonData") > 0			 И СтруктураДляJSON.pageNum = 1;
	ЭтоEmitentList			 = СтрНайти(URL, "Emitent/List") > 0		 И СтруктураДляJSON.pageNum = 1;
	ЭтоCountries			 = СтрНайти(URL, "Countries") > 0;
	
	ПолучитьТестовыеДанные = ЭтоSecurities Или ЭтоFintoolReferenceData Или ЭтоCommonData Или ЭтоEmitentList Или ЭтоCountries;
	
	Если ПолучитьТестовыеДанные Тогда
		XMLHTTPОтвет = ТестированиеVanessa.ТестовыеДанные(URL, СтруктураВозвратаПоУмолчанию);
		HTTPОтвет = ОбщегоНазначения.ЗначениеИзСтрокиXML(XMLHTTPОтвет);
	Иначе
		HTTPОтвет = Новый Массив;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(HTTPОтвет) И ТипЗнч(HTTPОтвет) = Тип("ХранилищеЗначения") Тогда
		
		HTTPОтвет = HTTPОтвет.Получить();
		
	КонецЕсли;
	
	Возврат HTTPОтвет;
	
КонецФункции

Процедура ДополнитьИмитаторТаблицыДанныхМетода(ИмяМетода, ВременнаяТаблица)
	
	Если Не ТестированиеVanessa.ЭтоТест() Тогда
		Возврат;
	КонецЕсли;
	
	Если ИмяМетода = "InfoFintoolReferenceData" Тогда
		// Добавляем те колонки, которых не оказалось в тестовых данных (файл vsFintoolReferenceData.txt).
		// Это нужно для того чтобы при очередной доработке, когда мы добавляем очередной реквизит, получаемый
		// из RuData не пересоздовать каждый раз vsFintoolReferenceData.txt в тестах.
		Колонки = ВременнаяТаблица.Колонки;
		ТолькоFintoolid = Ложь;
		РеквизитыИИхТипы = InfoFintoolReferenceDataРеквизитыИИхТипы(ТолькоFintoolid);
		Для каждого Реквизит Из РеквизитыИИхТипы Цикл
			Если Колонки.Найти(Реквизит.Имя) = Неопределено И Реквизит.Тип <> Неопределено Тогда
				Колонки.Добавить(Реквизит.Имя, Реквизит.Тип);
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область УниверсальныеМетоды

Функция ТипПоИмениРеквизита(ИмяРеквизита, ЧисловыеРеквизиты)
	
	Если ЧисловыеРеквизиты.НайтиПоЗначению(ИмяРеквизита) = Неопределено Тогда
		Возврат Тип("Строка");
	Иначе
		Возврат Тип("Число");
	КонецЕсли;
	
КонецФункции

Функция ЭтоКлючевойРеквизит(ИмяРеквизита)
	Если ИмяРеквизита = "fintoolid"
		Или ИмяРеквизита = "fininstid"
		Или ИмяРеквизита = "base_asset_fintoolid" Тогда
		Возврат Истина;
	Иначе
		Возврат Ложь;
	КонецЕсли;
КонецФункции

// Возвращает результат преобразования из массив структур - таблицы значений
//
// Параметры:
//  МассивСтруктур		 - Масив			 - Массив  структур
//  ЧисловыеРеквизиты	 - СписокЗначений	 - Список имен числовых реквизитов
// 
// Возвращаемое значение:
//   - ТаблицаЗначений - преобразованная из массива структур
//
Функция ПреобразоватьМассивВТаблицуЗначений(МассивСтруктур, ЧисловыеРеквизиты) Экспорт
	
	тзДанные = Новый ТаблицаЗначений;
	Для Каждого ЭлементМассива Из МассивСтруктур Цикл
		Если тзДанные.Колонки.Количество() = 0 Тогда
			ПреобразоватьМассивВТаблицуЗначенийКолонки(тзДанные, ЭлементМассива, ЧисловыеРеквизиты);
		КонецЕсли;
		НоваяСтрока = тзДанные.Добавить();
		ПреобразоватьМассивВТаблицуЗначенийСтроки(НоваяСтрока, ЭлементМассива);
	КонецЦикла;
	
	Возврат тзДанные;
КонецФункции

Процедура ПреобразоватьМассивВТаблицуЗначенийКолонки(тзДанные, ЭлементМассива, ЧисловыеРеквизиты)
	
	КС = Новый КвалификаторыСтроки(1000);
	Для Каждого ЗначениеСтруктуры Из ЭлементМассива Цикл
		МассивДопустимыеТипы = Новый Массив;
		
		Если ЭтоКлючевойРеквизит(ЗначениеСтруктуры.Ключ) Тогда
			ТипКолонки = Тип("Строка");
		Иначе
			ТипКолонки = ТипЗнч(ЗначениеСтруктуры.Значение);
		КонецЕсли;
		Если ТипКолонки = Тип("Неопределено") Тогда
			ТипКолонки = ТипПоИмениРеквизита(ЗначениеСтруктуры.Ключ, ЧисловыеРеквизиты);
		КонецЕсли;
		
		МассивДопустимыеТипы.Добавить(ТипКолонки);
		Если ТипКолонки = Тип("Строка") Тогда
			Описание_Типов = Новый ОписаниеТипов(МассивДопустимыеТипы, , , , КС);
		Иначе
			Описание_Типов = Новый ОписаниеТипов(МассивДопустимыеТипы);
		КонецЕсли;
		тзДанные.Колонки.Добавить(ЗначениеСтруктуры.Ключ, Описание_Типов);
	КонецЦикла;
	
КонецПроцедуры

Процедура ПреобразоватьМассивВТаблицуЗначенийСтроки(НоваяСтрока, ЭлементМассива)
	
	Для Каждого ЗначениеСтруктуры Из ЭлементМассива Цикл
		Если ЭтоКлючевойРеквизит(ЗначениеСтруктуры.Ключ) Тогда
			НоваяСтрока[ЗначениеСтруктуры.Ключ] = Формат(ЗначениеСтруктуры.Значение, "ЧГ=0");
		Иначе
			НоваяСтрока[ЗначениеСтруктуры.Ключ] = ЗначениеСтруктуры.Значение;
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

// Возвращает результат конкатенации таблиц значений
//  (должны быть одинаковые колонки)
//
// Параметры:
//  Таблица1					 - ТаблицаЗначений	 - Первая таблица (основная)
//  Таблица2					 - ТаблицаЗначений	 - Вторая таблица (добавляемая)
//  ПоместитьТаблицу2ВТаблицу1	 - Булево			 - Если Истина - то вторая таблица дописывается к первой (Таблица1 - изменяется),
//  													иначе возвращается новая таблица - объединение первой и второй
// 
// Возвращаемое значение:
//   - ТаблицаЗначений - результат конкатенации
//
Функция КонкатенацияТаблицЗначений(Таблица1, Таблица2, ПоместитьТаблицу2ВТаблицу1 = Истина) Экспорт
	Если Таблица1 = Неопределено Или Таблица1.Количество() = 0 Тогда
		Возврат Таблица2;
	КонецЕсли;
	Если Таблица2 = Неопределено Или Таблица2.Количество() = 0 Тогда
		Возврат Таблица1;
	КонецЕсли;
	
	Если ПоместитьТаблицу2ВТаблицу1 Тогда
		ОбъединениеТаблиц = Таблица1;
	Иначе
		ОбъединениеТаблиц = Таблица1.Скопировать();
	КонецЕсли;
	
	Для Каждого Строка Из Таблица2 Цикл
		ЗаполнитьЗначенияСвойств(ОбъединениеТаблиц.Добавить(), Строка);
	КонецЦикла;
	
	Возврат ОбъединениеТаблиц;
КонецФункции

Функция СвойствоЗаполнено(Структура, ИмяСвойства)
	Заполнено = Структура.Свойство(ИмяСвойства) И ЗначениеЗаполнено(Структура[ИмяСвойства]);
	
	Возврат Заполнено;
КонецФункции

