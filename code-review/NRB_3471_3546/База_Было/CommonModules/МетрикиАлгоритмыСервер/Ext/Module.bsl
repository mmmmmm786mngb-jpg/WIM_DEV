
#Область СлужебныйПрограммныйИнтерфейс

// Определение времени с последнего успешного обмена с Кафка (выгрузка)
// функция предназначена для вызова из кода поля Алгоритм элементов справочника МетрикиPrometheus
// Возвращаемое значение:
//	Структура - см.МетрикиСервер.НоваяПустаяТаблицаМетрики()
Функция ВремяСПоследнегоУспешногоОбменаКафка_Выгрузка() Экспорт
	
	Результат = МетрикиСервер.НоваяПустаяТаблицаМетрики();
	
	ТекущаяДата = ТекущаяДатаСеанса();
	ВремяУспешногоОбмена = ВремяСПоследнегоУспешногоОбменаКафка("ЖурналИсходящихСообщенийKafka", "ПериодОтправкиСообщения", "ОшибкаОтправки");
	ВремяСПоследнегоУспешногоОбменаКафка_Выгрузка = РазницаСекунды(ТекущаяДата, ВремяУспешногоОбмена);
	МетрикиСервер.ДобавитьКМетрикам(Результат, "ВремяСПоследнегоУспешногоОбменаКафка_Выгрузка", ВремяСПоследнегоУспешногоОбменаКафка_Выгрузка);
	
	Возврат Результат;
	
КонецФункции

// Определение времени с последнего успешного обмена с Кафка (загрузка)
// функция предназначена для вызова из кода поля Алгоритм элементов справочника МетрикиPrometheus
// Возвращаемое значение:
//	Структура - см.МетрикиСервер.НоваяПустаяТаблицаМетрики()
Функция ВремяСПоследнегоУспешногоОбменаКафка_Загрузка() Экспорт
	
	Результат = МетрикиСервер.НоваяПустаяТаблицаМетрики();
	
	ТекущаяДата = ТекущаяДатаСеанса();
	ВремяУспешногоОбмена = ВремяСПоследнегоУспешногоОбменаКафка("ЖурналВходящихСообщенийKafka", "ПериодОбработкиСообщения", "ОшибкаОбработки");
	ВремяСПоследнегоУспешногоОбменаКафка_Загрузка = РазницаСекунды(ТекущаяДата, ВремяУспешногоОбмена);
	МетрикиСервер.ДобавитьКМетрикам(Результат, "ВремяСПоследнегоУспешногоОбменаКафка_Загрузка", ВремяСПоследнегоУспешногоОбменаКафка_Загрузка);
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыФункции

Функция РазницаСекунды(ВремяКонец, ВремяНачало)
	Если ЗначениеЗаполнено(ВремяНачало) Тогда
		Возврат ВремяКонец - ВремяНачало;
	Иначе
		Возврат 0;
	КонецЕсли;
КонецФункции

Функция ВремяСПоследнегоУспешногоОбменаКафка(ИмяЖурнала, ИмяПоляПериода, ИмяФлагаОшибка)
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ЕСТЬNULL(МАКСИМУМ(ЖурналВходящихСообщенийKafka.ПериодОбработкиСообщения), ДАТАВРЕМЯ(1, 1, 1)) КАК ПериодОбработкиСообщения
	|ИЗ
	|	РегистрСведений.ЖурналВходящихСообщенийKafka КАК ЖурналВходящихСообщенийKafka
	|ГДЕ
	|	НЕ ЖурналВходящихСообщенийKafka.ОшибкаОбработки";
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "ЖурналВходящихСообщенийKafka", ИмяЖурнала);
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "ПериодОбработкиСообщения", ИмяПоляПериода);
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "ОшибкаОбработки", ИмяФлагаОшибка);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Выборка.Следующий();
	ВремяУспешногоОбмена = Выборка[ИмяПоляПериода];
	
	Возврат ВремяУспешногоОбмена;
	
КонецФункции

#КонецОбласти