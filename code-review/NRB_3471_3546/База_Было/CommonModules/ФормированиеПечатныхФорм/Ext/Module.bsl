//ФУНКЦИИ И ПРОЦЕДУРЫ ОБРАБОТКИ ИНФОРМАЦИИ О ЦБ.

Процедура УстановитьПараметрМакетаПосимвольно(Параметры, ИмяПараметра, ЧислоСимволов, ЗначениеПараметра) Экспорт

	Для сч=1 По ЧислоСимволов Цикл
		Параметры[ИмяПараметра+Строка(Сч)] = Сред(ЗначениеПараметра, Сч, 1);
	КонецЦикла; 

КонецПроцедуры

Процедура СформироватьДатуДДММММГГ(пПараметры, ПрефиксИмени, Дата) Экспорт

	Если НЕ ЗначениеЗаполнено(Дата) Тогда
		Возврат;
	КонецЕсли;
	
	ДеньСтрокой = Формат(День(Дата), "ЧЦ=2; ЧВН=");
	ГодСтрокой = Прав(Формат(Год(Дата), "ЧЦ=4; ЧВН=; ЧГ=0"), 2);
	
	Если ТипЗнч(пПараметры) = Тип("Структура") Тогда
		стПараметры = пПараметры;
	Иначе
		стПараметры = Новый Структура;
	КонецЕсли;
	
	стПараметры.Вставить(ПрефиксИмени + "День1", Лев(ДеньСтрокой, 1));
	стПараметры.Вставить(ПрефиксИмени + "День2", Прав(ДеньСтрокой, 1));

	стПараметры.Вставить(ПрефиксИмени + "Месяц", СтрЗаменить(Формат(НачалоМесяца(Дата), "ДФ='дд ММММ'"), "01 ", ""));

	стПараметры.Вставить(ПрефиксИмени + "Год1", Лев(ГодСтрокой, 1));
	стПараметры.Вставить(ПрефиксИмени + "Год2", Прав(ГодСтрокой, 1));
	
	Если ТипЗнч(пПараметры) = Тип("ПараметрыМакетаТабличногоДокумента") Тогда
		пПараметры.Заполнить(стПараметры);
	Иначе
		пПараметры = стПараметры;
	КонецЕсли;
	
КонецПроцедуры

Процедура СформироватьДатуДДММГГ(пПараметры, ПрефиксИмени, Дата) Экспорт

	Если НЕ ЗначениеЗаполнено(Дата) Тогда
		Возврат;
	КонецЕсли;
	
	ДатаСтрокой = Формат(Дата, "ДФ=ddMMyyyy");
	
	Если ТипЗнч(пПараметры) = Тип("Структура") Тогда
		стПараметры = пПараметры;
	Иначе
		стПараметры = Новый Структура;
	КонецЕсли;
	
	стПараметры.Вставить(ПрефиксИмени + "День1",	Сред(ДатаСтрокой, 1, 1));
	стПараметры.Вставить(ПрефиксИмени + "День2",	Сред(ДатаСтрокой, 2, 1));
	стПараметры.Вставить(ПрефиксИмени + "Месяц1",	Сред(ДатаСтрокой, 3, 1));
	стПараметры.Вставить(ПрефиксИмени + "Месяц2",	Сред(ДатаСтрокой, 4, 1));
	стПараметры.Вставить(ПрефиксИмени + "Год1",		Сред(ДатаСтрокой, 7, 1));
	стПараметры.Вставить(ПрефиксИмени + "Год2",		Сред(ДатаСтрокой, 8, 1));
	
	Если ТипЗнч(пПараметры) = Тип("ПараметрыМакетаТабличногоДокумента") Тогда
		пПараметры.Заполнить(стПараметры);
	Иначе
		пПараметры = стПараметры;
	КонецЕсли;
	
КонецПроцедуры

Процедура СформироватьДатуВремяДДММГГЧЧММ(пПараметры, ПрефиксИмени, Дата) Экспорт
	СформироватьДатуДДММГГ(пПараметры, ПрефиксИмени, Дата);
	
	ДатаСтрокой = Формат(Дата, "ДФ=HHmm");
	
	Если ТипЗнч(пПараметры) = Тип("Структура") Тогда
		стПараметры = пПараметры;
	Иначе
		стПараметры = Новый Структура;
	КонецЕсли;

	стПараметры.Вставить(ПрефиксИмени + "Час1",		Сред(ДатаСтрокой, 1, 1));
	стПараметры.Вставить(ПрефиксИмени + "Час2",		Сред(ДатаСтрокой, 2, 1));
	стПараметры.Вставить(ПрефиксИмени + "Минута1",	Сред(ДатаСтрокой, 3, 1));
	стПараметры.Вставить(ПрефиксИмени + "Минута2",	Сред(ДатаСтрокой, 4, 1));
	
	Если ТипЗнч(пПараметры) = Тип("ПараметрыМакетаТабличногоДокумента") Тогда
		пПараметры.Заполнить(стПараметры);
	Иначе
		пПараметры = стПараметры;
	КонецЕсли;
	
КонецПроцедуры

// Заполняет параметры макета посимвольно
// 
Процедура ЗаполнитьПараметрыДатыПечатнойФормы(ПараметрыМакета, Дата) Экспорт
	
	ДеньСтрокой = Формат(День(Дата), "ЧЦ=2; ЧН=; ЧВН=");
	МесяцСтрокой = Формат(Месяц(Дата), "ЧЦ=2; ЧН=; ЧВН=");
	ГодСтрокой = Прав(Формат(Год(Дата), "ЧЦ=4; ЧН=; ЧВН=; ЧГ=0"),2);
	
	ПараметрыМакета.День1 = Лев(ДеньСтрокой,1);
	ПараметрыМакета.День2 = Прав(ДеньСтрокой,1);
	
	ПараметрыМакета.Месяц1 = Лев(МесяцСтрокой,1);
	ПараметрыМакета.Месяц2 = Прав(МесяцСтрокой,1);
	
	ПараметрыМакета.Год1 = Лев(ГодСтрокой,1);
	ПараметрыМакета.Год2 = Прав(ГодСтрокой,1);
	
КонецПроцедуры

Процедура ПоказатьТабличныйДокумент(ТабДок) Экспорт
	
	ТабДок.ОтображатьСетку = Ложь;
	ТабДок.Защита = Ложь;
	ТабДок.ТолькоПросмотр = Истина;
	ТабДок.ОтображатьЗаголовки = Ложь;
	ТабДок.АвтоМасштаб = Истина;
	ТабДок.Показать();
	
КонецПроцедуры

// Получение картинки факсимилье
Процедура ПолучитьФаксимилье(ФизическоеЛицо, ТочкаВставки) Экспорт
	// Если нет физ. лица, то и получать нечего (возвращаем пустую картинку)
	Если ФизическоеЛицо = Неопределено Тогда
		ТочкаВставки = Новый Картинка;
		Возврат;
	КонецЕсли;
	// Находим факсимилье в справочнике файлов
	ЗапросФаксимилье	= Новый Запрос("ВЫБРАТЬ Ссылка ИЗ Справочник.Файлы ГДЕ НЕ ПометкаУдаления И Объект = &Объект И ДополнительныйПризнакФайла = ЗНАЧЕНИЕ(Перечисление.ДополнительныеПризнакиФайлов.Факсимилье)");
	ЗапросФаксимилье.УстановитьПараметр("Объект", ФизическоеЛицо);
	
	Результат	= ЗапросФаксимилье.Выполнить().Выгрузить();
	
	Если Результат.Количество()>0 Тогда
		СсылкаФайл	= Результат[0].Ссылка;
		// Сформируем картинку
		ТочкаВставки = Новый Картинка(СсылкаФайл.Данные.Получить(), Истина);
		Возврат;
	Иначе
		ТочкаВставки = Новый Картинка;
		Возврат;
	КонецЕсли;	
КонецПроцедуры

// Проверяет, умещаются ли переданные табличные документы на страницу при печати.
//
// Параметры:
//  ТабДокумент			 - ТабличныйДокумент - Табличный документ
//  ВыводимыеОбласти	 - Массив			 - Массив из проверяемых таблиц или табличный документ
//  РезультатПриОшибке	 - Булево			 - Какой возвращать результат при возникновении ошибки
// 
// Возвращаемое значение:
//  Булево - умещаются или нет переданные документы
//
Функция ПроверитьВыводТабличногоДокумента(ТабДокумент, ВыводимыеОбласти, РезультатПриОшибке = Истина) Экспорт
	
	Попытка
		Возврат ТабДокумент.ПроверитьВывод(ВыводимыеОбласти);
	Исключение
		Возврат РезультатПриОшибке;
	КонецПопытки;
	
КонецФункции // ПроверитьВыводТабличногоДокумента()

// Процедура - Вывести горизонтальный разделитель
//
// Параметры:
//  ТабличныйДокумент			 - ТабличныйДокумент - Табличный документ куда выводятся области
//  ОбластиКПечатиНаОдномЛисте	 - Массив			 - Массив областей макета к печати на одном листе
//
Процедура ВывестиГоризонтальныйРазделитель(ТабличныйДокумент, ОбластиКПечатиНаОдномЛисте) Экспорт
	Если Не ПроверитьВыводТабличногоДокумента(ТабличныйДокумент, ОбластиКПечатиНаОдномЛисте) Тогда
		// Если проверяемые области не помещаются на один лист - начать их вывод с нового листа
		ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();
	КонецЕсли;
КонецПроцедуры
