// ФУНКЦИИ ЗАПОЛНЕНИЯ ЗАГОЛОВКОВ ОТЧЕТОВ ПО ВИДУ СЧЕТА ДЕПО

// Читает XML-строку с текстами заголовков.
// Возвращает таблицу значений, содержащую тексты заголовков для вариантов ЦБ и ИФИ.
//
// Для добавления текстов заголовков в макетах:
// 1. В макете для печати заменить текст заголовка на имя параметра.
// Например, "Уполномоченное лицо Депозитария" заменить на "УполномоченноеЛицоДепозитария";
// 2. В XML-макет отчета "Заголовки" добавить узлы со значениями для подстановки в параметр.
//
// Параметры:
//	ОписаниеЗаголовковXML - строка с текстом XML
Функция ТекстыЗаголовковОтчетов(ОписаниеЗаголовковXML) Экспорт
	Тексты = Новый ТаблицаЗначений;
	Тексты.Колонки.Добавить("ИмяМакета");
	Тексты.Колонки.Добавить("ИмяСекции");
	Тексты.Колонки.Добавить("ИмяПараметра");
	Тексты.Колонки.Добавить("ЗаголовокЦБ");
	Тексты.Колонки.Добавить("ЗаголовокИФИ");
	
	ЧтениеXML = Новый ЧтениеXML;
	ЧтениеXML.УстановитьСтроку(ОписаниеЗаголовковXML);
	Построитель = Новый ПостроительDOM;
	Документ = Построитель.Прочитать(ЧтениеXML);
	Для Каждого Элемент0 Из Документ.ЭлементДокумента.ДочерниеУзлы Цикл
		Если Элемент0.ИмяУзла = "Макет" Тогда
			Макет = Элемент0;
			ИмяМакета = Макет.Атрибуты.ПолучитьИменованныйЭлемент("Имя");
			
			Для Каждого Элемент1 Из Макет.ДочерниеУзлы Цикл
				Если Элемент1.ИмяУзла = "Секция" Тогда
					Секция = Элемент1;
					ИмяСекции = Секция.Атрибуты.ПолучитьИменованныйЭлемент("Имя");
					
					Для Каждого Элемент2 Из Секция.ДочерниеУзлы Цикл
						Если Элемент2.ИмяУзла = "Параметр" Тогда
							Параметр = Элемент2;
							ИмяПараметра = Параметр.Атрибуты.ПолучитьИменованныйЭлемент("Имя");
							
							Строка = Тексты.Добавить();
							Строка.ИмяМакета	= СокрЛП(ИмяМакета.Значение);
							Строка.ИмяСекции	= СокрЛП(ИмяСекции.Значение);
							Строка.ИмяПараметра	= СокрЛП(ИмяПараметра.Значение);
							Строка.ЗаголовокЦБ	= "";
							Строка.ЗаголовокИФИ	= "";
							
							Для Каждого Элемент3 Из Параметр.ДочерниеУзлы Цикл
								Если Элемент3.ИмяУзла = "ЦБ" Тогда
									Строка.ЗаголовокЦБ = СокрЛП(Элемент3.ТекстовоеСодержимое);
								ИначеЕсли Элемент3.ИмяУзла = "ИФИ" Тогда
									Строка.ЗаголовокИФИ = СокрЛП(Элемент3.ТекстовоеСодержимое);
								КонецЕсли;
							КонецЦикла;
						КонецЕсли;
					КонецЦикла;
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
	КонецЦикла;
	
	Возврат Тексты;
КонецФункции

// Из таблицы выбираются строки с указанным макетом и секцией, в параметры области устанавливаются значения
// заголовков, соответствующих виду счета депо.
//
// Параметры:
//	ПараметрыОбласти - параметры области табличного документа, которая заполняется.
//	ИмяМакета и ИмяСекции - макет и секция указанной области.
//	ТекстыЗаголовков - таблица, из которой берутся имена параметров и их значения (заголовки).
//	ВидСчетаДепо - по нему определяется, какой заголовок брать из таблицы (для счета ДЕПО - ЦБ, для счета НФИ - ИФИ).
Процедура УстановитьЗаголовкиСекцииМакета(ПараметрыОбласти, ИмяМакета, ИмяСекции, ТекстыЗаголовков, ВидСчетаДепо) Экспорт
	Перем Отбор, Строки, Строка;
	
	Отбор = Новый Структура("ИмяМакета, ИмяСекции", ИмяМакета, ИмяСекции);
	Строки = ТекстыЗаголовков.НайтиСтроки(Отбор);
	Для Каждого Строка из Строки Цикл
		ПараметрыОбласти[Строка.ИмяПараметра] = Строка.ЗаголовокЦБ;
	КонецЦикла;
КонецПроцедуры

