//ФУНКЦИИ И ПРОЦЕДУРЫ ПРОВЕРКИ И ПЕЧАТИ АНКЕТЫ ДЕПОНЕНТА И ПРЕДСТАВИТЕЛЯ СЧЕТА ДЕПО.

// Функция проверяет на наличие представителя счета депо 
//                       на текущую дату.
// Параметры
//  СчетДепо  - СправочникСсылка.СчетДепо.
//    
// Возвращаемое значение:
//		Булево.Истина - если представитель есть и имеет статус назначен.   
//
Функция ПроверкаНаНаличиеПредставителяСчетаДепо(СчетДепо,ВидПредставителяСчетаДепо)  Экспорт

	СтруктураПредставителя	=	РегистрыСведений.ПредставителиСчетаДепо.ПолучитьПоследнее(ТекущаяДата(),	
            Новый Структура("СчетДепо,ВидПредставителя",СчетДепо,ВидПредставителяСчетаДепо));
			                            
	Если НЕ СтруктураПредставителя.Представитель.Пустая()  Тогда		
			
		Если СтруктураПредставителя.СтатусПредставителя = Перечисления.СтатусыПредставителей.Назначен Тогда
			
			Если ТекущаяДата() > СтруктураПредставителя.ДатаОкончанияДействияДоверенности  Тогда
			    			
			    Сообщить("Срок действия доверенности истек "+СтруктураПредставителя.ДатаОкончанияДействияДоверенности );
				
			КонецЕсли; 
			
			Результат	=	Истина;
			
		Иначе
			Сообщить("Представитель счета депо №" + СчетДепо.Код + " " + СтруктураПредставителя.Представитель
			        + " имеет статус отменен.");
			Результат	=	Ложь;
			
		КонецЕсли;	
		
	Иначе
		
		Сообщить(Строка(ВидПредставителяСчетаДепо) +" счета депо не назначен!");
		Результат	=	Ложь;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции // ПроверкаНаНаличиеПредставителяСчетаДепо(СчетДепо)
 
