//

//Функция проверяет заполненность ревизита шаблона и существование этого шаблона.
//
// Параметы:
//    ИмяФайла - строка, путь у шаблону печати.
//
//    НомерДоговора - строка, номер договора печати.
//
// Возвращаемое значение:
//    Истина.Булево - если проверка не проходит, иначе Ложь.
//
Функция ПроверкаШаблонаПечати(ИмяФайла,НомерДоговора) Экспорт
	
	//проверка на наличие указанного пути шаблона договора
	Если Не ЗначениеЗаполнено(ИмяФайла) Тогда
		Сообщить("Установите файл шаблона!");
		Возврат Истина;
	КонецЕсли;
	
	//проверка на существование договора.
    ВыбИмяФайла = Новый Файл(ИмяФайла);
    Если Не ВыбИмяФайла.Существует() Тогда  
        Сообщить("Не правильно указан путь к шаблону печати договора!!!");
        ИмяФайла = "";
		Возврат Истина;
	КонецЕсли;
	
	//проверка на наличие номера договора
	Если Не ЗначениеЗаполнено(НомерДоговора) Тогда
		Сообщить("Установите номер договора");
		Возврат Истина;
	КонецЕсли;

	Возврат Ложь;
	
КонецФункции

 // Функция получения данных о депозитарной лицензии контрагента в ввиде структуры.
//
// Параметры
//  Контрагент  – СправочникССылка.Контрагент. 
//                
// Возвращаемое значение:
//   Структура   – Данные о депозитарной лицензии.
//
Функция ДепозитарнаяЛицензияЮрика(Контрагент) Экспорт
	
	ДепозитарнаяЛицензия = Новый Структура("НомерЛицензии,ДатаЛицензии,ОрганВыдачи");
    Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ ПЕРВЫЕ 1
	|	КонтрагентыЛицензии.НомерЛицензии,
	|	КонтрагентыЛицензии.ДатаВыдачиЛицензии КАК ДатаВыдачиЛицензии,
	|	КонтрагентыЛицензии.ОрганВыдавшийЛицензию
	|ИЗ
	|	Справочник.Контрагенты.Лицензии КАК КонтрагентыЛицензии
	|ГДЕ
	|	КонтрагентыЛицензии.Ссылка = &Ссылка
	|	И КонтрагентыЛицензии.ТипЛицензии = &ТипЛицензии
	|
	|УПОРЯДОЧИТЬ ПО
	|	ДатаВыдачиЛицензии";
	
	Запрос.УстановитьПараметр("Ссылка",Контрагент );
	Запрос.УстановитьПараметр("ТипЛицензии",Справочники.ВидыЛицензий.БрокерскаяДеятельность);
	
	Результат = Запрос.Выполнить();
	
	Выборка = Результат.Выбрать();	
	Пока Выборка.Следующий() Цикл 	
		
	  ДепозитарнаяЛицензия.НомерЛицензии  =   Выборка.НомерЛицензии;
	  ДепозитарнаяЛицензия.ДатаЛицензии   =   Формат(Выборка.ДатаВыдачиЛицензии,"ДФ=dd.MM.yyyy; ДП=-");
	  ДепозитарнаяЛицензия.ОрганВыдачи    =	  Выборка.ОрганВыдавшийЛицензию
	  
	КонецЦикла;
	
	Если ДепозитарнаяЛицензия.НомерЛицензии = Неопределено Тогда
	    ДепозитарнаяЛицензия.НомерЛицензии = "Нет данных о номере лицензии";	
	КонецЕсли; 
	
	Если ДепозитарнаяЛицензия.ДатаЛицензии = Неопределено Тогда
	    ДепозитарнаяЛицензия.ДатаЛицензии = "Нет данных о дате лицензии";	
	КонецЕсли; 
    	
   Возврат ДепозитарнаяЛицензия
   
КонецФункции // ДанныеЛицензииОрганизации()


