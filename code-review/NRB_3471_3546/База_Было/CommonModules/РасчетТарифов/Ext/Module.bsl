Функция РасчетПоПоручению(Дата, Договор, Услуга)
	Перем Запрос, Выборка;
	Перем ДатаНачалаДействияУслуги, Шкала;
	
	Запрос = Новый Запрос("ВЫБРАТЬ
	                      |	РегистрНазначенныхКомиссийСрезПоследних.Услуга,
	                      |	РегистрНазначенныхКомиссийСрезПоследних.ФлагАктивности
	                      |ИЗ
	                      |	РегистрСведений.РегистрНазначенныхКомиссий.СрезПоследних(
	                      |			&Дата,
	                      |			ДоговорКонтрагента = &ДоговорКонтрагента
	                      |				И Услуга.Операция = &Операция
	                      |				"+?(Услуга.МестоХранения1 = Неопределено,""," И Услуга.МестоХранения1 = &МестоХранения1")+"
	                      |				"+?(Услуга.МестоХранения2 = Неопределено,""," И Услуга.МестоХранения2 = &МестоХранения2")+"
						  |) КАК РегистрНазначенныхКомиссийСрезПоследних");
	Запрос.УстановитьПараметр("Дата", Дата);
	Запрос.УстановитьПараметр("ДоговорКонтрагента",Договор);
	Запрос.УстановитьПараметр("Операция",Услуга.Операция);
	Если Услуга.МестоХранения1 <> Неопределено Тогда
		Запрос.УстановитьПараметр("МестоХранения1",Услуга.МестоХранения1);
	КонецЕсли;
	Если Услуга.МестоХранения2 <> Неопределено Тогда
		Запрос.УстановитьПараметр("МестоХранения2",Услуга.МестоХранения2);
	КонецЕсли;
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Если Выборка.ФлагАктивности Тогда
			Возврат РасчетПоШкале(Дата, Выборка.Услуга, 1);
		КонецЕсли;
	КонецЕсли;
	Возврат Неопределено;
КонецФункции

Функция КоличествоОткрытыхСчетовДепо(Дата, Клиент, ПериодРасчета)
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ЕСТЬNULL(КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ОстаткиИОборотыЦБ.СчетДепо), 0) КАК КоличествоСчетовДепо
	|ИЗ
	|	РегистрНакопления.ОстаткиЦБ.ОстаткиИОбороты(&НачалоПериода, &Дата, , , СчетДепо.Владелец = &Клиент) КАК ОстаткиИОборотыЦБ
	|ГДЕ
	|	(ОстаткиИОборотыЦБ.КоличествоНачальныйОстаток > 0
	|			ИЛИ ОстаткиИОборотыЦБ.КоличествоПриход > 0
	|			ИЛИ ОстаткиИОборотыЦБ.КоличествоРасход > 0)";
	
	Запрос.УстановитьПараметр("НачалоПериода",	ДатаНачалаПериодаРасчета(Дата, ПериодРасчета));	
	Запрос.УстановитьПараметр("Дата",			КонецДня(Дата));
	Запрос.УстановитьПараметр("Клиент",			Клиент);
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.КоличествоСчетовДепо;
	Иначе
		Возврат 0;
	КонецЕсли;
КонецФункции

// Возвращаемое значение:
// Если Услуга имеет тип "Структура", то расчетные параметры в виде структуры или Неопределено.
// Если Услуга имеет тип "СправочникСсылка.УслугиТарифногоПлана", то расчетные параметры в виде структуры
// или таблицы значений или Неопределено.
Функция РасчетСтоимостиУслуги(Дата, Договор, Услуга, ПериодРасчета = Неопределено) Экспорт
	Перем Результат;
	
	Если НЕ ЗначениеЗаполнено(ПериодРасчета) Тогда
		ПериодРасчета = Перечисления.ВариантыНачисленияКомиссий.Месяц;
	КонецЕсли;
	
	Результат = Новый Структура("Сумма, Тариф, ТипТарифа, СуммаКомиссии", 0, 0, Перечисления.ТипыТарифов.ПустаяСсылка(), 0);
	
	Если ТипЗнч(Услуга) = Тип("Структура") Тогда
		Возврат РасчетПоПоручению(Дата, Договор, Услуга);
		
	ИначеЕсли Услуга.ТипРасчета = Перечисления.ТипыРасчетаУслуги.ОстатокПоРыночнойСтоимости 
				ИЛИ Услуга.ТипРасчета = Перечисления.ТипыРасчетаУслуги.ОстатокПоВыпуску 
				ИЛИ Услуга.ТипРасчета = Перечисления.ТипыРасчетаУслуги.ОценкаРыночнойСтоимостиЗаМесяц Тогда
		РезультатЗапроса = ОценкаАктивов(Дата, Договор, Услуга, ПериодРасчета);
		ТаблицаОценок = РезультатЗапроса.Выгрузить();
		ТаблицаОценок.Свернуть("Тариф, ТипТарифа, Выгодоприобретатель", "Сумма, СуммаКомиссии");
		Возврат ТаблицаОценок;
		
	ИначеЕсли Услуга.ТипРасчета = Перечисления.ТипыРасчетаУслуги.КоличествоСчетовДЕПО Тогда
		Если РегистрыСведений.ЦенныеБумагиБезКомиссииЗаУслуги.НачислятьКомиссию(Дата, Услуга, Договор.Владелец) Тогда
			КоличествоОткрытыхСчетовДепо = КоличествоОткрытыхСчетовДепо(Дата, Договор.Владелец, ПериодРасчета);
			Возврат РасчетКомиссииПоШкалеУслуги(Дата, Услуга, КоличествоОткрытыхСчетовДепо, ПериодРасчета);
		КонецЕсли;
	КонецЕсли;
	Возврат Неопределено;
КонецФункции

Функция РТ_РасчетНДС(СтавкаНДС,Сумма) Экспорт
	Если СтавкаНДС = Перечисления.СтавкиНДС.БезНДС Тогда
		Возврат 0;
	ИначеЕсли СтавкаНДС = Перечисления.СтавкиНДС.НДС0 Тогда 
		Возврат 0;
	ИначеЕсли СтавкаНДС = Перечисления.СтавкиНДС.НДС10 Тогда 
		Возврат Сумма*0.1;
	ИначеЕсли СтавкаНДС = Перечисления.СтавкиНДС.НДС10_110 Тогда 
		Возврат Сумма*0.11;
	ИначеЕсли СтавкаНДС = Перечисления.СтавкиНДС.НДС18 Тогда 
		Возврат Сумма*0.18;
	ИначеЕсли СтавкаНДС = Перечисления.СтавкиНДС.НДС18_118 Тогда 
		Возврат Сумма*18/118;
	КонецЕсли;
	Возврат 0;
КонецФункции

Функция РТ_ОбщаяСумма(СтавкаНДС,Сумма,СуммаНДС) Экспорт
	Если СтавкаНДС = Перечисления.СтавкиНДС.НДС10 или СтавкаНДС = Перечисления.СтавкиНДС.НДС18 Тогда
		Возврат Сумма + СуммаНДС;
	Иначе
		Возврат Сумма;
	КонецЕсли;
КонецФункции


// Получение списка услуг по договору
// Используется из документа Услуги депозитария для промежуточного расчета комиссий при закрытии договора
// Использование отлеживает пользователь
// 
Функция ФормированиеСпискаЕжемесячныхУслуг(Дата, Знач Договор = НЕОПРЕДЕЛЕНО, Знач ТипРасчета = НЕОПРЕДЕЛЕНО) Экспорт
	Запрос = Новый Запрос();
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Календарь.Период КАК Период
	|ПОМЕСТИТЬ Календарь
	|ИЗ
	|	РегистрСведений.Календарь КАК Календарь
	|ГДЕ
	|	Календарь.Период МЕЖДУ &НачалоПериода И &Дата
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	МАКСИМУМ(РегистрНазначенныхКомиссий.Период) КАК ПериодНазначенияКомиссии,
	|	РегистрНазначенныхКомиссий.ДоговорКонтрагента КАК ДоговорКонтрагента,
	|	РегистрНазначенныхКомиссий.Услуга КАК Услуга,
	|	Календарь.Период КАК ПредварительнаяДатаРасчетаКомиссии
	|ПОМЕСТИТЬ РегистрНазначенныхКомиссийПоКалендарю
	|ИЗ
	|	РегистрСведений.РегистрНазначенныхКомиссий КАК РегистрНазначенныхКомиссий
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Календарь КАК Календарь
	|		ПО РегистрНазначенныхКомиссий.Период <= Календарь.Период
	|			И (РегистрНазначенныхКомиссий.Услуга.ПериодРасчета = ЗНАЧЕНИЕ(Перечисление.ВариантыНачисленияКомиссий.Месяц))
	|			И (РегистрНазначенныхКомиссий.ДоговорКонтрагента.Владелец ССЫЛКА Справочник.Контрагенты)
	|			И (РегистрНазначенныхКомиссий.ДоговорКонтрагента = &Договор
	|				ИЛИ &Договор = НЕОПРЕДЕЛЕНО)
	|			И (РегистрНазначенныхКомиссий.Услуга.ТипРасчета = &ТипРасчета
	|				ИЛИ &ТипРасчета = НЕОПРЕДЕЛЕНО)
	|			И (РегистрНазначенныхКомиссий.Услуга.ТипРасчета В (&ТипыРасчетаХранениеЦБ))
	|
	|СГРУППИРОВАТЬ ПО
	|	РегистрНазначенныхКомиссий.ДоговорКонтрагента,
	|	РегистрНазначенныхКомиссий.Услуга,
	|	Календарь.Период
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Комиссии.Услуга КАК Услуга,
	|	Комиссии.ДоговорКонтрагента КАК Договор
	|ИЗ
	|	РегистрСведений.РегистрНазначенныхКомиссий КАК Комиссии
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрНазначенныхКомиссийПоКалендарю КАК РегистрНазначенныхКомиссийПоКалендарю
	|		ПО Комиссии.Период = РегистрНазначенныхКомиссийПоКалендарю.ПериодНазначенияКомиссии
	|			И Комиссии.Услуга = РегистрНазначенныхКомиссийПоКалендарю.Услуга
	|			И Комиссии.ДоговорКонтрагента = РегистрНазначенныхКомиссийПоКалендарю.ДоговорКонтрагента
	|			И (Комиссии.ФлагАктивности = ИСТИНА)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Комиссии.Услуга,
	|	Комиссии.ДоговорКонтрагента
	|ИЗ
	|	РегистрСведений.РегистрНазначенныхКомиссий.СрезПоследних(
	|			&Дата,
	|			Услуга.ПериодРасчета = ЗНАЧЕНИЕ(Перечисление.ВариантыНачисленияКомиссий.Месяц)
	|				И ДоговорКонтрагента.Владелец ССЫЛКА Справочник.Контрагенты) КАК Комиссии
	|ГДЕ
	|	Комиссии.ФлагАктивности = ИСТИНА
	|	И (Комиссии.ДоговорКонтрагента = &Договор
	|			ИЛИ &Договор = НЕОПРЕДЕЛЕНО)
	|	И (Комиссии.Услуга.ТипРасчета = &ТипРасчета
	|			ИЛИ &ТипРасчета = НЕОПРЕДЕЛЕНО)
	|	И НЕ Комиссии.Услуга.ТипРасчета В (&ТипыРасчетаХранениеЦБ)";
	
	Запрос.УстановитьПараметр("Дата", Дата);
	Запрос.УстановитьПараметр("Договор", Договор);
	Запрос.УстановитьПараметр("ТипРасчета", ТипРасчета);
	Запрос.УстановитьПараметр("НачалоПериода", НачалоМесяца(Дата));
	ТипыРасчетаХранениеЦБ = Новый Массив;
	ТипыРасчетаХранениеЦБ.Добавить(Перечисления.ТипыРасчетаУслуги.ОстатокПоВыпуску);
	ТипыРасчетаХранениеЦБ.Добавить(Перечисления.ТипыРасчетаУслуги.ОстатокПоРыночнойСтоимости);
	ТипыРасчетаХранениеЦБ.Добавить(Перечисления.ТипыРасчетаУслуги.ОценкаРыночнойСтоимостиЗаМесяц);
	Запрос.УстановитьПараметр("ТипыРасчетаХранениеЦБ", ТипыРасчетаХранениеЦБ);
	
	Возврат Запрос.Выполнить().Выбрать();
КонецФункции

