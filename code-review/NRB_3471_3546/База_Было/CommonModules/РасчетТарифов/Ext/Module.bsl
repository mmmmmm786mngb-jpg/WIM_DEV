Функция ТипТарифа_ФиксированнаяСумма(Дата, Тариф, Валюта, Знач ОграничениеСуммы=0)
	Перем ПараметрыВалюты;
	Перем ВозвращаемоеЗначение;
	ПараметрыВалюты = РегистрыСведений.КурсыВалют.ПолучитьПоследнее(Дата,Новый Структура("Валюта",Валюта));
	Если ПараметрыВалюты.Курс = Неопределено Тогда
		Сообщить("Для валюты "+Валюта+" на дату "+Дата+" не определен курс валюты",СтатусСообщения.Важное);
		Возврат Неопределено;
	КонецЕсли;
	Если ПараметрыВалюты.Кратность = Неопределено Тогда
		Сообщить("Для валюты "+Валюта+" на дату "+Дата+" не определена кратность валюты",СтатусСообщения.Важное);
		Возврат Неопределено;
	КонецЕсли;
	ВозвращаемоеЗначение = ?(ОграничениеСуммы = 0, Тариф * ПараметрыВалюты.Курс / ПараметрыВалюты.Кратность, Мин(Тариф * ПараметрыВалюты.Курс / ПараметрыВалюты.Кратность,ОграничениеСуммы));
	Возврат ВозвращаемоеЗначение;
КонецФункции	

Функция ТипТарифа_ПроцентОтНачисления(Дата, Объем, Тариф, Валюта, Знач ОграничениеСуммы=0)
	Перем ПараметрыВалюты, НоминалЦБ;
	Перем ВозвращаемоеЗначение;
	ПараметрыВалюты = РегистрыСведений.КурсыВалют.ПолучитьПоследнее(Дата,Новый Структура("Валюта",Валюта));
	Если ПараметрыВалюты.Курс = Неопределено Тогда
		Сообщить("Для валюты "+Валюта+" на дату "+Дата+" не определен курс валюты",СтатусСообщения.Важное);
		Возврат Неопределено;
	КонецЕсли;
	Если ПараметрыВалюты.Кратность = Неопределено Тогда
		Сообщить("Для валюты "+Валюта+" на дату "+Дата+" не определена кратность валюты",СтатусСообщения.Важное);
		Возврат Неопределено;
	КонецЕсли;
	ВозвращаемоеЗначение = ?(ОграничениеСуммы = 0,Объем * Тариф / 100 * ПараметрыВалюты.Курс / ПараметрыВалюты.Кратность,Мин(Объем * Тариф / 100 * ПараметрыВалюты.Курс / ПараметрыВалюты.Кратность,ОграничениеСуммы));
	Возврат ВозвращаемоеЗначение;
КонецФункции	

Функция ТипТарифа_ЦенаЗаЕдиницу(Дата, Тариф, ЦеннаяБумага, Валюта, Знач ОграничениеСуммы=0)
	Перем ПараметрыВалюты, НоминалЦБ;
	Перем ВозвращаемоеЗначение;
	ПараметрыВалюты = РегистрыСведений.КурсыВалют.ПолучитьПоследнее(Дата,Новый Структура("Валюта",Валюта));
	Если ПараметрыВалюты.Курс = Неопределено Тогда
		Сообщить("Для валюты "+Валюта+" на дату "+Дата+" не определен курс валюты",СтатусСообщения.Важное);
		Возврат Неопределено;
	КонецЕсли;
	Если ПараметрыВалюты.Кратность = Неопределено Тогда
		Сообщить("Для валюты "+Валюта+" на дату "+Дата+" не определена кратность валюты",СтатусСообщения.Важное);
		Возврат Неопределено;
	КонецЕсли;
	ВозвращаемоеЗначение = ?(ОграничениеСуммы = 0,НоминалЦБ.Сумма * Тариф * ПараметрыВалюты.Курс / ПараметрыВалюты.Кратность,Мин(НоминалЦБ.Сумма * Тариф * ПараметрыВалюты.Курс / ПараметрыВалюты.Кратность,ОграничениеСуммы));
	Возврат ВозвращаемоеЗначение;
КонецФункции	

Функция ШкалаДляРасчетаУслуги(Дата, Услуга, Объем) Экспорт
	Перем Запрос, Выборка, Результат;
	Запрос = Новый Запрос("ВЫБРАТЬ ПЕРВЫЕ 1
	                      |	ТарифыСрезПоследних.Тариф,
	                      |	ТарифыСрезПоследних.ТипТарифа
	                      |ИЗ
	                      |	РегистрСведений.Тарифы.СрезПоследних(
	                      |			&Дата,
	                      |			Услуга = &Услуга
	                      |				И Шкала >= &Шкала) КАК ТарифыСрезПоследних
	                      |
	                      |УПОРЯДОЧИТЬ ПО
	                      |	ТарифыСрезПоследних.Шкала");
	Запрос.УстановитьПараметр("Дата", Дата);
	Запрос.УстановитьПараметр("Услуга", Услуга);
	Запрос.УстановитьПараметр("Шкала", Объем);
	Возврат Запрос.Выполнить().Выбрать();
КонецФункции

Функция РасчетПоШкале(Дата, Услуга, Объем)
	Перем Выборка, СтруктураОтвета;
	
	СтруктураОтвета = Новый Структура("Тариф,ТипТарифа,Сумма,Валюта,Услуга,Объем");
	СтруктураОтвета.Услуга = Услуга;
	СтруктураОтвета.Валюта = Услуга.Валюта;
	СтруктураОтвета.Объем = Объем;
	Выборка = ШкалаДляРасчетаУслуги(Дата, Услуга, Объем);
	Если НЕ Выборка.Следующий() Тогда
		Сообщить("Для услуги <"+Услуга+"> на дату <"+Дата+"> не удалось определить шкалу расчета",СтатусСообщения.Важное);
		Возврат Неопределено
	КонецЕсли;
	СтруктураОтвета.Тариф = Выборка.Тариф;
	СтруктураОтвета.ТипТарифа = Выборка.ТипТарифа;
	
	Если Выборка.ТипТарифа = Перечисления.ТипыТарифов.ФиксированнаяСумма Тогда
		СтруктураОтвета.Сумма = ТипТарифа_ФиксированнаяСумма(Дата, Выборка.Тариф, Услуга.Валюта, Услуга.ОграничениеСуммыНачисления);
		Возврат СтруктураОтвета;
	ИначеЕсли Выборка.ТипТарифа = Перечисления.ТипыТарифов.ПроцентОтНачисления Тогда
		СтруктураОтвета.Сумма = ТипТарифа_ПроцентОтНачисления(Дата, Объем, Выборка.Тариф, Услуга.Валюта, Услуга.ОграничениеСуммыНачисления);
		Возврат СтруктураОтвета;
	ИначеЕсли Выборка.ТипТарифа = Перечисления.ТипыТарифов.ЦенаЗаЕдиницу Тогда
		СтруктураОтвета.Сумма = ТипТарифа_ЦенаЗаЕдиницу(Дата, Выборка.Тариф, Услуга.Валюта, Услуга.ОграничениеСуммыНачисления);
		Возврат СтруктураОтвета;
	КонецЕсли;
	Возврат Неопределено;
КонецФункции

Функция ОценкаАктивов(Дата, Знач Договор = Неопределено, Услуга, ПериодРасчета = Неопределено) Экспорт
	ДоступныеПериодыРасчета = Новый Массив;
	ДоступныеПериодыРасчета.Добавить(Перечисления.ВариантыНачисленияКомиссий.Месяц);
	ДоступныеПериодыРасчета.Добавить(Перечисления.ВариантыНачисленияКомиссий.Квартал);
	ДоступныеПериодыРасчета.Добавить(Перечисления.ВариантыНачисленияКомиссий.Полугодие);
	ДоступныеПериодыРасчета.Добавить(Перечисления.ВариантыНачисленияКомиссий.Год);
	
	Если НЕ ЗначениеЗаполнено(ПериодРасчета) ИЛИ ДоступныеПериодыРасчета.Найти(ПериодРасчета) = Неопределено Тогда
		ПериодРасчета = Перечисления.ВариантыНачисленияКомиссий.Месяц;
	КонецЕсли;
	
	// Внимание. Если нужно изменить запрос, то нужно так же изменить и запрос по расшифровке данных.
	// Он находится в этом же модуле в функции "РасшифровкаОценкиАктивовПоСтроке".
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	Календарь.Период КАК Период
	|ПОМЕСТИТЬ Календарь
	|ИЗ
	|	РегистрСведений.Календарь КАК Календарь
	|ГДЕ
	|	Календарь.Период МЕЖДУ &НачалоПериода И &Период
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	МАКСИМУМ(РегистрНазначенныхКомиссий.Период) КАК ПериодНазначенияКомиссии,
	|	РегистрНазначенныхКомиссий.ДоговорКонтрагента КАК ДоговорКонтрагента,
	|	РегистрНазначенныхКомиссий.Услуга КАК Услуга,
	|	Календарь.Период КАК ПредварительнаяДатаРасчетаКомиссии
	|ПОМЕСТИТЬ РегистрНазначенныхКомиссийПоКалендарю
	|ИЗ
	|	РегистрСведений.РегистрНазначенныхКомиссий КАК РегистрНазначенныхКомиссий
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Календарь КАК Календарь
	|		ПО РегистрНазначенныхКомиссий.Период <= Календарь.Период
	|			И (РегистрНазначенныхКомиссий.Услуга = &Услуга)
	|			И (РегистрНазначенныхКомиссий.Услуга.ПериодРасчета = &ПериодРасчета)
	|			И (РегистрНазначенныхКомиссий.Услуга.ВидКомиссии = &ДепозитарнаяКомиссия)
	|			И (РегистрНазначенныхКомиссий.Услуга.ТипРасчета = &ТипРасчета)
	|			И (РегистрНазначенныхКомиссий.ДоговорКонтрагента = &Договор
	|				ИЛИ &Договор = НЕОПРЕДЕЛЕНО)
	|			И РегистрНазначенныхКомиссий.ДоговорКонтрагента.ДатаНачалоДействия <= Календарь.Период
	|			И (РегистрНазначенныхКомиссий.ДоговорКонтрагента.ДатаОкончанияДействия = ДАТАВРЕМЯ(1, 1, 1, 0, 0, 0))
	|
	|СГРУППИРОВАТЬ ПО
	|	РегистрНазначенныхКомиссий.ДоговорКонтрагента,
	|	РегистрНазначенныхКомиссий.Услуга,
	|	Календарь.Период
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Комиссии.ДоговорКонтрагента КАК ДоговорКонтрагента,
	|	Комиссии.Услуга КАК Услуга
	|ПОМЕСТИТЬ СписокКлиентов
	|ИЗ
	|	РегистрСведений.РегистрНазначенныхКомиссий КАК Комиссии
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрНазначенныхКомиссийПоКалендарю КАК РегистрНазначенныхКомиссийПоКалендарю
	|		ПО Комиссии.Период = РегистрНазначенныхКомиссийПоКалендарю.ПериодНазначенияКомиссии
	|			И Комиссии.ДоговорКонтрагента = РегистрНазначенныхКомиссийПоКалендарю.ДоговорКонтрагента
	|			И Комиссии.Услуга = РегистрНазначенныхКомиссийПоКалендарю.Услуга
	|			И (Комиссии.ФлагАктивности)
	|			И (Комиссии.ДоговорКонтрагента.ДатаНачалоДействия <= &Период)
	|
	|СГРУППИРОВАТЬ ПО
	|	Комиссии.ДоговорКонтрагента,
	|	Комиссии.Услуга
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Комиссии.ДоговорКонтрагента КАК ДоговорКонтрагента,
	|	РегистрНазначенныхКомиссийПоКалендарю.ПредварительнаяДатаРасчетаКомиссии КАК Период
	|ПОМЕСТИТЬ КалендарьПоДоговору
	|ИЗ
	|	РегистрСведений.РегистрНазначенныхКомиссий КАК Комиссии
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрНазначенныхКомиссийПоКалендарю КАК РегистрНазначенныхКомиссийПоКалендарю
	|		ПО Комиссии.Период = РегистрНазначенныхКомиссийПоКалендарю.ПериодНазначенияКомиссии
	|			И Комиссии.ДоговорКонтрагента = РегистрНазначенныхКомиссийПоКалендарю.ДоговорКонтрагента
	|			И Комиссии.Услуга = РегистрНазначенныхКомиссийПоКалендарю.Услуга
	|			И (Комиссии.ФлагАктивности)
	|			И (Комиссии.ДоговорКонтрагента.ДатаНачалоДействия <= &Период)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ОстаткиИОборотыЦБ.Период КАК Период,
	|	ОстаткиИОборотыЦБ.ЦБ КАК ЦБ,
	|	ОстаткиИОборотыЦБ.ЦБ.ТипЦБ КАК ЦБТипЦБ,
	|	ОстаткиИОборотыЦБ.ЦБ.ДатаПогашения КАК ЦБДатаПогашения,
	|	ОстаткиИОборотыЦБ.КоличествоКонечныйОстаток КАК КоличествоКонечныйОстаток,
	|	ОстаткиИОборотыЦБ.СчетДепо КАК СчетДепо,
	|	ОстаткиИОборотыЦБ.СчетДепо.Владелец КАК СчетДепоВладелец,
	|	НЕОПРЕДЕЛЕНО КАК Выгодоприобретатель
	|ПОМЕСТИТЬ ВТ_ОстаткиИОборотыЦБ
	|ИЗ
	|	РегистрНакопления.ОстаткиЦБ.ОстаткиИОбороты(
	|			&НачалоПериода,
	|			КОНЕЦПЕРИОДА(&Период, ДЕНЬ),
	|			День,
	|			,
	|			НЕ СчетДепо.Владелец.Субброкер
	|				И &УсловиеОтбораПоМестуХранения
	|				И &УсловиеОтбораПоВидамЦББанкаРоссии
	|				И СчетДепо.Владелец В
	|					(ВЫБРАТЬ
	|						СписокКлиентов.ДоговорКонтрагента.Владелец КАК Клиент
	|					ИЗ
	|						СписокКлиентов КАК СписокКлиентов)) КАК ОстаткиИОборотыЦБ
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ОстаткиИОборотыЦБ.Период,
	|	ОстаткиИОборотыЦБ.ЦБ,
	|	ОстаткиИОборотыЦБ.ЦБ.ТипЦБ,
	|	ОстаткиИОборотыЦБ.ЦБ.ДатаПогашения,
	|	ОстаткиИОборотыЦБ.КоличествоКонечныйОстаток,
	|	ОстаткиИОборотыЦБ.СчетДепо,
	|	ОстаткиИОборотыЦБ.СчетДепо.Владелец,
	|	ОстаткиИОборотыЦБ.РазделСчетаДепо.Субклиент
	|ИЗ
	|	РегистрНакопления.ОстаткиЦБ.ОстаткиИОбороты(
	|			&НачалоПериода,
	|			КОНЕЦПЕРИОДА(&Период, ДЕНЬ),
	|			День,
	|			,
	|			СчетДепо.Владелец.Субброкер
	|				И &УсловиеОтбораПоМестуХранения
	|				И &УсловиеОтбораПоВидамЦББанкаРоссии
	|				И СчетДепо.Владелец В
	|					(ВЫБРАТЬ
	|						СписокКлиентов.ДоговорКонтрагента.Владелец КАК Клиент
	|					ИЗ
	|						СписокКлиентов КАК СписокКлиентов)) КАК ОстаткиИОборотыЦБ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ОстаткиИОборотыЦБ.Период КАК Период,
	|	ОстаткиИОборотыЦБ.ЦБ КАК ЦБ,
	|	ВЫБОР
	|		КОГДА ОстаткиИОборотыЦБ.ЦБТипЦБ = &ТипЦБОблигация
	|				И ОстаткиИОборотыЦБ.ЦБДатаПогашения <= НАЧАЛОПЕРИОДА(ОстаткиИОборотыЦБ.Период, КВАРТАЛ)
	|				И НЕ ОстаткиИОборотыЦБ.ЦБДатаПогашения = ДАТАВРЕМЯ(1, 1, 1)
	|			ТОГДА 0
	|		ИНАЧЕ ОстаткиИОборотыЦБ.КоличествоКонечныйОстаток
	|	КОНЕЦ КАК КоличествоКонечныйОстаток,
	|	СписокКлиентов.ДоговорКонтрагента КАК ДоговорКонтрагента,
	|	ОстаткиИОборотыЦБ.СчетДепо КАК СчетДепо,
	|	ОстаткиИОборотыЦБ.Выгодоприобретатель КАК Выгодоприобретатель
	|ПОМЕСТИТЬ ОстаткиПоСчетамДЕПО
	|ИЗ
	|	СписокКлиентов КАК СписокКлиентов
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_ОстаткиИОборотыЦБ КАК ОстаткиИОборотыЦБ
	|		ПО СписокКлиентов.ДоговорКонтрагента.Владелец = ОстаткиИОборотыЦБ.СчетДепоВладелец
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Календарь.Период КАК Период,
	|	МАКСИМУМ(ОстаткиПоСчетамДЕПО.Период) КАК ПериодРасчета,
	|	ОстаткиПоСчетамДЕПО.ДоговорКонтрагента КАК ДоговорКонтрагента,
	|	ОстаткиПоСчетамДЕПО.СчетДепо КАК СчетДепо,
	|	ОстаткиПоСчетамДЕПО.Выгодоприобретатель КАК Выгодоприобретатель,
	|	ОстаткиПоСчетамДЕПО.ЦБ КАК ЦБ
	|ПОМЕСТИТЬ ТаблицаРаспределенияПериодовПоДням
	|ИЗ
	|	КалендарьПоДоговору КАК Календарь
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ОстаткиПоСчетамДЕПО КАК ОстаткиПоСчетамДЕПО
	|		ПО Календарь.Период >= ОстаткиПоСчетамДЕПО.Период
	|			И Календарь.ДоговорКонтрагента = ОстаткиПоСчетамДЕПО.ДоговорКонтрагента
	|
	|СГРУППИРОВАТЬ ПО
	|	Календарь.Период,
	|	ОстаткиПоСчетамДЕПО.ДоговорКонтрагента,
	|	ОстаткиПоСчетамДЕПО.СчетДепо,
	|	ОстаткиПоСчетамДЕПО.Выгодоприобретатель,
	|	ОстаткиПоСчетамДЕПО.ЦБ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТаблицаРаспределенияПериодовПоДням.Период КАК Период,
	|	ТаблицаРаспределенияПериодовПоДням.ДоговорКонтрагента КАК ДоговорКонтрагента,
	|	ТаблицаРаспределенияПериодовПоДням.СчетДепо КАК СчетДепо,
	|	ТаблицаРаспределенияПериодовПоДням.Выгодоприобретатель КАК Выгодоприобретатель,
	|	ТаблицаРаспределенияПериодовПоДням.ЦБ КАК ЦБ,
	|	ВЫБОР
	|		КОГДА ОстаткиПоСчетамДЕПО.ЦБ.ТипЦБ = &ТипЦБОблигация
	|				И ОстаткиПоСчетамДЕПО.ЦБ.ДатаПогашения <= НАЧАЛОПЕРИОДА(ТаблицаРаспределенияПериодовПоДням.Период, КВАРТАЛ)
	|				И НЕ ОстаткиПоСчетамДЕПО.ЦБ.ДатаПогашения = ДАТАВРЕМЯ(1, 1, 1)
	|			ТОГДА 0
	|		ИНАЧЕ ОстаткиПоСчетамДЕПО.КоличествоКонечныйОстаток
	|	КОНЕЦ КАК Количество
	|ПОМЕСТИТЬ ТаблицаОстатковРаспределеннаяПоДням
	|ИЗ
	|	ТаблицаРаспределенияПериодовПоДням КАК ТаблицаРаспределенияПериодовПоДням
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ОстаткиПоСчетамДЕПО КАК ОстаткиПоСчетамДЕПО
	|		ПО ТаблицаРаспределенияПериодовПоДням.ПериодРасчета = ОстаткиПоСчетамДЕПО.Период
	|			И ТаблицаРаспределенияПериодовПоДням.ДоговорКонтрагента = ОстаткиПоСчетамДЕПО.ДоговорКонтрагента
	|			И ТаблицаРаспределенияПериодовПоДням.СчетДепо = ОстаткиПоСчетамДЕПО.СчетДепо
	|			И ТаблицаРаспределенияПериодовПоДням.Выгодоприобретатель = ОстаткиПоСчетамДЕПО.Выгодоприобретатель
	|			И ТаблицаРаспределенияПериодовПоДням.ЦБ = ОстаткиПоСчетамДЕПО.ЦБ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ТаблицаОстатковРаспределеннаяПоДням.Период КАК Период,
	|	ТаблицаОстатковРаспределеннаяПоДням.ЦБ КАК ЦБ
	|ПОМЕСТИТЬ ТаблицаЦБПоДатамПриНаличииОстатков
	|ИЗ
	|	ТаблицаОстатковРаспределеннаяПоДням КАК ТаблицаОстатковРаспределеннаяПоДням
	|ГДЕ
	|	ТаблицаОстатковРаспределеннаяПоДням.Количество <> 0
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТаблицаЦБПоДатамПриНаличииОстатков.Период КАК Период,
	|	ТаблицаЦБПоДатамПриНаличииОстатков.ЦБ КАК ЦБ,
	|	МАКСИМУМ(Котировки.Период) КАК ПериодКотировки
	|ПОМЕСТИТЬ ТаблицаДатКотировок
	|ИЗ
	|	ТаблицаЦБПоДатамПриНаличииОстатков КАК ТаблицаЦБПоДатамПриНаличииОстатков
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.Котировки КАК Котировки
	|		ПО ТаблицаЦБПоДатамПриНаличииОстатков.ЦБ = Котировки.ЦеннаяБумага
	|			И ТаблицаЦБПоДатамПриНаличииОстатков.Период >= Котировки.Период
	|			И (ТаблицаЦБПоДатамПриНаличииОстатков.Период <= ДОБАВИТЬКДАТЕ(Котировки.Период, ДЕНЬ, 90))
	|			И (Котировки.РыночнаяЦена > 0)
	|			И (Котировки.Биржа = &НРД)
	|			И (Котировки.РежимТоргов.РежимТоргов = &РежимТорговРыночный)
	|
	|СГРУППИРОВАТЬ ПО
	|	ТаблицаЦБПоДатамПриНаличииОстатков.Период,
	|	ТаблицаЦБПоДатамПриНаличииОстатков.ЦБ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТаблицаДатКотировок.Период КАК Период,
	|	ТаблицаДатКотировок.ЦБ КАК ЦБ,
	|	ЕСТЬNULL(МАКСИМУМ(Котировки.РыночнаяЦена), 0) КАК РыночнаяЦена
	|ПОМЕСТИТЬ ТаблицаРыночныхЦенНаДатыОстатков
	|ИЗ
	|	ТаблицаДатКотировок КАК ТаблицаДатКотировок
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.Котировки КАК Котировки
	|		ПО ТаблицаДатКотировок.ПериодКотировки = Котировки.Период
	|			И ТаблицаДатКотировок.ЦБ = Котировки.ЦеннаяБумага
	|			И (Котировки.Биржа = &НРД)
	|			И (Котировки.РежимТоргов.РежимТоргов = &РежимТорговРыночный)
	|
	|СГРУППИРОВАТЬ ПО
	|	ТаблицаДатКотировок.Период,
	|	ТаблицаДатКотировок.ЦБ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТаблицаОстатковРаспределеннаяПоДням.Период КАК Период,
	|	ТаблицаОстатковРаспределеннаяПоДням.ДоговорКонтрагента КАК ДоговорКонтрагента,
	|	ТаблицаОстатковРаспределеннаяПоДням.СчетДепо КАК СчетДепо,
	|	ТаблицаОстатковРаспределеннаяПоДням.Выгодоприобретатель КАК Выгодоприобретатель,
	|	ТаблицаОстатковРаспределеннаяПоДням.ЦБ КАК ЦБ,
	|	ТаблицаОстатковРаспределеннаяПоДням.Количество КАК Количество,
	|	ЕСТЬNULL(ТаблицаРыночныхЦенНаДатыОстатков.РыночнаяЦена, 0) КАК РыночнаяЦена
	|ПОМЕСТИТЬ ТаблицаОстатковЗаКаждыйДеньВключаяКотировки
	|ИЗ
	|	ТаблицаОстатковРаспределеннаяПоДням КАК ТаблицаОстатковРаспределеннаяПоДням
	|		ЛЕВОЕ СОЕДИНЕНИЕ ТаблицаРыночныхЦенНаДатыОстатков КАК ТаблицаРыночныхЦенНаДатыОстатков
	|		ПО ТаблицаОстатковРаспределеннаяПоДням.Период = ТаблицаРыночныхЦенНаДатыОстатков.Период
	|			И ТаблицаОстатковРаспределеннаяПоДням.ЦБ = ТаблицаРыночныхЦенНаДатыОстатков.ЦБ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ИтоговаяТаблица.Период КАК Период,
	|	ИтоговаяТаблица.ДоговорКонтрагента КАК ДоговорКонтрагента,
	|	ИтоговаяТаблица.СчетДепо КАК СчетДепо,
	|	ИтоговаяТаблица.Выгодоприобретатель КАК Выгодоприобретатель,
	|	ИтоговаяТаблица.ЦБ КАК ЦБ,
	|	ИтоговаяТаблица.Количество КАК Количество,
	|	ИтоговаяТаблица.РыночнаяЦена КАК РыночнаяЦена,
	|	ВЫБОР
	|		КОГДА ИтоговаяТаблица.РыночнаяЦена > 0
	|			ТОГДА ИтоговаяТаблица.РыночнаяЦена * ИтоговаяТаблица.Количество
	|		КОГДА ИтоговаяТаблица.Количество > 0
	|			ТОГДА 1
	|		ИНАЧЕ 0
	|	КОНЕЦ КАК Оценка
	|ПОМЕСТИТЬ ИтоговаяТаблицаРасчета
	|ИЗ
	|	ТаблицаОстатковЗаКаждыйДеньВключаяКотировки КАК ИтоговаяТаблица
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ИтоговаяТаблицаРасчета.ДоговорКонтрагента КАК ДоговорКонтрагента,
	|	ИтоговаяТаблицаРасчета.Выгодоприобретатель КАК Выгодоприобретатель,
	|	СУММА(ИтоговаяТаблицаРасчета.Оценка) КАК Оценка,
	|	ИтоговаяТаблицаРасчета.Период КАК Период
	|ПОМЕСТИТЬ ИтоговаяОценкаПоДоговорамПоДням
	|ИЗ
	|	ИтоговаяТаблицаРасчета КАК ИтоговаяТаблицаРасчета
	|ГДЕ
	|	(ИтоговаяТаблицаРасчета.РыночнаяЦена = 0
	|				И &ТипРасчета В (&ТипыРасчетаДляНулевойРыночнойЦены)
	|			ИЛИ ИтоговаяТаблицаРасчета.РыночнаяЦена > 0
	|				И &ТипРасчета В (&ТипыРасчетаДляНенулевойРыночнойЦены))
	|
	|СГРУППИРОВАТЬ ПО
	|	ИтоговаяТаблицаРасчета.ДоговорКонтрагента,
	|	ИтоговаяТаблицаРасчета.Выгодоприобретатель,
	|	ИтоговаяТаблицаРасчета.Период
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ИтоговаяОценкаПоДоговорам.ДоговорКонтрагента КАК ДоговорКонтрагента,
	|	ИтоговаяОценкаПоДоговорам.Выгодоприобретатель КАК Выгодоприобретатель,
	|	ИтоговаяОценкаПоДоговорам.Оценка КАК Оценка,
	|	ИтоговаяОценкаПоДоговорам.Период КАК Дата
	|ПОМЕСТИТЬ ИтоговаяОценкаПоДоговорам
	|ИЗ
	|	ИтоговаяОценкаПоДоговорамПоДням КАК ИтоговаяОценкаПоДоговорам
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ИтоговаяОценкаПоДоговорам.ДоговорКонтрагента КАК ДоговорКонтрагента,
	|	ИтоговаяОценкаПоДоговорам.Выгодоприобретатель КАК Выгодоприобретатель,
	|	ИтоговаяОценкаПоДоговорам.Оценка КАК Оценка,
	|	МИНИМУМ(ТарифыСрезПоследних.Шкала) КАК Шкала,
	|	ИтоговаяОценкаПоДоговорам.Дата КАК Дата
	|ПОМЕСТИТЬ ОценкаПоДоговорамИШкала
	|ИЗ
	|	ИтоговаяОценкаПоДоговорам КАК ИтоговаяОценкаПоДоговорам
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.Тарифы.СрезПоследних(&Период, Услуга = &Услуга) КАК ТарифыСрезПоследних
	|		ПО ИтоговаяОценкаПоДоговорам.Оценка <= ТарифыСрезПоследних.Шкала
	|
	|СГРУППИРОВАТЬ ПО
	|	ИтоговаяОценкаПоДоговорам.ДоговорКонтрагента,
	|	ИтоговаяОценкаПоДоговорам.Выгодоприобретатель,
	|	ИтоговаяОценкаПоДоговорам.Оценка,
	|	ИтоговаяОценкаПоДоговорам.Дата
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ОценкаПоДоговорамИШкала.ДоговорКонтрагента КАК Договор,
	|	ОценкаПоДоговорамИШкала.Выгодоприобретатель КАК Выгодоприобретатель,
	|	&Услуга КАК Комиссия,
	|	ТарифыСрезПоследних.ТипТарифа КАК ТипТарифа,
	|	СУММА(ОценкаПоДоговорамИШкала.Оценка) КАК Сумма,
	|	СУММА(ВЫБОР
	|			КОГДА ТарифыСрезПоследних.ТипТарифа = &ТарифФиксированнаяСумма
	|				ТОГДА ОценкаПоДоговорамИШкала.Оценка / (РАЗНОСТЬДАТ(НАЧАЛОПЕРИОДА(ОценкаПоДоговорамИШкала.Дата, МЕСЯЦ), КОНЕЦПЕРИОДА(ОценкаПоДоговорамИШкала.Дата, МЕСЯЦ), ДЕНЬ) + 1) * ТарифыСрезПоследних.Тариф
	|			КОГДА ТарифыСрезПоследних.ТипТарифа = &ТарифПроцентОтНачисления
	|				ТОГДА ОценкаПоДоговорамИШкала.Оценка / (РАЗНОСТЬДАТ(НАЧАЛОПЕРИОДА(ОценкаПоДоговорамИШкала.Дата, МЕСЯЦ), КОНЕЦПЕРИОДА(ОценкаПоДоговорамИШкала.Дата, МЕСЯЦ), ДЕНЬ) + 1) * ТарифыСрезПоследних.Тариф / 100
	|		КОНЕЦ) КАК СуммаКомиссии,
	|	ТарифыСрезПоследних.Тариф КАК Тариф,
	|	&Валюта КАК Валюта
	|ИЗ
	|	ОценкаПоДоговорамИШкала КАК ОценкаПоДоговорамИШкала
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.Тарифы.СрезПоследних(&Период, Услуга = &Услуга) КАК ТарифыСрезПоследних
	|		ПО ОценкаПоДоговорамИШкала.Шкала = ТарифыСрезПоследних.Шкала
	|			И (ТарифыСрезПоследних.Тариф > 0)
	|
	|СГРУППИРОВАТЬ ПО
	|	ОценкаПоДоговорамИШкала.ДоговорКонтрагента,
	|	ОценкаПоДоговорамИШкала.Выгодоприобретатель,
	|	ТарифыСрезПоследних.ТипТарифа,
	|	ТарифыСрезПоследних.Тариф");
	
	Запрос.УстановитьПараметр("НачалоПериода",	ДатаНачалаПериодаРасчета(Дата, ПериодРасчета));
	Запрос.УстановитьПараметр("Период",			Дата);
	Запрос.УстановитьПараметр("ПериодРасчета",	ПериодРасчета);
	Запрос.УстановитьПараметр("ДепозитарнаяКомиссия",	Перечисления.ВидыКомиссий.Депозитарная);
	Запрос.УстановитьПараметр("ТипЦБОблигация",			Перечисления.ТипыЦБ.Облигация);
	Запрос.УстановитьПараметр("РежимТорговРыночный",	Перечисления.РежимыТоргов.Рыночная);
	
	ТипыРасчетаДляНулевойРыночнойЦены = Новый Массив;
	ТипыРасчетаДляНулевойРыночнойЦены.Добавить(Перечисления.ТипыРасчетаУслуги.ОстатокПоВыпуску);
	Запрос.УстановитьПараметр("ТипыРасчетаДляНулевойРыночнойЦены", ТипыРасчетаДляНулевойРыночнойЦены);
	
	ТипыРасчетаДляНенулевойРыночнойЦены = Новый Массив;
	ТипыРасчетаДляНенулевойРыночнойЦены.Добавить(Перечисления.ТипыРасчетаУслуги.ОстатокПоРыночнойСтоимости);
	ТипыРасчетаДляНенулевойРыночнойЦены.Добавить(Перечисления.ТипыРасчетаУслуги.ОценкаРыночнойСтоимостиЗаМесяц);
	Запрос.УстановитьПараметр("ТипыРасчетаДляНенулевойРыночнойЦены", ТипыРасчетаДляНенулевойРыночнойЦены);
	
	Запрос.УстановитьПараметр("ТарифФиксированнаяСумма",	Перечисления.ТипыТарифов.ФиксированнаяСумма);
	Запрос.УстановитьПараметр("ТарифПроцентОтНачисления",	Перечисления.ТипыТарифов.ПроцентОтНачисления);
	
	Запрос.УстановитьПараметр("Валюта",			Услуга.Валюта);
	Запрос.УстановитьПараметр("Договор",		Договор);
	Запрос.УстановитьПараметр("ТипРасчета",		Услуга.ТипРасчета);
	Запрос.УстановитьПараметр("Услуга",			Услуга);
	
	Если ЗначениеЗаполнено(Услуга) И ЗначениеЗаполнено(Услуга.МестоХранения1) Тогда
		Запрос.УстановитьПараметр("НРД", Услуга.МестоХранения1);
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеОтбораПоМестуХранения", "СчетДепоМХ.Владелец В (&МестаХранения)");
		Запрос.УстановитьПараметр("МестаХранения", Справочники.УслугиТарифногоПлана.МестаХраненияДляПолученияОстатков(Услуга));
	Иначе
		Запрос.УстановитьПараметр("НРД", Константы.МестоХраненияПоУмолчанию.Получить());
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеОтбораПоМестуХранения", "1 = 1");
	КонецЕсли;
	
	УстановитьОтборПоВидамЦБЕслиНужно(Запрос, Услуга.ТипРасчета, Услуга.ОтборПоВидуЦБ, Услуга.ИсключатьПриОтбореПеречисленныеВидыЦБ);

	РезультатЗапроса = Запрос.Выполнить();
	Возврат РезультатЗапроса;
КонецФункции

Функция РасшифровкаОценкиАктивовПоСтроке(Дата, Знач Договор = Неопределено, Услуга, Субклиент, ПериодРасчета = Неопределено) Экспорт
	
	// Внимание. Если нужно изменить запрос, то нужно так же учесть, что есть запрос, по которому делается данная Расшифровка.
	// Он находится в этом же модуле в функции "ОценкаАктивов".
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	Календарь.Период КАК Период
	|ПОМЕСТИТЬ Календарь
	|ИЗ
	|	РегистрСведений.Календарь КАК Календарь
	|ГДЕ
	|	Календарь.Период МЕЖДУ &НачалоПериода И &Период
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	МАКСИМУМ(РегистрНазначенныхКомиссий.Период) КАК ПериодНазначенияКомиссии,
	|	РегистрНазначенныхКомиссий.ДоговорКонтрагента КАК ДоговорКонтрагента,
	|	РегистрНазначенныхКомиссий.Услуга КАК Услуга,
	|	Календарь.Период КАК ПредварительнаяДатаРасчетаКомиссии
	|ПОМЕСТИТЬ РегистрНазначенныхКомиссийПоКалендарю
	|ИЗ
	|	РегистрСведений.РегистрНазначенныхКомиссий КАК РегистрНазначенныхКомиссий
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Календарь КАК Календарь
