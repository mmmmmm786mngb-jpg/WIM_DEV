Функция РасчетКомиссииПоШкалеУслуги(Дата, Услуга, СуммаРасчета, ПериодРасчета = Неопределено)
	Если НЕ ЗначениеЗаполнено(ПериодРасчета) Тогда
		ПериодРасчета = Перечисления.ВариантыНачисленияКомиссий.Месяц;
	КонецЕсли;
	
	Результат = Новый Структура("Тариф, ТипТарифа, Сумма, СуммаКомиссии");
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ТарифыСрезПоследних.Услуга КАК Услуга,
	|	МИНИМУМ(ТарифыСрезПоследних.Шкала) КАК Шкала
	|ПОМЕСТИТЬ ПараметрыШкалыУслуги
	|ИЗ
	|	РегистрСведений.Тарифы.СрезПоследних(
	|			&Дата,
	|			Услуга = &Услуга
	|				И Шкала >= &Сумма) КАК ТарифыСрезПоследних
	|
	|СГРУППИРОВАТЬ ПО
	|	ТарифыСрезПоследних.Услуга
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТарифыСрезПоследних.Тариф КАК Тариф,
	|	ТарифыСрезПоследних.ТипТарифа КАК ТипТарифа,
	|	РАЗНОСТЬДАТ(&НачалоПериода, &КонецПериода, ДЕНЬ) + 1 КАК КоличествоДнейВПериоде
	|ИЗ
	|	РегистрСведений.Тарифы.СрезПоследних(
	|			&Дата,
	|			Услуга = &Услуга
	|				И Шкала >= &Сумма) КАК ТарифыСрезПоследних
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ПараметрыШкалыУслуги КАК ПараметрыШкалыУслуги
	|		ПО ТарифыСрезПоследних.Услуга = ПараметрыШкалыУслуги.Услуга
	|			И ТарифыСрезПоследних.Шкала = ПараметрыШкалыУслуги.Шкала";
	Запрос.УстановитьПараметр("Дата",			Дата);
	Запрос.УстановитьПараметр("НачалоПериода",	ДатаНачалаПериодаРасчета(Дата, ПериодРасчета));
	Запрос.УстановитьПараметр("КонецПериода",	ДатаОкончанияПериодаРасчета(Дата, ПериодРасчета));
	Запрос.УстановитьПараметр("Услуга",			Услуга);
	Запрос.УстановитьПараметр("Сумма",			СуммаРасчета);
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Результат.Тариф		= Выборка.Тариф;
		Результат.ТипТарифа	= Выборка.ТипТарифа;
		Результат.Сумма		= СуммаРасчета;
		Результат.СуммаКомиссии = ?(Выборка.ТипТарифа = Перечисления.ТипыТарифов.ФиксированнаяСумма, Выборка.Тариф,
			СуммаРасчета * Выборка.Тариф / 100 / Выборка.КоличествоДнейВПериоде);
		Если Услуга.ОграничениеСуммыНачисления > 0 Тогда
			Результат.СуммаКомиссии = Мин(Результат.СуммаКомиссии, Услуга.ОграничениеСуммыНачисления);
		КонецЕсли;
	КонецЕсли;
	Возврат Результат;
КонецФункции

