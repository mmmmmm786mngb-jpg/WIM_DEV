#Область ПрограммныйИнтерфейс

// Возвращает список измененных ЦБ со всеми нобходимыми для экспорта во внешние системы реквизитами, в том числе
// хранящихся не в основном объекте, а в связанных регистрах.
// Параметры:
//	ДатаОтбора - Дата - Максимальные дата и время изменения (включительно) для отбираемых ЦБ. ЦБ измененные позже в возвращаемый
//						результат включены не будут.
// Возвращаемое значение:
//	 Структура - состоит из двух элементов типа ТаблицаЗначений: ЦенныеБумаги и Эмитенты
Функция ИзмененныеОбъекты(ДатаОтбора) Экспорт
	ИзмененныеОбъекты = ДанныеИзмененныхОбъектов(ДатаОтбора);
	
	КолонкиСоВложеннымиТаблицами = "Номиналы,Купоны";
	КолонкиНеДляХэша = "ЦБ,ЭмитентЮрЛицо,ВремяИзменения,СтарыйХешРеквизитов,НовыйХешРеквизитов,ЭтоДепозитарнаяРасписка";
	РассчитатьХэшиИзмененныхОбъектов(ИзмененныеОбъекты.ЦенныеБумаги, КолонкиНеДляХэша, КолонкиСоВложеннымиТаблицами);
	
	КолонкиСоВложеннымиТаблицами = "КонтактнаяИнформация,МеждународныеКомпании";
	КолонкиНеДляХэша = "Эмитент,ЦеннаяБумага,ВремяИзменения,СтарыйХешРеквизитов,НовыйХешРеквизитов,ОбработанВместеСЦеннойБумагой,Обработано";
	РассчитатьХэшиИзмененныхОбъектов(ИзмененныеОбъекты.Эмитенты, КолонкиНеДляХэша, КолонкиСоВложеннымиТаблицами);
	
	Возврат ИзмененныеОбъекты;
КонецФункции

// Выгружает в Kafka все ценные бумаги, у которых есть реальные изменения и вместе с ними их эмитентов
// Параметры:
//	ЦенныеБумаги - ТаблицаЗачений
//	Эмитенты - ТаблицаЗачений
//	ТолькоОбновлениеХэшей - Булево - необязательный параметр, при его наличии со значением Истина, не происходит реальной
//									выгрузки изменений в Kafka, но происходит перерасчет и обновление хэшей измененных
//									объектов в РС СтатусыОбъектовКОтправке, причем они получают статус обработанных.
Процедура ВыгрузитьЦенныеБумаги(ЦенныеБумаги, Эмитенты, ТолькоОбновлениеХэшей = Ложь) Экспорт
	Для каждого РеквизитыЦБ Из ЦенныеБумаги Цикл
		ОшибкаОбработки = Ложь;
		ОписаниеОшибки = "";
		Если Не ЗначениеЗаполнено(РеквизитыЦБ.ЭмитентЮрЛицо) Тогда
			ОшибкаОбработки = Истина;
			ОписаниеОшибки = "Для ценной бумаги не найден эмитент. ЦБ: " 
								+ РеквизитыЦБ.Name + " (ISIN: " + РеквизитыЦБ.ISIN + ")";
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ОписаниеОшибки);
		Иначе
			Если РеквизитыЦБ.ЕстьИзмененияХэша И Не ТолькоОбновлениеХэшей Тогда
				ВыгрузитьОднуЦБ(РеквизитыЦБ, Эмитенты, ОшибкаОбработки, ОписаниеОшибки);
			КонецЕсли;
		КонецЕсли;
		РегистрацияИзмененийДляВыгрузки.ЗавершитьОбработку(РеквизитыЦБ.ЦБ, РеквизитыЦБ.ВремяИзменения, 
															РеквизитыЦБ.НовыйХешРеквизитов, ОшибкаОбработки, ОписаниеОшибки);
	КонецЦикла;
КонецПроцедуры

// Выгружает в Kafka всех эмитентов, в у которых есть реальные изменения и которые еще не были выгружены ранее
// Параметры:
//	Эмитенты - ТаблицаЗачений
//	ТолькоОбновлениеХэшей - Булево - необязательный параметр, при его наличии со значением Истина, не происходит реальной
//									выгрузки изменений в Kafka, но происходит перерасчет и обновление хэшей измененных
//									объектов в РС СтатусыОбъектовКОтправке, причем они получают статус обработанных.
Процедура ВыгрузитьЭмитентов(Эмитенты, ТолькоОбновлениеХэшей) Экспорт
	Для каждого РеквизитыЭмитента Из Эмитенты Цикл
		Если Не РеквизитыЭмитента.ОбработанВместеСЦеннойБумагой Тогда
			ОшибкаОбработки = Ложь;
			ОписаниеОшибки = "";
			Если Не ЗначениеЗаполнено(РеквизитыЭмитента.ЦеннаяБумага) Тогда
				ОшибкаОбработки = Истина;
				ОписаниеОшибки = "Для эмитента не найдена ценная бумага. Эмитент: " 
									+ РеквизитыЭмитента.Name + " (Код RuData: " + РеквизитыЭмитента.RuDataCode + ")";
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ОписаниеОшибки);
			Иначе
				Если РеквизитыЭмитента.ЕстьИзмененияХэша И Не ТолькоОбновлениеХэшей Тогда
					ВыгрузитьЦеннуюБумагуИЭмитента(Неопределено, РеквизитыЭмитента, ОшибкаОбработки, ОписаниеОшибки);
				КонецЕсли;
			КонецЕсли;
			РегистрацияИзмененийДляВыгрузки.ЗавершитьОбработку(РеквизитыЭмитента.Эмитент, РеквизитыЭмитента.ВремяИзменения,
																РеквизитыЭмитента.НовыйХешРеквизитов, ОшибкаОбработки, ОписаниеОшибки);
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

#КонецОбласти


#Область СлужебныеПроцедурыИФункции

Процедура ВыгрузитьОднуЦБ(РеквизитыЦБ, Эмитенты,  ОшибкаОбработки, ОписаниеОшибки)
	// С новыми ЦБ выгружаем эмитента всегда, даже если он был выгружен ранее и в нем нет изменений
	ВместеСЦеннойБумагой = Истина;
	РеквизитыЭмитента = РеквизитыЭмитента(РеквизитыЦБ.ЭмитентЮрЛицо, Эмитенты, ВместеСЦеннойБумагой);
	ВыгрузитьЦеннуюБумагуИЭмитента(РеквизитыЦБ, РеквизитыЭмитента, ОшибкаОбработки, ОписаниеОшибки);
	Если ЗначениеЗаполнено(РеквизитыЭмитента) И Не ОшибкаОбработки Тогда
		РеквизитыЭмитента.ОбработанВместеСЦеннойБумагой = Истина;
		РегистрацияИзмененийДляВыгрузки.ЗавершитьОбработку(РеквизитыЦБ.ЭмитентЮрЛицо, РеквизитыЭмитента.ВремяИзменения,
															РеквизитыЭмитента.НовыйХешРеквизитов, ОшибкаОбработки, ОписаниеОшибки);
	КонецЕсли;
КонецПроцедуры

// BSLLS:MethodSize-off
// BSLLS:AssignAliasFieldsInQuery-off		// (пришлось поставить из-за ложных срабатываний при использовании функци СОКРЛП в теле запроса

// Функция возвращает данные измененных (перезаписанных) ценных бумаг и эмитентов - юридических лиц.
// Параметры:
//	ДатаОтбора - Дата - Максимальные дата и время изменения (включительно) для отбираемых ЦБ. ЦБ измененные позже в возвращаемый
//						результат включены не будут.
// Возвращаемое значение:
//	 Структура - состоит из двух элементов типа ТаблицаЗначений: ЦенныеБумаги и Эмитенты
Функция ДанныеИзмененныхОбъектов(ДатаОтбора)
	Запрос = Новый Запрос;
	
	Запрос.Текст = 
	// Осторожно, в конце пакета в основном запросе по ЦБ и в запросах по связанной с ЦБ информации из вспомогательных
	// таблиц должна быть одинаковая сортировка по ЦБ. На это опирается алгоритм обработки результатов.
	// В основном запросе по ЮЛ и в запросах по связанной с ЮЛ информации из вспомогательных РС также должна быть
	// одинаковая сортировка по ЮЛ (на это опирается алгоритм обработки результатов запросов пакета).
	"/////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
	|//												ИЗМЕНЕННЫЕ ОБЪЕКТЫ														//
	|/////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СтатусыОбъектовКОтправке.Объект КАК ЦБ,
	|	СтатусыОбъектовКОтправке.ВремяИзменения КАК ВремяИзменения,
	|	СтатусыОбъектовКОтправке.ХешРеквизитов КАК ХешРеквизитов,
	|	ЦенныеБумаги.Эмитент КАК ЭмитентКонтрагент,
	|	ЦенныеБумаги.БазовыйАктив КАК БазовыйАктив,
	|	ВЫБОР
	|		КОГДА ЦенныеБумаги.ТипЦБ = ЗНАЧЕНИЕ(Перечисление.ТипыЦБ.ДепозитарнаяРасписка)
	|			ТОГДА ИСТИНА
	|		КОГДА ЦенныеБумаги.ТипЦБ = ЗНАЧЕНИЕ(Перечисление.ТипыЦБ.АДР)
	|			ТОГДА ИСТИНА
	|		КОГДА ЦенныеБумаги.ТипЦБ = ЗНАЧЕНИЕ(Перечисление.ТипыЦБ.ГДР)
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК ЭтоДепозитарнаяРасписка
	|ПОМЕСТИТЬ ВТ_ИзмененныеЦБ
	|ИЗ
	|	РегистрСведений.СтатусыОбъектовКОтправке КАК СтатусыОбъектовКОтправке
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ЦенныеБумаги КАК ЦенныеБумаги
	|		ПО СтатусыОбъектовКОтправке.Объект = ЦенныеБумаги.Ссылка
	|ГДЕ
	|	СтатусыОбъектовКОтправке.Объект ССЫЛКА Справочник.ЦенныеБумаги
	|	И НЕ СтатусыОбъектовКОтправке.Обработано
	|	И СтатусыОбъектовКОтправке.ВремяИзменения <= &ДатаВремяОтбора
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СтатусыОбъектовКОтправке.Объект КАК ЮЛ,
	|	СтатусыОбъектовКОтправке.ВремяИзменения КАК ВремяИзменения,
	|	СтатусыОбъектовКОтправке.ХешРеквизитов КАК ХешРеквизитов,
	|	СтатусыОбъектовКОтправке.Обработано КАК Обработано
	|ПОМЕСТИТЬ ВТ_ВсеНужныеЮЛ
	|ИЗ
	|	РегистрСведений.СтатусыОбъектовКОтправке КАК СтатусыОбъектовКОтправке
	|ГДЕ
	|	СтатусыОбъектовКОтправке.Объект ССЫЛКА Справочник.ЮридическиеЛица
	|	И НЕ СтатусыОбъектовКОтправке.Обработано
	|	И СтатусыОбъектовКОтправке.ВремяИзменения <= &ДатаВремяОтбора
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ЮридическиеЛица.Ссылка КАК ЮЛ,
	|	СтатусыОбъектовКОтправке.ВремяИзменения КАК ВремяИзменения,
	|	СтатусыОбъектовКОтправке.ХешРеквизитов КАК ХешРеквизитов,
	|	СтатусыОбъектовКОтправке.Обработано КАК Обработано
	|ИЗ ВТ_ИзмененныеЦБ
	|ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Контрагенты КАК Контрагенты
	|	ПО ВТ_ИзмененныеЦБ.ЭмитентКонтрагент = Контрагенты.Ссылка
	|ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ЮридическиеЛица КАК ЮридическиеЛица
	|	ПО Контрагенты.ЮридическиеФизическиеЛица = ЮридическиеЛица.Ссылка
	|ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.СтатусыОбъектовКОтправке КАК СтатусыОбъектовКОтправке
	|	ПО ЮридическиеЛица.Ссылка = СтатусыОбъектовКОтправке.Объект
	|ГДЕ
	|	НЕ ЮридическиеЛица.Ссылка ЕСТЬ NULL
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_ВсеНужныеЮЛ.ЮЛ КАК ЮЛ,
	|	МАКСИМУМ(ВТ_ВсеНужныеЮЛ.ВремяИзменения) КАК ВремяИзменения,
	|	МАКСИМУМ(ВТ_ВсеНужныеЮЛ.ХешРеквизитов) КАК ХешРеквизитов,
	|	МАКСИМУМ(ВТ_ВсеНужныеЮЛ.Обработано) КАК Обработано
	|ПОМЕСТИТЬ ВТ_ИзмененныеЮЛ
	|ИЗ ВТ_ВсеНужныеЮЛ
	|СГРУППИРОВАТЬ ПО
	|	ВТ_ВсеНужныеЮЛ.ЮЛ
	|;
	|
	|/////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
	|//												ПРОМЕЖУТОЧНЫЕ ДАННЫЕ													//
	|/////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_ИзмененныеЮЛ.ЮЛ КАК ЮЛ,
	|	МАКСИМУМ(ЦенныеБумаги.Ссылка) КАК ЛюбаяВыгруженнаяЦБЭтогоЭмитента
	|ПОМЕСТИТЬ ВТ_ЦБЭмитентов
	|ИЗ
	|	ВТ_ИзмененныеЮЛ КАК ВТ_ИзмененныеЮЛ
	|	ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Контрагенты КАК Контрагенты
	|		ПО Контрагенты.ЮридическиеФизическиеЛица = ВТ_ИзмененныеЮЛ.ЮЛ
	|	ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ЦенныеБумаги КАК ЦенныеБумаги
	|		ПО ЦенныеБумаги.Эмитент = Контрагенты.Ссылка
	|	ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.СтатусыОбъектовКОтправке КАК СтатусыОбъектовКОтправке
	|		ПО СтатусыОбъектовКОтправке.Объект = ЦенныеБумаги.Ссылка
	|	СГРУППИРОВАТЬ ПО
	|		ВТ_ИзмененныеЮЛ.ЮЛ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВсеЦБ.ЦБ КАК ЦБ
	|ПОМЕСТИТЬ ВТ_ВсеЦБ
	|ИЗ
	|	(ВЫБРАТЬ
	|		ВТ_ИзмененныеЦБ.ЦБ КАК ЦБ
	|	ИЗ
	|		ВТ_ИзмененныеЦБ КАК ВТ_ИзмененныеЦБ
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		ВТ_ЦБЭмитентов.ЛюбаяВыгруженнаяЦБЭтогоЭмитента
	|	ИЗ
	|		ВТ_ЦБЭмитентов КАК ВТ_ЦБЭмитентов) КАК ВсеЦБ
	|
	|СГРУППИРОВАТЬ ПО
	|	ВсеЦБ.ЦБ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_ВсеЦБ.ЦБ КАК ЦБ,
	|	СОКРЛП(МАКСИМУМ(КодыЗагрузки.Код)) КАК КодRuData
	|ПОМЕСТИТЬ ВТ_КодыЦБRuData
	|ИЗ
	|	ВТ_ВсеЦБ КАК ВТ_ВсеЦБ
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.КодыЗагрузки КАК КодыЗагрузки
	|		ПО ВТ_ВсеЦБ.ЦБ = КодыЗагрузки.Владелец
	|			И (КодыЗагрузки.Биржа = ЗНАЧЕНИЕ(Справочник.КлассификаторыЗагрузки.RuData))
	|			И (ВЫБОР
	|				КОГДА КодыЗагрузки.ДатаНачалаДействия <= &ДатаОтбора
	|					ТОГДА ИСТИНА
	|				КОГДА КодыЗагрузки.ДатаНачалаДействия = ДАТАВРЕМЯ(1, 1, 1)
	|					ТОГДА ИСТИНА
	|				ИНАЧЕ ЛОЖЬ
	|			КОНЕЦ)
	|			И (ВЫБОР
	|				КОГДА КодыЗагрузки.ДатаОкончанияДействия > &ДатаОтбора
	|					ТОГДА ИСТИНА
	|				КОГДА КодыЗагрузки.ДатаОкончанияДействия = ДАТАВРЕМЯ(1, 1, 1)
	|					ТОГДА ИСТИНА
	|				ИНАЧЕ ЛОЖЬ
	|			КОНЕЦ)
	|
	|СГРУППИРОВАТЬ ПО
	|	ВТ_ВсеЦБ.ЦБ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_ИзмененныеЦБ.ЦБ КАК ЦБ,
	|	СОКРЛП(МАКСИМУМ(КодыЗагрузки.Код)) КАК КодRuData
	|ПОМЕСТИТЬ ВТ_БазовыхАктивовКодыRuData
	|ИЗ
	|	ВТ_ИзмененныеЦБ КАК ВТ_ИзмененныеЦБ
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.КодыЗагрузки КАК КодыЗагрузки
	|		ПО ВТ_ИзмененныеЦБ.БазовыйАктив = КодыЗагрузки.Владелец
	|			И (КодыЗагрузки.Биржа = ЗНАЧЕНИЕ(Справочник.КлассификаторыЗагрузки.RuData))
	|			И (ВЫБОР
	|				КОГДА КодыЗагрузки.ДатаНачалаДействия <= &ДатаОтбора
	|					ТОГДА ИСТИНА
	|				КОГДА КодыЗагрузки.ДатаНачалаДействия = ДАТАВРЕМЯ(1, 1, 1)
	|					ТОГДА ИСТИНА
	|				ИНАЧЕ ЛОЖЬ
	|			КОНЕЦ)
	|			И (ВЫБОР
	|				КОГДА КодыЗагрузки.ДатаОкончанияДействия > &ДатаОтбора
	|					ТОГДА ИСТИНА
	|				КОГДА КодыЗагрузки.ДатаОкончанияДействия = ДАТАВРЕМЯ(1, 1, 1)
	|					ТОГДА ИСТИНА
	|				ИНАЧЕ ЛОЖЬ
	|			КОНЕЦ)
	|
	|СГРУППИРОВАТЬ ПО
	|	ВТ_ИзмененныеЦБ.ЦБ
	|;
	| 
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_ВсеЦБ.ЦБ КАК ЦБ,
