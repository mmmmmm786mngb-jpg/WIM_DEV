	|// Осторожно, в основном запросе по ЮЛ и в запросах по связанной с ЮЛ информации из вспомогательных РС (см. ниже)
	|// должна быть одинаковая сортировка по ЮЛ (на это опирается алгоритм обработки результатов)
	|УПОРЯДОЧИТЬ ПО
	|	ВТ_ИзмененныеЮЛ.ЮЛ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	// 7. Блок 'EmitentContactData' ------------------------
	|	КонтактнаяИнформацияСрезПоследних.Объект КАК Эмитент,
	|	ВЫБОР
	|		КОГДА КонтактнаяИнформацияСрезПоследних.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыКонтактнойИнформации.Адрес)
	|			ТОГДА ""ADDRESS""
	|		КОГДА КонтактнаяИнформацияСрезПоследних.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыКонтактнойИнформации.Телефон)
	|			ТОГДА ""PHONE""
	|		КОГДА КонтактнаяИнформацияСрезПоследних.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыКонтактнойИнформации.АдресЭлектроннойПочты)
	|			ТОГДА ""EMAIL""
	|		КОГДА КонтактнаяИнформацияСрезПоследних.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыКонтактнойИнформации.ВебСтраница)
	|			ТОГДА ""WEB""
	|		КОГДА КонтактнаяИнформацияСрезПоследних.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыКонтактнойИнформации.Другое)
	|			ТОГДА ""OTHER""
	|		ИНАЧЕ """"
	|	КОНЕЦ КАК ContactInfoTypeCode,
	|	ВЫБОР
	|		КОГДА КонтактнаяИнформацияСрезПоследних.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.EmailЮрЛица)
	|			ТОГДА ""EMAIL""
	|		КОГДА КонтактнаяИнформацияСрезПоследних.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыКонтактнойИнформации.ВебСтраница)
	|			ТОГДА ""WEB""
	|		КОГДА КонтактнаяИнформацияСрезПоследних.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.АдресЮрлицаПочтовый)
	|			ТОГДА ""POST""
	|		КОГДА КонтактнаяИнформацияСрезПоследних.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ФактАдресЮрЛица)
	|			ТОГДА ""FACT""
	|		КОГДА КонтактнаяИнформацияСрезПоследних.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ЮрАдресЮрЛица)
	|			ТОГДА ""LEG""
	|		КОГДА КонтактнаяИнформацияСрезПоследних.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ТелефонЮрЛица)
	|			ТОГДА ""MOBILE""
	|		КОГДА КонтактнаяИнформацияСрезПоследних.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ФаксЮрЛица)
	|			ТОГДА ""OTHER""
	|		ИНАЧЕ """"
	|	КОНЕЦ КАК ContactInfoKindCode,
	|	КонтактнаяИнформацияСрезПоследних.Представление КАК Value,
	|	КонтактнаяИнформацияСрезПоследних.Период КАК DateStart
	|ИЗ
	|	РегистрСведений.КонтактнаяИнформация.СрезПоследних(
	|			&ДатаОтбора,
	|			Объект В
	|				(ВЫБРАТЬ
	|					ВТ_ИзмененныеЮЛ.ЮЛ КАК ЮЛ
	|				ИЗ
	|					ВТ_ИзмененныеЮЛ КАК ВТ_ИзмененныеЮЛ)) КАК КонтактнаяИнформацияСрезПоследних
	|
	|
	|// Осторожно, в основном запросе по ЮЛ и в запросах по связанной с ЮЛ информации из вспомогательных РС 
	|// должна быть одинаковая сортировка по ЮЛ (на это опирается алгоритм обработки результатов)
	|УПОРЯДОЧИТЬ ПО
	|	КонтактнаяИнформацияСрезПоследних.Объект,
	|	КонтактнаяИнформацияСрезПоследних.Тип,
	|	КонтактнаяИнформацияСрезПоследних.Вид,
	|	КонтактнаяИнформацияСрезПоследних.Период
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	// 7. Блок 'EmitentPeriodICData' -----------------------
	|	ЮридическиеЛицаМеждународныеКомпании.ЮридическоеЛицо КАК Эмитент,
	|	ЮридическиеЛицаМеждународныеКомпании.МеждународнаяКомпания КАК IsInternationalCompany,
	|	ЮридическиеЛицаМеждународныеКомпании.Период КАК DateStart
	|ИЗ
	|	ВТ_ИзмененныеЮЛ КАК ВТ_ИзмененныеЮЛ
	|	ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ЮридическиеЛицаМеждународныеКомпании КАК ЮридическиеЛицаМеждународныеКомпании
	|	ПО ВТ_ИзмененныеЮЛ.ЮЛ = ЮридическиеЛицаМеждународныеКомпании.ЮридическоеЛицо
	|
	|// Осторожно, в основном запросе по ЮЛ и в запросах по связанной с ЮЛ информации из вспомогательных РС 
	|// должна быть одинаковая сортировка по ЮЛ (на это опирается алгоритм обработки результатов)
	|УПОРЯДОЧИТЬ ПО
	|	ЮридическиеЛицаМеждународныеКомпании.ЮридическоеЛицо,
	|	ЮридическиеЛицаМеждународныеКомпании.Период
	|";
	Запрос.УстановитьПараметр("ДатаВремяОтбора", ДатаОтбора);
	Запрос.УстановитьПараметр("ДатаОтбора", НачалоДня(ДатаОтбора));
	Запрос.УстановитьПараметр("ВсеТипыДепозитарныхРасписок", Перечисления.ТипыЦБ.ВсеТипыДепозитарныхРасписок());
	
	РезультатыЗапросов = Запрос.ВыполнитьПакет();
	ИзмененныеОбъекты = ИзмененныеОбъектыИзДанныхЗапросов(РезультатыЗапросов);
	
	Возврат ИзмененныеОбъекты;
КонецФункции
// BSLLS:AssignAliasFieldsInQuery-on
// BSLLS:MethodSize-on

Функция ИзмененныеОбъектыИзДанныхЗапросов(РезультатыЗапросов)
	ИндексЗапросаПоМеждународнымКомпаниям = РезультатыЗапросов.Количество() - 1;
	ИндексЗапросаПоКонтактнойИнформации = ИндексЗапросаПоМеждународнымКомпаниям - 1;
	ИндексОсновногоЗапросаПоЭмитентам = ИндексЗапросаПоКонтактнойИнформации - 1;
	ИндексЗапросаПоКупонам = ИндексОсновногоЗапросаПоЭмитентам - 1;
	ИндексЗапросаПоНоминаламЦБ = ИндексЗапросаПоКупонам - 1;
	ИндексОсновногоЗапросаПоЦБ = ИндексЗапросаПоНоминаламЦБ - 1;
	
	РезультатЗапросаЦБ = РезультатыЗапросов[ИндексОсновногоЗапросаПоЦБ];
	РезультатЗапросаНоминалы = РезультатыЗапросов[ИндексЗапросаПоНоминаламЦБ];
	РезультатЗапросаКупоны = РезультатыЗапросов[ИндексЗапросаПоКупонам];
	ЦенныеБумаги = РезультатЗапросаЦБ.Выгрузить();
	Номиналы = РезультатЗапросаНоминалы.Выгрузить();
	Купоны = РезультатЗапросаКупоны.Выгрузить();
	СобратьВсеДанныеОЦенныхБумагахВОсновнуюТаблицу(ЦенныеБумаги, Номиналы, Купоны);
	
	РезультатЗапросаЭмитенты = РезультатыЗапросов[ИндексОсновногоЗапросаПоЭмитентам];
	РезультатЗапросаКонтактнаяИнформация = РезультатыЗапросов[ИндексЗапросаПоКонтактнойИнформации];
	РезультатЗапросаМеждународныеКомпании = РезультатыЗапросов[ИндексЗапросаПоМеждународнымКомпаниям];
	Эмитенты = РезультатЗапросаЭмитенты.Выгрузить();
	КИЭмитентов = РезультатЗапросаКонтактнаяИнформация.Выгрузить();
	МеждународныеКомпании = РезультатЗапросаМеждународныеКомпании.Выгрузить();
	СобратьВсеДанныеОбЭмитентахВОсновнуюТаблицу(Эмитенты, КИЭмитентов, МеждународныеКомпании);
	
	ИзмененныеОбъекты = Новый Структура("ЦенныеБумаги, Эмитенты", ЦенныеБумаги, Эмитенты);
	
	Возврат ИзмененныеОбъекты;
КонецФункции

Процедура СобратьВсеДанныеОЦенныхБумагахВОсновнуюТаблицу(ЦенныеБумаги, Номиналы, Купоны)
	ЦенныеБумаги.Колонки.Добавить("Номиналы");
	ЦенныеБумаги.Колонки.Добавить("Купоны");
	ТекИндексНоминалы = 0;
	ТекИндексКупоны = 0;
	МаксИндексНоминалы = Номиналы.Количество() - 1;
	МаксИндексКупоны = Купоны.Количество() - 1;
	
	Для каждого ДанныеТекущейЦБ Из ЦенныеБумаги Цикл
		ТекущаяЦБ = ДанныеТекущейЦБ.ЦБ;
		НоминалыТекущейЦБ = Номиналы.СкопироватьКолонки("Value,DateStart");
		КупоныТекущейЦБ = Купоны.СкопироватьКолонки("Number,IssueDate,CancelDate,Coupon,CirculationPeriod,Amount,Rate,ListFixDate,Comment");
		// Пользуемся тем фактом, что в основной таблице и во вспомогательной данные по ЦБ отсортированы одинаковым образом:
		// будем продвигаться по всем трем таблицам от начала к концу параллельно и перекладывать данные в основную таблицу
		// из двух вспомогательных
		ЗаполнитьТаблицуДаннымиТекОбъекта(ТекущаяЦБ, "ЦБ", НоминалыТекущейЦБ, Номиналы, ТекИндексНоминалы, МаксИндексНоминалы);
		ЗаполнитьТаблицуДаннымиТекОбъекта(ТекущаяЦБ, "ЦБ", КупоныТекущейЦБ, Купоны, ТекИндексКупоны, МаксИндексКупоны);
		ДанныеТекущейЦБ.Номиналы = НоминалыТекущейЦБ;
		ДанныеТекущейЦБ.Купоны = КупоныТекущейЦБ;
	КонецЦикла;
КонецПроцедуры

Процедура СобратьВсеДанныеОбЭмитентахВОсновнуюТаблицу(Эмитенты, КИЭмитентов, МеждународныеКомпании)
	Эмитенты.Колонки.Добавить("КонтактнаяИнформация");
	Эмитенты.Колонки.Добавить("МеждународныеКомпании");
	ТекИндексКИ = 0;
	ТекИндексМК = 0;
	МаксИндексКИ = КИЭмитентов.Количество() - 1;
	МаксИндексМК = МеждународныеКомпании.Количество() - 1;
	
	Для каждого ДанныеТекущегоЭмитента Из Эмитенты Цикл
		ТекущийЭмитент = ДанныеТекущегоЭмитента.Эмитент;
		КИТекущегоЭмитента = КИЭмитентов.СкопироватьКолонки("ContactInfoTypeCode,ContactInfoKindCode,Value,DateStart");
		МКТекущегоЭмитента = МеждународныеКомпании.СкопироватьКолонки("IsInternationalCompany,DateStart");
		
		// Пользуемся тем фактом, что в основной таблице и во вспомогательной данные по эмитентам отсортированы одинаковым образом:
		// будем продвигаться по всем трем таблицам от начала к концу параллельно и перекладывать данные в основную таблицу
		// из двух вспомогательных
		ЗаполнитьТаблицуДаннымиТекОбъекта(ТекущийЭмитент, "Эмитент", КИТекущегоЭмитента, КИЭмитентов, ТекИндексКИ, МаксИндексКИ);
		ЗаполнитьТаблицуДаннымиТекОбъекта(ТекущийЭмитент, "Эмитент", МКТекущегоЭмитента, МеждународныеКомпании, ТекИндексМК, МаксИндексМК);
		
		ДанныеТекущегоЭмитента.КонтактнаяИнформация = КИТекущегоЭмитента;
		ДанныеТекущегоЭмитента.МеждународныеКомпании = МКТекущегоЭмитента;
	КонецЦикла;
КонецПроцедуры

Процедура ЗаполнитьТаблицуДаннымиТекОбъекта(ТекОбъект, ИмяПоляСсылки, ДопДанныеПоТекОбъекту, ДопДанныеПоВсем, ТекИндекс, МаксИндекс)
	Если МаксИндекс >= 0 Тогда
		Пока ТекИндекс <= МаксИндекс И ДопДанныеПоВсем[ТекИндекс][ИмяПоляСсылки] = ТекОбъект Цикл
			НовСтрока = ДопДанныеПоТекОбъекту.Добавить();
			ЗаполнитьЗначенияСвойств(НовСтрока, ДопДанныеПоВсем[ТекИндекс]);
			ТекИндекс = ТекИндекс + 1;
		КонецЦикла;
	КонецЕсли;
КонецПроцедуры

Процедура РассчитатьХэшиИзмененныхОбъектов(ТаблицаИзмененных, СписокИсключаемыхКолонок, СписокКолонокСВложеннымиТаблицами)
	Если ТаблицаИзмененных.Количество() > 0 Тогда
		СтруктураРеквизитовОбъекта = СтруктураТаблицы(ТаблицаИзмененных, СписокИсключаемыхКолонок, СписокКолонокСВложеннымиТаблицами);
		Для каждого РеквизитыОбъекта Из ТаблицаИзмененных Цикл
			РеквизитыОбъекта.НовыйХешРеквизитов = РассчитатьХешРеквизитов(РеквизитыОбъекта, СтруктураРеквизитовОбъекта);
			РеквизитыОбъекта.ЕстьИзмененияХэша = (РеквизитыОбъекта.НовыйХешРеквизитов <> РеквизитыОбъекта.СтарыйХешРеквизитов);
		КонецЦикла;
	КонецЕсли;
КонецПроцедуры

Функция СтруктураТаблицы(ТаблицаЗначений, СписокИсключаемыхКолонок, СписокИменКолонокСТаблицами)
	СтруктураРеквизитов = Новый Структура;
	ОбычныеКолонки = Новый Массив;
	КолонкиСТаблицами = Новый Массив;
	
	ИменаКолонокСТаблицами = СтрРазделить(СписокИменКолонокСТаблицами, ",");
	ИсключаемыеКолонки = СтрРазделить(СписокИсключаемыхКолонок, ",");
	
	Для каждого Колонка Из ТаблицаЗначений.Колонки Цикл
		ИмяКолонки = Колонка.Имя;
		Если ИсключаемыеКолонки.Найти(ИмяКолонки) <> Неопределено Тогда
			Продолжить;
		ИначеЕсли ИменаКолонокСТаблицами.Найти(ИмяКолонки) = Неопределено Тогда
			ОбычныеКолонки.Добавить(ИмяКолонки);
		Иначе
			КолонкиВложеннойТаблицы = СтруктураТаблицы(ТаблицаЗначений[0][ИмяКолонки], СписокИсключаемыхКолонок, "");
			ОписаниеКолонкиСТаблицами = Новый Структура("ИмяКолонки, КолонкиВложеннойТаблицы", ИмяКолонки, КолонкиВложеннойТаблицы);
			КолонкиСТаблицами.Добавить(ОписаниеКолонкиСТаблицами);
		КонецЕсли;
	КонецЦикла;
		
	СтруктураРеквизитов.Вставить("Обычные", ОбычныеКолонки);
	СтруктураРеквизитов.Вставить("СТаблицами", КолонкиСТаблицами);
	
	Возврат СтруктураРеквизитов;
КонецФункции

Функция РассчитатьХешРеквизитов(СтрокаТЗ, ОписаниеКолонок)
	ХешДанных = Новый ХешированиеДанных(ХешФункция.SHA512); // возможная альтернатива ХешФункция.CRC32, но она возвращала бы число
	
	ДобавитьВХэш(ХешДанных, СтрокаТЗ, ОписаниеКолонок);
	
	ДвоичныйХеш = ХешДанных.ХешСумма;
	СтроковыйХеш = СтрЗаменить(Строка(ДвоичныйХеш), " ", "");
	
	Возврат СтроковыйХеш;
КонецФункции

Процедура ДобавитьВХэш(ХешДанных, СтрокаТЗ, ОписаниеКолонок)
	Для Каждого ИмяКолонки Из ОписаниеКолонок.Обычные Цикл
		СтроковоеЗначение = Строка(СтрокаТЗ[ИмяКолонки]);
		ХешДанных.Добавить(СтроковоеЗначение);
	КонецЦикла;
		
	Для Каждого ОписаниеКолонкиСТаблицей Из ОписаниеКолонок.СТаблицами Цикл
		ВложеннаяТаблица = СтрокаТЗ[ОписаниеКолонкиСТаблицей.ИмяКолонки];
		ОписаниеКолонокВложеннойТаблицы = ОписаниеКолонкиСТаблицей.КолонкиВложеннойТаблицы;
		Для каждого СтрокаВложеннойТЗ Из ВложеннаяТаблица Цикл
			ДобавитьВХэш(ХешДанных, СтрокаВложеннойТЗ, ОписаниеКолонокВложеннойТаблицы);
		КонецЦикла;
	КонецЦикла;
КонецПроцедуры

Функция РеквизитыЭмитента(ЭмитентЮрЛицо, Эмитенты, ВместеСЦеннойБумагой)
	Отбор = Новый Структура();
	Отбор.Вставить("Эмитент", ЭмитентЮрЛицо);
	Если Не ВместеСЦеннойБумагой Тогда
		Отбор.Вставить("ОбработанВместеСЦеннойБумагой", Ложь);
		Отбор.Вставить("ЕстьИзмененияХэша", Истина);
	КонецЕсли;
	
	НайденныеСтроки = Эмитенты.НайтиСтроки(Отбор);
	
	Если НайденныеСтроки.Количество() > 0 Тогда
		РеквизитыЭмитента = НайденныеСтроки[0];
	Иначе
		РеквизитыЭмитента = Неопределено;
	КонецЕсли;
	
	Возврат РеквизитыЭмитента;
КонецФункции

// Создает запись в регистре сведений ЖурналИсходящихСообщенийKafka с текущими значениями реквизитов ЦБ и/или Эмитента
// Параметры:
//	РеквизитыЦБ - СтрокаТаблицыЗначений - может иметь значение Неопределено, но хотя бы одно из двух
//											(ЦБ и Эмитентов) должно быть задано.
//	РеквизитыЭмитента - СтрокаТаблицыЗначений - может иметь значение Неопределено, но хотя бы одно из двух
//											(ЦБ и Эмитентов) должно быть задано.
//	ОшибкаОбработки - Булево
//	ОписаниеОшибки - Строка
Процедура ВыгрузитьЦеннуюБумагуИЭмитента(РеквизитыЦБ, РеквизитыЭмитента,  ОшибкаОбработки, ОписаниеОшибки)
	Попытка
		ВнешнийИсточник = ПланыВидовХарактеристик.ВнешниеИсточники.KafkaDepoToBqSecuritiesStatic1642;
		УИДСообщения = Строка(Новый УникальныйИдентификатор());
		Ключ = "SecurityStatic";
		ТекстJSON = ТекстСообщенияJSON(УИДСообщения, РеквизитыЦБ, РеквизитыЭмитента);
		ОтправляемыйОбъект = ?(РеквизитыЦБ = Неопределено, РеквизитыЭмитента.ЦеннаяБумага, РеквизитыЦБ.ЦБ);
		Кафка.ПоместитьСообщениеВРегистрКОтправке(ВнешнийИсточник, Ключ, ТекстJSON, УИДСообщения, ОтправляемыйОбъект);
		
		Если РеквизитыЦБ <> Неопределено Тогда
			ТекстСообщения = "Выгружена ЦБ: " + РеквизитыЦБ.Name + " (ISIN: " + РеквизитыЦБ.ISIN + ")";
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
		КонецЕсли;
		Если РеквизитыЭмитента <> Неопределено Тогда
			ТекстСообщения = "Выгружен эмитент: " + РеквизитыЭмитента.Name + " (Код RuData: " + РеквизитыЭмитента.RuDataCode + ")";
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
		КонецЕсли;
	Исключение
		ОшибкаОбработки = Истина;
		ТекстДиагностики = "Не удалось выгрузить в JSON данные содержащие следующие объекты:";
		Если РеквизитыЦБ <> Неопределено Тогда
			ТекстДиагностики = ТекстДиагностики + Символы.ПС + "ЦБ " + РеквизитыЦБ.Name 
								+ "; ISIN=" + РеквизитыЦБ.ISIN + "; RuDataCode=" + РеквизитыЦБ.RuDataCode;
		КонецЕсли;
		Если РеквизитыЭмитента <> Неопределено Тогда
			ТекстДиагностики = ТекстДиагностики + Символы.ПС + "Эмитент " + РеквизитыЭмитента.Name
								+ "; RuDataCode=" + РеквизитыЭмитента.RuDataCode + Символы.ПС;
		КонецЕсли;
		ТекстДиагностики = ТекстДиагностики + "По причине: " + ОписаниеОшибки();
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстДиагностики);
		ОписаниеОшибки = ТекстДиагностики;
	КонецПопытки;
КонецПроцедуры

Функция ТекстСообщенияJSON(УИДСообщения, РеквизитыЦБ, РеквизитыЭмитента)
	MessageInfo = РаботаСJSON.СтруктураMessageInfo();
	MessageInfo.MessageType = "SecurityStatic";
	MessageInfo.JsonVersion = "1.0.0";
	MessageInfo.MessageId = УИДСообщения;
	MessageInfo.SystemSource = "Depo";
	Если РеквизитыЦБ <> Неопределено И Не ЗначениеЗаполнено(РеквизитыЦБ.СтарыйХешРеквизитов) Тогда
		MessageInfo.ActionType = "INS";
	Иначе
		MessageInfo.ActionType = "UPD";
	КонецЕсли;
	MessageInfo.MasterMessageId = УИДСообщения;
	MessageInfo.ParentMessageId = Неопределено;	// null
	MessageInfo.DateTimeCreate = ЗаписатьДатуJSON(ТекущаяДатаСеанса(), ФорматДатыJSON.ISO);
	
	Data = БлокData(РеквизитыЦБ, РеквизитыЭмитента);
	
	ТекстСообщенияJSON = РаботаСJSON.ТекстСообщенияJSON(MessageInfo, Data);
	
	Возврат ТекстСообщенияJSON;
КонецФункции

Функция БлокData(РеквизитыЦБ, РеквизитыЭмитента)
	Data = Новый Структура;
	
	Если РеквизитыЦБ <> Неопределено Тогда
		Asset = БлокAsset(РеквизитыЦБ);
		Data.Вставить("Asset", Asset);
		SecurityMainData = БлокSecurityMainData(РеквизитыЦБ);
		Data.Вставить("SecurityMainData", SecurityMainData);
		Если РеквизитыЦБ.ЭтоКупоннаяОблигация Или РеквизитыЦБ.Купоны.Количество() > 0 Тогда
			CouponMainData = БлокCouponMainData(РеквизитыЦБ);
			Data.Вставить("CouponMainData", CouponMainData);
		КонецЕсли;
		Если РеквизитыЦБ.Номиналы.Количество() > 0 Тогда
			SecurityNominalData = БлокSecurityNominalData(РеквизитыЦБ.Номиналы);
			Data.Вставить("SecurityNominalData", SecurityNominalData);
		КонецЕсли;
		Если РеквизитыЦБ.Купоны.Количество() > 0 Тогда
			SecurityCouponData = БлокSecurityCouponData(РеквизитыЦБ.Купоны);
			Data.Вставить("SecurityCouponData", SecurityCouponData);
		КонецЕсли;
	КонецЕсли;
	Если РеквизитыЭмитента <> Неопределено Тогда
		EmitentMainData = БлокEmitentMainData(РеквизитыЭмитента);
		Data.Вставить("EmitentMainData", EmitentMainData);
		Если РеквизитыЭмитента.КонтактнаяИнформация.Количество() > 0 Тогда
			EmitentContactData = БлокEmitentContactData(РеквизитыЭмитента.КонтактнаяИнформация);
			Data.Вставить("EmitentContactData", EmitentContactData);
		КонецЕсли;
		Если РеквизитыЭмитента.МеждународныеКомпании.Количество() > 0 Тогда
			EmitentPeriodICData = БлокEmitentPeriodICData(РеквизитыЭмитента.МеждународныеКомпании);
			Data.Вставить("EmitentPeriodICData", EmitentPeriodICData);
		КонецЕсли;
	КонецЕсли;
	
	Возврат Data;
КонецФункции

Функция БлокAsset(РеквизитыЦБ)
	Asset = Новый Структура;
	
	AssetCode	= РеквизитыЦБ.AssetCode;
	Isin		= РеквизитыЦБ.Isin;
	RegNum		= РеквизитыЦБ.RegNum;
	RuDataCode	= РаботаСJSON.ЧисловойКодRuData(РеквизитыЦБ.RuDataCode);
		
	Asset.Вставить("AssetCode",		НеопределеноЕслиПусто(AssetCode) );
	Asset.Вставить("Isin",			НеопределеноЕслиПусто(Isin) );
	Asset.Вставить("RegNum",		НеопределеноЕслиПусто(RegNum) );
	Asset.Вставить("RuDataCode",	НеопределеноЕслиПусто(RuDataCode) );
	
	Возврат Asset;
КонецФункции

