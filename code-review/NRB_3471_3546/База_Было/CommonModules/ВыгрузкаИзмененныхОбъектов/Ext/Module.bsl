Процедура ВставитьВСтруктуру(Структура, Источник, ИмяЭлемента, ЭтоДата = Ложь)
	ЗначениеЭлемента = НеопределеноЕслиПусто(Источник[ИмяЭлемента]);
	
	Если ЭтоДата И ЗначениеЭлемента <> Неопределено Тогда
		ЗначениеЭлемента = ЗаписатьДатуJSON(ЗначениеЭлемента, ФорматДатыJSON.ISO);
	КонецЕсли;

	Структура.Вставить(ИмяЭлемента, ЗначениеЭлемента);
КонецПроцедуры

Функция НеопределеноЕслиПусто(Значение)
	Если ЗначениеЗаполнено(Значение) Или Значение = 0 Тогда
		Результат = Значение;
	Иначе
		Результат = Неопределено;
	КонецЕсли;
	
	Возврат Результат;
КонецФункции

#КонецОбласти