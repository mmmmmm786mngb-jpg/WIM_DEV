// Формирует почтовый профиль по учетной записи
//
// Параметры
//  УчетнаяЗапись
//
// Возвращаемое значение:
//   ИнтернетПочтовыйПрофиль
//
Функция ПолучитьИнтернетПочтовыйПрофиль(УчетнаяЗапись) Экспорт

	Профиль = Новый ИнтернетПочтовыйПрофиль;
	
	Профиль.АдресСервераPOP3 = УчетнаяЗапись.POP3Сервер;
	Профиль.АдресСервераSMTP = УчетнаяЗапись.SMTPСервер;
	Если УчетнаяЗапись.ВремяОжиданияСервера > 0 Тогда
		Профиль.ВремяОжидания = УчетнаяЗапись.ВремяОжиданияСервера;
	КонецЕсли; 
	Профиль.Пароль           = УчетнаяЗапись.Пароль;
	Профиль.Пользователь     = УчетнаяЗапись.Логин;
	Профиль.ПортPOP3         = УчетнаяЗапись.ПортPOP3;
	Профиль.ПортSMTP         = УчетнаяЗапись.ПортSMTP;
	
	Если УчетнаяЗапись.ТребуетсяSMTPАутентификация Тогда
		Профиль.АутентификацияSMTP = СпособSMTPАутентификации.ПоУмолчанию;
		Профиль.ПарольSMTP         = УчетнаяЗапись.ПарольSMTP;
		Профиль.ПользовательSMTP   = УчетнаяЗапись.ЛогинSMTP;
	Иначе
		Профиль.АутентификацияSMTP = СпособSMTPАутентификации.БезАутентификации;
		Профиль.ПарольSMTP         = "";
		Профиль.ПользовательSMTP   = "";
	КонецЕсли; 
	
	Возврат Профиль;

КонецФункции

Процедура ОтправитьСообщениеПолучателям(Настройка, ТемаСообщения, ТекстСообщения, Вложения = Неопределено) Экспорт
	
	Если Не ЗначениеЗаполнено(Настройка) Тогда
		Возврат;
	КонецЕсли;
	Если ТипЗнч(Настройка) = Тип("СправочникСсылка.НастройкиОбменаДанными") Тогда
		АктуальнаяУчетнаяЗаписьОтправки = Справочники.НастройкиОбменаДанными.АктуальнаяУчетнаяЗаписьПриемаОтправкиСообщений(Настройка);
	Иначе
		АктуальнаяУчетнаяЗаписьОтправки = Настройка.УчетнаяЗаписьПриемаОтправкиСообщений;
	КонецЕсли;
	УправлениеЭлектроннойПочтой.ИнтернетПисьмо(АктуальнаяУчетнаяЗаписьОтправки, ТемаСообщения, Настройка.АдресПолучателя, ТекстСообщения, Вложения);
	
КонецПроцедуры // ОтправитьСообщениеПолучателям()

Процедура ИнтернетПисьмо(УчетнаяЗаписьПриемаОтправкиСообщений, Тема, СписокПолучателей, ТекстПисьма, Вложения = Неопределено) Экспорт

	Перем Профиль, ИнтернетПочта;

	Профиль = ПолучитьИнтернетПочтовыйПрофиль(УчетнаяЗаписьПриемаОтправкиСообщений);
	
	ИмяОтправителя = УчетнаяЗаписьПриемаОтправкиСообщений.ЛогинSMTP;

	Письмо = Новый ИнтернетПочтовоеСообщение;
	Письмо.СпособКодированияНеASCIIСимволов = СпособКодированияНеASCIIСимволовИнтернетПочтовогоСообщения.MIME;

	Письмо.Отправитель.Адрес = УчетнаяЗаписьПриемаОтправкиСообщений.АдресЭлектроннойПочты;
	Письмо.Отправитель.ОтображаемоеИмя = УчетнаяЗаписьПриемаОтправкиСообщений.Наименование;
	
	ПозицияСимвола = Найти(ИмяОтправителя, "@");
	Письмо.ИмяОтправителя = ?(ПозицияСимвола > 0, Лев(ИмяОтправителя,ПозицияСимвола-1), ИмяОтправителя);
	Если ПозицияСимвола > 0 Тогда
		Письмо.Отправитель.Сервер = Прав(ИмяОтправителя, СтрДлина(ИмяОтправителя) - ПозицияСимвола);
		Письмо.Отправитель.Пользователь = Письмо.ИмяОтправителя;
	КонецЕсли;
	
	Письмо.Тема = ТемаПисьмаСИсточником(Тема);
	
	Если ТипЗнч(СписокПолучателей) = Тип("СписокЗначений") Тогда
		
		Для Каждого Адрес Из СписокПолучателей Цикл
			Письмо.Получатели.Добавить(Адрес.Значение);
		КонецЦикла;
		
	ИначеЕсли  ТипЗнч(СписокПолучателей) = Тип("Строка") Тогда
		
		МассивАдресовПолучателей = ПроцедурыУправленияПерсоналом.РазложитьСтрокуВМассивПодстрок(СписокПолучателей, ";");
		Для Каждого АдресПолучателя Из МассивАдресовПолучателей Цикл
			Письмо.Получатели.Добавить(СокрЛП(АдресПолучателя));
		КонецЦикла;
		
	ИначеЕсли  ТипЗнч(СписокПолучателей) = Тип("Массив") Тогда
		
		Для Каждого ЭлементАдресПолучателя Из СписокПолучателей Цикл
			Если ТипЗнч(ЭлементАдресПолучателя) = Тип("Строка") Тогда
				АдресПолучателя = ЭлементАдресПолучателя;
			ИначеЕсли ТипЗнч(ЭлементАдресПолучателя) = Тип("Структура") 
						И ЭлементАдресПолучателя.Свойство("Адрес") Тогда
				АдресПолучателя = ЭлементАдресПолучателя.Адрес;
			Иначе
				Продолжить;
			КонецЕсли;
			Письмо.Получатели.Добавить(СокрЛП(АдресПолучателя));
		КонецЦикла;
		
	КонецЕсли;

	Письмо.Тексты.Добавить(ТекстПисьма, ТипТекстаПочтовогоСообщения.ПростойТекст);
	Если ТипЗнч(Вложения) = Тип("СписокЗначений") Тогда
		Для Каждого Адрес Из Вложения Цикл
			Письмо.Вложения.Добавить(Адрес.Значение);
		КонецЦикла;
	КонецЕсли;

	Письмо.ОбработатьТексты();

	ИнтернетПочта = Новый ИнтернетПочта;

	Попытка
		ИнтернетПочта.Подключиться(Профиль);
		ИнтернетПочта.Послать(Письмо);
		ИнтернетПочта.Отключиться();
	Исключение
		ЗаписьЖурналаРегистрации(ОписаниеОшибки(), УровеньЖурналаРегистрации.Ошибка);
	КонецПопытки;

КонецПроцедуры

// Возвращает Тему письма с источником (для тестовых баз)
//
// Параметры:
//  Тема			 - Строка	 - Оригинальное название Темы
//  ЭтоТестоваяБаза	 - Булево	 - Признак тестовой базы
// 
// Возвращаемое значение:
//   - Строка - Для "Прод": просто Тема; для остальных баз: Тема + «Отправлено с UAT» + Имя базы
//
Функция ТемаПисьмаСИсточником(Знач Тема, ЭтоТестоваяБаза = Ложь) Экспорт
	
	Если ЭтоТестоваяБаза Или Привилегированный.ЭтоТестоваяБаза() Тогда
		ШаблонТемы = "%1%2(Отправлено с UAT) [%3]";
		Разделитель = ?(ПустаяСтрока(Тема), "", " ");
		Тема = СтрШаблон(ШаблонТемы, Тема, Разделитель, ПараметрыСеанса.ТекущаяИнформационнаяБаза);
	КонецЕсли;
	
	Возврат Тема;
КонецФункции

// Преобразовывает внутренние форматы вложений к двоичным данным.
//
Функция ПривестиВложениеДляВставкиВПисьмо(Вложение) Экспорт
	Если ТипЗнч(Вложение) = Тип("Строка") И ЭтоАдресВременногоХранилища(Вложение) Тогда
		Вложение = ПолучитьИзВременногоХранилища(Вложение);
		ПривестиВложениеДляВставкиВПисьмо(Вложение);
		Возврат Истина;
	ИначеЕсли ТипЗнч(Вложение) = Тип("Картинка") Тогда
		Вложение = Вложение.ПолучитьДвоичныеДанные();
		Возврат Истина;
	ИначеЕсли ТипЗнч(Вложение) = Тип("Файл") И Вложение.Существует() И Вложение.ЭтоФайл() Тогда
		Вложение = Новый ДвоичныеДанные(Вложение.ПолноеИмя);
		Возврат Истина;
	КонецЕсли;
	Возврат Ложь;
КонецФункции

// Процедура - Отправить сообщения контроля поручений по электронной почте
//
// Параметры:
//	СсылкаНаПоручение - ДокументСсылка.Поручение
//	СообщенияКонтроля	 - Массив	 - Массив структур с ключами СообщениеКонтроля (строка)
//										и СобытиеКонтроля (ПеречислениеСсылка.СобытияКонтроляПоручений)
Процедура ОтправитьСообщенияКонтроляПорученийПоЭлектроннойПочте(СсылкаНаПоручение, СообщенияКонтроля) Экспорт
	Если СообщенияКонтроля.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	ВнешнийИсточник = ПланыВидовХарактеристик.ВнешниеИсточники.РассылкаУведомленийОСрабатыванииКонтроляПоручений;
	НастройкиОбмена = ВнешниеДанные.ПолучитьПараметрыВнешнегоИсточника(ВнешнийИсточник).Настройка;
	Если НастройкиОбмена = Неопределено Тогда
		ТекстОшибки = "Не заданы параметры внешнего источника " + ВнешнийИсточник;
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстОшибки);
		ИмяСобытия = "Уведомления о срабатывании контроля поручения";
		ЗаписьЖурналаРегистрации(ИмяСобытия, УровеньЖурналаРегистрации.Ошибка, , ВнешнийИсточник, ТекстОшибки);
		Возврат;
	КонецЕсли;
	
	СобытиеКонтроля = СообщенияКонтроля[0].СобытиеКонтроля;
	Пользователь = СообщенияКонтроля[0].Пользователь;
		
	Если СобытиеКонтроля = Перечисления.СобытияКонтроляПоручений.ПриПроведенииСЗапретом Тогда
		ОписаниеСобытия = "при ручном проведении (с запретом проведения)";
	ИначеЕсли СобытиеКонтроля = Перечисления.СобытияКонтроляПоручений.ПриПроведении Тогда
		ОписаниеСобытия = "при ручном проведении";
	Иначе
		ОписаниеСобытия = "при записи";
	КонецЕсли;
	
	ТемаПисьма = "Сработал контроль " + ОписаниеСобытия + " документа " + Строка(СсылкаНаПоручение);
	
	ТекстПисьма = "Сработал контроль " + ОписаниеСобытия + " пользователем " + Строка(Пользователь)
					+ " документа " + Строка(СсылкаНаПоручение) + Символы.ПС;
	Для Каждого РезультатКонтроля Из СообщенияКонтроля Цикл
		Если РезультатКонтроля.ОтправкаУведомленияПоЭлектроннойПочте Тогда
			ТекстПисьма = ТекстПисьма + Символы.ПС + " - " + РезультатКонтроля.СообщениеКонтроля;
		КонецЕсли;
	КонецЦикла; 
	
	ПараметрыУведомления = Новый Соответствие;
	ПараметрыУведомления.Вставить("Вложения",			Неопределено);
	ПараметрыУведомления.Вставить("НастройкиОбмена",	НастройкиОбмена);
	ПараметрыУведомления.Вставить("Кодировка",			"UTF-8");
	ПараметрыУведомления.Вставить("ТемаПисьма",			ТемаПисьма);
	ПараметрыУведомления.Вставить("ТекстПисьма",		ТекстПисьма);
	ПараметрыУведомления.Вставить("ТипТекстаПисьма",	ТипТекстаПочтовогоСообщения.ПростойТекст);
	ПараметрыУведомления.Вставить("Важность",			ВажностьИнтернетПочтовогоСообщения.Обычная);
	РегистрыСведений.УведомленияКОтправке.ДобавитьУведомлениеКотправке(ПараметрыУведомления);
КонецПроцедуры

