Функция ВидОперацииДокумента(ДанныеПоручения, Источник)
	
	Если ДанныеПоручения <> Неопределено И ТипЗнч(ДанныеПоручения) = Тип("Структура") И ДанныеПоручения.Свойство("ВидОперацииД") Тогда
		ВидОперации = ДанныеПоручения.ВидОперацииД;
	ИначеЕсли ТипЗнч(Источник) = Тип("ДокументОбъект.Поручение") Или ТипЗнч(Источник) = Тип("ДокументОбъект.ОперацииЦБ") Тогда
		ВидОперации = Источник.ВидОперацииД;
	ИначеЕсли ТипЗнч(Источник) = Тип("ДокументСсылка.ОперацииЦБ") Тогда
		ВидОперации = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Источник, "ВидОперацииД");
	ИначеЕсли ТипЗнч(Источник) = Тип("ДокументСсылка.ГлобальнаяОперация") Тогда
		ВидОперации = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Источник, "ВидГлобальнойОперации");
	Иначе
		ВидОперации = Неопределено;
	КонецЕсли;
	
	Возврат ВидОперации;

КонецФункции

Процедура ПодготовитьТекстСообщенияИЗаписатьВОчередьКафка(Источник, ДополнительныеПараметры, ДокументСсылка)
	
	БылаВыгрузка = БылаВыгрузкаВКафка(ДокументСсылка, ДополнительныеПараметры);
	ДополнительныеПараметры.Вставить("БылаВыгрузкаВКафка", БылаВыгрузка);
	
	ВидОперации = ДополнительныеПараметры.ВидОперации;
	
	Если ВидОперации = Справочники.ВидыОпераций.Депонирование
		Или ВидОперации = Справочники.ВидыОпераций.СнятиеСДепонирования Тогда
		Ключ = "TransactionSec";
		ВнешнийИсточник = ПланыВидовХарактеристик.ВнешниеИсточники.KafkaTransactionSec;
	ИначеЕсли Справочники.ВидыОпераций.ЭтоПереводЦБ(ВидОперации) Тогда
		Ключ = "TransactionTransf";
		ВнешнийИсточник = ПланыВидовХарактеристик.ВнешниеИсточники.KafkaTransactionTransf;
	ИначеЕсли ВидОперации = Справочники.ВидыОпераций.Конвертация Тогда
		Ключ = "TransactionConv";
		ВнешнийИсточник = ПланыВидовХарактеристик.ВнешниеИсточники.KafkaTransactionConv;
	ИначеЕсли ВидОперации = Справочники.ВидыОпераций.ВыкупСписаниеЦБ
		Или ВидОперации = Справочники.ВидыОпераций.Погашение Тогда
		Ключ = "Redemption";
		ВнешнийИсточник = ПланыВидовХарактеристик.ВнешниеИсточники.KafkaRedemption;
	Иначе
		Возврат;
	КонецЕсли;
	
	ТекстJSON = ОперацияЦБТекстJSON(Источник, ДополнительныеПараметры);
	Если ЗначениеЗаполнено(ТекстJSON) Тогда
		Кафка.ПоместитьСообщениеВРегистрКОтправке(ВнешнийИсточник, Ключ, ТекстJSON, , ДокументСсылка);
		Если Не БылаВыгрузка Тогда
			DepoId = ?(ДополнительныеПараметры.Свойство("СтрокаТЧ"), ДополнительныеПараметры.СтрокаТЧ.DepoId, "");
			РегистрыСведений.ВыгруженныеОперацииСЦБ.Добавить(ДокументСсылка, DepoId);
		КонецЕсли;
	КонецЕсли;

КонецПроцедуры

Процедура ЗаполнитьДанныеПорученияВыкупСписаниеПогашение(ДанныеДокумента, Источник, ДополнительныеПараметры)
	
	ДанныеПоручения = Неопределено;
	Если ДополнительныеПараметры.Свойство("ДанныеПоручения") Тогда
		ДанныеПоручения = ДополнительныеПараметры.ДанныеПоручения;
		
		ПоручениеСсылка = ДанныеПоручения.Поручение;
		НомерПоручения = ДанныеПоручения.Номер;
		ДатаИсполненияПоручения = ДанныеПоручения.ДатаИсполненияПоручения;
		Комментарий = ДанныеПоручения.Комментарий;
	Иначе
		ПоручениеСсылка = Источник.Ссылка;
		НомерПоручения = Источник.Номер;
		ДатаИсполненияПоручения = Источник.ДатаИсполненияПоручения;
		Комментарий = Источник.Комментарий;
	КонецЕсли;
	
	ДанныеДокумента.Вставить("ObjectVersion", ИсторияДанныхВызовСервера.КоличествоВерсийОбъекта(ПоручениеСсылка) + 1);
	ДанныеДокумента.Вставить("CLTypeCode", ?(ДополнительныеПараметры.ВидОперации = Справочники.ВидыОпераций.Погашение,
		"redemption", "buyback"));
	ДанныеДокумента.Вставить("OperationNum", СокрЛП(НомерПоручения));
	
	ДанныеДокумента.Вставить("Date", ЗаписатьДатуJSON(ДатаИсполненияПоручения, ФорматДатыJSON.ISO));
	
	ЭтоСтрокаКУдалению = ДополнительныеПараметры.Свойство("ДанныеУдаляемойСтроки");
	
	СтрокаТЧ = ?(ЭтоСтрокаКУдалению, ДополнительныеПараметры.ДанныеУдаляемойСтроки, ДополнительныеПараметры.СтрокаТЧ);
	ИмяРеквизитаКод = "Код";
	ДанныеДокумента.Вставить("DepoId", Строка(СтрокаТЧ.DepoId));
	Депонент = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СтрокаТЧ.СчетДепо, "Владелец");
	ДанныеДепонента = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Депонент, "ЮридическиеФизическиеЛица");
	ДанныеДокумента.Вставить("CrmClientId", Обработки.РегистрацияКлиентаЧерезKafka.CrmClientId(ДанныеДепонента.ЮридическиеФизическиеЛица));
	ДанныеДокумента.Вставить("ContractNumber", Обработки.РегистрацияКлиентаЧерезKafka.CrmContractNumber(Депонент));
	ДанныеДокумента.Вставить("DepoDivisionCode", СокрЛП(ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СтрокаТЧ.РазделСчетаДепо, ИмяРеквизитаКод)));
	DepoMxFactCode = СокрЛП(ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СтрокаТЧ.СчетДепоМХ, ИмяРеквизитаКод));
	ДанныеДокумента.Вставить("DepoMxFactCode", DepoMxFactCode);
	DepoMxDivisionCode = СокрЛП(ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СтрокаТЧ.РазделСчетаДепоМХ, ИмяРеквизитаКод));
	ДанныеДокумента.Вставить("DepoMxDivisionCode", DepoMxDivisionCode);
	
	Asset = ДанныеЦБ(СтрокаТЧ.ЦеннаяБумага);
	ДанныеДокумента.Вставить("Asset", Asset);
	
	ОписаниеРеквизитов = Новый Структура;
	ОписаниеРеквизитов.Вставить("РеференсКД", "КарточкаКД.КДРеференсВходящий");
	РеквизитыПоручения = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ПоручениеСсылка, ОписаниеРеквизитов);
	ДанныеДокумента.Вставить("Reference", ?(ЗначениеЗаполнено(РеквизитыПоручения.РеференсКД), РеквизитыПоручения.РеференсКД, Неопределено));
	
	ДанныеДокумента.Вставить("Qty", СтрокаТЧ.Количество);
	
	ДополнительныеПараметры.Вставить("СчетДепо", Источник.СчетДепо);
	ДанныеСводногоОтчета = ДанныеСводногоОтчета(Источник, ДополнительныеПараметры);
	ДанныеДокумента.Вставить("PDocNum", СокрЛП(ДанныеСводногоОтчета.СводныйОтчетНомер));
	ДанныеДокумента.Вставить("PDocDate", ДанныеСводногоОтчета.СводныйОтчетДата);
	PDocName = ?(ЗначениеЗаполнено(ДанныеСводногоОтчета.СводныйОтчетНомер), "Сводный отчет о совершенных операциях", "");
	ДанныеДокумента.Вставить("PDocName", PDocName);
	
	ДанныеДокумента.Вставить("Comment", СокрЛП(Комментарий));

КонецПроцедуры

Функция ДанныеСводногоОтчета(Источник, ДополнительныеПараметры)
	
	ДанныеСводногоОтчета = Новый Структура("СводныйОтчетНомер, СводныйОтчетДата", "", Неопределено);
	
	СводныйОтчет = Неопределено;
	
	Если ДополнительныеПараметры = Неопределено Тогда
		ДополнительныеПараметры = Новый Структура;
	КонецЕсли;
	
	ЭтоСводныйОтчет = ДополнительныеПараметры.Свойство("СводныйОтчет", СводныйОтчет);
	
	Если ЭтоСводныйОтчет И ДополнительныеПараметры.Свойство("СчетДепо") И ДополнительныеПараметры.СчетДепо = СводныйОтчет.СчетДепо Тогда
		ДанныеСводногоОтчета.СводныйОтчетНомер = СводныйОтчет.Номер;
		ДанныеСводногоОтчета.СводныйОтчетДата = СводныйОтчет.Дата;
	Иначе
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	СводныйОтчетОСовершенныхОперацияхОперации.Ссылка.Номер КАК Номер,
		|	СводныйОтчетОСовершенныхОперацияхОперации.Ссылка.Дата КАК Дата
		|ИЗ
		|	Документ.СводныйОтчетОСовершенныхОперациях.Операции КАК СводныйОтчетОСовершенныхОперацияхОперации
		|ГДЕ
		|	СводныйОтчетОСовершенныхОперацияхОперации.ДокументОперации = &ДокументСсылка
		|	И СводныйОтчетОСовершенныхОперацияхОперации.Ссылка.Проведен
		|	И СводныйОтчетОСовершенныхОперацияхОперации.Ссылка.Дата >= &КонецДняОперацииЦБ
		|	И &УсловиеПоСчетуДепо
		|	И СводныйОтчетОСовершенныхОперацияхОперации.ДокументОперации ССЫЛКА Документ.ОперацииЦБ
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ ПЕРВЫЕ 1
		|	СводныйОтчетОСовершенныхОперацияхОперации.Ссылка.Номер,
		|	СводныйОтчетОСовершенныхОперацияхОперации.Ссылка.Дата
		|ИЗ
		|	Документ.СводныйОтчетОСовершенныхОперациях.Операции КАК СводныйОтчетОСовершенныхОперацияхОперации
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ГлобальнаяОперация КАК ГлобальнаяОперация
		|		ПО СводныйОтчетОСовершенныхОперацияхОперации.ДокументОперации = ГлобальнаяОперация.Ссылка
		|ГДЕ
		|	СводныйОтчетОСовершенныхОперацияхОперации.ДокументОперации ССЫЛКА Документ.ГлобальнаяОперация
		|	И СводныйОтчетОСовершенныхОперацияхОперации.Ссылка.Проведен
		|	И СводныйОтчетОСовершенныхОперацияхОперации.Ссылка.Дата >= &КонецДняОперацииЦБ
		|	И ГлобальнаяОперация.ДокументОснование = &ДокументСсылка";
		
		Если ДополнительныеПараметры.Свойство("СчетДепо") Тогда
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеПоСчетуДепо", "СводныйОтчетОСовершенныхОперацияхОперации.НомерСчетаДепо = &СчетДепо");
			Запрос.УстановитьПараметр("СчетДепо", ДополнительныеПараметры.СчетДепо);
		Иначе
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеПоСчетуДепо", "Истина");
		КонецЕсли;
		Запрос.УстановитьПараметр("ДокументСсылка", Источник.Ссылка);
		Запрос.УстановитьПараметр("КонецДняОперацииЦБ", КонецДня(Источник.Дата));
		
		РезультатЗапроса = Запрос.Выполнить();
		ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
		Если ВыборкаДетальныеЗаписи.Следующий() Тогда
			ДанныеСводногоОтчета.СводныйОтчетНомер = ВыборкаДетальныеЗаписи.Номер;
			ДанныеСводногоОтчета.СводныйОтчетДата = ВыборкаДетальныеЗаписи.Дата;
		КонецЕсли;
	КонецЕсли;

	Возврат ДанныеСводногоОтчета;
	
КонецФункции

Функция MessageInfoWithActionType(Источник, ДополнительныеПараметры)
	
	ЭтоУдалениеСтроки = Ложь;
	Идентификатор = ИдентификаторИсточника(Источник, ДополнительныеПараметры, ЭтоУдалениеСтроки);
	MessageInfo = ДанныеMessageInfo(Идентификатор);
	Если ДополнительныеПараметры.Свойство("СводныйОтчет") Тогда
		MessageInfo.ActionType = "UPD";
	Иначе
		Если Не Источник.Проведен Или ЭтоУдалениеСтроки Тогда
			MessageInfo.ActionType = "DEL";
		Иначе
			MessageInfo.ActionType = ?(ДополнительныеПараметры.Свойство("БылаВыгрузкаВКафка")
				И ДополнительныеПараметры.БылаВыгрузкаВКафка, "UPD", "INS");
		КонецЕсли;
	КонецЕсли;
	
	Возврат MessageInfo;
	
КонецФункции

Функция ИдентификаторИсточника(Источник, ДополнительныеПараметры, ЭтоУдалениеСтроки)
	
	Если ТипЗнч(Источник) = Тип("ДокументСсылка.ОперацииЦБ") Тогда
		Идентификатор = Строка(Источник.УникальныйИдентификатор());
	ИначеЕсли (ТипЗнч(Источник) = Тип("ДокументОбъект.Поручение")
		Или ТипЗнч(Источник) = Тип("ДокументСсылка.ГлобальнаяОперация"))
		И ДополнительныеПараметры.Свойство("СтрокаТЧ") Тогда
		Идентификатор = ДополнительныеПараметры.СтрокаТЧ.DepoId;
	ИначеЕсли ТипЗнч(Источник) = Тип("ДокументОбъект.Поручение")
		И ДополнительныеПараметры.Свойство("ДанныеУдаляемойСтроки") Тогда
		Идентификатор = ДополнительныеПараметры.ДанныеУдаляемойСтроки.DepoId;
		ЭтоУдалениеСтроки = Истина;
	Иначе
		Идентификатор = Строка(Источник.Ссылка.УникальныйИдентификатор());
	КонецЕсли;
	
	Возврат Идентификатор;
	
КонецФункции

Функция ЭтоОперацияЦБСводногоПоручения(Источник)
	
	Если ТипЗнч(Источник) = Тип("ДокументСсылка.ОперацииЦБ") Тогда
		ДокументОснование = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Источник, "ДокументОснование");
	ИначеЕсли ТипЗнч(Источник) = Тип("ДокументОбъект.ОперацииЦБ") Тогда
		ДокументОснование = Источник.ДокументОснование;
	Иначе
		ДокументОснование = Неопределено;
	КонецЕсли;
	
	Возврат ЗначениеЗаполнено(ДокументОснование) И ТипЗнч(ДокументОснование) = Тип("ДокументСсылка.иц_СводноеПоручение");
	
КонецФункции

Процедура ЗаписатьВОчередьКафкаПогашениеВыкупСписаниеЦБ(Источник, ДополнительныеПараметры, ТипИсточника, ДанныеПоручения)
	
	Если ДанныеПоручения <> Неопределено Тогда
		ЦенныеБумагиСписываемые = ДанныеПоручения.ЦенныеБумагиСписываемые.Выгрузить();
		ПоручениеСсылка = ДанныеПоручения.Поручение;
	Иначе
		ЦенныеБумагиСписываемые = Источник.ЦенныеБумагиСписываемые;
		ПоручениеСсылка = Источник.Ссылка;
	КонецЕсли;
	Для Каждого СтрокаТЧ Из ЦенныеБумагиСписываемые Цикл
		Если СтрокаТЧ.СчетДепо = Источник.СчетДепо Или ТипИсточника = Тип("ДокументОбъект.Поручение") Тогда
			ДополнительныеПараметры.Вставить("СтрокаТЧ", СтрокаТЧ);
			ПодготовитьТекстСообщенияИЗаписатьВОчередьКафка(Источник, ДополнительныеПараметры, ПоручениеСсылка);
		КонецЕсли;
	КонецЦикла;
	ДополнительныеПараметры.Удалить("СтрокаТЧ");
	Если ТипЗнч(Источник) = Тип("ДокументОбъект.Поручение") И Источник.ДополнительныеСвойства.Свойство("СтрокиКУдалению") Тогда
		Для Каждого ДанныеУдаляемойСтроки Из Источник.ДополнительныеСвойства.СтрокиКУдалению Цикл
			ДополнительныеПараметры.Вставить("ДанныеУдаляемойСтроки", ДанныеУдаляемойСтроки);
			ПодготовитьТекстСообщенияИЗаписатьВОчередьКафка(Источник, ДополнительныеПараметры, ПоручениеСсылка);
		КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры

Функция СчетДепоВТабличнойЧастиДокумента(ДанныеТранзакции)
	Попытка
		Возврат ДанныеТранзакции.СчетДепо;
	Исключение
		Возврат ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДанныеТранзакции.РазделСчетаДепо, "Владелец");
	КонецПопытки;
КонецФункции

// Процедура формирует сообщение для передачи данных ИНН, ОГРН Эмитента по данным ЦБ РФ, а также ряда других реквизитов
// кодов загрузки эмитента в BackQort.
// в базе в справочнике ЦБ
// Параметры:
//	Данные - ВыборкаИзРезультатаЗапроса - данные о юридическом лице являющимся эмитентом
Процедура ВыгрузитьИНН_ОГРН_ЦБРФ_ЭмитентаВBackQort(Данные) Экспорт
	
	Сущность = "EmitentCBRData";
	ВнешнийИсточник = ПланыВидовХарактеристик.ВнешниеИсточники.KafkaDepoToBqSecuritiesStatic1642;
	УИДСообщения = Строка(Новый УникальныйИдентификатор);

	Попытка
		MessageInfo = ОбменДаннымиКафка.ТиповыеДанныеMessageInfo(Сущность, "INS", "1.0.0", УИДСообщения);
		ДанныеДляСообщения = Новый Структура;
		ДанныеДляСообщения.Вставить("RuDataCode", РаботаСJSON.ЧисловойКодRuData(СокрЛП(Данные.RuDataCode)) );
		ДанныеДляСообщения.Вставить("NrdCode", СокрЛП(Данные.NrdCode) );
		ДанныеДляСообщения.Вставить("LeiCode", СокрЛП(Данные.LeiCode) );
		ДанныеДляСообщения.Вставить("Tin", Данные.TIN);
		ДанныеДляСообщения.Вставить("Name", Данные.НаименованиеЮЛ);
		ДанныеДляСообщения.Вставить("InnCBR", Данные.ИНН);
		ДанныеДляСообщения.Вставить("OgrnCBR", Данные.ОГРН);
		ДанныеДляСообщения.Вставить("KppCBR", Данные.КПП);
		ДанныеДляСообщения.Вставить("NameCBR", Данные.Наименование);
		ТекстJSON = РаботаСJSON.ТекстСообщенияJSON(MessageInfo, ДанныеДляСообщения);
		Кафка.ПоместитьСообщениеВРегистрКОтправке(ВнешнийИсточник, Сущность, ТекстJSON, УИДСообщения, Данные.ЮрлицоЭмитент);
	Исключение
		ТекстОшибки = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстОшибки);
		ЗаписьЖурналаРегистрации("ИНН_ОГРН_ЦБРФ_ЭмитентаВBackQort", УровеньЖурналаРегистрации.Ошибка, , , ТекстОшибки);
	КонецПопытки;
	
КонецПроцедуры

#КонецОбласти

#Область ПроверкиВходящихСообщений

// Процедура добавления данных набора записей в РС ЖурналИсходящихСообщенийKafka
//
// Параметры:
//  ИсходныйMessageInfo - Структура - MessageInfo, полученный из входящего сообщения
//  MessageInfo - Строка - Проверенный MessageInfo
//  ИмяСобытия - Строка - имя события, из которого вызвана процедура
//  ТекстОшибки - Строка - текст ошибки
Процедура ПодготовитьMessageInfo(ИсходныйMessageInfo, MessageInfo, ИмяСобытия, ТекстОшибки) Экспорт
	
	MessageInfo.MessageType		= ИсходныйMessageInfo.MessageType;
	MessageInfo.MessageId		= ИсходныйMessageInfo.MessageId;
	MessageInfo.MasterMessageId = ИсходныйMessageInfo.MasterMessageId;
	MessageInfo.ParentMessageId = ИсходныйMessageInfo.ParentMessageId;
	MessageInfo.SystemSource	= ИсходныйMessageInfo.SystemSource;
	MessageInfo.DateTimeCreate	= ПрочитатьДатуJSON(ИсходныйMessageInfo.DateTimeCreate, ФорматДатыJSON.ISO);
	MessageInfo.JsonVersion		= ИсходныйMessageInfo.JsonVersion;
	MessageInfo.ActionType		= ИсходныйMessageInfo.ActionType;
		
КонецПроцедуры

#КонецОбласти

#Область ВыгрузкаДанныхСводныхОтчетовПоСделкамVPFI_OTC

// Процедура выгружает из документа Сводный отчет о совершенных операциях данные по первичным документам по VPFI и OTC сделкам
// в Kafka для backQORT. Выгрузка происходит если документ еще не был проведен или в нем есть изменения касающиеся информации
// по VPFI и OTC сделкам по сравнению с его предыдущим состоянием.
// Параметры:
//	СводныйОтчетСсылка - ДокументСсылка.СводныйОтчетОСовершенныхОперациях
//	УжеБылПроведен - Булево
//	ПрошлыеДанныеДляВыгрузки - массив - данные для выгрузки основанные на прошлой версии докмуента (массив структур)
Процедура ВыгрузитьПервичныеДокументыПоСделкамVPFI_OTC(СводныйОтчетСсылка, УжеБылПроведен, ПрошлыеДанныеДляВыгрузки) Экспорт
	ДанныеДляВыгрузки = ДанныеДляВыгрузкиСводногоОтчетаПоСделкамVPFI_OTC(СводныйОтчетСсылка);
	Если Не УжеБылПроведен Или ДанныеДляВыгрузкиИзменились(ПрошлыеДанныеДляВыгрузки, ДанныеДляВыгрузки) Тогда
		Для Каждого ДанныеДляОдногоСообщения Из ДанныеДляВыгрузки Цикл
			ВыгрузитьПервичныйДокумент(ДанныеДляОдногоСообщения, СводныйОтчетСсылка);
		КонецЦикла;
	КонецЕсли;
КонецПроцедуры

// Процедура возвращает данные по первичным документам по VPFI и OTC сделкам содержащиеся в документе
// СводныйОтчетОСовершенныхОперациях.
// Параметры:
//	СводныйОтчетСсылка - ДокументСсылка.СводныйОтчетОСовершенныхОперациях
// Возвращаемое значение:
//	- Массив - (Массив структур).
Функция ДанныеДляВыгрузкиСводногоОтчетаПоСделкамVPFI_OTC(СводныйОтчетСсылка) Экспорт
	ДанныеДляВыгрузки = Новый Массив;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	СводныйОтчетОСовершенныхОперациях.Дата КАК PDocDate,
		|	СводныйОтчетОСовершенныхОперациях.Номер КАК PDocNum,
		|	СводныйОтчетОСовершенныхОперацияхОперации.ОснованиеОперации.НомерПорученияВБО КАК НомерПорученияВБО,
		|	ЕСТЬNULL(КодыЗагрузкиЮридическиеФизическиеЛица.Код, """") КАК CrmClientId,
		|	ЕСТЬNULL(КодыЗагрузкиКонтрагенты.Код, """") КАК ContractNumber,
		|	ВЫБОР
		|		КОГДА СводныйОтчетОСовершенныхОперацияхОперации.ОснованиеОперации.НомерПорученияВБО ПОДОБНО ""VPFI_%""
		|			ТОГДА ""34""
		|		КОГДА СводныйОтчетОСовершенныхОперацияхОперации.ОснованиеОперации.НомерПорученияВБО ПОДОБНО ""OTC_%""
		|			ТОГДА ""4""
		|		ИНАЧЕ """"
		|	КОНЕЦ КАК TypeCode
		|ПОМЕСТИТЬ ВТ_Операции
		|ИЗ
		|	Документ.СводныйОтчетОСовершенныхОперациях КАК СводныйОтчетОСовершенныхОперациях
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.СводныйОтчетОСовершенныхОперациях.Операции КАК СводныйОтчетОСовершенныхОперацияхОперации
		|		ПО (СводныйОтчетОСовершенныхОперацияхОперации.Ссылка = СводныйОтчетОСовершенныхОперациях.Ссылка)
		|			И (СводныйОтчетОСовершенныхОперацияхОперации.ОснованиеОперации ССЫЛКА Документ.Поручение)
		|			И (СводныйОтчетОСовершенныхОперацияхОперации.ОснованиеОперации.НомерПорученияВБО ПОДОБНО ""VPFI_%""
		|				ИЛИ СводныйОтчетОСовершенныхОперацияхОперации.ОснованиеОперации.НомерПорученияВБО ПОДОБНО ""OTC_%"")
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.КодыЗагрузки КАК КодыЗагрузкиЮридическиеФизическиеЛица
		|		ПО (КодыЗагрузкиЮридическиеФизическиеЛица.Владелец = СводныйОтчетОСовершенныхОперациях.ВладелецСчета.ЮридическиеФизическиеЛица)
		|			И (НЕ КодыЗагрузкиЮридическиеФизическиеЛица.ПометкаУдаления)
		|			И (КодыЗагрузкиЮридическиеФизическиеЛица.Биржа = ЗНАЧЕНИЕ(Справочник.КлассификаторыЗагрузки.Клиенты))
		|			И (ВЫБОР
		|				КОГДА КодыЗагрузкиЮридическиеФизическиеЛица.ДатаОкончанияДействия = ДАТАВРЕМЯ(1, 1, 1)
		|					ТОГДА ИСТИНА
		|				КОГДА КодыЗагрузкиЮридическиеФизическиеЛица.ДатаОкончанияДействия > &ТекущаяДата
		|					ТОГДА ИСТИНА
		|				ИНАЧЕ ЛОЖЬ
		|			КОНЕЦ)
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.КодыЗагрузки КАК КодыЗагрузкиКонтрагенты
		|		ПО (КодыЗагрузкиКонтрагенты.Владелец = СводныйОтчетОСовершенныхОперациях.ВладелецСчета)
		|			И (КодыЗагрузкиКонтрагенты.Владелец ССЫЛКА Справочник.Контрагенты)
		|			И (НЕ КодыЗагрузкиКонтрагенты.ПометкаУдаления)
		|			И (КодыЗагрузкиКонтрагенты.Биржа = ЗНАЧЕНИЕ(Справочник.КлассификаторыЗагрузки.CrmContractNumber))
		|			И (ВЫБОР
		|				КОГДА КодыЗагрузкиКонтрагенты.ДатаОкончанияДействия = ДАТАВРЕМЯ(1, 1, 1)
		|					ТОГДА ИСТИНА
		|				КОГДА КодыЗагрузкиКонтрагенты.ДатаОкончанияДействия > &ТекущаяДата
		|					ТОГДА ИСТИНА
		|				ИНАЧЕ ЛОЖЬ
		|			КОНЕЦ)
		|ГДЕ
		|	СводныйОтчетОСовершенныхОперациях.Ссылка = &ЭтотСводныйОтчет
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_Операции.TypeCode КАК TypeCode,
		|	ВТ_Операции.PDocDate КАК PDocDate,
		|	ВТ_Операции.PDocNum КАК PDocNum,
		|	ВТ_Операции.CrmClientId КАК CrmClientId,
		|	ВТ_Операции.ContractNumber КАК ContractNumber,
		|	ВТ_Операции.НомерПорученияВБО КАК НомерПорученияВБО
		|ИЗ
		|	ВТ_Операции КАК ВТ_Операции
		|
		|УПОРЯДОЧИТЬ ПО
		|	TypeCode,
		|	НомерПорученияВБО
		|ИТОГИ
		|	МАКСИМУМ(PDocDate),
		|	МАКСИМУМ(PDocNum),
		|	МАКСИМУМ(CrmClientId),
		|	МАКСИМУМ(ContractNumber)
		|ПО
		|	TypeCode";
	Запрос.УстановитьПараметр("ЭтотСводныйОтчет", СводныйОтчетСсылка);
	Запрос.УстановитьПараметр("ТекущаяДата", ТекущаяДатаСеанса());
	РезультатЗапроса = Запрос.Выполнить();
	
	Если Не РезультатЗапроса.Пустой() Тогда
		ВыборкаТипыОпераций = РезультатЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		Пока ВыборкаТипыОпераций.Следующий() Цикл
			ВыборкаНомераПоручений = ВыборкаТипыОпераций.Выбрать();
			ДанныеДляОдногоСообщения = ПолучитьДанныеДляОдногоСообщения(ВыборкаТипыОпераций, ВыборкаНомераПоручений);
			ДанныеДляВыгрузки.Добавить(ДанныеДляОдногоСообщения);
		КонецЦикла;
	КонецЕсли;
	
	Возврат ДанныеДляВыгрузки;
КонецФункции

Функция ПолучитьДанныеДляОдногоСообщения(ВыборкаТипыОпераций, ВыборкаНомераПоручений)
	НомераПорученийВБО = Новый Массив;
	Пока ВыборкаНомераПоручений.Следующий() Цикл
		НомерПорученияВБО =
			СтроковыеФункцииКлиентСервер.СтрокаТолькоДопустимыхСимволов(ВыборкаНомераПоручений.НомерПорученияВБО, "0123456789");
		НомерПорученияВБО = СтроковыеФункцииКлиентСервер.ЧислоИзСтроки(НомерПорученияВБО);
		BqId = Новый Структура("BqId", НомерПорученияВБО);
		НомераПорученийВБО.Добавить(BqId);
	КонецЦикла;
	
	ДанныеКОтправке = Новый Структура;
	ДанныеКОтправке.Вставить("PDocDate", ВыборкаТипыОпераций.PDocDate);
	ДанныеКОтправке.Вставить("PDocNum", ВыборкаТипыОпераций.PDocNum);
	ДанныеКОтправке.Вставить("PDocName", "Сводный отчет о совершенных операциях");
	ДанныеКОтправке.Вставить("CrmClientId", ВыборкаТипыОпераций.CrmClientId);
	ДанныеКОтправке.Вставить("ContractNumber", СокрЛП(ВыборкаТипыОпераций.ContractNumber));
	ДанныеКОтправке.Вставить("TypeCode", ВыборкаТипыОпераций.TypeCode);
	ДанныеКОтправке.Вставить("Operations", НомераПорученийВБО);
	
	Возврат ДанныеКОтправке;
КонецФункции

Функция ДанныеДляВыгрузкиИзменились(ПрошлыеДанныеДляВыгрузки, ДанныеДляВыгрузки)
	Если ПрошлыеДанныеДляВыгрузки.Количество() <> ДанныеДляВыгрузки.Количество() Тогда
		Возврат Истина;
	КонецЕсли;

	Для Индекс = 0 По ДанныеДляВыгрузки.Количество() - 1 Цикл
		НовыеДанные = ДанныеДляВыгрузки[Индекс];
		СтарыеДанные = ПрошлыеДанныеДляВыгрузки[Индекс];
		Для Каждого Элемент Из НовыеДанные Цикл
			Если Элемент.Ключ = "Operations" Тогда
				Если Не МассивыСделокИдентичны(НовыеДанные.Operations, СтарыеДанные.Operations) Тогда
					Возврат Истина;
				КонецЕсли;
			Иначе
				Если Элемент.Значение <> СтарыеДанные[Элемент.Ключ] Тогда
					Возврат Истина;
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;
	
	Возврат Ложь;
КонецФункции

Функция МассивыСделокИдентичны(Массив1, Массив2)
	Идентичны = Истина;
	
	Если Массив1.Количество() <> Массив2.Количество() Тогда
		Идентичны = Ложь;
	Иначе
		Для Индекс = 0 По Массив1.Количество() - 1 Цикл
			Если Массив1[Индекс].BqId <> Массив2[Индекс].BqId Тогда
				Идентичны = Ложь;
				Прервать;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	Возврат Идентичны;
КонецФункции

Функция ВыгрузитьПервичныйДокумент(ДанныеДляСообщения, СводныйОтчетСсылка)
	
	Сущность = "PrimaryDocs";
	ВнешнийИсточник = ПланыВидовХарактеристик.ВнешниеИсточники.KafkaMultiToBqOperationPrimaryDocs1643;
	УИДСообщения = Строка(Новый УникальныйИдентификатор);
	Успешно = Ложь;
	
	Попытка
		MessageInfo = ОбменДаннымиКафка.ТиповыеДанныеMessageInfo(Сущность, "UPD", "1.0.0", УИДСообщения);
		ТекстJSON = РаботаСJSON.ТекстСообщенияJSON(MessageInfo, ДанныеДляСообщения);
		Кафка.ПоместитьСообщениеВРегистрКОтправке(ВнешнийИсточник, Сущность, ТекстJSON, УИДСообщения, СводныйОтчетСсылка);
		Успешно = Истина;
	Исключение
		Успешно = Ложь;
		ТекстОшибки = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстОшибки);
		ЗаписьЖурналаРегистрации("ВыгрузкаПервичныхДокументовВBackQort", УровеньЖурналаРегистрации.Ошибка, , , ТекстОшибки);
	КонецПопытки;
	
	Возврат Успешно;
КонецФункции

#КонецОбласти

