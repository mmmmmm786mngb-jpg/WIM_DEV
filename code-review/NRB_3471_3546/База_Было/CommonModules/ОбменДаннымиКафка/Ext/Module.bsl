Процедура ЗаполнитьДанныеОперацииЦБПеревод(ДанныеДокумента, Источник, ДополнительныеПараметры)
	
	ИмяРеквизитаКод = "Код";
	ИмяРеквизитаСчетДепо = "СчетДепо";
	
	ДанныеДокумента.Вставить("ObjectVersion", ИсторияДанныхВызовСервера.КоличествоВерсийОбъекта(Источник.Ссылка) + 1);
	ДанныеДокумента.Вставить("OperationNum", СокрЛП(Источник.Номер));
	ДанныеДокумента.Вставить("Date", ЗаписатьДатуJSON(Источник.Дата, ФорматДатыJSON.ISO));
	ДанныеДокумента.Вставить("DepoId", Строка(Источник.Ссылка.УникальныйИдентификатор()));
	
	ДанныеДепонента = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Источник.Депонент, "ЮридическиеФизическиеЛица");
	ДанныеДокумента.Вставить("CrmClientId",
		Обработки.РегистрацияКлиентаЧерезKafka.CrmClientId(ДанныеДепонента.ЮридическиеФизическиеЛица));
	ДанныеДокумента.Вставить("ContractNumber",
		Обработки.РегистрацияКлиентаЧерезKafka.CrmContractNumber(Источник.Депонент));
	ДанныеДокумента.Вставить("DepoDivisionCode",
		СокрЛП(ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Источник.РазделСчетаДепо, ИмяРеквизитаКод)));
	ДанныеДокумента.Вставить("DepoMxDivisionCode",
		СокрЛП(ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Источник.РазделСчетаДепоМХ, ИмяРеквизитаКод)));
	ДанныеДокумента.Вставить("DepoMxFactCode",
		СокрЛП(ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Источник.СчетДепоМХ, ИмяРеквизитаКод)));
	ДанныеДокумента.Вставить("OnlyDepoClient", Источник.Депонент.КлиентОтсутствуетВBQ);
	ДополнительныеПараметры.Вставить(ИмяРеквизитаСчетДепо, Источник.СчетДепо);
	ДанныеСводногоОтчета = ДанныеСводногоОтчета(Источник, ДополнительныеПараметры);
	ДанныеДокумента.Вставить("DocNum", СокрЛП(ДанныеСводногоОтчета.СводныйОтчетНомер));
	ДанныеДокумента.Вставить("DocDate", ДанныеСводногоОтчета.СводныйОтчетДата);
	PDocName = ?(ЗначениеЗаполнено(ДанныеСводногоОтчета.СводныйОтчетНомер), "Сводный отчет о совершенных операциях", "");
	ДанныеДокумента.Вставить("DocName", PDocName);
	Если ЗначениеЗаполнено(Источник.Получатель) Тогда
		ДанныеПолучателя = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Источник.Получатель, "ЮридическиеФизическиеЛица");
		ДанныеДокумента.Вставить("GetCrmClientId",
			Обработки.РегистрацияКлиентаЧерезKafka.CrmClientId(ДанныеПолучателя.ЮридическиеФизическиеЛица));
		ДанныеДокумента.Вставить("GetContractNumber",
			Обработки.РегистрацияКлиентаЧерезKafka.CrmContractNumber(Источник.Получатель));
		ДанныеДокумента.Вставить("GetDepoDivisionCode",
			СокрЛП(ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Источник.РазделСчетаДепоПолучатель, ИмяРеквизитаКод)));
		ДанныеДокумента.Вставить("GetDepoMxDivisionCode",
			СокрЛП(ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Источник.РазделСчетаДепоМХПолучатель, ИмяРеквизитаКод)));
		ДанныеДокумента.Вставить("GetDepoMxFactCode",
			СокрЛП(ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Источник.СчетДепоМХПолучатель, ИмяРеквизитаКод)));
		ДанныеДокумента.Вставить("GetOnlyDepoClient", Источник.Получатель.КлиентОтсутствуетВBQ);
	Иначе
		ДанныеДокумента.Вставить("GetCrmClientId", Неопределено);
		ДанныеДокумента.Вставить("GetContractNumber", Неопределено);
		ДанныеДокумента.Вставить("GetDepoDivisionCode", Неопределено);
		ДанныеДокумента.Вставить("GetDepoMxDivisionCode", Неопределено);
		ДанныеДокумента.Вставить("GetDepoMxFactCode", Неопределено);
	КонецЕсли;	
	ДополнительныеПараметры.Вставить(ИмяРеквизитаСчетДепо, Источник.СчетДепоПолучатель);
	ДанныеСводногоОтчета = ДанныеСводногоОтчета(Источник, ДополнительныеПараметры);
	ДанныеДокумента.Вставить("GetDocNum", СокрЛП(ДанныеСводногоОтчета.СводныйОтчетНомер));
	ДанныеДокумента.Вставить("GetDocDate", ДанныеСводногоОтчета.СводныйОтчетДата);
	PDocName = ?(ЗначениеЗаполнено(ДанныеСводногоОтчета.СводныйОтчетНомер), "Сводный отчет о совершенных операциях", "");
	ДанныеДокумента.Вставить("GetDocName", PDocName);
	ДополнительныеПараметры.Удалить(ИмяРеквизитаСчетДепо);
	
	Asset = ДанныеЦБ(Источник.ЦБ);
	Asset.Вставить("Qty", Источник.Количество);
	ДанныеДокумента.Вставить("Asset", Asset);
	
	Trades = ДанныеПоСделкамОперации(Источник.Ссылка);
	ДанныеДокумента.Вставить("Trades", Trades);
	
КонецПроцедуры

