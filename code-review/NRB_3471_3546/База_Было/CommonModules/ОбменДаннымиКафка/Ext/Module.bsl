	ДанныеДокумента.Вставить("DepoMxFactCode", СокрЛП(ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Источник.СчетДепоМХ, "Код")));
	ДанныеДокумента.Вставить("DepoDivisionCode", СокрЛП(ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Источник.РазделСчетаДепо, "Код")));
