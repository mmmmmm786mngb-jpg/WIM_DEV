#Область ПрограммныйИнтерфейс

// Процедура-обработчик события "ПриЗаписи" документов для добавления в РС ЖурналИсходящихСообщенийKafka
//
// Параметры:
//  Источник - ДокументОбъект - источник события
// 
Процедура ЗаписатьОбъектВИсходящиеСообщенияКафкаПриЗаписиДокумента(Источник) Экспорт
	
	Если ВыполненыУсловияРегистрации(Источник) Тогда
		Если ТипЗнч(Источник) = Тип("ДокументОбъект.СводныйОтчетОСовершенныхОперациях") Тогда
			ДополнительныеПараметры = Новый Структура("СводныйОтчет", Источник);
			ДокументыОперации = ОбщегоНазначения.ВыгрузитьКолонку(Источник.Операции, "ДокументОперации", Истина, Истина);
			Для Каждого ДокументОперации Из ДокументыОперации Цикл
				ЭтоОперацияЦБ = ТипЗнч(ДокументОперации) = Тип("ДокументСсылка.ОперацииЦБ");
				Если (Не ЭтоОперацияЦБ) Или (ЭтоОперацияЦБ И ВыполненыУсловияРегистрации(ДокументОперации)) Тогда
					СформироватьЗаписьВЖурналИсходящихСообщенийКафка(ДокументОперации, ДополнительныеПараметры);
				КонецЕсли;
			КонецЦикла;
		Иначе
			СформироватьЗаписьВЖурналИсходящихСообщенийКафка(Источник);
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

// Возвращает структуру заполненного MessageInfo для нового сообщения
// Параметры:
//  УИД - Строка - Уникальный идентификатор источника сообщения в виде строки
// Возвращаемое значение:
//  MessageInfo - Структура - новая заполненная структура блока MessageInfo
Функция ДанныеMessageInfo(УИД = Неопределено) Экспорт
	
	Если УИД = Неопределено Тогда
		УИД = Строка(Новый УникальныйИдентификатор);
	КонецЕсли;
	
	MessageInfo = РаботаСJSON.СтруктураMessageInfo();
	MessageInfo.SystemSource = "Depo";
	MessageInfo.MessageId = УИД;
	MessageInfo.MasterMessageId = УИД;
	MessageInfo.DateTimeCreate = ЗаписатьДатуJSON(ТекущаяДатаСеанса(), ФорматДатыJSON.ISO);
	
	Возврат MessageInfo;
	
КонецФункции

// Возвращает подготовленный блок Data для сообщения об ошибке
// Возвращаемое значение:
//  Data - Структура - новая структура блока Data
Функция СообщениеОбОшибкеБлокData() Экспорт

	Data = Новый Структура;
	Data.Вставить("ErrorCode", "");
	Data.Вставить("SystemSource", "Depo");
	Data.Вставить("DateTimeCreate", ЗаписатьДатуJSON(ТекущаяДатаСеанса(), ФорматДатыJSON.ISO));
	Data.Вставить("ErrorDescription", "");
	Data.Вставить("ErrorCodeExternal", "");
	Data.Вставить("UserId", "");
	Data.Вставить("CrmClientId", "");
	
	Возврат Data;

КонецФункции

// Процедура, отмечающая запись в в РС ЖурналВходящихСообщенийKafka как ошибочную
//
// Параметры:
//  ИмяСобытия - Строка - имя события, в котором возникла ошибка
//  СлужебныеДанные - Структура - Структура MessageInfo
//  ТекстОшибки - Строка - текст ошибки
//
Процедура ОбработатьОшибкуДанныхИзJSON(ИмяСобытия, СлужебныеДанные, ТекстОшибки) Экспорт
	
	ОписаниеОшибки = "";
	Если СлужебныеДанные.Свойство("ОписаниеОшибки", ОписаниеОшибки) Тогда
		ОписаниеОшибки = ТекстОшибки + Символы.ПС + ОписаниеОшибки;
	Иначе
		ОписаниеОшибки = ТекстОшибки;
	КонецЕсли;
	ЗаписьЖурналаРегистрации(ИмяСобытия, УровеньЖурналаРегистрации.Ошибка, , , ОписаниеОшибки);
	
	ИдентификаторСообщения = СлужебныеДанные.MessageId;
	ДанныеОтвета = СообщениеОбОшибке(ИдентификаторСообщения, ТекстОшибки);
	ДанныеОтвета.Вставить("Ключ", СлужебныеДанные.MessageType);
	Кафка.ОтправитьОшибкуОбработки(ДанныеОтвета);

КонецПроцедуры

// Возвращает подготовленную структуру для сообщения об ошибке
// Параметры:
//  MessageId - Строка - Уникальный идентификатор сообщения в виде строки
//  ErrorDescription - Строка - Описание ошибки
// Возвращаемое значение:
//  Результат - Структура - новая структура сообщения об ошибке
Функция СообщениеОбОшибке(MessageId, ErrorDescription) Экспорт
	
	MessageInfo = ДанныеMessageInfo();
	MessageInfo.Вставить("ParentMessageId", MessageId);
	MessageInfo.Вставить("MasterMessageId", MessageId);
	
	Data = СообщениеОбОшибкеБлокData();
	Data.Вставить("ErrorDescription", ErrorDescription);
	
	Результат = Новый Структура("MessageInfo, Data", MessageInfo, Data);
	Возврат Результат;
	
КонецФункции

// Процедура добавления данных набора записей в РС ЖурналИсходящихСообщенийKafka
//
// Параметры:
//  ТекстJSON			 - Строка			 - сформированный текст JSON для записи в РС ЖурналИсходящихСообщенийKafka
//  ВнешнийИсточник		 - ПланыВидовХарактеристик.ВнешниеИсточники	- топик
//  Идентификатор 		 - Строка			 - идентификатор записи в РС ЖурналИсходящихСообщенийKafka
//  РегистраторСсылка	 - ДокументСсылка	 - ссылка на источник события
//
Процедура ЗаписатьДанныеНабораЗаписиВИсходящиеСообщенияКафка(ТекстJSON, ВнешнийИсточник, Идентификатор, РегистраторСсылка) Экспорт
	
	Если ЗначениеЗаполнено(ТекстJSON) Тогда
		Ключ = "AccrualDepoComission";
		Кафка.ПоместитьСообщениеВРегистрКОтправке(ВнешнийИсточник, Ключ, ТекстJSON, Идентификатор, РегистраторСсылка);
	КонецЕсли;
	
КонецПроцедуры

// Возвращает список сформированных текстов JSON для записи в РС ЖурналИсходящихСообщенийKafka
//
// Параметры:
//  ДанныеРегистратора	 - СтрокаТаблицыЗначений, Структура - содержит свойства:
//      * Номер - Строка - Номер документа
//      * Дата - Дата - Дата документа
//      * Документ - ДокументСсылка - Ссылка на документ, которым начислена комиссия
//  ДанныеПоУслугам		 - Массив - Строки таблицы значений с данными по услугам депозитария
// 
// Возвращаемое значение:
//  ТекстJSON - СписокЗначений - сформированный список строк (текстов) JSON
//
Функция УслугиДепозитарияТекстыJSON(ДанныеРегистратора, ДанныеПоУслугам) Экспорт
	
	ТекстыJSON = Новый СписокЗначений;
	
	Для Каждого ИнформацияПоУслуге Из ДанныеПоУслугам Цикл
		
		MessageInfo = ОбменДаннымиКафка.ДанныеMessageInfo();
		MessageId = MessageInfo.MessageId;
		MessageInfo.MessageType = "AccrualDepoComission";
		MessageInfo.JsonVersion = "1.0.02";
		MessageInfo.ActionType = "INS";
		
		ИдОперации = СтрШаблон("%1Ком%2Строка%3", ДанныеРегистратора.Номер, ИнформацияПоУслуге.КодКомиссии,
		ИнформацияПоУслуге.НомерСтрокиВРегистре);
		ТекстНДС = ?(ЗначениеЗаполнено(ИнформацияПоУслуге.НДСКомиссии), ", " + ИнформацияПоУслуге.НДСКомиссии, "");
		Comment = СтрШаблон("%1%2", "Депозитарная комиссия", ТекстНДС);
		Data = Новый Структура;
		Data.Вставить("ObjectVersion", 1);
		Data.Вставить("Date", ЗаписатьДатуJSON(ИнформацияПоУслуге.Период, ФорматДатыJSON.ISO));
		Data.Вставить("PDocNum", ДанныеРегистратора.Номер);
		Data.Вставить("PDocName", Строка(ТипЗнч(ДанныеРегистратора.Документ)));
		Data.Вставить("PDocDate", ЗаписатьДатуJSON(ДанныеРегистратора.Дата, ФорматДатыJSON.ISO));
		Data.Вставить("OperationId", ИдОперации);
		Data.Вставить("Comment", Comment);
		Data.Вставить("Value", ИнформацияПоУслуге.Сумма);
		Data.Вставить("Code", ИнформацияПоУслуге.КодКомиссии);
		Data.Вставить("Name", ИнформацияПоУслуге.НаименованиеКомиссии);
		Data.Вставить("CurrencyCode", ИнформацияПоУслуге.КодВалюты);
		Data.Вставить("ContractNumber", СокрЛП(ИнформацияПоУслуге.НаименованиеДоговора));
		Data.Вставить("CrmClientId", ИнформацияПоУслуге.CrmClientId);
		Data.Вставить("CalculationPeriod", Формат(ИнформацияПоУслуге.ПериодРасчета, "ДФ=dd.MM.yyyy"));
		
		ТекстJSON = РаботаСJSON.ТекстСообщенияJSON(MessageInfo, Data);
		ТекстыJSON.Добавить(ТекстJSON, MessageId);
		
	КонецЦикла;
	
	Возврат ТекстыJSON;
	
КонецФункции

// Возвращает список сформированных текстов JSON для записи в РС ЖурналИсходящихСообщенийKafka
//
// Параметры:
//  ДанныеРегистратора	 - СтрокаТаблицыЗначений, Структура - содержит свойства:
//      * Номер - Строка - Номер документа
//      * Дата - Дата - Дата документа
//      * Документ - ДокументСсылка - Ссылка на документ, которым начислена комиссия
//  ДанныеПоУслугам		 - Массив - Строки таблицы значений с данными по услугам депозитария
// 
// Возвращаемое значение:
//  ТекстJSON - СписокЗначений - сформированный список строк (текстов) JSON
//
Функция УслугиДепозитарияТолькоДепозитарноеОбслуживаниеТекстыJSON(ДанныеРегистратора, ДанныеПоУслугам) Экспорт
	
	ТекстыJSON = Новый СписокЗначений;
	
	Для Каждого ИнформацияПоУслуге Из ДанныеПоУслугам Цикл
		
		MessageInfo = ОбменДаннымиКафка.ДанныеMessageInfo();
		MessageId = MessageInfo.MessageId;
		MessageInfo.MessageType = "AccrualDepoComission";
		MessageInfo.JsonVersion = "1.0.02";
		MessageInfo.ActionType = "INS";
		
		ИдОперации = СтрШаблон("%1Ком%2Строка%3", ДанныеРегистратора.Номер, ИнформацияПоУслуге.КодКомиссии,
		ИнформацияПоУслуге.НомерСтрокиВРегистре);
		ТекстНДС = ?(ЗначениеЗаполнено(ИнформацияПоУслуге.НДСКомиссии), ", " + ИнформацияПоУслуге.НДСКомиссии, "");
		Comment = СтрШаблон("%1%2", "Депозитарная комиссия", ТекстНДС);
		Data = Новый Структура;
		Data.Вставить("OnlyDepoService", ИнформацияПоУслуге.КлиентОтсутствуетВBQ);
		Data.Вставить("ObjectVersion", 1);
		Data.Вставить("Date", ЗаписатьДатуJSON(ИнформацияПоУслуге.Период, ФорматДатыJSON.ISO));
		Data.Вставить("PDocNum", ДанныеРегистратора.Номер);
		Data.Вставить("PDocName", Строка(ТипЗнч(ДанныеРегистратора.Документ)));
		Data.Вставить("PDocDate", ЗаписатьДатуJSON(ДанныеРегистратора.Дата, ФорматДатыJSON.ISO));
		Data.Вставить("OperationId", ИдОперации);
		Data.Вставить("Comment", Comment);
		Data.Вставить("Value", ИнформацияПоУслуге.Сумма);
		Data.Вставить("Code", ИнформацияПоУслуге.КодКомиссии);
		Data.Вставить("Name", ИнформацияПоУслуге.НаименованиеКомиссии);
		Data.Вставить("CurrencyCode", ИнформацияПоУслуге.КодВалюты);
		Data.Вставить("ContractNumber", СокрЛП(ИнформацияПоУслуге.НаименованиеДоговора));
		Data.Вставить("CrmClientId", ?(ЗначениеЗаполнено(ИнформацияПоУслуге.CrmClientId), ИнформацияПоУслуге.CrmClientId, Неопределено));
		Data.Вставить("DirectDebitingOfMoney", ИнформацияПоУслуге.БезАкцептноеСписание);
		Data.Вставить("AccountNumber", ИнформацияПоУслуге.НомерСчетаСписанияКомиссии);
		Data.Вставить("CalculationPeriod", Формат(ИнформацияПоУслуге.ПериодРасчета, "ДФ=dd.MM.yyyy"));
		ТекстJSON = РаботаСJSON.ТекстСообщенияJSON(MessageInfo, Data);
		ТекстыJSON.Добавить(ТекстJSON, MessageId);
		
	КонецЦикла;
	
	Возврат ТекстыJSON;
	
КонецФункции

// Возвращает структуру MessageInfo заполненую для типового случая
// Параметры:
//  MessageType - Строка - Тип сообщения, например "EmailGen"
//  ActionType - Строка - Тип действия, например "INS" или "UPD"
//  JsonVersion - Строка - версия JSON, если Неопределено то "1.0.0"
//  УИДСообщения - Строка - Уникальный идентификатор источника сообщения в виде строки
// Возвращаемое значение:
//  MessageInfo - Структура - полностью заполненная для типового случая структура блока MessageInfo
Функция ТиповыеДанныеMessageInfo(MessageType, ActionType, JsonVersion = "1.0.0", УИДСообщения = Неопределено) Экспорт
	MessageInfo = ДанныеMessageInfo(УИДСообщения);
	
	MessageInfo.JsonVersion = JsonVersion;
	MessageInfo.ActionType = ActionType;
	MessageInfo.MessageType = MessageType;
	
	Возврат MessageInfo;
КонецФункции

// Отправляет почтовое сообщение через Kafka
// Параметры:
//  EmailПолучателя - Строка
//  MailTemplateTitle - Строка - Title шаблона почтового сообщения
//  ReplaceFields - Структура - Заменяемые поля в шаблоне - имена заменяемых полей и их значения, например "ЗаголовокСообщения".
//  							Состав заменяемых полей зависит от шаблона, причем отправка, не всех ключей или лишних ключей
//								ведет к ошибкам согласно документации на модель сущности EmailGen. Может быть Неопределено, тогда
//								ReplaceFields в JSON добавлено не будет.
//  Вложения - Массив - Массив структур со следующими полями: 
//  							fileName (Строка - имя файла без пути и расширения),
//  							fileExt (Строка - расширение файла)
//  							fileBody (Данные файла - Base64Строка)
//  ОтправляемыйОбъект - Ссылка - ссылка на объект ИБ, с которым связано сообщение, может быть Неопредлено
Процедура ОтправитьПочтовоеУведомление(EmailПолучателя, MailTemplateTitle, ReplaceFields = Неопределено, Вложения = Неопределено,
										ОтправляемыйОбъект = Неопределено) Экспорт
	Data = Новый Структура();
	Data.Вставить("Email", EmailПолучателя);
	Data.Вставить("MailTemplateId", Неопределено);
	Data.Вставить("MailTemplateTitle", MailTemplateTitle);
	Если ReplaceFields <> Неопределено Тогда
		Data.Вставить("ReplaceFields", ReplaceFields);
	КонецЕсли;
	Если Вложения <> Неопределено Тогда
		Data.Вставить("Attachments", Вложения);
	КонецЕсли;
	
	MessageInfo = ТиповыеДанныеMessageInfo("EmailGen", "INS");
	ТекстJSON = РаботаСJSON.ТекстСообщенияJSON(MessageInfo, Data);
	
	ВнешнийИсточник = ПланыВидовХарактеристик.ВнешниеИсточники.KafkaEmailGen;	// Текущее наименование в ИБ Multi.Email.EmailGeneratorIn
	Кафка.ПоместитьСообщениеВРегистрКОтправке(ВнешнийИсточник, "EmailGen", ТекстJSON, , ОтправляемыйОбъект);
КонецПроцедуры

#КонецОбласти

#Область МетодыПроверкиВыполненияУсловийРегистрацииОбъектов

Функция ВыполненыУсловияРегистрацииОперацияПеревод(Источник)
	
	ТипРазделаСчетаДЕПО				 = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Источник.РазделСчетаДепо			, "ТипРазделаСчетаДЕПО");
	ТипРазделаСчетаДЕПОПолучатель	 = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Источник.РазделСчетаДепоПолучатель	, "ТипРазделаСчетаДЕПО");
	
	ЭтоПереводМеждуРазделамиСчетаДепоНаБлокировочныйРаздел =
		Источник.ВидОперацииД = Справочники.ВидыОпераций.ПереводМеждуРазделамиСчетаДепо
			И (ТипРазделаСчетаДЕПО = Перечисления.ТипыРазделовСчетовДЕПО.БлокированоРасчеты
				Или ТипРазделаСчетаДЕПОПолучатель = Перечисления.ТипыРазделовСчетовДЕПО.БлокированоРасчеты);
				
	Если Источник.Депонент = Источник.Получатель Тогда
		ЭтоСменаМХ = (Источник.СчетДЕПОМХ <> Источник.СчетДепоМХПолучатель) ИЛИ (Источник.РазделСчетаДЕПОМХ <> Источник.РазделСчетаДепоМХПолучатель);
	Иначе
		ЭтоСменаМХ = Истина;
	КонецЕсли;
				
	Возврат Не ЭтоПереводМеждуРазделамиСчетаДепоНаБлокировочныйРаздел И Источник.Проведен И ЭтоСменаМХ
			И Источник.Дата >= ОбщегоНазначенияПовтИсп.ЗначениеКонстанты("ДатаНачалаОбменаНеторговымиОперациями");
	
КонецФункции

Функция ВыполненыУсловияРегистрацииОперацииСписаниеЗачисление(Источник)
	
	Возврат (Источник.ВидОперацииД = Справочники.ВидыОпераций.Депонирование
		Или Источник.ВидОперацииД = Справочники.ВидыОпераций.СнятиеСДепонирования)
		И (Источник.Проведен Или БылаВыгрузкаВКафка(Источник.Ссылка))
		И Не Источник.ИсключитьИзОбменаДанными;
		
КонецФункции

Функция ВыполненыУсловияРегистрации(Источник)
	
	ТипИсточника = ТипЗнч(Источник);
	
	Если ТипИсточника = Тип("ДокументОбъект.Поручение") Или ТипИсточника = Тип("ДокументСсылка.Поручение") Тогда
		
		ВыполненыУсловия = ВыполненыУсловияРегистрацииПоручения(Источник);
		
	ИначеЕсли ТипИсточника = Тип("ДокументОбъект.ОперацииЦБ") Или ТипИсточника = Тип("ДокументСсылка.ОперацииЦБ") Тогда
		
		Если Справочники.ВидыОпераций.ЭтоПереводЦБ(Источник.ВидОперацииД) Тогда
			ВыполненыУсловия = ВыполненыУсловияРегистрацииОперацияПеревод(Источник);
		Иначе
			ВыполненыУсловия = ВыполненыУсловияРегистрацииОперацииСписаниеЗачисление(Источник);
		КонецЕсли;
		
	ИначеЕсли ТипИсточника = Тип("ДокументОбъект.СводныйОтчетОСовершенныхОперациях")
		Или ТипИсточника = Тип("ДокументСсылка.СводныйОтчетОСовершенныхОперациях") Тогда
		
		ВыполненыУсловия = ВыполненыУсловияРегистрацииСводныйОтчетОСовершенныхОперациях(Источник);
		
	Иначе
		
		ВыполненыУсловия = Ложь;
		
	КонецЕсли;
	
	Возврат ВыполненыУсловия;
	
КонецФункции
	
Функция ВыполненыУсловияРегистрацииПоручения(Источник)
	
	ВыполненыУсловия = Ложь;
	
	ЭтоВыкупСписаниеИлиПогашениеЦБ = (Источник.ВидОперацииД = Справочники.ВидыОпераций.ВыкупСписаниеЦБ
	Или Источник.ВидОперацииД = Справочники.ВидыОпераций.Погашение);
	
	СтатусПодходит = Истина;
	
	Если ЭтоВыкупСписаниеИлиПогашениеЦБ Тогда
		Статус = РегистрыСведений.СтатусыПоручений.СтатусПоручения(Источник.Ссылка);
		СтатусПодходит = (Статус = Перечисления.СтатусыПоручений.Исполнено);
	КонецЕсли;
	
	ВыполненыУсловия = ЗначениеЗаполнено(Источник.ДатаИсполненияПоручения)
		И (Источник.ВидОперацииД = Справочники.ВидыОпераций.Конвертация Или ЭтоВыкупСписаниеИлиПогашениеЦБ)
		И (СтатусПодходит Или БылаВыгрузкаВКафка(Источник.Ссылка));
	
	Возврат ВыполненыУсловия;

КонецФункции

Функция ВыполненыУсловияРегистрацииСводныйОтчетОСовершенныхОперациях(Источник)
	
	УсловияВыполнены = Ложь;
	
	ДопустимыеВидыОпераций = Новый Массив;
	ДопустимыеВидыОпераций.Добавить(Справочники.ВидыОпераций.Депонирование);
	ДопустимыеВидыОпераций.Добавить(Справочники.ВидыОпераций.СнятиеСДепонирования);
	ДопустимыеВидыОпераций.Добавить(Справочники.ВидыОпераций.ВыкупСписаниеЦБ);
	ДопустимыеВидыОпераций.Добавить(Справочники.ВидыОпераций.Погашение);
	ДопустимыеВидыОпераций.Добавить(Справочники.ВидыОпераций.Перевод);
	ДопустимыеВидыОпераций.Добавить(Справочники.ВидыОпераций.ПереводМеждуРазделамиСчетаДепо);
	ДопустимыеВидыОпераций.Добавить(Справочники.ВидыОпераций.Перемещение);
	
	Для Каждого Операция Из Источник.Операции Цикл
		Если ДопустимыеВидыОпераций.Найти(Операция.ТипОперации) <> Неопределено Тогда
			УсловияВыполнены = Истина;
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	Возврат УсловияВыполнены;

КонецФункции
	
#КонецОбласти

#Область ФормированиеТекстаСообщенияДляЖурналИсходящихСообщенийКафка

Функция ОперацияЦБТекстJSON(Источник, ДополнительныеПараметры)
	
	ТекстJSON = "";
	Transactions = Новый Массив;
	
	MessageInfo = MessageInfoWithActionType(Источник, ДополнительныеПараметры);
	Если MessageInfo.ActionType <> "INS" Тогда
		MessageInfo.MessageId = Строка(Новый УникальныйИдентификатор);
	КонецЕсли;
	
	ВалютаРеглУчета = Константы.ВалютаРегламентированногоУчета.Получить().Код;
	ВидОперации = ДополнительныеПараметры.ВидОперации;
	Если ВидОперации = Справочники.ВидыОпераций.Депонирование Или ВидОперации = Справочники.ВидыОпераций.СнятиеСДепонирования Тогда
		MessageInfo.MessageType = "TransactionSec";
		MessageInfo.JsonVersion = "1.1.0";
	ИначеЕсли ВидОперации = Справочники.ВидыОпераций.ВыкупСписаниеЦБ Или ВидОперации = Справочники.ВидыОпераций.Погашение Тогда
		MessageInfo.MessageType = "Redemption";
		MessageInfo.JsonVersion = "1.0.1";
	ИначеЕсли Справочники.ВидыОпераций.ЭтоПереводЦБ(ВидОперации) Тогда
		MessageInfo.MessageType = "TransactionTransf";
		MessageInfo.JsonVersion = "1.0.1";
	ИначеЕсли ВидОперации = Справочники.ВидыОпераций.Конвертация Тогда
		Отказ = Ложь;
		ДобавитьДанныеОперацииКонвертацияЦБ(MessageInfo, Transactions, ВалютаРеглУчета, Источник, Отказ);
		Если Отказ Тогда
			Возврат ТекстJSON;
		КонецЕсли;
	Иначе
		Возврат ТекстJSON;
	КонецЕсли;
	
	Data = ДанныеДокумента(Источник, ДополнительныеПараметры);
	
	Если Transactions.Количество() Тогда
		Data.Вставить("Transactions", Transactions);
	КонецЕсли;
	
	Если MessageInfo.MessageType = "TransactionSec" 
			И ТипЗнч(Источник) = Тип("ДокументОбъект.ОперацииЦБ")
			И ТипЗнч(Источник.ДокументОснование) = Тип("ДокументСсылка.Поручение") Тогда
		Data.Вставить("NoLimit", Источник.ДокументОснование.ИсточникЗагрузки = Перечисления.ИсточникиЗагрузки.QUIK);
	КонецЕсли;
	
	ТекстJSON = РаботаСJSON.ТекстСообщенияJSON(MessageInfo, Data);
	
	Возврат ТекстJSON;
	
КонецФункции

Процедура ДобавитьДанныеОперацииКонвертацияЦБ(MessageInfo, Transactions, ВалютаРеглУчета, Источник, Отказ)
	
	Перем Transaction, СтрокаТЧ;
	
	MessageInfo.MessageType = "TransactionConv";
	MessageInfo.JsonVersion = "1.0.03";
	
	Если Не Источник.Списание.Количество() Тогда
		Отказ = Истина;
	КонецЕсли;
	
	Если Источник.Зачисление.Количество() Тогда
		Отказ = Истина;
	КонецЕсли;
	
	ВидОперацииИсточника = ВидОперацииДокумента(Неопределено, Источник);
	Для Каждого СтрокаТЧ Из Источник.Списание Цикл
		Transaction = ДанныеTransaction(ВалютаРеглУчета, ВидОперацииИсточника, СтрокаТЧ, "CT_SEC_OUT");
		Transactions.Добавить(Transaction);
	КонецЦикла;
	
	Для Каждого СтрокаТЧ Из Источник.Зачисление Цикл
		Transaction = ДанныеTransaction(ВалютаРеглУчета, ВидОперацииИсточника, СтрокаТЧ, "CT_SEC_IN");
		Transactions.Добавить(Transaction);
	КонецЦикла;

КонецПроцедуры

Функция ДанныеДокумента(Источник, ДополнительныеПараметры)
	
	ДанныеДокумента = Новый Структура;
	
	Если Справочники.ВидыОпераций.ЭтоПереводЦБ(ДополнительныеПараметры.ВидОперации) Тогда
		ЗаполнитьДанныеОперацииЦБПеревод(ДанныеДокумента, Источник, ДополнительныеПараметры);
	ИначеЕсли ДополнительныеПараметры.ВидОперации = Справочники.ВидыОпераций.ВыкупСписаниеЦБ
		Или ДополнительныеПараметры.ВидОперации = Справочники.ВидыОпераций.Погашение Тогда
		ЗаполнитьДанныеПорученияВыкупСписаниеПогашение(ДанныеДокумента, Источник, ДополнительныеПараметры);
	ИначеЕсли ДополнительныеПараметры.ВидОперации = Справочники.ВидыОпераций.Депонирование
		Или ДополнительныеПараметры.ВидОперации = Справочники.ВидыОпераций.СнятиеСДепонирования Тогда
		ЗаполнитьДанныеОперацииЦБЗачислениеСписание(ДанныеДокумента, Источник, ДополнительныеПараметры);
	ИначеЕсли ДополнительныеПараметры.ВидОперации = Справочники.ВидыОпераций.Конвертация Тогда
		ЗаполнитьДанныеОперацииЦБКонвертация(ДанныеДокумента, Источник);
	КонецЕсли;
	
	Возврат ДанныеДокумента;
	
КонецФункции

Функция ДанныеTransaction(ВалютаРеглУчета, ВидОперации, ДанныеТранзакции, TransactionType)
	
	Transaction = Новый Структура;
	
	Asset = ДанныеЦБ(?(ВидОперации = Справочники.ВидыОпераций.Конвертация, ДанныеТранзакции.ЦеннаяБумага, ДанныеТранзакции.ЦБ));
	
	Transaction.Вставить("Asset", Asset);
	Transaction.Вставить("Count", ДанныеТранзакции.Количество);
	Transaction.Вставить("TransactionType", TransactionType);
	Если Справочники.ВидыОпераций.ЭтоПереводЦБ(ВидОперации) Тогда
		ФизЛицоПолучателя = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДанныеТранзакции.Получатель, "ФизЛицо");
		Transaction.Вставить("CrmClientId", Обработки.РегистрацияКлиентаЧерезKafka.CrmClientId(ФизЛицоПолучателя));
		Transaction.Вставить("getDepoMxDivisionCode",
		ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДанныеТранзакции.РазделСчетаДепоМХПолучатель, "Код"));
		Transaction.Вставить("getDivisionCode",
		ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДанныеТранзакции.РазделСчетаДепоПолучатель, "Код"));
	ИначеЕсли ВидОперации = Справочники.ВидыОпераций.Конвертация Тогда
		СчетДепо = СчетДепоВТабличнойЧастиДокумента(ДанныеТранзакции);
		Transaction.Вставить("DepoAccountCode",
		ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СчетДепо, "Код"));
		Transaction.Вставить("DepoMxDivisionCode",
		ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДанныеТранзакции.РазделСчетаДепоМХ, "Код"));
	КонецЕсли;
	
	Возврат Transaction;
	
КонецФункции

Функция ДанныеЦБ(ЦеннаяБумага)
	
	Asset = Новый Структура("Isin, NrdCode, RegNum");
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	СправочникЦенныеБумаги.Ссылка КАК Ссылка,
		|	СправочникЦенныеБумаги.ISIN КАК ISIN,
		|	СправочникЦенныеБумаги.НомерРегистрации КАК НомерРегистрации
		|ПОМЕСТИТЬ ВТ_ЦБ
		|ИЗ
		|	Справочник.ЦенныеБумаги КАК СправочникЦенныеБумаги
		|ГДЕ
		|	СправочникЦенныеБумаги.Ссылка = &Ссылка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ ПЕРВЫЕ 1
		|	ЕСТЬNULL(КодыЗагрузки.Код, """") КАК NrdCode,
		|	ВТ_ЦБ.ISIN КАК Isin,
		|	ВТ_ЦБ.НомерРегистрации КАК RegNum
		|ИЗ
		|	ВТ_ЦБ КАК ВТ_ЦБ
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.КодыЗагрузки КАК КодыЗагрузки
		|		ПО ВТ_ЦБ.Ссылка = КодыЗагрузки.Владелец
		|			И (ВЫБОР
		|				КОГДА КодыЗагрузки.ДатаОкончанияДействия = ДАТАВРЕМЯ(1, 1, 1)
		|					ТОГДА ИСТИНА
		|				ИНАЧЕ КодыЗагрузки.ДатаОкончанияДействия > &ТекущаяДата
		|			КОНЕЦ)
		|			И (КодыЗагрузки.Биржа = &КлассификаторНДЦ)";
	
	Запрос.УстановитьПараметр("КлассификаторНДЦ", Справочники.КлассификаторыЗагрузки.NrdCode);
	Запрос.УстановитьПараметр("Ссылка", ЦеннаяБумага);
	Запрос.УстановитьПараметр("ТекущаяДата", ТекущаяДатаСеанса());
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда
		Asset.Isin = СокрЛП(ВыборкаДетальныеЗаписи.Isin);
		Asset.NrdCode = СокрЛП(ВыборкаДетальныеЗаписи.NrdCode);
		Asset.RegNum = СокрЛП(ВыборкаДетальныеЗаписи.RegNum);
	КонецЕсли;
	
	Возврат Asset;
	
КонецФункции

Функция ДанныеПоСделкамОперации(ОперацияЦБ)
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ЕСТЬNULL(ВЫБОР
	|			КОГДА Поручение.ТипПеревода = &ТипПереводаСписание
	|				ТОГДА Поручение.НомерПорученияВБО
	|			КОГДА ПоручениеВстречное.ТипПеревода = &ТипПереводаСписание
	|				ТОГДА ПоручениеВстречное.НомерПорученияВБО
	|		КОНЕЦ, НЕОПРЕДЕЛЕНО) КАК НомерПорученияВБО1,
	|	ЕСТЬNULL(ВЫБОР
	|			КОГДА Поручение.ТипПеревода = &ТипПереводаЗачисление
	|				ТОГДА Поручение.НомерПорученияВБО
	|			КОГДА ПоручениеВстречное.ТипПеревода = &ТипПереводаЗачисление
	|				ТОГДА ПоручениеВстречное.НомерПорученияВБО
	|		КОНЕЦ, НЕОПРЕДЕЛЕНО) КАК НомерПорученияВБО2
	|ИЗ
	|	Документ.ОперацииЦБ КАК ОперацииЦБ
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.Поручение КАК Поручение
	|		ПО ОперацииЦБ.ДокументОснование = Поручение.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.Поручение КАК ПоручениеВстречное
	|		ПО ОперацииЦБ.ДокументОснованиеВстречный = ПоручениеВстречное.Ссылка
	|ГДЕ
	|	ОперацииЦБ.Ссылка = &ОперацияЦБ";
	
	Запрос.УстановитьПараметр("ОперацияЦБ", ОперацияЦБ);
	Запрос.УстановитьПараметр("ТипПереводаЗачисление", Перечисления.ТипыПереводов.Зачисление);
	Запрос.УстановитьПараметр("ТипПереводаСписание", Перечисления.ТипыПереводов.Списание);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Выборка.Следующий();
	
	Trades = Новый Структура;
	Trades.Вставить("ExternalId", Выборка.НомерПорученияВБО1);
	Trades.Вставить("GetExternalId", Выборка.НомерПорученияВБО2);
	
	Возврат Trades;
	
КонецФункции

Процедура СформироватьЗаписьВЖурналИсходящихСообщенийКафка(Источник, ДополнительныеПараметры = Неопределено)
	
	Если ЭтоОперацияЦБСводногоПоручения(Источник) Тогда
		Возврат;
	КонецЕсли;
	
	Если ДополнительныеПараметры = Неопределено Тогда
		ДополнительныеПараметры = Новый Структура;
	КонецЕсли;
	
	ТипИсточника = ТипЗнч(Источник);
	
	ДанныеПоручения = Неопределено;
	Если ТипИсточника = Тип("ДокументСсылка.ГлобальнаяОперация") Тогда
		ДокументОснование = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Источник, "ДокументОснование");
		Если ЗначениеЗаполнено(ДокументОснование) И ТипЗнч(ДокументОснование) = Тип("ДокументСсылка.Поручение") Тогда
			ДанныеПоручения = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ДокументОснование,
				"ВидОперацииД, Номер, Дата, ДатаИсполненияПоручения, ЦенныеБумагиСписываемые, Комментарий");
			ДанныеПоручения.Вставить("Поручение", ДокументОснование);
			ДополнительныеПараметры.Вставить("ДанныеПоручения", ДанныеПоручения);
		КонецЕсли;
	КонецЕсли;
	
	ВидОперации = ВидОперацииДокумента(ДанныеПоручения, Источник);
	
	Если Не ЗначениеЗаполнено(ВидОперации) Тогда
		Возврат;
	КонецЕсли;
	
	ДополнительныеПараметры.Вставить("ВидОперации", ВидОперации);
	
	Если ВидОперации = Справочники.ВидыОпераций.ВыкупСписаниеЦБ Или ВидОперации = Справочники.ВидыОпераций.Погашение Тогда
		ЗаписатьВОчередьКафкаПогашениеВыкупСписаниеЦБ(Источник, ДополнительныеПараметры, ТипИсточника, ДанныеПоручения);
	Иначе
		ПодготовитьТекстСообщенияИЗаписатьВОчередьКафка(Источник, ДополнительныеПараметры, Источник.Ссылка);
	КонецЕсли;
	
КонецПроцедуры

Функция БылаВыгрузкаВКафка(ДокументСсылка, ДополнительныеПараметры = Неопределено)
	
	DepoId = Неопределено;
	Если ТипЗнч(ДополнительныеПараметры) = Тип("Структура") И ДополнительныеПараметры.Свойство("СтрокаТЧ") Тогда
		DepoId = ДополнительныеПараметры.СтрокаТЧ.DepoId;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ВыгруженныеОперацииСЦБ.Объект КАК Объект
	|ИЗ
	|	РегистрСведений.ВыгруженныеОперацииСЦБ КАК ВыгруженныеОперацииСЦБ
	|ГДЕ
	|	ВыгруженныеОперацииСЦБ.Объект = &Документ
	|	И &УсловиеПоИдентификатору";
	
	Запрос.УстановитьПараметр("Документ", ДокументСсылка);
	
	Если ЗначениеЗаполнено(DepoId) Тогда
		УсловиеПоИдентификатору = "ВыгруженныеОперацииСЦБ.DepoId = &DepoId";
		Запрос.УстановитьПараметр("DepoId", DepoId);
	Иначе
		УсловиеПоИдентификатору = "Истина";
	КонецЕсли;
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеПоИдентификатору", УсловиеПоИдентификатору);
	
	РезультатЗапроса = Запрос.Выполнить();
	БылаВыгрузкаВКафка = ?(Не РезультатЗапроса.Пустой(), Истина, Ложь);
	Возврат БылаВыгрузкаВКафка;

КонецФункции

