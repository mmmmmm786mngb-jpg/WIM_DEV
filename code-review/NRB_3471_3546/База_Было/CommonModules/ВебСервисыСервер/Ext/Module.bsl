Процедура ОбновитьДоговорВСУДК(ДанныеДоговора) Экспорт
	
	// Получаем старые номер и тип договора
	СтарыйКод = "";
	СтарыйТипДоговора = Перечисления.ТипыДоговоров.ПустаяСсылка();
	Если ДанныеДоговора.ЭтоНовый Тогда
		СтарыйКод = ДанныеДоговора.Код;
		СтарыйТипДоговора = ДанныеДоговора.ТипДоговора;
	Иначе
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	ДоговорыКонтрагентов.Код,
		|	ДоговорыКонтрагентов.ТипДоговора,
		|	ДоговорыКонтрагентов.ПометкаУдаления
		|ИЗ
		|	Справочник.ДоговорыКонтрагентов КАК ДоговорыКонтрагентов
		|ГДЕ
		|	ДоговорыКонтрагентов.Ссылка = &Ссылка";
		Запрос.УстановитьПараметр("Ссылка", ДанныеДоговора.Ссылка);
		Выборка = Запрос.Выполнить().Выбрать();
		Если Выборка.Следующий() Тогда
			СтарыйКод = Выборка.Код;
			СтарыйТипДоговора = Выборка.ТипДоговора;
		КонецЕсли;
	КонецЕсли;
	
	ВнешнийИсточник = ПланыВидовХарактеристик.ВнешниеИсточники.ВебСервисКлиенты;
	ПараметрыВнешнегоИсточника = ВнешниеДанные.ПолучитьПараметрыВнешнегоИсточника(ВнешнийИсточник);
	Адрес = ПараметрыВнешнегоИсточника.Папка;
	ПространствоИмен = ПараметрыВнешнегоИсточника.База;
	Прокси = ВебСервисыПовтИсп.ПолучитьПроксиСУДК();
	
	// Изменение параметров договора в СУДК, а если новый договор - его добавленние.
	Если СтарыйТипДоговора = Перечисления.ТипыДоговоров.Депозитарный Тогда
		Если (СтарыйКод <> ДанныеДоговора.Код) 
			ИЛИ (СтарыйТипДоговора <> ДанныеДоговора.ТипДоговора) 
			ИЛИ ДанныеДоговора.ПометкаУдаления Тогда
			
			// Удаляем договор из СУДК
			Попытка
				ТипПараметра = Прокси.ФабрикаXDTO.Тип(ПространствоИмен, "ContractDelete");
				Параметры = Прокси.ФабрикаXDTO.Создать(ТипПараметра);
				Параметры.clientId = ПолучитьИдентификаторКлиентаПоСсылке(ДанныеДоговора.Владелец);
				Параметры.contractTypeId = "2";
				Параметры.number = СокрЛП(СтарыйКод);
				Прокси.ContractDelete(Параметры);
				ЗаписьЖурналаРегистрации("Удаление из СУДК", УровеньЖурналаРегистрации.Информация,,, "Депозитарный договор № " + СтарыйКод + " удален из СУДК!");
			Исключение
				#Если Клиент Тогда
					Сообщить("Договор не удалось удалить из СУДК!", СтатусСообщения.ОченьВажное);
				#КонецЕсли
				ЗаписьЖурналаРегистрации("Удаление из СУДК", УровеньЖурналаРегистрации.Ошибка,,, "Договор не удалось удалить из СУДК!");
			КонецПопытки;
		КонецЕсли;
	КонецЕсли;
	
	Если (ДанныеДоговора.ТипДоговора = Перечисления.ТипыДоговоров.Депозитарный) И НЕ ДанныеДоговора.ПометкаУдаления Тогда
		Попытка
			ТипПараметра = Прокси.ФабрикаXDTO.Тип(ПространствоИмен, "ContractUpdate");
			Параметры = Прокси.ФабрикаXDTO.Создать(ТипПараметра);
			Параметры.clientId = ПолучитьИдентификаторКлиентаПоСсылке(ДанныеДоговора.Владелец);
			Параметры.contractTypeId = "2";
			Параметры.number = СокрЛП(ДанныеДоговора.Код);
			Параметры.dateBegin	= ПолучитьЗначениеДатыДляВебСервиса(ДанныеДоговора.ДатаНачалоДействия);
			Параметры.dateEnd = ПолучитьЗначениеДатыДляВебСервиса(ДанныеДоговора.ДатаОкончанияДействия);
			Прокси.ContractUpdate(Параметры);
			ЗаписьЖурналаРегистрации("Запись изменений в СУДК", УровеньЖурналаРегистрации.Информация,,, "Изменения в депозитарном договоре сохранены в СУДК");
		Исключение
			#Если Клиент Тогда
				Сообщить("Изменения в договоре не удалось сохранить в СУДК!", СтатусСообщения.ОченьВажное);
			#КонецЕсли
			ЗаписьЖурналаРегистрации("Запись изменений в СУДК",УровеньЖурналаРегистрации.Ошибка,,, "Изменения в договоре не удалось сохранить в СУДК!");
		КонецПопытки;
	КонецЕсли;
	
КонецПроцедуры

Функция ПолучитьИдентификаторКлиентаПоСсылке(КлиентСсылка)
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	КодыЗагрузки.Код
	|ИЗ
	|	Справочник.КодыЗагрузки КАК КодыЗагрузки
	|ГДЕ
	|	КодыЗагрузки.Биржа = ЗНАЧЕНИЕ(Справочник.КлассификаторыЗагрузки.Клиенты)
	|	И КодыЗагрузки.Владелец = &КлиентСсылка
	|	И КодыЗагрузки.ПометкаУдаления = ЛОЖЬ");
	Запрос.УстановитьПараметр("КлиентСсылка", КлиентСсылка);
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() Тогда
		Возврат "";
	КонецЕсли;
	Выборка = РезультатЗапроса.Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат СокрЛП(Выборка.Код);
	КонецЕсли;
	
КонецФункции

Функция ПолучитьЗначениеДатыДляВебСервиса(Знач ПараметрДата)
	
	Если ЗначениеЗаполнено(ПараметрДата) Тогда
		Возврат Формат(ПараметрДата, "ДФ=yyyy-MM-dd-HH-mm-ss");
	Иначе
		Возврат Неопределено;
	КонецЕсли;
	
КонецФункции

