Функция СтруктураДляСозданияКоллекции(ИмяКоллекции, ИмяЭкземпляра, ВходящаяКоллекция,
	ИмяВходящейКоллекции = "") Экспорт
	
	СтруктураКВозврату = Новый Структура();
	СтруктураКВозврату.Вставить("ИмяКоллекции", ИмяКоллекции);
	СтруктураКВозврату.Вставить("ИмяЭкземпляра", ИмяЭкземпляра);
	СтруктураКВозврату.Вставить("ВходящаяКоллекция", ВходящаяКоллекция);
	СтруктураКВозврату.Вставить("ИмяВходящейКоллекции", ИмяВходящейКоллекции);
	Возврат СтруктураКВозврату;
КонецФункции

Функция СоздатьИЗаполнитьКоллекциюОбъектаXDTO(Фабрика, Источник, ПространствоИмен, СтруктураКоллекции) Экспорт	
	ТипКоллекции = Фабрика.Тип(ПространствоИмен, СтруктураКоллекции.ИмяКоллекции);
	Коллекция = Фабрика.Создать(ТипКоллекции);					  
	Если ТипЗнч(Источник) = Тип("ТаблицаЗначений") Тогда
		Для каждого СтрокаТЧ из Источник Цикл                                    
			ТипЭкземпляра = Фабрика.Тип(ПространствоИмен, СтруктураКоллекции.ИмяЭкземпляра);
			Экземпляр = Фабрика.Создать(ТипЭкземпляра); 
			ЗаполнитьЗначенияСвойств(Экземпляр, СтрокаТЧ);                                   
			Коллекция[СтруктураКоллекции.ИмяЭкземпляра].Добавить(Экземпляр);
			
			Если НЕ СтруктураКоллекции.ВходящаяКоллекция = Неопределено Тогда
				ВходящаяКоллекция = СоздатьИЗаполнитьКоллекциюОбъектаXDTO(Фабрика, СтрокаТЧ, ПространствоИмен, СтруктураКоллекции.ВходящаяКоллекция);
				Экземпляр.Установить(СтруктураКоллекции.ИмяВходящейКоллекции, ВходящаяКоллекция);
			КонецЕсли;
			
		КонецЦикла;
	ИначеЕсли ТипЗнч(Источник) = Тип("ВыборкаИзРезультатаЗапроса") Тогда 
		Пока Источник.Следующий() Цикл
			ТипЭкземпляра = Фабрика.Тип(ПространствоИмен, СтруктураКоллекции.ИмяЭкземпляра);
			Экземпляр = Фабрика.Создать(ТипЭкземпляра); 
			ЗаполнитьЗначенияСвойств(Экземпляр, Источник);                                   
			Если НЕ СтруктураКоллекции.ВходящаяКоллекция = Неопределено Тогда
				ВыборкаСледующегоУровня = Источник.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
				ВходящаяКоллекция = СоздатьИЗаполнитьКоллекциюОбъектаXDTO(Фабрика, ВыборкаСледующегоУровня, ПространствоИмен, СтруктураКоллекции.ВходящаяКоллекция);
				Экземпляр.Установить(СтруктураКоллекции.ИмяВходящейКоллекции, ВходящаяКоллекция);
			КонецЕсли;
			Коллекция[СтруктураКоллекции.ИмяЭкземпляра].Добавить(Экземпляр);						
		КонецЦикла;
	ИначеЕсли ТипЗнч(Источник) = Тип("СтрокаТаблицыЗначений") Тогда 
		ТипЭкземпляра = Фабрика.Тип(ПространствоИмен, СтруктураКоллекции.ИмяЭкземпляра);
		Экземпляр = Фабрика.Создать(ТипЭкземпляра);
		ЗаполнитьЗначенияСвойств(Экземпляр, Источник);
		Коллекция[СтруктураКоллекции.ИмяЭкземпляра].Добавить(Экземпляр);
	КонецЕсли;
	Возврат Коллекция;
КонецФункции

// Процедура выполняет загрузку новых заявлений на участие в оферте из кабинета клиента
// Параметры:
//	ОбработкаВебСервисы - ОбработкаОбъект - либо обработка ВебСервисы, либо обработка TEST_ВебСервисы
Процедура ЗагрузкаНовыхЗаявленийНаУчастиеВОфертеИзКабинетаКлиента(ОбработкаВебСервисы = Неопределено) Экспорт
	
	Если ОбработкаВебСервисы = Неопределено Тогда
		ИнициироватьСоединение(ОбработкаВебСервисы);
	КонецЕсли;
	
	ТаблицаЗаявлений = ОбработкаВебСервисы.НовыеЗаявленияНаУчастиеВОферте();
	ЗагруженныеЗаявления = НовыеЗаявленияПоДаннымСервиса(ТаблицаЗаявлений);
	Если ЗагруженныеЗаявления.Количество() > 0 Тогда
		ОбработкаВебСервисы.СообщитьСУДКЧтоЗаявленияНаУчастиеВОфертеЗагружены(ЗагруженныеЗаявления);
	КонецЕсли;
	
КонецПроцедуры

Функция НовыеЗаявленияПоДаннымСервиса(ТаблицаЗаявлений)
	ЗагруженныеЗаявления = Новый Массив;
	
	Для Каждого СтрокаТЗ Из ТаблицаЗаявлений Цикл
		Клиент = Справочники.Контрагенты.КлиентПоClientId(СтрокаТЗ.ClientId);
		Если Не ЗначениеЗаполнено(Клиент) Тогда
			ОписаниеОшибки = "Не удалось определить клиента по ClientID = " + СтрокаТЗ.ClientId;
			СообщитьОбОшибкеПриЗагрузкеЗаявкиНаУчастиеВОферте(СтрокаТЗ, ОписаниеОшибки);
			Продолжить;
		КонецЕсли;
		ДоговорКлиента = Справочники.ДоговорыКонтрагентов.ДоговорПоКлиенту(Клиент);
		Если Не ЗначениеЗаполнено(ДоговорКлиента) Тогда
			ОписаниеОшибки = "Не удалось найти действующий договор по клиенту = " + Строка(Клиент) 
								+ " (ClientID = " + СтрокаТЗ.ClientId + ")";
			СообщитьОбОшибкеПриЗагрузкеЗаявкиНаУчастиеВОферте(СтрокаТЗ, ОписаниеОшибки);
			Продолжить;
		КонецЕсли;
		ЦеннаяБумага = Справочники.ЦенныеБумаги.ЦеннаяБумагаПоРегНомеруИISIN(СтрокаТЗ.ISIN, СтрокаТЗ.RegNumber);
		Если Не ЗначениеЗаполнено(ЦеннаяБумага) Тогда
			ОписаниеОшибки = "Не удалось найти ценную бумагу по ISIN = " + СтрокаТЗ.ISIN + " и регистрационному номеру = " + СтрокаТЗ.RegNumber;
			СообщитьОбОшибкеПриЗагрузкеЗаявкиНаУчастиеВОферте(СтрокаТЗ, ОписаниеОшибки);
			Продолжить;
		КонецЕсли;
		Если СуществуетЗаявлениеНаУчастиеВОферте(СтрокаТЗ.DocumentNumber, ЦеннаяБумага, 
													СтрокаТЗ.OfferDate, Клиент, СтрокаТЗ.StockBondsCount) Тогда
			Продолжить;
		КонецЕсли;
		
		ЗаявлениеОбъект = Документы.ЗаявлениеНаУчастиеВОферте.СоздатьДокумент();
		ЗаявлениеОбъект.ВходящийНомерСЭД = СтрокаТЗ.DocumentNumber;
		ЗаявлениеОбъект.ДатаОферты = СтрокаТЗ.OfferDate;
		ЗаявлениеОбъект.Клиент = Клиент;
		ЗаявлениеОбъект.ДоговорКлиента = ДоговорКлиента;
		ЗаявлениеОбъект.ЦеннаяБумага = ЦеннаяБумага;
		ЗаявлениеОбъект.КоличествоЦБ = СтрокаТЗ.StockBondsCount;
		ЗаявлениеОбъект.Дата = ТекущаяДатаСеанса();
		ЗаявлениеОбъект.ДатаСозданияВКабинетеКлиента = СтрокаТЗ.CreatedAt;
		Попытка
			ЗаявлениеОбъект.Записать();
			ЗагруженныеЗаявления.Добавить(СтрокаТЗ.DocumentId);
		Исключение
			ИнформацияОбОшибке = ИнформацияОбОшибке();
			ОписаниеОшибки = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке);
			СообщитьОбОшибкеПриЗагрузкеЗаявкиНаУчастиеВОферте(СтрокаТЗ, ОписаниеОшибки);
		КонецПопытки;
	КонецЦикла;
	
	Возврат ЗагруженныеЗаявления;
КонецФункции

Функция СуществуетЗаявлениеНаУчастиеВОферте(ВходящийНомерСЭД, ЦеннаяБумага, ДатаОферты, Клиент, КоличествоЦБ)
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	1 КАК Поле
	|ИЗ
	|	Документ.ЗаявлениеНаУчастиеВОферте КАК ЗаявлениеНаУчастиеВОферте
	|ГДЕ
	|	ЗаявлениеНаУчастиеВОферте.ВходящийНомерСЭД = &ВходящийНомерСЭД
	|	И ЗаявлениеНаУчастиеВОферте.Клиент = &Клиент
	|	И ЗаявлениеНаУчастиеВОферте.ЦеннаяБумага = &ЦеннаяБумага
	|	И ЗаявлениеНаУчастиеВОферте.КоличествоЦБ = &КоличествоЦБ
	|	И ЗаявлениеНаУчастиеВОферте.ДатаОферты = &ДатаОферты
	|	И Не ЗаявлениеНаУчастиеВОферте.ПометкаУдаления";
	Запрос.УстановитьПараметр("ВходящийНомерСЭД", ВходящийНомерСЭД);
	Запрос.УстановитьПараметр("ЦеннаяБумага", ЦеннаяБумага);
	Запрос.УстановитьПараметр("ДатаОферты", ДатаОферты);
	Запрос.УстановитьПараметр("Клиент", Клиент);
	Запрос.УстановитьПараметр("КоличествоЦБ", КоличествоЦБ);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Возврат Не РезультатЗапроса.Пустой();
КонецФункции

Процедура СообщитьОбОшибкеПриЗагрузкеЗаявкиНаУчастиеВОферте(РеквизитыЗаявки, ОписаниеОшибки)
	ИмяСобытияОшибки = "Не удалось загрузить заявление на участие в оферте из кабинета клиента";
	ОписаниеОшибкиДополненное = "При загрузке заявления с DocumentId = " + Формат(РеквизитыЗаявки.DocumentId, "ЧГ=")
								+ " произошла ошибка: " + ОписаниеОшибки;
	ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ОписаниеОшибки);
	ЗаписьЖурналаРегистрации(ИмяСобытияОшибки, УровеньЖурналаРегистрации.Ошибка, , , ОписаниеОшибкиДополненное);
КонецПроцедуры