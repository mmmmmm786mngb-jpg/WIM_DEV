// Регламентное задание "Формирование уведомлений клиентам"

Процедура ФормированиеУведомленийКлиентам() Экспорт
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	ДокументыДляФормированияУведомлений.Документ КАК Документ
	|ИЗ
	|	РегистрСведений.ДокументыДляФормированияУведомлений КАК ДокументыДляФормированияУведомлений");
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		Документы.КорпоративноеДействие_Новый.НовыйДокументУведомлениеКлиента(Выборка.Документ);
	КонецЦикла;
КонецПроцедуры

