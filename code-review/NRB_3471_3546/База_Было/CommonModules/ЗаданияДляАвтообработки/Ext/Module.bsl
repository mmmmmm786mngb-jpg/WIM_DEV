// Регламентная перенумерация документов в конце дня.
//
Процедура ПеренумерацияДокументов() Экспорт
	
	НачалоПериода = НачалоДня(ТекущаяДата());
	КонецПериода = КонецДня(ТекущаяДата());
	НумераторыОбъектов.ПеренумероватьДокументыЗаПериод(НачалоПериода, КонецПериода);
	
КонецПроцедуры // ПеренумерацияДокументов()

Функция ДатаЗагрузкиПоДатеЗапуска(ДатаЗапуска)
	
	ДвадцатыйЧас = 20;
	СекундВЧасе = 3600;
	Если ДатаЗапуска >= (НачалоДня(ДатаЗапуска) + ДвадцатыйЧас * СекундВЧасе) Тогда
		ДатаЗагрузки = ДатаЗапуска;
	Иначе
		ДатаЗагрузки = НачалоДня(ДатаЗапуска) - 1;
	КонецЕсли;
	
	Возврат ДатаЗагрузки;
	
КонецФункции

// Процедура - Загрузка котировок
//
// Параметры:
//  Действие - Строка - Название алгоритма загрузки
//
Процедура ЗагрузкаКотировок(Действие) Экспорт
	
	Если Действие = "ФайлММВБ" Тогда
		
		ДатаЗагрузки = ДатаЗагрузкиПоДатеЗапуска(ТекущаяДатаСеанса());
		Если Не ОбщегоНазначения.РабочийДень(ДатаЗагрузки) Тогда
			Возврат;
		КонецЕсли;
		
		Загрузчик = Обработки.ЗагрузкаКотировок.Создать();
		Загрузчик.ПериодЗагрузки = Новый СтандартныйПериод(ДатаЗагрузки, ДатаЗагрузки);
		
		ВнешнийИсточникХранилищеБиржевыхФайловММВБ = ПланыВидовХарактеристик.ВнешниеИсточники.ХранилищеБиржевыхФайловММВБ;
		КаталогДанных = ВнешниеДанные.ПолучитьПараметрыВнешнегоИсточника(ВнешнийИсточникХранилищеБиржевыхФайловММВБ).Папка;
		КаталогДанных = ОбщегоНазначенияКлиентСервер.ДобавитьКонечныйРазделительПути(КаталогДанных);
		Загрузчик.КаталогДанных = РаботаСФайлами.ПолучитьАбсолютныйПуть(КаталогДанных);
		
		Загрузчик.ВыполнитьЗагрузку(Действие, Загрузчик.ПериодЗагрузки);
		
	КонецЕсли;
	
КонецПроцедуры

// Процедура - Отправить сообщение о загрузке получателям
//
// Параметры:
//  Настройка		 - СправочникСсылка.НастройкиОбменаДанными	 - см. Функция АктуальнаяУчетнаяЗаписьПриемаОтправкиСообщений
//  ТемаСообщения	 - Строка									 - Тема сообщения
//  ТекстСообщения	 - Строка									 - Текст сообщения
//
Процедура ОтправитьСообщениеОЗагрузкеПолучателям(Настройка, ТемаСообщения, ТекстСообщения) Экспорт
	
	Если Не ЗначениеЗаполнено(Настройка) Тогда
		Возврат;
	КонецЕсли;
	
	АктуальнаяУчетнаяЗапись = Справочники.НастройкиОбменаДанными.АктуальнаяУчетнаяЗаписьПриемаОтправкиСообщений(Настройка);
	УправлениеЭлектроннойПочтой.ИнтернетПисьмо(АктуальнаяУчетнаяЗапись, ТемаСообщения, Настройка.АдресПолучателя, ТекстСообщения);
	
КонецПроцедуры

Процедура ЗагрузитьНеторговыеПоручения() Экспорт
	Загрузчик = Обработки.ЗагрузкаНеторговыхПоручений_Новая.Создать();
	Загрузчик.ПолучитьТаблицуПорученийЗаПериод(ТекущаяДата() - 57600, ТекущаяДата());
	Загрузчик.ПроверитьПоставщикаВПоручениях();
	Загрузчик.ЗагрузитьНеторговыеПоручения();
КонецПроцедуры

Процедура ЗагрузкаКД(Депозитарий = Неопределено, ДатаЗагрузки = Неопределено) Экспорт
	Если Депозитарий = Неопределено Тогда
		Депозитарий = ОбщегоНазначенияПовтИсп.ЗначениеКонстанты("МестоХраненияПоУмолчанию");
	КонецЕсли;
	Обработка = Обработки.ЗагрузкаКДИзДепозитария.Создать();
	Обработка.ВышестоящийДепозитарий = Депозитарий;
	Если ДатаЗагрузки = Неопределено Тогда
		ДатаЗагрузки = НачалоДня(ТекущаяДатаСеанса());
	КонецЕсли;
	ШестьСуток = 6;
	Обработка.ПериодНачало = ДатаЗагрузки - ОбщегоНазначенияПовтИсп.СекундВСутках(ШестьСуток);
	Обработка.ПериодКонец = ДатаЗагрузки;
	Обработка.ЗагрузитьДокументыКДИзФайлов();
КонецПроцедуры

Процедура ЗагрузкаРаскрытияСпискаВладельцев() Экспорт
	
	ИсточникЗагрузки = Константы.ВнешнийИсточникДляЗагрузкиРаскрытияСписков.Получить();
	
	ДатаНачала = НачалоДня(ТекущаяДата());
	ДатаОкончания = КонецДня(ТекущаяДата());
	
	Если ИсточникЗагрузки = ПланыВидовХарактеристик.ВнешниеИсточники.Луч Тогда
		РаскрытиеСпискаВладельцев.ЗагрузитьФайлыРаскрытияСписковИзЛуча(ДатаНачала, ДатаОкончания);     
	ИначеЕсли ИсточникЗагрузки = ПланыВидовХарактеристик.ВнешниеИсточники.ШлюзНРД Тогда 
		РаскрытиеСпискаВладельцев.ЗагрузитьФайлыРаскрытияСписковИзШлюза(ДатаНачала, ДатаОкончания);
	КонецЕсли;
	
КонецПроцедуры

Процедура ВыгрузкаДанныхОКлиентахДляWEB() Экспорт
	
	ПараметрыИсточника = ВнешниеДанные.ПолучитьПараметрыВнешнегоИсточника(ПланыВидовХарактеристик.ВнешниеИсточники.КаталогДанныхОКлиентахДляWEB);
	
	Если ПараметрыИсточника.Папка = "" Тогда 
		ЗаписьЖурналаРегистрации("РегламентноеЗадание.ВыгрузкаДанныхОКлиентахДляWEB"
									,УровеньЖурналаРегистрации.Ошибка
									,,,"Не указан путь к каталогу выгрузки! " + ОписаниеОшибки());
		Возврат;
	КонецЕсли;
	
	ОбработкаВыгрузки = Обработки.ВыгрузкаДанныхОКлиентахДляWEB.Создать();
	ОбработкаВыгрузки.ДатаЗапроса = ТекущаяДата();
	ОбработкаВыгрузки.КаталогВыгрузки = ПараметрыИсточника.Папка;
	ОбработкаВыгрузки.Сформировать(Истина); // режим выгрузки в файл
	
КонецПроцедуры

