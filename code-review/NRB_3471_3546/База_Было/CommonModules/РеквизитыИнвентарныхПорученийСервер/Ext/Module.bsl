Процедура ЗаполнитьРеквизитыПоручения(Ссылка, Форма) Экспорт
	Если НЕ ЗначениеЗаполнено(Ссылка.ВидПоручения) Тогда
		Возврат;
	КонецЕсли; 
	
	Если ТипЗнч(Ссылка) = Тип("ДокументСсылка.Поручение") Тогда
		Запрос = Новый Запрос;
		Запрос.УстановитьПараметр("Ссылка", Ссылка);
		Запрос.Текст = "ВЫБРАТЬ
		|	НеттоПоручениеПоручения.Поручение
		|ИЗ
		|	Документ.НеттоПоручение.Поручения КАК НеттоПоручениеПоручения
		|ГДЕ
		|	НеттоПоручениеПоручения.Поручение = &Ссылка
		|	И НЕ НеттоПоручениеПоручения.Ссылка.ПометкаУдаления";
		
		Результат = Запрос.Выполнить();
		Если НЕ Результат.Пустой() Тогда
			Возврат;
		КонецЕсли; 
	КонецЕсли; 
	
	МакетОтображения = Ссылка.ВидПоручения.НастройкиОтображения.Получить();
	Если МакетОтображения = Неопределено Тогда
		Возврат;
	КонецЕсли; 
	
	//СКД = Справочники.ВидыИнвентарныхПоручений.ПолучитьМакет("РеквизитыПоручения");
	СКД = Ссылка.ВидПоручения.СхемаКомпоновкиДанных.Получить();
	Если СКД = Неопределено Тогда
		СКД = Справочники.ВидыИнвентарныхПоручений.ПолучитьМакет("РеквизитыПоручения");
	КонецЕсли; 
	
	СоздатьЭлементыФормы(Форма, МакетОтображения, Ссылка.ВидПоручения);
	
	//ЗаполнитьЭлементыФормы(Ссылка, Форма, СКД, "Поручение");
	Для каждого НаборДанных Из СКД.НаборыДанных Цикл
		Если Найти(НаборДанных.Имя, "ТЧ_") > 0 Тогда
			ЗаполнитьТаблицуФормы(Ссылка, Форма, СКД, НаборДанных.Имя);
		Иначе
			ЗаполнитьЭлементыФормы(Ссылка, Форма, СКД, НаборДанных.Имя);
		КонецЕсли; 
	КонецЦикла; 
	
	ЗаполнитьСтатус_ФШ(Ссылка, Форма);
	
	//ЗаполнитьТаблицуФормы(Ссылка, Форма, СКД, "ДополнительнаяИнформация");
	//ЗаполнитьТаблицуФормы(Ссылка, Форма, СКД, "Документы");
	
	УдалитьНезаполненныеЭлементыФормы(Форма);
КонецПроцедуры

Процедура СоздатьЭлементыФормы(Форма, МакетОтображения, ВидПоручения)
	//МакетОтображения = Объект.ВидПоручения.НастройкиОтображения.Получить();
	
	НомераКолонок = Новый Соответствие;
	НомераКолонок.Вставить("Значение", 5);
	НомераКолонок.Вставить("Группа", 7);
	НомераКолонок.Вставить("Элемент", 6);
	НомераКолонок.Вставить("НомерГруппы", 9);
	НомераКолонок.Вставить("НомерЭлемента", 10);
	НомераКолонок.Вставить("Видимость", 8);
	НомераКолонок.Вставить("Обязательное", 11);
	НомераКолонок.Вставить("Таблица", 2);
	НомераКолонок.Вставить("ПолеБлока", 4);
	НомераКолонок.Вставить("КолонкаНаФорме", 13);
	
	УдаляемыеРеквизиты = Новый Массив;
	УдаляемыеЭлементы = Новый Массив;
	//Для каждого СтрокаРеквизит Из Форма.ТаблицаРеквизитов Цикл
	//	Если Форма.ПолучитьРеквизиты().Найти(СтрокаРеквизит.ИмяЭлемента) <> Неопределено Тогда
	//		УдаляемыеРеквизиты.Добавить(Форма[СтрокаРеквизит.ИмяЭлемента]);
	//	КонецЕсли; 
	//	
	//	//Если Форма.Элементы.Найти(СтрокаРеквизит.ИмяЭлемента) <> Неопределено Тогда
	//	//	УдаляемыеЭлементы.Добавить(СтрокаРеквизит.ИмяЭлемента);
	//	//КонецЕсли; 
	//	
	//КонецЦикла; 
	Для каждого РеквизитФормы Из Форма.ПолучитьРеквизиты() Цикл
		Если Найти(РеквизитФормы.Имя, "Реквизит_") > 0 ИЛИ Найти(РеквизитФормы.Имя, "Таблица_") > 0 Тогда
			УдаляемыеРеквизиты.Добавить(РеквизитФормы.Имя);
		КонецЕсли; 
	КонецЦикла; 
	Для каждого ЭлементФормы Из Форма.Элементы Цикл
		
		//Если Найти(ЭлементФормы.Имя, "ВспомГруппа_") > 0 Тогда
		Если Найти(ЭлементФормы.Имя, "Группа_") > 0 Тогда
			УдаляемыеЭлементы.Добавить(ЭлементФормы.Имя);
		КонецЕсли; 
	КонецЦикла; 
	Для каждого ЭлементУдалить Из УдаляемыеЭлементы Цикл
		Попытка
		
			Форма.Элементы.Удалить(Форма.Элементы[ЭлементУдалить]);
		
		Исключение
		
		КонецПопытки;
		
	КонецЦикла; 
	
	Форма.ИзменитьРеквизиты(, УдаляемыеРеквизиты);
	
	Форма.ТаблицаРеквизитов.Очистить();
	
	// Массив для новых реквизитов
	ДобавляемыеРеквизиты	= Новый Массив;
	
	ТаблицаОтображения = Новый ТаблицаЗначений;
	ТаблицаОтображения.Колонки.Добавить("ИмяГруппы");
	ТаблицаОтображения.Колонки.Добавить("ИмяЭлемента");
	ТаблицаОтображения.Колонки.Добавить("НомерГруппы");
	ТаблицаОтображения.Колонки.Добавить("НомерЭлемента");
	ТаблицаОтображения.Колонки.Добавить("ИмяРеквизита");
	ТаблицаОтображения.Колонки.Добавить("ИмяТаблицы");
	ТаблицаОтображения.Колонки.Добавить("ФорматнаяСтрока");
	ТаблицаОтображения.Колонки.Добавить("Видимость");
	ТаблицаОтображения.Колонки.Добавить("Обязательное");
	ТаблицаОтображения.Колонки.Добавить("ПолеБлока");
	ТаблицаОтображения.Колонки.Добавить("ЭтоТаблица");
	ТаблицаОтображения.Колонки.Добавить("КолонкаНаФорме");
	
	Для НомерСтроки = 2 По МакетОтображения.ВысотаТаблицы Цикл
		ИмяГруппы = МакетОтображения.Область("R" + НомерСтроки + "C" + НомераКолонок["Группа"]).Текст;
		ИмяЭлемента = МакетОтображения.Область("R" + НомерСтроки + "C" + НомераКолонок["Элемент"]).Текст;
		ПолеБлока = МакетОтображения.Область("R" + НомерСтроки + "C" + НомераКолонок["ПолеБлока"]).Текст;
		НомерГруппы = МакетОтображения.Область("R" + НомерСтроки + "C" + НомераКолонок["НомерГруппы"]).Текст;
		НомерЭлемента = МакетОтображения.Область("R" + НомерСтроки + "C" + НомераКолонок["НомерЭлемента"]).Текст;
		ИмяРеквизита = МакетОтображения.Область("R" + НомерСтроки + "C" + НомераКолонок["Значение"]).Текст;
		ФорматнаяСтрока = МакетОтображения.Область("R" + НомерСтроки + "C" + НомераКолонок["Значение"]).Формат;
		Видимость = МакетОтображения.Область("R" + НомерСтроки + "C" + НомераКолонок["Видимость"]).Текст;
		Обязательное = МакетОтображения.Область("R" + НомерСтроки + "C" + НомераКолонок["Обязательное"]).Текст;
		ИмяТаблицы = МакетОтображения.Область("R" + НомерСтроки + "C" + НомераКолонок["Таблица"]).Текст;
		ЭтоТаблица = ЗначениеЗаполнено(МакетОтображения.Область("R" + НомерСтроки + "C" + НомераКолонок["Таблица"]).Текст);
		КолонкаНаФорме = МакетОтображения.Область("R" + НомерСтроки + "C" + НомераКолонок["КолонкаНаФорме"]).Текст;
		
		Если ЭтоТаблица И Найти(ИмяГруппы, "(таблица)") = 0 Тогда
			ИмяГруппы = ИмяГруппы + " (таблица)";
		КонецЕсли;
		
		НовСтрока = ТаблицаОтображения.Добавить();
		НовСтрока.ИмяГруппы = ИмяГруппы;
		НовСтрока.ИмяЭлемента = ИмяЭлемента;
		НовСтрока.НомерГруппы = НомерГруппы;
		НовСтрока.НомерЭлемента = НомерЭлемента;
		НовСтрока.ИмяРеквизита = ИмяРеквизита;
		НовСтрока.ИмяТаблицы = ИмяТаблицы;
		НовСтрока.ФорматнаяСтрока = ФорматнаяСтрока;
		НовСтрока.Видимость = Видимость;
		НовСтрока.Обязательное = Обязательное;//ЗначениеЗаполнено(Обязательное) ИЛИ ВРЕГ(Обязательное) = "НЕТ";
		НовСтрока.ЭтоТаблица = ЭтоТаблица;
		НовСтрока.ПолеБлока = ПолеБлока;
		НовСтрока.КолонкаНаФорме = КолонкаНаФорме;
	КонецЦикла;		
	
	ТаблицаОтображения.Сортировать("НомерГруппы, НомерЭлемента"); 
	
	ИсправитьКолонкиНаФормеНаРазрешенныеЗначения(ТаблицаОтображения, ВидПоручения);
	ИсправитьКолонкиНаФормеНаОдноЗначениеВнутриГруппы(ТаблицаОтображения, ВидПоручения);
	КолонкиГруппы = КолонкиГруппНаФорме(ТаблицаОтображения);
	СоздатьКолонкиНаФорме(Форма, Форма.Элементы.СтраницаРеквизиты, ТаблицаОтображения);
	
	ДобавленныеГруппы = Новый Массив;
	ДобавленныеТаблицы = Новый Массив;
	
	Для каждого Строка Из ТаблицаОтображения Цикл
		
		Если ДобавленныеГруппы.Найти(Строка.ИмяГруппы) = Неопределено Тогда
			//ЧислоНомерГруппы = Число(Строка.НомерГруппы);
			//Если ЧислоНомерГруппы/2 = Цел(ЧислоНомерГруппы/2) Тогда
			//	ВспомГруппаФормы = Форма.Элементы.Добавить("ВспомГруппа_" + Цел(ЧислоНомерГруппы/2), Тип("ГруппаФормы"), Форма.Элементы.СтраницаРеквизиты);	
			//	ВспомГруппаФормы.Вид                        = ВидГруппыФормы.ОбычнаяГруппа;
			//	ВспомГруппаФормы.Отображение                = ОтображениеОбычнойГруппы.Нет;
			//	ВспомГруппаФормы.ОтображатьЗаголовок        = ЛОжь;
			//	ВспомГруппаФормы.Группировка                = ГруппировкаПодчиненныхЭлементовФормы.Горизонтальная;
			//Иначе
			//	ВспомГруппаФормы = Форма.Элементы["ВспомГруппа_" + Цел(ЧислоНомерГруппы/2)];
			//КонецЕсли; 
			
			//ГруппаФормы = Форма.Элементы.Добавить("Группа_" + Строка.НомерГруппы, Тип("ГруппаФормы"), ВспомГруппаФормы);
			
			ГруппаРодитель = Форма.Элементы["РеквизитыКолонка" + КолонкиГруппы[Строка.НомерГруппы]];
			ГруппаФормы = Форма.Элементы.Добавить("Группа_" + Строка.НомерГруппы, Тип("ГруппаФормы"), ГруппаРодитель);
			ГруппаФормы.Вид                        = ВидГруппыФормы.ОбычнаяГруппа;
			ГруппаФормы.Отображение                = ОтображениеОбычнойГруппы.СлабоеВыделение;
			ГруппаФормы.Заголовок                  = Строка.ИмяГруппы;
			ГруппаФормы.ОтображатьЗаголовок        = Истина;
			ГруппаФормы.Группировка                = ГруппировкаПодчиненныхЭлементовФормы.Вертикальная;
			
			ДобавленныеГруппы.Добавить(Строка.ИмяГруппы);
		Иначе
			ГруппаФормы = Форма.Элементы["Группа_" + Строка.НомерГруппы];
		КонецЕсли; 
		
		Если Не ПустаяСтрока(Строка.ИмяЭлемента) Тогда
			ЗаголовокРеквизита = Строка.ИмяЭлемента;
			ИмяРеквизита = Строка.ИмяРеквизита;
			
			Если Строка.ЭтоТаблица Тогда
				Если ДобавленныеТаблицы.Найти(Строка.ИмяГруппы) = Неопределено Тогда
					РеквизитТаблица = Новый РеквизитФормы("Таблица_" + Строка.НомерГруппы, Новый ОписаниеТипов("ТаблицаЗначений"), , Строка.ИмяГруппы);
					ДобавляемыеРеквизиты.Добавить(РеквизитТаблица);
					
					НоваяСтрока = Форма.ТаблицаРеквизитов.Добавить();
					НоваяСтрока.Имя 	        = "";
					НоваяСтрока.ИмяЭлемента     = "Таблица_" + Строка.НомерГруппы;
					НоваяСтрока.Заголовок       = Строка.ИмяГруппы;
					НоваяСтрока.ПутьКДанным     = "Таблица_" + Строка.НомерГруппы;
					НоваяСтрока.Родитель		= ГруппаФормы.Имя;
					НоваяСтрока.Видимость		= Строка.Видимость;
					
					ДобавленныеТаблицы.Добавить(Строка.ИмяГруппы);
					
				КонецЕсли; 	
				ПутьКРеквизиту = "Таблица_" + Строка.НомерГруппы;
				Родитель = "Таблица_" + Строка.НомерГруппы;
			Иначе
				ПутьКРеквизиту = "";
				Родитель = ГруппаФормы.Имя;
			КонецЕсли;  
			
			Реквизит = Новый РеквизитФормы("Реквизит_" + Строка.НомерГруппы + "_" + Строка.НомерЭлемента, Новый ОписаниеТипов("Строка"), ПутьКРеквизиту, ЗаголовокРеквизита);
			ДобавляемыеРеквизиты.Добавить(Реквизит);
			
			НоваяСтрока = Форма.ТаблицаРеквизитов.Добавить();
			НоваяСтрока.Имя 	        = ИмяРеквизита;
			НоваяСтрока.ИмяЭлемента     = "Реквизит_" + Строка.НомерГруппы + "_" + Строка.НомерЭлемента;
			НоваяСтрока.Заголовок       = ЗаголовокРеквизита + " (" + Строка.ПолеБлока + ")";
			НоваяСтрока.ПутьКДанным     = ?(ПутьКРеквизиту = "", "", ПутьКРеквизиту + ".") +"Реквизит_" + Строка.НомерГруппы + "_" + Строка.НомерЭлемента; // 
			НоваяСтрока.Родитель		= Родитель;
			НоваяСтрока.ФорматнаяСтрока = Строка.ФорматнаяСтрока;
			НоваяСтрока.Видимость		= Строка.Видимость;
			НоваяСтрока.Обязательный	= Строка.Обязательное;
			НоваяСтрока.ИмяТаблицы		= Строка.ИмяТаблицы;
		КонецЕсли; 
		
	КонецЦикла;	
	
	ГруппаФормыСтатус = Форма.Элементы.Добавить("Группа_СтатусПорученияФШ", Тип("ГруппаФормы"), Форма.Элементы.СтраницаОсновное);
	ГруппаФормыСтатус.Вид                        = ВидГруппыФормы.ОбычнаяГруппа;
	ГруппаФормыСтатус.Отображение                = ОтображениеОбычнойГруппы.СлабоеВыделение;
	ГруппаФормыСтатус.Заголовок                  = "Статус поручения в файловом шлюзе";
	ГруппаФормыСтатус.ОтображатьЗаголовок        = Истина;
	ГруппаФормыСтатус.Группировка                = ГруппировкаПодчиненныхЭлементовФормы.Горизонтальная;
	
	Строка20 = Новый ОписаниеТипов("Строка", , , , Новый КвалификаторыСтроки(20));
	Реквизит = Новый РеквизитФормы("Реквизит_РегистрационныйНомерФШ", Строка20, , "Регистрационный номер");
	ДобавляемыеРеквизиты.Добавить(Реквизит);
	Реквизит = Новый РеквизитФормы("Реквизит_СтатусПорученияФШ", Новый ОписаниеТипов("Строка"), , "Статус поручения");
	ДобавляемыеРеквизиты.Добавить(Реквизит);
	Реквизит = Новый РеквизитФормы("Реквизит_КомментарийФШ", Новый ОписаниеТипов("Строка"), , "Комментарий (файловый шлюз)");
	ДобавляемыеРеквизиты.Добавить(Реквизит);
	
	//Таблица статусов выгрузки в ФШ
	//РеквизитДинамическийСписок = Новый РеквизитФормы("Таблица_СтатусыФШ", Новый ОписаниеТипов("ДинамическийСписок"), , "Статус выгрузки");
	//ДобавляемыеРеквизиты.Добавить(РеквизитДинамическийСписок);
	
	Форма.ИзменитьРеквизиты(ДобавляемыеРеквизиты);
	
	Для каждого СтрокаРеквизит Из Форма.ТаблицаРеквизитов Цикл
		Если Найти(СтрокаРеквизит.ИмяЭлемента, "Таблица_") > 0 Тогда
			ЭлементФормы = Форма.Элементы.Добавить(СтрокаРеквизит.ИмяЭлемента, Тип("ТаблицаФормы"), Форма.Элементы[СтрокаРеквизит.Родитель]);
			ЭлементФормы.Заголовок = СтрокаРеквизит.Заголовок;
			ЭлементФормы.ПоложениеКоманднойПанели	= ПоложениеКоманднойПанелиЭлементаФормы.Нет;
			ЭлементФормы.ТолькоПросмотр				= Истина;
			ЭлементФормы.ПутьКДанным 			    = СтрокаРеквизит.ПутьКДанным;
		Иначе
