Процедура УдалитьНезаполненныеЭлементыФормы(Форма)
	
	УдаляемыеРеквизиты	= Новый Массив;
	
	МассивВидимыхРеквизитов = Форма.ТаблицаРеквизитов.НайтиСтроки(Новый Структура("Видимость, Обязательный", Истина, Ложь));
	Для каждого СтрокаРеквизит Из МассивВидимыхРеквизитов Цикл
		Если Найти(СтрокаРеквизит.ПутьКДанным, "Таблица") > 0 Тогда
			Если СтрокаРеквизит.ИмяЭлемента = СтрокаРеквизит.ПутьКданным Тогда
				Если Форма[СтрокаРеквизит.ИмяЭлемента].Количество() = 0 Тогда
					УдаляемыеРеквизиты.Добавить(СтрокаРеквизит.ИмяЭлемента);
				Иначе
					МассивКолонок = Форма.ТаблицаРеквизитов.НайтиСтроки(Новый Структура("Видимость, Родитель", Истина, СтрокаРеквизит.ИмяЭлемента));
					Для каждого Колонка Из МассивКолонок Цикл
						КолонкаЗаполнена = Ложь;
						Для каждого Строка Из Форма[СтрокаРеквизит.ИмяЭлемента] Цикл
							Если ЗначениеЗаполнено(Строка[Колонка.ИмяЭлемента]) Тогда
								КолонкаЗаполнена = истина;
								Прервать;
							КонецЕсли; 
						КонецЦикла; 
						
						Если НЕ КолонкаЗаполнена Тогда
							УдаляемыеРеквизиты.Добавить(Колонка.ПутьКданным);
						КонецЕсли; 
					КонецЦикла; 
				КонецЕсли; 	
			КонецЕсли; 
		Иначе
			Если НЕ ЗначениеЗаполнено(Форма[СтрокаРеквизит.ИмяЭлемента]) Тогда
				УдаляемыеРеквизиты.Добавить(СтрокаРеквизит.ИмяЭлемента);
			КонецЕсли; 	
		КонецЕсли;	
		
	КонецЦикла; 
	
	Форма.ИзменитьРеквизиты(,УдаляемыеРеквизиты);
	
КонецПроцедуры

Процедура ЗаполнитьЭлементыФормы(Ссылка, Форма, СКД, ИмяНабораДанных)
	
	НаборДанных = СКД.НаборыДанных[ИмяНабораДанных];
	
	ИмяНабораДанных = СтрЗаменить(ИмяНабораДанных, "ТЧ_", "");
	
	Запрос = Новый Запрос(НаборДанных.Запрос);
	Запрос.УстановитьПараметр("Сделка", Ссылка);
	Запрос.УстановитьПараметр("Дата", ТекущаяДата());
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
		МассивВидимыхРеквизитов = Форма.ТаблицаРеквизитов.НайтиСтроки(Новый Структура("Видимость", Истина));
		Для каждого СтрокаРеквизит Из МассивВидимыхРеквизитов Цикл
			ИмяРеквизита = СтрокаРеквизит.Имя;
			
			Если ИмяРеквизита = "" Тогда
				Продолжить;
			КонецЕсли;
			
			Если Найти(СтрокаРеквизит.ПутьКДанным, "Таблица") > 0 Тогда
				Продолжить;
			КонецЕсли; 
			
			Если Найти(ИмяРеквизита, "[") > 0 И Найти(ИмяРеквизита, "]") > 0 Тогда
				ТекстВыражения = СтрЗаменить(ИмяРеквизита, "[", "Выборка[""");
				ПозицияТочки = Найти(ТекстВыражения, ".");
				ПозицияЛевойСкобки = Найти(ИмяРеквизита, "[");
				Если ПозицияТочки > 0 И ПозицияТочки > ПозицияЛевойСкобки Тогда
					ТекстВыражения = Сред(ТекстВыражения, 1, ПозицияТочки - 1) + """]" + "." + СтрЗаменить(Сред(ТекстВыражения, ПозицияТочки + 1), "]", "");
				Иначе
					ТекстВыражения = СтрЗаменить(ТекстВыражения, "]", """]");
					//ПозицияСкобки = Найти(ИмяРеквизита, "]");
					//ТекстВыражения = СтрЗаменить(ТекстВыражения, "]", """]");
				КонецЕсли; 
				
				Попытка
					Значение = Вычислить(ТекстВыражения);
				Исключение
					Значение = "";
					Сообщить("Ошибка при вычислении поля """ + ИмяРеквизита + """ для заполнения реквизита """ + СтрокаРеквизит.Заголовок + """: " + ОписаниеОшибки());
				КонецПопытки;
				
				Если Значение <> "" Тогда
					Если СтрокаРеквизит.ФорматнаяСтрока = "" Тогда
						Форма[СтрокаРеквизит.ИмяЭлемента] = Значение;
					Иначе
						Форма[СтрокаРеквизит.ИмяЭлемента] = Формат(Значение, СтрокаРеквизит.ФорматнаяСтрока);
					КонецЕсли;
				КонецЕсли; 
				
			Иначе
				Форма[СтрокаРеквизит.ИмяЭлемента] = ИмяРеквизита;
			КонецЕсли;
			
			Если НЕ ЗначениеЗаполнено(Форма[СтрокаРеквизит.ИмяЭлемента]) И НЕ СтрокаРеквизит.Обязательный Тогда
				Форма.Элементы[СтрокаРеквизит.ИмяЭлемента].Видимость = Ложь;
				//Форма.Элементы[СтрокаРеквизит.ИмяЭлемента].ПутьКданным = "";
			КонецЕсли; 
		КонецЦикла; 
	КонецЕсли; 
	
КонецПроцедуры

Процедура ЗаполнитьТаблицуФормы(Ссылка, Форма, СКД, ИмяНабораДанных)
	
	НаборДанных = СКД.НаборыДанных[ИмяНабораДанных];
	
	Запрос = Новый Запрос(НаборДанных.Запрос);
	Запрос.УстановитьПараметр("Сделка", Ссылка);
	Запрос.УстановитьПараметр("Дата", ТекущаяДата());
	Запрос.УстановитьПараметр("ЭтоНеторговоеПоручениеСоСпискомЦБ", Документы.Поручение.ЭтоНеторговоеПоручениеСоСпискомЦБ(Ссылка));
	Выборка = Запрос.Выполнить().Выбрать();
	
	ПапкиНабораДанных = Новый массив;
	Для каждого Поле Из НаборДанных.Поля Цикл
		Если ТипЗнч(Поле) = Тип("ПапкаПолейНабораДанныхСхемыКомпоновкиДанных") Тогда
			ПапкиНабораДанных.Добавить(Поле.Заголовок);
		КонецЕсли; 
	КонецЦикла; 
	
	МассивВидимыхРеквизитов = Форма.ТаблицаРеквизитов.НайтиСтроки(Новый Структура("Видимость", Истина));
	
	Пока Выборка.Следующий() Цикл
		СтрокаДобавлена = Ложь;
		
		Для каждого СтрокаРеквизит Из МассивВидимыхРеквизитов Цикл
			Если Найти(СтрокаРеквизит.ПутьКДанным, "Таблица") = 0 Тогда
				Продолжить;
			КонецЕсли; 
			
			ИмяРеквизита = СтрокаРеквизит.Имя;
			Если ИмяРеквизита = "" Тогда
				Продолжить;
			КонецЕсли; 
			
			Если ПапкиНабораДанных.Найти(СтрокаРеквизит.ИмяТаблицы) = Неопределено Тогда
				Продолжить;
			КонецЕсли; 
			//Если Найти(ИмяРеквизита, "[") > 0 И Найти(ИмяРеквизита, "]") > 0 И Найти(ИмяРеквизита, ИмяНабораДанных) = 0 Тогда
			//	Продолжить;
			//КонецЕсли; 
			
			ИмяПоля = ИмяРеквизита;
			ИмяПоля = СтрЗаменить(ИмяПоля, "[", "");
			ИмяПоля = СтрЗаменить(ИмяПоля, "]", "");
			
			//ПолеНабораДанных = НаборДанных.Поля.Найти(ИмяПоля);
			//Если ПолеНабораДанных = Неопределено Тогда
			//	Продолжить;
			//КонецЕсли;				
			
			Если Не СтрокаДобавлена Тогда
				НовСтрока = Форма[СтрокаРеквизит.Родитель].Добавить();
				СтрокаДобавлена = Истина;
			КонецЕсли; 

			ИмяРеквизита = СтрЗаменить(ИмяРеквизита, ИмяНабораДанных + ".", "");
			
			Если Найти(ИмяРеквизита, "[") > 0 И Найти(ИмяРеквизита, "]") > 0 Тогда
				ТекстВыражения = СтрЗаменить(ИмяРеквизита, "[", "Выборка[""");
				ТекстВыражения = СтрЗаменить(ТекстВыражения, "]", """]");
				Попытка
					Значение = Вычислить(ТекстВыражения);
				Исключение
					Значение = "";
					Сообщить("Ошибка при вычислении поля """ + ИмяРеквизита + """ для заполнения реквизита """ + СтрокаРеквизит.Заголовок + """");
				КонецПопытки;
				
				Если Значение <> "" Тогда
					Если Найти(Значение, "[") > 0 Тогда
						ТекстВыражения = Значение;
						ТекстВыражения = СтрЗаменить(ТекстВыражения, "[", "Выборка.Поручение[");
						Попытка
							Значение = Вычислить(ТекстВыражения);
						Исключение
							Значение = "";
						КонецПопытки;
					КонецЕсли;
					
					Если ТипЗнч(Значение) = Тип("Строка") Тогда
						Значение = СтрЗаменить(Значение, """", "");
					КонецЕсли; 
					
					Если СтрокаРеквизит.ФорматнаяСтрока = "" Тогда
						НовСтрока[СтрокаРеквизит.ИмяЭлемента] = Значение;
					Иначе
						НовСтрока[СтрокаРеквизит.ИмяЭлемента] = Формат(Значение, СтрокаРеквизит.ФорматнаяСтрока);
					КонецЕсли;
				КонецЕсли; 
				
			Иначе
				НовСтрока[СтрокаРеквизит.ИмяЭлемента] = ИмяРеквизита;
			КонецЕсли;

		КонецЦикла; 
	КонецЦикла; 
	
 КонецПроцедуры

Процедура ЗаполнитьСтатус_ФШ(Ссылка, Форма)
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	Запрос.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
	|	СостоянияДокументовВФайловомШлюзеСрезПоследних.Статус,
	|	СостоянияДокументовВФайловомШлюзеСрезПоследних.Комментарий
	|ИЗ
	|	РегистрСведений.СостоянияДокументовВФайловомШлюзе.СрезПоследних(, Документ В (ВЫБРАТЬ ПЕРВЫЕ 1 Ссылка ИЗ Документ.ТехническаяОперация ГДЕ ДОкументОснование = &Ссылка УПОРЯДОЧИТЬ ПО Дата УБЫВ)) КАК СостоянияДокументовВФайловомШлюзеСрезПоследних";
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
		Форма["Реквизит_СтатусПорученияФШ"] = Выборка.Статус;
		Форма["Реквизит_КомментарийФШ"] = Выборка.Комментарий;
	КонецЕсли; 
	
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	ТехническаяОперация.РегистрационныйНомер КАК РегистрационныйНомер
	|ИЗ
	|	Документ.ТехническаяОперация КАК ТехническаяОперация
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.НеттоПоручение.Поручения КАК НеттоПоручениеПоручения
	|		ПО ТехническаяОперация.ДокументОснование = НеттоПоручениеПоручения.Ссылка
	|ГДЕ
	|	ВЫБОР
	|			КОГДА ТехническаяОперация.ДокументОснование ССЫЛКА Документ.Поручение
	|				ТОГДА ТехническаяОперация.ДокументОснование = &Поручение
	|			КОГДА ТехническаяОперация.ДокументОснование ССЫЛКА Документ.НеттоПоручение
	|				ТОГДА НеттоПоручениеПоручения.Поручение = &Поручение
	|			ИНАЧЕ ЛОЖЬ
	|		КОНЕЦ
	|
	|УПОРЯДОЧИТЬ ПО
	|	ТехническаяОперация.Дата УБЫВ";
	Запрос.УстановитьПараметр("Поручение", Ссылка);
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		Форма["Реквизит_РегистрационныйНомерФШ"] = Выборка.РегистрационныйНомер;
	КонецЦикла;
	
КонецПроцедуры

Процедура ИсправитьКолонкиНаФормеНаРазрешенныеЗначения(ТаблицаОтображения, ВидПоручения)
	
	РазрешенныеЗначенияСтр = "1,2,3,4,5,6,7,8,9";
	РазрешенныеЗначения = СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(РазрешенныеЗначенияСтр);
	Ошибка = Ложь;
	Для Каждого Строка Из ТаблицаОтображения Цикл
		Если НЕ ЗначениеЗаполнено(Строка.КолонкаНаФорме) Тогда
			Строка.КолонкаНаФорме = РазрешенныеЗначения[0];
		КонецЕсли;
		Если РазрешенныеЗначения.Найти(Строка.КолонкаНаФорме) = Неопределено Тогда
			Ошибка = Истина;
			Строка.КолонкаНаФорме = РазрешенныеЗначения[0];
		КонецЕсли;
	КонецЦикла;
	Если Ошибка Тогда
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "В справочнике ""Виды инвентарных поручений"" с кодом " + ВидПоручения.Код
			+ " обнаружено запрещенное значение колонки на форме." + Символы.ПС
			+ "Разрешенные значения: " + РазрешенныеЗначенияСтр;
		Сообщение.Сообщить();
	КонецЕсли;
	
КонецПроцедуры

Процедура ИсправитьКолонкиНаФормеНаОдноЗначениеВнутриГруппы(ТаблицаОтображения, ВидПоручения)
	
	ТекущаяГруппа = "<Неопределено>";
	ТекущаяКолонка = "";
	Ошибка = Ложь;
	Для Каждого Строка Из ТаблицаОтображения Цикл
		Если Строка.НомерГруппы <> ТекущаяГруппа Тогда
			ТекущаяГруппа = Строка.НомерГруппы;
			ТекущаяКолонка = Строка.КолонкаНаФорме;
		Иначе
			Если Строка.КолонкаНаФорме <> ТекущаяКолонка Тогда
				Ошибка = Истина;
				Строка.КолонкаНаФорме = ТекущаяКолонка;
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	Если Ошибка Тогда
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "В справочнике ""Виды инвентарных поручений"" с кодом " + ВидПоручения.Код
			+ " обнаружены различные номера колонок на форме в пределах одной группы.";
		Сообщение.Сообщить();
	КонецЕсли;
	
КонецПроцедуры

Функция КолонкиГруппНаФорме(ТаблицаОтображения)
	
	КолонкиНаФорме = ТаблицаОтображения.Скопировать(, "НомерГруппы, КолонкаНаФорме");
	КолонкиНаФорме.Свернуть("НомерГруппы, КолонкаНаФорме");
	КолонкиГрупп = Новый Соответствие;
	Для Каждого Строка Из КолонкиНаФорме Цикл
		КолонкиГрупп.Вставить(Строка.НомерГруппы, Строка.КолонкаНаФорме);
	КонецЦикла;
	Возврат КолонкиГрупп;
	
КонецФункции

Процедура СоздатьКолонкиНаФорме(Форма, ЭлементРодитель, ТаблицаОтображения)
	
	ЭлементРодитель.Группировка = ГруппировкаПодчиненныхЭлементовФормы.ГоризонтальнаяВсегда;
	КолонкиНаФорме = ТаблицаОтображения.Скопировать(, "КолонкаНаФорме");
	КолонкиНаФорме.Свернуть("КолонкаНаФорме");
	КолонкиНаФорме.Сортировать("КолонкаНаФорме");
	Для Каждого Строка Из КолонкиНаФорме Цикл
		ИмяНовойКолонки = "РеквизитыКолонка" + Строка.КолонкаНаФорме;
		Если Форма.Элементы.Найти(ИмяНовойКолонки) = Неопределено Тогда
			ГруппаКолонки = Форма.Элементы.Добавить(ИмяНовойКолонки, Тип("ГруппаФормы"), ЭлементРодитель);
			ГруппаКолонки.Вид			= ВидГруппыФормы.ОбычнаяГруппа;
			ГруппаКолонки.Отображение	= ОтображениеОбычнойГруппы.Нет;
			ГруппаКолонки.ОтображатьЗаголовок	= Ложь;
			ГруппаКолонки.Группировка	= ГруппировкаПодчиненныхЭлементовФормы.Вертикальная;
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры
