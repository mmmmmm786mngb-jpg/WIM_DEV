#Область ПрограммныйИнтерфейс

// Возвращает список статусов поручений Панда
// 
// Возвращаемое значение:
//  Соответствие - число и соответствующий статус
//
Функция СписокСтатусовПорученийДляПанда() Экспорт
	СписокСтатусов = Новый Соответствие;
	СписокСтатусов.Вставить(7, "Снято");
	СписокСтатусов.Вставить(8, "Исполнено");
	СписокСтатусов.Вставить(12, "Обрабатывается");
	Возврат СписокСтатусов;
КонецФункции

// Возвращает числовое значение статуса в Панда по наименованию
//
// Параметры:
//  НаименованиеСтатуса	 - Строка
// 
// Возвращаемое значение:
//  Число - числовое значение статуса в Панда
Функция СтатусПоНаименованию(НаименованиеСтатуса) Экспорт
	СписокСтатусовПоручений = СписокСтатусовПорученийДляПанда();
	Для Каждого СтатусПоручений Из СписокСтатусовПоручений Цикл
		Если СтатусПоручений.Значение = НаименованиеСтатуса Тогда
			Возврат СтатусПоручений.Ключ;
		КонецЕсли;
	КонецЦикла;
КонецФункции

// Возвращает таблицу значений с данными о неторговых поручениях из Панда. Для этого ищет необработанные
// записи в регистре ЖурналИсходящихСообщенийKafka, содержащие данные о неторговых поручениях из Панда,
// распарсивает их и отбирает поручения в соответствии с указанными в параметрах функции критериями.
// Параметры:
// 	НачалоПериода - Дата
// 	КонецПериода - Дата
// 	Контрагент - СправочникСсылка.Контрагенты
// Возвращаемое значение:
//	ТаблицаЗначений
Функция ДанныеНеторговыхПоручений(НачалоПериода, КонецПериода, Контрагент) Экспорт
	ДанныеПоручений = ТаблицаДанныхНеторговыхПоручений();
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ЖурналВходящихСообщенийKafka.ВнешнийИсточник КАК ВнешнийИсточник,
	|	ЖурналВходящихСообщенийKafka.Ключ КАК Ключ,
	|	ЖурналВходящихСообщенийKafka.Идентификатор КАК Идентификатор,
	|	ЖурналВходящихСообщенийKafka.Сообщение КАК Сообщение,
	|	ЖурналВходящихСообщенийKafka.ОшибкаОбработки КАК ОшибкаОбработки,
	|	ЖурналВходящихСообщенийKafka.ОписаниеОшибки КАК ОписаниеОшибки,
	|	ЖурналВходящихСообщенийKafka.ПериодСообщения КАК ПериодСообщения,
	|	ЖурналВходящихСообщенийKafka.ПериодОбработкиСообщения КАК ПериодОбработкиСообщения
	|ИЗ
	|	РегистрСведений.ЖурналВходящихСообщенийKafka КАК ЖурналВходящихСообщенийKafka
	|ГДЕ
	|	ЖурналВходящихСообщенийKafka.ВнешнийИсточник = ЗНАЧЕНИЕ(ПланВидовХарактеристик.ВнешниеИсточники.KafkaPandaConsNti1634)
	|	И ЖурналВходящихСообщенийKafka.Ключ = ""NTConsInstrData""
	|	И НЕ ЖурналВходящихСообщенийKafka.Обработан
	|	И НЕ ЖурналВходящихСообщенийKafka.ОшибкаОбработки";
	
	РезультатЗапроса = Запрос.Выполнить();
	Если Не РезультатЗапроса.Пустой() Тогда
		CrmContractNumber = Справочники.Контрагенты.CrmContractNumberПоКлиенту(Контрагент);
		Если ЗначениеЗаполнено(Контрагент) И Не ЗначениеЗаполнено(CrmContractNumber) Тогда
			ТекстСообщения = "Для депонента " + Строка(Контрагент)
								+ " не удалось определить номер договора в CRM Панда (CrmContractNumber) - отбор по депоненту невозможен";
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
		КонецЕсли;
		Выборка = Запрос.Выполнить().Выбрать();
		Пока Выборка.Следующий() Цикл
			ОбработатьОдноВходящееСообщениеОНеторговомПоручении(Выборка, ДанныеПоручений, CrmContractNumber);
		КонецЦикла;
	КонецЕсли;
	Возврат ДанныеПоручений;
КонецФункции

// Создает запись в регистре ЖурналИсходящихСообщенийKafka содержащую запрос к Диасофт
// на получение данных для отчетности
// Параметры:
//	Поручение - ДокументСсылка.Поручение
//	Статус - Число
Процедура СоздатьСообщениеОбИзмененииСтатусаПорученияВПанда(Поручение, Статус) Экспорт
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Поручение.ИдентификаторЗагрузки КАК ConsolidatedNumber,
	|	Поручение.KafkaMessageId КАК KafkaMessageId,
	|	ПоручениеЦенныеБумагиСписываемые.ИдентификаторЗагрузки КАК Id
	|ИЗ
	|	Документ.Поручение.ЦенныеБумагиСписываемые КАК ПоручениеЦенныеБумагиСписываемые
	|	ЛЕВОЕ СОЕДИНЕНИЕ Документ.Поручение КАК Поручение
	|		ПО ПоручениеЦенныеБумагиСписываемые.Ссылка = Поручение.Ссылка
	|ГДЕ
	|	ПоручениеЦенныеБумагиСписываемые.Ссылка = &Поручение";
	Запрос.УстановитьПараметр("Поручение", Поручение);
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() Тогда
		Ошибка = "Отсутствуют данные для отправки в CRM Панда статуса по поручению " + Строка(Поручение);
		ОбщегоНазначенияклиентСервер.СообщитьПользователю(Ошибка);
		Возврат;
	КонецЕсли;
	
	ТЗРезультат = РезультатЗапроса.Выгрузить();
	МассивId = ТЗРезультат.ВыгрузитьКолонку("Id");
	ПерваяСтрокаРезультата = ТЗРезультат[0];
	ConsolidatedNumber = ПерваяСтрокаРезультата.ConsolidatedNumber;
	УИДИсходногоСообщения = ПерваяСтрокаРезультата.KafkaMessageId;
	
	ВнешнийИсточник = ПланыВидовХарактеристик.ВнешниеИсточники.KafkaDepoToPandaNotification1642;
	УИДСообщения = Строка(Новый УникальныйИдентификатор());
	Ключ = "DepoConsNti";
	ТекстJSON = СформироватьТекстИзвещенияJSON(УИДСообщения, УИДИсходногоСообщения, ConsolidatedNumber, МассивId, Статус);
	Кафка.ПоместитьСообщениеВРегистрКОтправке(ВнешнийИсточник, Ключ, ТекстJSON, УИДСообщения);
КонецПроцедуры

#КонецОбласти


#Область СлужебныеПроцедурыИФункции

Функция ТаблицаДанныхНеторговыхПоручений()
