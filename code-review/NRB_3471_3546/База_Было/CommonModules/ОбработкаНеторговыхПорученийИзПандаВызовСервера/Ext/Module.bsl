	Колонки = ДанныеПоручений.Колонки;
	Колонки.Добавить("Id",								ТипСтрока20);
	Колонки.Добавить("KafkaMessageId",					ТипСтрока36);
	Колонки.Добавить("DepoMessageId",					ТипСтрока36);
	Колонки.Добавить("Created",							ТипДатаВремя);
	Колонки.Добавить("Operation",						ТипСтрока20);
	Колонки.Добавить("OperationText",					ТипСтрока1000);
	Колонки.Добавить("ConsolidatedNumber",				ТипСтрока1000);
	Колонки.Добавить("DealReference",					ТипСтрока1000);
	Колонки.Добавить("PayDate",							ТипДатаВремя);
	Колонки.Добавить("DealDate",						ТипДатаВремя);
	Колонки.Добавить("DocComment",						ТипСтрока1000);
	Колонки.Добавить("DeponentCode",					ТипСтрока1000);
	Колонки.Добавить("DeponentName",					ТипСтрока1000);
	Колонки.Добавить("DeponentSubAccount",				ТипСтрока1000);
	Колонки.Добавить("DeponentDepoAccount",				ТипСтрока1000);
	Колонки.Добавить("DeponentDepoAccountSection",		ТипСтрока1000);
	Колонки.Добавить("CounterpartyName",				ТипСтрока1000);
	Колонки.Добавить("CounterpartyIdentifier",			ТипСтрока1000);
	Колонки.Добавить("CounterpartyDepoAccount",			ТипСтрока1000);
	Колонки.Добавить("CounterpartyDepoAccountSection",	ТипСтрока1000);
	Колонки.Добавить("CounterpartyClientName",			ТипСтрока1000);
	Колонки.Добавить("CounterpartyClientDepoAccount",	ТипСтрока1000);
