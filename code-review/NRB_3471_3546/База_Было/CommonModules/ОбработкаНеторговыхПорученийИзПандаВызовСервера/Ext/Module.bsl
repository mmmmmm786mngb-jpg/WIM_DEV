	Колонки.Добавить("PlaceText",						ТипСтрока1000);
	Колонки.Добавить("SecCode",							ТипСтрока1000);
	Колонки.Добавить("ISIN",							ТипСтрока1000);
	Колонки.Добавить("SecRegNumber",					ТипСтрока1000);
	Колонки.Добавить("Quantity",						ТипЧисло20_7);
	
	Возврат ДанныеПоручений;
КонецФункции

Процедура ОбработатьОдноВходящееСообщениеОНеторговомПоручении(Выборка, ДанныеПоручений, CrmContractNumber)
	ОписаниеОшибки = "";
	
	СтруктураИзJSON = РаботаСJSON.РезультатЧтенияJSON(Выборка.Сообщение);
	
	Если ОбязательныеПоляВНаличии(СтруктураИзJSON, ОписаниеОшибки) Тогда
		Data = СтруктураИзJSON.Data;
		Если ЗначениеЗаполнено(CrmContractNumber) И Data.DeponentCode <> CrmContractNumber Тогда
			Возврат;
		КонецЕсли;
		KafkaMessageId = СтруктураИзJSON.MessageInfo.MessageId;
		Created = ПрочитатьДатуJSON(Data.Created, ФорматДатыJSON.ISO);
		PayDate = ПрочитатьДатуJSON(Data.PayDate, ФорматДатыJSON.ISO);
		DealDate = ПрочитатьДатуJSON(Data.DealDate, ФорматДатыJSON.ISO);
		Для каждого Instruction Из СтруктураИзJSON.Data.Instructions Цикл
			НовСтрокаДанных = ДанныеПоручений.Добавить();
			НовСтрокаДанных.DepoMessageId = Выборка.Идентификатор;
			НовСтрокаДанных.KafkaMessageId = KafkaMessageId;
			ЗаполнитьЗначенияСвойств(НовСтрокаДанных, Data, , "Created,PayDate,DealDate");
			НовСтрокаДанных.Created = Created;
			НовСтрокаДанных.PayDate = PayDate;
			НовСтрокаДанных.DealDate = DealDate;
			ЗаполнитьЗначенияСвойств(НовСтрокаДанных, Instruction);
		КонецЦикла;
	Иначе
		Запись = РегистрыСведений.ЖурналВходящихСообщенийKafka.СоздатьМенеджерЗаписи();
		ЗаполнитьЗначенияСвойств(Запись, Выборка, "ВнешнийИсточник,Идентификатор");
		Запись.Прочитать();
		Запись.ОписаниеОшибки = ОписаниеОшибки;
		Запись.Обработан = Ложь;
		Запись.ОшибкаОбработки = Не ПустаяСтрока(ОписаниеОшибки);
		Запись.Записать();
		ИмяСобытия = "Загрузка неторговых поручений из CRM Панда";
		ЗаписьЖурналаРегистрации(ИмяСобытия, УровеньЖурналаРегистрации.Ошибка, , , ОписаниеОшибки);
		Текст = ИмяСобытия + " - ошибка в записи с идентификатором " + Выборка.Идентификатор
				+ " в журнале входящих сообщений Kafka: " + ОписаниеОшибки;
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(Текст);
	КонецЕсли;
КонецПроцедуры

Функция ОбязательныеПоляВНаличии(СтруктураИзJSON, ОписаниеОшибки)
	ПроверятьЗаполненность = Ложь;
	СписокПолейСтрокой = "MessageInfo,Data";
	РаботаСJSON.ПроверитьОбязательныеПоля(СтруктураИзJSON, СписокПолейСтрокой, ОписаниеОшибки, ПроверятьЗаполненность);
	Если Не ПустаяСтрока(ОписаниеОшибки) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	ПроверятьЗаполненность = Истина;
	СписокПолейСтрокой = "MessageId";
	РаботаСJSON.ПроверитьОбязательныеПоля(СтруктураИзJSON.MessageInfo, СписокПолейСтрокой, ОписаниеОшибки, ПроверятьЗаполненность);
	СписокПолейСтрокой = "ConsolidatedNumber,Instructions,Operation,DeponentCode,DeponentName,DeponentDepoAccount,CounterpartyDepoAccount"
						+ ",CounterpartyName,Created";
	РаботаСJSON.ПроверитьОбязательныеПоля(СтруктураИзJSON.Data, СписокПолейСтрокой, ОписаниеОшибки, ПроверятьЗаполненность);
	Если Не ПустаяСтрока(ОписаниеОшибки) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	СписокПолейСтрокой = "Id,Quantity";
	Для каждого Instruction Из СтруктураИзJSON.Data.Instructions Цикл
		РаботаСJSON.ПроверитьОбязательныеПоля(Instruction, СписокПолейСтрокой, ОписаниеОшибки, ПроверятьЗаполненность);
		Если Не ПустаяСтрока(ОписаниеОшибки) Тогда
			Возврат Ложь;
		КонецЕсли;
	КонецЦикла;
	
	Возврат ПустаяСтрока(ОписаниеОшибки);
КонецФункции

Функция СформироватьТекстИзвещенияJSON(УИДСообщения, УИДИсходногоСообщения, ConsolidatedNumber, МассивId, Статус)
	MessageInfo = РаботаСJSON.СтруктураMessageInfo();
	MessageInfo.MessageType = "Notification";
	MessageInfo.JsonVersion = "1.0.0";
	MessageInfo.MessageId = УИДСообщения;
	MessageInfo.MasterMessageId = УИДИсходногоСообщения;
	MessageInfo.ParentMessageId = УИДИсходногоСообщения;
	MessageInfo.SystemSource = "Depo";
	MessageInfo.ActionType = "Ins";
	ТекущаяДатаВФорматеJSON_ISO = ЗаписатьДатуJSON(ТекущаяДатаСеанса(), ФорматДатыJSON.ISO);
	MessageInfo.DateTimeCreate = ТекущаяДатаВФорматеJSON_ISO;
	
	Instructions = Новый Массив;
	Для Каждого Id Из МассивId Цикл
		Instruction = Новый Структура;
		Instruction.Вставить("Id", Id);
		Instruction.Вставить("Status", Статус);
		Instruction.Вставить("ExecuteDate", ТекущаяДатаВФорматеJSON_ISO);
		Instructions.Добавить(Instruction);
	КонецЦикла;
	
	Content = Новый Структура;
	Content.Вставить("ConsolidatedNumber", ConsolidatedNumber);
	Content.Вставить("Instructions", Instructions);
	
	Data = Новый Структура;
	Data.Вставить("NotificationType", "DepoConsNti");
	Data.Вставить("ResultCode", "SUCCESS");
	Data.Вставить("ResultDescription", "");
	Data.Вставить("Content", Content);
	
	ТекстЗапросаJSON = РаботаСJSON.ТекстСообщенияJSON(MessageInfo, Data);
	
	Возврат ТекстЗапросаJSON;
КонецФункции

#КонецОбласти