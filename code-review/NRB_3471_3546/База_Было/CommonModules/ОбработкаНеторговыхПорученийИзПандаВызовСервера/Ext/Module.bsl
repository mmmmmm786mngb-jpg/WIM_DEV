	Строка = "Строка";
	ТипСтрока1000	= Новый ОписаниеТипов(Строка, , Новый КвалификаторыСтроки(1000));
	ТипСтрока36		= Новый ОписаниеТипов(Строка, , Новый КвалификаторыСтроки(36));
