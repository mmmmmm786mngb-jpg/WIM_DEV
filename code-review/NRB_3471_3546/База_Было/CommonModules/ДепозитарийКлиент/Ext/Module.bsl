			СтрокаЦБ.РАСХ = ?(СтрокаТЗ.Количество_БО - СтрокаТЗ.Количество_Д >= 0, СтрокаТЗ.Количество_БО - СтрокаТЗ.Количество_Д, (СтрокаТЗ.Количество_БО - СтрокаТЗ.Количество_Д) * (-1));
			Клиент_БО = СтрокаТЗ.КлиентНаименование_БО;
