#Область API

Функция API_AccountLogin(НастройкиСоединения, ОписаниеОшибки, Сессия)
	
	URL = "https://" + НастройкиСоединения.HTTPСервисАдресСервера + НастройкиСоединения.HTTPСервисАдресРесурсаАутентификации;
	
	ОписаниеВызова = РегистрыСведений.ЖурналРегистрацииВызовов.НовоеОписаниеВызова(
		"URL = " + URL,
		"ОбщийМодуль.NSDAPI." + "API_AccountLogin");
	РегистрыСведений.ЖурналРегистрацииВызовов.ЗафиксироватьНачало(ОписаниеВызова);
	
	Если Не ТестированиеVanessa.ЭтоТест() Тогда
		ssl		= Новый ЗащищенноеСоединениеOpenSSL();
		Если НастройкиСоединения.ПроксиСерверИспользовать Тогда
			ПроксиСервер = Новый ИнтернетПрокси;
			ПроксиСервер.Установить("https", НастройкиСоединения.ПроксиСерверАдрес, НастройкиСоединения.ПроксиСерверПорт);
		Иначе
			ПроксиСервер = Неопределено;
		КонецЕсли;
		Попытка
			Соединение = Новый HTTPСоединение(НастройкиСоединения.HTTPСервисАдресСервера, 443, , , ПроксиСервер, 10, ssl);
			Сессия = Новый Структура("Соединение", Соединение);
		Исключение
			ОписаниеОшибки	= НСтр("ru='Ошибка соединения с НРД. Техническая информация: '") + ОписаниеОшибки();
			РегистрыСведений.ЖурналРегистрацииВызовов.ЗафиксироватьОшибку(ОписаниеВызова, ОписаниеОшибки);
			Возврат "";
		КонецПопытки;
	КонецЕсли;
	РегистрыСведений.ЖурналРегистрацииВызовов.ЗафиксироватьОкончание(ОписаниеВызова);
	
	Возврат НастройкиСоединения.HTTPСервисПароль;
	
КонецФункции

// BSLLS:LatinAndCyrillicSymbolInWord-off

Функция HTTPЗапросМетодPOST(АдресСервиса, ПараметрыURLЗапроса)
	
	ЗаголовкиЗапроса	= Новый Соответствие;
	ЗаголовкиЗапроса.Вставить("Content-Type", "application/json");
	ЗаголовкиЗапроса.Вставить("Accept", "application/xml");
	
	ИнтернетЗапрос	= Новый HTTPЗапрос;
	ИнтернетЗапрос.АдресРесурса	= АдресСервиса + "?token=" + ПараметрыСеанса.APIKeyNSD;
	ИнтернетЗапрос.Заголовки	= ЗаголовкиЗапроса;
	
	ТелоЗапроса	= Новый ЗаписьJSON;
	ТелоЗапроса.УстановитьСтроку();
	
	ТелоЗапроса.ЗаписатьНачалоОбъекта();
	
	Для Каждого ТекПараметр Из ПараметрыURLЗапроса Цикл
		ТелоЗапроса.ЗаписатьИмяСвойства(ТекПараметр.Ключ);
		ТелоЗапроса.ЗаписатьЗначение(ТекПараметр.Значение);
	КонецЦикла;
	
	ТелоЗапроса.ЗаписатьКонецОбъекта();
	
	СтрокаТелоЗапроса	= ТелоЗапроса.Закрыть();
	
	ИнтернетЗапрос.УстановитьТелоИзСтроки(СтрокаТелоЗапроса);
	
	Возврат ИнтернетЗапрос;
	
КонецФункции

Функция HTTPЗапросМетодGET(АдресСервиса, ПараметрыURLЗапроса, ЛогПолученныхДанных = Неопределено, ИмяКлюча = "apikey")
	
	ЗаголовкиЗапроса = Новый Соответствие();
	ЗаголовкиЗапроса.Вставить("Accept-Encoding", "gzip");
	ЗаголовкиЗапроса.Вставить("Content-Type", "application/json");
	ЗаголовкиЗапроса.Вставить("Accept", "application/json");
	
	ИнтернетЗапрос = Новый HTTPЗапрос();
	ИнтернетЗапрос.АдресРесурса = АдресСервиса;
	ИнтернетЗапрос.Заголовки	= ЗаголовкиЗапроса;
	
	СтрокаПараметровURLЗапроса = СтрокаПараметровURLЗапроса_Преобразовать(ПараметрыURLЗапроса);
	
	Если ЗначениеЗаполнено(СтрокаПараметровURLЗапроса) Тогда
		
		// Сохраняем полученные даные в логе
		Если ТипЗнч(ЛогПолученныхДанных) = Тип("ТекстовыйДокумент") Тогда
			ПозицияКлюча = СтрНайти(СтрокаПараметровURLЗапроса, ИмяКлюча);
			ДлинаКлюча = СтрДлина(ПараметрыURLЗапроса[ИмяКлюча]);
			ДлинаИмениКлюча = СтрДлина(ИмяКлюча);
			ИнформационнаяСтрокаПараметровURLЗапроса = "?" + Лев(СтрокаПараметровURLЗапроса, ПозицияКлюча - 1) + ИмяКлюча + "=*"
				+ Сред(СтрокаПараметровURLЗапроса, ПозицияКлюча + ДлинаКлюча + ДлинаИмениКлюча + 1);
			ЛогПолученныхДанных.ДобавитьСтроку("Тело запроса:");
			ЛогПолученныхДанных.ДобавитьСтроку(ИнформационнаяСтрокаПараметровURLЗапроса);
		КонецЕсли;
		
		ИнтернетЗапрос.АдресРесурса = ИнтернетЗапрос.АдресРесурса + "?" + СтрокаПараметровURLЗапроса;
	КонецЕсли;
	
	Возврат ИнтернетЗапрос;
	
КонецФункции

Функция СтрокаПараметровURLЗапроса_Преобразовать(ПараметрыURLЗапроса)
	
	СтрокаПараметровURLЗапроса = "";
	Для Каждого ТекПараметр Из ПараметрыURLЗапроса Цикл
		
		Если ТекПараметр.Ключ = "filter" Тогда
			
			Если ТипЗнч(ТекПараметр.Значение) = Тип("Структура") Или ТипЗнч(ТекПараметр.Значение) = Тип("Соответствие") Тогда
				
				ЗаписьJSON = Новый ЗаписьJSON;
				ЗаписьJSON.УстановитьСтроку();
				ЗаписатьJSON(ЗаписьJSON, ТекПараметр.Значение);
				УсловияФильтра = ЗаписьJSON.Закрыть();
				УсловияФильтра = СтрЗаменить(УсловияФильтра, "_S_", "$");
				
				СтрокаПараметровURLЗапроса = СтрокаПараметровURLЗапроса
					+ "filter=" + КодироватьСтроку(УсловияФильтра , СпособКодированияСтроки.URLВКодировкеURL) + "&";
				
			КонецЕсли;
			
		Иначе
			СтрокаПараметровURLЗапроса = СтрокаПараметровURLЗапроса
				+ ТекПараметр.Ключ + "=" + КодироватьСтроку(ТекПараметр.Значение, СпособКодированияСтроки.КодировкаURL) + "&";
		КонецЕсли;
		
	КонецЦикла;
	
	Если Прав(СтрокаПараметровURLЗапроса, 1) = "&" Тогда
		СтрокаПараметровURLЗапроса = Лев(СтрокаПараметровURLЗапроса, СтрДлина(СтрокаПараметровURLЗапроса) - 1);
	КонецЕсли;
	
	Возврат СтрокаПараметровURLЗапроса;
	
КонецФункции

Функция ДанныеИзСервиса(Метод,
	ПараметрыURLЗапроса,
	Отказ,
	ТекстОтказа,
	ЛогПолученныхДанных,
	Соединение,
	ПараметрыЖурналаРегистрации)
	
	НастройкиСоединения = ПараметрыИсточника();
	АдресСервиса	= НастройкиСоединения.HTTPСервисАдресРесурса;
	
	URL = "https://" + НастройкиСоединения.HTTPСервисАдресСервера + АдресСервиса;
	
	ОставитьЗаписьВЖурналеРегистрацииВызовов = ПараметрыЖурналаРегистрации.ОставитьЗаписьВЖурналеРегистрацииВызовов;
	Комментарий								 = ПараметрыЖурналаРегистрации.Комментарий;
	
	Если ОставитьЗаписьВЖурналеРегистрацииВызовов Тогда
		ОписаниеВызова = РегистрыСведений.ЖурналРегистрацииВызовов.НовоеОписаниеВызова(
			"URL = " + URL,
			"ОбщийМодуль.NSDAPI.ДанныеИзСервиса");
		РегистрыСведений.ЖурналРегистрацииВызовов.ЗафиксироватьНачало(ОписаниеВызова);
	Иначе
		ОписаниеВызова = Неопределено;
	КонецЕсли;
	
	ДанныеИзСервиса = Новый Массив;
	КодСостояния200 = 200;
	КодСостояния400 = 400;
	Ответ = Неопределено;
	
	Попытка
		
		Если Метод = "GET" Тогда
			HTTPЗапрос = HTTPЗапросМетодGET(АдресСервиса, ПараметрыURLЗапроса, ЛогПолученныхДанных);
			Ответ = Соединение.Получить(HTTPЗапрос);
		Иначе
			Ответ = Соединение.ОтправитьДляОбработки(HTTPЗапросМетодPOST(АдресСервиса, ПараметрыURLЗапроса));
		КонецЕсли;
		
		Если Ответ.КодСостояния = КодСостояния200 Тогда
			ТекстОтказа = "";
		ИначеЕсли Ответ.КодСостояния = КодСостояния400 Тогда
			ТекстШаблона = НСтр("ru='Не удалось получить данные Из сервиса %1. Код ошибки: %2.'");
			ТекстОтказа =  СтрШаблон(ТекстШаблона, АдресСервиса, ОписаниеПоКодуОтвета(Ответ.КодСостояния));
		Иначе
			ТекстШаблона = НСтр("ru='Не удалось получить данные Из сервиса %1. Код ошибки: %2.'");
			ТекстОтказа =  СтрШаблон(ТекстШаблона, АдресСервиса, ОписаниеПоКодуОтвета(Ответ.КодСостояния));
			Отказ = Истина;
		КонецЕсли;
		
	Исключение
		ОбработатьОшибкиПодключения(ОписаниеОшибки(), АдресСервиса, Ответ, Отказ, ТекстОтказа);
	КонецПопытки;
	
	Если Отказ Тогда
		Если ТипЗнч(ЛогПолученныхДанных) = Тип("ТекстовыйДокумент") Тогда
			ЛогПолученныхДанных.ДобавитьСтроку("Ответ:");
			ЛогПолученныхДанных.ДобавитьСтроку(ТекстОтказа);
		КонецЕсли;
		ЗафиксироватьОшибку(ОписаниеВызова, ТекстОтказа, Комментарий, АдресСервиса);
		Возврат ДанныеИзСервиса;
	КонецЕсли;
	
	ДанныеИзСервиса = ОтветСервиса(АдресСервиса, Ответ, Отказ, ТекстОтказа, ЛогПолученныхДанных);
	
	Если Отказ Тогда
		Если ТипЗнч(ЛогПолученныхДанных) = Тип("ТекстовыйДокумент") Тогда
			ЛогПолученныхДанных.ДобавитьСтроку("Ответ:");
			ЛогПолученныхДанных.ДобавитьСтроку(ТекстОтказа);
		КонецЕсли;
		ЗафиксироватьОшибку(ОписаниеВызова, ТекстОтказа, Комментарий, АдресСервиса);
		Возврат Новый Массив;
	КонецЕсли;
	
	Если ОставитьЗаписьВЖурналеРегистрацииВызовов Тогда
		РегистрыСведений.ЖурналРегистрацииВызовов.ЗафиксироватьОкончание(ОписаниеВызова, Комментарий);
	КонецЕсли;
	
	Возврат ДанныеИзСервиса;
	
КонецФункции

