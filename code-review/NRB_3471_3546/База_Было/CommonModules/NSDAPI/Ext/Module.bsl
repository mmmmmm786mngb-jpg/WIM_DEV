Процедура ЗафиксироватьОшибку(ОписаниеВызова, ТекстОтказа, Комментарий, АдресСервиса)
	
	Если ОписаниеВызова = Неопределено Тогда
		ОписаниеВызова = РегистрыСведений.ЖурналРегистрацииВызовов.НовоеОписаниеВызова(
			"URL = " + АдресСервиса,
			"ОбщийМодуль.NSDAPI.ДанныеИзСервиса");
		РегистрыСведений.ЖурналРегистрацииВызовов.ЗафиксироватьНачало(ОписаниеВызова);
	КонецЕсли;
	РегистрыСведений.ЖурналРегистрацииВызовов.ЗафиксироватьОшибку(ОписаниеВызова, ТекстОтказа, Комментарий);
	
КонецПроцедуры

Функция ОтветСервиса(АдресСервиса, Ответ, Отказ, ТекстОтказа, ЛогПолученныхДанных = Неопределено)
	
	ДанныеОтветаСервиса = Новый Массив;
	
	ЗаписатьВЛогПолученныхДанных = ТипЗнч(ЛогПолученныхДанных) = Тип("ТекстовыйДокумент");
	СтрокаОтвета = "";
	
	Попытка
		Если ТипЗнч(Ответ) = Тип("HTTPОтвет") Тогда
			мОтвет = Новый Структура;
			мОтвет.Вставить("Тело", Ответ.ПолучитьТелоКакДвоичныеДанные());
			мОтвет.Вставить("Заголовки", Ответ.Заголовки);
			мОтвет.Вставить("Кодировка", "utf-8");
			ПараметрыПреобразованияJSON = Новый Структура;
			ПараметрыПреобразованияJSON.Вставить("ПрочитатьВСоответствие", Ложь);
			мПолученныеДанные = КоннекторHTTP.КакJson(мОтвет, ПараметрыПреобразованияJSON);
			Если ЗаписатьВЛогПолученныхДанных Тогда
				СтрокаОтвета = КоннекторHTTP.КакТекст(мОтвет);
			КонецЕсли;
		ИначеЕсли ТипЗнч(Ответ) = Тип("ТекстовыйДокумент") Тогда
			СтрокаОтвета	= Ответ.ПолучитьТекст();
			ОтветJSON = Новый ЧтениеJSON;
			ОтветJSON.УстановитьСтроку(СтрокаОтвета);
			мПолученныеДанные = ПрочитатьJSON(ОтветJSON);
			ОтветJSON.Закрыть();
		Иначе
			Отказ = Истина;
			ТекстОтказа = СтрШаблон("Не удалось прочитать полученные данные. Техническая информация: Пустой ответ.");
			Возврат ДанныеОтветаСервиса;
		КонецЕсли;
	Исключение
		Отказ = Истина;
		ТекстОтказа = СтрШаблон("Не удалось прочитать полученные данные. Техническая информация: %1", ОписаниеОшибки());
		Возврат ДанныеОтветаСервиса;
	КонецПопытки;
	
	// Сохраняем полученные даные в логе
	Если ЗаписатьВЛогПолученныхДанных Тогда
		ЛогПолученныхДанных.ДобавитьСтроку("Ответ:");
		СтрокаЛога = СтрЗаменить(СтрокаОтвета, "}", "}" + Символы.ПС);
		ЛогПолученныхДанных.ДобавитьСтроку(СтрокаЛога);
	КонецЕсли;
	
	ПреобразоватьДанныеОтветаСервиса(АдресСервиса, мПолученныеДанные, ДанныеОтветаСервиса, Отказ, ТекстОтказа);
	
	Возврат ДанныеОтветаСервиса;
	
КонецФункции

Процедура ПреобразоватьДанныеОтветаСервиса(АдресСервиса, мПолученныеДанные, ДанныеОтветаСервиса, Отказ, ТекстОтказа)
	
	Если ТипЗнч(мПолученныеДанные) = Тип("Структура") Тогда
		
		errors = Неопределено;
		Если мПолученныеДанные.Свойство("errors", errors) Тогда
			Отказ = Истина;
			ПричинаОшибки = ПричинаОшибкиНРД(errors);
			ТекстОтказа = СтрШаблон(НСтр("ru='Не удалось получить данные из сервиса %1. Причина: %2'"),
				АдресСервиса, ПричинаОшибки);
		Иначе
			ДанныеОтветаСервиса.Добавить(мПолученныеДанные);
		КонецЕсли;
		
	ИначеЕсли ТипЗнч(мПолученныеДанные) = Тип("Массив") Тогда
		
		Для Каждого Значение Из мПолученныеДанные Цикл
			ДанныеОтветаСервиса.Добавить(Значение);
		КонецЦикла;
		
	ИначеЕсли ТипЗнч(мПолученныеДанные) = Тип("Соответствие") Тогда
		
		ДанныеОтветаСервиса.Добавить(мПолученныеДанные);
		
	Иначе
		Отказ = Истина;
		ТекстОтказа = СтрШаблон(НСтр("ru='Не удалось получить данные из сервиса %1. Тип данных: %2 не поддерживается'"),
			АдресСервиса, ТипЗнч(мПолученныеДанные));
	КонецЕсли;
	
КонецПроцедуры

Функция ПричинаОшибкиНРД(Ошибки)
	
	ПричинаОшибки = "";
	
	Для Каждого Ошибка Из Ошибки Цикл
		КлючОшибки = Ошибка.Ключ;
		ТекстОшибкиПоКлючу = СтрСоединить(Ошибка.Значение, ",");
		ПричинаОшибки = ПричинаОшибки + КлючОшибки + ":" + ТекстОшибкиПоКлючу + "; ";
	КонецЦикла;
	
	Возврат ПричинаОшибки;
	
КонецФункции

Функция КешСоединения(Сессия)
	
	Если Не Сессия = Неопределено И Сессия.Свойство("Соединение") Тогда
		Возврат Сессия.Соединение;
	Иначе
		Возврат Неопределено;
	КонецЕсли;
	
КонецФункции

Функция КодыСостоянияHTTP()
	
	КодыСостояния = Новый Соответствие;
	Для Каждого Описание Из КоннекторHTTP.КодыСостоянияHTTP() Цикл
		КодыСостояния.Вставить(Описание.Значение, Описание.Ключ);
	КонецЦикла;
	
	Возврат КодыСостояния;
	
КонецФункции

Функция ОписаниеПоКодуОтвета(КодОтвета)
	
	СписокКодовОтвета = КодыСостоянияHTTP();
	Описание = Строка(КодОтвета) + " - ";
	
	НайденноеОписание = СписокКодовОтвета[КодОтвета];
	
	Если НайденноеОписание <> Неопределено Тогда
		Описание = Описание + НайденноеОписание;
	КонецЕсли;
	
	Возврат Описание;
	
КонецФункции

