
#Область СлужебныйПрограммныйИнтерфейс

// Получить параметры источника NSD
// 
// Возвращаемое значение:
//   - Структура - Параметры подключения к источнику NSD
//
Функция ПараметрыИсточника() Экспорт
	
	Источник = ПланыВидовХарактеристик.ВнешниеИсточники.ЗагрузкаИзВнешнейAPINSD;
	
	Если ТестированиеVanessa.ЭтоТест() Тогда
		Настройка = Неопределено;
	Иначе
		Настройка = ВнешниеДанные.ПолучитьПараметрыВнешнегоИсточника(Источник).Настройка;
	КонецЕсли;
	
	СтруктураНастроек = Новый Структура;
	
	Если ЗначениеЗаполнено(Настройка) Тогда
		СтруктураНастроек.Вставить("HTTPСервисАдресСервера"								, Настройка.HTTPСервисАдресСервера);
		СтруктураНастроек.Вставить("HTTPСервисПорт"										, Настройка.HTTPСервисПорт);
		СтруктураНастроек.Вставить("HTTPСервисТаймаут"									, Настройка.HTTPСервисТаймаут);
		СтруктураНастроек.Вставить("HTTPСервисЗащищенноеСоединение"						, Настройка.HTTPСервисЗащищенноеСоединение);
		СтруктураНастроек.Вставить("HTTPСервисПользователь"								, Настройка.HTTPСервисПользователь);
		СтруктураНастроек.Вставить("HTTPСервисПароль"									, Настройка.HTTPСервисПароль);
		СтруктураНастроек.Вставить("HTTPСервисАдресРесурсаАутентификации"				, Настройка.HTTPСервисАдресРесурсаАутентификации);
		СтруктураНастроек.Вставить("HTTPСервисАдресРесурса"								, Настройка.HTTPСервисАдресРесурса);
	Иначе
		СтруктураНастроек.Вставить("HTTPСервисАдресСервера"								, "ServerNSDAPI");
		СтруктураНастроек.Вставить("HTTPСервисПорт"										, 0);
		СтруктураНастроек.Вставить("HTTPСервисТаймаут"									, 0);
		СтруктураНастроек.Вставить("HTTPСервисЗащищенноеСоединение"						, Истина);
		СтруктураНастроек.Вставить("HTTPСервисПользователь"								, "");
		СтруктураНастроек.Вставить("HTTPСервисПароль"									, "");
		СтруктураНастроек.Вставить("HTTPСервисАдресРесурсаАутентификации"				, "");
		СтруктураНастроек.Вставить("HTTPСервисАдресРесурса"								, "/api/get/eod");
	КонецЕсли;
	
	СтруктураНастроек.Вставить("ПроксиСерверАдрес",			 ОбщегоНазначенияПовтИсп.ЗначениеГлобальногоПараметра("ПроксиСерверАдрес"));
	СтруктураНастроек.Вставить("ПроксиСерверПорт",			 ОбщегоНазначенияПовтИсп.ЗначениеГлобальногоПараметра("ПроксиСерверПорт", 3128));
	СтруктураНастроек.Вставить("ПроксиСерверИспользовать",
		ОбщегоНазначенияПовтИсп.ЗначениеГлобальногоПараметра("ПроксиСерверИспользовать", Ложь));
	
	СтруктураНастроек.Вставить("ИмяИсточника",				 Источник.Наименование);
	
	Возврат СтруктураНастроек;
	
КонецФункции

// Получает источник NSD API, записывает ключ авторизации в параметры сеанса
//
// Параметры:
//  ОписаниеОшибки	 - Строка	 - Описание ошибки (если есть)
//  СлужебныйВызов	 - Булево	 - Признак вызова из служебной процедуры (по - умолчанию)
//  Сессия			 - Структура - Кеш соединения
// 
// Возвращаемое значение:
//   - Булево - Стутус получения ключа
//
Функция Подключить(ОписаниеОшибки, СлужебныйВызов = Истина, Сессия = Неопределено) Экспорт
	
	ОписаниеОшибки = "";
	
	НастройкиСоединения = ПараметрыИсточника();
	
	Если ЗначениеЗаполнено(НастройкиСоединения) Тогда
		
		ПараметрыСеанса.APIKeyNSD = API_AccountLogin(НастройкиСоединения, ОписаниеОшибки, Сессия);
		
	Иначе
		
		ПараметрыСеанса.APIKeyNSD = "";
		
		ОписаниеОшибки = "Не заполнены настройки для подключения внешнего источника NSDAPI.";
		
	КонецЕсли;
	
	Если Не СлужебныйВызов И ЗначениеЗаполнено(ОписаниеОшибки) Тогда
		
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ОписаниеОшибки);
		
	КонецЕсли;
	
	Если ОписаниеОшибки = "" И Не ТестированиеVanessa.ЭтоТест() Тогда
		Соединение = КешСоединения(Сессия);
		Если Соединение = Неопределено Тогда
			ОписаниеОшибки = "Нет HTTP Соединения";
		Иначе
			Возврат Соединение;
		КонецЕсли;
		Возврат Неопределено;
	Иначе
		Возврат Неопределено;
	КонецЕсли;
	
КонецФункции

// Процедура - Подключиться к сервису
//
// Параметры:
//  Соединение		 - HTTPСоединение	 - Соединение
//  Токен			 - Строка			 - Токен
//  Отказ			 - Булево			 - Отказ
//  ТекстОтказа		 - Строка			 - Описание ошибки
//  СлужебныйВызов	 - Булево			 - Признак служебного вызова
//  Сессия			 - Структура		 - Кеш
//
Процедура ПодключитьсяКСервису(Соединение,
	Токен,
	Отказ,
	ТекстОтказа,
	СлужебныйВызов = Ложь, Сессия = Неопределено) Экспорт
	
	ТекстОтказа = "";
	Соединение = Подключить(ТекстОтказа, СлужебныйВызов, Сессия);
	Если ЗначениеЗаполнено(ТекстОтказа) Тогда
		Отказ = Истина;
	Иначе
		Токен = ПараметрыСеанса.APIKeyNSD;
	КонецЕсли;
	
КонецПроцедуры

// BSLLS:LatinAndCyrillicSymbolInWord-off

// Возвращает данные из метода getValuation
//
// Параметры:
//  ВхПараметры								 - Строка	 - Входные параметры метода
//  Отказ									 - Булево	 - Признак отказа
//  ТекстОтказа								 - Строка	 - Описание ошибки
//  ЛогПолученныхДанных						 - ТекстовыйДокумент - Логирование
//  Соединение								 - HTTPСоединение	 - Кеш соединения
//  ОставитьЗаписьВЖурналеРегистрацииВызовов - Булево			 - Делать запись в журнале регистрации вызовов
//  Комментарий								 - Строка			 - Комментарий в журнале регистрации вызовов
// 
// Возвращаемое значение:
//   - Массив - Котировки
//
Функция ДанныеМетода_getValuation(ВхПараметры,
	Отказ,
	ТекстОтказа,
	ЛогПолученныхДанных,
	Соединение = Неопределено,
	ОставитьЗаписьВЖурналеРегистрацииВызовов = Истина,
	Комментарий = "") Экспорт
	
	Токен = ПараметрыСеанса.APIKeyNSD;
	Если Соединение = Неопределено Или Токен = "" Тогда
		СлужебныйВызов = Истина;
		ПодключитьсяКСервису(Соединение, Токен, Отказ, ТекстОтказа, СлужебныйВызов);
	КонецЕсли;
	Если Отказ Тогда
		Возврат Новый Массив;
	КонецЕсли;
	
	// Параметры метода
	ПараметрыURLЗапроса = Новый Структура;
	ПараметрыURLЗапроса.Вставить("apikey", Токен);
	
	// JSON документ (массив JSON документов), описывающий условие(я), которым должны удовлетворять запрашиваемые данные
	// &filter={"val_date":"2019-10-01","isin":"RU0009029540"} 
	Если ВхПараметры.Свойство("filter") Тогда // В параметр фильтр пердается структура параметров.
		ПараметрыURLЗапроса.Вставить("filter", ВхПараметры.filter);
	КонецЕсли;
	
	// Позволяет ограничить количество документов в ответе
	// &limit=10 Выдать не более 10 документов, удовлетворяющих условию
	Если ВхПараметры.Свойство("limit") Тогда
		ПараметрыURLЗапроса.Вставить("limit", ВхПараметры.limit);
	КонецЕсли;
	
	// Позволяет пропустить n документов в ответе. Совместно с limit можно использовать для реализации постраничной загрузки
	// &skip=1000 пропустить первые 1000 документов
	Если ВхПараметры.Свойство("skip") Тогда
		ПараметрыURLЗапроса.Вставить("skip", ВхПараметры.skip);
	КонецЕсли;
	
	// Включить в ответ только указанные аттрибуты. Для вложенные аттрибутов указываются полный путь через точку
	// &include=id,corp_action_type,coupon.number
	Если ВхПараметры.Свойство("include") Тогда
		ПараметрыURLЗапроса.Вставить("include", ВхПараметры.include);
	КонецЕсли;
	
	// Исключить из ответа указанные аттрибуты. Может применяться для уменьшения объема получаемых данных, если элемент точно не нужен.
	// Для вложенные аттрибутов указываются полный путь через точку
	// &exclude=corp_action_type,securities.issuer,securities.bond.depository
	Если ВхПараметры.Свойство("exclude") Тогда
		ПараметрыURLЗапроса.Вставить("exclude", ВхПараметры.exclude);
	КонецЕсли;
	
	ПараметрыЖурналаРегистрации =
		Новый Структура("ОставитьЗаписьВЖурналеРегистрацииВызовов, Комментарий", ОставитьЗаписьВЖурналеРегистрацииВызовов, Комментарий);
	ДанныеИзСервиса =
		ДанныеИзСервиса("GET", ПараметрыURLЗапроса, Отказ, ТекстОтказа, ЛогПолученныхДанных, Соединение, ПараметрыЖурналаРегистрации);
	
	Возврат ДанныеИзСервиса;
	
КонецФункции

// BSLLS:LatinAndCyrillicSymbolInWord-on

#КонецОбласти

