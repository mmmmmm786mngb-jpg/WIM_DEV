// Работа с принтерами
Функция ФормированиеPDFФайла(Отчет, Знач Перезапись = "yes", Знач ПоказыватьФайл = "yes") Экспорт
	Перем ИмяПринтера, КлассПринтера, УникальныйИдентификатор;
	
	//УникальныйИдентификатор = Новый УникальныйИдентификатор;
	ИмяПринтера = "Bullzip PDF Printer";
	КлассПринтера = "Bullzip.PDFPrinterSettings";
	ИмяФайла = ПолучитьИмяВременногоФайла("pdf"); //КаталогВременныхФайлов()+УникальныйИдентификатор+".pdf";
	
	PDF = Новый ComОбъект(КлассПринтера);
	PDF.SetValue("Output", ИмяФайла);
    PDF.SetValue("ConfirmOverwrite",Перезапись);
    PDF.SetValue("ShowSaveAS","never");
    PDF.SetValue("ShowSettings","never");
    PDF.SetValue("ShowPDF",ПоказыватьФайл);
    PDF.SetValue("RememberLastFileName","no");
    PDF.SetValue("RememberLastFolderName","no");
    PDF.WriteSettings(True);
	Отчет.ИмяПринтера = ИмяПринтера;
	Отчет.Напечатать();
	PDF = Неопределено;
	Возврат ИмяФайла;
КонецФункции

