// Работа с файловой системой
Функция ВыборКаталога(ТекущийКаталог) Экспорт
	Режим = РежимДиалогаВыбораФайла.ВыборКаталога;
	ДиалогОткрытияФайла = Новый ДиалогВыбораФайла(Режим);
	ДиалогОткрытияФайла.Каталог = ТекущийКаталог;
	ДиалогОткрытияФайла.МножественныйВыбор = Ложь;
	ДиалогОткрытияФайла.Заголовок = "Выберите каталог";
	Если ДиалогОткрытияФайла.Выбрать() Тогда
		Возврат ДиалогОткрытияФайла.Каталог;
	КонецЕсли;
	Возврат "";
КонецФункции

Функция ВыборФайла(ТекущийКаталог) Экспорт
	Режим = РежимДиалогаВыбораФайла.Открытие;
	ДиалогОткрытияФайла = Новый ДиалогВыбораФайла(Режим);
	ДиалогОткрытияФайла.МножественныйВыбор = Ложь;
	ДиалогОткрытияФайла.Заголовок = "Выберите файл";
	Если ДиалогОткрытияФайла.Выбрать() Тогда
		Возврат ДиалогОткрытияФайла.ПолноеИмяФайла;
	КонецЕсли;
	Возврат "";
КонецФункции

#КонецЕсли


Процедура ПоискФайлов(Директория, Маска, Знач ОбходДиректорий = Ложь, СписокФайлов) Экспорт
	МассивФайлов = НайтиФайлы(Директория,Маска);
	Для Каждого ОтобранныйФайл Из МассивФайлов Цикл
		Если ОтобранныйФайл.ЭтоФайл() Тогда
			СписокФайлов.Добавить(ОтобранныйФайл.ПолноеИмя, ОтобранныйФайл.Имя);
		КонецЕсли;
	КонецЦикла;
	Если ОбходДиректорий Тогда
		МассивДиректорий = НайтиФайлы(Директория,"*.*");
		Для Каждого ОтобранныйФайл Из МассивДиректорий Цикл
			Если НЕ ОтобранныйФайл.ЭтоФайл() Тогда
				ПоискФайлов(Директория+"\"+ОтобранныйФайл.Имя, Маска, ОбходДиректорий, СписокФайлов);
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
КонецПроцедуры

Функция ОчисткаВременногоКаталога(ВременныйКаталог) Экспорт
	Попытка
    	УдалитьФайлы(ВременныйКаталог,"*.*"); 
	Исключение
		МассивФайлов = НайтиФайлы(ВременныйКаталог,"*.*");
		Если МассивФайлов.Количество()>0 Тогда
			Сообщить("Место: "+ВременныйКаталог);
			Сообщить(ОписаниеОшибки(),СтатусСообщения.ОченьВажное);
			Возврат Ложь;
		КонецЕсли;
	КонецПопытки;
	Возврат Истина;
КонецФункции

