Функция GetNDCReports(Date1, Date2, OrderTypeId)
	СквознойИдентификаторВызова = Новый УникальныйИдентификатор;
	
	Если НЕ ПолучитьФункциональнуюОпцию("ИспользоватьФайловыйШлюзДляОтправкиПоручений") Тогда 
		Возврат "";//ОтветВебСервиса(СквознойИдентификаторВызова, 0, "Функциональная опция ""ИспользоватьФайловыйШлюзДляОтправкиПоручений"" выключена");
	КонецЕсли;	
	
	ВнешнийИсточникФайловыйШлюзКаталогКОтправке = ПланыВидовХарактеристик.ВнешниеИсточники.ФайловыйШлюзКаталогОбменИЦ;	
	ПутьДляВыгрузки = ВнешниеДанные.ПолучитьПараметрыВнешнегоИсточника(ВнешнийИсточникФайловыйШлюзКаталогКОтправке).Папка;
	Если НЕ ЗначениеЗаполнено(ПутьДляВыгрузки) Тогда
		Возврат "";//ОтветВебСервиса(СквознойИдентификаторВызова, 0, "Не указан внешний источник ""ФайловыйШлюзКаталогОбменИЦ""");
	КонецЕсли;
	
	Папка = Новый Файл(ПутьДляВыгрузки);
	Если НЕ Папка.Существует() ИЛИ НЕ Папка.ЭтоКаталог() Тогда
		Возврат "";//ОтветВебСервиса(СквознойИдентификаторВызова, 0, "Каталог " + ПутьДляВыгрузки + " не существует");
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Дата1", Date1);
	Запрос.УстановитьПараметр("Дата2", КонецДня(Date2));
	Запрос.УстановитьПараметр("КодОперации", OrderTypeId);
	Запрос.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
	               |	ВходящийПакетИзФайловогоШлюза.Ссылка КАК Ссылка,
	               |	ВходящийПакетИзФайловогоШлюза.ИмяФайла
	               |ИЗ
	               |	Документ.ТехническаяОперация КАК ТехническаяОперация
	               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ВходящийПакетИзФайловогоШлюза.СодержимоеФайла КАК ВходящийПакетИзФайловогоШлюза
	               |		ПО (ВходящийПакетИзФайловогоШлюза.Ссылка.ДокументОснование = ТехническаяОперация.Ссылка)
	               |			И (ВходящийПакетИзФайловогоШлюза.Ссылка.Обработан = ЛОЖЬ)
	               |ГДЕ
	               |	ТехническаяОперация.ДатаДокументаОснования МЕЖДУ &дата1 И &дата2
	               |	И ТехническаяОперация.КодОперации = &КодОперации
	               |	И ТехническаяОперация.ПометкаУдаления = ЛОЖЬ
	               |ИТОГИ ПО
	               |	Ссылка";
				   
		
	КоличествоФайлов = 0;
	
	ВыборкаПакет = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Пока ВыборкаПакет.Следующий() Цикл
		КоличествоФайлов = КоличествоФайлов + 1;
		
		ИмяФайлаАрхив = ПутьДляВыгрузки + "\" + ВыборкаПакет.Ссылка.ОтносительныйПуть + ".zip";	
		МассивФайловDBF = Новый Массив;
		
		СодержимоеФайла = ВыборкаПакет.Ссылка.СодержимоеФайла.Выгрузить();
		
		ВыборкаФайл = ВыборкаПакет.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		Пока ВыборкаФайл.Следующий() Цикл
			МассивПолей = СодержимоеФайла.НайтиСтроки(Новый Структура("ИмяФайла, НомерСтрокиФайла", ВыборкаФайл.ИмяФайла, 1));
			Если МассивПолей.Количество() = 0 Тогда
				Продолжить;
			КонецЕсли; 
			
			ИмяФайла = ПутьДляВыгрузки + "\" + ВыборкаФайл.ИмяФайла;
			
			НовыйФайл = Новый XBase;
			НовыйФайл.Кодировка = КодировкаXBase.OEM;
			//НовыйФайл.СоздатьФайл(ИмяФайла);
			//НовыйФайл.Записать();
			
			МассивПолей = СодержимоеФайла.НайтиСтроки(Новый Структура("ИмяФайла, НомерСтрокиФайла", ВыборкаФайл.ИмяФайла, 1));
			Для каждого Поле Из МассивПолей Цикл
				НовыйФайл.Поля.Добавить(Поле.Элемент, Поле.Тип, Поле.Длина);
			КонецЦикла; 
			
			НовыйФайл.СоздатьФайл(ИмяФайла);
			НовыйФайл.Записать();
			
			ТекНомерСтроки = 0;
			МассивПолей = СодержимоеФайла.НайтиСтроки(Новый Структура("ИмяФайла", ВыборкаФайл.ИмяФайла));
			Для каждого Поле Из МассивПолей Цикл
				Если ТекНомерСтроки <> Поле.НомерСтрокиФайла Тогда
					Если ТекНомерСтроки <> 0 Тогда
						НовыйФайл.Записать();
					КонецЕсли; 
					НовыйФайл.Добавить();
					ТекНомерСтроки = Поле.НомерСтрокиФайла
				КонецЕсли; 
				
				НовыйФайл[Поле.Элемент] = Поле.Значение;
				
			КонецЦикла; 
			
			НовыйФайл.Записать();
			НовыйФайл.ЗакрытьФайл();
			
			МассивФайловDBF.Добавить(ИмяФайла);
			
		КонецЦикла; 
		
		Архиватор = Новый ЗаписьZipФайла(ИмяФайлаАрхив);
		Для каждого ИмяФайла Из МассивФайловDBF Цикл
			Архиватор.Добавить(ИмяФайла);	
		КонецЦикла; 
		Архиватор.Записать();		
		
		Для каждого ИмяФайла Из МассивФайловDBF Цикл
			УдалитьФайлы(ИмяФайла);
		КонецЦикла;	
		
	КонецЦикла; 
	
	Возврат ПутьДляВыгрузки;//ОтветВебСервиса(СквознойИдентификаторВызова, КоличествоФайлов, ПутьДляВыгрузки);
КонецФункции

Функция СтатусЧислом(Статус)
	
	Коды = Новый Соответствие;
	Коды.Вставить(Перечисления.СтатусыДокументовФайловыйШлюз.ВыгруженоФайловыйШлюз,	0);
	Коды.Вставить(Перечисления.СтатусыДокументовФайловыйШлюз.ОшибкаФайловыйШлюз,	1);
	Коды.Вставить(Перечисления.СтатусыДокументовФайловыйШлюз.ВыгруженоВебКабинет,	2);
	Коды.Вставить(Перечисления.СтатусыДокументовФайловыйШлюз.ПринятоКИсполнению,	3);
	Коды.Вставить(Перечисления.СтатусыДокументовФайловыйШлюз.НеПринятоКИсполнению,	4);
	Коды.Вставить(Перечисления.СтатусыДокументовФайловыйШлюз.Исполнено,				5);
	Коды.Вставить(Перечисления.СтатусыДокументовФайловыйШлюз.НеИсполнено,			6);
	Коды.Вставить(Перечисления.СтатусыДокументовФайловыйШлюз.ИсполненоЧастично,		7);
	
	Коды.Вставить(Перечисления.СтатусыПоручений.Обрабатывается,						8);
	Коды.Вставить(Перечисления.СтатусыПоручений.Исполнено,							5);
	Коды.Вставить(Перечисления.СтатусыПоручений.ОтказаноВИсполнении,				9);
	Коды.Вставить(Перечисления.СтатусыПоручений.Другой,								10);
	Коды.Вставить(Перечисления.СтатусыПоручений.Отменено,							11);
	Коды.Вставить(Перечисления.СтатусыПоручений.ИсполненоЧастично,					7);
	
	Код = Коды[Статус];
	Если Код = Неопределено Тогда
		Код = -1;
	КонецЕсли;
	Возврат Код;
	
КонецФункции

Функция ОтветВебСервиса(CallId, StatusCode, Description)
	ResponceType = ФабрикаXDTO.Тип("http://www.vtbcapital-broker.com/depo/FunctionalElectronicDocuments", "SendFunctionalElectronicDocumentsResponceType");
	Responce = ФабрикаXDTO.Создать(ResponceType);
	BaseStatusType = ФабрикаXDTO.Тип("http://www.vtbcapital-broker.com/depo/FunctionalElectronicDocuments", "BaseStatusType");
	BaseStatus = ФабрикаXDTO.Создать(BaseStatusType);
	
	BaseStatus.StatusCode = StatusCode;
	BaseStatus.Description = Description;
	BaseStatus.CallId = CallId;
	Responce.BaseStatus = BaseStatus;
	
	Возврат Responce;
КонецФункции // ()

Функция СформироватьСтруктуруДокумента(Document, DocumentHeader)
	СтруктураВозврата = Новый Структура("ТекстДокумента, Ошибка");
	
	СоответствиеРеквизитовОбъекта = ОбщегоНазначения.ПолучитьСоответствиеРеквизитовОбъектаПоУмолчанию("Обработка.ЭкспортПорученийВЛуч", "Номера версий", , DocumentHeader.OrderDate);
	НомераВерсий = СоответствиеРеквизитовОбъекта["НомераВерсий"];
	
	Если НомераВерсий <> Неопределено Тогда
		НайденныеСтроки = НомераВерсий.НайтиСтроки(Новый Структура("КодОперации", Document.Order_Header.order_t_id));
		Если НайденныеСтроки.Количество() = 1 Тогда
			НомерВерсии = СокрЛП(НайденныеСтроки[0].НомерВерсии);
		Иначе
			СтруктураВозврата.Ошибка = "Не удалось определить номер версии для кода операции " + Document.Order_Header.order_t_id;
			СтруктураВозврата.ТекстДокумента = "";
			Возврат СтруктураВозврата;
		КонецЕсли;
	Иначе
		СтруктураВозврата.Ошибка = "Не найдены номера версий для эскпорта поручений в Луч";
		СтруктураВозврата.ТекстДокумента = "";
		Возврат СтруктураВозврата;
	КонецЕсли; 
	
	Запись = Новый ЗаписьXML;
	Запись.УстановитьСтроку("Windows-1251");
	Запись.ЗаписатьОбъявлениеXML();
	
	Запись.ЗаписатьНачалоЭлемента("Batch");
	ЗаписатьЭлементXML(Запись, "Documents_amount", "1");
	
	Запись.ЗаписатьНачалоЭлемента("Document");
	Запись.ЗаписатьАтрибут("DOC_ID"		, "1");
	Запись.ЗаписатьАтрибут("version"	, НомерВерсии);
	
	Для каждого Свойство Из Document.Свойства() Цикл
		Если Document[Свойство.Имя] <> Неопределено Тогда
			ЗаписатьБлокXML(Запись, Document[Свойство.Имя], Свойство.Имя);		
		КонецЕсли; 
	КонецЦикла; 
	//ЗаписатьБлокXML(Запись, Document.Order_Header, "ORDER_HEADER"); 
	//
	//OrderType = DocumentHeader.OrderType;
	//ЗаписатьБлокXML(Запись, Document[OrderType], OrderType);
	
	Запись.ЗаписатьКонецЭлемента(); //Document
	Запись.ЗаписатьКонецЭлемента(); //Batch
	
	СтруктураВозврата.Ошибка = "";
	СтруктураВозврата.ТекстДокумента = Запись.Закрыть();
	
	Возврат СтруктураВозврата;
КонецФункции // СформироватьСтруктуруДокумента()

Процедура ЗаписатьБлокXML(Запись, Источник, Имя)
	Запись.ЗаписатьНачалоЭлемента(Имя);
	Для каждого Свойство Из Источник.Свойства() Цикл
		Если Источник[Свойство.Имя] = Неопределено Тогда
			Продолжить;
		КонецЕсли; 
		Если ТипЗнч(Источник[Свойство.Имя]) = Тип("ОбъектXDTO") Тогда
			ЗаписатьБлокXML(Запись, Источник[Свойство.Имя], Свойство.Имя)
		ИначеЕсли ТипЗнч(Источник[Свойство.Имя]) = Тип("СписокXDTO") Тогда
			
			Для каждого ЭлементСписка Из Источник[Свойство.Имя] Цикл
				Запись.ЗаписатьНачалоЭлемента(Свойство.Имя);
				Для каждого СвойствоСписка Из ЭлементСписка.Свойства() Цикл
					Если ЭлементСписка[СвойствоСписка.Имя] = Неопределено Тогда
						Продолжить;
					КонецЕсли; 
					Если ТипЗнч(ЭлементСписка[СвойствоСписка.Имя]) = Тип("Дата") Тогда
						ЗаписатьЭлементXML(Запись, СвойствоСписка.Имя,  Формат(ЭлементСписка[СвойствоСписка.Имя], "ДФ=yyyy-MM-dd"));
					ИначеЕсли ТипЗнч(ЭлементСписка[СвойствоСписка.Имя]) = Тип("Число") Тогда
						ЗаписатьЭлементXML(Запись, СвойствоСписка.Имя,  Формат(ЭлементСписка[СвойствоСписка.Имя], "ЧРД=.; ЧГ=0"));	
					Иначе	
						ЗаписатьЭлементXML(Запись, СвойствоСписка.Имя,  ЭлементСписка[СвойствоСписка.Имя]);
					КонецЕсли;	
				КонецЦикла; 
				Запись.ЗаписатьКонецЭлемента();
			КонецЦикла; 
			
		ИначеЕсли ТипЗнч(Источник[Свойство.Имя]) = Тип("Дата") Тогда
			Если Свойство.Имя = "execute_dt" ИЛИ Свойство.Имя = "expirat_dt" Тогда
				ЗаписатьЭлементXML(Запись, Свойство.Имя, Формат(Источник[Свойство.Имя], "ДФ='yyyy-MM-dd ЧЧ:мм:сс'"));
			Иначе
				ЗаписатьЭлементXML(Запись, Свойство.Имя, Формат(Источник[Свойство.Имя], "ДФ=yyyy-MM-dd"));
			КонецЕсли; 
		ИначеЕсли ТипЗнч(Источник[Свойство.Имя]) = Тип("Число") Тогда
			ЗаписатьЭлементXML(Запись, Свойство.Имя, Формат(Источник[Свойство.Имя], "ЧРД=.; ЧГ=0"));
		Иначе
			Если Источник[Свойство.Имя] <> Неопределено Тогда
				ЗаписатьЭлементXML(Запись, Свойство.Имя, Источник[Свойство.Имя]);
			КонецЕсли;
		КонецЕсли; 
	КонецЦикла;
	Запись.ЗаписатьКонецЭлемента(); //Имя
КонецПроцедуры

Функция XDTOСтрокой(ОбъектXDTO)
	ЗаписьXML = Новый ЗаписьXML;
    ЗаписьXML.УстановитьСтроку("Windows-1251");
    ФабрикаXDTO.ЗаписатьXML(ЗаписьXML, ОбъектXDTO);
	
    Возврат ЗаписьXML.Закрыть();
КонецФункции // XDTOСтрокой()
 
Процедура ЗаписатьЭлементXML(ЗаписьXML, Тег, Значение)
	ЗаписьXML.ЗаписатьНачалоЭлемента(Строка(Тег));						// Начало элемента
	//ЗаписьXML.ЗаписатьТекст(СтрЗаменить(Строка(Значение), " ", ""));	// Значение элемента
	ЗаписьXML.ЗаписатьТекст(СокрЛП(Строка(Значение)));				    // Значение элемента
	ЗаписьXML.ЗаписатьКонецЭлемента();									// Конец элемента
КонецПроцедуры
