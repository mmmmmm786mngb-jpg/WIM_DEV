Функция Send(SendFunctionalElectronicDocumentsRequest)
	СквознойИдентификаторВызова = SendFunctionalElectronicDocumentsRequest.FunctionalElectronicDocumentHeader.CallId;
	
	Если НЕ ПолучитьФункциональнуюОпцию("ИспользоватьФайловыйШлюзДляОтправкиПоручений") Тогда 
		Возврат ОтветВебСервиса(СквознойИдентификаторВызова, -1, "Функциональная опция ""ИспользоватьФайловыйШлюзДляОтправкиПоручений"" выключена");
	КонецЕсли;
	
	ТекстСообщения = XDTOСтрокой(SendFunctionalElectronicDocumentsRequest);
	
	РегистрыСведений.СообщенияОбменаСоСмежнымиСистемами.ДобавитьЗапись(СквознойИдентификаторВызова, "FunctionalElectronicDocuments", "SendFunctionalElectronicDocuments", "Входящее", ТекстСообщения);
	
	DocumentHeader  = SendFunctionalElectronicDocumentsRequest.FunctionalElectronicDocumentHeader;
	DocumentMessage = SendFunctionalElectronicDocumentsRequest.FunctionalElectronicDocumentMessage;
	OrderHeader = DocumentMessage.Order_Header;
	
	СтруктураДокумента = СформироватьСтруктуруДокумента(DocumentMessage, DocumentHeader);
	Если СтруктураДокумента.ТекстДокумента <> "" Тогда
		Ошибка = Обработки.ЭкспортПорученийВЛуч.СформироватьИсходящийПакетВФайловыйШлюз(DocumentHeader.OrderId, DocumentHeader.OrderDate, DocumentHeader.OrderType, OrderHeader.order_t_id, , СтруктураДокумента.ТекстДокумента);
		Если Ошибка = Неопределено Тогда
			Возврат ОтветВебСервиса(СквознойИдентификаторВызова, 0, "");
		Иначе
			Возврат ОтветВебСервиса(СквознойИдентификаторВызова, -1, Ошибка.СообщениеПользователю);
		КонецЕсли; 
	Иначе
		Возврат ОтветВебСервиса(СквознойИдентификаторВызова, -1, СтруктураДокумента.Ошибка);
	КонецЕсли; 
	
	Возврат ОтветВебСервиса(СквознойИдентификаторВызова, 0, "");
КонецФункции

Функция GetFunctionalElectronicDocumentsStatus(DocumentHeaderParam)
	
	СквознойИдентификаторВызова = DocumentHeaderParam.CallId;
	
	Если НЕ ПолучитьФункциональнуюОпцию("ИспользоватьФайловыйШлюзДляОтправкиПоручений") Тогда
		Возврат ОтветВебСервиса(СквознойИдентификаторВызова, -1,
			"Функциональная опция ""ИспользоватьФайловыйШлюзДляОтправкиПоручений"" выключена");
	КонецЕсли;
	
	ВремяНачалаWSGetFunctionalElectronicDocumentsStatus = ОценкаПроизводительности.НачатьЗамерВремени();
	
	RequestStatusType = ФабрикаXDTO.Тип("http://www.vtbcapital-broker.com/depo/FunctionalElectronicDocuments",
		"SendFunctionalElectronicDocumentsRequestStatusType");
	HeaderType = ФабрикаXDTO.Тип("http://www.vtbcapital-broker.com/depo/FunctionalElectronicDocuments",
		"FunctionalElectronicDocumentHeaderType");
	StatusMessageType = ФабрикаXDTO.Тип("http://www.vtbcapital-broker.com/depo/FunctionalElectronicDocuments",
		"FunctionalElectronicDocumentStatusMessageType");
		
	DistributedSeqAmountType = ФабрикаXDTO.Тип("http://www.vtbcapital-broker.com/depo/FunctionalElectronicDocuments",
		"DistributedSeqAmountType");
	
	RequestStatus	= ФабрикаXDTO.Создать(RequestStatusType);
	DocumentHeader	= ФабрикаXDTO.Создать(HeaderType);
	StatusMessage	= ФабрикаXDTO.Создать(StatusMessageType);
	
	Поручение = ПоручениеПоНомеруСделкиВБО(DocumentHeaderParam.OrderId, DocumentHeaderParam.OrderDate);
	Если ЗначениеЗаполнено(Поручение) Тогда
		РасчетыНаDMA = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Поручение, "РасчетыНаDMA");
		Если РасчетыНаDMA Тогда
			Данные = ДанныеИсполненийПоручений(Поручение);
		Иначе
			Данные = ДанныеСтатусовПоручений(Поручение);
		КонецЕсли;
	Иначе
		РасчетыНаDMA = Истина;
		Данные = ДанныеВходящихПакетов(DocumentHeaderParam.OrderId, DocumentHeaderParam.OrderDate);
	КонецЕсли;
	
	Выборка = Данные.ЗапросМаксимальноеКоличествоОтчета.Выбрать();
	Если Выборка.Следующий() Тогда
		МаксимальноеКоличествоОтчета = СтрокуВЧисло(Выборка.МаксимальноеКоличествоОтчета);
	Иначе
		МаксимальноеКоличествоОтчета = 0;
	КонецЕсли;
	
	Выборка = Данные.ЗапросВходящийРегНомер.Выбрать();
	Если Выборка.Следующий() Тогда
		StatusMessage.InRegNumber = Выборка.ВходящийРегНомер;
	КонецЕсли;
	
	Выборка = Данные.ЗапросРаспределенныеКоличества.Выбрать();
	Пока Выборка.Следующий() Цикл
		// Ограничение количества отчета НРД (актуально при избыточном количестве для клиентских сделок)
		КоличествоОтчета = СтрокуВЧисло(Выборка.КоличествоОтчета);
		КоличествоОтчета = Мин(КоличествоОтчета, МаксимальноеКоличествоОтчета);
		МаксимальноеКоличествоОтчета = МаксимальноеКоличествоОтчета - КоличествоОтчета;
		
		// Отбор возвращаемых строк по дате среза LastReportDate только для расчетов на DMA
		Если Не РасчетыНаDMA
			Или (Не ЗначениеЗаполнено(DocumentHeaderParam.LastReportDate)
					Или Выборка.ДатаПакета > DocumentHeaderParam.LastReportDate) Тогда
			
			СтрокаXDTO = ФабрикаXDTO.Создать(DistributedSeqAmountType);
			СтрокаXDTO.Status		= СтатусЧислом(Выборка.Статус);
			СтрокаXDTO.Description	= Выборка.Комментарий;
			СтрокаXDTO.reg_no		= Выборка.КодОтчетаВышестоящегоДепозитария;
			СтрокаXDTO.reg_date		= Выборка.ДатаИсполнения;
			СтрокаXDTO.PacketDate	= Выборка.ДатаПакета;
			СтрокаXDTO.ExecutedAmount	= ЧислоСтрокой(Выборка.ИсполненноеКоличество);
			СтрокаXDTO.ReportAmount		= ЧислоСтрокой(КоличествоОтчета);
			СтрокаXDTO.OperationReportNumber	= Выборка.НомерОтчетаОСовершеннойОперации;
			СтрокаXDTO.OperationReportDate		= Выборка.ДатаОтчетаОСовершеннойОперации;
			
			ОбработатьНеопределенныеЗначения(СтрокаXDTO);
			
			StatusMessage.DistributedSeqAmountRows.Добавить(СтрокаXDTO);
		КонецЕсли;
	КонецЦикла;
	
	ЗаполнитьЗначенияСвойств(DocumentHeader, DocumentHeaderParam);
		
	RequestStatus.FunctionalElectronicDocumentHeader = DocumentHeader;
	RequestStatus.FunctionalElectronicDocumentStatusMessage = StatusMessage;
	
	ОценкаПроизводительности.ЗакончитьЗамерВремени("ВыполнениеWSGetFunctionalElectronicDocumentsStatus", ВремяНачалаWSGetFunctionalElectronicDocumentsStatus);
	
	Возврат RequestStatus;
	
КонецФункции

Функция ЧислоСтрокой(Данные)
	
	Если ТипЗнч(Данные) = Тип("Строка") Тогда
		Возврат СтрЗаменить(Данные, " ", "");		
	ИначеЕсли ТипЗнч(Данные) = Тип("Число") Тогда
		Возврат Формат(Данные, "ЧГ=0");
	Иначе
		Возврат "0";
	КонецЕсли;
	
КонецФункции

Функция СтрокуВЧисло(Знач Данные)
	
	Если ТипЗнч(Данные) = Тип("Число") Тогда
		Возврат Данные;
		
	ИначеЕсли ТипЗнч(Данные) = Тип("Строка") Тогда
		Данные = СтрЗаменить(Данные, " ", "");
		Если Данные = "" Тогда
			Данные = "0";
		КонецЕсли;
		Возврат Число(Данные);
		
	Иначе
		Возврат 0;
	КонецЕсли;
	
КонецФункции

Функция ПоручениеПоНомеруСделкиВБО(Номер, Дата)
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	Поручение.Ссылка КАК Поручение
	|ИЗ
	|	Документ.Поручение КАК Поручение
	|ГДЕ
	|	Поручение.НомерПорученияВБО = &Номер
	|	И НАЧАЛОПЕРИОДА(Поручение.Дата, ГОД) = НАЧАЛОПЕРИОДА(&Дата, ГОД)
	|	И НЕ Поручение.ПометкаУдаления
	|
	|УПОРЯДОЧИТЬ ПО
	|	Поручение.Дата УБЫВ";
	Запрос.УстановитьПараметр("Номер",	Номер);
	Запрос.УстановитьПараметр("Дата",	Дата);
	Результат = Запрос.Выполнить();
	Если НЕ Результат.Пустой() Тогда
		Выборка = Результат.Выбрать();
		Если Выборка.Следующий() Тогда
			Возврат Выборка.Поручение;
		КонецЕсли;
	КонецЕсли;
	Возврат Документы.Поручение.ПустаяСсылка();
	
КонецФункции

Функция ДанныеИсполненийПоручений(Поручение)
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	ТабЧастьПоручения.Ссылка КАК НеттоПоручение,
	|	ТабЧастьПоручения.Ссылка.Количество КАК Количество
	|ПОМЕСТИТЬ втНеттоПоручение
	|ИЗ
	|	Документ.НеттоПоручение.Поручения КАК ТабЧастьПоручения
	|ГДЕ
	|	ТабЧастьПоручения.Поручение = &Поручение
	|	И НЕ ТабЧастьПоручения.Ссылка.ПометкаУдаления
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	втНеттоПоручение.Количество КАК МаксимальноеКоличествоОтчета
	|ИЗ
	|	втНеттоПоручение КАК втНеттоПоручение
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ ПЕРВЫЕ 1
	|	ТехОперация.Ссылка КАК Документ,
	|	ТехОперация.РегистрационныйНомер КАК РегистрационныйНомер
	|ПОМЕСТИТЬ втТехОперация
	|ИЗ
	|	Документ.ТехническаяОперация КАК ТехОперация
	|ГДЕ
	|	НЕ ТехОперация.ПометкаУдаления
	|	И ВЫРАЗИТЬ(ТехОперация.ДокументОснование КАК Документ.НеттоПоручение) В
	|			(ВЫБРАТЬ
	|				втНеттоПоручение.НеттоПоручение
	|			ИЗ
	|				втНеттоПоручение КАК втНеттоПоручение)
	|
	|УПОРЯДОЧИТЬ ПО
	|	ТехОперация.Дата УБЫВ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	втТехОперация.РегистрационныйНомер КАК ВходящийРегНомер
	|ИЗ
	|	втТехОперация КАК втТехОперация
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Состояния.Пакет.НомерВходящегоДокумента КАК НомерВходящегоДокумента,
	|	Состояния.Пакет.ДатаВходящегоДокумента КАК ДатаВходящегоДокумента,
	|	Состояния.Пакет.Дата КАК ДатаПакета
	|ПОМЕСТИТЬ втДатыПакетов
	|ИЗ
	|	РегистрСведений.СостоянияДокументовВФайловомШлюзе КАК Состояния
	|ГДЕ
	|	Состояния.Статус В(&СтатусыИсполненияВФайловомШлюзе)
	|	И Состояния.Документ В
	|			(ВЫБРАТЬ
	|				втТехОперация.Документ
	|			ИЗ
	|				втТехОперация КАК втТехОперация)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ОстаткиЦБ.Статус КАК Статус,
	|	ОстаткиЦБ.Ссылка.Комментарий КАК Комментарий,
	|	ОстаткиЦБ.Ссылка.КодОтчетаВышестоящегоДепозитария КАК КодОтчетаВышестоящегоДепозитария,
	|	ОстаткиЦБ.Ссылка.Дата КАК ДатаИсполнения,
	|	ЕСТЬNULL(втДатыПакетов.ДатаПакета, ОстаткиЦБ.Ссылка.Дата) КАК ДатаПакета,
	|	ОстаткиЦБ.КоличествоОтчета КАК ИсполненноеКоличество,
	|	ОстаткиЦБ.Ссылка.Количество КАК КоличествоОтчета,
	|	Выписка.Номер КАК НомерОтчетаОСовершеннойОперации,
	|	Выписка.Дата КАК ДатаОтчетаОСовершеннойОперации
	|ПОМЕСТИТЬ втИсполнения
	|ИЗ
	|	Документ.ИсполнениеПоручения.ОстаткиЦБ КАК ОстаткиЦБ
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.Выписка КАК Выписка
	|		ПО (Выписка.ДокументОснование = &Поручение)
	|			И (Выписка.Проведен)
	|			И (ВЫРАЗИТЬ(Выписка.ОперацияЦБ КАК Документ.ОперацииЦБ).Дата = ОстаткиЦБ.Ссылка.Дата)
	|			И (ВЫРАЗИТЬ(Выписка.ОперацияЦБ КАК Документ.ОперацииЦБ).Количество = ОстаткиЦБ.КоличествоОтчета)
	|			И (ВЫРАЗИТЬ(Выписка.ОперацияЦБ КАК Документ.ОперацииЦБ).Проведен)
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.РегистрацияДокументовВЭДО КАК РегистрацияДокументовВЭДО
	|		ПО (РегистрацияДокументовВЭДО.Документ = Выписка.Ссылка)
	|		ЛЕВОЕ СОЕДИНЕНИЕ втДатыПакетов КАК втДатыПакетов
	|		ПО (втДатыПакетов.НомерВходящегоДокумента = ОстаткиЦБ.Ссылка.КодОтчетаВышестоящегоДепозитария)
	|			И (втДатыПакетов.ДатаВходящегоДокумента = ОстаткиЦБ.Ссылка.Дата)
	|ГДЕ
	|	ОстаткиЦБ.Ссылка.Проведен
	|	И ОстаткиЦБ.Поручение = &Поручение
	|	И ОстаткиЦБ.Ссылка.ДокументОснование В
	|			(ВЫБРАТЬ
	|				втНеттоПоручение.НеттоПоручение
	|			ИЗ
	|				втНеттоПоручение КАК втНеттоПоручение)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Состояния.Статус КАК Статус,
	|	Состояния.Комментарий КАК Комментарий,
	|	Состояния.Документ.КодОтчетаНРД КАК КодОтчетаВышестоящегоДепозитария,
	|	Состояния.Документ.ДатаИсполнения КАК ДатаИсполнения,
	|	ЕСТЬNULL(Состояния.Пакет.Дата, ДАТАВРЕМЯ(1, 1, 1)) КАК ДатаПакета
	|ПОМЕСТИТЬ втСостоянияФШ
	|ИЗ
	|	РегистрСведений.СостоянияДокументовВФайловомШлюзе.СрезПоследних(
	|			,
	|			Документ В
	|					(ВЫБРАТЬ
	|						втТехОперация.Документ
	|					ИЗ
	|						втТехОперация КАК втТехОперация)
	|				И НЕ Статус В (&СтатусыИсполненияВФайловомШлюзе)) КАК Состояния
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЕСТЬNULL(втИсполнения.Статус, втСостоянияФШ.Статус) КАК Статус,
	|	ЕСТЬNULL(втИсполнения.Комментарий, втСостоянияФШ.Комментарий) КАК Комментарий,
	|	ЕСТЬNULL(втИсполнения.КодОтчетаВышестоящегоДепозитария, втСостоянияФШ.КодОтчетаВышестоящегоДепозитария) КАК КодОтчетаВышестоящегоДепозитария,
	|	ЕСТЬNULL(втИсполнения.ДатаИсполнения, втСостоянияФШ.ДатаИсполнения) КАК ДатаИсполнения,
	|	ЕСТЬNULL(втИсполнения.ДатаПакета, втСостоянияФШ.ДатаПакета) КАК ДатаПакета,
	|	ЕСТЬNULL(втИсполнения.ИсполненноеКоличество, 0) КАК ИсполненноеКоличество,
	|	ЕСТЬNULL(втИсполнения.КоличествоОтчета, 0) КАК КоличествоОтчета,
	|	ЕСТЬNULL(втИсполнения.НомерОтчетаОСовершеннойОперации, """") КАК НомерОтчетаОСовершеннойОперации,
	|	ЕСТЬNULL(втИсполнения.ДатаОтчетаОСовершеннойОперации, ДАТАВРЕМЯ(1, 1, 1)) КАК ДатаОтчетаОСовершеннойОперации
	|ИЗ
	|	втСостоянияФШ КАК втСостоянияФШ
	|		ПОЛНОЕ СОЕДИНЕНИЕ втИсполнения КАК втИсполнения
	|		ПО (ИСТИНА)
	|
	|УПОРЯДОЧИТЬ ПО
	|	ЕСТЬNULL(втИсполнения.ДатаИсполнения, втСостоянияФШ.ДатаИсполнения)";
	Запрос.УстановитьПараметр("Поручение",	Поручение);
	
	СтатусыИсполненияВФайловомШлюзе = Новый Массив;
	СтатусыИсполненияВФайловомШлюзе.Добавить(Перечисления.СтатусыДокументовФайловыйШлюз.Исполнено);
	СтатусыИсполненияВФайловомШлюзе.Добавить(Перечисления.СтатусыДокументовФайловыйШлюз.ИсполненоЧастично);
	Запрос.УстановитьПараметр("СтатусыИсполненияВФайловомШлюзе", СтатусыИсполненияВФайловомШлюзе);
	
	НачатьТранзакцию();
	РезультатыЗапроса = Запрос.ВыполнитьПакет();
	ЗафиксироватьТранзакцию();
	
	Возврат Новый Структура("ЗапросМаксимальноеКоличествоОтчета, ЗапросВходящийРегНомер, ЗапросРаспределенныеКоличества",
		РезультатыЗапроса[1], РезультатыЗапроса[3], РезультатыЗапроса[7]);
	
КонецФункции

Функция ДанныеВходящихПакетов(Номер, Дата)
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"//00//////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ ПЕРВЫЕ 1
	|	ТехОперация.Ссылка КАК Документ,
	|	ТехОперация.РегистрационныйНомер КАК ВходящийРегНомер
	|ПОМЕСТИТЬ втТехОперации
	|ИЗ
	|	Документ.ТехническаяОперация КАК ТехОперация
	|ГДЕ
	|	ТехОперация.НомерДокументаОснования = &Номер
	|	И НАЧАЛОПЕРИОДА(ТехОперация.Дата, ГОД) = НАЧАЛОПЕРИОДА(&Дата, ГОД)
	|	И НЕ ТехОперация.ПометкаУдаления
	|
	|УПОРЯДОЧИТЬ ПО
	|	ТехОперация.Дата УБЫВ
	|;
	|
	|//01//////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	втТехОперации.ВходящийРегНомер КАК ВходящийРегНомер
	|ИЗ
	|	втТехОперации КАК втТехОперации
	|;
	|
	|//02//////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЕСТЬNULL(СУММА(ЗапросКоличество.КоличествоИсполнения), 0) КАК МаксимальноеКоличествоОтчета
	|ИЗ
	|	(ВЫБРАТЬ
	|		Состояния.КоличествоИсполнения КАК КоличествоИсполнения
	|	ИЗ
	|		РегистрСведений.СостоянияДокументовВФайловомШлюзе КАК Состояния
	|	ГДЕ
	|		Состояния.Статус В (&СтатусыИсполненияВФайловомШлюзе)
	|		И Состояния.Документ В
	|			(ВЫБРАТЬ
	|				втТехОперации.Документ
	|			ИЗ
	|				втТехОперации КАК втТехОперации)) КАК ЗапросКоличество
	|;
	|
	|//03//////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Состояния.Статус КАК Статус,
	|	Состояния.Комментарий КАК Комментарий,
	|	ВЫБОР
	|		КОГДА Состояния.Статус В (&СтатусыИсполненияВФайловомШлюзе)
	|			ТОГДА Состояния.Пакет.НомерВходящегоДокумента
	|		ИНАЧЕ Состояния.Документ.КодОтчетаНРД
	|	КОНЕЦ КАК КодОтчетаВышестоящегоДепозитария,
	|	ВЫБОР
	|		КОГДА Состояния.Статус В (&СтатусыИсполненияВФайловомШлюзе)
	|			ТОГДА Состояния.Пакет.ДатаВходящегоДокумента
	|		ИНАЧЕ Состояния.Документ.ДатаИсполнения
	|	КОНЕЦ КАК ДатаИсполнения,
	|	ЕСТЬNULL(Состояния.Пакет.Дата, ДАТАВРЕМЯ(1,1,1)) КАК ДатаПакета,
	|	Состояния.КоличествоИсполнения КАК ИсполненноеКоличество,
	|	Состояния.КоличествоИсполнения КАК КоличествоОтчета,
	|	"""" КАК НомерОтчетаОСовершеннойОперации,
	|	ДАТАВРЕМЯ(1,1,1) КАК ДатаОтчетаОСовершеннойОперации
	|ИЗ
	|	РегистрСведений.СостоянияДокументовВФайловомШлюзе КАК Состояния
	|ГДЕ
	|	Состояния.Документ В
	|		(ВЫБРАТЬ
	|			втТехОперации.Документ
	|		ИЗ
	|			втТехОперации КАК втТехОперации)
	|
	|УПОРЯДОЧИТЬ ПО
	|	Состояния.Период
	|";
	Запрос.УстановитьПараметр("Номер",	Номер);
	Запрос.УстановитьПараметр("Дата",	Дата);

	СтатусыИсполненияВФайловомШлюзе = Новый Массив;
	СтатусыИсполненияВФайловомШлюзе.Добавить(Перечисления.СтатусыДокументовФайловыйШлюз.Исполнено);
	СтатусыИсполненияВФайловомШлюзе.Добавить(Перечисления.СтатусыДокументовФайловыйШлюз.ИсполненоЧастично);
	Запрос.УстановитьПараметр("СтатусыИсполненияВФайловомШлюзе", СтатусыИсполненияВФайловомШлюзе);
	
	НачатьТранзакцию();
	РезультатыЗапроса = Запрос.ВыполнитьПакет();
	ЗафиксироватьТранзакцию();
	
	Возврат Новый Структура("ЗапросВходящийРегНомер, ЗапросМаксимальноеКоличествоОтчета, ЗапросРаспределенныеКоличества",
		РезультатыЗапроса[1], РезультатыЗапроса[2], РезультатыЗапроса[3]);
	
КонецФункции

Функция ДанныеСтатусовПоручений(Поручение)
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	"""" КАК ВходящийРегНомер
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	""0"" КАК МаксимальноеКоличествоОтчета
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ ПЕРВЫЕ 1
	|	ТехОперация.Ссылка КАК Документ
	|ПОМЕСТИТЬ втТехОперация
	|ИЗ
	|	Документ.ТехническаяОперация КАК ТехОперация
	|ГДЕ
	|	НЕ ТехОперация.ПометкаУдаления
	|	И ТехОперация.ДокументОснование = &Поручение
	|
	|УПОРЯДОЧИТЬ ПО
	|	ТехОперация.Дата УБЫВ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Состояния.Статус КАК Статус,
	|	Состояния.Комментарий КАК Комментарий,
	|	ВЫБОР
	|		КОГДА ТИПЗНАЧЕНИЯ(Состояния.Пакет) = ТИП(Документ.ВходящийПакетИзФайловогоШлюза)
	|			ТОГДА ВЫРАЗИТЬ(Состояния.Пакет КАК Документ.ВходящийПакетИзФайловогоШлюза).НомерВходящегоДокумента
	|		ИНАЧЕ """"
	|	КОНЕЦ КАК КодОтчетаВышестоящегоДепозитария,
	|	ВЫБОР
	|		КОГДА ТИПЗНАЧЕНИЯ(Состояния.Пакет) = ТИП(Документ.ВходящийПакетИзФайловогоШлюза)
	|			ТОГДА ВЫРАЗИТЬ(Состояния.Пакет КАК Документ.ВходящийПакетИзФайловогоШлюза).ДатаВходящегоДокумента
	|		ИНАЧЕ ДАТАВРЕМЯ(1, 1, 1)
	|	КОНЕЦ КАК ДатаИсполнения,
	|	ЕСТЬNULL(Состояния.Пакет.Дата, ДАТАВРЕМЯ(1, 1, 1)) КАК ДатаПакета,
	|	0 КАК ИсполненноеКоличество,
	|	0 КАК КоличествоОтчета,
	|	"""" КАК НомерОтчетаОСовершеннойОперации,
	|	ДАТАВРЕМЯ(1, 1, 1) КАК ДатаОтчетаОСовершеннойОперации
	|ИЗ
	|	РегистрСведений.СостоянияДокументовВФайловомШлюзе.СрезПоследних(
	|			,
	|			Документ В
	|				(ВЫБРАТЬ
	|					втТехОперация.Документ
	|				ИЗ
	|					втТехОперация КАК втТехОперация)) КАК Состояния
	|ГДЕ
	|	Состояния.Статус <> &Исполнено
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	&Исполнено,
	|	"""",
	|	ДокументПоручение.КодОтчетаНРД,
	|	ДокументПоручение.ДатаИсполненияПоручения,
	|	ДАТАВРЕМЯ(1, 1, 1),
	|	0,
	|	0,
	|	"""",
	|	ДАТАВРЕМЯ(1, 1, 1)
	|ИЗ
	|	Документ.Поручение КАК ДокументПоручение
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.СтатусыПорученийВСЭД.СрезПоследних КАК Документооборот
	|		ПО ДокументПоручение.Ссылка = Документооборот.Поручение
	|			И (Документооборот.Статус В (&СтатусыСЭД))
	|ГДЕ
	|	ДокументПоручение.Ссылка = &Поручение
	|	И ДокументПоручение.ДатаИсполненияПоручения <> ДАТАВРЕМЯ(1, 1, 1)";
	
	Запрос.УстановитьПараметр("Исполнено", Перечисления.СтатусыДокументовФайловыйШлюз.Исполнено);
	СтатусыСЭД = Новый Массив;
	СтатусыСЭД.Добавить(Перечисления.СтатусыДокументовВСЭД.Загружено);
	СтатусыСЭД.Добавить(Перечисления.СтатусыДокументовВСЭД.Подписано);
	Запрос.УстановитьПараметр("СтатусыСЭД", СтатусыСЭД);
	
	Запрос.УстановитьПараметр("Поручение", Поручение);
	
	НачатьТранзакцию();
	РезультатыЗапроса = Запрос.ВыполнитьПакет();
	ЗафиксироватьТранзакцию();
	
	Возврат Новый Структура("ЗапросВходящийРегНомер, ЗапросМаксимальноеКоличествоОтчета, ЗапросРаспределенныеКоличества",
	РезультатыЗапроса[0], РезультатыЗапроса[1], РезультатыЗапроса[3]);
	
КонецФункции

Процедура ОбработатьНеопределенныеЗначения(StatusMessage)
	
	Если StatusMessage.Status = Неопределено Тогда
		StatusMessage.Status = -1;
	КонецЕсли;
	
	Если StatusMessage.Description = Неопределено Тогда
		StatusMessage.Description = "";
	КонецЕсли;
	
	Если StatusMessage.reg_no = Неопределено Тогда
		StatusMessage.reg_no = "";
	КонецЕсли;
	
	Если StatusMessage.reg_date = Неопределено Тогда
		StatusMessage.reg_date = Дата(1,1,1);
	КонецЕсли;
	
КонецПроцедуры

Функция GetFunctionalElectronicDocumentsStatusMulti(DocumentHeader)
	СквознойИдентификаторВызова = DocumentHeader.CallId;
	
	Если НЕ ПолучитьФункциональнуюОпцию("ИспользоватьФайловыйШлюзДляОтправкиПоручений") Тогда 
		Возврат ОтветВебСервиса(СквознойИдентификаторВызова, -1, "Функциональная опция ""ИспользоватьФайловыйШлюзДляОтправкиПоручений"" выключена");
	КонецЕсли;
	
	RequestStatusType = ФабрикаXDTO.Тип("http://www.vtbcapital-broker.com/depo/FunctionalElectronicDocuments", "SendFunctionalElectronicDocumentsRequestStatusMultiType");
	FunctionalElectronicDocumentHeaderType = ФабрикаXDTO.Тип("http://www.vtbcapital-broker.com/depo/FunctionalElectronicDocuments", "FunctionalElectronicDocumentHeaderMultiType");
	FunctionalElectronicDocumentStatusMessageType = ФабрикаXDTO.Тип("http://www.vtbcapital-broker.com/depo/FunctionalElectronicDocuments", "FunctionalElectronicDocumentMultiStatusMessageType");
	
	RequestStatus = ФабрикаXDTO.Создать(RequestStatusType);
	FunctionalElectronicDocumentHeader = ФабрикаXDTO.Создать(FunctionalElectronicDocumentHeaderType);
	FunctionalElectronicDocumentStatusMessage = ФабрикаXDTO.Создать(FunctionalElectronicDocumentStatusMessageType);
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Номер", DocumentHeader.OrderId);
	Запрос.УстановитьПараметр("Количество", DocumentHeader.SeqAmo);
	Запрос.УстановитьПараметр("ЭлементКоличество", "SEQ_AMO");
	Запрос.УстановитьПараметр("СтатусИсполнено", Перечисления.СтатусыДокументовФайловыйШлюз.Исполнено);
	Запрос.Текст = 
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	ТехническаяОперация.Ссылка КАК Документ
	|ПОМЕСТИТЬ ВТ_ТехническиеОперации
	|ИЗ
	|	Документ.ТехническаяОперация КАК ТехническаяОперация
	|ГДЕ
	|	ТехническаяОперация.НомерДокументаОснования = &Номер
	|
	|УПОРЯДОЧИТЬ ПО
	|	ТехническаяОперация.Дата УБЫВ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_ТехническиеОперации.Документ КАК Документ,
	|	ВходящийПакетИзФайловогоШлюзаСодержимоеФайла.Ссылка КАК ВходящийПакет
	|ПОМЕСТИТЬ ВТ_ВходящиеПакетыФШ
	|ИЗ
	|	ВТ_ТехническиеОперации КАК ВТ_ТехническиеОперации
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ВходящийПакетИзФайловогоШлюза.СодержимоеФайла КАК ВходящийПакетИзФайловогоШлюзаСодержимоеФайла
	|		ПО (ВходящийПакетИзФайловогоШлюзаСодержимоеФайла.Ссылка.ДокументОснование = ВТ_ТехническиеОперации.Документ)
	|ГДЕ
	|	НЕ ВходящийПакетИзФайловогоШлюзаСодержимоеФайла.Ссылка ЕСТЬ NULL 
	|	И ВходящийПакетИзФайловогоШлюзаСодержимоеФайла.Значение = &Количество
	|	И ВходящийПакетИзФайловогоШлюзаСодержимоеФайла.Элемент = &ЭлементКоличество
	|	И ВходящийПакетИзФайловогоШлюзаСодержимоеФайла.Ссылка.Статус = &СтатусИсполнено
	|	И НЕ ВходящийПакетИзФайловогоШлюзаСодержимоеФайла.Ссылка.ОбработанMulti
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ ПЕРВЫЕ 1
	|	ВТ_ВходящиеПакетыФШ.Документ КАК Документ,
	|	ВТ_ВходящиеПакетыФШ.ВходящийПакет КАК ВходящийПакет,
	|	TREG_DATE.Значение КАК TREG_DATE,
	|	REPORT_ID.Значение КАК REPORT_ID,
	|	REG_DATE.Значение КАК REG_DATE,
	|	REG_NO.Значение КАК РегистрационныйНомер,
	|	ВТ_ВходящиеПакетыФШ.ВходящийПакет.Статус КАК Статус
	|ИЗ
	|	ВТ_ВходящиеПакетыФШ КАК ВТ_ВходящиеПакетыФШ
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ВходящийПакетИзФайловогоШлюза.СодержимоеФайла КАК REG_DATE
	|		ПО ВТ_ВходящиеПакетыФШ.ВходящийПакет = REG_DATE.Ссылка
	|			И (REG_DATE.Элемент = ""REG_DATE"")
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ВходящийПакетИзФайловогоШлюза.СодержимоеФайла КАК TREG_DATE
	|		ПО ВТ_ВходящиеПакетыФШ.ВходящийПакет = TREG_DATE.Ссылка
	|			И (TREG_DATE.Элемент = ""TREG_DATE"")
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ВходящийПакетИзФайловогоШлюза.СодержимоеФайла КАК REPORT_ID
	|		ПО ВТ_ВходящиеПакетыФШ.ВходящийПакет = REPORT_ID.Ссылка
	|			И (REPORT_ID.Элемент = ""REPORT_ID"")
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ВходящийПакетИзФайловогоШлюза.СодержимоеФайла КАК REG_NO
	|		ПО ВТ_ВходящиеПакетыФШ.ВходящийПакет = REG_NO.Ссылка
	|			И (REG_NO.Элемент = ""REG_NO"")
	|ГДЕ
	|	НЕ TREG_DATE.Ссылка ЕСТЬ NULL 
	|	И НЕ REPORT_ID.Ссылка ЕСТЬ NULL 
	|	И НЕ REG_DATE.Ссылка ЕСТЬ NULL 
	|	И НЕ REG_NO.Ссылка ЕСТЬ NULL 
	|
	|УПОРЯДОЧИТЬ ПО
	|	РегистрационныйНомер,
	|	REG_DATE,
	|	TREG_DATE,
	|	REPORT_ID";
	
	Результат = Запрос.Выполнить();
	Выборка = Результат.Выбрать();
	
	Если Выборка.Следующий() Тогда
		FunctionalElectronicDocumentStatusMessage.Status = СтатусЧислом(Выборка.Статус);
		FunctionalElectronicDocumentStatusMessage.Description = "";
		FunctionalElectronicDocumentStatusMessage.reg_no = Выборка.РегистрационныйНомер;
		FunctionalElectronicDocumentStatusMessage.ReportId = Выборка.REPORT_ID;
		ДатаРегистрации = Выборка.REG_DATE+Сред(Выборка.TREG_DATE,0,2)*3600+Сред(Выборка.TREG_DATE,4,2)*60+Сред(Выборка.TREG_DATE,7,2);
		FunctionalElectronicDocumentStatusMessage.reg_date = ДатаРегистрации;
	КонецЕсли;
	
	ЗаполнитьЗначенияСвойств(FunctionalElectronicDocumentHeader, DocumentHeader);
	Если FunctionalElectronicDocumentStatusMessage.reg_no = Неопределено Тогда
		FunctionalElectronicDocumentStatusMessage.reg_no = "";
	КонецЕсли; 
	Если FunctionalElectronicDocumentStatusMessage.reg_date = Неопределено Тогда
		FunctionalElectronicDocumentStatusMessage.reg_date = Дата(1,1,1);
	КонецЕсли; 
	Если FunctionalElectronicDocumentStatusMessage.Status = Неопределено Тогда
		FunctionalElectronicDocumentStatusMessage.Status = -1;
	КонецЕсли; 
	Если FunctionalElectronicDocumentStatusMessage.Description = Неопределено Тогда
		FunctionalElectronicDocumentStatusMessage.Description = "";
	КонецЕсли;
	Если FunctionalElectronicDocumentStatusMessage.ReportId = Неопределено Тогда
		FunctionalElectronicDocumentStatusMessage.ReportId = 0;
	КонецЕсли;
	
	RequestStatus.FunctionalElectronicDocumentHeader = FunctionalElectronicDocumentHeader;
	RequestStatus.FunctionalElectronicDocumentStatusMessage = FunctionalElectronicDocumentStatusMessage;
	
	Возврат RequestStatus;
КонецФункции

