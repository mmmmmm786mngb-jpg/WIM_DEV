
#Область CSDR

// Функция - Номер технической операции по поручению ДЕПО
//
// Параметры:
//  Поручение	 - 	 - Ссылка на документ Поручение базы ДЕПО
//  Номер		 - 	 - Номер документа ПоручениеДЕПО базы ИЦ
//  Дата		 - 	 - Дата документа ПоручениеДЕПО базы ИЦ
// 
// Возвращаемое значение: Номер (string) документа ТехническаяОперация
//   - 
//
Функция ДанныеТехническойОперацииПоПоручениюДЕПО(Поручение,Номер,Дата)
	// Учесть что нумерация Поручений ДЕПО в пределах года
	// 1.Если поле "ДокументОснование" пустое, поиск документа осуществлять по номеру основания из документа "Тех. операция" или по номеру самого документа "Тех. операция"
	// 2.Если поле "ДокументОснование" заполнено документом "Поручение", поиск документа осуществлять по номеру из реквизита "Входящий номер поручения" документа "Поручение"
	// 3.Если поле "ДокументОснование" заполнено "Нетто-поручение", поиск документа осуществлять по алгоритму: из основания берем документ "Нетто-поручение", 
	// 	из него берем все Поручения из табличной части, в каждом поручении берем "Входящий номер поручения"
	
	// Поручению может быть пустое - тогда по номеру основаня, иначе или Поручение = ДокументОснование или Поручение - в табличной части Нетто-поручения, которое = ДокументОснование
	
	Запрос = новый Запрос;
	Запрос.УстановитьПараметр("Поручение",Поручение);
	Запрос.УстановитьПараметр("Номер"    ,Номер);
	Запрос.УстановитьПараметр("Дата"     ,Дата);
	
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	ТехОперация.Ссылка КАК Документ,
	|	ТехОперация.РегистрационныйНомер КАК РегистрационныйНомер,
	|	ТехОперация.Номер КАК Номер
	|ПОМЕСТИТЬ втТехОперацияБезПоручения
	|ИЗ
	|	Документ.ТехническаяОперация КАК ТехОперация
	|ГДЕ
	|	&Поручение = ЗНАЧЕНИЕ(ДОКУМЕНТ.Поручение.ПустаяСсылка)
	|	И (ТехОперация.НомерДокументаОснования = &Номер
	|			ИЛИ ТехОперация.Номер = &Номер)
	|	И НАЧАЛОПЕРИОДА(ТехОперация.Дата, ГОД) = НАЧАЛОПЕРИОДА(&Дата, ГОД)
	|	И НЕ ТехОперация.ПометкаУдаления
	|
	|УПОРЯДОЧИТЬ ПО
	|	ТехОперация.Дата УБЫВ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ ПЕРВЫЕ 1
	|	ТабЧастьПоручения.Ссылка КАК НеттоПоручение
	|ПОМЕСТИТЬ втНеттоПоручение
	|ИЗ
	|	Документ.НеттоПоручение.Поручения КАК ТабЧастьПоручения
	|ГДЕ
	|	НЕ &Поручение = ЗНАЧЕНИЕ(ДОКУМЕНТ.Поручение.ПустаяСсылка)
	|	И ТабЧастьПоручения.Поручение = &Поручение
	|	И НЕ ТабЧастьПоручения.Ссылка.ПометкаУдаления
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ ПЕРВЫЕ 1
	|	ТехОперация.Ссылка КАК Документ,
	|	ТехОперация.РегистрационныйНомер КАК РегистрационныйНомер,
	|	ТехОперация.Номер КАК Номер
	|ПОМЕСТИТЬ втТехОперацияПоНетоПоручению
	|ИЗ
	|	Документ.ТехническаяОперация КАК ТехОперация
	|ГДЕ
	|	НЕ &Поручение = ЗНАЧЕНИЕ(ДОКУМЕНТ.Поручение.ПустаяСсылка)
	|	И НЕ ТехОперация.ПометкаУдаления
	|	И ВЫРАЗИТЬ(ТехОперация.ДокументОснование КАК Документ.НеттоПоручение) В
	|			(ВЫБРАТЬ
	|				втНеттоПоручение.НеттоПоручение
	|			ИЗ
	|				втНеттоПоручение КАК втНеттоПоручение)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТехОперация.Ссылка КАК Документ,
	|	ТехОперация.РегистрационныйНомер КАК РегистрационныйНомер,
	|	ТехОперация.Номер КАК Номер
	|ПОМЕСТИТЬ втТехОперацияПоПоручению
	|ИЗ
	|	Документ.ТехническаяОперация КАК ТехОперация
	|ГДЕ
	|	НЕ &Поручение = ЗНАЧЕНИЕ(ДОКУМЕНТ.Поручение.ПустаяСсылка)
	|	И (ВЫРАЗИТЬ(ТехОперация.ДокументОснование КАК Документ.Поручение)) = &Поручение
	|	И НЕ ТехОперация.ПометкаУдаления
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	втТехОперацияБезПоручения.Документ КАК Документ,
	|	втТехОперацияБезПоручения.РегистрационныйНомер КАК РегистрационныйНомер,
	|	втТехОперацияБезПоручения.Номер КАК Номер
	|ИЗ
	|	втТехОперацияБезПоручения КАК втТехОперацияБезПоручения
	|
	|ОБЪЕДИНИТЬ
	|
	|ВЫБРАТЬ
	|	втТехОперацияПоНетоПоручению.Документ,
	|	втТехОперацияПоНетоПоручению.РегистрационныйНомер,
	|	втТехОперацияПоНетоПоручению.Номер
	|ИЗ
	|	втТехОперацияПоНетоПоручению КАК втТехОперацияПоНетоПоручению
	|
	|ОБЪЕДИНИТЬ
	|
	|ВЫБРАТЬ
	|	втТехОперацияПоПоручению.Документ,
	|	втТехОперацияПоПоручению.РегистрационныйНомер,
	|	втТехОперацияПоПоручению.Номер
	|ИЗ
	|	втТехОперацияПоПоручению КАК втТехОперацияПоПоручению";
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Результат = Новый Структура("Номер,РегистрационныйНомер","","");
	
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда
		ЗаполнитьЗначенияСвойств(Результат,ВыборкаДетальныеЗаписи);
	КонецЕсли;
	
	AddNumberType = ФабрикаXDTO.Тип("http://www.vtbcapital-broker.com/depo/FunctionalElectronicDocuments",
		"AddNumberType");
	AddNumber	= ФабрикаXDTO.Создать(AddNumberType);
	AddNumber.number = Результат.Номер;
	AddNumber.reg_no = Результат.РегистрационныйНомер;
	
	Возврат AddNumber;
КонецФункции

// Функция - Get functional electronic documents nomer
//
// Параметры:
//  DocumentHeaderParam	 - 	 - Параметры документа(структура) ПоручениеДЕПО (из базы ИЦ): Номер(OrderId),Дата(OrderDate)
// 
// Возвращаемое значение: Номер (string) документа ТехническаяОперация
//   - 
//
Функция GetFunctionalElectronicDocumentsNumber(DocumentHeaderParam)
	
	СквознойИдентификаторВызова = DocumentHeaderParam.CallId;
	
	Если НЕ ПолучитьФункциональнуюОпцию("ИспользоватьФайловыйШлюзДляОтправкиПоручений") Тогда
		Возврат ОтветВебСервиса(СквознойИдентификаторВызова, -1,
			"Функциональная опция ""ИспользоватьФайловыйШлюзДляОтправкиПоручений"" выключена");
	КонецЕсли;
	
	ВремяНачалаWSGetFunctionalElectronicDocumentsNomer = ОценкаПроизводительности.НачатьЗамерВремени();

	Поручение = ПоручениеПоНомеруСделкиВБО(DocumentHeaderParam.OrderId, DocumentHeaderParam.OrderDate);
	
	ДанныеТехническойОперацииПоПоручениюДЕПО = ДанныеТехническойОперацииПоПоручениюДЕПО(Поручение,DocumentHeaderParam.OrderId, DocumentHeaderParam.OrderDate);
	
	ОценкаПроизводительности.ЗакончитьЗамерВремени("ВыполнениеWSGetFunctionalElectronicDocumentsNomer", ВремяНачалаWSGetFunctionalElectronicDocumentsNomer);
	
	Возврат ДанныеТехническойОперацииПоПоручениюДЕПО;

КонецФункции

