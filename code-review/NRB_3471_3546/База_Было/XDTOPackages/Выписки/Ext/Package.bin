<package xmlns="http://v8.1c.ru/8.1/xdto" xmlns:xs="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" targetNamespace="http://www.vtbcapital-broker.com/depo">
	<objectType name="Statement">
		<property name="DateTime" type="xs:dateTime"/>
		<property name="Number" type="xs:string"/>
		<property name="Title" type="xs:string"/>
		<property name="DateBegin" type="xs:date"/>
		<property name="DateEnd" type="xs:date"/>
		<property name="OperationType" type="xs:string"/>
		<property name="Initiator" type="xs:string"/>
		<property name="AccountNo" type="xs:string"/>
		<property name="Depositor" type="xs:string"/>
		<property xmlns:d3p1="http://www.vtbcapital-broker.com/depo" name="BalanceBegin" type="d3p1:BalanceRecords"/>
		<property name="Transactions"/>
		<property xmlns:d3p1="http://www.vtbcapital-broker.com/depo" name="BalanceEnd" type="d3p1:BalanceRecords"/>
	</objectType>
	<objectType name="BalanceRecords">
		<property xmlns:d3p1="http://www.vtbcapital-broker.com/depo" name="BalanceRecord" type="d3p1:BalanceRecord" lowerBound="0" upperBound="-1"/>
	</objectType>
	<objectType name="BalanceRecord">
		<property name="Security"/>
		<property name="StateRegNumber" type="xs:string"/>
		<property name="StoragePlace" type="xs:string"/>
		<property name="AccountSection"/>
		<property name="FreeQuantity"/>
		<property name="BlockedQuantity"/>
		<property name="PledgedQuantity"/>
		<property name="NonClosedOperationsQuantity"/>
	</objectType>
	<objectType name="Transaction">
		<property name="DateTime" type="xs:dateTime"/>
		<property name="Number" type="xs:string"/>
		<property name="Type" type="xs:string"/>
		<property name="Security"/>
		<property name="StateRegNumber" type="xs:string"/>
		<property name="Receipt" type="xs:decimal"/>
		<property name="Expense" type="xs:decimal"/>
		<property name="BasedOn"/>
	</objectType>
	<objectType name="Transactions">
		<property xmlns:d3p1="http://www.vtbcapital-broker.com/depo" name="Transaction" type="d3p1:Transaction" lowerBound="0" upperBound="-1"/>
	</objectType>
</package>