<package xmlns="http://v8.1c.ru/8.1/xdto" xmlns:xs="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" targetNamespace="VO_CIK_CB_7.xsd">
	<property name="Файл">
		<typeDef xsi:type="ObjectType">
			<property name="ВерсФорм" type="xs:string" lowerBound="1" form="Attribute"/>
			<property name="ТипИнф" type="xs:string" lowerBound="1" form="Attribute"/>
			<property name="ВерсПрог" type="xs:string" lowerBound="1" form="Attribute"/>
			<property name="ИдФайл" type="xs:string" lowerBound="1" form="Attribute"/>
			<property name="Запрос">
				<typeDef xsi:type="ObjectType">
					<property name="Ид" type="xs:string" lowerBound="1" form="Attribute"/>
					<property xmlns:d6p1="VO_CIK_CB_7.xsd" name="Дата" type="d6p1:ДатаТип" lowerBound="1" form="Attribute"/>
				</typeDef>
			</property>
			<property name="ИнфОрг" lowerBound="0">
				<typeDef xsi:type="ObjectType">
					<property name="Название" type="xs:string" lowerBound="1" form="Attribute"/>
					<property name="Адрес" type="xs:string" lowerBound="1" form="Attribute"/>
					<property name="ИНН" type="xs:string" lowerBound="1" form="Attribute"/>
					<property name="ОГРН" type="xs:string" lowerBound="1" form="Attribute"/>
					<property name="ФИО" type="xs:string" lowerBound="1" form="Attribute"/>
					<property name="Телефон" type="xs:string" lowerBound="1" form="Attribute"/>
					<property name="ЭлПочта" type="xs:string" lowerBound="1" form="Attribute"/>
				</typeDef>
			</property>
			<property name="Персона" upperBound="-1">
				<typeDef xsi:type="ObjectType">
					<property name="Ид" type="xs:string" lowerBound="1" form="Attribute"/>
					<property name="ПерсИнфо">
						<typeDef xsi:type="ObjectType">
							<property name="ФИОД">
								<typeDef xsi:type="ObjectType">
									<property name="Фамилия" type="xs:string" lowerBound="1" form="Attribute"/>
									<property name="Имя" type="xs:string" lowerBound="1" form="Attribute"/>
									<property name="Отчество" type="xs:string" lowerBound="1" form="Attribute"/>
									<property xmlns:d10p1="VO_CIK_CB_7.xsd" name="ДатаРожд" type="d10p1:ДатаТип" lowerBound="0" form="Attribute"/>
								</typeDef>
							</property>
							<property name="Документ">
								<typeDef xsi:type="ObjectType">
									<property name="КодВидДок" type="xs:string" lowerBound="1" form="Attribute"/>
									<property name="Серия" type="xs:string" lowerBound="1" form="Attribute"/>
									<property name="Номер" type="xs:string" lowerBound="1" form="Attribute"/>
								</typeDef>
							</property>
							<property name="Адрес">
								<typeDef xsi:type="ObjectType">
									<property name="КодСубъекта" type="xs:string" lowerBound="1" form="Attribute"/>
									<property name="НеконфАдрес" type="xs:string" lowerBound="1" form="Attribute"/>
									<property name="КонфАдрес" type="xs:string" lowerBound="1" form="Attribute"/>
									<property name="МестоРождения" type="xs:string" lowerBound="1" form="Attribute"/>
								</typeDef>
							</property>
						</typeDef>
					</property>
					<property name="ЦенныеБумаги" lowerBound="0" upperBound="-1">
						<typeDef xsi:type="ObjectType">
							<property name="ИдБумаги" type="xs:string" lowerBound="1" form="Attribute"/>
							<property name="Организация">
								<typeDef xsi:type="ObjectType">
									<property name="Название" type="xs:string" lowerBound="1" form="Attribute"/>
									<property name="ИННОрг" type="xs:string" lowerBound="1" form="Attribute"/>
									<property name="ПИФ" type="xs:string" lowerBound="1" form="Attribute"/>
									<property name="Статус" type="xs:string" lowerBound="1" form="Attribute"/>
									<property name="ДоляПроцент" type="xs:string" lowerBound="1" form="Attribute"/>
									<property name="ДоляЧислитель" type="xs:string" lowerBound="1" form="Attribute"/>
									<property name="ДоляЗнаменатель" type="xs:string" lowerBound="1" form="Attribute"/>
									<property name="ОКСМ" type="xs:string" lowerBound="1" form="Attribute"/>
									<property name="Страна" type="xs:string" lowerBound="1" nillable="true" form="Attribute"/>
									<property name="КодСубОрг" type="xs:string" lowerBound="1" form="Attribute"/>
									<property name="НеконфАдрОрг" type="xs:string" lowerBound="1" form="Attribute"/>
									<property name="КонфАдрОрг" type="xs:string" lowerBound="1" form="Attribute"/>
								</typeDef>
							</property>
							<property name="Бумага">
								<typeDef xsi:type="ObjectType">
									<property name="КодТипБум" type="xs:string" lowerBound="1" form="Attribute"/>
									<property name="КодИдент" type="xs:string" lowerBound="1" nillable="true" form="Attribute"/>
									<property name="КодКласс" type="xs:string" lowerBound="1" nillable="true" form="Attribute"/>
									<property name="КодВидБум" type="xs:string" lowerBound="1" form="Attribute"/>
									<property name="КодКатег" type="xs:string" lowerBound="1" form="Attribute"/>
									<property xmlns:d10p1="VO_CIK_CB_7.xsd" name="Колво" type="d10p1:Number" lowerBound="1" form="Attribute"/>
									<property xmlns:d10p1="VO_CIK_CB_7.xsd" name="КолвоЧисл" type="d10p1:Number" lowerBound="1" form="Attribute"/>
									<property xmlns:d10p1="VO_CIK_CB_7.xsd" name="КолвоЗнам" type="d10p1:Number" lowerBound="1" form="Attribute"/>
									<property name="Стоимость" type="xs:decimal" lowerBound="1" form="Attribute"/>
									<property xmlns:d10p1="VO_CIK_CB_7.xsd" name="ДатаСведОтв" type="d10p1:ДатаТип" lowerBound="1" form="Attribute"/>
								</typeDef>
							</property>
						</typeDef>
					</property>
					<property name="Счета" lowerBound="0" upperBound="-1">
						<typeDef xsi:type="ObjectType">
							<property name="ИдСчета" type="xs:string" lowerBound="1" form="Attribute"/>
							<property name="Счет">
								<typeDef xsi:type="ObjectType">
									<property name="ВидСчета" type="xs:string" lowerBound="1" form="Attribute"/>
									<property name="НомерСчета" type="xs:string" lowerBound="1" form="Attribute"/>
									<property name="Остаток" type="xs:decimal" lowerBound="1" form="Attribute"/>
								</typeDef>
							</property>
							<property name="КредитОрг">
								<typeDef xsi:type="ObjectType">
									<property name="НаимКредит" type="xs:string" lowerBound="1" form="Attribute"/>
									<property name="КодСубКред" type="xs:string" lowerBound="1" form="Attribute"/>
									<property name="НеконфАдрКред" type="xs:string" lowerBound="1" form="Attribute"/>
									<property name="КонфАдрКред" type="xs:string" lowerBound="1" form="Attribute"/>
								</typeDef>
							</property>
						</typeDef>
					</property>
					<property name="СлужИнфо">
						<typeDef xsi:type="ObjectType">
							<property name="ВРНКанд" type="xs:integer" lowerBound="1" form="Attribute"/>
							<property name="ИДИнфо">
								<typeDef xsi:type="ObjectType">
									<property name="КодСубъекта" type="xs:string" lowerBound="1" form="Attribute"/>
									<property name="Кампания" type="xs:integer" lowerBound="1" form="Attribute"/>
									<property name="Система" type="xs:unsignedByte" lowerBound="1" form="Attribute"/>
								</typeDef>
							</property>
							<property name="Наименование">
								<typeDef xsi:type="ObjectType">
									<property name="Выборы" type="xs:string" lowerBound="1" form="Attribute"/>
									<property name="Субъект" type="xs:string" lowerBound="1" form="Attribute"/>
									<property xmlns:d10p1="VO_CIK_CB_7.xsd" name="ДатаСвед" type="d10p1:ДатаТип" lowerBound="1" form="Attribute"/>
								</typeDef>
							</property>
						</typeDef>
					</property>
				</typeDef>
			</property>
		</typeDef>
	</property>
	<valueType name="Number" base="xs:string" variety="Atomic" minLength="0" maxLength="25">
		<pattern>[0-9]{0,16}|[0-9]{1,16}\.{1}[0-9]{1,8}</pattern>
	</valueType>
	<valueType name="ДатаТип" base="xs:string" variety="Atomic" length="10">
		<pattern>(0[1-9]{1}|[1-2]{1}[0-9]{1}|3[0-1]{1})\.(0[1-9]{1}|1[0-2]{1})\.(1[0-9]{3}|20[0-9]{2})</pattern>
	</valueType>
</package>