&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	Шаблон = Параметры.Шаблон;
КонецПроцедуры

&НаКлиенте
Процедура ПередЗакрытием(Отказ, СтандартнаяОбработка)
	Если ВычислитьВыражениеНаСервере(Параметры.Поручение, Шаблон) = Неопределено Тогда
		Ответ = Вопрос("Выражение не может быть вычислено, удалить внесённые изменения?", РежимДиалогаВопрос.ДаНет);
		Если Ответ = КодВозвратаДиалога.Да Тогда
			Шаблон = Параметры.Шаблон;
		Иначе
			Отказ = Истина;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ПриЗакрытии()
	ОповеститьОВыборе(Шаблон);
КонецПроцедуры

&НаСервереБезКонтекста
Функция ВычислитьВыражениеНаСервере(Поручение, Шаблон)
	Возврат РегистрыСведений.ПараметрыСделокДляЭкспортаВЛуч.ЗначениеПараметра(Поручение, Шаблон);
КонецФункции

&НаКлиенте
Процедура ВставитьРеквизит(Команда)
	Реквизиты = РеквизитыПоручения();
	ВыборПользователя = Реквизиты.ВыбратьЭлемент();
	Если ВыборПользователя = Неопределено Тогда
		Возврат;
	КонецЕсли;
	Шаблон = Шаблон + "[""" + ВыборПользователя.Значение + """]";
КонецПроцедуры


Функция РеквизитыПоручения()
	Реквизиты = Новый СписокЗначений;
	МетаданныеПоручения = Параметры.Поручение.Метаданные();
	Для Каждого Реквизит Из МетаданныеПоручения.СтандартныеРеквизиты Цикл
		Реквизиты.Добавить(Реквизит.Имя, Реквизит.Синоним);
	КонецЦикла;
	Для Каждого Реквизит Из МетаданныеПоручения.Реквизиты Цикл
		Реквизиты.Добавить(Реквизит.Имя, Реквизит.Синоним);
	КонецЦикла;
	Возврат Реквизиты;
КонецФункции
