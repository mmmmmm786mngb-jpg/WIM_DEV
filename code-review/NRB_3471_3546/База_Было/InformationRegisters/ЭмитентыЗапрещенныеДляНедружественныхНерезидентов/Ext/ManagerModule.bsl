// Функция - Эмитент является запрещенным
//
// Параметры:
//  Контрагент	 - СправочникСсылка.Контрагенты - Контрагент которого требуется проверить
//  Дата		 - Дата - Дата на которую идет проверка
// 
// Возвращаемое значение:
//   -Булево
//
Функция ЭмитентЯвляетсяЗапрещенным(Контрагент, Дата) Экспорт

	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ЭмитентыЗапрещенныеДляНедружественныхНерезидентов.Эмитент КАК Эмитент
	|ИЗ
	|	РегистрСведений.ЭмитентыЗапрещенныеДляНедружественныхНерезидентов КАК ЭмитентыЗапрещенныеДляНедружественныхНерезидентов
	|ГДЕ
	|	ЭмитентыЗапрещенныеДляНедружественныхНерезидентов.ДатаНачалаДействия <= &Дата
	|	И ЭмитентыЗапрещенныеДляНедружественныхНерезидентов.ДатаНачалаДействия <> ДАТАВРЕМЯ(1, 1, 1)
	|	И (ЭмитентыЗапрещенныеДляНедружественныхНерезидентов.ДатаОкончанияДействия >= &Дата
	|			ИЛИ ЭмитентыЗапрещенныеДляНедружественныхНерезидентов.ДатаОкончанияДействия = ДАТАВРЕМЯ(1, 1, 1))
	|	И ЭмитентыЗапрещенныеДляНедружественныхНерезидентов.Эмитент В(&Контрагент)";
	
	Запрос.УстановитьПараметр("Контрагент", Контрагент);
	Запрос.УстановитьПараметр("Дата", Дата);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Истина;
	Иначе
		Возврат Ложь;
	КонецЕсли;


КонецФункции