
Процедура ПроверитьВыгруженныеПлатежиВЭДО(ДатаВыгрузки) Экспорт 
	ДеньВыгрузки = НачалоДня(ДатаВыгрузки);
	
	Запись = РегистрыСведений.ПодтвержденныеДокументыЭДО.СоздатьМенеджерЗаписи();
	Запись.Дата = ДеньВыгрузки;
	Запись.Прочитать();
	
	Если ЗначениеЗаполнено(Запись.Дата) И Запись.Подтвержден Тогда
		Возврат;
	КонецЕсли;
		
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	КОЛИЧЕСТВО(Регистрация.Документ) КАК Количество
	|ИЗ
	|	РегистрСведений.РегистрацияДокументовВЭДО КАК Регистрация
	|ГДЕ
	|	НАЧАЛОПЕРИОДА(Регистрация.ДатаВыгрузки, ДЕНЬ) = &ДеньВыгрузки
	|	И Регистрация.Документ ССЫЛКА Документ.Выписка
	|
	|ИМЕЮЩИЕ
	|	КОЛИЧЕСТВО(Регистрация.Документ) >= 10";
	Запрос.УстановитьПараметр("ДеньВыгрузки", ДеньВыгрузки);
	Если НЕ Запрос.Выполнить().Пустой() Тогда
		Запись = РегистрыСведений.ПодтвержденныеДокументыЭДО.СоздатьМенеджерЗаписи();
		Запись.Дата			= ДеньВыгрузки;
		Запись.Подтвержден	= Истина;
		Запись.Записать();
	КонецЕсли;
КонецПроцедуры
