
// Процедура - Список перед удалением
//
// Параметры:
//  Элемент	 - ТаблицаФормы - Таблица формы Список
//  Отказ	 - Булево - Признак отказа от удаления строки
//
&НаКлиенте
Процедура СписокПередУдалением(Элемент, Отказ)
	
	ТекущаяЗапись = Элементы.Список.ТекущиеДанные;
	
	Если ЗначениеЗаполнено(ТекущаяЗапись.Основание) И ТипЗнч(ТекущаяЗапись.Основание) <> Тип("Строка") Тогда
		
		ТекстВопросаОбУдаленииЗаписи = "Запись принадлежит документу " + ТекущаяЗапись.Основание
			+ "! Вы уверены, что хотите удалить её?";
		
		Если Не Вопрос(ТекстВопросаОбУдаленииЗаписи, РежимДиалогаВопрос.ДаНетОтмена) = КодВозвратаДиалога.Да Тогда
			
			Отказ = Истина; // Запретим удалять записи созданные документами
			
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры
