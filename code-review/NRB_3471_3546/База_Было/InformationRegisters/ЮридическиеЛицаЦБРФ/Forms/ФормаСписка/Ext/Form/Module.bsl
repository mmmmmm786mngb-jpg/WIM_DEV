#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ВыгрузитьВ_BQ(Команда)
	ВыгрузитьНаСервере();
КонецПроцедуры

#КонецОбласти


#Область ВспомогательныеПроцедурыИФункции

// BSLLS:MethodSize-off

&НаСервере
Функция ТекстЗапросаДляВыгрузки()
	ТекстЗапроса = 
		"ВЫБРАТЬ
		|	ИННКВыгрузке.ИНН КАК ИНН
		|ПОМЕСТИТЬ ВТ_ИННКВыгрузкеВсе
		|ИЗ
		|	&ИННКВыгрузке КАК ИННКВыгрузке
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_ИННКВыгрузкеВсе.ИНН КАК ИНН
		|ПОМЕСТИТЬ ВТ_ИННКВыгрузке
		|ИЗ
		|	ВТ_ИННКВыгрузкеВсе КАК ВТ_ИННКВыгрузкеВсе
		|
		|СГРУППИРОВАТЬ ПО
		|	ВТ_ИННКВыгрузкеВсе.ИНН
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_ИННКВыгрузке.ИНН КАК ИНН,
		|	ЮридическиеЛица.Ссылка КАК Юрлицо
		|ПОМЕСТИТЬ ВТ_ИННЮрлицНерезидентовЭтап1
		|ИЗ
		|	ВТ_ИННКВыгрузке КАК ВТ_ИННКВыгрузке
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ЮридическиеЛица КАК ЮридическиеЛица
		|		ПО ВТ_ИННКВыгрузке.ИНН = ЮридическиеЛица.ИНН_РФ_ДляНерезидентов
		|			И (НЕ ЮридическиеЛица.ПометкаУдаления)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_ИННКВыгрузке.ИНН КАК ИНН,
		|	ЮридическиеЛица.Ссылка КАК Юрлицо
		|ПОМЕСТИТЬ ВТ_ИННЮрлицЭтап1
		|ИЗ
		|	ВТ_ИННКВыгрузке КАК ВТ_ИННКВыгрузке
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ЮридическиеЛица КАК ЮридическиеЛица
		|		ПО ВТ_ИННКВыгрузке.ИНН = ЮридическиеЛица.ИНН
		|			И (НЕ ЮридическиеЛица.ПометкаУдаления)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_ИННЮрлицЭтап1.ИНН КАК ИНН,
		|	ВТ_ИННЮрлицЭтап1.Юрлицо КАК Юрлицо,
		|	МАКСИМУМ(ЦенныеБумаги.Ссылка) КАК ЦБ
		|ПОМЕСТИТЬ ВТ_ИННЮрлиц
		|ИЗ
		|	ВТ_ИННЮрлицЭтап1 КАК ВТ_ИННЮрлицЭтап1
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Контрагенты КАК Контрагенты
		|		ПО ВТ_ИННЮрлицЭтап1.Юрлицо = Контрагенты.ЮридическиеФизическиеЛица
		|			И (НЕ Контрагенты.ПометкаУдаления)
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ЦенныеБумаги КАК ЦенныеБумаги
		|		ПО (ЦенныеБумаги.Эмитент = Контрагенты.Ссылка)
		|			И (НЕ ЦенныеБумаги.ПометкаУдаления)
		|
		|СГРУППИРОВАТЬ ПО
		|	ВТ_ИННЮрлицЭтап1.ИНН,
		|	ВТ_ИННЮрлицЭтап1.Юрлицо
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_ИННКВыгрузке.ИНН КАК ИНН,
		|	МАКСИМУМ(ВТ_ИННЮрлиц.Юрлицо) КАК ЮрЛицоЭмитент
		|ПОМЕСТИТЬ ВТ_ЮрлицаЭмитентыПоИНН
		|ИЗ
		|	ВТ_ИННКВыгрузке КАК ВТ_ИННКВыгрузке
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_ИННЮрлиц КАК ВТ_ИННЮрлиц
		|		ПО ВТ_ИННКВыгрузке.ИНН = ВТ_ИННЮрлиц.ИНН
		|			И (НЕ ВТ_ИННЮрлиц.ЦБ ЕСТЬ NULL)
		|
		|СГРУППИРОВАТЬ ПО
		|	ВТ_ИННКВыгрузке.ИНН
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_ИННКВыгрузке.ИНН КАК ИНН,
		|	МАКСИМУМ(ВТ_ИННЮрлиц.Юрлицо) КАК ЮрЛицо
		|ПОМЕСТИТЬ ВТ_ЛюбыеЮрЛицаПоИНН
		|ИЗ
		|	ВТ_ИННКВыгрузке КАК ВТ_ИННКВыгрузке
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ИННЮрлиц КАК ВТ_ИННЮрлиц
		|		ПО ВТ_ИННКВыгрузке.ИНН = ВТ_ИННЮрлиц.ИНН
		|
		|СГРУППИРОВАТЬ ПО
		|	ВТ_ИННКВыгрузке.ИНН
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_ЛюбыеЮрЛицаПоИНН.ИНН КАК ИНН,
		|	ВТ_ЮрлицаЭмитентыПоИНН.ЮрЛицоЭмитент КАК ЮрЛицоЭмитент,
		|	ЕСТЬNULL(ВТ_ЮрлицаЭмитентыПоИНН.ЮрЛицоЭмитент, ВТ_ЛюбыеЮрЛицаПоИНН.ЮрЛицо) КАК ЮрЛицо
		|ПОМЕСТИТЬ ВТ_ЮрЛицаПоИНН
		|ИЗ
		|	ВТ_ЛюбыеЮрЛицаПоИНН КАК ВТ_ЛюбыеЮрЛицаПоИНН
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ЮрлицаЭмитентыПоИНН КАК ВТ_ЮрлицаЭмитентыПоИНН
		|		ПО ВТ_ЛюбыеЮрЛицаПоИНН.ИНН = ВТ_ЮрлицаЭмитентыПоИНН.ИНН
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ЮридическиеЛицаЦБРФСрезПоследних.ИНН КАК ИНН,
		|	ЮридическиеЛицаЦБРФСрезПоследних.КПП КАК КПП,
		|	ЮридическиеЛицаЦБРФСрезПоследних.ОГРН КАК ОГРН,
		|	ЮридическиеЛицаЦБРФСрезПоследних.Наименование КАК Наименование
		|ПОМЕСТИТЬ ВТ_ДанныеИзРегистра
		|ИЗ
		|	РегистрСведений.ЮридическиеЛицаЦБРФ.СрезПоследних(
		|			&ТекущаяДата,
		|			ИНН В
		|				(ВЫБРАТЬ
		|					ВТ_ЮрЛицаПоИНН.ИНН КАК ИНН
		|				ИЗ
		|					ВТ_ЮрЛицаПоИНН КАК ВТ_ЮрЛицаПоИНН
		|				ГДЕ
		|					НЕ ВТ_ЮрЛицаПоИНН.ЮрЛицоЭмитент ЕСТЬ NULL)) КАК ЮридическиеЛицаЦБРФСрезПоследних
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_ЮрЛицаПоИНН.ЮрЛицоЭмитент КАК ЮрЛицо,
		|	МАКСИМУМ(КодыНРД.Код) КАК NrdCode,
		|	МАКСИМУМ(КодыLei.Код) КАК LeiCode,
		|	МАКСИМУМ(КодыRuData.Код) КАК RuDataCode
		|ПОМЕСТИТЬ ВТ_Коды
		|ИЗ
		|	ВТ_ЮрЛицаПоИНН КАК ВТ_ЮрЛицаПоИНН
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.КодыЗагрузки КАК КодыНРД
		|		ПО ВТ_ЮрЛицаПоИНН.ЮрЛицоЭмитент = КодыНРД.Владелец
		|			И (КодыНРД.Биржа = ЗНАЧЕНИЕ(Справочник.КлассификаторыЗагрузки.NrdCode))
		|			И (НЕ КодыНРД.ПометкаУдаления)
		|			И (ВЫБОР
		|				КОГДА КодыНРД.ДатаОкончанияДействия = ДАТАВРЕМЯ(1, 1, 1)
		|					ТОГДА ИСТИНА
		|				КОГДА КодыНРД.ДатаОкончанияДействия > &ТекущаяДата
		|					ТОГДА ИСТИНА
		|				ИНАЧЕ ЛОЖЬ
		|			КОНЕЦ)
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.КодыЗагрузки КАК КодыRuData
		|		ПО ВТ_ЮрЛицаПоИНН.ЮрЛицоЭмитент = КодыRuData.Владелец
		|			И (КодыRuData.Биржа = ЗНАЧЕНИЕ(Справочник.КлассификаторыЗагрузки.RuData))
		|			И (НЕ КодыRuData.ПометкаУдаления)
		|			И (ВЫБОР
		|				КОГДА КодыRuData.ДатаОкончанияДействия = ДАТАВРЕМЯ(1, 1, 1)
		|					ТОГДА ИСТИНА
		|				КОГДА КодыRuData.ДатаОкончанияДействия > &ТекущаяДата
		|					ТОГДА ИСТИНА
		|				ИНАЧЕ ЛОЖЬ
		|			КОНЕЦ)
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.КодыЗагрузки КАК КодыLei
		|		ПО ВТ_ЮрЛицаПоИНН.ЮрЛицоЭмитент = КодыLei.Владелец
		|			И (КодыLei.Биржа = ЗНАЧЕНИЕ(Справочник.КлассификаторыЗагрузки.LEI_Code))
		|			И (НЕ КодыLei.ПометкаУдаления)
		|			И (ВЫБОР
		|				КОГДА КодыLei.ДатаОкончанияДействия = ДАТАВРЕМЯ(1, 1, 1)
		|					ТОГДА ИСТИНА
		|				КОГДА КодыLei.ДатаОкончанияДействия > &ТекущаяДата
		|					ТОГДА ИСТИНА
		|				ИНАЧЕ ЛОЖЬ
		|			КОНЕЦ)
		|ГДЕ
		|	НЕ ВТ_ЮрЛицаПоИНН.ЮрЛицоЭмитент ЕСТЬ NULL
		|
		|СГРУППИРОВАТЬ ПО
		|	ВТ_ЮрЛицаПоИНН.ЮрЛицоЭмитент
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_ЮрЛицаПоИНН.ИНН КАК ИНН,
		|	ВТ_ЮрЛицаПоИНН.ЮрЛицоЭмитент КАК ЮрЛицоЭмитент,
		|	ВТ_ЮрЛицаПоИНН.ЮрЛицо КАК ЮрЛицо,
		|	ЮридическиеЛица.TIN КАК TIN,
		|	ЮридическиеЛица.Наименование КАК НаименованиеЮЛ,
		|	ВТ_ДанныеИзРегистра.КПП КАК КПП,
		|	ВТ_ДанныеИзРегистра.ОГРН КАК ОГРН,
		|	ВТ_ДанныеИзРегистра.Наименование КАК Наименование,
		|	ЕСТЬNULL(ВТ_Коды.NrdCode, """") КАК NrdCode,
		|	ЕСТЬNULL(ВТ_Коды.LeiCode, """") КАК LeiCode,
		|	ЕСТЬNULL(ВТ_Коды.RuDataCode, """") КАК RuDataCode
		|ИЗ
		|	ВТ_ЮрЛицаПоИНН КАК ВТ_ЮрЛицаПоИНН
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ДанныеИзРегистра КАК ВТ_ДанныеИзРегистра
		|		ПО ВТ_ЮрЛицаПоИНН.ИНН = ВТ_ДанныеИзРегистра.ИНН
		|			И (НЕ ВТ_ЮрЛицаПоИНН.ЮрЛицоЭмитент ЕСТЬ NULL)
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ЮридическиеЛица КАК ЮридическиеЛица
		|		ПО ВТ_ЮрЛицаПоИНН.ЮрЛицоЭмитент = ЮридическиеЛица.Ссылка
		|			И (НЕ ВТ_ЮрЛицаПоИНН.ЮрЛицоЭмитент ЕСТЬ NULL)
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_Коды КАК ВТ_Коды
		|		ПО ВТ_ЮрЛицаПоИНН.ЮрЛицоЭмитент = ВТ_Коды.ЮрЛицо
		|			И (НЕ ВТ_ЮрЛицаПоИНН.ЮрЛицоЭмитент ЕСТЬ NULL)";

	Возврат ТекстЗапроса;
КонецФункции

// BSLLS:MethodSize-on

&НаСервере
Процедура ВыгрузитьНаСервере()
	ИННКВыгрузке = ИННКВыгрузке();
	
	Запрос = Новый Запрос;
	Запрос.Текст = ТекстЗапросаДляВыгрузки();
	Запрос.УстановитьПараметр("ИННКВыгрузке", ИННКВыгрузке);
	Запрос.УстановитьПараметр("ТекущаяДата", ТекущаяДатаСеанса());
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		Если ЗначениеЗаполнено(Выборка.ЮрЛицоЭмитент) Тогда
			ОбменДаннымиКафка.ВыгрузитьИНН_ОГРН_ЦБРФ_ЭмитентаВBackQort(Выборка);
		Иначе
			Если ЗначениеЗаполнено(Выборка.ЮрЛицо) Тогда
				Текст = "По ИНН = " + Выборка.ИНН + " в нашей базе не найдено юридических лиц являющихся эмитентами ЦБ";
			Иначе
				Текст = "По ИНН = " + Выборка.ИНН + " в нашей базе не найдено ни одного юридического лица";
			КонецЕсли;
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(Текст);
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

&НаСервере
Функция ИННКВыгрузке()
	ИННКВыгрузке = Новый ТаблицаЗначений;
	ИННКВыгрузке.Колонки.Добавить("ИНН", ОбщегоНазначения.ОписаниеТипаСтрока(12));
	
	Если Элементы.Список.ВыделенныеСтроки.Количество() > 0 Тогда
			Для Каждого КлючЗаписи Из Элементы.Список.ВыделенныеСтроки Цикл
			НоваяЗапись = ИННКВыгрузке.Добавить();
			НоваяЗапись.ИНН = КлючЗаписи.ИНН;
		КонецЦикла;
	КонецЕсли;
	
	Возврат ИННКВыгрузке;
КонецФункции

#КонецОбласти