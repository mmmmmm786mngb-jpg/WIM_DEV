// Процедура - Тестирование подключения КСУБД
//
// Параметры:
//  Команда	 - КомандаФормы - Описывает выполняемую команду
//
&НаКлиенте
Процедура ТестированиеПодключенияКСУБД(Команда)
	
	СписокПараметров = "ШаблонПодключенияКБДSQL, Сервер, БазаДанных, Логин, Пароль";
	ПараметрыТестирования = Новый Структура(СписокПараметров);
	ЗаполнитьЗначенияСвойств(ПараметрыТестирования, Запись, СписокПараметров);
	
	ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Результат тестирования на КЛИЕНТЕ:");
	ТестированиеПодключенияКСУБДКлиент(ПараметрыТестирования);
	
	ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Результат тестирования на СЕРВЕРЕ:");
	ТестированиеПодключенияКСУБДСервер(ПараметрыТестирования);
	
КонецПроцедуры
