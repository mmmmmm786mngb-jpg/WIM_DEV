&НаСервере
Процедура УправлениеРеквизитамиФормы()
	Элементы.ГруппаНастройкиПоТипамБаз.ТекущаяСтраница = Элементы.ГруппаНастройкиПоТипамБаз.ПодчиненныеЭлементы.ГруппаНастройкиSQL;
	
	ТипВнешнегоИсточника = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Запись.ВнешнийИсточник, "ТипВнешнегоИсточника");
	Страница = ПолучитьСтраницыПоТипуИсточника()[ТипВнешнегоИсточника];
	Если Страница = Неопределено Тогда
		Элементы.ГруппаНастройкиПоТипамБаз.ТекущаяСтраница	= Элементы.ГруппаНастройкиПоТипамБаз.ПодчиненныеЭлементы["НевозможноОпределитьНастройки"];
	Иначе
		Элементы.ГруппаНастройкиПоТипамБаз.ТекущаяСтраница	= Элементы.ГруппаНастройкиПоТипамБаз.ПодчиненныеЭлементы[Страница];
	КонецЕсли;
	
	ВидимостьНастроекSSL = ТипВнешнегоИсточника = Перечисления.ТипыВнешнихИсточников.ВебСервис
		Или (ТипВнешнегоИсточника = Перечисления.ТипыВнешнихИсточников.НастройкаОбменаДанными 
			И ТипЗнч(Запись.Настройка) = Тип("СправочникСсылка.НастройкиОбменаДанными")
			И ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Запись.Настройка, "СпособОбмена") = Перечисления.СпособыОбменаДанными.ОбменЧерезВебСервис);
	Элементы.ГруппаНастройкиSSL.Видимость = ВидимостьНастроекSSL;
КонецПроцедуры

&НаСервереБезКонтекста
Функция ПолучитьСтраницыПоТипуИсточника()
	ТипыВнешнихИсточников	= Перечисления.ТипыВнешнихИсточников;
	
	СтраницыПоТипуИсточника = Новый Соответствие;
	
	СтраницыПоТипуИсточника.Вставить(ТипыВнешнихИсточников.БазаДанныхSQL			, "ГруппаНастройкиSQL");
	СтраницыПоТипуИсточника.Вставить(ТипыВнешнихИсточников.ВебСервис				, "ГруппаНастройкиВебСервис");
	СтраницыПоТипуИсточника.Вставить(ТипыВнешнихИсточников.ИнформационнаяБаза		, "ГруппаНастройкиБаза1С");
	СтраницыПоТипуИсточника.Вставить(ТипыВнешнихИсточников.НастройкаОбменаДанными	, "ГруппаНастройкиОбменаДанными");
	СтраницыПоТипуИсточника.Вставить(ТипыВнешнихИсточников.Папка					, "ГруппаНастройкиКаталог");
	
	Возврат СтраницыПоТипуИсточника;
КонецФункции

&НаКлиенте
Процедура ВнешнийИсточникПриИзменении(Элемент)
	Если НЕ Запись.ВнешнийИсточник.Пустая() Тогда
		ТипВнешнегоИсточника = ТипВнешнегоИсточникаНаСревере(Запись.ВнешнийИсточник);
		Если Не ЗначениеЗаполнено(ТипВнешнегоИсточника) Тогда
			Предупреждение("У 'Внешнего источника' не заполнен 'Тип' - невозможно определить параметры полей для настроек!");
		КонецЕсли;
	КонецЕсли;
	УправлениеРеквизитамиФормы();
КонецПроцедуры

&НаКлиенте
Процедура ПолучитьНастройкиТекущейЛИБ(Команда)
	Попытка
		ПараметрыСеансаТекущейБазы = ПараметрыСеансаТекущейБазы();
		Запись.КластерСерверов		= ПараметрыСеансаТекущейБазы.КластерСерверов;
		Запись.ИнформационнаяБаза	= ПараметрыСеансаТекущейБазы.ИнформационнаяБаза;
	Исключение
	КонецПопытки;
КонецПроцедуры

&НаКлиенте
Процедура Сервер2НачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	СтандартнаяОбработка		= Ложь;
	
	ДиалогВыбораКаталога						= Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.ВыборКаталога);
	ДиалогВыбораКаталога.Заголовок				= "Выбор каталога";
	ДиалогВыбораКаталога.Каталог				= Запись.Сервер;
	ДиалогВыбораКаталога.ПолноеИмяФайла			= Запись.Сервер;
	ДиалогВыбораКаталога.ПредварительныйПросмотр= Ложь;
	
	Если ДиалогВыбораКаталога.Выбрать() Тогда
		Запись.Сервер	= ДиалогВыбораКаталога.Каталог;
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	ПрочитатьДанныеСертификата();
	УправлениеРеквизитамиФормы();
КонецПроцедуры

&НаСервере
Процедура ПередЗаписьюНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	Если ЭтоАдресВременногоХранилища(АдресДанныхФайла) Тогда
		ТекущийОбъект.ДанныеСертификатаКлиента = Новый ХранилищеЗначения(ПолучитьИзВременногоХранилища(АдресДанныхФайла));
	КонецЕсли;
КонецПроцедуры

&НаСервереБезКонтекста
Функция ТипВнешнегоИсточникаНаСревере(ВнешнийИсточник)
	
	Возврат ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ВнешнийИсточник, "ТипВнешнегоИсточника");
	
КонецФункции

&НаСервереБезКонтекста
Функция ПараметрыСеансаТекущейБазы()
	
	ПараметрыСеансаТекущейБазы = Новый Структура();
	ПараметрыСеансаТекущейБазы.Вставить("КластерСерверов",		 ПараметрыСеанса.ТекущийКластерСерверов);
	ПараметрыСеансаТекущейБазы.Вставить("ИнформационнаяБаза",		ПараметрыСеанса.ТекущаяИнформационнаяБаза);
	
	Возврат ПараметрыСеансаТекущейБазы;
	
КонецФункции

&НаКлиенте
Процедура НастройкаПриИзменении(Элемент)
	УправлениеРеквизитамиФормы();
КонецПроцедуры

&НаКлиенте
Процедура ИмяФайлаСертификатаКлиентаНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	СтандартнаяОбработка = Ложь;
	
	Оповещение = Новый ОписаниеОповещения("ИмяФайлаСертификатаКлиентаНачалоВыбора_ФайлВыбран", ЭтотОбъект);
	
	Диалог = Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.Открытие);
	Диалог.Фильтр = "Файл сертификата P12 (*.PFX; *.P12)|*.PFX;*.P12|Файл сертификата PEM (*.PEM)|*.PEM|Все файлы (*.*)|*.*";
	Диалог.Заголовок = "Выберите файл клиентского сертификата SSL";
	Диалог.Показать(Оповещение);
КонецПроцедуры

&НаКлиенте
Процедура ИмяФайлаСертификатаКлиентаОчистка(Элемент, СтандартнаяОбработка)
	ОчиститьСертификатКлиента();
КонецПроцедуры

&НаКлиенте
Процедура ИмяФайлаСертификатаКлиентаНачалоВыбора_ФайлВыбран(ВыбранныеФайлы, ДополнительныеПараметры) Экспорт
	Если ВыбранныеФайлы <> Неопределено Тогда
		ПолноеИмяФайла = ВыбранныеФайлы[0];
		ФайлСертификата = Новый Файл(ПолноеИмяФайла);
		ДанныеФайла = Новый ДвоичныеДанные(ПолноеИмяФайла);
		ЗагрузитьСертификатКлиента(ФайлСертификата.Имя, ДанныеФайла);
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ЗагрузитьСертификатКлиента(ИмяФайла, ДанныеФайла)
	Запись.ИмяФайлаСертификатаКлиента = ИмяФайла;
	АдресДанныхФайла = ПоместитьВоВременноеХранилище(ДанныеФайла, УникальныйИдентификатор);
	Модифицированность = Истина;
КонецПроцедуры

&НаКлиенте
Процедура ОчиститьСертификатКлиента()
	ЗагрузитьСертификатКлиента("", Неопределено);
КонецПроцедуры

&НаСервере
Процедура ПрочитатьДанныеСертификата()
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ВнешниеИсточники.ДанныеСертификатаКлиента КАК ДанныеСертификатаКлиента
	|ИЗ
	|	РегистрСведений.ВнешниеИсточники КАК ВнешниеИсточники
	|ГДЕ
	|	ВнешниеИсточники.ВнешнийИсточник = &ВнешнийИсточник
	|	И ВнешниеИсточники.КластерСерверов = &КластерСерверов
	|	И ВнешниеИсточники.ИнформационнаяБаза = &ИнформационнаяБаза";
	Запрос.УстановитьПараметр("ВнешнийИсточник", Запись.ВнешнийИсточник);
	Запрос.УстановитьПараметр("КластерСерверов", Запись.КластерСерверов);
	Запрос.УстановитьПараметр("ИнформационнаяБаза", Запись.ИнформационнаяБаза);
	Результат = Запрос.Выполнить();
	Если Не Результат.Пустой() Тогда
		Выборка = Результат.Выбрать();
		Выборка.Следующий();
		ДанныеСертификата = Выборка.ДанныеСертификатаКлиента.Получить();
	Иначе
		ДанныеСертификата = Неопределено;
	КонецЕсли;
	
	АдресДанныхФайла = ПоместитьВоВременноеХранилище(ДанныеСертификата, УникальныйИдентификатор);
КонецПроцедуры

// Процедура - Тестирование подключения КСУБД без привязки к контексту
//
// Параметры:
//  Запись	 - Структура - Входящие параметры для тестирования
//
&НаКлиентеНаСервереБезКонтекста
Процедура ТестированиеПодключенияКСУБДКлиентСервер(Запись)
	
	Если ПустаяСтрока(Запись.ШаблонПодключенияКБДSQL) Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(
			"Тестирование соединения: Отказ. Причина:Не задан шаблон подключения к БД SQL");
		Возврат;
	КонецЕсли;
	
	Соединение	= Новый COMОбъект("ADODB.Connection");
	Команда		= Новый COMОбъект("ADODB.Command");
	RS			= Новый COMОбъект("ADODB.RecordSet");
	
	ПараметрыПодключения = Новый Структура;
	ПараметрыПодключения.Вставить("Сервер", Запись.Сервер);
	ПараметрыПодключения.Вставить("База", Запись.БазаДанных);
	ПараметрыПодключения.Вставить("Логин", Запись.Логин);
	ПараметрыПодключения.Вставить("Пароль", Запись.Пароль);
	ConnectionString	=
		ВнешниеДанные.СтрокаПодключенияПоШаблонуИПараметрам(Запись.ШаблонПодключенияКБДSQL, ПараметрыПодключения);
	
	ТаймаутСоединения	= 20;
	ТаймаутЗапроса		= 0;
	Соединение.ConnectionTimeOut= ТаймаутСоединения;
	Соединение.CommandTimeOut	= ТаймаутЗапроса;
	Команда.CommandTimeOut		= ТаймаутЗапроса;
	Соединение.CursorLocation	= 3;
	
	Попытка
		Соединение.Open(ConnectionString);
		Команда.ActiveConnection = Соединение;
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Тестирование соединения: Успешно");
	Исключение
		ТекстОшибки = "Тестирование соединения: Отказ. Причина:" + Символы.ПС + ОписаниеОшибки();
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстОшибки);
	КонецПопытки;

КонецПроцедуры

// Процедура - Тестирование подключения КСУБД Клиент
