

Функция ПолучитьПутьФайлаКлассификатора(ДанныеФайла)
	
	ПутьКФайлу = "";
	Если ДанныеФайла <> Неопределено Тогда 
		ПутьКФайлу = КаталогВременныхФайлов() + ДанныеФайла.ИмяФайла;
		ДанныеФайла.ДанныеФайла.Записать(ПутьКФайлу);
		Файл = Новый Файл(ПутьКФайлу);
	КонецЕсли;	
	
	Возврат ПутьКФайлу;
	
КонецФункции

Процедура УстановитьКодировку(ФайлБД, КодировкаWindows)
	
	Если КодировкаWindows Тогда
		ФайлБД.Кодировка = КодировкаXBase.ANSI;
	Иначе
		ФайлБД.Кодировка = КодировкаXBase.OEM;
	КонецЕсли;
	
КонецПроцедуры

