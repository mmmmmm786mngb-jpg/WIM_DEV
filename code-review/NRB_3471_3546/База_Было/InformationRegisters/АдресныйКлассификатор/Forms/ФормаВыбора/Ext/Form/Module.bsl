
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
		
	Элементы.Список.РежимВыбора = Истина;
 	
КонецПроцедуры

&НаКлиенте
Процедура СписокПриАктивизацииСтроки(Элемент)
	
	ТД = Элементы.Список.ТекущиеДанные;
	Если ТД = Неопределено Тогда 
		Возврат;
	КонецЕсли;
	
	Если ТД.Код > 0 Тогда
		
		НадписьРодителей = КонтактнаяИнформация.ПолучитьПолноеНазвание(ТД.Код);
		Индекс = ТД.Индекс;
		
	Иначе
		НадписьРодителей = "Не выбран элемент для детализации сведений!";
		Индекс = "";
		
	КонецЕсли;

КонецПроцедуры

