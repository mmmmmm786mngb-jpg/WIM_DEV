// ПРОЦЕДУРЫ И ФУНКЦИИ ФОРМИРОВАНИЯ СПИСКА

// Процедура устанавливает "родителя" для постороения условий отбора по переданным
// уже заполненным адресным полям
//
// Параметры: 
// Параметры: 
//  НазваниеРегиона - название региона( с сокращением)
//  НазваниеРайона - название района( с сокращением)
//  НазваниеГорода - название города( с сокращением)
//  НазваниеНаселенногоПункта - название населенного пункта( с сокращением)
//
Процедура УстановитьРодителя(Знач НазваниеРегиона, Знач НазваниеРайона, Знач НазваниеГорода, Знач НазваниеНаселенногоПункта) Экспорт

	РодительскийЭлемент = КонтактнаяИнформация.ПолучитьПустуюСтруктуруАдреса();
	КодРодителяРодителя = 0;

	Регион = КонтактнаяИнформация.ПолучитьАдресныйЭлемент(КонтактнаяИнформация.ОбрезатьСокращение(НазваниеРегиона), 1);
	Если Регион.Код > 0 Тогда
		РодительскийЭлемент = Регион;
		КодРодителяРодителя = Регион.Код;
	КонецЕсли;
	
	Район = КонтактнаяИнформация.ПолучитьАдресныйЭлемент(КонтактнаяИнформация.ОбрезатьСокращение(НазваниеРайона), 2, КодРодителяРодителя);
	Если Район.Код > 0 Тогда
		РодительскийЭлемент = Район;
		КодРодителяРодителя = Район.Код;
	КонецЕсли;
	
	Город = КонтактнаяИнформация.ПолучитьАдресныйЭлемент(КонтактнаяИнформация.ОбрезатьСокращение(НазваниеГорода), 3, КодРодителяРодителя);	
	Если Город.Код > 0 Тогда
		РодительскийЭлемент = Город;
		КодРодителяРодителя = Город.Код;
	КонецЕсли;
	
	НаселенныйПункт = КонтактнаяИнформация.ПолучитьАдресныйЭлемент(КонтактнаяИнформация.ОбрезатьСокращение(НазваниеНаселенногоПункта), 4, КодРодителяРодителя);
	
	Если НаселенныйПункт.Код > 0 Тогда
		РодительскийЭлемент = НаселенныйПункт;
		КодРодителяРодителя = НаселенныйПункт.Код;
	КонецЕсли;
	
	КодРодительскогоЭлемента = РодительскийЭлемент.Код;
		
	КодРегионаРодительскогоЭлемента   = Цел(КодРодительскогоЭлемента / КонтактнаяИнформация.МаскаРегиона());
	КодРайонаРодительскогоЭлемента    = Цел(КодРодительскогоЭлемента / КонтактнаяИнформация.МаскаРайона()) % 1000;
	КодГородаРодительскогоЭлемента    = Цел(КодРодительскогоЭлемента / КонтактнаяИнформация.МаскаГорода()) % 1000;
	КодНасПунктаРодительскогоЭлемента = Цел(КодРодительскогоЭлемента / КонтактнаяИнформация.МаскаНасПункта()) % 1000;
	КодУлицыРодительскогоЭлемента     = Цел(КодРодительскогоЭлемента / КонтактнаяИнформация.МаскаУлицы())% 10000;
	
КонецПроцедуры


// Процедура устанавливает условия отбора для демонстрации в списке для 
// выбора только регионов
//
// Параметры: 
//  нет
//
Процедура ОтобратьТолькоРегионы() Экспорт
	
	Список.Отбор.Элементы.Очистить();
	ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(Список, "ТипАдресногоЭлемента", 1, ВидСравненияКомпоновкиДанных.Равно,, Истина);	

КонецПроцедуры

// Процедура устанавливает условия отбора для демонстрации в списке для 
// выбора только регионов
//
// Параметры: 
//  нет
//
Процедура ОтобратьТолькоРайоны() Экспорт
	
	Если КодРодительскогоЭлемента = 0 Тогда
		ОтключитьЭлементОтбораСписка("КодРегионаВКоде");
	Иначе
		ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(Список, "КодРегионаВКоде", КодРегионаРодительскогоЭлемента, ВидСравненияКомпоновкиДанных.Равно,, Истина);
	КонецЕсли;
	
	ОтключитьЭлементОтбораСписка("КодРайонаВКоде");
	ОтключитьЭлементОтбораСписка("КодГородаВКоде");
	ОтключитьЭлементОтбораСписка("КодНаселенногоПунктаВКоде");
	
	ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(Список, "ТипАдресногоЭлемента", 2, ВидСравненияКомпоновкиДанных.Равно,, Истина);
		
КонецПроцедуры

// Процедура устанавливает условия отбора для демонстрации в списке для 
// выбора только районов
//
// Параметры: 
//  нет
//
Процедура ОтобратьТолькоГорода() Экспорт

	Если КодРодительскогоЭлемента = 0 Тогда
		ОтключитьЭлементОтбораСписка("КодРегионаВКоде");
		ОтключитьЭлементОтбораСписка("КодРайонаВКоде");
	Иначе
		ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(Список, "КодРегионаВКоде", КодРегионаРодительскогоЭлемента, ВидСравненияКомпоновкиДанных.Равно,, Истина);
		ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(Список, "КодРайонаВКоде", КодРайонаРодительскогоЭлемента, ВидСравненияКомпоновкиДанных.Равно,, Истина);
	КонецЕсли;
	
	ОтключитьЭлементОтбораСписка("КодГородаВКоде");
	ОтключитьЭлементОтбораСписка("КодНаселенногоПунктаВКоде");

    ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(Список, "ТипАдресногоЭлемента", 3, ВидСравненияКомпоновкиДанных.Равно,, Истина);

КонецПроцедуры

// Процедура устанавливает условия отбора для демонстрации в списке для 
// выбора только населенных пунктов
//
// Параметры: 
//  нет
//
Процедура ОтобратьТолькоНаселенныеПункты() Экспорт

	Если КодРодительскогоЭлемента = 0 Тогда
		ОтключитьЭлементОтбораСписка("КодРегионаВКоде");
		ОтключитьЭлементОтбораСписка("КодРайонаВКоде");
		ОтключитьЭлементОтбораСписка("КодГородаВКоде");
	Иначе
		ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(Список, "КодРегионаВКоде", КодРегионаРодительскогоЭлемента, ВидСравненияКомпоновкиДанных.Равно,, Истина);
		ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(Список, "КодРайонаВКоде", КодРайонаРодительскогоЭлемента, ВидСравненияКомпоновкиДанных.Равно,, Истина);
		ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(Список, "КодГородаВКоде", КодГородаРодительскогоЭлемента, ВидСравненияКомпоновкиДанных.Равно,, Истина);		 
	КонецЕсли;
	
	ОтключитьЭлементОтбораСписка("КодНаселенногоПунктаВКоде");
	ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(Список, "ТипАдресногоЭлемента", 4, ВидСравненияКомпоновкиДанных.Равно,, Истина);

КонецПроцедуры

