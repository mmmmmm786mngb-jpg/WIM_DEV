// ОСНОВНЫЕ ДЕЙСТВИЯ ФОРМЫ ЗАГРУЗКА

&НаКлиенте
Функция ПолучитьДанныеФайла(ПутькФайлу)
	
	Результат = Неопределено;
	
	Файл = Новый Файл(ПутькФайлу);	
	Если Файл.Существует() Тогда 
		Результат = Новый Структура("ИмяФайла, ДанныеФайла", Файл.Имя, Новый ДвоичныеДанные(ПутькФайлу));	
	КонецЕсли;  
	
	Возврат Результат;
	
КонецФункции	

// Процедура - обработчик события "Загрузить" командной панели "ДействияФормы".
//
&НаКлиенте
Процедура Загрузить(Команда)	
	
	ТолькоАдресныеСокращения = ПустаяСтрока(ФайлАдресногоКлассификатора)
	                         И ПустаяСтрока(ФайлКлассификатораУлиц)
	                         И (Формат2003 И ПустаяСтрока(ФайлКлассификатораДомов));
	
	ИспользуемыеРегионы = Новый Массив;
	Для каждого Элемент Из СписокРегионов Цикл
		Если Элемент.Пометка Тогда 
			ИспользуемыеРегионы.Добавить(Элемент.Значение);	
		КонецЕсли;	
	КонецЦикла;
	
	Если ИспользуемыеРегионы.Количество() = 0 И Не ТолькоАдресныеСокращения Тогда 
		Предупреждение("Необходимо отметить хотя бы один регион для загрузки");
		Возврат;
	КонецЕсли;	
							 
	АдресАдресногоКлассификатора 	= ПолучитьДанныеФайла(ФайлАдресногоКлассификатора);
	АдресКлассификатораУлиц 		= ПолучитьДанныеФайла(ФайлКлассификатораУлиц);
	АдресКлассификатораДомов 		= ПолучитьДанныеФайла(ФайлКлассификатораДомов);
	АдресКлассификатораСокращений 	= ПолучитьДанныеФайла(ФайлКлассификатораСокращений);
	ФайлыКлассификатора = Новый Структура("АдресАдресногоКлассификатора, АдресКлассификатораУлиц, АдресКлассификатораДомов, АдресКлассификатораСокращений",
												АдресАдресногоКлассификатора, АдресКлассификатораУлиц, АдресКлассификатораДомов, АдресКлассификатораСокращений);
		   		  		
	ПараметрыВыполненияОперации = Новый Структура;	
	ПараметрыВыполненияОперации.Вставить("ТолькоАдресныеСокращения", 	ТолькоАдресныеСокращения);
	ПараметрыВыполненияОперации.Вставить("ФайлыКлассификатора", 		ФайлыКлассификатора);
	ПараметрыВыполненияОперации.Вставить("ИспользуемыеРегионы", 		ИспользуемыеРегионы);
	ПараметрыВыполненияОперации.Вставить("Формат2003", 					Формат2003);
	ПараметрыВыполненияОперации.Вставить("КодировкаWindows",			КодировкаWindows);	
                  	
	ЗагрузитьКлассификаторыНаСервере(ПараметрыВыполненияОперации);
	
КонецПроцедуры

&НаСервереБезКонтекста
Процедура ЗагрузитьКлассификаторыНаСервере(ПараметрыОперации)
	
	РегистрыСведений.АдресныйКлассификатор.ВыполнитьЗагрузкуКлассификатора(ПараметрыОперации);
	
КонецПроцедуры	


	  