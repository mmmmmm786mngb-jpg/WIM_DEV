// Процедура загружает регионы из внутренних таблиц.
//
// Параметры:
//  нет
//
&НаКлиенте
Процедура ЗагрузитьРегионы(Команда)
	
	ФормаИндикацииХодаЗагрузки = ПолучитьФорму("ОбщаяФорма.ХодВыполненияОбработкиДанных");
	ФормаИндикацииХодаЗагрузки.НаименованиеОбработкиДанных = "Загрузка адресной информации";
	ФормаИндикацииХодаЗагрузки.Открыть();
	ФормаИндикацииХодаЗагрузки.КомментарийОбработкиДанных = "Чтение внутренних таблиц.";
	ФормаИндикацииХодаЗагрузки.КомментарийЗначения = "Прочитано:";    
	
	КлассификаторАдресов 	= ПолучитьТаблицуРегионов();
	ВсегоЗаписей 			= КлассификаторАдресов.ВысотаТаблицы - 1;    	
	
	
	ДанныеТаблицыРегионов = Новый Массив;  	
	
	Для Сч = 2 По КлассификаторАдресов.ВысотаТаблицы Цикл

		ФормаИндикацииХодаЗагрузки.Значение = (Сч - 1) * 100 / ВсегоЗаписей;		
		
		СтруктураРегиона = Новый Структура("Код, Наименование, Сокращение, Индекс, ТипАдресногоЭлемента, КодРегионаВКоде, КодРайонаВКоде, КодГородаВКоде, КодНаселенногоПунктаВКоде, КодУлицыВКоде");		
		
		СтруктураРегиона.Код = Число(КлассификаторАдресов.Область(Сч, 1, Сч, 1).Текст);
		КодРегиона = Цел(СтруктураРегиона.Код / КонтактнаяИнформация.МаскаРегиона());
		
		СтруктураРегиона.Наименование = СокрЛП(КлассификаторАдресов.Область(Сч, 2, Сч, 2).Текст);
		СтруктураРегиона.Сокращение   = СокрЛП(КлассификаторАдресов.Область(Сч, 3, Сч, 3).Текст);
		СтруктураРегиона.Индекс       = СокрЛП(КлассификаторАдресов.Область(Сч, 4, Сч, 4).Текст);
		СтруктураРегиона.ТипАдресногоЭлемента = 1;
		
		СтруктураРегиона.КодРегионаВКоде           = КодРегиона;
		СтруктураРегиона.КодРайонаВКоде            = Цел(СтруктураРегиона.Код / КонтактнаяИнформация.МаскаРайона()) % 1000;
		СтруктураРегиона.КодГородаВКоде            = Цел(СтруктураРегиона.Код / КонтактнаяИнформация.МаскаГорода()) % 1000;
		СтруктураРегиона.КодНаселенногоПунктаВКоде = Цел(СтруктураРегиона.Код / КонтактнаяИнформация.МаскаНасПункта()) % 1000;
		СтруктураРегиона.КодУлицыВКоде             = Цел(СтруктураРегиона.Код / КонтактнаяИнформация.МаскаУлицы())% 10000;
		
		ДанныеТаблицыРегионов.Добавить(СтруктураРегиона);
		
	КонецЦикла;
	
	ФормаИндикацииХодаЗагрузки.КомментарийОбработкиДанных = "Загружаются регионы из внутренних таблиц.";
	ФормаИндикацииХодаЗагрузки.КомментарийЗначения = "Загружено:";
	
	КоличествоЗаписейКОбработке = ДанныеТаблицыРегионов.Количество() - 1;
	ШагЗагрузки = 10;
	Сч = 0;
	Пока Сч <= КоличествоЗаписейКОбработке Цикл 
		
		МаксимальноеЗначениеИтерации = Мин(Сч + ШагЗагрузки, КоличествоЗаписейКОбработке);
		
		ФормаИндикацииХодаЗагрузки.Значение = (Сч - 1) * 100 / КоличествоЗаписейКОбработке;	
		ЗагрузитьЧастьДанных(ДанныеТаблицыРегионов, Сч, МаксимальноеЗначениеИтерации);
		
	КонецЦикла;	
	
	ФормаИндикацииХодаЗагрузки.Закрыть();  	
	
	ЗаполнитьСписокРегионов();      
	
КонецПроцедуры	

&НаСервереБезКонтекста
Процедура ЗагрузитьЧастьДанных(КоллекцияЗаписей, СчетчикЭлементов, МаксимальныйНомерЭлемента)
	
	
	Пока СчетчикЭлементов <= МаксимальныйНомерЭлемента Цикл 
		
		ЭлементКоллекции = КоллекцияЗаписей[СчетчикЭлементов];
		
		ЗаписьАдреса = РегистрыСведений.АдресныйКлассификатор.СоздатьМенеджерЗаписи();	
		ЗаполнитьЗначенияСвойств(ЗаписьАдреса, ЭлементКоллекции);
		ЗаписьАдреса.Записать(Истина);
		
		СчетчикЭлементов = СчетчикЭлементов + 1;
		
	КонецЦикла;			
	
КонецПроцедуры    

&НаСервереБезКонтекста
Функция ПолучитьТаблицуРегионов()	
	Возврат РегистрыСведений.АдресныйКлассификатор.ПолучитьМакет("ТаблицаРегионов");
КонецФункции	

