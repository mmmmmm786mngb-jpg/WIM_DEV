
#Область ОбработчикиСобытий

&НаКлиенте
Процедура СписокПередНачаломДобавления(Элемент, Отказ, Копирование, Родитель, Группа, Параметр)
	Отказ = Истина;
	Если Копирование Тогда
		ОткрытьФормуРедактированияКИ(Элементы.Список.ТекущиеДанные);
	Иначе
		ОткрытьФормуРедактированияКИ();
	КонецЕсли;
КонецПроцедуры
 
#КонецОбласти

&НаКлиенте
Процедура ОткрытьФормуРедактированияКИ(ТекущаяЗапись = Неопределено)
	ПараметрыОткрытия = Новый Структура("РедактироватьВладельца, Запись", Истина);
	Если ТекущаяЗапись = Неопределено Тогда
		СписокВыбораТиповКИ = Новый СписокЗначений;
		Для Каждого ЗначениеТипаКИ Из КоллекцияЗначенийПеречисления("ТипыКонтактнойИнформации") Цикл
			СписокВыбораТиповКИ.Добавить(ЗначениеТипаКИ, Строка(ЗначениеТипаКИ));
		КонецЦикла;
		ВыбранныйЭлемент = ВыбратьИзМеню(СписокВыбораТиповКИ, Элементы.ФормаКоманднаяПанель);
		Если ВыбранныйЭлемент = Неопределено Тогда
			Возврат;
		КонецЕсли;
		ТипКИ = ВыбранныйЭлемент.Значение;
		ПустаяЗапись = Новый Структура("Период, Тип, Вид, Объект", ТекущаяДата(), ТипКИ);
		ПараметрыОткрытия.Запись = ПустаяЗапись;
	Иначе
		ТипКИ = ТекущаяЗапись.Тип;
		ПараметрыОткрытия.Запись = ТекущаяЗапись;
	КонецЕсли;
	
	ДопПараметры = Новый Структура("Форма, ТекущаяЗапись", ЭтаФорма, ТекущаяЗапись);
	ПриОкончанииРедактирования = Новый ОписаниеОповещения("ПриОкончанииРедактированияКИ", ЭтотОбъект, ДопПараметры);
	
	ИмяФормыКИ = ОбщегоНазначения.ИмяЗначенияПеречисления(ТипКИ);	
	ОткрытьФорму("Обработка.РедактированиеКИУпр.Форма." + ИмяФормыКИ, ПараметрыОткрытия, , , , , ПриОкончанииРедактирования);
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОкончанииРедактированияКИ(РезультатЗакрытия, ДопПараметры) Экспорт
	Если РезультатЗакрытия <> Неопределено Тогда
		СохранитьЗаписьКИ(РезультатЗакрытия);
		Элементы.Список.Обновить();
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура СохранитьЗаписьКИ(ДанныеЗаписи)
	Запись = РегистрыСведений.КонтактнаяИнформация.СоздатьМенеджерЗаписи();
	ЗаполнитьЗначенияСвойств(Запись, ДанныеЗаписи);
	Запись.Записать(Истина);
КонецПроцедуры
	
&НаСервереБезКонтекста
Функция КоллекцияЗначенийПеречисления(ИмяПеречисления)
	Коллекция = Новый Массив;
	Для Каждого Значение Из Метаданные.Перечисления[ИмяПеречисления].ЗначенияПеречисления Цикл
		Коллекция.Добавить(ПредопределенноеЗначение("Перечисление." + ИмяПеречисления + "." + Значение.Имя));
	КонецЦикла;
	Возврат Коллекция;
КонецФункции
