
Процедура ПриЗаписи(Отказ, Замещение)
	Перем Запись;
	Для Каждого Запись Из ЭтотОбъект Цикл
		Запись.Автор = ?(Не ОбщегоНазначения.ЗначениеНеЗаполнено(ПараметрыСеанса.ТекущийПользователь),ПараметрыСеанса.ТекущийПользователь,ИмяПользователя());
		Запись.Компьютер = СокрЛП(ИмяКомпьютера());
		Запись.ДатаЗаписи = ТекущаяДата();
	КонецЦикла;

КонецПроцедуры
