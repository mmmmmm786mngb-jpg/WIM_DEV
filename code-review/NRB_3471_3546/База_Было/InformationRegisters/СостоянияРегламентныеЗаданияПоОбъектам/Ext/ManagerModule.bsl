// СЛУЖЕБНЫЕ ПРОЦЕДУРЫ И ФУНКЦИИ

// Для внутреннего использования
// 
Процедура ЗафиксироватьЗапускРегламента(РегламентноеЗадание) Экспорт
	МенеджерЗаписи = СоздатьМенеджерЗаписи();
	МенеджерЗаписи.РегламентноеЗадание	= РегламентноеЗадание;
	МенеджерЗаписи.ПоследнийЗапуск		= ТекущаяДатаСеанса();
	МенеджерЗаписи.Выполнено			= Ложь;
	МенеджерЗаписи.СОшибками			= Истина;
	МенеджерЗаписи.Записать(Истина);
КонецПроцедуры

// Для внутреннего использования
// 
Процедура ЗафиксироватьРезультатВыполненияРегламента(РегламентноеЗадание, РезультатВыполнения) Экспорт
	МенеджерЗаписи = СоздатьМенеджерЗаписи();
	МенеджерЗаписи.РегламентноеЗадание = РегламентноеЗадание;
	МенеджерЗаписи.Прочитать();
	
	МенеджерЗаписи.Выполнено = РезультатВыполнения.Выполнен;
	МенеджерЗаписи.СОшибками = РезультатВыполнения.БылиОшибки;
	
	Если МенеджерЗаписи.СОшибками Тогда 
		МенеджерЗаписи.ОписаниеОшибки	= РезультатВыполнения.ТекстОшибки;
	КонецЕсли;
	
	МенеджерЗаписи.Записать(Истина);
КонецПроцедуры

#КонецЕсли
