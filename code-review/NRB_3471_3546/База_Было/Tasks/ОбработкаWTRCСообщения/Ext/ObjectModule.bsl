					Уведомление = WTRCСообщенияQI.УведомлениеОКД_Участие_ЦБНеСШААктивнаяСсылка(БизнесПроцесс);
				Иначе
					Уведомление = WTRCСообщенияQI.УведомлениеОКД_Участие_ЦБНеСШААктивнаяСсылка(БизнесПроцесс);
				КонецЕсли;
			Иначе
				Если ДатаФиксации5РабочихДней <= ДатаОкончанияПриемаНРД Тогда
					Если ДанныеКОбработке.НД ИЛИ ДанныеКОбработке.ИНД Тогда 
						//Уведомление = WTRCСообщенияQI.УведомлениеОКД_УчастиеРаскрытие_ЦБНеСШАНеактивнаяСсылка(БизнесПроцесс);
						Уведомление = WTRCСообщенияQI.УведомлениеОКД_Участие_ЦБНеСШАНеактивнаяСсылка(БизнесПроцесс);
					Иначе
						Уведомление = WTRCСообщенияQI.УведомлениеОКД_Участие_ЦБНеСШАНеактивнаяСсылка(БизнесПроцесс);
					КонецЕсли;
				Иначе
					Если ДанныеКОбработке.НД ИЛИ ДанныеКОбработке.ИНД Тогда 
						ТребуетсяПовторнаяОтправка   = Ложь;
						//Уведомление = WTRCСообщенияQI.УведомлениеОКД_УчастиеРаскрытие_ЦБНеСШААктивнаяСсылкаОтветственность(БизнесПроцесс, ТребуетсяПовторнаяОтправка);
						Уведомление = WTRCСообщенияQI.УведомлениеОКД_Участие_ЦБНеСШААктивнаяСсылкаОтветственность(БизнесПроцесс, ТребуетсяПовторнаяОтправка);
					Иначе
						ТребуетсяПовторнаяОтправка   = Ложь;
						Уведомление = WTRCСообщенияQI.УведомлениеОКД_Участие_ЦБНеСШААктивнаяСсылкаОтветственность(БизнесПроцесс, ТребуетсяПовторнаяОтправка);
					КонецЕсли;
				КонецЕсли;
			КонецЕсли;
		ИначеЕсли ТекущаяДата >= ДатаФиксации1РабочийДень 
			И (СтрокаТабличнойЧасти.НомерОтправленногоУведомления = 10 
			ИЛИ СтрокаТабличнойЧасти.НомерОтправленногоУведомления = 11)
			И СтрокаТабличнойЧасти.Уведомление1_10 = Перечисления.СтатусыЗавершенияБПОбработкаWTRCСообщения.Отправлено Тогда
			Если ДанныеКОбработке.НД ИЛИ ДанныеКОбработке.ИНД Тогда 
				ТребуетсяПовторнаяОтправка   = Истина;
				//Уведомление = WTRCСообщенияQI.УведомлениеОКД_УчастиеРаскрытие_ЦБНеСШААктивнаяСсылкаОтветственность(БизнесПроцесс, ТребуетсяПовторнаяОтправка);
				Уведомление = WTRCСообщенияQI.УведомлениеОКД_Участие_ЦБНеСШААктивнаяСсылкаОтветственность(БизнесПроцесс, ТребуетсяПовторнаяОтправка);
			Иначе
				ТребуетсяПовторнаяОтправка   = Истина;
				Уведомление = WTRCСообщенияQI.УведомлениеОКД_Участие_ЦБНеСШААктивнаяСсылкаОтветственность(БизнесПроцесс, ТребуетсяПовторнаяОтправка);
			КонецЕсли;
		КонецЕсли;	
		Если Не Уведомление = Неопределено Тогда
			ДобавитьУведомлениеКОтправке(УведомленияКОтправке, Уведомление, ДанныеКОбработке, СтрокаТабличнойЧасти);					
		КонецЕсли;		
	КонецЦикла;
	
	Для Каждого УведомлениеКОтправке Из УведомленияКОтправке Цикл
		
		ПараметрыУведомления = УведомлениеКОтправке.Значение;
		Уведомление = ПараметрыУведомления.Уведомление;
		Если РезультатСозданияИОтправкиУведомленияКлиентам(БизнесПроцесс, ПараметрыУведомления, ДанныеКОбработке, ОбработкаВебСервисы)  Тогда
			Если Уведомление.Повторное Тогда 
				Статус = Перечисления.СтатусыЗавершенияБПОбработкаWTRCСообщения.ОтправленоПовторно;
			Иначе 
				Статус = Перечисления.СтатусыЗавершенияБПОбработкаWTRCСообщения.Отправлено;
			КонецЕсли;
		Иначе
			Статус = Перечисления.СтатусыЗавершенияБПОбработкаWTRCСообщения.ОшибкаОтправки;
			Если Уведомление.НомерУведомления = 12 Тогда 
				БизнесПроцессОбъект.ВыполненаПроверкаОстатков = Ложь;	
			КонецЕсли;
		КонецЕсли;
		
		Для Каждого СтрокаТаблицыКлиентов Из ПараметрыУведомления.ТаблицаКлиентов Цикл
			СтрокаТабличнойЧасти = СтрокаТаблицыКлиентов.СтрокаТабличнойЧасти;
			Если Не СтрокаТабличнойЧасти = Неопределено Тогда
				
				СтрокаТабличнойЧасти.Уведомление1_10 = Статус;
				УстановитьЗначениеВТабличнойЧастиДепонента(БизнесПроцессОбъект.Депоненты, СтрокаТабличнойЧасти.Депонент, "Уведомление1_10", СтрокаТабличнойЧасти.Уведомление1_10);				
				Если Не Статус = Перечисления.СтатусыЗавершенияБПОбработкаWTRCСообщения.ОшибкаОтправки Тогда
					Если ПараметрыУведомления.Уведомление.Уведомление1_10 ИЛИ ПараметрыУведомления.Уведомление.Уведомление2_13 Тогда 
						СтрокаТабличнойЧасти.НомерОтправленногоУведомления = ПараметрыУведомления.Уведомление.НомерУведомления;
						УстановитьЗначениеВТабличнойЧастиДепонента(БизнесПроцессОбъект.Депоненты, СтрокаТабличнойЧасти.Депонент, "НомерОтправленногоУведомления", ПараметрыУведомления.Уведомление.НомерУведомления);
					КонецЕсли;
					ДанныеПоСубброкеру = ДанныеСубброкеровДляОтправкиЗапроса.НайтиСтроки(Новый Структура("КодСубброкера", СтрокаТаблицыКлиентов.Клиент.Код));
					Если Уведомление.ТребуетсяОтправкаЗапросовСубброкеру 
						И ДанныеПоСубброкеру.Количество() > 0 Тогда 
						ОтправитьФайлЗапросаНаРаскрытие(БизнесПроцессОбъект, ДанныеПоСубброкеру, Уведомление, Ложь, ИспользоватьРегистрациюЗапросовСубброкера);				
					КонецЕсли;
				КонецЕсли;
			ИначеЕсли Уведомление.НомерУведомления = 12 Тогда
				// Уведомление об изменении остатков не отражаем в списке депонентов
				ДанныеПоСубброкеру = ДанныеСубброкеровДляОтправкиЗапроса.НайтиСтроки(Новый Структура("КодСубброкера", СтрокаТаблицыКлиентов.Клиент.Код));
				Если ДанныеПоСубброкеру.Количество() > 0 Тогда
					ДанныеПоСубброкеруСТекущимиОстатками = ДанныеРасшифровкиСубброкераДополненныеПоТекущимОстаткам(ДанныеПоСубброкеру, ПараметрыУведомления.Уведомление.Остатки);
					ОтправитьФайлЗапросаНаРаскрытие(БизнесПроцессОбъект, ДанныеПоСубброкеру, Уведомление, Ложь, ИспользоватьРегистрациюЗапросовСубброкера);				
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;
				
		Если Статус = Перечисления.СтатусыЗавершенияБПОбработкаWTRCСообщения.ОшибкаОтправки Тогда 
			Продолжить;	
		КонецЕсли;
	КонецЦикла;
	
	БизнесПроцессОбъект.ОбновитьСтатусыОтправкиЗапросовСубброкера();
	Попытка
		БизнесПроцессОбъект.Записать();
	Исключение
		ЗаписьЖурналаРегистрации(Наименование, УровеньЖурналаРегистрации.Предупреждение, Метаданные(), Ссылка, 
		"Не удалось записать задачу по причине: " + ОписаниеОшибки());	
	КонецПопытки;
	Выполнена = ВозможноЗавершениеЗадачиОбработкаСообщенийWTRCQI(КорпоративноеДействиеСсылка);	
	Возврат Истина;
		
КонецФункции

Функция РезультатЗадачиОбработкаСообщенийWTRCQIАмериканскихЦБ()
	
	Выполнена = Ложь;
	БизнесПроцессОбъект = БизнесПроцесс.ПолучитьОбъект();
	Попытка
		БизнесПроцессОбъект.Заблокировать();
	Исключение
		ЗаписьЖурналаРегистрации("ОбработкаWTRCСообщения",УровеньЖурналаРегистрации.Информация,Метаданные(),БизнесПроцессОбъект.Ссылка
		,"Не удалось заблокировать объект");
		Возврат Истина;
	КонецПопытки;

	ОбработкаВебСервисы = Неопределено;
	Если ДополнительныеСвойства.Свойство("Тестирование") Тогда 
		ОбработкаВебСервисы = Обработки.TEST_ВебСервисы.Создать();
	КонецЕсли;
	
	АмериканскаяЦБ = Истина;
	ДанныеКОбработке = ДанныеКОбработке(АмериканскаяЦБ);
	КорпоративноеДействиеСсылка = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(БизнесПроцесс,"КД");
	ИспользоватьРегистрациюЗапросовСубброкера = WTRCСообщенияQI.ИспользоватьРегистрациюЗапросовСубброкераДляДокумента(КорпоративноеДействиеСсылка);
	ПолучателиСообщенийW8 = Новый Соответствие(); 
	ПолучателиСообщений   = Новый Массив();
    УведомленияКОтправке = Новый Соответствие();

	ТекущаяДата = НачалоДня(ТекущаяДатаСеанса());
	ДатаСообщенияWTRC = НачалоДня(БизнесПроцессы.ОбработкаWTRCСообщения.ДатаСообщенияWTRC(БизнесПроцессОбъект.КД));
    ДатаФиксации = БизнесПроцессОбъект.ДатаФиксации;
	ДатаФиксации1РабочийДень = ОбщегоНазначения.ДобавитьРабочийКалендарныйДень(ДатаФиксации,1);
	ДатаФиксации5РабочихДней = ОбщегоНазначения.ДобавитьРабочийКалендарныйДень(ДатаФиксации,5);
	ДатаОкончанияПриемаНРД = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(БизнесПроцессОбъект.КД,"ДатаОкончанияПриемаИнструкцийНРД");
	Если ЗначениеЗаполнено(ДатаОкончанияПриемаНРД) Тогда 
		ДатаОкончанияПриемаНРД = НачалоДня(ДатаОкончанияПриемаНРД);
	Иначе
		СообщениеОбОшибке = "Не указана  ДатаОкончанияПриемаИнструкцийНРД";
		ЗаписьЖурналаРегистрации("Обработка WTRC соббщения",УровеньЖурналаРегистрации.Ошибка,СообщениеОбОшибке,БизнесПроцесс);
		ВызватьИсключение СообщениеОбОшибке;
	КонецЕсли;
	
	ДатаОкончанияПриемаИнструкцийВТБКБ = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(БизнесПроцессОбъект.КД,"ДатаОкончанияПриемаИнструкцийВТБКБ");
	ДатаПовторнойОтправкиУведомленияW8 = ОбщегоНазначения.ДобавитьРабочийКалендарныйДень(БизнесПроцессОбъект.ДатаОкончанияПриемаФормыW8,-2);
	
	Если ДатаСообщенияWTRC <= ДатаФиксации Тогда 
		ПроверитьОстаткиЦБ(АмериканскаяЦБ, БизнесПроцессОбъект, УведомленияКОтправке);
	КонецЕсли;
	МВТ = Новый МенеджерВременныхТаблиц;
	WTRCСообщенияQI.ДобавитьИсточникДляРаскрытияИзБизнесПроцесса(МВТ, БизнесПроцесс);
	Если ИспользоватьРегистрациюЗапросовСубброкера Тогда 
		ДанныеСубброкеровДляОтправкиЗапроса = WTRCСообщенияQI.ДанныеДляЗаполненияЗапросовНаРаскрытиеПоСубклиентам(МВТ, ДатаФиксации);
	Иначе 
		ДанныеСубброкеровДляОтправкиЗапроса = WTRCСообщенияQI.ДанныеДляЗаполненияЗапросовНаРаскрытиеПоСубклиентам_БезДокументовЗапросов(МВТ, ДатаФиксации);	
	КонецЕсли;

		
	Пока ДанныеКОбработке.Следующий() Цикл
		
		УведомлениеW8 = Неопределено;
		СтрокаТабличнойЧасти = БизнесПроцессОбъект.Депоненты.Найти(ДанныеКОбработке.НомерСтроки,"НомерСтроки");
		Если Не РазрешенаОбработкаСтрокиСОшибкойОтправки(СтрокаТабличнойЧасти) Тогда 
			Продолжить;
		КонецЕсли;
		ПредоставленаФормаW8 = Ложь;
		Если ДанныеКОбработке.НД ИЛИ ДанныеКОбработке.ИНД Тогда
			
			ЕстьНепредоставленнаяФормаУСубклиента = Ложь;
			СтрокиДепонента = БизнесПроцессОбъект.Депоненты.НайтиСтроки(Новый Структура("Депонент",ДанныеКОбработке.Клиент));
			Для Каждого СтрокаДепонента Из СтрокиДепонента Цикл 
				Если СтрокаДепонента.УведомлениеW8 <> Перечисления.СтатусыЗавершенияБПОбработкаWTRCСообщения.Успешно Тогда 
					ЕстьНепредоставленнаяФормаУСубклиента = Истина;
					Прервать;		
				КонецЕсли;
			КонецЦикла;
			
			ПредоставленаФормаW8 = Не ЕстьНепредоставленнаяФормаУСубклиента; 
			
		ИначеЕсли СтрокаТабличнойЧасти.УведомлениеW8 = Перечисления.СтатусыЗавершенияБПОбработкаWTRCСообщения.Успешно  Тогда
			ПредоставленаФормаW8 = Истина;
		КонецЕсли;
		Если Не ПредоставленаФормаW8 Тогда 
			ПредоставленаФормаW8 = ПредоставленаФормаW8(ДанныеКОбработке, СтрокаТабличнойЧасти, ПолучателиСообщенийW8, ДатаПовторнойОтправкиУведомленияW8, УведомлениеW8);
		КонецЕсли;
		Если Не УведомлениеW8 = Неопределено Тогда	
			Если ДатаПовторнойОтправкиУведомленияW8 = ТекущаяДата Тогда 
				УведомлениеW8.Повторное = Истина;
			КонецЕсли;
			ДобавитьУведомлениеКОтправке(УведомленияКОтправке, УведомлениеW8, ДанныеКОбработке, СтрокаТабличнойЧасти);	
		КонецЕсли;
		Если НЕ (ДанныеКОбработке.НД ИЛИ ДанныеКОбработке.ИНД) Тогда 
			СтрокаТабличнойЧасти.Уведомление1_10 = Перечисления.СтатусыЗавершенияБПОбработкаWTRCСообщения.НеТребуется;			
		КонецЕсли;
			
		Если ПредоставленаФормаW8  Тогда
			Если (ДанныеКОбработке.НД ИЛИ ДанныеКОбработке.ИНД) Тогда
				Если ДанныеКОбработке.W8BEN_W8BENEПредоставленаВсемиСубклиентами = ИСТИНА Тогда 
					УстановитьЗначениеВТабличнойЧастиДепонента(БизнесПроцессОбъект.Депоненты, СтрокаТабличнойЧасти.Депонент, "УведомлениеW8", СтрокаТабличнойЧасти.УведомлениеW8);
				КонецЕсли;
			Иначе 
				СтрокаТабличнойЧасти.УведомлениеW8 = Перечисления.СтатусыЗавершенияБПОбработкаWTRCСообщения.Успешно;
			КонецЕсли;	
			ТребуетсяПовторнаяОтправка		= Ложь;
			ТребуетсяОтправкаЗапроса	 	= Ложь;
			Уведомление 					= Неопределено;
			Если ПолучателиСообщений.Найти(ДанныеКОбработке.Клиент) <> Неопределено Тогда 
				Продолжить;	
			Иначе
				ПолучателиСообщений.Добавить(ДанныеКОбработке.Клиент);
			КонецЕсли;
			Если Не ЗначениеЗаполнено(СтрокаТабличнойЧасти.Уведомление1_10)
				ИЛИ СтрокаТабличнойЧасти.Уведомление1_10 = Перечисления.СтатусыЗавершенияБПОбработкаWTRCСообщения.ОшибкаОтправки Тогда
				Если ДанныеКОбработке.НД ИЛИ ДанныеКОбработке.ИНД Тогда 
					Если ДатаСообщенияWTRC <= ДатаФиксации Тогда
						Если ДатаФиксации5РабочихДней <= ДатаОкончанияПриемаНРД Тогда
							Уведомление = WTRCСообщенияQI.УведомлениеОКД_Раскрытие_ЦБСШАНеактивнаяСсылка(БизнесПроцесс);
						Иначе
							Уведомление = WTRCСообщенияQI.УведомлениеОКД_Раскрытие_ЦБСШААктивнаяСсылкаОтветственность(БизнесПроцесс);
						КонецЕсли;
					Иначе 
						ПовторнаяОтправка	 = Ложь;
						Уведомление = WTRCСообщенияQI.УведомлениеОКД_Раскрытие_ЦБСШААктивнаяСсылка(БизнесПроцесс, ПовторнаяОтправка);
					КонецЕсли;
				КонецЕсли;	
			ИначеЕсли ТекущаяДата = ДатаФиксации1РабочийДень
				И (ДанныеКОбработке.НД ИЛИ ДанныеКОбработке.ИНД )
				И СтрокаТабличнойЧасти.НомерОтправленногоУведомления = 3 
				И СтрокаТабличнойЧасти.Уведомление1_10 = Перечисления.СтатусыЗавершенияБПОбработкаWTRCСообщения.Отправлено Тогда
				ПовторнаяОтправка	 = Истина;
				Уведомление = WTRCСообщенияQI.УведомлениеОКД_Раскрытие_ЦБСШААктивнаяСсылка(БизнесПроцесс, ПовторнаяОтправка);
			КонецЕсли;
			Если Не Уведомление = Неопределено Тогда
				ДобавитьУведомлениеКОтправке(УведомленияКОтправке, Уведомление, ДанныеКОбработке, СтрокаТабличнойЧасти);								
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;	
	
	Для Каждого УведомлениеКОтправке Из УведомленияКОтправке Цикл
		
		ПараметрыУведомления = УведомлениеКОтправке.Значение;
		Уведомление = ПараметрыУведомления.Уведомление;
		Если РезультатСозданияИОтправкиУведомленияКлиентам(БизнесПроцесс, ПараметрыУведомления, ДанныеКОбработке, ОбработкаВебСервисы) Тогда
			Если Уведомление.Повторное Тогда 
				Статус = Перечисления.СтатусыЗавершенияБПОбработкаWTRCСообщения.ОтправленоПовторно;
			Иначе 
				Статус = Перечисления.СтатусыЗавершенияБПОбработкаWTRCСообщения.Отправлено;
			КонецЕсли;	
		Иначе 
			Статус = Перечисления.СтатусыЗавершенияБПОбработкаWTRCСообщения.ОшибкаОтправки;
			Если Уведомление.НомерУведомления = 12 Тогда 
				БизнесПроцессОбъект.ВыполненаПроверкаОстатков = Ложь;	
			КонецЕсли;
		КонецЕсли;
		
		Для Каждого СтрокаТаблицыКлиентов Из ПараметрыУведомления.ТаблицаКлиентов Цикл
			СтрокаТабличнойЧасти = СтрокаТаблицыКлиентов.СтрокаТабличнойЧасти;
			Если Не СтрокаТабличнойЧасти = Неопределено Тогда
				Если ПараметрыУведомления.Уведомление.Уведомление1_10 ИЛИ ПараметрыУведомления.Уведомление.Уведомление2_13 Тогда
					СтрокаТабличнойЧасти.НомерОтправленногоУведомления = Уведомление.НомерУведомления;
					УстановитьЗначениеВТабличнойЧастиДепонента(БизнесПроцессОбъект.Депоненты, СтрокаТабличнойЧасти.Депонент, "НомерОтправленногоУведомления", Уведомление.НомерУведомления);
		        КонецЕсли;
				Если (ПараметрыУведомления.Уведомление.НомерУведомления = 1 ИЛИ ПараметрыУведомления.Уведомление.НомерУведомления = 2) Тогда 
					СтрокаТабличнойЧасти.УведомлениеW8 = Статус;
					УстановитьЗначениеВТабличнойЧастиДепонента(БизнесПроцессОбъект.Депоненты, СтрокаТабличнойЧасти.Депонент, "УведомлениеW8", Статус);					
				Иначе 
					СтрокаТабличнойЧасти.Уведомление1_10 = Статус;
					УстановитьЗначениеВТабличнойЧастиДепонента(БизнесПроцессОбъект.Депоненты, СтрокаТабличнойЧасти.Депонент, "Уведомление1_10", Статус);
					Если Не Статус = Перечисления.СтатусыЗавершенияБПОбработкаWTRCСообщения.ОшибкаОтправки Тогда
						ДанныеПоСубброкеру = ДанныеСубброкеровДляОтправкиЗапроса.НайтиСтроки(Новый Структура("КодСубброкера", СтрокаТаблицыКлиентов.Клиент.Код));
						Если ДанныеПоСубброкеру.Количество() > 0 Тогда  
							Если Уведомление.ТребуетсяОтправкаЗапросовСубброкеру Тогда 
								ОтправитьФайлЗапросаНаРаскрытие(БизнесПроцессОбъект, ДанныеПоСубброкеру, Уведомление, АмериканскаяЦБ, ИспользоватьРегистрациюЗапросовСубброкера);
							КонецЕсли;
						Иначе 
							СтрокаТабличнойЧасти.Уведомление1_10 = Перечисления.СтатусыЗавершенияБПОбработкаWTRCСообщения.НеТребуется;
						КонецЕсли;
						УстановитьЗначениеВТабличнойЧастиДепонента(БизнесПроцессОбъект.Депоненты, СтрокаТабличнойЧасти.Депонент, "Уведомление1_10", СтрокаТабличнойЧасти.Уведомление1_10);
					КонецЕсли;
				КонецЕсли;	
			ИначеЕсли Уведомление.НомерУведомления = 12 Тогда
				// Уведомление об изменении остатков не отражаем в списке депонентов
				ДанныеПоСубброкеру = ДанныеСубброкеровДляОтправкиЗапроса.НайтиСтроки(Новый Структура("КодСубброкера", СтрокаТаблицыКлиентов.Клиент.Код));
				Если ДанныеПоСубброкеру.Количество() > 0 Тогда
					ДанныеПоСубброкеруСТекущимиОстатками = ДанныеРасшифровкиСубброкераДополненныеПоТекущимОстаткам(ДанныеПоСубброкеру, ПараметрыУведомления.Уведомление.Остатки);
					ОтправитьФайлЗапросаНаРаскрытие(БизнесПроцессОбъект, ДанныеПоСубброкеруСТекущимиОстатками, Уведомление, Ложь, ИспользоватьРегистрациюЗапросовСубброкера);				
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;
	
	БизнесПроцессОбъект.ОбновитьСтатусыОтправкиЗапросовСубброкера();
	Попытка
		БизнесПроцессОбъект.Записать();
	Исключение
		ЗаписьЖурналаРегистрации(Наименование, УровеньЖурналаРегистрации.Предупреждение, Метаданные(), Ссылка, 
		"Не удалось записать задачу по причине: " + ОписаниеОшибки());	
	КонецПопытки;
	Выполнена = ВозможноЗавершениеЗадачиОбработкаСообщенийWTRCQI(КорпоративноеДействиеСсылка);		
	Возврат Истина;

КонецФункции

// Возвращает Истина, если по всем депонентам (у которых бумаги были не на налоговом) есть поручение 1.5 или 1.10
Функция ПринялиУчастиеВсеДепоненты()
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	Депоненты.Депонент КАК Депонент
	|ПОМЕСТИТЬ втДепонентыБП
	|ИЗ
	|	БизнесПроцесс.ОбработкаWTRCСообщения.Депоненты КАК Депоненты
	|ГДЕ
	|	Депоненты.Ссылка = &БизнесПроцесс
	|	И Депоненты.РазделСчета.ТипРазделаСчетаДЕПО <> &Налоговый
	|;
	|
	|////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Поручение.Депонент КАК Депонент
	|ПОМЕСТИТЬ втПорученияНаУчастие
	|ИЗ
	|	Документ.Поручение КАК Поручение
	|ГДЕ
	|	Поручение.КарточкаКД = &КД
	|	И НЕ Поручение.ПометкаУдаления
	|	И ВЫРАЗИТЬ(Поручение.ВидОперацииД КАК Справочник.ВидыОпераций) В (&ВидыПорученийУчастия)
	|;
	|
	|////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ДепонентыБП.Депонент КАК Депонент
	|ИЗ
	|	втДепонентыБП КАК ДепонентыБП
	|	ЛЕВОЕ СОЕДИНЕНИЕ втПорученияНаУчастие КАК ПорученияНаУчастие
	|	ПО
	|		ДепонентыБП.Депонент = ПорученияНаУчастие.Депонент	
	|
	|ГДЕ
	|	ПорученияНаУчастие.Депонент ЕСТЬ NULL");
	
	ВидыПорученийУчастия = Новый Массив;
	ВидыПорученийУчастия.Добавить(Справочники.ВидыОпераций.ПереводМеждуРазделамиСчетаДепо);	// Поручение 1.5
	ВидыПорученийУчастия.Добавить(Справочники.ВидыОпераций.Перемещение);					// Поручение 1.5
	ВидыПорученийУчастия.Добавить(Справочники.ВидыОпераций.УчастиеВКД);						// Поручение 1.10
	
	Запрос.УстановитьПараметр("БизнесПроцесс",			БизнесПроцесс);
	Запрос.УстановитьПараметр("Налоговый",				Перечисления.ТипыРазделовСчетовДЕПО.Налоговый);
	Запрос.УстановитьПараметр("КД",						БизнесПроцесс.КД);
	Запрос.УстановитьПараметр("ВидыПорученийУчастия",	ВидыПорученийУчастия);
	
	Возврат Запрос.Выполнить().Пустой();
КонецФункции

Функция РезультатСозданияДокументаРаскрытиеСпискаВладельцев(АмериканскаяЦБ = Ложь)
	ИмяСобытия = "Создание налогового списка раскрытия владельцев";
	ДепонентыСПоручениями1_10 = Документы.РаскрытиеСпискаВладельцев.ДепонентыСПоручениями1_10(БизнесПроцесс.КД);
	
	Если АмериканскаяЦБ = Ложь И ДепонентыСПоручениями1_10.Депоненты.Количество() = 0 Тогда
		ЗаписьЖурналаРегистрации(ИмяСобытия, УровеньЖурналаРегистрации.Предупреждение,,,
			"Нет депонентов с поручениями 1.10 для раскрытия. Документ РСВ не создан.");
		Возврат Ложь;
	КонецЕсли;
	
	ДокОбъект = Документы.РаскрытиеСпискаВладельцев.СоздатьДокумент();
	ДокОбъект.Дата = ТекущаяДата();	
	ДокОбъект.Заполнить(БизнесПроцесс.КД);
	
	Если АмериканскаяЦБ Тогда
		
		КорпоративноеДействие = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(БизнесПроцесс,"КД");
		РеквизитыКорпоративноеДействие = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(КорпоративноеДействие,"ВидКД, ДатаОкончанияПриемаИнструкцийВТБКБ, КДРеференс");
		ДокОбъект.ДатаОкончанияПриемаИнструкцийВТБКБ = РеквизитыКорпоративноеДействие.ДатаОкончанияПриемаИнструкцийВТБКБ;
		ДокОбъект.ВидКорпоративногоДействия = РеквизитыКорпоративноеДействие.ВидКД;
		ДокОбъект.КДРеференс = РеквизитыКорпоративноеДействие.КДРеференс;
		ДокОбъект.ЗаполнитьСписокВладельцевПоОстаткам();
		ДокОбъект.УстановитьПризнакПоДаннымСубброкераДляРазделовСубклиентов();
	КонецЕсли;
	
	Попытка
		ДокОбъект.Записать(РежимЗаписиДокумента.Запись);
	Исключение
		ЗаписьЖурналаРегистрации(ИмяСобытия, УровеньЖурналаРегистрации.Ошибка,,,
			"Документ РСВ не создан: " + ОписаниеОшибки());
		Возврат Ложь;
	КонецПопытки;
	
	РегистрыСведений.Поручения1_10ПоРСВ.УстановитьСвязи(ДокОбъект.Ссылка, ДепонентыСПоручениями1_10.Поручения);
	Возврат Истина;
КонецФункции

Функция РезультатЗадачиОбработкаWTRCСообщения()
	Если НЕ РезультатОбновленияРазделаСчетаВДепонентахБП() Тогда
		Выполнена = Ложь;
		Возврат Ложь;
	КонецЕсли;
	
	Если НачалоДня(ТекущаяДата()) > НачалоДня(БизнесПроцесс.ДатаОкончанияПриемаФормыW8) Тогда
		Возврат Истина;	// Дата просрочена, отправка уведомлений не имеет смысла
	КонецЕсли;
	
	НеобработанныеДепоненты = НеобработанныеДепоненты();

	ДепонентыДляОтправки = ДепонентыСФормойW8_ЦБ_НЕ_НаНалоговомРазделе(НеобработанныеДепоненты);
	Если ДепонентыДляОтправки.Количество() > 0 Тогда
		ПодтвержденноеУведомление = Документы.УведомлениеКлиентам.ПодтвержденноеУведомлениеПоКД(БизнесПроцесс.КД);
		Если ЗначениеЗаполнено(ПодтвержденноеУведомление) Тогда
			МассивДепонентов = ОтправленныеРанееДепоненты(ПодтвержденноеУведомление, ДепонентыДляОтправки);
			УстановитьФлажокВТаблицеДепонентов(МассивДепонентов,
				"ОтправленоУведомлениеККОПеремещенииНаНалоговыйРаздел");
				
			МассивДепонентов = НеотправленныеДепоненты(ПодтвержденноеУведомление, ДепонентыДляОтправки);
			Если МассивДепонентов.Количество() > 0 Тогда
				Успешно = РезультатСозданияКДИлиДобавленияКлиентаВ_КД_WTRC(МассивДепонентов,
					ПодтвержденноеУведомление);
				Если НЕ Успешно Тогда
					СообщитьОбОшибке("Не удалось отправить уведомления в КК.");
					Выполнена = Ложь;
					Возврат Ложь;
				КонецЕсли;
				УстановитьФлажокВТаблицеДепонентов(МассивДепонентов,
					"ОтправленоУведомлениеККОПеремещенииНаНалоговыйРаздел");
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	ДепонентыДляУстановкиФлажка = ДепонентыСФормойW8_ЦБНаНалоговомРазделе(НеобработанныеДепоненты);
	УстановитьФлажокВТаблицеДепонентов(ДепонентыДляУстановкиФлажка, "ЦБНаНалоговомРазделе");
	
	Если НеобработанныеДепоненты().Количество() > 0 Тогда
		Выполнена = Ложь;
	КонецЕсли;
	Возврат Истина;
КонецФункции

Функция РезультатОбновленияРазделаСчетаВДепонентахБП(ИмяТабЧастиИсточника = "Депоненты")
	НачатьТранзакцию();
	
	//Попытка
	//	Блокировка = Новый БлокировкаДанных;
	//	ЭлементБлокировки = Блокировка.Добавить("БизнесПроцесс.ОбработкаWTRCСообщения");
	//	ЭлементБлокировки.УстановитьЗначение("Ссылка", БизнесПроцесс);
	//	ЭлементБлокировки.Режим = РежимБлокировкиДанных.Исключительный;
	//	Блокировка.Заблокировать();
	//Исключение
	//	ОтменитьТранзакцию();
	//	Возврат Ложь;
	//КонецПопытки;
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Депоненты.Депонент КАК Депонент,
	|	Депоненты.РазделСчета КАК РазделСчета
	|ПОМЕСТИТЬ втДепонентыСПустымРазделом
	|ИЗ
	|	БизнесПроцесс.ОбработкаWTRCСообщения.Депоненты КАК Депоненты
	|ГДЕ
	|	Депоненты.Ссылка = &БизнесПроцесс
	|	И Депоненты.РазделСчетаПолучатель = &ПустойРазделСчета
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Депоненты.Депонент КАК Депонент,
	|	МАКСИМУМ(Разделы.Ссылка) КАК РазделСчетаПолучатель
	|ИЗ
	|	Справочник.РазделыСчетаДепо КАК Разделы
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ втДепонентыСПустымРазделом КАК Депоненты
	|		ПО Разделы.Владелец.Владелец = Депоненты.РазделСчета.Владелец
	|ГДЕ
	|	Разделы.ТипРазделаСчетаДЕПО = &Налоговый
	|	И НЕ Разделы.ПометкаУдаления
	|
	|СГРУППИРОВАТЬ ПО
	|	Депоненты.Депонент");
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "БизнесПроцесс.ОбработкаWTRCСообщения.Депоненты",
		"БизнесПроцесс.ОбработкаWTRCСообщения." + ИмяТабЧастиИсточника);
	Запрос.УстановитьПараметр("БизнесПроцесс",		БизнесПроцесс);
	Запрос.УстановитьПараметр("ПустойРазделСчета",	Справочники.РазделыСчетаДепо.ПустаяСсылка());
	Запрос.УстановитьПараметр("Налоговый",			Перечисления.ТипыРазделовСчетовДЕПО.Налоговый);
	РезультатЗапроса = Запрос.Выполнить();
	Если НЕ РезультатЗапроса.Пустой() Тогда
		БПОбъект = БизнесПроцесс.ПолучитьОбъект();
		Выборка = РезультатЗапроса.Выбрать();
		Пока Выборка.Следующий() Цикл
			Отбор = Новый Структура("Депонент", Выборка.Депонент);
			Строки = БПОбъект[ИмяТабЧастиИсточника].НайтиСтроки(Отбор);
			Для Каждого Строка Из Строки Цикл
				Строка.РазделСчетаПолучатель = Выборка.РазделСчетаПолучатель;
			КонецЦикла;
		КонецЦикла;
		
		Попытка
			БПОбъект.Записать();
		Исключение
			ЗаписьЖурналаРегистрации("Обновление раздела счета ДЕПО в бизнес-процессе 'Обработка WTRC-сообщения'",
				УровеньЖурналаРегистрации.Ошибка, Метаданные.БизнесПроцессы.ОбработкаWTRCСообщения, БизнесПроцесс,
				"Не удалось записать бизнес-процесс: " + ОписаниеОшибки());			
			ОтменитьТранзакцию();
			Возврат Ложь;
		КонецПопытки;
	КонецЕсли;
	
	ЗафиксироватьТранзакцию();
	Возврат Истина;
КонецФункции

Функция РезультатСозданияКДИлиДобавленияКлиентаВ_КД_WTRC(МассивДепонентов, ПодтвержденноеУведомление,
	ИмяТабЧастиИсточника = "Депоненты")
	Данные = Документы.УведомлениеКлиентам.ДанныеДляWebСервисовWTRC(БизнесПроцесс.КД, МассивДепонентов, Дата, ИмяТабЧастиИсточника);
		
	ПараметрыWebСервиса = Новый Структура;
	ПараметрыWebСервиса.Вставить("Данные", Данные);
	ПараметрыWebСервиса.Вставить("РеференсКД", СокрЛП(БизнесПроцесс.КДРеференс));	
	ПараметрыWebСервиса.Вставить("НаименованиеЭмитента",
		Справочники.ЦенныеБумаги.НаименованиеЭмитента(БизнесПроцесс.ЦеннаяБумага1));
	ПараметрыWebСервиса.Вставить("НаименованиеЦБ",		Справочники.ЦенныеБумаги.РусскоеНаименование(БизнесПроцесс.ЦеннаяБумага1));
	ПараметрыWebСервиса.Вставить("ДатаОкончанияПриемаПоручений1_10", БизнесПроцесс.ДатаОкончанияПриемаПоручений1_10);
	ПараметрыWebСервиса.Вставить("ДатаОкончанияПриемаПоручений1_5", БизнесПроцесс.ДатаОкончанияПриемаПоручений1_5);
	ПараметрыWebСервиса.Вставить("ЗаголовокСообщения",	ПодтвержденноеУведомление.ЗаголовокСообщения);
	ПараметрыWebСервиса.Вставить("ТекстСообщения",		ПодтвержденноеУведомление.ТелоСообщения);
	Успешно = Документы.УведомлениеКлиентам.РезультатСозданияКДИлиДобавленияКлиентаВ_КД_WTRC(
		ПодтвержденноеУведомление, ПараметрыWebСервиса);
	Если Успешно Тогда
		РегистрыСведений.УведомленияОтправленныеЧерезЛичныйКабинет.ДобавитьКлиентов(ТекущаяДата(),
			ПодтвержденноеУведомление, Данные.Скопировать(, "Клиент, Договор, СчетДепо, РазделСчетаДепо, ЦеннаяБумага, Количество"));
	КонецЕсли;
	Возврат Успешно;
КонецФункции

Процедура УстановитьФлажокВТаблицеДепонентов(МассивДепонентов, ИмяРеквизитаТабЧасти)
	Если МассивДепонентов.Количество() > 0 Тогда
		Для Каждого Строка Из Депоненты Цикл
			Если МассивДепонентов.Найти(Строка.Депонент) <> Неопределено Тогда
				Строка[ИмяРеквизитаТабЧасти] = Истина;
			Конецесли;
		КонецЦикла;
	КонецЕсли;
КонецПроцедуры

Процедура СообщитьОбОшибке(ОписаниеОшибки)
	ИмяСобытия = "Вызов внешнего веб-сервиса для отправки уведомления о КД";
	ЗаписьЖурналаРегистрации(ИмяСобытия, УровеньЖурналаРегистрации.Ошибка,,, ОписаниеОшибки);
	Сообщение = Новый СообщениеПользователю;
	Сообщение.Текст = ОписаниеОшибки;
	Сообщение.Сообщить();
КонецПроцедуры

Функция ДепонентыСФормойW8_ЦБ_НЕ_НаНалоговомРазделе(МассивДепонентов, ИмяТабЧастиИсточника = "Депоненты")
	Условия =
	"Депоненты.РазделСчета.ТипРазделаСчетаДЕПО <> &Налоговый
	|И Депоненты.РазделСчетаПолучатель.ТипРазделаСчетаДЕПО = &Налоговый";
	Возврат ДепонентыСФормойW8_ЦБСУсловием(МассивДепонентов, Условия, ИмяТабЧастиИсточника);
КонецФункции

Функция ДепонентыСФормойW8_ЦБНаНалоговомРазделе(МассивДепонентов, ИмяТабЧастиИсточника = "Депоненты")
	Условия = "Депоненты.РазделСчета.ТипРазделаСчетаДЕПО = &Налоговый";
	Возврат ДепонентыСФормойW8_ЦБСУсловием(МассивДепонентов, Условия, ИмяТабЧастиИсточника);
КонецФункции

Функция ДепонентыСФормойW8_ЦБСУсловием(МассивДепонентов, УсловиеОтбора, ИмяТабЧастиИсточника)
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Депоненты.Депонент КАК Депонент
	|ИЗ
	|	БизнесПроцесс.ОбработкаWTRCСообщения.Депоненты КАК Депоненты
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ПредоставленныеДокументы.СрезПоследних(&ДатаСреза, ВидДокумента = &ФормаW8) КАК ФормаW8
	|		ПО (ФормаW8.Депонент = Депоненты.Депонент)
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ПредоставленныеДокументы.СрезПоследних(&ДатаСреза, 
	|			ВидДокумента = &УсловноеДлящеесяПоручение
	|			И (СрокДействия = ДАТАВРЕМЯ(1,1,1) ИЛИ СрокДействия >= НАЧАЛОПЕРИОДА(&ДатаСреза, ДЕНЬ))	) КАК УДП
	|		ПО (УДП.Депонент = Депоненты.Депонент)
	|ГДЕ
	|	Депоненты.Депонент В(&Депоненты)
	|	И Депоненты.Ссылка = &БизнесПроцесс
	|	И &УсловиеОтбора
	|	И Депоненты.Депонент.Субброкер = ЛОЖЬ
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Депоненты.Депонент
	|ИЗ
	|	БизнесПроцесс.ОбработкаWTRCСообщения.Депоненты КАК Депоненты
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ПредоставленныеДокументы.СрезПоследних(&ДатаСреза, ВидДокумента = &ФормаW8) КАК ФормаW8
	|		ПО Депоненты.РазделСчета.Субклиент = ФормаW8.Депонент
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ПредоставленныеДокументы.СрезПоследних(&ДатаСреза, 
	|			ВидДокумента = &УсловноеДлящеесяПоручение
	|			И (СрокДействия = ДАТАВРЕМЯ(1,1,1) ИЛИ СрокДействия >= НАЧАЛОПЕРИОДА(&ДатаСреза, ДЕНЬ))	) КАК УДП
	|		ПО (УДП.Депонент = Депоненты.РазделСчета.Субклиент)
	|ГДЕ
	|	Депоненты.Депонент В(&Депоненты)
	|	И Депоненты.Ссылка = &БизнесПроцесс
	|	И &УсловиеОтбора
	|	И Депоненты.РазделСчета.РазделСубклиента = ИСТИНА");
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "БизнесПроцесс.ОбработкаWTRCСообщения.Депоненты",
		"БизнесПроцесс.ОбработкаWTRCСообщения." + ИмяТабЧастиИсточника);
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеОтбора", УсловиеОтбора);
	Запрос.УстановитьПараметр("ДатаСреза",	ТекущаяДата());
	Запрос.УстановитьПараметр("Депоненты",	МассивДепонентов);
	Запрос.УстановитьПараметр("БизнесПроцесс", БизнесПроцесс);
	Запрос.УстановитьПараметр("Налоговый",	Перечисления.ТипыРазделовСчетовДЕПО.Налоговый);
	Запрос.УстановитьПараметр("ФормаW8",	Справочники.ВидыДокументовУдостоверяющихПолномочия.ФормаW8BENE_W8BEN);
	Запрос.УстановитьПараметр("УсловноеДлящеесяПоручение",	Справочники.ВидыДокументовУдостоверяющихПолномочия.УсловноеДлящеесяПоручение);
	Возврат Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Депонент");
КонецФункции

Функция ОтправленныеРанееДепоненты(ПодтвержденноеУведомление, МассивДепонентов)
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ОтправленныеУведомления.Клиент КАК Депонент
	|ИЗ
	|	РегистрСведений.УведомленияОтправленныеЧерезЛичныйКабинет.СрезПоследних(
	|			&ДатаСреза,
	|			КД = &ПодтвержденноеУведомление
	|				И Клиент В (&Депоненты)) КАК ОтправленныеУведомления");
	Запрос.УстановитьПараметр("ДатаСреза",	ТекущаяДата());
	Запрос.УстановитьПараметр("Депоненты",	МассивДепонентов);
	Запрос.УстановитьПараметр("ПодтвержденноеУведомление", ПодтвержденноеУведомление);
	Возврат Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Депонент");
КонецФункции

Функция НеотправленныеДепоненты(ПодтвержденноеУведомление, МассивДепонентов)
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Контрагенты.Ссылка КАК Депонент
	|ИЗ
	|	Справочник.Контрагенты КАК Контрагенты
	|
	|	ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.УведомленияОтправленныеЧерезЛичныйКабинет.СрезПоследних(&ДатаСреза,
	|			КД = &ПодтвержденноеУведомление) КАК ОтправленныеУведомления
	|	ПО
	|		ОтправленныеУведомления.Клиент = Контрагенты.Ссылка
	|
	|ГДЕ
	|	Контрагенты.Ссылка В(&Депоненты)
	|	И ОтправленныеУведомления.Клиент ЕСТЬ NULL");
	Запрос.УстановитьПараметр("ДатаСреза",	ТекущаяДата());
	Запрос.УстановитьПараметр("Депоненты",	МассивДепонентов);
	Запрос.УстановитьПараметр("ПодтвержденноеУведомление", ПодтвержденноеУведомление);
	Возврат Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Депонент");
КонецФункции

Функция НеобработанныеДепоненты()
	МассивДепонентов = Новый Массив;
	Для Каждого Строка Из Депоненты Цикл
		ДепонентОбработан = Строка.ЦБНаНалоговомРазделе
			ИЛИ Строка.ОтправленоУведомлениеККОПеремещенииНаНалоговыйРаздел;
		Если НЕ ДепонентОбработан Тогда
			МассивДепонентов.Добавить(Строка.Депонент);
		Конецесли;
	КонецЦикла;
	Возврат МассивДепонентов;
КонецФункции

Функция ПредоставленаФормаW8(ДанныеКОбработке, СтрокаТабличнойЧасти, ПолучателиСообщений, ДатаПовторнойОтправкиУведомленияW8, Уведомление)
	
	ПовторнаяОтправка = Ложь;
	Тестирование =  ДополнительныеСвойства.Свойство("Тестирование");
	Возврат БизнесПроцессы.ОбработкаWTRCСообщения.ПредоставленаФормаW8(БизнесПроцесс, ДанныеКОбработке, СтрокаТабличнойЧасти, ПолучателиСообщений, 
	ДатаПовторнойОтправкиУведомленияW8, Уведомление, ПовторнаяОтправка, Тестирование); 	
	
КонецФункции
