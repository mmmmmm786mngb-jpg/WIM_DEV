
Процедура ПриВыполнении(Отказ)
	
	Если ТочкаМаршрута = БизнесПроцессы.ОбработкаWTRCСообщения.ТочкиМаршрута.ОбработкаWTRCСообщения Тогда
		Успешно = РезультатЗадачиОбработкаWTRCСообщения();	
	ИначеЕсли ТочкаМаршрута = БизнесПроцессы.ОбработкаWTRCСообщения.ТочкиМаршрута.ФормированиеДокументаРаскрытиеСпискаВладельцев Тогда
		Успешно = РезультатЗадачиФормированиеДокументаРаскрытиеСпискаВладельцев(Истина);
	ИначеЕсли ТочкаМаршрута = БизнесПроцессы.ОбработкаWTRCСообщения.ТочкиМаршрута.ФормированиеДокументаРаскрытиеСпискаВладельцевАмериканскаяЦБ Тогда
		Успешно = РезультатЗадачиФормированиеДокументаРаскрытиеСпискаВладельцев(Истина);
	ИначеЕсли ТочкаМаршрута = БизнесПроцессы.ОбработкаWTRCСообщения.ТочкиМаршрута.ФормированиеДокументаРаскрытиеСпискаВладельцевУДП
		ИЛИ ТочкаМаршрута = БизнесПроцессы.ОбработкаWTRCСообщения.ТочкиМаршрута.ДопФормированиеДокументаРаскрытиеСпискаВладельцевУДППослеФиксации Тогда
		Успешно = РезультатЗадачиФормированиеДокументаРаскрытиеСпискаВладельцевУДП();
	ИначеЕсли ТочкаМаршрута = БизнесПроцессы.ОбработкаWTRCСообщения.ТочкиМаршрута.ФормированиеУведомленияОКД Тогда
		Успешно = РезультатЗадачиФормированиеУведомленияОКД("Депоненты");
	ИначеЕсли ТочкаМаршрута = БизнесПроцессы.ОбработкаWTRCСообщения.ТочкиМаршрута.ДопФормированиеУведомленияОКДПослеФиксации Тогда
		Успешно = РезультатЗадачиФормированиеУведомленияОКД("ДепонентыПослеФиксации");
	ИначеЕсли ТочкаМаршрута = БизнесПроцессы.ОбработкаWTRCСообщения.ТочкиМаршрута.ОжиданиеНаступленияДатыФиксации Тогда
		Успешно = РезультатЗадачиОжиданиеНаступленияДатыФиксации();
	ИначеЕсли ТочкаМаршрута = БизнесПроцессы.ОбработкаWTRCСообщения.ТочкиМаршрута.ДопЗаполнениеБизнесПроцессаПослеФиксации Тогда
		Успешно = РезультатЗадачиДопЗаполнениеБизнесПроцессаПослеФиксации();
	ИначеЕсли ТочкаМаршрута = БизнесПроцессы.ОбработкаWTRCСообщения.ТочкиМаршрута.ОбработкаСообщенийWTRCQI Тогда 
		Успешно = РезультатЗадачиОбработкаСообщенийWTRCQI();
	ИначеЕсли ТочкаМаршрута = БизнесПроцессы.ОбработкаWTRCСообщения.ТочкиМаршрута.ОбработкаСообщенийWTRCQIАмериканскихЦБ Тогда 
		Успешно = РезультатЗадачиОбработкаСообщенийWTRCQIАмериканскихЦБ();
	ИначеЕсли ТочкаМаршрута = БизнесПроцессы.ОбработкаWTRCСообщения.ТочкиМаршрута.ОбработкаСообщенийWTRCQIНеАмериканскиеЦБ Тогда 
		Успешно = РезультатЗадачиОбработкаСообщенийWTRCQIНеАмериканскихЦБ();
	КонецЕсли;
	
	Если НЕ Успешно Тогда
		Отказ = Истина;
	КонецЕсли;
	
	
КонецПроцедуры

Функция РезультатЗадачиДопЗаполнениеБизнесПроцессаПослеФиксации()
	
	БизнесПроцессОбъект = БизнесПроцесс.ПолучитьОбъект();
	БизнесПроцессОбъект.ЗаполнитьТаблицуДепонентов("ДепонентыПослеФиксации");
	БизнесПроцессОбъект.Записать();
	Возврат Истина;
	
КонецФункции

Функция РезультатЗадачиОжиданиеНаступленияДатыФиксации()
	
	ДатаФиксацииСоВременем = БизнесПроцесс.ДатаФиксации;
	ОбщегоНазначения.СкопироватьВремя(ДатаФиксацииСоВременем, '00010101190000');
	Выполнена = ТекущаяДатаСеанса() > ДатаФиксацииСоВременем;
	Возврат Истина;
	
КонецФункции

Функция РезультатЗадачиФормированиеДокументаРаскрытиеСпискаВладельцевУДП()
	
	Успешно = Задачи.ОбработкаWTRCСообщения.РезультатСозданияОбновленияДокументаРаскрытиеСпискаВладельцев(БизнесПроцесс.КД);
	Если Успешно Тогда
		Задачи.ОбработкаWTRCСообщения.ОтправитьУведомлениеДепозитарию(БизнесПроцесс);
	КонецЕсли;
	
	Возврат Истина;
	
КонецФункции

Функция РезультатЗадачиФормированиеУведомленияОКД(ИмяТабЧастиИсточника)
	Если НЕ РезультатОбновленияРазделаСчетаВДепонентахБП(ИмяТабЧастиИсточника) Тогда
		Выполнена = Ложь;
		Возврат Ложь;
	КонецЕсли;
	
	Если НачалоДня(ТекущаяДата()) > НачалоДня(БизнесПроцесс.ДатаОкончанияПриемаФормыW8) Тогда
		Возврат Истина;	// Дата просрочена, отправка уведомлений не имеет смысла
	КонецЕсли;
	
	НеобработанныеДепоненты = НеобработанныеДепонентыПоУДП();

	ДепонентыДляОтправки = ДепонентыСФормойW8_ЦБ_НЕ_НаНалоговомРазделеБезУДП(НеобработанныеДепоненты, ИмяТабЧастиИсточника);
	Если ДепонентыДляОтправки.Количество() > 0 Тогда
		ПодтвержденноеУведомление = Документы.УведомлениеКлиентам.ПодтвержденноеУведомлениеПоКД(БизнесПроцесс.КД);
		Если ЗначениеЗаполнено(ПодтвержденноеУведомление) Тогда
			МассивДепонентов = ОтправленныеРанееДепоненты(ПодтвержденноеУведомление, ДепонентыДляОтправки);
			УстановитьФлажокВТаблицеДепонентов(МассивДепонентов,
				"ОтправленоУведомлениеККОПеремещенииНаНалоговыйРаздел");
				
			МассивДепонентов = НеотправленныеДепоненты(ПодтвержденноеУведомление, ДепонентыДляОтправки);
			Если МассивДепонентов.Количество() > 0 Тогда
				Успешно = РезультатСозданияКДИлиДобавленияКлиентаВ_КД_WTRC(МассивДепонентов,
					ПодтвержденноеУведомление, ИмяТабЧастиИсточника);
				Если НЕ Успешно Тогда
					СообщитьОбОшибке("Не удалось отправить уведомления в КК.");
					Выполнена = Ложь;
					Возврат Ложь;
				КонецЕсли;
				УстановитьФлажокВТаблицеДепонентов(МассивДепонентов,
					"ОтправленоУведомлениеККОПеремещенииНаНалоговыйРаздел");
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	ДепонентыДляУстановкиФлажка = ДепонентыСФормойW8_ЦБНаНалоговомРазделе(НеобработанныеДепоненты, ИмяТабЧастиИсточника);
	УстановитьФлажокВТаблицеДепонентов(ДепонентыДляУстановкиФлажка, "ЦБНаНалоговомРазделе");
	
	Возврат Истина;
КонецФункции

Функция НеобработанныеДепонентыПоУДП()
	МассивДепонентов = Новый Массив;
	Для Каждого Строка Из Депоненты Цикл
		Если НЕ Строка.ЦБНаНалоговомРазделе
			И НЕ Строка.ЕстьУсловноеДлящеесяПоручение
			И НЕ Строка.ОтправленоУведомлениеККОПеремещенииНаНалоговыйРаздел Тогда
			МассивДепонентов.Добавить(Строка.Депонент);
		Конецесли;
	КонецЦикла;
	Возврат МассивДепонентов;
КонецФункции

Функция ДепонентыСФормойW8_ЦБ_НЕ_НаНалоговомРазделеБезУДП(МассивДепонентов, ИмяТабЧастиИсточника)
	Условия =
	"Депоненты.РазделСчета.ТипРазделаСчетаДЕПО <> &Налоговый
	|И Депоненты.РазделСчетаПолучатель.ТипРазделаСчетаДЕПО = &Налоговый
	|И УДП.Депонент ЕСТЬ NULL";
	Возврат ДепонентыСФормойW8_ЦБСУсловием(МассивДепонентов, Условия, ИмяТабЧастиИсточника);
КонецФункции

Функция ДанныеРасшифровкиСубброкераДополненныеПоТекущимОстаткам(ДанныеСубброкера, Остатки) 
	
	Если ДанныеСубброкера.Количество() = 0 Тогда 
		
		Возврат ДанныеСубброкера;
		
	Иначе
		
		Для Каждого Элемент Из ДанныеСубброкера Цикл 
			
			СтрокаОстатков  = Остатки.Найти(Элемент.РазделСчетаДепо, "РазделСчета");
			Если СтрокаОстатков = Неопределено Тогда 
				Элемент.Количество = 0;	
			Иначе 
				Элемент.Количество = СтрокаОстатков.Количество;
			КонецЕсли;
			
		КонецЦикла;
		
		Возврат ДанныеСубброкера;
		
	КонецЕсли;
	
КонецФункции

Процедура УстановитьЗначениеВТабличнойЧастиДепонента(ТабличнаяЧасть, Депонент, ИмяКолонки, Значение)
	
	Строки = ТабличнаяЧасть.НайтиСтроки(Новый Структура("Депонент",Депонент));
	Для Каждого Строка Из Строки Цикл 
		Строка[ИмяКолонки] = Значение;	
	КонецЦикла;
	
КонецПроцедуры

Функция РезультатЗадачиФормированиеДокументаРаскрытиеСпискаВладельцев(АмериканскаяЦБ = Ложь)
	
	Если АмериканскаяЦБ И WTRCСообщенияQI.ИспользоватьСхемуУведомленийWTRC_QI(БизнесПроцесс.Дата) Тогда 
		 РезультатСозданияДокументаРаскрытиеСпискаВладельцев(АмериканскаяЦБ);
	Иначе 
		Если НачалоДня(ТекущаяДата()) > НачалоДня(БизнесПроцесс.ДатаОкончанияПриемаПоручений1_10)
			ИЛИ ПринялиУчастиеВсеДепоненты()
			ИЛИ ДополнительныеСвойства.Свойство("БезусловноСформироватьДокументРаскрытиеСпискаВладельцев") Тогда
			
			Успешно = РезультатСозданияДокументаРаскрытиеСпискаВладельцев();
			Если Успешно Тогда
				Задачи.ОбработкаWTRCСообщения.ОтправитьУведомлениеДепозитарию(БизнесПроцесс);
			КонецЕсли;
		Иначе
			Выполнена = Ложь;
		КонецЕсли;

	КонецЕсли;
	
	Возврат Истина;
	
КонецФункции

Функция РезультатОтправкиЗапросаПоЭлПочте(ДанныеПоСубброкеру, ФайлЗапроса, ФайлРасшифровки)
	// Подготовка данных письма
	ТемаТекстПисьма = "Запрос на раскрытие списка владельцев ценных бумаг.";		
	НастройкиОбмена = ВнешниеДанные.ПолучитьПараметрыВнешнегоИсточника(ДанныеПоСубброкеру.ВнешнийИсточник).Настройка;
	
	Если НастройкиОбмена = Неопределено Тогда
		ТекстОшибки = "Не заданы параметры внешнего источника контрагента/субброкера. Подробности см. в журнале регистрации.";
		#Если Клиент Тогда
		ОбщегоНазначения.СообщитьОбОшибке(ТекстОшибки);
		#КонецЕсли
		ИмяСобытия = "Отправка запроса на раскрытие по субклиентам по эл.почте";
		ЗаписьЖурналаРегистрации(ИмяСобытия, УровеньЖурналаРегистрации.Ошибка,, ДанныеПоСубброкеру.Субброкер, ТекстОшибки);
		Возврат Ложь;
	КонецЕсли;
	
	СписокВложений = Новый Соответствие;
	СписокВложений.Вставить("Раскрытие списка владельцев.xlsx", Новый ДвоичныеДанные(ФайлЗапроса));
	СписокВложений.Вставить("Приложение 02.5. Запрос на раскрытие списка владельцев ценных бумаг.pdf",Новый ДвоичныеДанные(ФайлРасшифровки));
	// Удалить файлы из временного хранилища
	УдалитьФайлы(ФайлЗапроса);
	
	// Сформируем уведомление
	ПараметрыУведомления = Новый Соответствие;
	ПараметрыУведомления.Вставить("Вложения",			СписокВложений);
	ПараметрыУведомления.Вставить("НастройкиОбмена",	НастройкиОбмена);
	ПараметрыУведомления.Вставить("Кодировка",			"UTF-8");
	ПараметрыУведомления.Вставить("ТемаПисьма",			ТемаТекстПисьма);
	ПараметрыУведомления.Вставить("ТекстПисьма",		ТемаТекстПисьма);
	ПараметрыУведомления.Вставить("ТипТекстаПисьма",	ТипТекстаПочтовогоСообщения.ПростойТекст);
	ПараметрыУведомления.Вставить("Важность",			ВажностьИнтернетПочтовогоСообщения.Обычная);
	
	РегистрыСведений.УведомленияКОтправке.ДобавитьУведомлениеКотправке(ПараметрыУведомления);				
	Возврат Истина;
КонецФункции

Процедура ОтправитьФайлЗапросаНаРаскрытие(БизнесПроцессОбъект, ДанныеПоСубброкеру, Уведомление, АмериканскаяЦБ = Истина, ИспользоватьРегистрациюЗапросовСубброкера = Ложь) 
	
	Если ИспользоватьРегистрациюЗапросовСубброкера Тогда 
		ДокументЗапрос = Документы.ЗапросСубброкеруНаРаскрытие.ЗапросСубброкеруНаРаскрытиеЗаполненныйWTRC(БизнесПроцесс.КД, Уведомление, ДанныеПоСубброкеру, АмериканскаяЦБ);
		
		СлужебноеУведомление = СообщенияQI.СлужебноеУведомлениеОФормированииЗапросаСубброкеру(ДокументЗапрос);
		СообщенияQI.ОтправитьСлужебноеУведомление(ПланыВидовХарактеристик.ВнешниеИсточники.РассылкаУведомленийОСозданииЗапросаНаРаскрытиеTrec
			,СлужебноеУведомление.Тема,СлужебноеУведомление.Тело);

		ДокументЗапросСтатус = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДокументЗапрос,"Статус");
		ЕСли ДокументЗапросСтатус = Перечисления.СтатусыДокументаЗапросСубброкеруНаРаскрытие.Отправлен
			ИЛИ ДокументЗапросСтатус = Перечисления.СтатусыДокументаЗапросСубброкеруНаРаскрытие.ОтправленПовторно Тогда
			СтатусОтправки = Перечисления.СтатусыЗавершенияБПОбработкаWTRCСообщения.Отправлено;
		Иначе 	
			СтатусОтправки =  Перечисления.СтатусыЗавершенияБПОбработкаWTRCСообщения.Сформировано;
		КонецЕсли;
		УстановитьЗначениеВТабличнойЧастиДепонента(БизнесПроцессОбъект.Депоненты, ДанныеПоСубброкеру[0].Субброкер, "ЗапросНаРаскрытие", СтатусОтправки);
	Иначе 
		Если АмериканскаяЦБ Тогда 
			ФайлЗапроса = WTRCСообщенияQI.ФайлРасшифровкиЗапросаНаРаскрытиеПоСубклиентамЦБСША(ДанныеПоСубброкеру);
		Иначе 
			ФайлЗапроса = WTRCСообщенияQI.ФайлРасшифровкиЗапросаНаРаскрытиеПоСубклиентамЦБНеСША(ДанныеПоСубброкеру);
		КонецЕсли;
		
		ФайлРасшифровки = WTRCСообщенияQI.ФайлЗапросаНаРаскрытиеПоСубклиентамПриложение2_5(ДанныеПоСубброкеру);
		
		Успешно = РезультатОтправкиЗапросаПоЭлПочте(ДанныеПоСубброкеру[0], ФайлЗапроса, ФайлРасшифровки);
		Если Успешно Тогда
			НачатьТранзакцию();
			
			Документы.РаскрытиеСпискаВладельцев.СоздатьДокументИсходящий(ДанныеПоСубброкеру[0]);
			
			ЗафиксироватьТранзакцию();
		Иначе 
			ВызватьИсключение "Не удалось сформировать и отправить файлы запроса на раскрытие"; 
		КонецЕсли;
	КонецЕсли;

КонецПроцедуры

Функция ДанныеКОбработке(АмериканскаяЦБ)
	
	Возврат БизнесПроцессы.ОбработкаWTRCСообщения.ДанныеКОбработке(АмериканскаяЦБ,БизнесПроцесс).Выбрать();
	
КонецФункции

Процедура ПроверитьОстаткиЦБ(ЭтоАмериканскаяЦБ, БизнесПроцессОбъект, УведомленияКОтправке)
		
	ТекущаяДата = НачалоДня(ТекущаяДатаСеанса());
	ДатаОкончанияПриемаНРД = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(БизнесПроцессОбъект.КД,"ДатаОкончанияПриемаИнструкцийНРД");
	ДатаПроверкиОстатков = ОбщегоНазначения.ДобавитьРабочийКалендарныйДень(ДатаОкончанияПриемаНРД,-3);
	Если БизнесПроцессОбъект.ВыполненаПроверкаОстатков ИЛИ ТекущаяДата <> ДатаПроверкиОстатков Тогда 
		Возврат;	
	КонецЕсли;
		
	БизнесПроцессОбъект.ВыполненаПроверкаОстатков = Истина;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Остатки.ЦБ КАК ЦеннаяБумага,
	|	Остатки.СчетДепо.Владелец КАК Депонент,
	|	Остатки.РазделСчетаДепо КАК РазделСчета,
	|	СУММА(Остатки.КоличествоОстаток) КАК Количество
	|ПОМЕСТИТЬ втОстатки
	|ИЗ
	|	РегистрНакопления.ОстаткиЦБМестоРасчетов.Остатки(
	|			&ДатаОстатков,
	|			ЦБ В (&МассивЦенныхБумаг)
	|				И СчетДепоМХ = &СчетДепоМХ
	|				И &ОстаткиТипСчетаНДИНД) КАК Остатки
	|
	|СГРУППИРОВАТЬ ПО
	|	Остатки.ЦБ,
	|	Остатки.СчетДепо.Владелец,
	|	Остатки.РазделСчетаДепо
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ОбработкаWTRCСообщенияДепоненты.ЦеннаяБумага КАК ЦеннаяБумага,
	|	ОбработкаWTRCСообщенияДепоненты.Депонент КАК Депонент,
	|	ОбработкаWTRCСообщенияДепоненты.РазделСчета КАК РазделСчета,
	|	ОбработкаWTRCСообщенияДепоненты.Количество КАК Количество
	|ПОМЕСТИТЬ втДепоненты
	|ИЗ
	|	БизнесПроцесс.ОбработкаWTRCСообщения.Депоненты КАК ОбработкаWTRCСообщенияДепоненты
	|ГДЕ
	|	ОбработкаWTRCСообщенияДепоненты.Ссылка = &БизнесПроцесс
	|	И &БПТипСчетаНДИНД
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	втДепоненты.ЦеннаяБумага КАК ЦеннаяБумага,
	|	втДепоненты.Депонент КАК Депонент,
	|	втДепоненты.Депонент.Код КАК ДепонентКод,
	|	втДепоненты.РазделСчета.Владелец КАК СчетДепо,
	|	СУММА(ЕСТЬNULL(втОстатки.Количество, 0)) КАК Количество,
	|	КодыЗагрузкиКлиента.Код КАК ClientId,
	|	втДепоненты.Депонент КАК Клиент,
	|	НЕ Поручение.Ссылка ЕСТЬ NULL КАК ВведеноПоручениеНаУчастие
	|ИЗ
	|	втДепоненты КАК втДепоненты
	|		ЛЕВОЕ СОЕДИНЕНИЕ втОстатки КАК втОстатки
	|		ПО втДепоненты.ЦеннаяБумага = втОстатки.ЦеннаяБумага
	|			И втДепоненты.Депонент = втОстатки.Депонент
	|			И втДепоненты.РазделСчета = втОстатки.РазделСчета
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.КодыЗагрузки КАК КодыЗагрузкиКлиента
	|		ПО втДепоненты.Депонент = КодыЗагрузкиКлиента.Владелец
	|			И (НЕ КодыЗагрузкиКлиента.ПометкаУдаления)
	|			И (КодыЗагрузкиКлиента.Биржа = &КлассификаторыЗагрузкиКлиенты)
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.Поручение КАК Поручение
	|		ПО (Поручение.ВидОперацииД = &ВидОперацииПоручениеНаУчастие)
	|			И (Поручение.КарточкаКД = &КорпоративноеДействие)
	|			И (Поручение.Депонент = втДепоненты.Депонент)
	|			И (НЕ Поручение.ПометкаУдаления)
	|ГДЕ
	|	втДепоненты.Количество <> втОстатки.Количество
	|
	|СГРУППИРОВАТЬ ПО
	|	втДепоненты.Депонент,
	|	втДепоненты.ЦеннаяБумага,
	|	КодыЗагрузкиКлиента.Код,
	|	втДепоненты.РазделСчета.Владелец,
	|	втДепоненты.Депонент.Код,
	|	НЕ Поручение.Ссылка ЕСТЬ NULL,
	|	втДепоненты.Депонент
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	втОстатки.ЦеннаяБумага КАК ЦеннаяБумага,
	|	втОстатки.Депонент КАК Депонент,
	|	втОстатки.РазделСчета КАК РазделСчета,
	|	втОстатки.Количество КАК Количество
	|ИЗ
	|	втОстатки КАК втОстатки";

	МассивЦенныхБумаг = Новый Массив;
	Если ЗначениеЗаполнено(БизнесПроцессОбъект.ЦеннаяБумага1) Тогда
		МассивЦенныхБумаг.Добавить(БизнесПроцессОбъект.ЦеннаяБумага1);
	КонецЕсли;
	Если ЗначениеЗаполнено(БизнесПроцессОбъект.ЦеннаяБумага2) Тогда
		МассивЦенныхБумаг.Добавить(БизнесПроцессОбъект.ЦеннаяБумага2);
	КонецЕсли;
	
	Запрос.УстановитьПараметр("ДатаОстатков",		ТекущаяДатаСеанса());
	Запрос.УстановитьПараметр("МассивЦенныхБумаг",	МассивЦенныхБумаг);
	Запрос.УстановитьПараметр("СчетДепоМХ",			БизнесПроцессОбъект.СчетДепоМХ);
	Запрос.УстановитьПараметр("БизнесПроцесс",		БизнесПроцесс);
	Запрос.УстановитьПараметр("КлассификаторыЗагрузкиКлиенты", Справочники.КлассификаторыЗагрузки.Клиенты);
	Запрос.УстановитьПараметр("КорпоративноеДействие", БизнесПроцессОбъект.КД);
	Запрос.УстановитьПараметр("ВидОперацииПоручениеНаУчастие", Справочники.ВидыОпераций.УчастиеВКД);

	Если ЭтоАмериканскаяЦБ Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст,"&ОстаткиТипСчетаНДИНД", "РазделСчетаДепо.Владелец.ТипСчетаДепо В (&ТипСчетаНДИНД)");
		Запрос.Текст = СтрЗаменить(Запрос.Текст,"&БПТипСчетаНДИНД", "ОбработкаWTRCСообщенияДепоненты.РазделСчета.Владелец.ТипСчетаДепо В (&ТипСчетаНДИНД)");
		Запрос.УстановитьПараметр("ТипСчетаНДИНД", БизнесПроцессы.ОбработкаWTRCСообщения.ТипыСчетовНДИНД());
	Иначе 
		Запрос.Текст = СтрЗаменить(Запрос.Текст,"&ОстаткиТипСчетаНДИНД", "ИСТИНА");
		Запрос.Текст = СтрЗаменить(Запрос.Текст,"&БПТипСчетаНДИНД", "ИСТИНА");
	КонецЕсли;
	
	Результаты = Запрос.ВыполнитьПакет();
	Если Результаты[2].Пустой() Тогда 
		Возврат;	
	КонецЕсли;
	
	ТаблицаОстатков = Результаты[3].Выгрузить();	
	Уведомление = WTRCСообщенияQI.УведомлениеОбИзмененииКоличестваЦБ(БизнесПроцесс);
	Уведомление.Вставить("Остатки", ТаблицаОстатков);
	
	Выборка = Результаты[2].Выбрать();
	Пока Выборка.Следующий() Цикл
		Если ЭтоАмериканскаяЦБ Или Выборка.ВведеноПоручениеНаУчастие 
			Или Не WTRCСообщенияQI.ИспользоватьСхемуУведомленийWTRC_QIДляДокумента(БизнесПроцессОбъект.КД) Тогда 
    		ДобавитьУведомлениеКОтправке(УведомленияКОтправке, Уведомление, Выборка);
		КонецЕсли;
	КонецЦикла;
		
КонецПроцедуры

Функция ВозможноЗавершениеЗадачиОбработкаСообщенийWTRCQI(КорпоративноеДействиеСсылка)
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	Поручение.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.Поручение КАК Поручение
	|ГДЕ
	|	Поручение.ВидОперацииД В(&ВыплатаДоходовВДенежнойФорме)
	|	И Поручение.КарточкаКД В
	|			(ВЫБРАТЬ
	|				КорпоративноеДействие_Новый.КДРеференсСвязанныйСсылка КАК КДРеференсСвязанныйСсылка
	|			ИЗ
	|				Документ.КорпоративноеДействие_Новый КАК КорпоративноеДействие_Новый
	|			ГДЕ
	|				КорпоративноеДействие_Новый.Ссылка = &КорпоративноеДействие
	|				И КорпоративноеДействие_Новый.КДРеференсСвязанныйСсылка <> &ПустойКД)");
	
	Запрос.Параметры.Вставить("ВыплатаДоходовВДенежнойФорме", Справочники.ВидыОпераций.ОперацииВыплатыДоходаВДенежнойФорме()); 
	Запрос.Параметры.Вставить("КорпоративноеДействие", КорпоративноеДействиеСсылка); 
	Запрос.Параметры.Вставить("ПустойКД", Документы.КорпоративноеДействие_Новый.ПустаяСсылка()); 
	Результат = Запрос.Выполнить();
	Возврат Не Результат.Пустой();
	
КонецФункции

Процедура СоздатьОбновитьДокументРСВ()
	
	ИмяСобытия = "Создание/обновление документа раскрытия владельцев";
	ДокументРСВ = БизнесПроцессы.ОбработкаWTRCСообщения.СвязанныйДокументРСВ(БизнесПроцесс.КД);
	Если Не ЗначениеЗаполнено(ДокументРСВ) Тогда 
		РезультатСозданияДокументаРаскрытиеСпискаВладельцев();
	Иначе
		ДокументРСВОбъект = ДокументРСВ.ПолучитьОбъект();
		ДокументРСВОбъект.ЗаполнитьСписокВладельцев();
		Попытка
			ДокументРСВОбъект.Записать(РежимЗаписиДокумента.Запись);
		Исключение
			ЗаписьЖурналаРегистрации(ИмяСобытия, УровеньЖурналаРегистрации.Ошибка,,,
			"Документ РСВ не создан: " + ОписаниеОшибки());
			Возврат;
		КонецПопытки;
		
		ДепонентыСПоручениями1_10 = Документы.РаскрытиеСпискаВладельцев.ДепонентыСПоручениями1_10(БизнесПроцесс.КД);
		Для Каждого Строка Из ДепонентыСПоручениями1_10.Поручения Цикл
			Запись = РегистрыСведений.Поручения1_10ПоРСВ.СоздатьМенеджерЗаписи();
			Запись.РаскрытиеСпискаВладельцев	= ДокументРСВ;
			Запись.Поручение1_10				= Строка.Поручение;
			Запись.Записать(Истина);
		КонецЦикла;
		
	КонецЕсли;

	
КонецПроцедуры

Процедура ДобавитьУведомлениеКОтправке(УведомленияКОтправке, Уведомление, ДанныеКОбработке, СтрокаТабличнойЧасти = Неопределено)
	
	WTRCСообщенияQI.ДобавитьУведомлениеКОтправке(УведомленияКОтправке, Уведомление, ДанныеКОбработке, СтрокаТабличнойЧасти);
	
КонецПроцедуры

Функция РезультатСозданияИОтправкиУведомленияКлиентам(БизнесПроцессСсылка, ПараметрыУведомления, ДанныеКОбработке, ОбработкаВебСервисы = Неопределено)
	
	Возврат WTRCСообщенияQI.РезультатСозданияИОтправкиУведомленияКлиентам(БизнесПроцессСсылка, ПараметрыУведомления, ДанныеКОбработке, ОбработкаВебСервисы);
	
КонецФункции

Функция РазрешенаОбработкаСтрокиСОшибкойОтправки(СтрокаТабличнойЧасти)
	ИнтерективныйРежим = ДополнительныеСвойства.Свойство("ИнтерективныйРежим");
	Если ИнтерективныйРежим Тогда 
		Возврат Истина;
	ИначеЕсли СтрокаТабличнойЧасти.УведомлениеW8 = Перечисления.СтатусыЗавершенияБПОбработкаWTRCСообщения.ОшибкаОтправки Тогда 
		Возврат Ложь;
	ИначеЕсли СтрокаТабличнойЧасти.Уведомление1_10 = Перечисления.СтатусыЗавершенияБПОбработкаWTRCСообщения.ОшибкаОтправки Тогда
		Возврат Ложь;
	ИначеЕсли СтрокаТабличнойЧасти.ЗапросНаРаскрытие = Перечисления.СтатусыЗавершенияБПОбработкаWTRCСообщения.ОшибкаОтправки Тогда
		Возврат Ложь;
	КонецЕсли; 
	Возврат Истина;
КонецФункции

Функция РезультатЗадачиОбработкаСообщенийWTRCQI()
	
	Выполнена = Ложь;
	БизнесПроцессОбъект = БизнесПроцесс.ПолучитьОбъект();
	
	ОбработкаВебСервисы = Неопределено;
	Если ДополнительныеСвойства.Свойство("Тестирование") Тогда 
		ОбработкаВебСервисы = Обработки.TEST_ВебСервисы.Создать();
	КонецЕсли;	
	АмериканскаяЦБ = Ложь;
	ДанныеКОбработке = ДанныеКОбработке(АмериканскаяЦБ);
	КорпоративноеДействиеСсылка = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(БизнесПроцесс,"КД");
	ИспользоватьРегистрациюЗапросовСубброкера = WTRCСообщенияQI.ИспользоватьРегистрациюЗапросовСубброкераДляДокумента(КорпоративноеДействиеСсылка);
	ПолучателиСообщений = Новый Массив();
    УведомленияКОтправке = Новый Соответствие();
	ТекущаяДата = НачалоДня(ТекущаяДатаСеанса());
	ДатаСообщенияWTRC = НачалоДня(БизнесПроцессы.ОбработкаWTRCСообщения.ДатаСообщенияWTRC(БизнесПроцессОбъект.КД));
    ДатаФиксации = БизнесПроцессОбъект.ДатаФиксации;
	ДатаФиксации1РабочийДень = ОбщегоНазначения.ДобавитьРабочийКалендарныйДень(ДатаФиксации,1);
	ДатаФиксации5РабочихДней = ОбщегоНазначения.ДобавитьРабочийКалендарныйДень(ДатаФиксации,5);
	ДатаОкончанияПриемаНРД = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(БизнесПроцессОбъект.КД,"ДатаОкончанияПриемаИнструкцийНРД");
	Если ЗначениеЗаполнено(ДатаОкончанияПриемаНРД) Тогда 
		ДатаОкончанияПриемаНРД = НачалоДня(ДатаОкончанияПриемаНРД);
	Иначе
		СообщениеОбОшибке = "Не указана  ДатаОкончанияПриемаИнструкцийНРД";
		ЗаписьЖурналаРегистрации("Обработка WTRC соббщения",УровеньЖурналаРегистрации.Ошибка,СообщениеОбОшибке,БизнесПроцесс);
		ВызватьИсключение СообщениеОбОшибке;
	КонецЕсли;

	ДатаОкончанияПриемаИнструкцийВТБКБ = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(БизнесПроцессОбъект.КД,"ДатаОкончанияПриемаИнструкцийВТБКБ");
	
	Если ДатаСообщенияWTRC <= ДатаФиксации Тогда 
		ПроверитьОстаткиЦБ(АмериканскаяЦБ, БизнесПроцессОбъект, УведомленияКОтправке);
	КонецЕсли;
		
	МВТ = Новый МенеджерВременныхТаблиц;
	WTRCСообщенияQI.ДобавитьИсточникДляРаскрытияИзБизнесПроцесса(МВТ, БизнесПроцесс);
	Если ИспользоватьРегистрациюЗапросовСубброкера Тогда 
		ДанныеСубброкеровДляОтправкиЗапроса = WTRCСообщенияQI.ДанныеДляЗаполненияЗапросовНаРаскрытиеПоСубклиентам(МВТ, ДатаФиксации);
	Иначе 
		ДанныеСубброкеровДляОтправкиЗапроса = WTRCСообщенияQI.ДанныеДляЗаполненияЗапросовНаРаскрытиеПоСубклиентам_БезДокументовЗапросов(МВТ, ДатаФиксации);	
	КонецЕсли;

	
	Пока ДанныеКОбработке.Следующий() Цикл
		
		СтрокаТабличнойЧасти = БизнесПроцессОбъект.Депоненты.Найти(ДанныеКОбработке.НомерСтроки,"НомерСтроки");
		Если Не РазрешенаОбработкаСтрокиСОшибкойОтправки(СтрокаТабличнойЧасти) Тогда 
			Продолжить;
		КонецЕсли;
		СтрокаТабличнойЧасти.УведомлениеW8 = Перечисления.СтатусыЗавершенияБПОбработкаWTRCСообщения.НеТребуется;
		
		Уведомление 					= Неопределено;
		
		Если НЕ (ДанныеКОбработке.НД ИЛИ ДанныеКОбработке.ИНД) Тогда 
			СтрокаТабличнойЧасти.ЗапросНаРаскрытие = Перечисления.СтатусыЗавершенияБПОбработкаWTRCСообщения.НеТребуется;	
		КонецЕсли;
		
		Если ПолучателиСообщений.Найти(ДанныеКОбработке.Клиент) <> Неопределено Тогда 
			Продолжить;	
		Иначе
			ПолучателиСообщений.Добавить(ДанныеКОбработке.Клиент);
		КонецЕсли;
		
		Если ДанныеКОбработке.Поручение_1_10 И СтрокаТабличнойЧасти.Уведомление1_10 <> Перечисления.СтатусыЗавершенияБПОбработкаWTRCСообщения.Успешно Тогда 
			
			СоздатьОбновитьДокументРСВ();
			СтрокаТабличнойЧасти.Уведомление1_10 = Перечисления.СтатусыЗавершенияБПОбработкаWTRCСообщения.Успешно;
			УстановитьЗначениеВТабличнойЧастиДепонента(БизнесПроцессОбъект.Депоненты, СтрокаТабличнойЧасти.Депонент, "Уведомление1_10", СтрокаТабличнойЧасти.Уведомление1_10);
			
		ИначеЕсли ЗначениеЗаполнено(СтрокаТабличнойЧасти.Уведомление1_10) = Ложь 
			ИЛИ ЗначениеЗаполнено(СтрокаТабличнойЧасти.ЗапросНаРаскрытие) = Ложь
			ИЛИ СтрокаТабличнойЧасти.ЗапросНаРаскрытие = Перечисления.СтатусыЗавершенияБПОбработкаWTRCСообщения.ОшибкаОтправки 
			ИЛИ СтрокаТабличнойЧасти.Уведомление1_10 = Перечисления.СтатусыЗавершенияБПОбработкаWTRCСообщения.ОшибкаОтправки Тогда 
														
			Если ДатаСообщенияWTRC > ДатаФиксации Тогда 
				
				Если ДанныеКОбработке.НД ИЛИ ДанныеКОбработке.ИНД Тогда 
					
					//Уведомление = WTRCСообщенияQI.УведомлениеОКД_УчастиеРаскрытие_ЦБНеСШААктивнаяСсылка(БизнесПроцесс);
					Уведомление = WTRCСообщенияQI.УведомлениеОКД_Участие_ЦБНеСШААктивнаяСсылка(БизнесПроцесс);
					
				Иначе
					
					Уведомление = WTRCСообщенияQI.УведомлениеОКД_Участие_ЦБНеСШААктивнаяСсылка(БизнесПроцесс);
					
				КонецЕсли;
				
			Иначе
				
				Если ДатаФиксации5РабочихДней <= ДатаОкончанияПриемаНРД Тогда
					
					Если ДанныеКОбработке.НД ИЛИ ДанныеКОбработке.ИНД Тогда 
						
