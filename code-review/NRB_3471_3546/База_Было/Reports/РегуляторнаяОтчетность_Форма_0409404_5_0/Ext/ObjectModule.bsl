#Область ПрограммныйИнтерфейс

// Процедура заполняет данными ТЧ ДанныеРаздела_2.
//
// BSLLS:MethodSize-off
Процедура ПолучитьДанные() Экспорт
	МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	
	// Получим промежуточные данные кроме рыночной цены
	Запрос.Текст = ТекстПакетаДляПодготовкиПромежуточныхДанных();
	Запрос.УстановитьПараметр("ПолучатьЦеныИзBQ", ПолучатьЦеныИзBQ);
	Запрос.УстановитьПараметр("ОтчетныйПериод", ОтчетныйПериод);
	Запрос.УстановитьПараметр("ГраницаОтчетногоПериода", Новый Граница(КонецДня(ОтчетныйПериод), ВидГраницы.Включая) );
	ТипыДепозитарныхРасписок = Новый Массив;
	Запрос.УстановитьПараметр("ТипыДепозитарныхРасписок", Перечисления.ТипыЦБ.ВсеТипыДепозитарныхРасписок());
	КодыВидовИностранныхЦБСтрокой = "BON6,BON5,BON7,DS2,SS2,SHS5,SHS6,SHS7,SHS9,SHS10,SN3,SN4,BIL6,BIL5,BIL7,DR2,DOL2,OTHER";
	КодыВидовИностранныхЦБ = СтрРазделить(КодыВидовИностранныхЦБСтрокой, ",");
	Запрос.УстановитьПараметр("КодыВидовИностранныхЦБ", КодыВидовИностранныхЦБ);
	КодыВидовДолговыхЦБСтрокой = "BON6,BON5,BON7,SN3,SN4";
	КодыВидовДолговыхЦБ = СтрРазделить(КодыВидовДолговыхЦБСтрокой, ",");
	Запрос.УстановитьПараметр("КодыВидовДолговыхЦБ", КодыВидовДолговыхЦБ);
	КодыВидовЦБСНулевымНоминаломСтрокой = "SHS7,DR2,DOL2,OTHER";
	КодыВидовЦБСНулевымНоминалом = СтрРазделить(КодыВидовЦБСНулевымНоминаломСтрокой, ",");
	Запрос.УстановитьПараметр("КодыВидовЦБСНулевымНоминалом", КодыВидовЦБСНулевымНоминалом);
	Запрос.УстановитьПараметр("КодРегионаОрганизации", Лев(Организация.КодПоОКАТО, 2));
	
	ИспользуемыеЦБ = Запрос.Выполнить().Выгрузить();
	
	// Получим рыночные цены ЦБ из backQORT
	РыночныеЦеныЦБ = РыночныеЦеныЦБ(ИспользуемыеЦБ);
	
	// Получим итогововые данные
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.Текст = ТекстПакетаДляПолученияИтоговыхДанных();
	Запрос.УстановитьПараметр("ТЗРыночныеЦеныЦБ", РыночныеЦеныЦБ);
	Запрос.УстановитьПараметр("ОтчетныйПериод", ОтчетныйПериод);
	
	РезультатПакета = Запрос.ВыполнитьПакет();
	
	ИндексПоследнегоЗапроса = РезультатПакета.Количество() - 1;
	ИндексВторогоЗапросаСКонца = ИндексПоследнегоЗапроса - 1;
	ИндексТретьегоЗапросаСКонца = ИндексВторогоЗапросаСКонца - 1;
		
	ДанныеМестХранения = РезультатПакета[ИндексВторогоЗапросаСКонца].Выгрузить();
	ПроверитьДанныеМестХранения(ДанныеМестХранения);
		
	ДанныеЦБ = РезультатПакета[ИндексТретьегоЗапросаСКонца].Выгрузить();
	ПроверитьДанныеЦБ(ДанныеЦБ, КодыВидовИностранныхЦБ, КодыВидовИностранныхЦБСтрокой);
		
	ДанныеРаздела_2.Загрузить(РезультатПакета[ИндексПоследнегоЗапроса].Выгрузить());
	ПронумероватьСтроки(ДанныеРаздела_2);
	
	МенеджерВременныхТаблиц = Неопределено;
КонецПроцедуры

// Процедура выгружает сформированный отчет (данные в табличных частях отчета) в XML-файл
// Параметры:
//	ОписаниеОшибок - Строка
//	ПроверкиУспешны - Булево
Процедура ВыгрузитьВXML(ОписаниеОшибок, ПроверкиУспешны) Экспорт
	// BSLLS:Typo-off
	СписокОбязательныхКолонок = "Разд2НомСтр, ISIN, КодТипЦБум, КодСрокаПог, НаимЭмит, КодСтраны, КодСектЭк, ПризКлиента"
								+ ", КодКлиента, КодВалюты, КодМестХранЦБум";
	// BSLLS:Typo-on
	МетаданныеТЧ = Метаданные().ТабличныеЧасти.ДанныеРаздела_2;
	ПроверкиУспешны = РегуляторнаяОтчетность.ЗаполненыОбязательныеКолонкиДляВыгрузкиВXML(ДанныеРаздела_2, МетаданныеТЧ,
													СписокОбязательныхКолонок, "Разд2НомСтр", ОписаниеОшибок);
	Если Не ПроверкиУспешны Тогда
		Возврат;
	КонецЕсли;
	
	ИмяФормы = "0409404";
	ПространствоИмен = "urn:cbr-ru:rep0409404:v5.0.4.5";
	
	// Осторожно! Схема хранимая в конфигурации модифицирована по сравнению с оригинальной:
	//	- добавлены типы: Строка21, Строка29
	//	- в разделе "Ф0409404Данные404Раздел2Раздел2Данные" типы атрибутов Строка29Число15_6Неотр-лок и Число15_6Полож-лок
	//		заменены на Строка21, а Число23_6Неотр-лок на Строка29.
	// Это потребовалось, чтобы все числа можно было выгрузить в файл дополненными до 6 нулей после запятой (см. NRB-321)
	СхемаXSD = ПолучитьМакет("Ф404_Schema_XSD");
	
	Фабрика = РегуляторнаяОтчетность.ФабрикаИзСхемыXSD(СхемаXSD);
	Отчетность = Фабрика.Создать(Фабрика.Тип(ПространствоИмен, "Ф0409404"));
	
	УникИдОЭС = Новый УникальныйИдентификатор;
	Отчетность.УникИдОЭС = Строка(УникИдОЭС);	// Пример: "8b91f09d-da8b-11ed-811d-00155d1a3509";
	Отчетность.ВидОтчета = ИмяФормы;
	Отчетность.КодФормы = ИмяФормы;
	Отчетность.ОКУД = "0409404";
	Отчетность.ВидОЭС = "Отчетность КО";
	Отчетность.ВидОтчета = "основной";
	Отчетность.Периодичность = "месячная";
	Отчетность.ДатаВремяФормирования = ТекущаяДатаСеанса();
	
	ОтчетнаяДатаДляXML = КонецДня(ОтчетныйПериод) + 1;	// Следующий день после конца отчетного периода
	// BSLLS:Typo-off
	Отчетность.ОтчДата = ОтчетнаяДатаДляXML;
	// BSLLS:Typo-on
	
	Отчетность.Составитель = СоставительОтчета(Фабрика, ПространствоИмен, ОтчетнаяДатаДляXML);
	Отчетность.Данные404 = Данные404(Фабрика, ПространствоИмен);
	
	РегуляторнаяОтчетность.ЗаписатьОтчетностьДляДельтыВXML(Фабрика, Отчетность, ИмяФормы, Неопределено, ОтчетныйПериод);
КонецПроцедуры

#КонецОбласти


#Область СлужебныеПроцедурыИФункции

Функция ТекстПакетаДляПодготовкиПромежуточныхДанных()
	Текст =
	// Ищем иностранные ЦБ принадлежащие резидентам, не являющимися кредитными оранизациями
	// Важно что реквизит Резидент в справочнике контрагентов, как это ни парадоксально, означает "Нерезидент по документам"
	// - живите теперь с этим, если не знали раньше
	"ВЫБРАТЬ
	|	ЮридическиеЛицаМеждународныеКомпанииСрезПоследних.МеждународнаяКомпания КАК МеждународнаяКомпания,
	|	ЮридическиеЛицаМеждународныеКомпанииСрезПоследних.ЮридическоеЛицо КАК ЮридическоеЛицо
	|ПОМЕСТИТЬ ВТ_МеждународныеКомпании
	|ИЗ
	|	РегистрСведений.ЮридическиеЛицаМеждународныеКомпании.СрезПоследних(&ОтчетныйПериод, 1 = 1) КАК ЮридическиеЛицаМеждународныеКомпанииСрезПоследних
	|ГДЕ
	|	ЮридическиеЛицаМеждународныеКомпанииСрезПоследних.МеждународнаяКомпания
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ОстаткиЦБОстатки.ЦБ КАК ЦБ,
	|	ОстаткиЦБОстатки.СчетДепо КАК СчетДепо,
	|	ОстаткиЦБОстатки.СчетДепоМХ КАК СчетДепоМХ,
	|	ОстаткиЦБОстатки.КоличествоОстаток КАК Количество
	|ПОМЕСТИТЬ ВТ_ОстаткиВсехЦБУРезидентов
	|ИЗ
	|	РегистрНакопления.ОстаткиЦБ.Остатки(
	|			&ГраницаОтчетногоПериода,
	|			НЕ СчетДепо.Владелец.Резидент
	|					И НЕ ЕСТЬNULL(ВЫРАЗИТЬ(СчетДепо.Владелец.ЮридическиеФизическиеЛица КАК Справочник.ЮридическиеЛица).КредитнаяОрганизация, ЛОЖЬ)
	|				ИЛИ СчетДепо.Владелец.ЮридическиеФизическиеЛица В
	|					(ВЫБРАТЬ
	|						ВТ_МеждународныеКомпании.ЮридическоеЛицо КАК ЮридическоеЛицо
	|					ИЗ
	|						ВТ_МеждународныеКомпании КАК ВТ_МеждународныеКомпании)) КАК ОстаткиЦБОстатки
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_ОстаткиВсехЦБУРезидентов.ЦБ КАК ЦБ
	|ПОМЕСТИТЬ ВТ_ВсеЦБРезидентов
	|ИЗ
	|	ВТ_ОстаткиВсехЦБУРезидентов КАК ВТ_ОстаткиВсехЦБУРезидентов
	|
	|СГРУППИРОВАТЬ ПО
	|	ВТ_ОстаткиВсехЦБУРезидентов.ЦБ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_ВсеЦБРезидентов.ЦБ КАК ЦБ,
	|	ЕСТЬNULL(БазовыеАктивыДепозитарныхРасписок.Эмитент, ЦенныеБумаги.Эмитент) КАК Эмитент,
	|	ЦенныеБумаги.ВидЦББанкаРоссии КАК ВидЦББанкаРоссии,
	|	ЕСТЬNULL(БазовыеАктивыДепозитарныхРасписок.ВалютаНоминала, ЦенныеБумаги.ВалютаНоминала) КАК ВалютаНоминала,
	|	ВЫБОР
	|		КОГДА ЦенныеБумаги.ТипЦБ В (&ТипыДепозитарныхРасписок)
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК ЭтоДепозитарнаяРасписка,
	|	ЦенныеБумаги.ДатаРазмещения КАК ДатаРазмещения,
	|	ЦенныеБумаги.ДатаПогашения КАК ДатаПогашения,
	|	ЦенныеБумаги.ISIN КАК ISIN
	|ПОМЕСТИТЬ ВТ_ВсеЦБРезидентовСРеквизитами
	|ИЗ
	|	ВТ_ВсеЦБРезидентов КАК ВТ_ВсеЦБРезидентов
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ЦенныеБумаги КАК ЦенныеБумаги
	|		ПО ВТ_ВсеЦБРезидентов.ЦБ = ЦенныеБумаги.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ЦенныеБумаги КАК БазовыеАктивыДепозитарныхРасписок
	|		ПО (ЦенныеБумаги.БазовыйАктив = БазовыеАктивыДепозитарныхРасписок.Ссылка)
	|			И (ЦенныеБумаги.ТипЦБ В (&ТипыДепозитарныхРасписок))
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_ВсеЦБРезидентовСРеквизитами.ЦБ КАК ЦБ,
	|	ВТ_ВсеЦБРезидентовСРеквизитами.Эмитент КАК Эмитент,
	|	ВТ_ВсеЦБРезидентовСРеквизитами.ВалютаНоминала КАК ВалютаНоминала,
	|	ВТ_ВсеЦБРезидентовСРеквизитами.ЭтоДепозитарнаяРасписка КАК ЭтоДепозитарнаяРасписка,
	|	ВидыЦББанкаРоссии.Код КАК КодВидаЦББанкаРоссии
	|ПОМЕСТИТЬ ВТ_ИностранныеЦБ
	|ИЗ
	|	ВТ_ВсеЦБРезидентовСРеквизитами КАК ВТ_ВсеЦБРезидентовСРеквизитами
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Контрагенты КАК Эмитенты
	|		ПО ВТ_ВсеЦБРезидентовСРеквизитами.Эмитент = Эмитенты.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ВидыЦББанкаРоссии КАК ВидыЦББанкаРоссии
	|		ПО ВТ_ВсеЦБРезидентовСРеквизитами.ВидЦББанкаРоссии = ВидыЦББанкаРоссии.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ЮридическиеЛица КАК ЮридическиеЛица
	|		ПО (Эмитенты.ЮридическиеФизическиеЛица = ЮридическиеЛица.Ссылка)
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_МеждународныеКомпании КАК ВТ_МеждународныеКомпании
	|		ПО ЮридическиеЛица.Ссылка = ВТ_МеждународныеКомпании.ЮридическоеЛицо
	|ГДЕ
	|	ВЫБОР
	|			КОГДА Эмитенты.РегионДляОтчетов ССЫЛКА Справочник.КлассификаторРегионов
	|					И Эмитенты.РегионДляОтчетов <> ЗНАЧЕНИЕ(Справочник.КлассификаторРегионов.ПустаяСсылка)
	|				ТОГДА ЛОЖЬ
	|			КОГДА Эмитенты.РегионДляОтчетов = ЗНАЧЕНИЕ(Справочник.КлассификаторСтранМира.РОССИЯ)
	|				ТОГДА ЛОЖЬ
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ
	|	И ВидыЦББанкаРоссии.Код В(&КодыВидовИностранныхЦБ)
	|	И ВТ_МеждународныеКомпании.ЮридическоеЛицо ЕСТЬ NULL
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	НоминалЦБСрезПоследних.ЦеннаяБумага КАК ЦБ,
	|	НоминалЦБСрезПоследних.Сумма КАК Сумма
	|ПОМЕСТИТЬ ВТ_НоминалЦБ
	|ИЗ
	|	РегистрСведений.НоминалЦБ.СрезПоследних(
	|			&ОтчетныйПериод,
	|			ЦеннаяБумага В
	|				(ВЫБРАТЬ
	|					ВТ_ИностранныеЦБ.ЦБ КАК ЦБ
	|				ИЗ
	|					ВТ_ИностранныеЦБ КАК ВТ_ИностранныеЦБ)) КАК НоминалЦБСрезПоследних
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_ИностранныеЦБ.ЦБ КАК ЦБ,
	|	ВТ_ИностранныеЦБ.Эмитент КАК Эмитент,
	|	ВТ_ИностранныеЦБ.ЭтоДепозитарнаяРасписка КАК ЭтоДепозитарнаяРасписка,
	|	ВТ_ИностранныеЦБ.КодВидаЦББанкаРоссии КАК КодВидаЦББанкаРоссии,
	|	ВТ_ИностранныеЦБ.ВалютаНоминала КАК ВалютаНоминала,
	|	Валюты.Код КАК КодВалютыНоминала,
	|	ВЫБОР
	|		КОГДА ЕСТЬNULL(ВЫРАЗИТЬ(Эмитенты.НаименованиеПолное КАК СТРОКА(500)), """") <> """"
	|			ТОГДА ВЫРАЗИТЬ(Эмитенты.НаименованиеПолное КАК СТРОКА(500))
	|		КОГДА ЕСТЬNULL(ВЫРАЗИТЬ(ЮридическиеЛица.ПолноеНаименованиеНаАнглийскомЯзыке КАК СТРОКА(500)), """") <> """"
	|			ТОГДА ВЫРАЗИТЬ(ЮридическиеЛица.ПолноеНаименованиеНаАнглийскомЯзыке КАК СТРОКА(500))
	|		ИНАЧЕ Эмитенты.Наименование
	|	КОНЕЦ КАК НаименованиеЭмитента,
	|	КлассификаторСекторовЭкономики.Код КАК КодСектораЭкономики,
	|	ВЫБОР
	|		КОГДА ЮридическиеЛица.МеждународнаяОрганизация = ИСТИНА
	|			ТОГДА ""998""
	|		КОГДА НЕ КлассификаторСтранМира.Код ЕСТЬ NULL
	|			ТОГДА КлассификаторСтранМира.Код
	|		ИНАЧЕ ""999""
	|	КОНЕЦ КАК КодСтраныЭмитента,
	|	ЦенныеБумаги.ТипЦБ КАК ТипЦБ,
	|	ЦенныеБумаги.ISIN КАК ISIN,
	|	ЦенныеБумаги.НомерРегистрации КАК НомерРегистрации,
	|	ВЫБОР
	|		КОГДА ЦенныеБумаги.ТипЦБ = ЗНАЧЕНИЕ(Перечисление.ТипыЦБ.Облигация)
	|				И ЦенныеБумаги.ДатаПогашения <> ДАТАВРЕМЯ(1, 1, 1)
	|				И ДОБАВИТЬКДАТЕ(ЦенныеБумаги.ДатаРазмещения, ГОД, 1) > ЦенныеБумаги.ДатаПогашения
	|			ТОГДА ""SHT""
	|		КОГДА ЦенныеБумаги.ТипЦБ = ЗНАЧЕНИЕ(Перечисление.ТипыЦБ.Облигация)
	|			ТОГДА ""LNT""
	|		ИНАЧЕ ""-""
	|	КОНЕЦ КАК КодСрокаПогашения,
	|	ВЫБОР
	|		КОГДА ВТ_ИностранныеЦБ.КодВидаЦББанкаРоссии В (&КодыВидовДолговыхЦБ)
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК ЭтоДолговаяЦБ,
	|	ЦенныеБумаги.Дефолтная КАК Дефолтная,
	|	ВЫБОР
	|		КОГДА ЦенныеБумаги.ДатаПогашения = ДАТАВРЕМЯ(1, 1, 1)
	|			ТОГДА ЛОЖЬ
	|		КОГДА ЦенныеБумаги.ДатаПогашения <= &ОтчетныйПериод
	|			ТОГДА ИСТИНА
