Функция РыночныеЦеныЦБ(ИспользуемыеЦБ)
	Перем АДО;
	
	ДатаКотировокСтрокой = Формат(ОтчетныйПериод, "ДФ='yyyyMMdd'");
	
	СписокЦБВФорматеJSON = СписокЦБВФорматеJSON(ИспользуемыеЦБ);
	
	РыночныеЦеныЦБ = Новый ТаблицаЗначений;
	ЛитералСтрока = "Строка";
	ОписаниеТипаДляКотировок = Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(15, 6));
	РыночныеЦеныЦБ.Колонки.Добавить("ЦБ", Новый ОписаниеТипов("СправочникСсылка.ЦенныеБумаги"));
	РыночныеЦеныЦБ.Колонки.Добавить("RegNum", Новый ОписаниеТипов(ЛитералСтрока, , Новый КвалификаторыСтроки(50)));
	РыночныеЦеныЦБ.Колонки.Добавить("ISIN", Новый ОписаниеТипов(ЛитералСтрока, , Новый КвалификаторыСтроки(30)));
	РыночныеЦеныЦБ.Колонки.Добавить("Rate", ОписаниеТипаДляКотировок);
	РыночныеЦеныЦБ.Колонки.Добавить("RateNominal", ОписаниеТипаДляКотировок);
	РыночныеЦеныЦБ.Колонки.Добавить("RateWithAccru", ОписаниеТипаДляКотировок);
	РыночныеЦеныЦБ.Колонки.Добавить("RateNominalWithAccru", ОписаниеТипаДляКотировок);
	РыночныеЦеныЦБ.Колонки.Добавить("NominalCurrency", Новый ОписаниеТипов(ЛитералСтрока, , Новый КвалификаторыСтроки(3)));
	РыночныеЦеныЦБ.Колонки.Добавить("Level", Новый ОписаниеТипов(ЛитералСтрока, , Новый КвалификаторыСтроки(1)));
	РыночныеЦеныЦБ.Колонки.Добавить("Metod", Новый ОписаниеТипов(ЛитералСтрока, , Новый КвалификаторыСтроки(2)));
	
	Если ПолучатьЦеныИзBQ И Не ПустаяСтрока(СписокЦБВФорматеJSON) Тогда
		ВнешнийИсточник = ПланыВидовХарактеристик.ВнешниеИсточники.НРБСервисStoredProcSQL;
		ВходныеПараметры = Новый Структура;
		ВходныеПараметры.Вставить("Date", ДатаКотировокСтрокой);
		ВходныеПараметры.Вставить("JsonParams", СписокЦБВФорматеJSON);
		
		Попытка
			Параметры = Неопределено;
			ВнешниеДанные.ДобавитьПараметрСоединения(Параметры, "ВнешнийИсточник", ВнешнийИсточник);
			ВнешниеДанные.ИнициироватьСоединение(АДО, "АДО", Параметры);
			// Получаем рыночные котировки ЦБ с помощью вызова хранимки из базы backQORT
			// Возвращается таблица с колонками RateDate, RegNum, ISIN, Rate, RateCurrency, Level, NominalCurrency, CrossRate, RateNominal
			ДанныеBQ = АДО.ВыполнитьХранимуюПроцедуру("[GATE].[GetMarketData]", ВходныеПараметры);
		Исключение
			ТекстОшибки = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
			ШаблонСообщенияОбОшибке = "BQ: при попытке получить рыночные котировки на дату: %1 произошла ошибка: " + ТекстОшибки;
			ТекстСообщенияОбОшибке = СтрШаблон(ШаблонСообщенияОбОшибке, ДатаКотировокСтрокой);
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщенияОбОшибке);
			ДанныеBQ = Неопределено;
		КонецПопытки;
		
		Если ДанныеBQ <> Неопределено 	Тогда
			ПереместитьДанныеОКотировкахВТаблицуСТипизированнымиКолонками(РыночныеЦеныЦБ, ДанныеBQ);
		КонецЕсли;
	КонецЕсли;
	
	Если Не ПолучатьЦеныИзBQ И Не ПустаяСтрока(СписокЦБВФорматеJSON) Тогда
		
		Если ОбщегоНазначения.РабочийДень(ОтчетныйПериод) Тогда
			ОтчетныйРабочийПериод = ОтчетныйПериод;
		Иначе
			ОтчетныйРабочийПериод = ОбщегоНазначения.ПредыдущийРабочийДень(ОтчетныйПериод);
		КонецЕсли;
		
		СрезНаДату = Ложь;
		РасчетРыночныхЦенДля0409404.ЗаполнитьТаблицуДляОтчета0409404(ОтчетныйРабочийПериод, ИспользуемыеЦБ, РыночныеЦеныЦБ, СрезНаДату);
		
		Методика = Перечисления.МетодикиРасчетаРыночныхЦен.Для0409404;
		ОписаниеОшибки =
			РегистрыСведений.СостоянияРасчетаРыночныхЦенЦенныхБумаг.ОписаниеНезавершенногоСостоянияОсновногоРасчета(ОтчетныйРабочийПериод, Методика);
		Если ЗначениеЗаполнено(ОписаниеОшибки) Тогда
			РегуляторнаяОтчетность.ДобавитьОписаниеОшибки(ОписаниеОшибок, ОписаниеОшибки);
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат РыночныеЦеныЦБ;
КонецФункции

Процедура ПереместитьДанныеОКотировкахВТаблицуСТипизированнымиКолонками(РыночныеЦеныЦБ, ДанныеBQ)
	Для Каждого ДанныеОБумагеИзBQ Из ДанныеBQ Цикл
		НовСтрокаТЗ = РыночныеЦеныЦБ.Добавить();
		ЗаполнитьЗначенияСвойств(НовСтрокаТЗ, ДанныеОБумагеИзBQ, , "Rate,RateNominal,RateWithAccru,RateNominalWithAccru");
		НовСтрокаТЗ.Rate = ПреобразоватьСтрокуВЧисло(ДанныеОБумагеИзBQ.Rate);
		НовСтрокаТЗ.RateNominal = ПреобразоватьСтрокуВЧисло(ДанныеОБумагеИзBQ.RateNominal);
		НовСтрокаТЗ.RateWithAccru = ПреобразоватьСтрокуВЧисло(ДанныеОБумагеИзBQ.RateWithAccru);
		НовСтрокаТЗ.RateNominalWithAccru = ПреобразоватьСтрокуВЧисло(ДанныеОБумагеИзBQ.RateNominalWithAccru);
	КонецЦикла;
КонецПроцедуры

Функция ПреобразоватьСтрокуВЧисло(ЧислоСтрокой)
	ЧислоСтрокойБезПробелов = СтрЗаменить(СтрЗаменить(ЧислоСтрокой, " ", ""), Символы.НПП, "");
	ОписаниеТипа = Новый ОписаниеТипов("Число");
	Число = ОписаниеТипа.ПривестиЗначение(ЧислоСтрокойБезПробелов);
	
	Возврат Число;
КонецФункции

Функция СписокЦБВФорматеJSON(ИспользуемыеЦБ)
	ТекстJSON = "";
	
	ЭтоПерваяСтрока = Истина;
	Для каждого СтрокаТЗ Из ИспользуемыеЦБ Цикл
		ПолеRegNum = ОписаниеПоляJSON("RegNum", СтрокаТЗ.НомерРегистрации);
		ПолеIsin = ОписаниеПоляJSON("Isin", СтрокаТЗ.ISIN);
		Если ПолеIsin = "" И ПолеRegNum = "" Тогда
			Продолжить;
		КонецЕсли;
		
		Если ЭтоПерваяСтрока Тогда
			ЭтоПерваяСтрока = Ложь;
		Иначе
			ТекстJSON = ТекстJSON + ",";
		КонецЕсли;
		ТекстJSON = ТекстJSON + "{" + ПолеRegNum + ?(ПолеRegNum = "" Или ПолеIsin = "", "", ",") + ПолеIsin + "}";
	КонецЦикла;
	
	Если Не ПустаяСтрока(ТекстJSON) Тогда
		ТекстJSON = "[" + ТекстJSON + "]";
	КонецЕсли;
	
	Возврат ТекстJSON;
КонецФункции

Функция ОписаниеПоляJSON(ИмяПоля, ЗначениеПоля)
	Если Не ПустаяСтрока(ЗначениеПоля) Тогда
		ОписаниеПоля = """" + ИмяПоля + """:""" + ЗначениеПоля + """";
	Иначе
		ОписаниеПоля = "";
	КонецЕсли;
	
	Возврат ОписаниеПоля;
КонецФункции

Процедура ПроверитьДанныеМестХранения(ДанныеМестХранения)
	Для каждого Данные Из ДанныеМестХранения Цикл
		ИмяНезаполненногоРеквизита = "";
		
		Если Не ЗначениеЗаполнено(Данные.ПризнакОрганизации) Тогда
			ИмяНезаполненногоРеквизита = "Признак организации";
		КонецЕсли;
		Если Не ЗначениеЗаполнено(Данные.КодМестаХранения) Тогда
			Если Данные.ПризнакМестаХранения = "1" Тогда
				ИмяНезаполненногоРеквизита = "Регистрационный номер";
			Иначе
				ИмяНезаполненногоРеквизита = "ИНН";
			КонецЕсли;
		КонецЕсли;
		
		Если ИмяНезаполненногоРеквизита <> "" Тогда
			ОписаниеОшибки =  "Для места хранения " + Строка(Данные.МестоХранения) + " не указан " + ИмяНезаполненногоРеквизита;
			РегуляторнаяОтчетность.ДобавитьОписаниеОшибки(ОписаниеОшибок, ОписаниеОшибки);
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

Процедура ПроверитьДанныеЦБ(ВсеДанные, КодыВидовИностранныхЦБ, КодыВидовИностранныхЦБСтрокой)
	ИмяИсточникаРыночныхЦен = ?(ПолучатьЦеныИзBQ, "BackQORT", "1С");
	Для каждого Данные Из ВсеДанные Цикл
		ПроверитьСтрокуДанных(Данные, КодыВидовИностранныхЦБ, КодыВидовИностранныхЦБСтрокой, ИмяИсточникаРыночныхЦен);
	КонецЦикла;
КонецПроцедуры

Функция КотировкаИзДЕПО(Данные)
	КотировкаИзДЕПО = Данные.ЭтоДолговаяЦБ И (Данные.Погашена Или Данные.Дефолтная);
	
	Возврат КотировкаИзДЕПО;
КонецФункции

Процедура ПроверитьСтрокуДанных(Данные, КодыВидовИностранныхЦБ, КодыВидовИностранныхЦБСтрокой, ИмяИсточникаРыночныхЦен)
	Если ПустаяСтрока(Данные.ISIN) И ПустаяСтрока(Данные.НомерРегистрации) Тогда
		ОписаниеОшибки = ОписаниеЦБ(Данные) + " не заполнены ни ISIN, ни регистрационный номер";
		РегуляторнаяОтчетность.ДобавитьОписаниеОшибки(ОписаниеОшибок, ОписаниеОшибки);
	КонецЕсли;
	
	Если КодыВидовИностранныхЦБ.Найти(Данные.КодВидаЦББанкаРоссии) = Неопределено Тогда
		ОписаниеОшибки = ОписаниеЦБ(Данные) + " код вида ЦБ банка России " 
							+ Данные.КодВидаЦББанкаРоссии + " не входит в список: " + КодыВидовИностранныхЦБСтрокой;
		РегуляторнаяОтчетность.ДобавитьОписаниеОшибки(ОписаниеОшибок, ОписаниеОшибки);
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(Данные.ВалютаНоминала) Тогда
		ОписаниеОшибки = ОписаниеЦБ(Данные) + " не указана валюта номинала";
		РегуляторнаяОтчетность.ДобавитьОписаниеОшибки(ОписаниеОшибок, ОписаниеОшибки);
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(Данные.НоминальнаяЦена) И НоминальнаяСтоимостьДолжнаБытьНеПустой(Данные) Тогда
		ОписаниеОшибки = ОписаниеЦБ(Данные) + " не указана номинальная стоимость";
		РегуляторнаяОтчетность.ДобавитьОписаниеОшибки(ОписаниеОшибок, ОписаниеОшибки);
	КонецЕсли;
	
	Если Данные.МетодОценки = "НО" И Данные.УровеньОценки = Неопределено Тогда
		ОписаниеОшибки = ОписаниеЦБ(Данные) + " не найдено никакой информации о ней в базе " + ИмяИсточникаРыночныхЦен
			+ ", рыночную цену определить невозможно";
		РегуляторнаяОтчетность.ДобавитьОписаниеОшибки(ОписаниеОшибок, ОписаниеОшибки);
	Иначе
		Если Не ЗначениеЗаполнено(Данные.РыночнаяКотировка) 
			И Не КотировкаИзДЕПО(Данные) Тогда
			ОписаниеОшибки = ОписаниеЦБ(Данные) + " из " + ИмяИсточникаРыночныхЦен
				+ " получена рыночная цена 0, уровень " + ОписаниеУровняОценки(Данные.УровеньОценки);
			РегуляторнаяОтчетность.ДобавитьОписаниеОшибки(ОписаниеОшибок, ОписаниеОшибки);
		КонецЕсли;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(Данные.МетодОценки) Тогда
		ОписаниеОшибки = ОписаниеЦБ(Данные) + " не указан код метода оценки рыночной цены";
		РегуляторнаяОтчетность.ДобавитьОписаниеОшибки(ОписаниеОшибок, ОписаниеОшибки);
	КонецЕсли;
	
	Если Данные.КодВалютыНоминала <> Данные.КодВалютыНоминалаПоДаннымBQ Тогда
		ОписаниеОшибки = ОписаниеЦБ(Данные) + " код валюты номинала по данным 1С ДЕПО (" + Данные.КодВалютыНоминала + ")"
						+ "отличается от кода валюты номинала по данным " + ИмяИсточникаРыночныхЦен + " (" + Данные.КодВалютыНоминалаПоДаннымBQ + ")";
		РегуляторнаяОтчетность.ДобавитьОписаниеОшибки(ОписаниеОшибок, ОписаниеОшибки);
	КонецЕсли;
	
	Если Данные.Просрочена Тогда
		ОписаниеОшибки = ОписаниеЦБ(Данные, "По ценной бумаге ") + " просрочено погашение";
		РегуляторнаяОтчетность.ДобавитьОписаниеОшибки(ОписаниеОшибок, ОписаниеОшибки);
	КонецЕсли;
	
	Если Данные.ВРегистреРыночныеЦеныЦБНеНайденаЦенаЦБ Тогда
		ОписаниеОшибки = ОписаниеЦБ(Данные, "По ценной бумаге ")
			+ " не найдена Рыночная цена в валюте ЦБ в регистре ""Рыночные цены ценных бумаг""";
		РегуляторнаяОтчетность.ДобавитьОписаниеОшибки(ОписаниеОшибок, ОписаниеОшибки);
	КонецЕсли;
	
КонецПроцедуры

Функция НоминальнаяСтоимостьДолжнаБытьНеПустой(Данные)
	Возврат (Не Данные.ЭтоДепозитарнаяРасписка И Не Данные.ЭтоВидЦБСНулевымНоминалом И Не Данные.Погашена);
КонецФункции

Функция ОписаниеУровняОценки(УровеньОценки)
	
	Если ПолучатьЦеныИзBQ Тогда
		ОписаниеУровня = ОписаниеУровняОценкиBQ(УровеньОценки);
	Иначе
		ОписаниеУровня = ОписаниеУровняОценки1С(УровеньОценки);
	КонецЕсли;
	
	Возврат ОписаниеУровня;
	
КонецФункции

Функция ОписаниеУровняОценкиBQ(УровеньОценки)
	
	Если УровеньОценки = "1" Тогда
		НазваниеУровня = "рыночная цена";
	ИначеЕсли УровеньОценки = "2" Тогда
		НазваниеУровня = "цена номинала";
	ИначеЕсли УровеньОценки = "3" Тогда
		НазваниеУровня = "нет данных о цене";
	Иначе
		НазваниеУровня = "непредвиденный номер уровня";
	КонецЕсли;
	ОписаниеУровня = УровеньОценки + " - " + НазваниеУровня;
	
	Возврат ОписаниеУровня;
КонецФункции

Функция ОписаниеУровняОценки1С(УровеньОценки)
	
	Если УровеньОценки = "1" Или  УровеньОценки = "2" Тогда
		НазваниеУровня = "рыночная цена";
	ИначеЕсли УровеньОценки = "3" Тогда
		НазваниеУровня = "цена последней сделки";
	ИначеЕсли УровеньОценки = "4" Тогда
		НазваниеУровня = "цена номинала";
	ИначеЕсли УровеньОценки = "5" Тогда
		НазваниеУровня = "нет данных о цене";
	Иначе
		НазваниеУровня = "непредвиденный номер уровня";
	КонецЕсли;
	ОписаниеУровня = УровеньОценки + " - " + НазваниеУровня;
	
	Возврат ОписаниеУровня;
КонецФункции

Функция ОписаниеЦБ(Данные, Префикс = Неопределено)
	Если Префикс = Неопределено Тогда
		Префикс = "У ЦБ ";
	КонецЕсли;
	Описание = Префикс + Строка(Данные.ЦБ);
	Если НЕ ПустаяСтрока(Данные.ISIN) Тогда
		Описание = Описание + " (ISIN:" + Данные.ISIN + ")";
	КонецЕсли;
	
	Возврат Описание;
КонецФункции

Функция СоставительОтчета(Фабрика, ПространствоИмен, ОтчетнаяДатаДляXML)
	Составитель = Фабрика.Создать(Фабрика.Тип(ПространствоИмен, "Ф0409404Составитель"));
	
	Составитель.Руководитель = Фабрика.Создать(Фабрика.Тип(ПространствоИмен, "Ф0409404СоставительРуководитель"));
	РегуляторнаяОтчетность.ЗаполнитьИнформациюОбОтветственномЛице(Составитель.Руководитель, Организация,
								Перечисления.ОтветственныеЛицаОрганизаций.ПодписантВРегуляторнойОтчетности, ОтчетнаяДатаДляXML);
	
	Составитель.Исполнитель = Фабрика.Создать(Фабрика.Тип(ПространствоИмен, "Ф0409404СоставительИсполнитель"));
	РегуляторнаяОтчетность.ЗаполнитьИнформациюОбОтветственномЛице(Составитель.Исполнитель, Организация,
								Перечисления.ОтветственныеЛицаОрганизаций.ИсполнительВРегуляторнойОтчетности, ОтчетнаяДатаДляXML);
	
	РегуляторнаяОтчетность.ЗаполнитьИнформациюОбОрганизации(Составитель, Организация, ОтчетнаяДатаДляXML);
	
	Возврат Составитель;
КонецФункции

Функция Данные404(Фабрика, ПространствоИмен)
	Данные404 = Фабрика.Создать(Фабрика.Тип(ПространствоИмен, "Ф0409404Данные404"));
	Данные404.Ид = "1";
	
	Данные404.Раздел2 = Раздел2(Фабрика, ПространствоИмен);
	
	Возврат Данные404;
КонецФункции

Функция Раздел2(Фабрика, ПространствоИмен)
	Раздел2 = Фабрика.Создать(Фабрика.Тип(ПространствоИмен, "Ф0409404Данные404Раздел2"));
	
	Для каждого Данные Из ДанныеРаздела_2 Цикл
		СтрокаРаздела2 = Фабрика.Создать(Фабрика.Тип(ПространствоИмен, "Ф0409404Данные404Раздел2Раздел2Данные"));
		
		// BSLLS:Typo-off
		ЗаполнитьЗначенияСвойств(СтрокаРаздела2, Данные, , "КодРегионКл, КолЦБум, ЦенаЦБумНомин, ЦенаЦБумРын, ОбщСтЦБумНомин, ОбщСтЦБумРын");
		
		// Осторожно! Схема хранимая в конфигурации модифицирована по сравнению с оригинальной:
		//	- добавлены типы: Строка21, Строка29
		//	- в разделе "Ф0409404Данные404Раздел2Раздел2Данные" типы атрибутов Строка29Число15_6Неотр-лок и Число15_6Полож-лок
		//		заменены на Строка21, а Число23_6Неотр-лок на Строка29.
		// Это потребовалось, чтобы все числа можно было выгрузить в файл дополненными до 6 нулей после запятой (см. NRB-321)
		ФорматЧисла = "ЧДЦ=6; ЧРД=.; ЧН=; ЧГ=";
		СтрокаРаздела2.КолЦБум = Формат(Данные.КолЦБум, ФорматЧисла);
		СтрокаРаздела2.ЦенаЦБумНомин = Формат(Данные.ЦенаЦБумНомин, ФорматЧисла);
		СтрокаРаздела2.ЦенаЦБумРын = Формат(Данные.ЦенаЦБумРын, ФорматЧисла);
		СтрокаРаздела2.ОбщСтЦБумНомин = Формат(Данные.ОбщСтЦБумНомин, ФорматЧисла);
		СтрокаРаздела2.ОбщСтЦБумРын = Формат(Данные.ОбщСтЦБумРын, ФорматЧисла);
		// BSLLS:Typo-on
		СтрокаРаздела2.ОсобПом = Данные.ОсобПом;
		РегуляторнаяОтчетность.ПрисвоитьНепустое(СтрокаРаздела2.КодРегионКл, Данные.КодРегионКл);
		Раздел2.Раздел2Данные.Добавить(СтрокаРаздела2);
	КонецЦикла;
	
	Раздел2.КолСтрокРаздДанные = ДанныеРаздела_2.Количество();
	
	Возврат Раздел2;
КонецФункции

// Нумерует строки в данных и заполняет колонку N1 с банковской лицензией организации
// Параметры:
//	Данные - ТабличнаяЧасть - Табличная часть или таблица значений, должна
Процедура ПронумероватьСтроки(Данные)
	НомСтр = 0;
	Для каждого Строка Из Данные Цикл
		НомСтр = НомСтр + 1;
		Строка.Разд2НомСтр = "2." + Формат(НомСтр, "ЧГ=");
	КонецЦикла;
КонецПроцедуры

