							<v8:content>Право использования ДС клиентов</v8:content>
						</v8:item>
					</dcsset:lwsTitle>
					<dcsset:item xsi:type="dcsset:SelectedItemField">
						<dcsset:field>ПредоставленоПравоИспользованияДС</dcsset:field>
					</dcsset:item>
					<dcsset:placement>Auto</dcsset:placement>
