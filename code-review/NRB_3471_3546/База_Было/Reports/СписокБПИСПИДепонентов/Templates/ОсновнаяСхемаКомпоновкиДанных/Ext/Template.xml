<?xml version="1.0" encoding="UTF-8"?>
<DataCompositionSchema xmlns="http://v8.1c.ru/8.1/data-composition-system/schema" xmlns:dcscom="http://v8.1c.ru/8.1/data-composition-system/common" xmlns:dcscor="http://v8.1c.ru/8.1/data-composition-system/core" xmlns:dcsset="http://v8.1c.ru/8.1/data-composition-system/settings" xmlns:v8="http://v8.1c.ru/8.1/data/core" xmlns:v8ui="http://v8.1c.ru/8.1/data/ui" xmlns:xs="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
	<dataSource>
		<name>ИсточникДанных1</name>
		<dataSourceType>Local</dataSourceType>
	</dataSource>
	<dataSet xsi:type="DataSetQuery">
		<name>НаборДанных1</name>
		<field xsi:type="DataSetFieldField">
			<dataPath>Клиент</dataPath>
			<field>Клиент</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>СчетДляВыплатыКД</dataPath>
			<field>СчетДляВыплатыКД</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>КлиентСУчетомНаСчетахТипаC</dataPath>
			<field>КлиентСУчетомНаСчетахТипаC</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ПредоставленоПравоИспользованияДС</dataPath>
			<field>ПредоставленоПравоИспользованияДС</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>НомерДоговора</dataPath>
			<field>НомерДоговора</field>
		</field>
		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ
	Контрагенты.Ссылка КАК Клиент,
	ЕСТЬNULL(ПравоИспользованияДСКлиентовСрезПоследних.Значение, ЛОЖЬ) КАК ПредоставленоПравоИспользованияДС,
	ЕСТЬNULL(КлиентыСУчетомНаСчетахТипаCСрезПоследних.ФлагАктивности, ЛОЖЬ) КАК КлиентСУчетомНаСчетахТипаC,
	ДоговорыКонтрагентов.Код КАК НомерДоговора,
	ВЫБОР
		КОГДА ЕСТЬNULL(КлиентыСУчетомНаСчетахТипаCСрезПоследних.ФлагАктивности, ЛОЖЬ) ТОГДА
			СчетаДляВыплатыКД.Счет
		ИНАЧЕ NULL
	КОНЕЦ КАК СчетДляВыплатыКД
ИЗ
	Справочник.Контрагенты КАК Контрагенты
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ПравоИспользованияЦБКлиентов.СрезПоследних(&amp;Период, ) КАК ПравоИспользованияДСКлиентовСрезПоследних
		ПО (ПравоИспользованияДСКлиентовСрезПоследних.Клиент = Контрагенты.Ссылка)
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ДоговорыКонтрагентов КАК ДоговорыКонтрагентов
		ПО Контрагенты.Ссылка = ДоговорыКонтрагентов.Владелец
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.КлиентыСУчетомНаСчетахТипаC.СрезПоследних(&amp;Период, ) КАК КлиентыСУчетомНаСчетахТипаCСрезПоследних
		ПО (КлиентыСУчетомНаСчетахТипаCСрезПоследних.Клиент = Контрагенты.Ссылка) 
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СчетаДляВыплатыКД.СрезПоследних(&amp;Период, ) КАК СчетаДляВыплатыКД
		ПО (СчетаДляВыплатыКД.Клиент = Контрагенты.Ссылка)
ГДЕ
	(ДоговорыКонтрагентов.ДатаОкончанияДействия &gt; &amp;Период
			ИЛИ ДоговорыКонтрагентов.ДатаОкончанияДействия = ДАТАВРЕМЯ(1, 1, 1))
	И ДоговорыКонтрагентов.ТипДоговора В(&amp;ТипДоговора)
	И Контрагенты.ЮрФизЛицо В (&amp;ЮрФизЛицо)</query>
	</dataSet>
	<parameter>
		<name>Период</name>
		<title xsi:type="v8:LocalStringType">
			<v8:item>
				<v8:lang>ru</v8:lang>
				<v8:content>Период</v8:content>
			</v8:item>
		</title>
		<valueType>
			<v8:Type>xs:dateTime</v8:Type>
			<v8:DateQualifiers>
				<v8:DateFractions>DateTime</v8:DateFractions>
			</v8:DateQualifiers>
		</valueType>
		<value xsi:type="xs:dateTime">0001-01-01T00:00:00</value>
		<useRestriction>false</useRestriction>
		<use>Always</use>
	</parameter>
	<parameter>
		<name>ТипДоговора</name>
		<title xsi:type="v8:LocalStringType">
			<v8:item>
				<v8:lang>ru</v8:lang>
				<v8:content>Тип договора</v8:content>
			</v8:item>
		</title>
		<valueType>
			<v8:Type xmlns:d4p1="http://v8.1c.ru/8.1/data/enterprise/current-config">d4p1:EnumRef.ТипыДоговоров</v8:Type>
		</valueType>
		<value xsi:type="dcscor:DesignTimeValue">Перечисление.ТипыДоговоров.Депозитарный</value>
		<value xsi:type="dcscor:DesignTimeValue">Перечисление.ТипыДоговоров.МежДепозитарный</value>
		<useRestriction>true</useRestriction>
		<valueListAllowed>true</valueListAllowed>
	</parameter>
	<parameter>
		<name>ЮрФизЛицо</name>
		<title xsi:type="v8:LocalStringType">
			<v8:item>
				<v8:lang>ru</v8:lang>
				<v8:content>Юр физ лицо</v8:content>
			</v8:item>
		</title>
		<valueType>
			<v8:Type xmlns:d4p1="http://v8.1c.ru/8.1/data/enterprise/current-config">d4p1:EnumRef.ЮрФизЛицо</v8:Type>
		</valueType>
		<value xsi:type="dcscor:DesignTimeValue">Перечисление.ЮрФизЛицо.ЮрЛицо</value>
		<value xsi:type="dcscor:DesignTimeValue">Перечисление.ЮрФизЛицо.ФизЛицо</value>
		<useRestriction>true</useRestriction>
		<valueListAllowed>true</valueListAllowed>
	</parameter>
	<settingsVariant>
		<dcsset:name>Основной</dcsset:name>
		<dcsset:presentation xsi:type="v8:LocalStringType">
			<v8:item>
				<v8:lang>ru</v8:lang>
				<v8:content>Основной</v8:content>
			</v8:item>
		</dcsset:presentation>
		<dcsset:settings xmlns:style="http://v8.1c.ru/8.1/data/ui/style" xmlns:sys="http://v8.1c.ru/8.1/data/ui/fonts/system" xmlns:web="http://v8.1c.ru/8.1/data/ui/colors/web" xmlns:win="http://v8.1c.ru/8.1/data/ui/colors/windows">
			<dcsset:selection>
