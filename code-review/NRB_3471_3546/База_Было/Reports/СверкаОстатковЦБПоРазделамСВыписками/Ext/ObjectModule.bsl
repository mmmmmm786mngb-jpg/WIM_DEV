
#Область ОбработчикиСобытий

Процедура ПриКомпоновкеРезультата(ДокументРезультат, ДанныеРасшифровки, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	СоздатьВТПоТаблицеЗначений(МенеджерВременныхТаблиц, ДанныеПоОстаткам, "ДанныеПоОстаткам");
	
	Схема = ПолучитьМакет("ОсновнаяСхемаКомпоновкиДанных");
	
	Настройки = КомпоновщикНастроек.ПолучитьНастройки();
	
	ПараметрыДанных = Настройки.ПараметрыДанных;
	РазделыСчетаДепоМХ = УникальныеЗначенияКолонкиТаблицы("КодРаздела", ДанныеПоОстаткам);
	ПараметрыДанных.УстановитьЗначениеПараметра("РазделыСчетаДепоМХ", РазделыСчетаДепоМХ);
	
	ДанныеРасшифровки = Новый ДанныеРасшифровкиКомпоновкиДанных;
	
	КомпоновщикМакета = Новый КомпоновщикМакетаКомпоновкиДанных;
	МакетКомпоновки = КомпоновщикМакета.Выполнить(Схема, Настройки, ДанныеРасшифровки);
	
	ПроцессорКомпоновкиДанных = Новый ПроцессорКомпоновкиДанных;
	ПроцессорКомпоновкиДанных.Инициализировать(МакетКомпоновки, , ДанныеРасшифровки, Истина, , МенеджерВременныхТаблиц);
	
	ДокументРезультат.Очистить();
	
	ПроцессорВывода = Новый ПроцессорВыводаРезультатаКомпоновкиДанныхВТабличныйДокумент;
	ПроцессорВывода.УстановитьДокумент(ДокументРезультат);
	ПроцессорВывода.Вывести(ПроцессорКомпоновкиДанных);
	
	ДокументРезультат.ОриентацияСтраницы = ОриентацияСтраницы.Портрет;
	ДокументРезультат.АвтоМасштаб = Истина;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция УникальныеЗначенияКолонкиТаблицы(ИмяКолонки, ВнешняяТаблица)
	
	Результат = Новый Массив;
	ОбщегоНазначенияКлиентСервер.ДополнитьМассив(Результат, ВнешняяТаблица.ВыгрузитьКолонку(ИмяКолонки), Истина);
	Возврат Результат;
	
КонецФункции

Процедура СоздатьВТПоТаблицеЗначений(МенеджерВременныхТаблиц, ВнешняяТаблица, ИмяВнешнейТаблицы)
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ *
	|ПОМЕСТИТЬ " + ИмяВнешнейТаблицы + "
	|ИЗ
	|	&ВнешняяТаблица КАК ВнешняяТаблица";
	
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("ВнешняяТаблица", ВнешняяТаблица);
	
	Запрос.Выполнить();
КонецПроцедуры

Процедура УстановитьПараметрСКД(КомпоновщикНастроек, ИмяПараметра, Значение)
	
	Перем ПараметрДанных, Настройки, ПользовательскиеНастройки, ПользовательскийПараметр;
	
	Настройки = КомпоновщикНастроек.Настройки;
	
	ПараметрДанных = Настройки.ПараметрыДанных.Элементы.Найти(ИмяПараметра);
	
	Если ЗначениеЗаполнено(ПараметрДанных.ИдентификаторПользовательскойНастройки) Тогда
		
		ПользовательскиеНастройки = КомпоновщикНастроек.ПользовательскиеНастройки;
		ПользовательскийПараметр
			= ПользовательскиеНастройки.Элементы.Найти(ПараметрДанных.ИдентификаторПользовательскойНастройки);
		ПользовательскийПараметр.Использование = Истина;
		ПользовательскийПараметр.Значение = Значение;
	Иначе
		
		Параметр = Настройки.ПараметрыДанных.Элементы.Найти(ИмяПараметра);
		Параметр.Использование = Истина;
		Параметр.Значение = Значение;
	КонецЕсли;
	
КонецПроцедуры

Процедура ДобавитьСтрокуВТаблицуДанныхПоОстаткам(ЭтоБлокировочныйРаздел, КодРазделаОригинал, КодРаздела, ISIN, Количество)
	
	Если ЭтоБлокировочныйРаздел = Ложь Тогда
		
		СтрокаДанных = ДанныеПоОстаткам.Добавить();
		СтрокаДанных.КодРаздела = КодРаздела;
		СтрокаДанных.Количество = Количество;
		
	Иначе
		
		СтруктураПоиска = Новый Структура("КодРаздела, ISIN", КодРазделаОригинал, ISIN);
		НайденыСтрокиДанных = ДанныеПоОстаткам.НайтиСтроки(СтруктураПоиска);
		
		Если НайденыСтрокиДанных.Количество() = 1 Тогда
			СтрокаДанных = НайденыСтрокиДанных[0];
			
		Иначе // Исключительная ситуация
			СтрокаДанных = ДанныеПоОстаткам.Добавить();
			СтрокаДанных.КодРаздела = КодРаздела;
			
			ШаблонСообщения = "ЦБ: [%1]. Для раздела блокировок: [%2] не найден раздел: [%3] !";
			ТекстСообщения = СтрШаблон(ШаблонСообщения, ISIN, КодРаздела, КодРазделаОригинал);
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
			
		КонецЕсли;
		
		СтрокаДанных.Блокировано = СтрокаДанных.Блокировано + Количество;
		
	КонецЕсли;
	
	СтрокаДанных.ISIN = ISIN;
	
КонецПроцедуры

Функция ДатаВФайлеВыписки(ВременноеИмяФайла, ИмяИсточникаВыписки)
	
	Период = Дата(1, 1, 1);
	
	Если ИмяИсточникаВыписки = "РДЦ" Тогда
		
		Текст = Новый ЧтениеТекста(ВременноеИмяФайла);
		ТекущаяСтрока = Текст.ПрочитатьСтроку();
		Пока ТекущаяСтрока <> Неопределено Цикл
			ТекущаяСтрока = Текст.ПрочитатьСтроку();
			
			Если СтрНайти(ТекущаяСтрока, ПризнакПериода) > 0 Тогда
				НачальныйНомер 			= СтрДлина(ПризнакПериода) + 1;
				ПериодВыпискиСтрокой 	= СокрЛП(Сред(ТекущаяСтрока, НачальныйНомер));
				Период = Дата(ПериодВыпискиСтрокой);
				Прервать;
			КонецЕсли;
			
		КонецЦикла;
		Текст.Закрыть();
		
	КонецЕсли;
	
	Если ИмяИсточникаВыписки = "КЦМФБ" Тогда
		
		Чтение = Новый ЧтениеXML;
		Чтение.ОткрытьФайл(ВременноеИмяФайла);
		
		Фабрика = Новый ФабрикаXDTO;
		ОбXDTO = Фабрика.ПрочитатьXML(Чтение);
		
		Попытка
			ОперационныйДень = ОбXDTO.Document.CtdyStmtOfHldgsV02[ПризнакПериода].StmtDtTm.Dt;
			Период = СтроковыеФункцииКлиентСерверПереопределяемый.ДатаВремяИзСтроки(ОперационныйДень);
		Исключение
			ОперационныйДень = "";
		КонецПопытки;
		
		Чтение.Закрыть();
		
	КонецЕсли;
	
	Возврат Период;
	
КонецФункции

Процедура УстановитьПутьККаталогуВыписок(ИмяОтчета, ИмяИсточникаВыписки)
	
	Попытка
		Если ИмяИсточникаВыписки = "РДЦ" Тогда
			ВнешнийИсточник = ПланыВидовХарактеристик.ВнешниеИсточники.ФайловыйШлюзРДЦКаталогВыписок;
		ИначеЕсли ИмяИсточникаВыписки = "КЦМФБ" Тогда
			ВнешнийИсточник = ПланыВидовХарактеристик.ВнешниеИсточники.ФайловыйШлюзКЦМФБКаталогВыписок;
		Иначе
			ТекстСообщения = СтрШаблон("Для источника '%1' загрузка не предусмотрена!", ИмяИсточникаВыписки);
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
			ЗаписьЖурналаРегистрации(ИмяОтчета, УровеньЖурналаРегистрации.Ошибка, , , ТекстСообщения);
			Возврат;
		КонецЕсли;
		
		ПараметрыВнешнегоИсточника = ВнешниеДанные.ПолучитьПараметрыВнешнегоИсточника(ВнешнийИсточник);
		КаталогВыписок = ПараметрыВнешнегоИсточника.Папка;
	Исключение
		ТекстСообщения = "В данной конфигурации внешних источников по-умолчанию нет.";
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
	КонецПопытки;
	
КонецПроцедуры

Функция ЭтоФайлВыписки(НайденныйФайл, ПараметрыФайлаВыписки, ИмяИсточникаВыписки)
	
	Если ИмяИсточникаВыписки = "РДЦ" Тогда
		
		ДлинаДаты = 6;
		ПозицияНачалаСчета 		= СтрНайти(НайденныйФайл.ИмяБезРасширения, "_", НаправлениеПоиска.СКонца, , 1) + 1;
		НомерСчета 				= Сред(НайденныйФайл.ИмяБезРасширения, ПозицияНачалаСчета);
		ПозицияНачалаДатыФайла 	= СтрНайти(НайденныйФайл.ИмяБезРасширения, "_", НаправлениеПоиска.СКонца, , 2) + 1;
		ДатаВИмениСтрокой		= Сред(НайденныйФайл.ИмяБезРасширения, ПозицияНачалаДатыФайла, ПозицияНачалаСчета - ПозицияНачалаДатыФайла - 1);
		Попытка
			ДатаВИмени = Дата("20" + Лев(ДатаВИмениСтрокой, ДлинаДаты));
		Исключение
			Возврат Ложь;
		КонецПопытки;
		ПозицияТипаФайла		= ПозицияНачалаДатыФайла + ДлинаДаты;
		ТипФайла				= ВРег(Сред(НайденныйФайл.ИмяБезРасширения, ПозицияТипаФайла, 1));
		Если Не ТипФайла = "R" Тогда
			Возврат Ложь;
		КонецЕсли;
		ДатаВФайле = ДатаВФайлеВыписки(НайденныйФайл.ПолноеИмя, ИмяИсточникаВыписки);
		
	КонецЕсли;
	
	Если ИмяИсточникаВыписки = "КЦМФБ" Тогда
		
		ДлинаДаты = 8;
		ТипФайла = НРег(Сред(НайденныйФайл.ИмяБезРасширения, 1, 4));
		Если Не ТипФайла = "rest" Тогда
			Возврат Ложь;
		КонецЕсли;
		ПозицияНачалаСчета		= СтрНайти(НайденныйФайл.ИмяБезРасширения, "_", НаправлениеПоиска.СНачала, , 1) + 1;
		ПозицияНачалаДатыФайла	= СтрНайти(НайденныйФайл.ИмяБезРасширения, "_", НаправлениеПоиска.СНачала, , 2) + 1;
		Если ПозицияНачалаСчета * ПозицияНачалаДатыФайла = 0 Тогда
			Возврат Ложь;
		КонецЕсли;
		НомерСчета				= Сред(НайденныйФайл.ИмяБезРасширения, ПозицияНачалаСчета, ПозицияНачалаДатыФайла - ПозицияНачалаСчета - 1);
		ДатаВИмениСтрокой		= Сред(НайденныйФайл.ИмяБезРасширения, ПозицияНачалаДатыФайла, ДлинаДаты);
		Попытка
			ДатаВИмени = Дата(ДатаВИмениСтрокой);
		Исключение
			Возврат Ложь;
		КонецПопытки;
		ДатаВФайле = ДатаВФайлеВыписки(НайденныйФайл.ПолноеИмя, ИмяИсточникаВыписки);
		Если ДатаВФайле = ДатаВИмени Тогда
			Возврат Ложь;
		КонецЕсли;
		
	КонецЕсли;
	
	ПараметрыФайлаВыписки.НомерСчета = НомерСчета;
	ПараметрыФайлаВыписки.ДатаВФайле = ДатаВФайле;
	ПараметрыФайлаВыписки.ДатаВИмени = ДатаВИмени;
	ПараметрыФайлаВыписки.ИмяФайла   = НайденныйФайл.ПолноеИмя;
	
	Возврат Истина;
	
КонецФункции

Функция НовыеПараметрыФайлаВыписки()
	
	Параметры = Новый Структура;
	Параметры.Вставить("НомерСчета"	, "");
	Параметры.Вставить("ДатаВФайле"	, Дата(1, 1, 1));
	Параметры.Вставить("ДатаВИмени"	, Дата(1, 1, 1));
	Параметры.Вставить("ИмяФайла"	, "");
	
	Возврат Параметры;
	
КонецФункции

Процедура ПолучитьОстаткиИзВыпискиПоИсточникуРДЦ(ВременноеИмяФайла)
	
	Текст = Новый ЧтениеТекста(ВременноеИмяФайла);
	
	ТекущаяСтрока = Текст.ПрочитатьСтроку();
	ЭтоРазделБлокировок = Ложь;
	КодРаздела = "";
	КодРазделаОригинал = "";
	Пока ТекущаяСтрока <> Неопределено Цикл
		
		ТекущаяСтрока = Текст.ПрочитатьСтроку();
		
		Если СтрНайти(ТекущаяСтрока, ПризнакСекцииРаздела) > 0 Тогда
			
			ТекущаяСтрока 	= Текст.ПрочитатьСтроку();
			НачальныйНомер 	= СтрДлина(ПризнакНомераРаздела) + 1;
			КодРаздела 		= СокрЛП(Сред(ТекущаяСтрока, НачальныйНомер));
			ЭтоРазделБлокировок = ПризнакРазделаБлокировки = Прав(КодРаздела , 1);
			Если ЭтоРазделБлокировок Тогда
				ДлинаРазделаБлокировок = СтрДлина(КодРаздела);
				КодРазделаОригинал = Сред(КодРаздела, 1, ДлинаРазделаБлокировок - 1);
			Иначе
				КодРазделаОригинал = КодРаздела;
			КонецЕсли;
		КонецЕсли;
		
		Если СтрНайти(ТекущаяСтрока, ПризнакISIN) > 0 Тогда
			
			НачальныйНомер 	= СтрДлина(ПризнакISIN) + 1;
			ISIN 			= СокрЛП(Сред(ТекущаяСтрока, НачальныйНомер));
			ТекущаяСтрока 	= Текст.ПрочитатьСтроку();
			ТекущаяСтрока	= СтрЗаменить(ТекущаяСтрока, "," , " ");
			НачальныйНомер 	= СтрДлина(ПризнакКоличества) + 1;
			КоличествоСтр 	= СокрЛП(Сред(ТекущаяСтрока, НачальныйНомер));
			Количество 		= СтроковыеФункцииКлиентСервер.СтрокаВЧисло(КоличествоСтр);
			
			ДобавитьСтрокуВТаблицуДанныхПоОстаткам(ЭтоРазделБлокировок, КодРазделаОригинал, КодРаздела, ISIN, Количество);
			
		КонецЕсли;
		
	КонецЦикла;
	
	Текст.Закрыть();
	
КонецПроцедуры

Процедура ПолучитьОстаткиИзВыпискиПоИсточникуКЦМФБ(ВременноеИмяФайла)
	
	Чтение = Новый ЧтениеXML;
	Чтение.ОткрытьФайл(ВременноеИмяФайла);
	
	Фабрика = Новый ФабрикаXDTO;
	ОбXDTO = Фабрика.ПрочитатьXML(Чтение);
	
	CtdyStmtOfHldgsV02 = ОбXDTO.Document.CtdyStmtOfHldgsV02;
	
	ЭтоРазделБлокировок = Ложь;
	КодРаздела = "";
	КодРазделаОригинал = "";
	
	ЭтоКоллекцияРазделов = ТипЗнч(CtdyStmtOfHldgsV02[ПризнакНомераРаздела]) = Тип("СписокXDTO");
	Если ЭтоКоллекцияРазделов Тогда
		КоличествоРазделов = CtdyStmtOfHldgsV02[ПризнакНомераРаздела].Количество();
	Иначе
		КоличествоРазделов = 1;
	КонецЕсли;
	Для ИндексРаздела = 0 По КоличествоРазделов - 1 Цикл
		
		Если ЭтоКоллекцияРазделов Тогда
			SubAcctDtls = CtdyStmtOfHldgsV02[ПризнакНомераРаздела][ИндексРаздела];
		Иначе
			SubAcctDtls = CtdyStmtOfHldgsV02[ПризнакНомераРаздела];
		КонецЕсли;
		КодРаздела = СокрЛП(SubAcctDtls.Id.SmplId.Prtry.Id);
		КодРазделаОригинал = КодРаздела;
		
		ЕстьОстатки = SubAcctDtls.Свойства().Получить(ПризнакСекцииРаздела) <> Неопределено;
		Если ЕстьОстатки Тогда
			
			ДобавитьОстаткиИзВыпискиПоИсточникуКЦМФБвТаблицу(SubAcctDtls, ЭтоРазделБлокировок, КодРазделаОригинал, КодРаздела);
			
		КонецЕсли;
		
	КонецЦикла;
	
	Чтение.Закрыть();
	
КонецПроцедуры

Процедура ДобавитьОстаткиИзВыпискиПоИсточникуКЦМФБвТаблицу(SubAcctDtls, ЭтоРазделБлокировок, КодРазделаОригинал, КодРаздела)
	
	ЭтоКоллекцияЦБ = ТипЗнч(SubAcctDtls[ПризнакСекцииРаздела]) = Тип("СписокXDTO");
	Если ЭтоКоллекцияЦБ Тогда
		КоличествоЦБ = SubAcctDtls[ПризнакСекцииРаздела].Количество();
	Иначе
		КоличествоЦБ = 1;
	КонецЕсли;
	
	Для ИндексЦБ = 0 По КоличествоЦБ - 1 Цикл
		
		Если ЭтоКоллекцияЦБ Тогда
			BalForSubAcct = SubAcctDtls[ПризнакСекцииРаздела][ИндексЦБ];
		Иначе
			BalForSubAcct = SubAcctDtls[ПризнакСекцииРаздела];
		КонецЕсли;
		
		ISIN 			= СокрЛП(BalForSubAcct[ПризнакISIN].Id.ISIN);
		КоличествоСтр 	= СокрЛП(BalForSubAcct[ПризнакКоличества].Qty.Unit);
		Количество 		= СтроковыеФункцииКлиентСервер.СтрокаВЧисло(КоличествоСтр);
		
		ДобавитьСтрокуВТаблицуДанныхПоОстаткам(ЭтоРазделБлокировок, КодРазделаОригинал, КодРаздела, ISIN, Количество);
		
	КонецЦикла;
	
КонецПроцедуры

