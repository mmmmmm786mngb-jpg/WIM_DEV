// Процедура - Инициализация по умолчанию
//
// Параметры:
//  ИмяОтчета			 - Строка - Название отчета
//  ИмяИсточникаВыписки	 - Строка - Название источника выписки
//
Процедура ИнициализацияПоУмолчанию(ИмяОтчета, ИмяИсточникаВыписки) Экспорт
	
	ИсточникВыписок = ИмяИсточникаВыписки;
	
	Если ИмяИсточникаВыписки = "РДЦ" Тогда
		ПризнакРазделаБлокировки 	= "P";
		ПризнакСекцииРаздела 		= ":16R:SUBSAFE";
		ПризнакНомераРаздела 		= ":97A::SAFE//";
		ПризнакISIN 				= ":35B:ISIN";
		ПризнакКоличества 			= ":93B::AGGR//UNIT/";
		ПризнакПериода	 			= ":98A::STAT//";
		ПризнакРасширенияФайла	 	= "txt";
	КонецЕсли;
	Если ИмяИсточникаВыписки = "КЦМФБ" Тогда
		ПризнакРазделаБлокировки 	= "";
		ПризнакСекцииРаздела 		= "BalForSubAcct";
		ПризнакНомераРаздела 		= "SubAcctDtls";
		ПризнакISIN 				= "FinInstrmDtls";
		ПризнакКоличества 			= "AggtQty";
		ПризнакПериода	 			= "StmtGnlDtls";
		ПризнакРасширенияФайла	 	= "xml";
	КонецЕсли;
	
	УстановитьПутьККаталогуВыписок(ИмяОтчета, ИмяИсточникаВыписки);
	
КонецПроцедуры

// Процедура - Сохранить настройки
//
// Параметры:
//  ИмяОтчета			 - Строка - Название отчета
//  ИмяИсточникаВыписки	 - Строка - Название источника выписки
//
Процедура СохранитьНастройки(ИмяОтчета, ИмяИсточникаВыписки) Экспорт
	
	СтруктураПараметров = Новый Структура;
	СтруктураПараметров.Вставить("ПризнакРазделаБлокировки"	, ПризнакРазделаБлокировки);
	СтруктураПараметров.Вставить("ПризнакСекцииРаздела"		, ПризнакСекцииРаздела);
	СтруктураПараметров.Вставить("ПризнакНомераРаздела"		, ПризнакНомераРаздела);
	СтруктураПараметров.Вставить("ПризнакISIN"				, ПризнакISIN);
	СтруктураПараметров.Вставить("ПризнакКоличества"		, ПризнакКоличества);
	СтруктураПараметров.Вставить("ПризнакПериода"			, ПризнакПериода);
	СтруктураПараметров.Вставить("КаталогВыписок"			, КаталогВыписок);
	СтруктураПараметров.Вставить("ПризнакРасширенияФайла"	, ПризнакРасширенияФайла);
	
	ХранилищеОбщихНастроек.Сохранить(ИмяОтчета , "СтруктураПараметров" + ИмяИсточникаВыписки , СтруктураПараметров);
	
КонецПроцедуры

// Процедура - Восстановить настройки
//
// Параметры:
//  ИмяОтчета			 - Строка - Название отчета
//  ИмяИсточникаВыписки	 - Строка - Название источника выписки
//
Процедура ВосстановитьНастройки(ИмяОтчета, ИмяИсточникаВыписки) Экспорт
	
	СтруктураПараметров = ХранилищеОбщихНастроек.Загрузить(ИмяОтчета , "СтруктураПараметров" + ИмяИсточникаВыписки);
	
	Если СтруктураПараметров <> Неопределено Тогда
		ЗаполнитьЗначенияСвойств(ЭтотОбъект, СтруктураПараметров);
	КонецЕсли;
	
КонецПроцедуры

// Процедура - Получить остатки из выписки
//
//  Информация о настройках ключевых точек файла источника "РДЦ"
//  	"P" - последний символ раздела, означает что это блокировка Раздела, с таким же номером, но без "P" в конце
//  	":16R:SUBSAFE" - начало секции Раздела счета депо МХ, в следующей строке будет:
//  	":97A::SAFE//" - за этим текстом идет номер Раздела
//  	В каждом разделе идут ценные бумаги:
//  	":35B:ISIN" - за этим текстом идет ISIN, в следующей строке будет:
//  	":93B::AGGR//UNIT/" - за этим текстом идет количество  (до символа ",")
//
//  Информация о настройках ключевых точек файла источника "КЦМФБ"
// 		Document.CtdyStmtOfHldgsV02 -обязательный тег
//  	в нем:
//  	 - <MsgId>       - обязательный тег в котором есть <CreDtTm>  2021-07-19T11:12:32.490   : дата выписки
//  	 - <StmtGnlDtls> - обязательный тег в котором есть  <StmtDtTm><Dt>2021-07-16</Dt>       : опер день
//  	   берем только Выписки, в которых Дата выписки отличается от Даты опер.дня 
//  	 - <AcctDtls>    - обязательный тег в котором есть: <Id><SmplId><Prtry><Id>RMM00511</Id>  - НомерСчета !
//  	 - <SubAcctDtls>: массив субсчетов, в котором есть:
//  	        - <Id><SmplId><Prtry><Id>RMM00511</Id>  - НомерРаздела !
//  	        - <BalForSubAcct> : нет, или 1 (тогда это структура) или >1 (тогда это массив структур)  , в котором есть:
//  	              - <AggtQty>      -    обязательный тег <Qty><Unit>1.00000000</Unit></Qty> - количество штук
//  	              - <AvlblQty>     - НЕ обязательный тег <Qty><Unit>1.00000000</Unit></Qty> - количество штук доступно
//  	              - <FinInstrmDtls>-    обязательный тег <Id><ISIN>XS0088543193</ISIN></Id> - ISIN ЦБ
//
// Параметры:
//  ФайлВХранилище		 - Строка	 - Адрес хранилища с файлом выписки
//  ИмяИсточникаВыписки	 - Строка	 - Название источника выписки
//
Процедура ПолучитьОстаткиИзВыписки(ФайлВХранилище, ИмяИсточникаВыписки) Экспорт
	
	ДвоичныеДанные = ПолучитьИзВременногоХранилища(ФайлВХранилище);
	ВременноеИмяФайла = ПолучитьИмяВременногоФайла(ПризнакРасширенияФайла);
	ДвоичныеДанные.Записать(ВременноеИмяФайла);
	
	ДанныеПоОстаткам.Очистить();
	
	Если ИмяИсточникаВыписки = "РДЦ" Тогда
		ПолучитьОстаткиИзВыпискиПоИсточникуРДЦ(ВременноеИмяФайла);
	КонецЕсли;
	
	Если ИмяИсточникаВыписки = "КЦМФБ" Тогда
		ПолучитьОстаткиИзВыпискиПоИсточникуКЦМФБ(ВременноеИмяФайла);
	КонецЕсли;
	
	Если ДанныеПоОстаткам.Количество() = 0 Тогда
		ТекстСообщения = "Данные для загрузки не обнаружены. Попробуйте другой файл (с секциями вида [" + ПризнакСекцииРаздела + "]).";
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
	КонецЕсли;
	
	Период = ДатаВФайлеВыписки(ВременноеИмяФайла, ИмяИсточникаВыписки);
	УстановитьПараметрСКД(КомпоновщикНастроек, "Период", Период);
	УстановитьПараметрСКД(КомпоновщикНастроек, "ИсточникВыписок", ИмяИсточникаВыписки);
	
	УдалитьФайлы(ВременноеИмяФайла);
	
КонецПроцедуры

// Процедура - Получить файлы выписки
//
// Параметры:
//  Каталог				 - Строка	 - Каталог файлов выписки
//  ИмяИсточникаВыписки	 - Строка - Название источника выписки
//
Процедура ПолучитьФайлыВыписки(Каталог, ИмяИсточникаВыписки) Экспорт
	
	ФайлыВыписок.Очистить();
	
	НайденныеФайлы = НайтиФайлы(Каталог, "*." + ПризнакРасширенияФайла, Истина);
	
	Для Каждого НайденныйФайл Из НайденныеФайлы Цикл
		
		ПараметрыФайлаВыписки = НовыеПараметрыФайлаВыписки();
		
		Если ЭтоФайлВыписки(НайденныйФайл, ПараметрыФайлаВыписки, ИмяИсточникаВыписки) Тогда
			
			НовыйФайл = ФайлыВыписок.Добавить();
			
			ЗаполнитьЗначенияСвойств(НовыйФайл, ПараметрыФайлаВыписки);
			
		КонецЕсли;
		
	КонецЦикла;
	
	ФайлыВыписок.Сортировать("ДатаВИмени УБЫВ, НомерСчета");
	
КонецПроцедуры

#КонецОбласти