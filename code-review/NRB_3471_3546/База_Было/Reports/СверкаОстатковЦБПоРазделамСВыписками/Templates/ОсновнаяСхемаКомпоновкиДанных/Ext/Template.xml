		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ
	ОстаткиЦБОстатки.РазделСчетаДепоМХ.Код КАК КодРаздела,
	ОстаткиЦБОстатки.ЦБ.ISIN КАК ISIN,
	ОстаткиЦБОстатки.КоличествоОстаток КАК Количество1С,
	0 КАК Блокировано1С,
	ОстаткиЦБОстатки.РазделСчетаДепоМХ КАК РазделСчетаДепоМХ,
	ОстаткиЦБОстатки.ЦБ КАК ЦеннаяБумага,
	ДанныеПоОстаткам.КодРаздела КАК РазделСчетаДепоМХФайл,
	ДанныеПоОстаткам.ISIN КАК ISINФайл,
	ДанныеПоОстаткам.Количество КАК КоличествоФайл,
	ДанныеПоОстаткам.Блокировано КАК БлокированоФайл,
	ЕСТЬNULL(ДанныеПоОстаткам.Блокировано, 0) + ЕСТЬNULL(ДанныеПоОстаткам.Количество, 0) - ЕСТЬNULL(ОстаткиЦБОстатки.КоличествоОстаток, 0) КАК Расхождение
ИЗ
	РегистрНакопления.ОстаткиЦБ.Остатки({(ДОБАВИТЬКДАТЕ(&amp;Период, ДЕНЬ, 1))}, РазделСчетаДепоМХ.Код В (&amp;РазделыСчетаДепоМХ)) КАК ОстаткиЦБОстатки
		ПОЛНОЕ СОЕДИНЕНИЕ ДанныеПоОстаткам КАК ДанныеПоОстаткам
		ПО ОстаткиЦБОстатки.РазделСчетаДепоМХ.Код = ДанныеПоОстаткам.КодРаздела
			И ОстаткиЦБОстатки.ЦБ.ISIN = ДанныеПоОстаткам.ISIN
ГДЕ
	(НЕ &amp;ПоказатьТолькоРасхождения
			ИЛИ ЕСТЬNULL(ДанныеПоОстаткам.Блокировано, 0) + ЕСТЬNULL(ДанныеПоОстаткам.Количество, 0) - ЕСТЬNULL(ОстаткиЦБОстатки.КоличествоОстаток, 0) &lt;&gt; 0)</query>
	</dataSet>
