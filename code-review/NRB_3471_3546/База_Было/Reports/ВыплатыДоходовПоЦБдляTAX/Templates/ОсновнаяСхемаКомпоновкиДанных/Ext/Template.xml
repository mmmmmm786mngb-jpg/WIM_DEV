;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	РазвернутыйОтчет.ДатаПлатежногоПоручения КАК ДатаПлатежногоПоручения,
	РазвернутыйОтчет.ЦеннаяБумага КАК ЦеннаяБумага,
	РазвернутыйОтчет.Эмитент КАК Эмитент,
	РазвернутыйОтчет.Депонент КАК Депонент,
	РазвернутыйОтчет.ЮрФизЛицо КАК ЮрФизЛицо,
	РазвернутыйОтчет.Ссылка КАК Поручение,
	ВЫРАЗИТЬ(РазвернутыйОтчет.ВидОперацииД КАК Справочник.ВидыОпераций) КАК ВидОперации,
	РазвернутыйОтчет.НомерИДатаДокументаОВыплатеДС КАК НомерИДатаДокументаОВыплатеДС,
	РазвернутыйОтчет.ПолноеНаименованиеЭмитента КАК ПолноеНаименованиеЭмитента,
	РазвернутыйОтчет.НаименованиеВыпускаЦБ КАК НаименованиеВыпускаЦБ,
	РазвернутыйОтчет.ISINГосНомер КАК ISINГосНомер,
	РазвернутыйОтчет.ЗначениеПоказателяД1ПредоставленноеЭмитентом КАК ЗначениеПоказателяД1ПредоставленноеЭмитентом,
	РазвернутыйОтчет.ЗначениеПоказателяД2ПредоставленноеЭмитентом КАК ЗначениеПоказателяД2ПредоставленноеЭмитентом,
	РазвернутыйОтчет.АкционерыПолучателиВыплатФИОНаименование КАК АкционерыПолучателиВыплатФИОНаименование,
	РазвернутыйОтчет.РезидентНерезидент КАК РезидентНерезидент,
	СУММА(РазвернутыйОтчет.КоличествоЦБНаКотороеНачисленыДС) КАК КоличествоЦБНаКотороеНачисленыДС,
	РазвернутыйОтчет.РазмерВыплатыНа1ЦБВРублях КАК РазмерВыплатыНа1ЦБВРублях,
	СУММА(РазвернутыйОтчет.ОбщаяСуммаНачисленныхДивидендовD1ВРублях) КАК ОбщаяСуммаНачисленныхДивидендовD1ВРублях,
	РазвернутыйОтчет.ВалютаВыплаты КАК ВалютаВыплаты,
	СУММА(РазвернутыйОтчет.СуммаУдержанногоНалогаВРублях) КАК СуммаУдержанногоНалогаВРублях,
	СУММА(РазвернутыйОтчет.СуммаКВыплатеДоходовВВалютеПлатежа) КАК СуммаКВыплатеДоходовВВалютеПлатежа,
	РазвернутыйОтчет.ДатаВыплатыДоходаАкционеру КАК ДатаВыплатыДоходаАкционеру,
	РазвернутыйОтчет.Примечание КАК Примечание,
	РазвернутыйОтчет.Комментарии КАК Комментарии
ИЗ
	РазвернутыйОтчет КАК РазвернутыйОтчет

СГРУППИРОВАТЬ ПО
	РазвернутыйОтчет.ДатаПлатежногоПоручения,
	РазвернутыйОтчет.ЦеннаяБумага,
	РазвернутыйОтчет.Эмитент,
	РазвернутыйОтчет.Депонент,
	РазвернутыйОтчет.ЮрФизЛицо,
	РазвернутыйОтчет.Ссылка,
	РазвернутыйОтчет.ВидОперацииД,
	РазвернутыйОтчет.НомерИДатаДокументаОВыплатеДС,
	РазвернутыйОтчет.НаименованиеВыпускаЦБ,
	РазвернутыйОтчет.ISINГосНомер,
	РазвернутыйОтчет.ЗначениеПоказателяД1ПредоставленноеЭмитентом,
	РазвернутыйОтчет.ЗначениеПоказателяД2ПредоставленноеЭмитентом,
	РазвернутыйОтчет.АкционерыПолучателиВыплатФИОНаименование,
	РазвернутыйОтчет.РезидентНерезидент,
	РазвернутыйОтчет.РазмерВыплатыНа1ЦБВРублях,
	РазвернутыйОтчет.ВалютаВыплаты,
	РазвернутыйОтчет.ДатаВыплатыДоходаАкционеру,
	РазвернутыйОтчет.Примечание,
	РазвернутыйОтчет.Комментарии,
	РазвернутыйОтчет.ПолноеНаименованиеЭмитента
;

