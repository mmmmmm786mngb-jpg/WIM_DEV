		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ
	Поручение.Ссылка КАК Ссылка,
	Поручение.ВидОперацииД КАК ВидОперацииД,
	ПоручениеЦенныеБумагиСписываемые.СчетДепо.Владелец КАК Депонент,
	ПоручениеЦенныеБумагиСписываемые.СчетДепо КАК СчетДепо,
	ПоручениеЦенныеБумагиСписываемые.РазделСчетаДепо КАК РазделСчетаДепо,
	Поручение.НомерИПД КАК НомерИПД,
	Поручение.НомерПлатежногоПоручения КАК НомерПлатежногоПоручения,
	Поручение.ДатаПлатежногоПоручения КАК ДатаПлатежногоПоручения,
	Поручение.КоэффициентД1 КАК КоэффициентД1,
	Поручение.КоэффициентД2 КАК КоэффициентД2,
	Поручение.ВыплатаНа1ЦБ КАК ВыплатаНа1ЦБ,
	Поручение.Валюта КАК Валюта,
	ВЫБОР
		КОГДА Поручение.Валюта.Наименование = "SUR"
			ТОГДА ИСТИНА
		ИНАЧЕ ЛОЖЬ
	КОНЕЦ КАК ЭтоРубли,
	(ВЫРАЗИТЬ(Поручение.Комментарий КАК СТРОКА(512))) + " " + (ВЫРАЗИТЬ(ПоручениеЦенныеБумагиСписываемые.Комментарий КАК СТРОКА(250))) КАК Комментарий,
	ПоручениеЦенныеБумагиСписываемые.Количество КАК Количество,
	ВЫБОР
		КОГДА ПоручениеЦенныеБумагиСписываемые.Резидент
			ТОГДА "Резидент"
		ИНАЧЕ "Нерезидент"
	КОНЕЦ КАК РезидентНерезидент,
	ПоручениеЦенныеБумагиСписываемые.ЦеннаяБумага КАК ЦеннаяБумага,
	ПоручениеЦенныеБумагиСписываемые.Сумма КАК ОбщаяСуммаНачисленныхДивидендовD1,
	ПоручениеЦенныеБумагиСписываемые.СуммаКВыплатеПоИПД КАК СуммаКВыплатеПоИПД,
	ПоручениеЦенныеБумагиСписываемые.ПлановаяДатаРасчетов КАК ПлановаяДатаРасчетов
ПОМЕСТИТЬ ДанныеПоручений
ИЗ
	Документ.Поручение.ЦенныеБумагиСписываемые КАК ПоручениеЦенныеБумагиСписываемые
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.Поручение КАК Поручение
		ПО ПоручениеЦенныеБумагиСписываемые.Ссылка = Поручение.Ссылка
			И (Поручение.Проведен)
			И (ВЫБОР
				КОГДА Поручение.ДатаИсполненияПоручения &lt;&gt; ДАТАВРЕМЯ(1, 1, 1, 0, 0, 0)
					ТОГДА Поручение.ДатаИсполненияПоручения МЕЖДУ &amp;НАЧАЛОПЕРИОДА И &amp;КОНЕЦПЕРИОДА
				ИНАЧЕ ПоручениеЦенныеБумагиСписываемые.ПлановаяДатаРасчетов МЕЖДУ &amp;НАЧАЛОПЕРИОДА И &amp;КОНЕЦПЕРИОДА
			КОНЕЦ)
			И (Поручение.ВидОперацииД.ВыплатаДоходаВДенежнойФорме = ИСТИНА)
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	ДанныеПоручений.Валюта КАК Валюта,
	ПлатежнаяОперацияВыплатаДохода.Основание КАК Основание,
	ПлатежнаяОперацияВыплатаДохода.СчетДепо КАК СчетДепо,
	ПлатежнаяОперацияВыплатаДохода.РазделСчетаДепо КАК РазделСчетаДепо,
	НАЧАЛОПЕРИОДА(ПлатежнаяОперацияВыплатаДохода.Дата, ДЕНЬ) КАК ДатаВыплатыДоходаАкционеру
ПОМЕСТИТЬ ПлатежныеОперации
ИЗ
	Документ.ПлатежнаяОперация КАК ПлатежнаяОперацияВыплатаДохода
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ДанныеПоручений КАК ДанныеПоручений
		ПО ПлатежнаяОперацияВыплатаДохода.Основание = ДанныеПоручений.Ссылка
			И ПлатежнаяОперацияВыплатаДохода.СчетДепо = ДанныеПоручений.СчетДепо
			И ПлатежнаяОперацияВыплатаДохода.РазделСчетаДепо = ДанныеПоручений.РазделСчетаДепо
			И (ПлатежнаяОперацияВыплатаДохода.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыПлатежныхОпераций.ВыплатаДохода))
			И (ПлатежнаяОперацияВыплатаДохода.Проведен)
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	НачисленныйНалог.Основание КАК Основание,
	НачисленныйНалог.СчетДепо КАК СчетДепо,
	НачисленныйНалог.РазделСчетаДепо КАК РазделСчетаДепо,
	НачисленныйНалог.СуммаНалога + НачисленныйНалог.СуммаНалогаПоСтавке15СПревышения КАК СуммаУдержанногоНалогаВРублях
ПОМЕСТИТЬ Налоги
ИЗ
	Документ.НачисленныйНалог КАК НачисленныйНалог
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ДанныеПоручений КАК ДанныеПоручений
		ПО НачисленныйНалог.Основание = ДанныеПоручений.Ссылка
			И НачисленныйНалог.СчетДепо = ДанныеПоручений.СчетДепо
			И НачисленныйНалог.РазделСчетаДепо = ДанныеПоручений.РазделСчетаДепо
			И (НачисленныйНалог.Проведен)
			И (НачисленныйНалог.Подтвержден)
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	ПлатежныеОперации.ДатаВыплатыДоходаАкционеру КАК ДатаВыплатыДоходаАкционеру,
	КурсыВалют.Валюта КАК Валюта,
	МАКСИМУМ(КурсыВалют.Период) КАК ПериодКурса
ПОМЕСТИТЬ ПериодыКурсовВалютПлатежа
ИЗ
	ПлатежныеОперации КАК ПлатежныеОперации
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.КурсыВалют КАК КурсыВалют
		ПО ПлатежныеОперации.Валюта = КурсыВалют.Валюта
			И ПлатежныеОперации.ДатаВыплатыДоходаАкционеру &gt;= КурсыВалют.Период

СГРУППИРОВАТЬ ПО
	ПлатежныеОперации.ДатаВыплатыДоходаАкционеру,
	КурсыВалют.Валюта
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	ДанныеПоручений.ПлановаяДатаРасчетов КАК ПлановаяДатаРасчетов,
	КурсыВалют.Валюта КАК Валюта,
	МАКСИМУМ(КурсыВалют.Период) КАК ПериодКурса
ПОМЕСТИТЬ ПериодыКурсовВалютПоручения
ИЗ
	ДанныеПоручений КАК ДанныеПоручений
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.КурсыВалют КАК КурсыВалют
		ПО ДанныеПоручений.Валюта = КурсыВалют.Валюта
			И ДанныеПоручений.ПлановаяДатаРасчетов &gt;= КурсыВалют.Период

СГРУППИРОВАТЬ ПО
	ДанныеПоручений.ПлановаяДатаРасчетов,
	КурсыВалют.Валюта
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	ДанныеПоручений.ДатаПлатежногоПоручения КАК ДатаПлатежногоПоручения,
	ЦенныеБумаги.Ссылка КАК ЦеннаяБумага,
	ЦенныеБумаги.Эмитент КАК Эмитент,
	ДанныеПоручений.Депонент КАК Депонент,
	ДанныеПоручений.Депонент.ЮрФизЛицо КАК ЮрФизЛицо,
	ДанныеПоручений.Ссылка КАК Ссылка,
	ДанныеПоручений.ВидОперацииД КАК ВидОперацииД,
	ВЫБОР
		КОГДА ДанныеПоручений.НомерИПД = ""
			ТОГДА ДанныеПоручений.НомерПлатежногоПоручения
		ИНАЧЕ ДанныеПоручений.НомерИПД
	КОНЕЦ + " от " + (ВЫРАЗИТЬ(ЛЕВ(СТРОКА(ДанныеПоручений.ДатаПлатежногоПоручения), СТРНАЙТИ(СТРОКА(ДанныеПоручений.ДатаПлатежногоПоручения), " ") - 1) КАК СТРОКА(10))) КАК НомерИДатаДокументаОВыплатеДС,
	ВЫРАЗИТЬ(ЦенныеБумаги.Эмитент.НаименованиеПолное КАК СТРОКА(1024)) КАК ПолноеНаименованиеЭмитента,
	ЦенныеБумаги.НаименованиеВыпуска КАК НаименованиеВыпускаЦБ,
	ВЫБОР
		КОГДА ЦенныеБумаги.ISIN = ""
				И ЦенныеБумаги.НомерРегистрации &lt;&gt; ""
			ТОГДА ЦенныеБумаги.НомерРегистрации
		КОГДА ЦенныеБумаги.НомерРегистрации = ""
				И ЦенныеБумаги.ISIN &lt;&gt; ""
			ТОГДА ЦенныеБумаги.ISIN
		КОГДА ЦенныеБумаги.ISIN &lt;&gt; ""
				И ЦенныеБумаги.НомерРегистрации &lt;&gt; ""
			ТОГДА ЦенныеБумаги.ISIN + " \ " + ЦенныеБумаги.НомерРегистрации
		ИНАЧЕ ""
	КОНЕЦ КАК ISINГосНомер,
	ДанныеПоручений.КоэффициентД1 КАК ЗначениеПоказателяД1ПредоставленноеЭмитентом,
	ДанныеПоручений.КоэффициентД2 КАК ЗначениеПоказателяД2ПредоставленноеЭмитентом,
	ДанныеПоручений.Депонент КАК АкционерыПолучателиВыплатФИОНаименование,
	ДанныеПоручений.РезидентНерезидент КАК РезидентНерезидент,
	ДанныеПоручений.Количество КАК КоличествоЦБНаКотороеНачисленыДС,
	ДанныеПоручений.ВыплатаНа1ЦБ * ЕСТЬNULL(ВЫБОР
			КОГДА КурсыВалютПлатежа.Кратность = 0
				ТОГДА КурсыВалютПлатежа.Курс
			ИНАЧЕ КурсыВалютПлатежа.Курс / КурсыВалютПлатежа.Кратность
		КОНЕЦ, ЕСТЬNULL(ВЫБОР
				КОГДА КурсыВалютПоручения.Кратность = 0
					ТОГДА КурсыВалютПоручения.Курс
				ИНАЧЕ КурсыВалютПоручения.Курс / КурсыВалютПоручения.Кратность
			КОНЕЦ, 1)) КАК РазмерВыплатыНа1ЦБВРублях,
	ВЫРАЗИТЬ(ДанныеПоручений.ОбщаяСуммаНачисленныхДивидендовD1 * ЕСТЬNULL(ВЫБОР
				КОГДА КурсыВалютПлатежа.Кратность = 0
					ТОГДА КурсыВалютПлатежа.Курс
				ИНАЧЕ КурсыВалютПлатежа.Курс / КурсыВалютПлатежа.Кратность
			КОНЕЦ, ЕСТЬNULL(ВЫБОР
					КОГДА КурсыВалютПоручения.Кратность = 0
						ТОГДА КурсыВалютПоручения.Курс
					ИНАЧЕ КурсыВалютПоручения.Курс / КурсыВалютПоручения.Кратность
				КОНЕЦ, 1)) КАК ЧИСЛО(18, 2)) КАК ОбщаяСуммаНачисленныхДивидендовD1ВРублях,
	ДанныеПоручений.Валюта КАК ВалютаВыплаты,
	ЕСТЬNULL(Налоги.СуммаУдержанногоНалогаВРублях, 0) КАК СуммаУдержанногоНалогаВРублях,
	ВЫБОР
		КОГДА ДанныеПоручений.ЭтоРубли
			ТОГДА ДанныеПоручений.ОбщаяСуммаНачисленныхДивидендовD1 - ЕСТЬNULL(Налоги.СуммаУдержанногоНалогаВРублях, 0)
		ИНАЧЕ ДанныеПоручений.СуммаКВыплатеПоИПД
	КОНЕЦ КАК СуммаКВыплатеДоходовВВалютеПлатежа,
	ЕСТЬNULL(ПлатежныеОперации.ДатаВыплатыДоходаАкционеру, ДАТАВРЕМЯ(1, 1, 1, 0, 0, 0)) КАК ДатаВыплатыДоходаАкционеру,
	ДанныеПоручений.Комментарий КАК Примечание,
	ВЫБОР
		КОГДА ЕСТЬNULL(ПлатежныеОперации.ДатаВыплатыДоходаАкционеру, ДАТАВРЕМЯ(1, 1, 1, 0, 0, 0)) &lt;&gt; ДАТАВРЕМЯ(1, 1, 1, 0, 0, 0)
			ТОГДА "Выплачен"
		КОГДА ЕСТЬNULL(Налоги.СуммаУдержанногоНалогаВРублях, 0) &gt; 0
			ТОГДА "Подтвержден"
		ИНАЧЕ ""
	КОНЕЦ КАК Комментарии
ПОМЕСТИТЬ РазвернутыйОтчет
ИЗ
	ДанныеПоручений КАК ДанныеПоручений
		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ЦенныеБумаги КАК ЦенныеБумаги
		ПО ДанныеПоручений.ЦеннаяБумага = ЦенныеБумаги.Ссылка
		ЛЕВОЕ СОЕДИНЕНИЕ ПлатежныеОперации КАК ПлатежныеОперации
			ЛЕВОЕ СОЕДИНЕНИЕ ПериодыКурсовВалютПлатежа КАК ПериодыКурсовВалютПлатежа
				ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.КурсыВалют КАК КурсыВалютПлатежа
				ПО ПериодыКурсовВалютПлатежа.Валюта = КурсыВалютПлатежа.Валюта
					И ПериодыКурсовВалютПлатежа.ПериодКурса = КурсыВалютПлатежа.Период
			ПО ПлатежныеОперации.ДатаВыплатыДоходаАкционеру = ПериодыКурсовВалютПлатежа.ДатаВыплатыДоходаАкционеру
				И ПлатежныеОперации.Валюта = ПериодыКурсовВалютПлатежа.Валюта
		ПО ДанныеПоручений.Ссылка = ПлатежныеОперации.Основание
			И ДанныеПоручений.СчетДепо = ПлатежныеОперации.СчетДепо
			И ДанныеПоручений.РазделСчетаДепо = ПлатежныеОперации.РазделСчетаДепо
		ЛЕВОЕ СОЕДИНЕНИЕ Налоги КАК Налоги
		ПО ДанныеПоручений.Ссылка = Налоги.Основание
			И ДанныеПоручений.СчетДепо = Налоги.СчетДепо
			И ДанныеПоручений.РазделСчетаДепо = Налоги.РазделСчетаДепо
		ЛЕВОЕ СОЕДИНЕНИЕ ПериодыКурсовВалютПоручения КАК ПериодыКурсовВалютПоручения
			ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.КурсыВалют КАК КурсыВалютПоручения
			ПО ПериодыКурсовВалютПоручения.Валюта = КурсыВалютПоручения.Валюта
				И ПериодыКурсовВалютПоручения.ПериодКурса = КурсыВалютПоручения.Период
		ПО ДанныеПоручений.ПлановаяДатаРасчетов = ПериодыКурсовВалютПоручения.ПлановаяДатаРасчетов
			И ДанныеПоручений.Валюта = ПериодыКурсовВалютПоручения.Валюта
;

