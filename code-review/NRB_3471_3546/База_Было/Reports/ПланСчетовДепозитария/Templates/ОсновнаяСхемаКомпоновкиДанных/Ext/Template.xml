		<field xsi:type="DataSetFieldField">
			<dataPath>ЦБ</dataPath>
			<field>ЦБ</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Ценная бумага</v8:content>
				</v8:item>
			</title>
			<role>
				<dcscom:dimension>true</dcscom:dimension>
			</role>
			<presentationExpression>ЦБ.Эмитент.Наименование + ВЫБОР
		КОГДА ЦБ.ТипЦБ = ЗНАЧЕНИЕ(Перечисление.ТипыЦБ.Акция)
				И ЦБ.ВидЦБ = ЗНАЧЕНИЕ(Перечисление.ВидыАкций.Обыкновенная)
			ТОГДА " АО"
		КОГДА ЦБ.ТипЦБ = ЗНАЧЕНИЕ(Перечисление.ТипыЦБ.Акция)
				И ЦБ.ВидЦБ = ЗНАЧЕНИЕ(Перечисление.ВидыАкций.Привилегированная)
			ТОГДА " АП"
		КОГДА ЦБ.ТипЦБ = ЗНАЧЕНИЕ(Перечисление.ТипыЦБ.Облигация)
			ТОГДА " Обл"
		ИНАЧЕ ЦБ.Наименование
	КОНЕЦ + ВЫБОР
		КОГДА ЦБ.СерияРегистрации &lt;&gt; ""
			ТОГДА " серия " + ЦБ.СерияРегистрации
		ИНАЧЕ ""
	КОНЕЦ + " " + ВЫБОР
		КОГДА ЦБ.НомерРегистрации &lt;&gt; ""
			ТОГДА " № " + ЦБ.НомерРегистрации
		ИНАЧЕ ""
	КОНЕЦ</presentationExpression>
