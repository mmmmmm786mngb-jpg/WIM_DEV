КонецПроцедуры	

//Процедура заполнения  ТаблицаЗначенийСчета по ПБОЮЛ.
//
Процедура КоличествоСчетовПБОЮЛРезидент(НачКол=0,КонКол=0)
	
	НоваяСтрока	=	ТаблицаЗначенийСчета.Добавить();
