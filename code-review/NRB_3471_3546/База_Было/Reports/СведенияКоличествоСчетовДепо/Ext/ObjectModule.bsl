//таблица значений для вывода остатков по счету депо.
ТаблицаЗначенийСчета = Новый ТаблицаЗначений;
ТаблицаЗначенийСчета.Колонки.Добавить("НПП"); 
ТаблицаЗначенийСчета.Колонки.Добавить("СчетОтбор"); 
ТаблицаЗначенийСчета.Колонки.Добавить("КолНач"); 
ТаблицаЗначенийСчета.Колонки.Добавить("КолКон");

ОбщегоНазначения.ЛогироватьИспользованиеОбъекта(ЭтотОбъект);
