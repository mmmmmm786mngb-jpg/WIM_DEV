	НоваяСтрока.КолКон		= КонКол;	
	
КонецПроцедуры	

//Процедура заполнения  ТаблицаЗначенийСчета по юрикам.
//
Процедура КоличествоСчетовЮриковНеРезидентов(НачКол=0,КонКол=0)
	
	НоваяСтрока	=	ТаблицаЗначенийСчета.Добавить();
