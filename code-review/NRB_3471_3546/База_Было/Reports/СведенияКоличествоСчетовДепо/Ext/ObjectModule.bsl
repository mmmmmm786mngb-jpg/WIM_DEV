КонецПроцедуры	

//Процедура заполнения  ТаблицаЗначенийСчета по ПБОЮЛ.
//
Процедура КоличествоСчетовПБОЮЛНеРезидент(НачКол=0,КонКол=0)
	
	НоваяСтрока	=	ТаблицаЗначенийСчета.Добавить();
	НоваяСтрока.НПП         = 6;
	НоваяСтрока.СчетОтбор	= "Счета депо ПБОЮЛ - нерезидентов";
	НоваяСтрока.КолНач		= НачКол;	
	НоваяСтрока.КолКон		= КонКол;
	
КонецПроцедуры	

//Процедура заполнения ТаблицаЗначенийСчета по МХ
//
Процедура КоличествоСчетовДепоМХ()
	
	Результат = КоличествоСчетовДепоМХЗаПериод();
	
	Если НЕ Результат.Пустой() Тогда
		
		Дерево = Результат.Выгрузить(ОбходРезультатаЗапроса.ПоГруппировкам);	
		Для каждого ВеткаСчета Из Дерево.Строки Цикл
			
			НоваяСтрока	=	ТаблицаЗначенийСчета.Добавить();
			НоваяСтрока.НПП         = 7;
			НоваяСтрока.СчетОтбор	= "в т.ч. междепозитарные счета депо";
			НоваяСтрока.КолНач		= ВеткаСчета.КолНач;	
			НоваяСтрока.КолКон		= ВеткаСчета.КолКон;
			
		КонецЦикла;
		
	КонецЕсли; 
	    	
КонецПроцедуры
