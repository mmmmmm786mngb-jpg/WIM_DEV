#Область ПрограммныйИнтерфейс

// Процедура заполняет данными ТЧ ДанныеПодраздела_1_2 и параметр ДанныеДляРасшифровки
// Параметры:
//	ДанныеДляРасшифровки - ТаблицаЗначений - возвращаемый параметр, в котором возвращается таблица значений
//
// BSLLS:MethodSize-off
Процедура ПолучитьДанные(ДанныеДляРасшифровки) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	// Также важно что реквизит Резидент в справочнике контрагентов, как это ни парадоксально, означает "Нерезидент по документам"
	// - живите теперь с этим, если не знали раньше
	"ВЫБРАТЬ
	|	ЮридическиеЛицаМеждународныеКомпанииСрезПоследних.МеждународнаяКомпания КАК МеждународнаяКомпания,
	|	ЮридическиеЛицаМеждународныеКомпанииСрезПоследних.ЮридическоеЛицо КАК ЮридическоеЛицо,
	|	ЮридическиеЛицаМеждународныеКомпанииСрезПоследних.ПризнакРегистрацииМеждународнойКомпании КАК ПризнакРегистрацииМК
	|ПОМЕСТИТЬ ВТ_МеждународныеКомпании
	|ИЗ
	|	РегистрСведений.ЮридическиеЛицаМеждународныеКомпании.СрезПоследних(&ПериодКонец, 1 = 1) КАК ЮридическиеЛицаМеждународныеКомпанииСрезПоследних
	|ГДЕ
	|	ЮридическиеЛицаМеждународныеКомпанииСрезПоследних.МеждународнаяКомпания
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	МАКСИМУМ(Поручение.БанковскийСчет.НомерСчета) КАК ДоходПеречисленНа,
	|	ГлобальнаяОперация.Ссылка КАК Документ,
	|	ГлобальнаяОперация.Дата КАК Период,
	|	ГлобальнаяОперация.ВидГлобальнойОперации КАК ВидОперации,
	|	ГлобальнаяОперация.СчетДепо КАК СчетДепо,
	|	Поручение.Ссылка КАК Поручение,
	|	МАКСИМУМ(Депоненты.Ссылка) КАК Депонент,
	|	МАКСИМУМ(ГлобальнаяОперация.БанковскийСчет) КАК БанковскийСчет,
	|	ГлобальнаяОперацияЦенныеБумаги.ЦеннаяБумага КАК ЦеннаяБумага,
	|	МАКСИМУМ(ЕСТЬNULL(ЭмитентыБазовыхАктивовДепозитарныхРасписок.Ссылка, Эмитенты.Ссылка)) КАК Эмитент,
	|	МАКСИМУМ(БазовыеАктивыДепозитарныхРасписок.Ссылка) КАК БазовыйАктивДепозитарнойРасписки,
	|	НАЧАЛОПЕРИОДА(МАКСИМУМ(ГлобальнаяОперация.Дата), ДЕНЬ) КАК ДатаОпер,
	|	СУММА(ГлобальнаяОперацияЦенныеБумаги.Количество) КАК КолЦб,
	|	СУММА(ГлобальнаяОперацияЦенныеБумаги.Сумма) КАК Сумма,
	|	СУММА(ГлобальнаяОперацияЦенныеБумаги.СуммаБезНалога) КАК СуммаВсего,
	|	СУММА(ВЫБОР
	|			КОГДА ГлобальнаяОперация.ВидГлобальнойОперации В (&ВидыОперацийНеПроценты)
	|				ТОГДА 0
	|			ИНАЧЕ ГлобальнаяОперацияЦенныеБумаги.СуммаБезНалога
	|		КОНЕЦ) КАК СуммаДоход,
	|	СУММА(ГлобальнаяОперацияЦенныеБумаги.СуммаНалога) КАК Налог,
	|	МАКСИМУМ(НЕ ДепонентыМеждународныеКомпании.ЮридическоеЛицо ЕСТЬ NULL) КАК ДепонентПроверкаМК,
	|	МАКСИМУМ(НЕ ЭмитентыМеждународныеКомпании.ЮридическоеЛицо ЕСТЬ NULL) КАК ЭмитентПроверкаМК,
	|	МАКСИМУМ(Депоненты.Резидент) КАК ДепонентНеРезидент,
	|	МАКСИМУМ(Эмитенты.Резидент) КАК ЭмитентНеРезидент
	|ПОМЕСТИТЬ ВТ_ОперацииЗаПериод
	|ИЗ
	|	Документ.ГлобальнаяОперация КАК ГлобальнаяОперация
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ГлобальнаяОперация.ЦенныеБумаги КАК ГлобальнаяОперацияЦенныеБумаги
	|		ПО (ГлобальнаяОперацияЦенныеБумаги.Ссылка = ГлобальнаяОперация.Ссылка)
	|			И (ГлобальнаяОперация.Проведен)
	|			И (ГлобальнаяОперация.Дата МЕЖДУ &ПериодНачало И &ПериодКонец)
	|			И (ГлобальнаяОперация.ВидГлобальнойОперации В (&ВидыОпераций))
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.Поручение.ЦенныеБумагиСписываемые КАК Поручение
	|		ПО ГлобальнаяОперация.ДокументОснование = Поручение.Ссылка
	|			И ГлобальнаяОперация.СчетДепо = Поручение.СчетДепо
	|			И (ГлобальнаяОперацияЦенныеБумаги.РазделСчетаДепо = Поручение.РазделСчетаДепо)
	|			И (ГлобальнаяОперацияЦенныеБумаги.СчетДепоМХ = Поручение.СчетДепоМХ)
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.СчетаДепо КАК СчетаДепо
	|		ПО ГлобальнаяОперация.СчетДепо = СчетаДепо.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Контрагенты КАК Депоненты
	|		ПО (СчетаДепо.Владелец = Депоненты.Ссылка)
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ЮридическиеЛица КАК ДепонентыЮридическиеЛица
	|		ПО Депоненты.ЮридическиеФизическиеЛица = ДепонентыЮридическиеЛица.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_МеждународныеКомпании КАК ДепонентыМеждународныеКомпании
	|		ПО ДепонентыЮридическиеЛица.Ссылка = ДепонентыМеждународныеКомпании.ЮридическоеЛицо
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ЦенныеБумаги КАК СправочникЦенныеБумаги
	|		ПО (ГлобальнаяОперацияЦенныеБумаги.ЦеннаяБумага = СправочникЦенныеБумаги.Ссылка)
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Контрагенты КАК Эмитенты
	|		ПО (СправочникЦенныеБумаги.Эмитент = Эмитенты.Ссылка)
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ЮридическиеЛица КАК ЭмитентыЮридическиеЛица
	|		ПО Эмитенты.ЮридическиеФизическиеЛица = ЭмитентыЮридическиеЛица.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_МеждународныеКомпании КАК ЭмитентыМеждународныеКомпании
	|		ПО ЭмитентыЮридическиеЛица.Ссылка = ЭмитентыМеждународныеКомпании.ЮридическоеЛицо
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ЦенныеБумаги КАК БазовыеАктивыДепозитарныхРасписок
	|		ПО (СправочникЦенныеБумаги.БазовыйАктив = БазовыеАктивыДепозитарныхРасписок.Ссылка)
	|			И (СправочникЦенныеБумаги.ТипЦБ В (&ТипыДепозитарныхРасписок))
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Контрагенты КАК ЭмитентыБазовыхАктивовДепозитарныхРасписок
	|		ПО (БазовыеАктивыДепозитарныхРасписок.Эмитент = ЭмитентыБазовыхАктивовДепозитарныхРасписок.Ссылка)
	|
	|СГРУППИРОВАТЬ ПО
	|	ГлобальнаяОперация.Ссылка,
	|	ГлобальнаяОперация.Дата,
	|	ГлобальнаяОперация.ВидГлобальнойОперации,
	|	ГлобальнаяОперация.СчетДепо,
	|	Поручение.Ссылка,
	|	ГлобальнаяОперацияЦенныеБумаги.ЦеннаяБумага
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_ОперацииЗаПериод.ДоходПеречисленНа КАК ДоходПеречисленНа,
	|	ВТ_ОперацииЗаПериод.Документ КАК Документ,
	|	ВТ_ОперацииЗаПериод.Период КАК Период,
	|	ВТ_ОперацииЗаПериод.ВидОперации КАК ВидОперации,
	|	ВТ_ОперацииЗаПериод.СчетДепо КАК СчетДепо,
	|	ВТ_ОперацииЗаПериод.Поручение КАК Поручение,
	|	ВТ_ОперацииЗаПериод.Депонент КАК Депонент,
	|	ВТ_ОперацииЗаПериод.БанковскийСчет КАК БанковскийСчет,
	|	ВТ_ОперацииЗаПериод.ЦеннаяБумага КАК ЦеннаяБумага,
	|	ВТ_ОперацииЗаПериод.Эмитент КАК Эмитент,
	|	ВТ_ОперацииЗаПериод.БазовыйАктивДепозитарнойРасписки КАК БазовыйАктивДепозитарнойРасписки,
	|	ВТ_ОперацииЗаПериод.ДатаОпер КАК ДатаОпер,
	|	ВТ_ОперацииЗаПериод.КолЦб КАК КолЦб,
	|	ВТ_ОперацииЗаПериод.Сумма КАК Сумма,
	|	ВТ_ОперацииЗаПериод.СуммаВсего КАК СуммаВсего,
	|	ВТ_ОперацииЗаПериод.СуммаДоход КАК СуммаДоход,
	|	ВТ_ОперацииЗаПериод.Налог КАК Налог,
	|	ВЫБОР
	|			КОГДА ВТ_ОперацииЗаПериод.ДепонентНеРезидент
	|					И НЕ ВТ_ОперацииЗаПериод.ДепонентПроверкаМК
	|					И НЕ ВТ_ОперацииЗаПериод.ЭмитентНеРезидент
	|				ТОГДА ИСТИНА
	|			КОГДА ВТ_ОперацииЗаПериод.ДепонентНеРезидент
	|					И НЕ ВТ_ОперацииЗаПериод.ДепонентПроверкаМК
	|					И ВТ_ОперацииЗаПериод.ЭмитентНеРезидент
	|					И ВТ_ОперацииЗаПериод.ЭмитентПроверкаМК
	|				ТОГДА ИСТИНА
	|			КОГДА ВТ_ОперацииЗаПериод.ЭмитентНеРезидент
	|					И НЕ ВТ_ОперацииЗаПериод.ЭмитентПроверкаМК
	|					И НЕ ВТ_ОперацииЗаПериод.ДепонентНеРезидент
	|				ТОГДА ИСТИНА
	|			КОГДА ВТ_ОперацииЗаПериод.ЭмитентНеРезидент
	|					И НЕ ВТ_ОперацииЗаПериод.ЭмитентПроверкаМК
	|					И ВТ_ОперацииЗаПериод.ДепонентНеРезидент
	|					И ВТ_ОперацииЗаПериод.ДепонентПроверкаМК
	|				ТОГДА ИСТИНА
	|			ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК ВключатьВОтчет
	|ПОМЕСТИТЬ ВТ_Операции
	|ИЗ
	|	ВТ_ОперацииЗаПериод КАК ВТ_ОперацииЗаПериод
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_Операции.ЦеннаяБумага КАК ЦеннаяБумага,
	|	ВТ_Операции.БазовыйАктивДепозитарнойРасписки КАК БазовыйАктивДепозитарнойРасписки
	|ПОМЕСТИТЬ ВТ_ЦБ
	|ИЗ
	|	ВТ_Операции КАК ВТ_Операции
	|
	|СГРУППИРОВАТЬ ПО
	|	ВТ_Операции.ЦеннаяБумага,
	|	ВТ_Операции.БазовыйАктивДепозитарнойРасписки
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	НоминалЦБСрезПоследних.ЦеннаяБумага КАК ЦеннаяБумага,
	|	НоминалЦБСрезПоследних.Сумма КАК Номинал
	|ПОМЕСТИТЬ ВТ_НоминалДепозитарныхРасписок
	|ИЗ
	|	РегистрСведений.НоминалЦБ.СрезПоследних(
	|			&ОтчетнаяДата,
	|			ЦеннаяБумага В
	|				(ВЫБРАТЬ
	|					ВТ_ЦБ.БазовыйАктивДепозитарнойРасписки КАК БазовыйАктив
	|				ИЗ
	|					ВТ_ЦБ КАК ВТ_ЦБ
	|				ГДЕ
	|					НЕ ВТ_ЦБ.БазовыйАктивДепозитарнойРасписки ЕСТЬ NULL)) КАК НоминалЦБСрезПоследних
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_ЦБ.ЦеннаяБумага КАК ЦеннаяБумага,
	|	ЦенныеБумаги.ISIN КАК ISIN,
	|	ЦенныеБумаги.НомерРегистрации КАК РегНомер,
	|	ЦенныеБумаги.Эмитент.Наименование КАК ЭмитентНаименование,
	|	ЦенныеБумаги.ТипЦБ КАК ТипЦБ,
	|	ЦенныеБумаги.Наименование КАК Наименование,
	|	ВТ_ЦБ.БазовыйАктивДепозитарнойРасписки КАК БазовыйАктивДепозитарнойРасписки,
	|	ВТ_НоминалДепозитарныхРасписок.Номинал КАК НоминалДепозитарнойРасписки,
	|	ЦенныеБумаги.ВидЦББанкаРоссии КАК ВидЦББанкаРоссии,
	|	ВЫБОР
	|		КОГДА ВидыЦББанкаРоссии.Код ЕСТЬ NULL
	|			ТОГДА ""OTH2""
	|		ИНАЧЕ ВидыЦББанкаРоссии.Код
	|	КОНЕЦ КАК КодИнструмента,
	|	ВЫБОР
	|		КОГДА НЕ ВТ_ЦБ.БазовыйАктивДепозитарнойРасписки ЕСТЬ NULL
	|				И ЕСТЬNULL(ВТ_НоминалДепозитарныхРасписок.Номинал, 0) = 0
	|			ТОГДА ИСТИНА
	|		КОГДА ВТ_ЦБ.БазовыйАктивДепозитарнойРасписки ЕСТЬ NULL
	|				И ВидыЦББанкаРоссии.Код В (&КодыБезВалюты)
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК ВалютаНоминалаНеТребуется,
	|	ВЫБОР
	|		КОГДА НЕ ВТ_ЦБ.БазовыйАктивДепозитарнойРасписки ЕСТЬ NULL
	|				И ЕСТЬNULL(ВТ_НоминалДепозитарныхРасписок.Номинал, 0) <> 0
	|			ТОГДА ВалютыНоминалаБазовыхАктивовДепозитарныхРасписок.Код
	|		КОГДА ВТ_ЦБ.БазовыйАктивДепозитарнойРасписки ЕСТЬ NULL
	|				И НЕ ВидыЦББанкаРоссии.Код В (&КодыБезВалюты)
	|			ТОГДА ВалютыНоминала.Код
	|		ИНАЧЕ """"
	|	КОНЕЦ КАК КодВалютыНоминала
	|ПОМЕСТИТЬ ВТ_ИнформацияОЦенныхБумагах
	|ИЗ
	|	ВТ_ЦБ КАК ВТ_ЦБ
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ЦенныеБумаги КАК ЦенныеБумаги
	|		ПО ВТ_ЦБ.ЦеннаяБумага = ЦенныеБумаги.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ЦенныеБумаги КАК БазовыеАктивыДепозитарныхРасписок
	|		ПО (ЦенныеБумаги.БазовыйАктив = БазовыеАктивыДепозитарныхРасписок.Ссылка)
	|			И (НЕ ВТ_ЦБ.БазовыйАктивДепозитарнойРасписки ЕСТЬ NULL)
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ВидыЦББанкаРоссии КАК ВидыЦББанкаРоссии
	|		ПО (ЦенныеБумаги.ВидЦББанкаРоссии = ВидыЦББанкаРоссии.Ссылка)
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Валюты КАК ВалютыНоминала
	|		ПО (ЦенныеБумаги.ВалютаНоминала = ВалютыНоминала.Ссылка)
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_НоминалДепозитарныхРасписок КАК ВТ_НоминалДепозитарныхРасписок
	|		ПО ВТ_ЦБ.БазовыйАктивДепозитарнойРасписки = ВТ_НоминалДепозитарныхРасписок.ЦеннаяБумага
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Валюты КАК ВалютыНоминалаБазовыхАктивовДепозитарныхРасписок
	|		ПО (БазовыеАктивыДепозитарныхРасписок.ВалютаНоминала = ВалютыНоминалаБазовыхАктивовДепозитарныхРасписок.Ссылка)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_Операции.Депонент КАК Контрагент
	|ПОМЕСТИТЬ ВТ_Депоненты
	|ИЗ
	|	ВТ_Операции КАК ВТ_Операции
	|
	|СГРУППИРОВАТЬ ПО
	|	ВТ_Операции.Депонент
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	КатегорииРолейКлиентовСогласноУказов81и95СрезПоследних.ЮрФизЛицо КАК ЮрФизЛицо,
	|	КатегорииРолейКлиентовСогласноУказов81и95СрезПоследних.КатегорияРоли КАК КатегорияРоли
	|ПОМЕСТИТЬ ВТ_КатегорииРолейДепонентов
	|ИЗ
	|	РегистрСведений.КатегорииРолейКлиентовСогласноУказов81и95.СрезПоследних(&ПериодКонец, 1 = 1) КАК КатегорииРолейКлиентовСогласноУказов81и95СрезПоследних
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ДепонентыИЭмитенты.Контрагент КАК Контрагент
	|ПОМЕСТИТЬ ВТ_ДепонентыИЭмитенты
	|ИЗ
	|	(ВЫБРАТЬ
	|		ВТ_Операции.Депонент КАК Контрагент
	|	ИЗ
	|		ВТ_Операции КАК ВТ_Операции
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		ВТ_Операции.Эмитент
	|	ИЗ
	|		ВТ_Операции КАК ВТ_Операции) КАК ДепонентыИЭмитенты
	|
	|СГРУППИРОВАТЬ ПО
