		СтрокаПодраздела.Запись.Добавить(ЗаписьПроЦБ);
		
		ЗаполнитьЗначенияСвойств(СтрокаПодраздела, Данные, КопируемыеВсегдаКолонки);
		РегуляторнаяОтчетность.ПрисвоитьНепустое(СтрокаПодраздела.КодРезидент, Данные.КодРезидент);
		РегуляторнаяОтчетность.ПрисвоитьНепустое(СтрокаПодраздела.ДатаРегВып, Данные.ДатаРегВып);
		РегуляторнаяОтчетность.ПрисвоитьНепустое(СтрокаПодраздела.ДатаПогашЦб, Данные.ДатаПогашЦб);
