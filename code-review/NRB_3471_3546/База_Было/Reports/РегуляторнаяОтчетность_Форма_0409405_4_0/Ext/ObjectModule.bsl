Процедура ПроверитьКодСтраныНерезидента(ДанныеНерезидента)
	Для каждого Данные Из ДанныеНерезидента Цикл
		Сущность = "Код страны";
		Если Данные.ДепонентыНеРезидент Тогда
			Принадлежность = "Юр/Физ. лица депонента";
			Владелец = Данные.Депонент;
		Иначе
			Принадлежность = "Юр/Физ. лица эмитента";
			Владелец = Данные.Эмитент;
		КонецЕсли;
		РегуляторнаяОтчетность.ПроверитьЦифровуюСтроку(ОписаниеОшибок, Сущность, Принадлежность, Данные.КодСтраны, Владелец, 3, Истина);
	КонецЦикла;
КонецПроцедуры

Процедура ПроверитьДанныеЭмитента(ДанныеЭмитента)
	Для каждого Данные Из ДанныеЭмитента Цикл
		Принадлежность = "Юр/Физ. лица эмитента";
		Владелец = Данные.Эмитент;
		Если Данные.ЭмитентНеРезидент Тогда
			Длина = 3;
			Сущность = "Код страны";
		Иначе
			Длина = РегуляторнаяОтчетность.ДопустимыеДлиныИНН();
			Сущность = "ИНН";
		КонецЕсли;
		РегуляторнаяОтчетность.ПроверитьЦифровуюСтроку(ОписаниеОшибок, Сущность, Принадлежность, Данные.КодЭмЦб, Владелец, Длина);
	КонецЦикла;
КонецПроцедуры

Процедура ПроверитьДанныеЦБ(ДанныеЦБ)
	Для каждого Данные Из ДанныеЦБ Цикл
		Если Не ЗначениеЗаполнено(Данные.КодВалютыНоминала) И Не Данные.ВалютаНоминалаНеТребуется Тогда
			Если ЗначениеЗаполнено(Данные.БазовыйАктивДепозитарнойРасписки) Тогда
				ВидОшибки = "не указана валюта номинала базового актива";
			Иначе
				ВидОшибки = "не указана валюта номинала";
			КонецЕсли;
			ОписаниеОшибки = РегуляторнаяОтчетность.ОписаниеОшибкиЦБ(Данные.ЦеннаяБумага, ВидОшибки, Данные.ISIN, Данные.РегНомер);
			РегуляторнаяОтчетность.ДобавитьОписаниеОшибки(ОписаниеОшибок, ОписаниеОшибки);
		КонецЕсли;
		Если ЗначениеЗаполнено(Данные.БазовыйАктивДепозитарнойРасписки) И Не ЗначениеЗаполнено(Данные.НоминалДепозитарнойРасписки) Тогда
			ВидОшибки = "не указан номинал базового актива";
			ОписаниеОшибки = РегуляторнаяОтчетность.ОписаниеОшибкиЦБ(Данные.ЦеннаяБумага, ВидОшибки, Данные.ISIN, Данные.РегНомер);
			РегуляторнаяОтчетность.ДобавитьОписаниеОшибки(ОписаниеОшибок, ОписаниеОшибки);
		КонецЕсли;
		РегуляторнаяОтчетность.ПроверитьЦифровуюСтроку(ОписаниеОшибок, "Код валюты", "ценной бумаги", 
														Данные.КодВалютыНоминала, Данные.ЦеннаяБумага, 3);
	КонецЦикла;
КонецПроцедуры

// Нумерует строки в данных и заполняет колонку N1 с банковской лицензией организации
// Параметры:
//	Строки - ТабличнаяЧасть - Табличная часть или таблица значений
Процедура ПронумероватьСтрокиПодраздела_1_2(Строки) Экспорт
	НомСтр = 0;
	Для каждого Строка Из Строки Цикл
		НомСтр = НомСтр + 1;
		Строка.НомСтроки2 = "1.2." + Формат(НомСтр, "ЧГ=");
	КонецЦикла;
КонецПроцедуры

