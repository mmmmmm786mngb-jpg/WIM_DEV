
Процедура ПриКомпоновкеРезультата(ДокументРезультат, ДанныеРасшифровки, СтандартнаяОбработка)
	Элемент = ЭлементПользовательскихНастроекПоИмениПараметра("ОтчетнаяДата");
	ОтчетнаяДата = Элемент.Значение;
	ЗначениеПараметраЗаголовок = КомпоновщикНастроек.Настройки.ПараметрыВывода.НайтиЗначениеПараметра(Новый ПараметрКомпоновкиДанных("Title"));
	ЗначениеПараметраЗаголовок.Значение = "Значения показателей деятельности по состоянию на "
		+ Лев(Формат(ОтчетнаяДата, "ДФ=""дд.ММ.гггг"""), 10) + " г. (на конец операционного дня)";
	ЗначениеПараметраЗаголовок.Использование = Истина;
	ПараметрыОтчета = КомпоновщикНастроек.Настройки.ПараметрыДанных;
	ПараметрыОтчета.УстановитьЗначениеПараметра("ТипыДепозитарныхРасписок", Перечисления.ТипыЦБ.ВсеТипыДепозитарныхРасписок());
	
	Методика = Перечисления.МетодикиРасчетаРыночныхЦен.Для481;
	ОписаниеОшибки =
		РегистрыСведений.СостоянияРасчетаРыночныхЦенЦенныхБумаг.ОписаниеНезавершенногоСостоянияОсновногоРасчета(ОтчетнаяДата.Дата, Методика);
	Если ЗначениеЗаполнено(ОписаниеОшибки) Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ОписаниеОшибки);
	КонецЕсли;
КонецПроцедуры

Функция ЭлементПользовательскихНастроекПоИмениПараметра(ИмяПарамтра)
	ИскомыйПараметр = Новый ПараметрКомпоновкиДанных(ИмяПарамтра);
	ИскомыйЭлемент = Неопределено;
	Для Каждого Элемент Из КомпоновщикНастроек.ПользовательскиеНастройки.Элементы Цикл
		Если Элемент.Параметр = ИскомыйПараметр Тогда
			ИскомыйЭлемент = Элемент;
		КонецЕсли;
	КонецЦикла;
	
	Возврат ИскомыйЭлемент;
КонецФункции
