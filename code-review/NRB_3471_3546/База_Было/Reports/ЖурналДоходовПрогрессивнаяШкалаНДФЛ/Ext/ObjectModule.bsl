// ВСПОМОГАТЕЛЬНЫЕ ФУНКЦИИ

Процедура СкорректироватьВалютуНалога(ПараметрыОбласти, Выборка)
	Если Не ( (Выборка.СуммаНачисленногоНалога + Выборка.СуммаНалогаПоСтавке15СПревышения) <> 0
				Или Выборка.СуммаУплаченногоНалога <> 0) Тогда
		ПараметрыОбласти.ВалютаНалога = "";
		ПараметрыОбласти.ВалютаНалогаНаименование = "";
	КонецЕсли;
КонецПроцедуры

Процедура ДополнитьКомментарий(ПараметрыОбласти, Выборка)
	Комментарий = Новый Массив;
	Если ЗначениеЗаполнено(Выборка.Комментарий) Тогда
		Комментарий.Добавить(БезЗнаковПрепинанияЛП(Выборка.Комментарий));
	КонецЕсли;
	Если Выборка.ЭтоЕврооблигацияМинфина И Выборка.СуммаНачисленногоНалога > 0 Тогда
		Комментарий.Добавить(" по курсу ЦБ " + Выборка.КурсВалюты + " на " + Формат(Выборка.ДатаНачисленияНалога, "ДЛФ=D"));
	КонецЕсли;
	ПараметрыОбласти.Комментарий = СтроковыеФункцииКлиентСервер.ПолучитьСтрокуИзМассиваПодстрок(Комментарий, ", ");
КонецПроцедуры

// Удаляет знаки препинания в начале и в конце строки. Возвращает исправленную строку.
//
// Параметры:
//  СтрокаИсточник	 - Строка - строка, в которой надо убрать знаки препинания 
//  ЗнакиПрепинания	 - Строка - знаки, которые убираются в исходной строке
// 
// Возвращаемое значение:
//  Строка
//
Функция БезЗнаковПрепинанияЛП(Знач СтрокаИсточник, ЗнакиПрепинания = ".,;")
	СтрокаИсточник = СокрЛП(СтрокаИсточник);
	Если СтрНайти(ЗнакиПрепинания, Лев(СтрокаИсточник, 1)) > 0 Тогда
		СтрокаИсточник = Сред(СтрокаИсточник, 2);
	КонецЕсли;
	Если СтрНайти(ЗнакиПрепинания, Прав(СтрокаИсточник, 1)) > 0 Тогда
		СтрокаИсточник = Лев(СтрокаИсточник, СтрДлина(СтрокаИсточник) - 1);
	КонецЕсли;
	Возврат СтрокаИсточник;
КонецФункции

// Возвращает результат запроса к БД
Функция СформироватьЗапрос()
	УстановитьПривилегированныйРежим(Истина);
	
	Запрос = Новый Запрос();
	Запрос.УстановитьПараметр("ДатаНачала",    	 НачалоДня(ДатаНач));
	Запрос.УстановитьПараметр("ДатаОкончания", 	 КонецДня(ДатаКон));
	Запрос.УстановитьПараметр("ОплатаНалога", 	 Перечисления.ВидыПлатежныхОпераций.ОплатаНалога);
	Запрос.УстановитьПараметр("ВыплатаДохода", 	 Перечисления.ВидыПлатежныхОпераций.ВыплатаДохода);
	Запрос.УстановитьПараметр("ОрганизацияПоУмолчанию", Константы.ОрганизацияПоУмолчанию.Получить());
	Запрос.УстановитьПараметр("Облигация",       Перечисления.ТипыЦБ.Облигация);
	Запрос.УстановитьПараметр("Государственная", Перечисления.ВидыОблигаций.Государственная);
	Запрос.УстановитьПараметр("ВалютаРегламентированногоУчета", Константы.ВалютаРегламентированногоУчета.Получить());
	Запрос.УстановитьПараметр("ПустаяВалюта",    Справочники.Валюты.ПустаяСсылка());
	Запрос.УстановитьПараметр("ДатаВводаПрогрШкалы", Константы.ДатаВводаРасчетаНДФЛПоПрогрессивнойШкале.Получить());
	ЗаполнитьПараметрыЗапросаПоОтборуСКД(Запрос);
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ЦБСписываемые.Ссылка КАК Поручение,
	|	СУММА(ЦБСписываемые.Количество) КАК Количество
	|ПОМЕСТИТЬ ВТ_Поручения
	|ИЗ
	|	Документ.Поручение.ЦенныеБумагиСписываемые КАК ЦБСписываемые
	|ГДЕ
	|	ЦБСписываемые.Ссылка.Проведен
	|	И ЦБСписываемые.ПлановаяДатаРасчетов МЕЖДУ &ДатаНачала И &ДатаОкончания
	|	И ВЫРАЗИТЬ(ЦБСписываемые.Ссылка.ВидОперацииД КАК Справочник.ВидыОпераций).ВыплатаДоходаВДенежнойФорме
	|	И &ОтборПорученийПоПоручению
	|	И &ВыводитьПоручения
	|
	|СГРУППИРОВАТЬ ПО
	|	ЦБСписываемые.Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЗамещающееПоручениеЦБСписываемые.Ссылка.Дата КАК Дата,
	|	0 КАК СуммаВыплаты,
	|	ЕСТЬNULL(ГОЦенныеБумаги.Ссылка.БанковскийСчет.ВалютаДенежныхСредств, ЗамещающееПоручениеЦБСписываемые.Ссылка.БанковскийСчет.ВалютаДенежныхСредств) КАК ВалютаВыплаты,
	|	ЕСТЬNULL(ГОЦенныеБумаги.ЦеннаяБумага, ЗамещающееПоручениеЦБСписываемые.ЦеннаяБумага) КАК ЦеннаяБумага,
	|	&ОрганизацияПоУмолчанию КАК ПлатежныйАгент,
	|	ЕСТЬNULL(ГОЦенныеБумаги.Ссылка.ВыплатаНа1ЦБ, ЗамещающееПоручениеЦБСписываемые.Ссылка.ВыплатаНа1ЦБ) КАК СуммаДоходаНа1ЦБ,
	|	ЕСТЬNULL(ГОЦенныеБумаги.Ссылка.СчетДепо, ЗамещающееПоручениеЦБСписываемые.СчетДепо) КАК СчетДепо,
	|	ЕСТЬNULL(ГОЦенныеБумаги.РазделСчетаДепо, ЗамещающееПоручениеЦБСписываемые.РазделСчетаДепо) КАК РазделСчетаДепо,
	|	ЕСТЬNULL(ГОЦенныеБумаги.Сумма, ЗамещающееПоручениеЦБСписываемые.Сумма) КАК Сумма,
	|	ЕСТЬNULL(ГОЦенныеБумаги.СуммаНалога, ЗамещающееПоручениеЦБСписываемые.СуммаНалога) КАК СуммаНалогаДокумента,
	|	0 КАК СуммаНедополученногоДохода,
	|	ЕСТЬNULL(ГОЦенныеБумаги.Ссылка.Комментарий, ЗамещающееПоручениеЦБСписываемые.Ссылка.Комментарий) КАК Комментарий,
	|	ЕСТЬNULL(ГОЦенныеБумаги.Ссылка, ЗамещающееПоручениеЦБСписываемые.Ссылка) КАК ДокументСсылка,
	|	ЕСТЬNULL(ГОЦенныеБумаги.Ссылка.ВидГлобальнойОперации, ЗамещающееПоручениеЦБСписываемые.Ссылка.ВидОперацииД) КАК НаименованиеВыплаты,
	|	ЕСТЬNULL(ГОЦенныеБумаги.Ссылка.ДатаФиксации, ЗамещающееПоручениеЦБСписываемые.Ссылка.ДатаФиксации) КАК ДатаФиксации,
	|	ЕСТЬNULL(ГОЦенныеБумаги.Количество, ЗамещающееПоручениеЦБСписываемые.Количество) КАК Количество,
	|	ЕСТЬNULL(ГОЦенныеБумаги.Ссылка.ДокументОснование, ЗамещающееПоручениеЦБСписываемые.Ссылка) КАК ОснованиеГОперации,
	|	ЕСТЬNULL(ГОЦенныеБумаги.Ссылка.ДокументОснование.Дата, ЗамещающееПоручениеЦБСписываемые.Ссылка.Дата) КАК ДатаОснования,
	|	ЗамещающееПоручениеЦБСписываемые.НДФЛУдержан КАК НДФЛУдержан,
	|	ЕСТЬNULL(ГОЦенныеБумаги.СуммаБезНалога, ВЫБОР
	|			КОГДА ЕСТЬNULL(ЗамещающееПоручениеЦБСписываемые.ЦеннаяБумага.ВидЦББанкаРоссии.ИностраннаяЦБ, ЛОЖЬ)
	|				ТОГДА ЗамещающееПоручениеЦБСписываемые.СуммаКВыплатеПоИПД
	|			ИНАЧЕ ЗамещающееПоручениеЦБСписываемые.Сумма - ЗамещающееПоручениеЦБСписываемые.СуммаНалога
	|		КОНЕЦ) КАК СуммаБезНалога,
	|	ЗамещающееПоручениеЦБСписываемые.Ссылка.Дата КАК ДатаПередачиДохода,
	|	ВЫРАЗИТЬ(&ВалютаРегламентированногоУчета КАК Справочник.Валюты) КАК ВалютаНалога,
	|	ЗамещающееПоручениеЦБСписываемые.СтавкаНалога КАК СтавкаНалогаДокумента,
	|	ВЫБОР
	|		КОГДА ЕСТЬNULL(ГОЦенныеБумаги.Ссылка.ДокументОснование.Дата, ЗамещающееПоручениеЦБСписываемые.Ссылка.Дата) >= &ДатаВводаПрогрШкалы
	|				И &ДатаВводаПрогрШкалы <> ДАТАВРЕМЯ(1, 1, 1)
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК ВведенаПрогрессивнаяШкала,
	|	ВЫБОР
	|		КОГДА ГОЦенныеБумаги.Ссылка ЕСТЬ NULL
	|			ТОГДА 2
	|		ИНАЧЕ 1
	|	КОНЕЦ КАК Порядок
	|ПОМЕСТИТЬ втДанные
	|ИЗ
	|	Документ.Поручение.ЦенныеБумагиСписываемые КАК ЗамещающееПоручениеЦБСписываемые
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ГлобальнаяОперация.ЦенныеБумаги КАК ГОЦенныеБумаги
	|		ПО ЗамещающееПоручениеЦБСписываемые.Ссылка = ГОЦенныеБумаги.Ссылка.ДокументОснование
	|			И ЗамещающееПоручениеЦБСписываемые.СчетДепо = ГОЦенныеБумаги.Ссылка.СчетДепо
	|			И ЗамещающееПоручениеЦБСписываемые.РазделСчетаДепо = ГОЦенныеБумаги.РазделСчетаДепо
	|			И (ГОЦенныеБумаги.Ссылка.Проведен)
	|			И (ГОЦенныеБумаги.Ссылка.Дата МЕЖДУ &ДатаНачала И &ДатаОкончания)
	|			И (ГОЦенныеБумаги.Ссылка.ВидГлобальнойОперации ССЫЛКА Справочник.ВидыОпераций)
	|			И (ГОЦенныеБумаги.Ссылка.ВидГлобальнойОперации.ВыплатаДоходаВДенежнойФорме)
	|			И (ГОЦенныеБумаги.ЦеннаяБумага.НФИ = 0)
	|			И (&ОтборГОперацийПоПлатежномуАгенту)
	|			И (&ОтборГОперацийПоЦеннойБумаге)
	|			И (&ОтборГОперацийПоПоручению)
	|			И (&ОтборГОперацийПоДепоненту)
	|ГДЕ
	|	ЗамещающееПоручениеЦБСписываемые.Ссылка.Проведен
	|	И ЗамещающееПоручениеЦБСписываемые.ПлановаяДатаРасчетов МЕЖДУ &ДатаНачала И &ДатаОкончания
	|	И ЗамещающееПоручениеЦБСписываемые.Ссылка.ВидОперацииД ССЫЛКА Справочник.ВидыОпераций
	|	И ЗамещающееПоручениеЦБСписываемые.Ссылка.ВидОперацииД.ВыплатаДоходаВДенежнойФорме
	|	И ЗамещающееПоручениеЦБСписываемые.ЦеннаяБумага.НФИ = 0
	|	И &ОтборЗамещающихПорученийПоПлатежномуАгенту
	|	И &ОтборЗамещающихПорученийПоЦеннойБумаге
	|	И &ОтборЗамещающихПорученийПоПоручению
	|	И &ОтборЗамещающихПорученийПоДепоненту
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ВТ_Поручения.Поручение.Дата,
	|	ВТ_Поручения.Поручение.СуммаИПД,
	|	ВТ_Поручения.Поручение.Валюта,
	|	ВТ_Поручения.Поручение.ЦБ,
	|	ВТ_Поручения.Поручение.ПлатежныйАгент,
	|	ВТ_Поручения.Поручение.ВыплатаНа1ЦБ,
	|	NULL,
	|	NULL,
	|	0,
	|	0,
	|	0,
	|	ВТ_Поручения.Поручение.Комментарий,
	|	ВТ_Поручения.Поручение,
	|	ВЫРАЗИТЬ(ВТ_Поручения.Поручение.ВидОперацииД КАК Справочник.ВидыОпераций),
	|	ВТ_Поручения.Поручение.ДатаФиксации,
	|	ВТ_Поручения.Количество,
	|	NULL,
	|	ВТ_Поручения.Поручение.Дата,
	|	ЛОЖЬ,
	|	0,
	|	ВТ_Поручения.Поручение.ДатаИсполненияПоручения,
	|	ВЫРАЗИТЬ(&ВалютаРегламентированногоУчета КАК Справочник.Валюты),
	|	0,
	|	ВЫБОР
	|		КОГДА ВТ_Поручения.Поручение.Дата >= &ДатаВводаПрогрШкалы
	|				И &ДатаВводаПрогрШкалы <> ДАТАВРЕМЯ(1, 1, 1)
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
