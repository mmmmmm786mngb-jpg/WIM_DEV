// ИНТЕРФЕЙС

Процедура СформироватьОтчет(Таблица) Экспорт
	РезультатЗапроса = СформироватьЗапрос();
	Если РезультатЗапроса.Пустой() Тогда
		Сообщение = Новый СообщениеПользователю();
		Сообщение.Текст = "Данные для формирования отчета не обнаружены!";
		Сообщение.Сообщить();
		Возврат;
	КонецЕсли;
	
	Макет = ПолучитьМакет("Отчет");
	ОбластьЗаголовок 		= Макет.ПолучитьОбласть("Заголовок");
	ОбластьШапкаОснование	= Макет.ПолучитьОбласть("Шапка|Основание");
	ОбластьШапкаОтчет		= Макет.ПолучитьОбласть("Шапка|Отчет");
	ОбластьСтрокаОснование	= Макет.ПолучитьОбласть("Строка|Основание");
	ОбластьСтрокаОтчет		= Макет.ПолучитьОбласть("Строка|Отчет");
	ОбластьПодвалОснование	= Макет.ПолучитьОбласть("Подвал|Основание");
	ОбластьПодвалОтчет		= Макет.ПолучитьОбласть("Подвал|Отчет");

	// ЗАГОЛОВОК
	СтруктураЗаголовка = СформироватьПараметрыШапкиМакета();
	ОбластьЗаголовок.Параметры.Заполнить(СтруктураЗаголовка);
	Таблица.Вывести(ОбластьЗаголовок);
	
	// ШАПКА
	ОбластьШапкаОтчет.Параметры.Организация = СокрЛП(ОбщегоНазначенияПовтИсп.ОрганизацияПоУмолчанию().ЮридическоеЛицо.Наименование);
	Если ПоказыватьДокументОснование Тогда
		Таблица.Вывести(ОбластьШапкаОснование);
		Таблица.Присоединить(ОбластьШапкаОтчет);
	Иначе
		Таблица.Вывести(ОбластьШапкаОтчет);
	КонецЕсли;
	
	Выборка = РезультатЗапроса.Выбрать();
	Пока Выборка.Следующий() Цикл
		// СТРОКА ОТЧЕТА
		ОчиститьЗначенияПараметровМакета(ОбластьСтрокаОтчет.Параметры);
		// Заполнение параметров строки
		ЗаполнитьЗначенияСвойств(ОбластьСтрокаОтчет.Параметры, Выборка);
		Если Выборка.ВведенаПрогрессивнаяШкала Тогда
			ДополнитьКомментарий(ОбластьСтрокаОтчет.Параметры, Выборка);
		КонецЕсли;
		
		СкорректироватьВалютуНалога(ОбластьСтрокаОтчет.Параметры, Выборка);
		
		Если ПоказыватьДокументОснование Тогда
			ОчиститьЗначенияПараметровМакета(ОбластьСтрокаОснование.Параметры);
			ЗаполнитьЗначенияСвойств(ОбластьСтрокаОснование.Параметры, Выборка);
			Таблица.Вывести(ОбластьСтрокаОснование);
			Таблица.Присоединить(ОбластьСтрокаОтчет);
		Иначе
			Таблица.Вывести(ОбластьСтрокаОтчет);
		КонецЕсли;
	КонецЦикла;
	
	// ПОДВАЛ ОТЧЕТА
	Если ПоказыватьДокументОснование Тогда
		Таблица.Вывести(ОбластьПодвалОснование);
		Таблица.Присоединить(ОбластьПодвалОтчет);
	Иначе
		Таблица.Вывести(ОбластьПодвалОтчет);
	КонецЕсли;
	
	// Установим ширину для колонок
	Если ПоказыватьДокументОснование Тогда
		УстановитьШиринуКолонки(Таблица, 0, 28);	// Документ-основание
	КонецЕсли;
	
	УстановитьШиринуКолонки(Таблица, 1, 10);	// Дата получения дохода на СДС
	УстановитьШиринуКолонки(Таблица, 3, 8);		// Валюта выплаты
	УстановитьШиринуКолонки(Таблица, 4, 50);	// Полное наименование эмитента /Номер гос.регистрации или ISIN ЦБ
	УстановитьШиринуКолонки(Таблица, 5, 18);	// Наименование плательщика
	УстановитьШиринуКолонки(Таблица, 6, 18);	// Сумма дохода на 1 ЦБ
	УстановитьШиринуКолонки(Таблица, 7, 11);	// Номер счета ДЕПО
	УстановитьШиринуКолонки(Таблица, 8, 15);	// Количество ЦБ на дату фиксации
	УстановитьШиринуКолонки(Таблица, 10, 11);	// Дата фиксации для выплаты дохода
	УстановитьШиринуКолонки(Таблица, 19, 12);	// Дата передачи депоненту дохода / возврата
	УстановитьШиринуКолонки(Таблица, 24, 45);	// Комментарий
КонецПроцедуры

