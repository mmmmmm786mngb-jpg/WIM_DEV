// Процедура выполняет замену ключей текста запроса на корректный текст компиляции
Процедура ВыполнитьОбработкуИЗаменуТекстаЗапроса(Запрос)
	ЗаменяемыеСтроки = Новый Соответствие;
	
	Отбор = ОтборПоПлатежномуАгенту(Запрос.Параметры);
	ЗаменяемыеСтроки.Вставить("&ОтборГОперацийПоПлатежномуАгенту", Отбор.ГОперации);
	ЗаменяемыеСтроки.Вставить("&ОтборЗамещающихПорученийПоПлатежномуАгенту", Отбор.ЗамещающиеПоручения);
	ЗаменяемыеСтроки.Вставить("&ОтборПорученийПоПлатежномуАгенту", Отбор.Поручения);
	
	Отбор = ОтборПоЦеннойБумаге(Запрос.Параметры);
	ЗаменяемыеСтроки.Вставить("&ОтборГОперацийПоЦеннойБумаге", Отбор.ГОперации);
	ЗаменяемыеСтроки.Вставить("&ОтборЗамещающихПорученийПоЦеннойБумаге", Отбор.ЗамещающиеПоручения);
	ЗаменяемыеСтроки.Вставить("&ОтборПорученийПоЦеннойБумаге", Отбор.Поручения);
	
	Отбор = ОтборПоПоручению(Запрос.Параметры);
	ЗаменяемыеСтроки.Вставить("&ОтборГОперацийПоПоручению", Отбор.ГОперации);
	ЗаменяемыеСтроки.Вставить("&ОтборЗамещающихПорученийПоПоручению", Отбор.ЗамещающиеПоручения);
	ЗаменяемыеСтроки.Вставить("&ОтборПорученийПоПоручению", Отбор.Поручения);
	
	Отбор = ОтборПоДепоненту(Запрос.Параметры);
	ЗаменяемыеСтроки.Вставить("&ОтборГОперацийПоДепоненту", Отбор.ГОперации);
	ЗаменяемыеСтроки.Вставить("&ОтборЗамещающихПорученийПоДепоненту", Отбор.ЗамещающиеПоручения);
	ЗаменяемыеСтроки.Вставить("&ВыводитьПоручения", Отбор.Поручения);
	
	Для Каждого КлючИЗначение Из ЗаменяемыеСтроки Цикл
		Запрос.Текст = СтрЗаменить(Запрос.Текст, КлючИЗначение.Ключ, КлючИЗначение.Значение);
	КонецЦикла;
КонецПроцедуры

