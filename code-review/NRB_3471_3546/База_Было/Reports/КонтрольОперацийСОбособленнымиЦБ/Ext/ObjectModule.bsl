#Область ПрограммныйИнтерфейс

// BSLLS:MethodSize-off
// Функция возвращает таблицу значений с данными которые необходимо поместить в отчет
// Параметры:
//	Ошибки - Строка
// Возвращаемое значение:
//	- ТаблицаЗначений
Функция ДанныеДляЗаполнения(Ошибки = "") Экспорт
	ВремяНачалаЗамера = ОценкаПроизводительности.НачатьЗамерВремени();
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	// Помните, что как ни удивительно, в справочнике контрагентов ЛОЖЬ реквизите НеРезидент означает, 
	// что это нерезидент по документам и наоборот ИСТИНА - что резидент.
	"ВЫБРАТЬ
	|	НАЧАЛОПЕРИОДА(ОстаткиЦБ.Период, ДЕНЬ) КАК ДатаОперации,
	|	ОстаткиЦБ.Регистратор КАК Регистратор,
	|	ОстаткиЦБ.НомерСтроки КАК НомерСтроки,
	|	ОстаткиЦБ.СчетДепо КАК СчетДепо,
	|	ОстаткиЦБ.РазделСчетаДепо КАК РазделСчетаДепо,
	|	ОстаткиЦБ.ЦБ КАК ЦБ,
	|	ОстаткиЦБ.Количество КАК Количество,
	|	ОстаткиЦБ.ВидДвижения КАК ВидДвижения
	|ПОМЕСТИТЬ ВТ_Операции
	|ИЗ
	|	РегистрНакопления.ОстаткиЦБ КАК ОстаткиЦБ
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.РазделыСчетаДепо КАК РазделыСчетаДепо
	|		ПО ОстаткиЦБ.РазделСчетаДепо = РазделыСчетаДепо.Ссылка
	|ГДЕ
	|	ОстаткиЦБ.Период МЕЖДУ &ПериодНачало И &ПериодКонец
	|	И РазделыСчетаДепо.ТипРазделаСчетаДЕПО В(&ТипыОбособленныхРазделов)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_Операции.СчетДепо КАК СчетДепо,
	|	ВТ_Операции.ДатаОперации КАК ДатаОперации
	|ПОМЕСТИТЬ ВТ_ДатыОперацийПоСчетамДепо
	|ИЗ
	|	ВТ_Операции КАК ВТ_Операции
	|
	|СГРУППИРОВАТЬ ПО
	|	ВТ_Операции.СчетДепо,
	|	ВТ_Операции.ДатаОперации
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_ДатыОперацийПоСчетамДепо.СчетДепо КАК СчетДепо
	|ПОМЕСТИТЬ ВТ_СчетаДепо
	|ИЗ
	|	ВТ_ДатыОперацийПоСчетамДепо КАК ВТ_ДатыОперацийПоСчетамДепо
	|
	|СГРУППИРОВАТЬ ПО
	|	ВТ_ДатыОперацийПоСчетамДепо.СчетДепо
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_СчетаДепо.СчетДепо КАК СчетДепо,
	|	СчетаДепо.Владелец КАК Депонент,
	|	Контрагенты.ЮридическиеФизическиеЛица КАК ЮрФизЛицо,
	|	ВЫБОР
	|		КОГДА Контрагенты.Резидент
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК НерезидентПоДокументам,
	|	Контрагенты.УправляющаяКомпания КАК УправляющаяКомпания,
	|	Контрагенты.Субброкер КАК Субброкер,
	|	ВЫБОР
	|		КОГДА НЕ ЮридическиеЛица.ИНН ЕСТЬ NULL
	|				И ЮридическиеЛица.ИНН <> """"
	|			ТОГДА ЮридическиеЛица.ИНН
	|		КОГДА НЕ ЮридическиеЛица.TIN ЕСТЬ NULL
	|				И ЮридическиеЛица.TIN <> """"
	|			ТОГДА ЮридическиеЛица.TIN
	|		КОГДА НЕ ФизическиеЛица.ИНН ЕСТЬ NULL
	|				И ФизическиеЛица.ИНН <> """"
	|			ТОГДА ФизическиеЛица.ИНН
	|		ИНАЧЕ ""-""
	|	КОНЕЦ КАК ИНН,
	|	ВЫБОР
	|		КОГДА НЕ ЮридическиеЛица.Ссылка ЕСТЬ NULL
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК ЭтоЮЛ,
	|	ВЫБОР
	|		КОГДА НЕ ФизическиеЛица.Ссылка ЕСТЬ NULL
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК ЭтоФЛ
	|ПОМЕСТИТЬ ВТ_Депоненты
	|ИЗ
	|	ВТ_СчетаДепо КАК ВТ_СчетаДепо
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.СчетаДепо КАК СчетаДепо
	|		ПО ВТ_СчетаДепо.СчетДепо = СчетаДепо.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Контрагенты КАК Контрагенты
	|		ПО (СчетаДепо.Владелец = Контрагенты.Ссылка)
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ФизическиеЛица КАК ФизическиеЛица
	|		ПО (Контрагенты.ЮридическиеФизическиеЛица = ФизическиеЛица.Ссылка)
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ЮридическиеЛица КАК ЮридическиеЛица
	|		ПО (Контрагенты.ЮридическиеФизическиеЛица = ЮридическиеЛица.Ссылка)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_Депоненты.ЮрФизЛицо КАК ЮрФизЛицо,
	|	ВТ_ДатыОперацийПоСчетамДепо.ДатаОперации КАК ДатаОперации,
	|	МАКСИМУМ(КатегорииРолейКлиентовСогласноУказов81и95.Период) КАК Период
	|ПОМЕСТИТЬ ВТ_ПериодКатегорииПоДатеОперации
	|ИЗ
	|	ВТ_ДатыОперацийПоСчетамДепо КАК ВТ_ДатыОперацийПоСчетамДепо
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_Депоненты КАК ВТ_Депоненты
	|		ПО ВТ_ДатыОперацийПоСчетамДепо.СчетДепо = ВТ_Депоненты.СчетДепо
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.КатегорииРолейКлиентовСогласноУказов81и95 КАК КатегорииРолейКлиентовСогласноУказов81и95
	|		ПО (ВТ_Депоненты.ЮрФизЛицо = КатегорииРолейКлиентовСогласноУказов81и95.ЮрФизЛицо)
	|			И (КатегорииРолейКлиентовСогласноУказов81и95.Период <= ВТ_ДатыОперацийПоСчетамДепо.ДатаОперации)
	|
	|СГРУППИРОВАТЬ ПО
	|	ВТ_Депоненты.ЮрФизЛицо,
	|	ВТ_ДатыОперацийПоСчетамДепо.ДатаОперации
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_ПериодКатегорииПоДатеОперации.ЮрФизЛицо КАК ЮрФизЛицо,
	|	ВТ_ПериодКатегорииПоДатеОперации.ДатаОперации КАК ДатаОперации,
	|	КатегорииРолейКлиентовСогласноУказов81и95.КатегорияРоли.Код КАК КатегорияРоли
	|ПОМЕСТИТЬ ВТ_КатегорииРолейКлиентовНаДатыОпераций
	|ИЗ
	|	ВТ_ПериодКатегорииПоДатеОперации КАК ВТ_ПериодКатегорииПоДатеОперации
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.КатегорииРолейКлиентовСогласноУказов81и95 КАК КатегорииРолейКлиентовСогласноУказов81и95
	|		ПО ВТ_ПериодКатегорииПоДатеОперации.ЮрФизЛицо = КатегорииРолейКлиентовСогласноУказов81и95.ЮрФизЛицо
	|			И ВТ_ПериодКатегорииПоДатеОперации.Период = КатегорииРолейКлиентовСогласноУказов81и95.Период
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_Депоненты.ЮрФизЛицо КАК ЮрЛицо,
	|	ВТ_ДатыОперацийПоСчетамДепо.ДатаОперации КАК ДатаОперации,
	|	МАКСИМУМ(ЮридическиеЛицаМеждународныеКомпании.Период) КАК Период
	|ПОМЕСТИТЬ ВТ_ПериодМКПоДатеОперации
	|ИЗ
	|	ВТ_ДатыОперацийПоСчетамДепо КАК ВТ_ДатыОперацийПоСчетамДепо
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_Депоненты КАК ВТ_Депоненты
	|		ПО ВТ_ДатыОперацийПоСчетамДепо.СчетДепо = ВТ_Депоненты.СчетДепо
	|			И (ВТ_Депоненты.ЭтоЮЛ)
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ЮридическиеЛицаМеждународныеКомпании КАК ЮридическиеЛицаМеждународныеКомпании
	|		ПО (ВТ_Депоненты.ЮрФизЛицо = ЮридическиеЛицаМеждународныеКомпании.ЮридическоеЛицо)
	|			И (ЮридическиеЛицаМеждународныеКомпании.Период <= ВТ_ДатыОперацийПоСчетамДепо.ДатаОперации)
	|
	|СГРУППИРОВАТЬ ПО
	|	ВТ_Депоненты.ЮрФизЛицо,
	|	ВТ_ДатыОперацийПоСчетамДепо.ДатаОперации
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_ПериодМКПоДатеОперации.ЮрЛицо КАК ЮрЛицо,
	|	ВТ_ПериодМКПоДатеОперации.ДатаОперации КАК ДатаОперации,
	|	ЮридическиеЛицаМеждународныеКомпании.МеждународнаяКомпания КАК ЭтоМК
	|ПОМЕСТИТЬ ВТ_МеждународныеКомпанииНаДатыОпераций
	|ИЗ
	|	ВТ_ПериодМКПоДатеОперации КАК ВТ_ПериодМКПоДатеОперации
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ЮридическиеЛицаМеждународныеКомпании КАК ЮридическиеЛицаМеждународныеКомпании
	|		ПО ВТ_ПериодМКПоДатеОперации.ЮрЛицо = ЮридическиеЛицаМеждународныеКомпании.ЮридическоеЛицо
	|			И ВТ_ПериодМКПоДатеОперации.Период = ЮридическиеЛицаМеждународныеКомпании.Период
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_Депоненты.Депонент КАК Клиент,
	|	ВТ_ДатыОперацийПоСчетамДепо.ДатаОперации КАК ДатаОперации,
	|	МАКСИМУМ(КлиентыСУчетомНаСчетахТипаC.Период) КАК Период
	|ПОМЕСТИТЬ ВТ_ПериодПоДатеОперацииДляСчетовТипаC
	|ИЗ
	|	ВТ_ДатыОперацийПоСчетамДепо КАК ВТ_ДатыОперацийПоСчетамДепо
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_Депоненты КАК ВТ_Депоненты
	|		ПО ВТ_ДатыОперацийПоСчетамДепо.СчетДепо = ВТ_Депоненты.СчетДепо
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.КлиентыСУчетомНаСчетахТипаC КАК КлиентыСУчетомНаСчетахТипаC
	|		ПО (ВТ_Депоненты.Депонент = КлиентыСУчетомНаСчетахТипаC.Клиент)
	|			И (КлиентыСУчетомНаСчетахТипаC.Период <= ВТ_ДатыОперацийПоСчетамДепо.ДатаОперации)
	|
	|СГРУППИРОВАТЬ ПО
	|	ВТ_Депоненты.Депонент,
	|	ВТ_ДатыОперацийПоСчетамДепо.ДатаОперации
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_ПериодПоДатеОперацииДляСчетовТипаC.Клиент КАК Клиент,
	|	ВТ_ПериодПоДатеОперацииДляСчетовТипаC.ДатаОперации КАК ДатаОперации,
	|	КлиентыСУчетомНаСчетахТипаC.ФлагАктивности КАК ИмеетСчетаТипаC
	|ПОМЕСТИТЬ ВТ_СчетаТипаC
	|ИЗ
	|	ВТ_ПериодПоДатеОперацииДляСчетовТипаC КАК ВТ_ПериодПоДатеОперацииДляСчетовТипаC
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.КлиентыСУчетомНаСчетахТипаC КАК КлиентыСУчетомНаСчетахТипаC
	|		ПО ВТ_ПериодПоДатеОперацииДляСчетовТипаC.Клиент = КлиентыСУчетомНаСчетахТипаC.Клиент
	|			И ВТ_ПериодПоДатеОперацииДляСчетовТипаC.Период = КлиентыСУчетомНаСчетахТипаC.Период
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	КлассификаторДляОтчетовВидыСчетовДЕПОСрезПоследних.ТипСчета1С КАК ТипСчета1С,
	|	КлассификаторДляОтчетовВидыСчетовДЕПОСрезПоследних.ВидСчетаДляОтчета КАК ВидСчетаДляОтчета,
	|	КлассификаторДляОтчетовВидыСчетовДЕПОСрезПоследних.ВидСчетаДляОтчетаКлиентаТипаC КАК ВидСчетаДляОтчетаКлиентаТипаC
	|ПОМЕСТИТЬ ВТ_КлассификаторДляОтчетовВидыСчетовДЕПО
	|ИЗ
	|	РегистрСведений.КлассификаторДляОтчетовВидыСчетовДЕПО.СрезПоследних(&ПериодКонец, 1 = 1) КАК КлассификаторДляОтчетовВидыСчетовДЕПОСрезПоследних
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_Операции.Регистратор КАК Регистратор
	|ПОМЕСТИТЬ ВТ_Регистраторы
	|ИЗ
	|	ВТ_Операции КАК ВТ_Операции
	|
	|СГРУППИРОВАТЬ ПО
	|	ВТ_Операции.Регистратор
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ОрганизацияПоУмолчанию.Значение КАК Организация,
	|	Организации.Наименование КАК Наименование,
	|	Организации.ИНН КАК ИНН
	|ПОМЕСТИТЬ ВТ_ОрганизацияПоУмолчанию
	|ИЗ
	|	Константа.ОрганизацияПоУмолчанию КАК ОрганизацияПоУмолчанию
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Организации КАК Организации
	|		ПО ОрганизацияПоУмолчанию.Значение = Организации.Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_Операции.Регистратор КАК Регистратор,
	|	ВТ_Операции.НомерСтроки КАК НомерСтроки,
	|	ЕСТЬNULL(ОперацииЦБ.ВидОперацииД, ГлобальнаяОперация.ВидГлобальнойОперации) КАК ВидОперации,
	|	Поручение.ОснованиеОперацииДКУ КАК ПоручениеОснованиеОперацииДКУ,
	|	Поручение.ТипСвертки КАК ПоручениеТипСвертки,
	|	ВЫБОР
	|		КОГДА ВТ_Операции.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход)
	|				И (ВТ_Операции.Регистратор ССЫЛКА Документ.ОперацииЦБ
	|						И ОперацииЦБ.ВидОперацииД <> ЗНАЧЕНИЕ(Справочник.ВидыОпераций.Перевод)
	|					ИЛИ ВТ_Операции.Регистратор ССЫЛКА Документ.ГлобальнаяОперация)
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК ЭтоСписание,
	|	ВЫБОР
	|		КОГДА ВТ_Операции.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход)
	|				И ВТ_Операции.Регистратор ССЫЛКА Документ.ОперацииЦБ
	|				И ОперацииЦБ.ВидОперацииД <> ЗНАЧЕНИЕ(Справочник.ВидыОпераций.Перевод)
	|				И Поручение.ТипСвертки = ЗНАЧЕНИЕ(Перечисление.ТипыСверток.ПоСделке)
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК ЭтоПередачаЦБ_КОПоУказу138,
	|	ОперацииЦБКонтрагенты.ЮридическиеФизическиеЛица КАК КонтрагентЛицо,
	|	ЕСТЬNULL(КонтрагентыЮридическиеЛица.Наименование, КонтрагентыФизическиеЛица.Наименование) КАК КонтрагентЛицоНаименование,
	|	ЕСТЬNULL(КонтрагентыЮридическиеЛица.ИНН, КонтрагентыФизическиеЛица.ИНН) КАК КонтрагентЛицоИНН,
	|	ЕСТЬNULL(КонтрагентыЮридическиеЛица.TIN, """") КАК КонтрагентЮрЛицоTIN
	|ПОМЕСТИТЬ ВТ_ДанныеРегистраторов
	|ИЗ
	|	ВТ_Операции КАК ВТ_Операции
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ОперацииЦБ КАК ОперацииЦБ
	|		ПО ВТ_Операции.Регистратор = ОперацииЦБ.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ГлобальнаяОперация КАК ГлобальнаяОперация
	|		ПО ВТ_Операции.Регистратор = ГлобальнаяОперация.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ОрганизацияПоУмолчанию КАК ВТ_ОрганизацияПоУмолчанию
	|		ПО (ИСТИНА)
