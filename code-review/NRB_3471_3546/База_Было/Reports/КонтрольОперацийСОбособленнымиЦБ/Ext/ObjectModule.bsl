	|		ПО ВТ_Операции.Регистратор = ВТ_ДанныеРегистраторов.Регистратор
	|			И ВТ_Операции.НомерСтроки = ВТ_ДанныеРегистраторов.НомерСтроки
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Контрагенты КАК КонтрагентыЭмитенты
	|		ПО (СправочникЦенныеБумаги.Эмитент = КонтрагентыЭмитенты.Ссылка)
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ЮридическиеЛица КАК ЮрЛицаЭмитенты
	|		ПО (КонтрагентыЭмитенты.ЮридическиеФизическиеЛица = ЮрЛицаЭмитенты.Ссылка)";
	Запрос.УстановитьПараметр("ПериодНачало", ПериодНачало);
	Запрос.УстановитьПараметр("ПериодКонец", КонецДня(ПериодКонец));
	ТипыОбособленныхРазделов = Новый Массив;
	ТипыОбособленныхРазделов.Добавить(Перечисления.ТипыРазделовСчетовДЕПО.БлокированоОбособленный);
	ТипыОбособленныхРазделов.Добавить(Перечисления.ТипыРазделовСчетовДЕПО.БлокированоОбособленныйПоПредписаниямБР);
	Запрос.УстановитьПараметр("ТипыОбособленныхРазделов", ТипыОбособленныхРазделов);
	
	ТаблицаДанных = Запрос.Выполнить().Выгрузить();
	
	ПроверитьДанные(ТаблицаДанных, Ошибки);
	ОценкаПроизводительности.ЗакончитьЗамерВремени("КонтрольОперацийСОбособленнымиЦБ.ПолучениеДанныхДляОтчета", ВремяНачалаЗамера);
	
	Возврат ТаблицаДанных; 
КонецФункции
// BSLLS:MethodSize-on

// Процедура заполняет табличный документ на основании данных для заполнения отчета
// Параметры:
//  ТабДок - ТабличныйДокумент
//  ДанныеДляЗаполнения - ТаблицаЗначений
Процедура ЗаполнитьОтчет(ТабДок, ДанныеДляЗаполнения) Экспорт
	ТабДок.Очистить();
	
	Макет = ПолучитьМакет("Макет");
	
	ОбластьШапка = Макет.ПолучитьОбласть("ОбластьШапка");
	ОбластьСтрокаОтчета = Макет.ПолучитьОбласть("ОбластьСтрокаОтчета");
	ОбластьПодвал = Макет.ПолучитьОбласть("ОбластьПодвал");
	
	ТабДок.Вывести(ОбластьШапка);
	Для Каждого СтрокаДанных Из ДанныеДляЗаполнения Цикл
		ОбластьСтрокаОтчета.Параметры.Заполнить(СтрокаДанных);
		ТабДок.Вывести(ОбластьСтрокаОтчета);
	КонецЦикла;
	ТабДок.Вывести(ОбластьПодвал);
	
	ТабДок.ФиксацияСверху = 4;
КонецПроцедуры

#КонецОбласти


#Область СлужебныеПроцедурыИФункции

Процедура ПроверитьДанные(ТаблицаДанных, Ошибки)
	НомерСтроки = 0;
	Для Каждого СтрокаТЗ Из ТаблицаДанных Цикл
		НомерСтроки = НомерСтроки + 1;
		Если Не ЗначениеЗаполнено(СтрокаТЗ.КатегорияДепонента) Тогда
			ОписаниеОшибки = "Не заполнена категория депонента в 5-й колонке";
			Если СтрокаТЗ.КатегорияРоли = Null Тогда
				ОписаниеОшибки = ОписаниеОшибки
								+ " (вероятная причина - для лица депонента не указана категория роли клиента согласно Указов №81 и №95)";
			КонецЕсли;
			ДобавитьВОшибки(Ошибки, ОписаниеОшибки, НомерСтроки, СтрокаТЗ);
		КонецЕсли;
		Если Не ЗначениеЗаполнено(СтрокаТЗ.ВидСчетаДепо) Тогда
			ОписаниеОшибки = "Не заполнен Вид счета Депо в 7-й колонке";
			ДобавитьВОшибки(Ошибки, ОписаниеОшибки, НомерСтроки, СтрокаТЗ);
		КонецЕсли;
		Если Не ЗначениеЗаполнено(СтрокаТЗ.ТипОперации) Тогда
			ОписаниеОшибки = "Не заполнен Тип операции в 9-й колонке";
			ДобавитьВОшибки(Ошибки, ОписаниеОшибки, НомерСтроки, СтрокаТЗ);
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

Процедура ДобавитьВОшибки(Ошибки, ОписаниеОшибки, НомерСтроки, Данные)
	ИдентификаторСтроки = "строка " + Строка(НомерСтроки) + " депонент " + Строка(Данные.ЮрФизЛицо) 
							+ " (идентификатор:" + Данные.ИдентификаторДепонента + ") за "
							+ Формат(Данные.ДатаОперации, "ДФ=""дд.ММ.гггг""");
	ОписаниеОшибки = ОписаниеОшибки + ", " + ИдентификаторСтроки;
	СтроковыеФункцииКлиентСервер.ДополнитьТекстСтрокой(Ошибки, ОписаниеОшибки);
	ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ОписаниеОшибки);
КонецПроцедуры

#КонецОбласти


#Область Инициализация

ОбщегоНазначения.ЛогироватьИспользованиеОбъекта(ЭтотОбъект);

#КонецОбласти