
//Выборка ЦБ из регистра ОстаткиЦБ на Дату.
//
//Параметры:
//     БезПараметров
//
//Результат:
//	ТаблицаЗначений -  выборка из запроса.
Функция ВыборкаЦБНаДату() Экспорт
	
Запрос = Новый Запрос;
Запрос.Текст = "ВЫБРАТЬ
               |	Котировки.ЦеннаяБумага,
               |	МАКСИМУМ(Котировки.Период) КАК Период
               |ПОМЕСТИТЬ ВремяКотировок
               |ИЗ
               |	РегистрСведений.Котировки КАК Котировки
               |ГДЕ
               |	Котировки.РежимТоргов.РежимТоргов = ЗНАЧЕНИЕ(Перечисление.РежимыТоргов.Рыночная)
               |	И Котировки.Период <= &ОтчетнаяДата
               |	И Котировки.РежимТоргов.Код <> ""SMAL""
               |	И Котировки.РежимТоргов.Код <> ""EQCC""
			   |	И Котировки.РежимТоргов.Код <> ""TQNL""
			   |	И Котировки.РежимТоргов.Код <> ""TQOB""
			   |	И Котировки.РежимТоргов.Код <> ""TQBS""
			   |	И Котировки.РежимТоргов.Код <> ""TQNE""
			   |	И Котировки.РежимТоргов.Код <> ""TQLV""
			   |	И Котировки.РежимТоргов.Код <> ""TQBR""
               |	И Котировки."+СокрЛП(Котировка)+" <> 0
               |
               |СГРУППИРОВАТЬ ПО
               |	Котировки.ЦеннаяБумага
               |;
               |
               |////////////////////////////////////////////////////////////////////////////////
               |ВЫБРАТЬ
               |	КатегорияЦБ.ЦеннаяБумага,
               |	МАКСИМУМ(КатегорияЦБ.Период) КАК Период
               |ПОМЕСТИТЬ ВремяКатегорий
               |ИЗ
               |	РегистрСведений.КатегорияЦБ КАК КатегорияЦБ
               |ГДЕ
               |	КатегорияЦБ.Период <= &ОтчетнаяДата
               |
               |СГРУППИРОВАТЬ ПО
               |	КатегорияЦБ.ЦеннаяБумага
               |;
               |
               |////////////////////////////////////////////////////////////////////////////////
               |ВЫБРАТЬ
               |	ОстаткиЦБОстатки.ЦБ.ТипЦБ КАК ЦБТипЦБ,
               |	ОстаткиЦБОстатки.ЦБ.Эмитент КАК ЦБЭмитент,
               |	ОстаткиЦБОстатки.ЦБ КАК ЦБ,
               |	ЕСТЬNULL(ОстаткиЦБОстатки.ЦБ.НомерРегистрации, """") КАК НомерРегистрации,
               |	ЕСТЬNULL(ОстаткиЦБОстатки.ЦБ.ISIN, """") КАК ISIN,
               |	ЕСТЬNULL(ОстаткиЦБОстатки.ЦБ.ВидЦБ, """") КАК ВидЦБ,
               |	ЕСТЬNULL(КатегорияЦБСрезПоследних.Категория, """") КАК Категория,
               |	ЕСТЬNULL(ОстаткиЦБОстатки.ЦБ.ОбъемРазмещения, 0) КАК ОбъемРазмещения,
               |	ОстаткиЦБОстатки.СтатусЦБ КАК СтатусЦБ,
               |	ОстаткиЦБОстатки.КоличествоОстаток КАК КоличествоВсего,
               |	ВЫБОР
               |		КОГДА ОстаткиЦБОстатки.СтатусЦБ = &Залог
               |			ТОГДА ОстаткиЦБОстатки.КоличествоОстаток
               |		ИНАЧЕ 0
               |	КОНЕЦ КАК КоличествоЗалог,
               |	ВЫБОР
               |		КОГДА ОстаткиЦБОстатки.СтатусЦБ = &Свободна
               |				И ОстаткиЦБОстатки.СчетДепо.ТипСчетаДепо = &ДУ
			   |				ИЛИ ОстаткиЦБОстатки.СчетДепо.ТипСчетаДепо = &ДУТ
               |			ТОГДА ОстаткиЦБОстатки.КоличествоОстаток
               |		ИНАЧЕ 0
               |	КОНЕЦ КАК КоличествоДУ,
               |	ВЫБОР
               |		КОГДА ОстаткиЦБОстатки.СтатусЦБ = &Обременена
               |			ТОГДА ОстаткиЦБОстатки.КоличествоОстаток
               |		ИНАЧЕ 0
               |	КОНЕЦ КАК КоличествоОбремененных,
               |	ВЫБОР
               |		КОГДА ОстаткиЦБОстатки.СчетДепо.Владелец = &БезПренадлежности
               |			ТОГДА ОстаткиЦБОстатки.КоличествоОстаток
               |		ИНАЧЕ 0
               |	КОНЕЦ КАК КоличествоБезПренадлежности,
               |	(IsNull(КотировкиСрезПоследних."+Котировка+",0)+IsNull(КотировкиСрезПоследних.NKD,0)) * ОстаткиЦБОстатки.КоличествоОстаток КАК РыночнаяСтоимость
               |ИЗ
               |	РегистрНакопления.ОстаткиЦБ.Остатки(&ОтчетнаяДата, ) КАК ОстаткиЦБОстатки
               |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.Котировки.СрезПоследних(&ОтчетнаяДата, РежимТоргов.РежимТоргов = ЗНАЧЕНИЕ(Перечисление.РежимыТоргов.Рыночная) И РежимТоргов.Код <> ""SMAL"" И РежимТоргов.Код <> ""EQCC"" И РежимТоргов.Код <> ""TQNL"" И РежимТоргов.Код <> ""TQOB"" И РежимТоргов.Код <> ""TQBS"" И РежимТоргов.Код <> ""TQNE"" И РежимТоргов.Код <> ""TQLV"" И РежимТоргов.Код <> ""TQBR"" и "+СокрЛП(Котировка)+" <> 0) КАК КотировкиСрезПоследних
               |			ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВремяКотировок КАК ВремяКотировок
               |			ПО КотировкиСрезПоследних.ЦеннаяБумага = ВремяКотировок.ЦеннаяБумага
               |				И КотировкиСрезПоследних.Период = ВремяКотировок.Период
               |		ПО ОстаткиЦБОстатки.ЦБ = КотировкиСрезПоследних.ЦеннаяБумага
               |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.КатегорияЦБ.СрезПоследних(&ОтчетнаяДата, ) КАК КатегорияЦБСрезПоследних
               |			ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВремяКатегорий КАК ВремяКатегорий
               |			ПО КатегорияЦБСрезПоследних.ЦеннаяБумага = ВремяКатегорий.ЦеннаяБумага
               |				И КатегорияЦБСрезПоследних.Период = ВремяКатегорий.Период
               |		ПО ОстаткиЦБОстатки.ЦБ = КатегорияЦБСрезПоследних.ЦеннаяБумага
               |ИТОГИ
               |	СУММА(КоличествоВсего),
               |	СУММА(КоличествоЗалог),
               |	СУММА(КоличествоДУ),
               |	СУММА(КоличествоОбремененных),
               |	СУММА(КоличествоБезПренадлежности),
               |	СУММА(РыночнаяСтоимость)
               |ПО
               |	ЦБТипЦБ,
               |	ЦБЭмитент,
               |	ЦБ,
               |	Категория";
//"+Котировка+" // Average
Запрос.УстановитьПараметр("Залог",Перечисления.СтатусыЦБ.Заложена );
Запрос.УстановитьПараметр("Свободна",Перечисления.СтатусыЦБ.Свободна);
Запрос.УстановитьПараметр("ДУ", Перечисления.ТипыСчетовДепо.ДоверительногоУправляющего);
Запрос.УстановитьПараметр("ДУТ", Перечисления.ТипыСчетовДепо.ДоверительногоУправляющегоТорговый);
Запрос.УстановитьПараметр("Обременена",Перечисления.СтатусыЦБ.Обременена);
Запрос.УстановитьПараметр("БезПренадлежности", Справочники.Контрагенты.НеОпределенныйДепонент);
Запрос.УстановитьПараметр("ОтчетнаяДата",КонецДня(ДатаОтчета));
Запрос.УстановитьПараметр("Биржа", Биржа);
Запрос.УстановитьПараметр("РежимТоргов", РежимТоргов );

Результат 	= Запрос.Выполнить();

Возврат Результат;

КонецФункции	

&НаСервере
Процедура СформироватьОтчет(ТабличныйДокумент) Экспорт
	
	РезультатЗапроса = ВыборкаЦБНаДату();
	Если РезультатЗапроса.Пустой() Тогда
		
		Сообщить("Нет операций за выбранный период!");	
		
	Иначе
		НПП 	=	1;
		
		//Предварительная очистка табличного документа.
		ТабличныйДокумент.Очистить();
		Макет	=	ПолучитьМакет("Макет");
		ОбластьШапка	=	Макет.ПолучитьОбласть("Шапка");
		ОбластьДетали   =   Макет.ПолучитьОбласть("Детали");
		//ОбластьИтоги	=	Макет.ПолучитьОбласть("Итоги");
		//шапка 
		ОбластьШапка.Параметры.ДатаОтчета = Формат(ДатаОтчета,"ДЛФ=DD");
		ТабличныйДокумент.Вывести(ОбластьШапка);
		
		//детали	
		Дерево = РезультатЗапроса.Выгрузить(ОбходРезультатаЗапроса.ПоГруппировкам);
		Для каждого ВеткаТипЦБ Из Дерево.Строки Цикл
			
			//ТипЦБ
			ОбдастьТипЦБ	=	Макет.ПолучитьОбласть("ТипЦБ");
			ОбдастьТипЦБ.Параметры.Заполнить(ВеткаТипЦБ);
			ТабличныйДокумент.Вывести(ОбдастьТипЦБ);
			Для каждого ВеткаЭмитент Из ВеткаТипЦБ.Строки Цикл
				Для каждого ВеткаЦБ Из ВеткаЭмитент.Строки Цикл
					Для каждого ВеткаКатегория Из ВеткаЦБ.Строки Цикл
						
						//Сообщить(" / ЦБ="+ ВеткаКатегория.ЦБЭмитент 
						//		+ " / КолВсего=" +ВеткаКатегория.КоличествоВсего
						//   	+" / Зал="+ ВеткаКатегория.КоличествоЗалог
						//   	+" / В ДУ="+ ВеткаКатегория.КоличествоДУ
						//   	+" / Обреме="+ ВеткаКатегория.КоличествоОбремененных
						//   	+" / НеОпределена=" + ВеткаКатегория.КоличествоБезПренадлежности
						//   	+" / РыночнаяСтоимость=" + ВеткаКатегория.РыночнаяСтоимость );
						ОбластьДетали.Параметры.Заполнить(ВеткаКатегория);
						ОбластьДетали.Параметры.ВидКатегория	=	СокрЛП(ВеткаКатегория.ЦБТипЦБ) + " " + НРег(ВеткаКатегория.ВидЦБ);
						ОбластьДетали.Параметры.НомерРег		=	  Строка(ВеткаКатегория.НомерРегистрации) + ?(ВеткаКатегория.ЦБ.Эмитент.Резидент, ", " + Строка(ВеткаКатегория.ISIN),"");
						ОбластьДетали.Параметры.НПП			=	НПП;
						ТабличныйДокумент.Вывести(ОбластьДетали);
						НПП	=	НПП	+	1;
					КонецЦикла;//ВеткаКатегория 					
				КонецЦикла;//ВеткаЦБ 			
			КонецЦикла;//ВеткаЭмитент 
			ОбдастьИтогиТипЦБ	=	Макет.ПолучитьОбласть("ИтогиТипЦБ");
			ОбдастьИтогиТипЦБ.Параметры.Заполнить(ВеткаТипЦБ);
			ТабличныйДокумент.Вывести(ОбдастьИтогиТипЦБ);
		КонецЦикла;//ВеткаТипЦБ
		
		ТабличныйДокумент.ОтображатьСетку 		= Ложь;
		//ЭлементыФормы.ПолеТабличногоДокументаИнформация.Защита 				= Истина;  //Не возможно сохранять в файл
		ТабличныйДокумент.ТолькоПросмотр 		= Истина;
		ТабличныйДокумент.ОтображатьЗаголовки 	= Ложь;  
		
	КонецЕсли;
КонецПроцедуры

ОбщегоНазначения.ЛогироватьИспользованиеОбъекта(ЭтотОбъект);
