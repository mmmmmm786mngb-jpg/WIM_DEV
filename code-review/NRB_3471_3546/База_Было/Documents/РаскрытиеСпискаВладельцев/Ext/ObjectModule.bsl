	|			&Дата,
	|			ВидДокумента = &УсловноеДлящеесяПоручение
	|				И (СрокДействия = ДАТАВРЕМЯ(1, 1, 1)
	|					ИЛИ СрокДействия >= НАЧАЛОПЕРИОДА(&Дата, ДЕНЬ))) КАК УсловноеДлящеесяПоручение
