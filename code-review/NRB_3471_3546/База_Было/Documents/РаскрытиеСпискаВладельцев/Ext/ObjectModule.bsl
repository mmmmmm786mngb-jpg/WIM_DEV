Перем ТипУведомленияNEWM;

Процедура ПриУстановкеНовогоНомера(СтандартнаяОбработка, Префикс)
	
	СтандартнаяОбработка = Ложь;
	
	Префикс = НумераторыОбъектов.ПолучитьПрефиксНомера(ЭтотОбъект);
	
	Номер = НумераторыОбъектов.ПолучитьНомерДокумента(ЭтотОбъект, Префикс);
	
КонецПроцедуры

Процедура ОбработкаЗаполнения(ДанныеЗаполнения, СтандартнаяОбработка)
	Если ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.РаскрытиеСпискаВладельцев") Тогда
		Дораскрытие					= Истина;
		ДораскрытиеДокумент			= ДанныеЗаполнения;
		
		ВидКорпоративногоДействия	= ДанныеЗаполнения.ВидКорпоративногоДействия;
		КДРеференс					= ДанныеЗаполнения.КДРеференс;
		СвязанныйВидКД1				= ДанныеЗаполнения.СвязанныйВидКД1;
		СвязанныйРеференсКД1		= ДанныеЗаполнения.СвязанныйРеференсКД1;
		СвязанныйВидКД2				= ДанныеЗаполнения.СвязанныйВидКД2;
		СвязанныйРеференсКД2		= ДанныеЗаполнения.СвязанныйРеференсКД2;
		Организация					= ДанныеЗаполнения.Организация;
		Инициатор					= ДанныеЗаполнения.Инициатор;
		СчетДЕПО					= ДанныеЗаполнения.СчетДЕПО;
		БанковскийСчет				= ДанныеЗаполнения.БанковскийСчет;
		Эмитент						= ДанныеЗаполнения.Эмитент;
		ЦеннаяБумага1				= ДанныеЗаполнения.ЦеннаяБумага1;
		ЦеннаяБумага2				= ДанныеЗаполнения.ЦеннаяБумага2;
		ВходящийДокументДата		= ДанныеЗаполнения.ВходящийДокументДата;
		ВходящийДокументНомер		= ДанныеЗаполнения.ВходящийДокументНомер;
		ДатаФиксации				= ДанныеЗаполнения.ДатаФиксации;
		ЦеннаяБумага1Остаток		= ДанныеЗаполнения.ЦеннаяБумага1Остаток;
		ЦеннаяБумага2Остаток		= ДанныеЗаполнения.ЦеннаяБумага2Остаток;
		REPORT_ID					= ДанныеЗаполнения.REPORT_ID;
		Комментарий					= ДанныеЗаполнения.Комментарий;
		ТипЗагрузкиСписковРаскрытия	= ДанныеЗаполнения.ТипЗагрузкиСписковРаскрытия;
		
		СписокВладельцев.Очистить();
	ИначеЕсли ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.КорпоративноеДействие_Новый") Тогда
		Дата 						= ТекущаяДатаСеанса();
		УстановитьСсылкуНового(Документы.РаскрытиеСпискаВладельцев.ПолучитьСсылку());
		КарточкаКД					= ДанныеЗаполнения;
		СвязанныйРеференсКД1		= ДанныеЗаполнения.КДРеференс;
		СвязанныйВидКД1				= ДанныеЗаполнения.ВидКД;
		ТипЗагрузкиСписковРаскрытия = Перечисления.ТипЗагрузкиСписковРаскрытия.ISO20022;
		СвязанныйРеференсКД2		= ДанныеЗаполнения.КДРеференсСвязанный;
		СвязанныйВидКД2				= ДанныеЗаполнения.КДРеференсСвязанныйСсылка.ВидКД;
		ДатаПоступленияЗапроса		= ДанныеЗаполнения.Дата;
		ВидКорпоративногоДействия	= ДанныеЗаполнения.ВидКД;
		КДРеференс					= ДанныеЗаполнения.КДРеференс;
		ОснованиеЗапроса			= "Корпоративное действие - '" + ДанныеЗаполнения.ВидКД + "'. Референс '" + ДанныеЗаполнения.КДРеференс + "'. ";
		Дораскрытие					= Ложь;
		ЗаполнитьЗначенияСвойств(ЭтотОбъект, ДанныеЗаполнения, 
									"Эмитент, СчетДЕПО, ЦеннаяБумага1, ЦеннаяБумага2, ЦеннаяБумага1Остаток, ЦеннаяБумага2Остаток,
									|Инициатор, БанковскийСчет, ДатаФиксации, ОстаткиНаУтро, Организация");
		Если Документы.КорпоративноеДействие_Новый.ЭтоВидКДВыкупа(ДанныеЗаполнения.ВидКД) Тогда
			ДатаОкончанияПриема		= ДанныеЗаполнения.ДатаОкончанияПриемаЗаявокНаВыкуп;
			
		ИначеЕсли Документы.КорпоративноеДействие_Новый.ЭтоВидКДСобрания(ДанныеЗаполнения.ВидКД) Тогда
			ДатаОкончанияПриема		= ДанныеЗаполнения.ДатаОкончанияПриемаИнструкцийНРД;
			ЗаполнитьЗначенияСвойств(ЭтотОбъект, ДанныеЗаполнения,
				"ДатаПроведенияСобрания, ТипСобрания, КлассСобрания");
			
		ИначеЕсли ДанныеЗаполнения.ВидКД.Код = "WTRC" Тогда
			ДатаОкончанияПриемаИнструкцийВТБКБ	= ДанныеЗаполнения.ДатаОкончанияПриемаИнструкцийВТБКБ;
			ДатаОкончанияПриема	= ДанныеЗаполнения.ДатаОкончанияПриемаИнструкцийНРД;
			ЗаполнитьЗначенияСвойств(ЭтотОбъект, ДанныеЗаполнения, "Организация");
		КонецЕсли;
		ЗаполнитьСписокВладельцев();
		СформироватьТекстСообщения();
	КонецЕсли;
КонецПроцедуры

Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
	  
	Если ОбменДанными.Загрузка = Истина Тогда
		Возврат;
	КонецЕсли;
	
	УстановитьНовыйНомер();
	
	Если (ТипЗагрузкиСписковРаскрытия = Перечисления.ТипЗагрузкиСписковРаскрытия.PARTAD) И (ТипСписка.Пустая()) Тогда
		ОбщегоНазначения.СообщитьОбОшибке("Не заполнен 'Тип сообщения' для ПАРТАД!!!", Отказ);
		Возврат;
	КонецЕсли;
	
	Если ТипЗагрузкиСписковРаскрытия = Перечисления.ТипЗагрузкиСписковРаскрытия.PARTAD И Не ЗначениеЗаполнено(БанковскийСчет) Тогда
		ОбщегоНазначения.СообщитьОбОшибке("Не заполнен 'Банковский счет' для 'ЛУЧ'!!!", Отказ);
		Возврат;
	КонецЕсли;
	
	ОтражатьСтатусОтправкиЗапросовСубброкеру = WTRCСообщенияQI.ИспользоватьРегистрациюЗапросовСубброкера(Дата) 
			И WTRCСообщенияQI.ТребуетсяЗапросСубброкеруНаРаскрытие(ВидКорпоративногоДействия)
			Или ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ВидКорпоративногоДействия,"Код") = "WTRC";
			
	Если ЭтоНовый() Тогда
		Если Не ЗначениеЗаполнено(Автор) Тогда
			Автор	= ПараметрыСеанса.ТекущийПользователь;
		КонецЕсли;
		Изменил	= Справочники.Пользователи.ПустаяСсылка();
		Если ТипЗагрузкиСписковРаскрытия = Перечисления.ТипЗагрузкиСписковРаскрытия.PARTAD Тогда
			Статус = Перечисления.СтатусыРаскрытияСписковВладельцев.Создано;
		ИначеЕсли ОтражатьСтатусОтправкиЗапросовСубброкеру Тогда 
			Статус = Перечисления.СтатусыРаскрытияСписковВладельцев.Создано;
		КонецЕсли;
	Иначе
				
		Если ОтражатьСтатусОтправкиЗапросовСубброкеру Тогда 
			ОбновитьСтатусОтправкиЗагрузкиЗапросаСубброкеруНаРаскрытие();	
		КонецЕсли;
		Изменил	= ПараметрыСеанса.ТекущийПользователь;
	КонецЕсли;
	

	
	Если НЕ ЗначениеЗаполнено(ДатаОкончанияПриемаИнструкцийВТБКБ) Тогда
		Если ЗначениеЗаполнено(ВидКорпоративногоДействия.ТипКорпоративныхДействий) Тогда
			ТипКД = ВидКорпоративногоДействия.ТипКорпоративныхДействий;
		ИначеЕсли ЗначениеЗаполнено(СвязанныйВидКД1.ТипКорпоративныхДействий) Тогда
			ТипКД = СвязанныйВидКД1.ТипКорпоративныхДействий;
		КонецЕсли;
		Если (ТипКД = Перечисления.ТипыКорпоративныхДействий.Доход
			ИЛИ ТипКД = Перечисления.ТипыКорпоративныхДействий.Добровольное) И ЗначениеЗаполнено(ДатаФиксации) Тогда
			ДатаОкончанияПриемаИнструкцийВТБКБ = ОбщегоНазначения.ДобавитьРабочийДень(ДатаФиксации, 5);
			ОбщегоНазначения.СкопироватьВремя(ДатаОкончанияПриемаИнструкцийВТБКБ, '00010101120000');
			
		ИначеЕсли ТипКД = Перечисления.ТипыКорпоративныхДействий.Обязательное И ЗначениеЗаполнено(ДатаОкончанияПриема) Тогда
			ДатаОкончанияПриемаИнструкцийВТБКБ = ОбщегоНазначения.ДобавитьРабочийДень(ДатаОкончанияПриема, -2);
			ОбщегоНазначения.СкопироватьВремя(ДатаОкончанияПриемаИнструкцийВТБКБ, ДатаОкончанияПриема);
			МинимальнаяДата = ТекущаяДата() - 3*60*60;
			ДатаОкончанияПриемаИнструкцийВТБКБ = Макс(ДатаОкончанияПриемаИнструкцийВТБКБ, МинимальнаяДата);
		КонецЕсли;
	КонецЕсли;
	
	Если Статус <> Ссылка.Статус ИЛИ ЭтоНовый() Тогда
		ДополнительныеСвойства.Вставить("СтатусДокументаИзменен", Истина);
	КонецЕсли;
	
КонецПроцедуры

Процедура ОбновитьСтатусОтправкиЗагрузкиЗапросаСубброкеруНаРаскрытие()
	
	Если Статус = Перечисления.СтатусыРаскрытияСписковВладельцев.Создано Тогда 
		Для Каждого Строка Из СписокВладельцев Цикл 
			Если ЗначениеЗаполнено(Строка.ЗапросНаРСВ) И ЗначениеЗаполнено(Строка.ДатаОтправкиЗапросаНД) Тогда 
				Статус = Перечисления.СтатусыРаскрытияСписковВладельцев.ОтправленЗапросНаРаскрытиеНД;
				Прервать;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	Если Статус = Перечисления.СтатусыРаскрытияСписковВладельцев.ОтправленЗапросНаРаскрытиеНД Тогда 
		Для Каждого Строка Из СписокВладельцев Цикл 
			Если ЗначениеЗаполнено(Строка.ОтветНаРСВ) Тогда 
				Статус = Перечисления.СтатусыРаскрытияСписковВладельцев.ПолученОтветНДПоРаскрытию;
				Прервать;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
			
КонецПроцедуры

// Заполняет табличную часть СписокВладельцев
Процедура ЗаполнитьСписокВладельцев() Экспорт
	
	МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц();
	ДанныеСпискаВладельцев = ДанныеСпискаВладельцев(МенеджерВременныхТаблиц);
	СписокВладельцев.Загрузить(ДанныеСпискаВладельцев);
	ТребуетсяРаскрытиеПоСубклиентам = ЕстьСубброкерВСпискеВладельцев();
	
	КодСвязанногоКД = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СвязанныйВидКД1,"Код");
	Если КодСвязанногоКД = "WTRC" Тогда 
		ДополнитьСписокВладельцевЗапросамиСубброкера();
	КонецЕсли;
	ДатаРегистрацииЗапросовСубброкера = Константы.ДатаРегистрацииЗапросовСубброкера.Получить();
	Если КодСвязанногоКД = "WTRC" И ЗначениеЗаполнено(КарточкаКД) 
		И НЕ Справочники.ЦенныеБумаги.ЦБПодпадаетПодНалоговоеРегулированиеСША(ЦеннаяБумага1) Тогда
		Если WTRCСообщенияQI.ИспользоватьРегистрациюЗапросовСубброкераДляДокумента(КарточкаКД) Тогда 
			ДополнитьСписокВладельцевПоОтветамСубброкераНаРСВ(МенеджерВременныхТаблиц);
		Иначе 
			ДобавитьПодтвержденияСубброкераПоРСВ();
		КонецЕсли;
	ИначеЕсли Дата > ДатаРегистрацииЗапросовСубброкера И ЗначениеЗаполнено(ДатаРегистрацииЗапросовСубброкера) Тогда
		ДополнитьСписокВладельцевПоОтветамСубброкераНаРСВ(МенеджерВременныхТаблиц);
	Иначе	
		ДобавитьПодтвержденияСубброкераПоРСВ();
	КонецЕсли;
	
  	ОбновитьОстатокЦенныхБумаг();
	Если WTRCСообщенияQI.ИспользоватьРегистрациюЗапросовСубброкера(Дата) 
			И WTRCСообщенияQI.ТребуетсяЗапросСубброкеруНаРаскрытие(ВидКорпоративногоДействия)
			Или ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ВидКорпоративногоДействия,"Код") = "WTRC" Тогда
			ОбновитьСтатусОтправкиЗагрузкиЗапросаСубброкеруНаРаскрытие();
	КонецЕсли;
	
КонецПроцедуры

Процедура ДобавитьПодтвержденияСубброкераПоРСВ()
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	Подтверждения.ДоговорСубброкера.Владелец КАК Клиент,
	|	Подтверждения.ДоговорСубброкера КАК Договор,
	|	Подтверждения.СчетДепо КАК СчетДепо,
	|	Подтверждения.Субклиент КАК Выгодоприобретатель,
	|	Подтверждения.ЦеннаяБумага КАК ЦеннаяБумага,
	|	Подтверждения.Количество КАК Количество,
	|	Подтверждения.ДатаПолученияОтветаНД КАК ДатаПолученияОтветаНД
	|ИЗ
	|	РегистрСведений.ПодтвержденияСубброкераПоРСВ КАК Подтверждения
	|ГДЕ
	|	Подтверждения.КД = &КД");
	Если ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ВидКорпоративногоДействия, "Код") = "DSCL" Тогда 
		Запрос.УстановитьПараметр("КД", Ссылка);	
	Иначе 
		Запрос.УстановитьПараметр("КД", КарточкаКД);
	КонецЕсли;
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		Отбор = Новый Структура("Клиент, Договор, СчетДепо, ЦеннаяБумага, Выгодоприобретатель, Количество");
		ЗаполнитьЗначенияСвойств(Отбор, Выборка);
		НайденныеСтроки = СписокВладельцев.НайтиСтроки(Отбор);
		Если НайденныеСтроки.Количество() > 0 Тогда
			НайденныеСтроки[0].ПоДаннымСубброкера = Истина;
			НайденныеСтроки[0].ДатаПолученияОтветаНД = Выборка.ДатаПолученияОтветаНД;
		Иначе
			НоваяСтрока = СписокВладельцев.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, Выборка);
			НоваяСтрока.ПоДаннымСубброкера = Истина;
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

Процедура ОбновитьОстатокЦенныхБумаг()
	
	Запрос = Новый Запрос();
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Остатки.ЦБ КАК ЦеннаяБумага,
	|	Остатки.КоличествоОстаток КАК Количество
	|ИЗ
	|	РегистрНакопления.ОстаткиЦБМестоРасчетов.Остатки(
	|			&Дата,
	|			ЦБ В (&ЦенныеБумаги)
	|				И СчетДепоМХ = &СчетДепоМХ) КАК Остатки";
	ГраницаДатыФиксации = ?(ОстаткиНаУтро,
		Новый Граница(НачалоДня(ДатаФиксации), ВидГраницы.Исключая),
		Новый Граница(КонецДня(ДатаФиксации), ВидГраницы.Включая));
	ДатаОстатков = ?(ДатаФиксации <= ТекущаяДатаСеанса(), ГраницаДатыФиксации, ТекущаяДатаСеанса());
	Запрос.УстановитьПараметр("Дата", ДатаОстатков);
	Запрос.УстановитьПараметр("СчетДепоМХ"	, СчетДЕПО);
	ЦенныеБумаги = Новый Массив;
	ЦенныеБумаги.Добавить(ЦеннаяБумага1);
	ЦенныеБумаги.Добавить(ЦеннаяБумага2);
	Запрос.УстановитьПараметр("ЦенныеБумаги", ЦенныеБумаги);	
	
	Результат = Запрос.Выполнить();
	Если Результат.Пустой() Тогда 
		ЦеннаяБумага1Остаток = 0;
		ЦеннаяБумага2Остаток = 0;
		Возврат;
	КонецЕсли;
	
	Выборка = Результат.Выбрать();
	Пока Выборка.Следующий() Цикл 		
		Если Выборка.ЦеннаяБумага = ЦеннаяБумага1 Тогда 
			ЦеннаяБумага1Остаток = Выборка.Количество;
		ИначеЕсли Выборка.ЦеннаяБумага = ЦеннаяБумага2 Тогда 
			ЦеннаяБумага2Остаток = Выборка.Количество;
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

// Дополняет в списке владельцев информацию о запросе субброкера и дате отправке запроса субброкера 
Процедура ДополнитьСписокВладельцевЗапросамиСубброкера() Экспорт
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	ЗапросСубброкеруНаРаскрытие.Клиент КАК Клиент,
	|	МАКСИМУМ(ЗапросСубброкеруНаРаскрытие.Дата) КАК ДатаФормирования,
	|	МАКСИМУМ(ЗапросСубброкеруНаРаскрытие.ДатаВремяОтправкиЗапроса) КАК ДатаОтправки
	|ПОМЕСТИТЬ ПоследниеСформированныеИОтправленныеЗапросы
	|ИЗ
	|	Документ.ЗапросСубброкеруНаРаскрытие КАК ЗапросСубброкеруНаРаскрытие
	|ГДЕ
	|	ЗапросСубброкеруНаРаскрытие.РеференсКД = &РеференсКД
	|	И НЕ ЗапросСубброкеруНаРаскрытие.ПометкаУдаления
	|
	|СГРУППИРОВАТЬ ПО
	|	ЗапросСубброкеруНаРаскрытие.Клиент
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЗапросСубброкеруНаРаскрытие.Клиент КАК Клиент,
	|	ЗапросСубброкеруНаРаскрытие.Ссылка КАК ЗапросНаРСВ,
	|	ЗапросСубброкеруНаРаскрытие.ДатаВремяОтправкиЗапроса КАК ДатаОтправкиЗапросаНД
	|ИЗ
	|	Документ.ЗапросСубброкеруНаРаскрытие КАК ЗапросСубброкеруНаРаскрытие
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ПоследниеСформированныеИОтправленныеЗапросы КАК ПоследниеСформированныеИОтправленныеЗапросы
	|		ПО (ЗапросСубброкеруНаРаскрытие.РеференсКД = &РеференсКД)
	|			И ЗапросСубброкеруНаРаскрытие.Клиент = ПоследниеСформированныеИОтправленныеЗапросы.Клиент
	|			И (ВЫБОР
	|				КОГДА ПоследниеСформированныеИОтправленныеЗапросы.ДатаОтправки = ДАТАВРЕМЯ(1, 1, 1, 0, 0, 0)
	|					ТОГДА ЗапросСубброкеруНаРаскрытие.Дата = ПоследниеСформированныеИОтправленныеЗапросы.ДатаФормирования
	|				ИНАЧЕ ЗапросСубброкеруНаРаскрытие.ДатаВремяОтправкиЗапроса = ПоследниеСформированныеИОтправленныеЗапросы.ДатаОтправки
	|			КОНЕЦ)");
	
	Запрос.УстановитьПараметр("РеференсКД",СвязанныйРеференсКД1);
	Результат = Запрос.Выполнить();
	Если Результат.Пустой() Тогда 
		Возврат;
	КонецЕсли;
	Выборка = Результат.Выбрать();
	Пока Выборка.Следующий() Цикл 
		
		Отбор = Новый Структура("Клиент",Выборка.Клиент);
		СтрокиКлиента = СписокВладельцев.НайтиСтроки(Отбор);
		Для Каждого СтрокаКлиента Из СтрокиКлиента Цикл 
			ЗаполнитьЗначенияСвойств(СтрокаКлиента, Выборка,"ЗапросНаРСВ, ДатаОтправкиЗапросаНД");	
		КонецЦикла;
		
	КонецЦикла;
		
КонецПроцедуры

Функция ТекстЗапросаДополненияСпискаВладельцевПоОтветамСубброкераНаРСВ(ЭтоКорпоративноеДействиеWTRCПоАмериканскойЦБ)
	ТекстЗапроса =
	"ВЫБРАТЬ
	|	ЗапросСубброкеруНаРаскрытие.Ссылка КАК Ссылка,
	|	ЗапросСубброкеруНаРаскрытие.Дата КАК Дата,
	|	ЗапросСубброкеруНаРаскрытие.Клиент КАК Клиент,
	|	ЗапросСубброкеруНаРаскрытие.ISIN КАК ISIN
	|ПОМЕСТИТЬ ЗапросыСубброкеру
	|ИЗ
	|	Документ.ЗапросСубброкеруНаРаскрытие КАК ЗапросСубброкеруНаРаскрытие
	|ГДЕ
	|	ЗапросСубброкеруНаРаскрытие.РеференсКД = &РеференсКД
	|	И НЕ ЗапросСубброкеруНаРаскрытие.ПометкаУдаления
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЗапросыСубброкеру.Ссылка КАК Ссылка,
	|	ЗапросыСубброкеру.Клиент КАК Клиент,
	|	ЗапросыСубброкеру.ISIN КАК ISIN
	|ПОМЕСТИТЬ ДанныеРСВПоследниеЗапросы
	|ИЗ
	|	ЗапросыСубброкеру КАК ЗапросыСубброкеру
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	|			ЗапросыСубброкеру.Клиент КАК Клиент,
	|			ЗапросыСубброкеру.ISIN КАК ISIN,
	|			МАКСИМУМ(ЗапросыСубброкеру.Дата) КАК Дата
	|		ИЗ
	|			ЗапросыСубброкеру КАК ЗапросыСубброкеру
	|		
	|		СГРУППИРОВАТЬ ПО
	|			ЗапросыСубброкеру.Клиент,
	|			ЗапросыСубброкеру.ISIN) КАК ДатаИВремяПоследнегоЗапросаСубброкеру
	|		ПО ЗапросыСубброкеру.Клиент = ДатаИВремяПоследнегоЗапросаСубброкеру.Клиент
	|			И ЗапросыСубброкеру.ISIN = ДатаИВремяПоследнегоЗапросаСубброкеру.ISIN
	|			И ЗапросыСубброкеру.Дата = ДатаИВремяПоследнегоЗапросаСубброкеру.Дата
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ОтветСубброкераНаРаскрытиеДанныеСубброкера.Ссылка КАК Ссылка
	|ПОМЕСТИТЬ ДанныеРСВПоследниеОтветы
	|ИЗ
	|	Документ.ОтветСубброкераНаРаскрытие.ДанныеСубброкера КАК ОтветСубброкераНаРаскрытиеДанныеСубброкера
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	|			ОтветСубброкераНаРаскрытиеДанныеСубброкера.Клиент КАК Клиент,
	|			ОтветСубброкераНаРаскрытиеДанныеСубброкера.ЦеннаяБумага КАК ЦеннаяБумага,
	|			МАКСИМУМ(ОтветСубброкераНаРаскрытие.Дата) КАК Дата
	|		ИЗ
	|			Документ.ОтветСубброкераНаРаскрытие.ДанныеСубброкера КАК ОтветСубброкераНаРаскрытиеДанныеСубброкера
	|				ЛЕВОЕ СОЕДИНЕНИЕ Документ.ОтветСубброкераНаРаскрытие КАК ОтветСубброкераНаРаскрытие
	|				ПО ОтветСубброкераНаРаскрытиеДанныеСубброкера.Ссылка = ОтветСубброкераНаРаскрытие.Ссылка
	|		ГДЕ
	|			ОтветСубброкераНаРаскрытие.РаскрытиеСпискаВладельцев = &РаскрытиеСпискаВладельцев
	|			И НЕ ОтветСубброкераНаРаскрытие.ПометкаУдаления
	|		
	|		СГРУППИРОВАТЬ ПО
	|			ОтветСубброкераНаРаскрытиеДанныеСубброкера.Клиент,
	|			ОтветСубброкераНаРаскрытиеДанныеСубброкера.ЦеннаяБумага) КАК ОтветыСубброкераАктуальнаяДата
	|		ПО (ОтветСубброкераНаРаскрытиеДанныеСубброкера.Ссылка.РаскрытиеСпискаВладельцев = &РаскрытиеСпискаВладельцев)
	|			И ОтветСубброкераНаРаскрытиеДанныеСубброкера.Ссылка.Дата = ОтветыСубброкераАктуальнаяДата.Дата
	|			И ОтветСубброкераНаРаскрытиеДанныеСубброкера.Клиент = ОтветыСубброкераАктуальнаяДата.Клиент
	|			И ОтветСубброкераНаРаскрытиеДанныеСубброкера.ЦеннаяБумага = ОтветыСубброкераАктуальнаяДата.ЦеннаяБумага
	|			И (НЕ ОтветСубброкераНаРаскрытиеДанныеСубброкера.Ссылка.ПометкаУдаления)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ОтветСубброкераНаРаскрытиеДанныеСубброкера.ЦеннаяБумага КАК ЦеннаяБумага,
	|	ОтветСубброкераНаРаскрытиеДанныеСубброкера.Клиент КАК Клиент,
	|	ОтветСубброкераНаРаскрытиеДанныеСубброкера.Договор КАК Договор,
	|	ОтветСубброкераНаРаскрытиеДанныеСубброкера.СчетДепо КАК СчетДепо,
	|	СУММА(ОтветСубброкераНаРаскрытиеДанныеСубброкера.Количество) КАК Количество
	|ПОМЕСТИТЬ КоличествоЦБНаОбщемРазделе
	|ИЗ
	|	ДанныеРСВПоследниеОтветы КАК ДанныеРСВПоследниеОтветы
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ОтветСубброкераНаРаскрытие.ДанныеСубброкера КАК ОтветСубброкераНаРаскрытиеДанныеСубброкера
	|		ПО ДанныеРСВПоследниеОтветы.Ссылка = ОтветСубброкераНаРаскрытиеДанныеСубброкера.Ссылка
	|			И (НЕ ОтветСубброкераНаРаскрытиеДанныеСубброкера.РазделСчетаДепо.РазделСубклиента)
	|
	|СГРУППИРОВАТЬ ПО
	|	ОтветСубброкераНаРаскрытиеДанныеСубброкера.Клиент,
	|	ОтветСубброкераНаРаскрытиеДанныеСубброкера.Договор,
	|	ОтветСубброкераНаРаскрытиеДанныеСубброкера.СчетДепо,
	|	ОтветСубброкераНаРаскрытиеДанныеСубброкера.ЦеннаяБумага
	|;
	|";
	
	Если ЭтоКорпоративноеДействиеWTRCПоАмериканскойЦБ Тогда
		ТекстЗапроса = ТекстЗапроса +
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ВложенныйЗапрос.ОтветСубброкера КАК ОтветСубброкера,
		|	ВложенныйЗапрос.Клиент КАК Клиент,
		|	ВложенныйЗапрос.КодКлиента КАК КодКлиента,
		|	Субклиенты.Ссылка КАК Выгодоприобретатель
		|ПОМЕСТИТЬ СубклиентПоДепозитарномуКодуФормуW8
		|ИЗ
		|	(ВЫБРАТЬ РАЗЛИЧНЫЕ
		|		ДанныеРСВПоследниеОтветы.Ссылка КАК ОтветСубброкера,
		|		ОтветСубброкераНаРаскрытиеДанныеСубброкера.Клиент КАК Клиент,
		|		ОтветСубброкераНаРаскрытиеДанныеСубброкера.КодКлиента КАК КодКлиента,
		|		ФормыW8.Лицо КАК ЮридическоеФизическоеЛицоСубклиента
		|	ИЗ
		|		ДанныеРСВПоследниеОтветы КАК ДанныеРСВПоследниеОтветы
		|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ОтветСубброкераНаРаскрытие.ДанныеСубброкера КАК ОтветСубброкераНаРаскрытиеДанныеСубброкера
		|				ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ФормыW8 КАК ФормыW8
		|				ПО ОтветСубброкераНаРаскрытиеДанныеСубброкера.КодКлиента = ФормыW8.ДепозитарныйКодСублиентаПоДаннымСубброкера
		|			ПО ДанныеРСВПоследниеОтветы.Ссылка = ОтветСубброкераНаРаскрытиеДанныеСубброкера.Ссылка) КАК ВложенныйЗапрос
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Субклиенты КАК Субклиенты
		|		ПО ВложенныйЗапрос.Клиент = Субклиенты.Владелец
		|			И ВложенныйЗапрос.ЮридическоеФизическоеЛицоСубклиента = Субклиенты.ЮридическиеФизическиеЛица
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ОтветСубброкераНаРаскрытиеДанныеСубброкера.Ссылка.ДатаОтправкиЗапроса КАК ДатаОтправкиЗапросаНД,
		|	ОтветСубброкераНаРаскрытиеДанныеСубброкера.Ссылка.Дата КАК ДатаПолученияОтветаНД,
		|	ДанныеРСВПоследниеЗапросы.Ссылка КАК ЗапросНаРСВ,
		|	ОтветСубброкераНаРаскрытиеДанныеСубброкера.Ссылка КАК ОтветНаРСВ,
		|	ОтветСубброкераНаРаскрытиеДанныеСубброкера.Количество КАК Количество,
		|	ОтветСубброкераНаРаскрытиеДанныеСубброкера.Клиент КАК Клиент,
		|	ОтветСубброкераНаРаскрытиеДанныеСубброкера.Договор КАК Договор,
		|	ОтветСубброкераНаРаскрытиеДанныеСубброкера.СчетДепо КАК СчетДепо,
		|	ОтветСубброкераНаРаскрытиеДанныеСубброкера.РазделСчетаДепо КАК РазделСчетаДепо,
		|	ОтветСубброкераНаРаскрытиеДанныеСубброкера.НомерСчетаДепоКлиента КАК НомерСчетаДепоКлиентаОтвета,
		|	ОтветСубброкераНаРаскрытиеДанныеСубброкера.ЦеннаяБумага КАК ЦеннаяБумага,
		|	ВЫБОР
		|		КОГДА ОтветСубброкераНаРаскрытиеДанныеСубброкера.Выгодоприобретатель ССЫЛКА Справочник.Субклиенты
		|			ТОГДА ОтветСубброкераНаРаскрытиеДанныеСубброкера.Выгодоприобретатель
		|		КОГДА НЕ СубклиентПоДепозитарномуКодуФормуW8.Выгодоприобретатель ЕСТЬ NULL
		|			ТОГДА СубклиентПоДепозитарномуКодуФормуW8.Выгодоприобретатель
		|		КОГДА ОтветСубброкераНаРаскрытиеДанныеСубброкера.Выгодоприобретатель = """"
		|			ТОГДА ОтветСубброкераНаРаскрытиеДанныеСубброкера.ПолноеНаименованиеЛица
		|		ИНАЧЕ ОтветСубброкераНаРаскрытиеДанныеСубброкера.Выгодоприобретатель
		|	КОНЕЦ КАК Выгодоприобретатель,
		|	ВЫБОР
		|		КОГДА ОтветСубброкераНаРаскрытиеДанныеСубброкера.Выгодоприобретатель ССЫЛКА Справочник.Субклиенты
		|			ТОГДА ОтветСубброкераНаРаскрытиеДанныеСубброкера.Выгодоприобретатель
		|		КОГДА НЕ СубклиентПоДепозитарномуКодуФормуW8.Выгодоприобретатель ЕСТЬ NULL
		|			ТОГДА СубклиентПоДепозитарномуКодуФормуW8.Выгодоприобретатель
		|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.Субклиенты.ПустаяСсылка)
		|	КОНЕЦ КАК Субклиент,
		|	ЕСТЬNULL(КоличествоЦБНаОбщемРазделе.Количество, 0) КАК КоличествоНаОбщемРазделе,
		|	ЕСТЬNULL(втОстатки.Количество, 0) КАК Остаток,
		|	ЕСТЬNULL(втОстатки.КоличествоВПоручении, 0) КАК КоличествоВПоручении,
		|	ОтветСубброкераНаРаскрытиеДанныеСубброкера.КодКлиента КАК КодКлиента,
		|	ОтветСубброкераНаРаскрытиеДанныеСубброкера.РазделСчетаДепо.РазделСубклиента КАК ЭтоРазделСубклиента
		|ИЗ
		|	ДанныеРСВПоследниеОтветы КАК ДанныеРСВПоследниеОтветы
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ОтветСубброкераНаРаскрытие.ДанныеСубброкера КАК ОтветСубброкераНаРаскрытиеДанныеСубброкера
		|			ЛЕВОЕ СОЕДИНЕНИЕ КоличествоЦБНаОбщемРазделе КАК КоличествоЦБНаОбщемРазделе
		|			ПО ОтветСубброкераНаРаскрытиеДанныеСубброкера.ЦеннаяБумага = КоличествоЦБНаОбщемРазделе.ЦеннаяБумага
		|				И ОтветСубброкераНаРаскрытиеДанныеСубброкера.Клиент = КоличествоЦБНаОбщемРазделе.Клиент
		|			ЛЕВОЕ СОЕДИНЕНИЕ втОстатки КАК втОстатки
		|			ПО ОтветСубброкераНаРаскрытиеДанныеСубброкера.ЦеннаяБумага = втОстатки.ЦеннаяБумага
		|				И ОтветСубброкераНаРаскрытиеДанныеСубброкера.Клиент = втОстатки.Клиент
		|				И ОтветСубброкераНаРаскрытиеДанныеСубброкера.СчетДепо = втОстатки.СчетДепо
		|				И ОтветСубброкераНаРаскрытиеДанныеСубброкера.РазделСчетаДепо = втОстатки.РазделСчетаДепо
		|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ ДанныеРСВПоследниеЗапросы КАК ДанныеРСВПоследниеЗапросы
		|			ПО (ДанныеРСВПоследниеЗапросы.Клиент = ОтветСубброкераНаРаскрытиеДанныеСубброкера.Клиент)
		|				И (ДанныеРСВПоследниеЗапросы.ISIN = ОтветСубброкераНаРаскрытиеДанныеСубброкера.ЦеннаяБумага.ISIN)
		|			ЛЕВОЕ СОЕДИНЕНИЕ СубклиентПоДепозитарномуКодуФормуW8 КАК СубклиентПоДепозитарномуКодуФормуW8
		|			ПО ОтветСубброкераНаРаскрытиеДанныеСубброкера.Ссылка = СубклиентПоДепозитарномуКодуФормуW8.ОтветСубброкера
		|				И ОтветСубброкераНаРаскрытиеДанныеСубброкера.Клиент = СубклиентПоДепозитарномуКодуФормуW8.Клиент
		|				И ОтветСубброкераНаРаскрытиеДанныеСубброкера.КодКлиента = СубклиентПоДепозитарномуКодуФормуW8.КодКлиента
		|		ПО ДанныеРСВПоследниеОтветы.Ссылка = ОтветСубброкераНаРаскрытиеДанныеСубброкера.Ссылка
		|ИТОГИ
		|	МАКСИМУМ(ЗапросНаРСВ),
		|	СУММА(Количество),
		|	МАКСИМУМ(Клиент),
		|	МАКСИМУМ(Договор),
		|	МАКСИМУМ(СчетДепо),
		|	МАКСИМУМ(ЦеннаяБумага)
		|ПО
		|	Субклиент";
	Иначе
		ТекстЗапроса = ТекстЗапроса +
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ОтветСубброкераНаРаскрытиеДанныеСубброкера.Ссылка.ДатаОтправкиЗапроса КАК ДатаОтправкиЗапросаНД,
		|	ОтветСубброкераНаРаскрытиеДанныеСубброкера.Ссылка.Дата КАК ДатаПолученияОтветаНД,
		|	ДанныеРСВПоследниеЗапросы.Ссылка КАК ЗапросНаРСВ,
		|	ОтветСубброкераНаРаскрытиеДанныеСубброкера.Ссылка КАК ОтветНаРСВ,
		|	ОтветСубброкераНаРаскрытиеДанныеСубброкера.Количество КАК Количество,
		|	ОтветСубброкераНаРаскрытиеДанныеСубброкера.Клиент КАК Клиент,
		|	ОтветСубброкераНаРаскрытиеДанныеСубброкера.Договор КАК Договор,
		|	ОтветСубброкераНаРаскрытиеДанныеСубброкера.СчетДепо КАК СчетДепо,
		|	ОтветСубброкераНаРаскрытиеДанныеСубброкера.РазделСчетаДепо КАК РазделСчетаДепо,
		|	ОтветСубброкераНаРаскрытиеДанныеСубброкера.НомерСчетаДепоКлиента КАК НомерСчетаДепоКлиентаОтвета,
		|	ОтветСубброкераНаРаскрытиеДанныеСубброкера.ЦеннаяБумага КАК ЦеннаяБумага,
		|	ВЫБОР
		|		КОГДА ОтветСубброкераНаРаскрытиеДанныеСубброкера.Выгодоприобретатель ССЫЛКА Справочник.Субклиенты
		|			ТОГДА ОтветСубброкераНаРаскрытиеДанныеСубброкера.Выгодоприобретатель
		|		КОГДА ОтветСубброкераНаРаскрытиеДанныеСубброкера.Выгодоприобретатель = """"
		|			ТОГДА ОтветСубброкераНаРаскрытиеДанныеСубброкера.ПолноеНаименованиеЛица
		|		ИНАЧЕ ОтветСубброкераНаРаскрытиеДанныеСубброкера.Выгодоприобретатель
		|	КОНЕЦ КАК Выгодоприобретатель,
		|	ВЫБОР
		|		КОГДА ОтветСубброкераНаРаскрытиеДанныеСубброкера.Выгодоприобретатель ССЫЛКА Справочник.Субклиенты
		|			ТОГДА ОтветСубброкераНаРаскрытиеДанныеСубброкера.Выгодоприобретатель
		|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.Субклиенты.ПустаяСсылка)
		|	КОНЕЦ КАК Субклиент,
		|	ЕСТЬNULL(КоличествоЦБНаОбщемРазделе.Количество, 0) КАК КоличествоНаОбщемРазделе,
		|	ЕСТЬNULL(втОстатки.Количество, 0) КАК Остаток,
		|	ЕСТЬNULL(втОстатки.КоличествоВПоручении, 0) КАК КоличествоВПоручении,
		|	ОтветСубброкераНаРаскрытиеДанныеСубброкера.КодКлиента КАК КодКлиента,
		|	ОтветСубброкераНаРаскрытиеДанныеСубброкера.РазделСчетаДепо.РазделСубклиента КАК ЭтоРазделСубклиента
		|ИЗ
		|	ДанныеРСВПоследниеОтветы КАК ДанныеРСВПоследниеОтветы
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ОтветСубброкераНаРаскрытие.ДанныеСубброкера КАК ОтветСубброкераНаРаскрытиеДанныеСубброкера
		|			ЛЕВОЕ СОЕДИНЕНИЕ КоличествоЦБНаОбщемРазделе КАК КоличествоЦБНаОбщемРазделе
		|			ПО ОтветСубброкераНаРаскрытиеДанныеСубброкера.ЦеннаяБумага = КоличествоЦБНаОбщемРазделе.ЦеннаяБумага
		|				И ОтветСубброкераНаРаскрытиеДанныеСубброкера.Клиент = КоличествоЦБНаОбщемРазделе.Клиент
		|			ЛЕВОЕ СОЕДИНЕНИЕ втОстатки КАК втОстатки
		|			ПО ОтветСубброкераНаРаскрытиеДанныеСубброкера.ЦеннаяБумага = втОстатки.ЦеннаяБумага
		|				И ОтветСубброкераНаРаскрытиеДанныеСубброкера.Клиент = втОстатки.Клиент
		|				И ОтветСубброкераНаРаскрытиеДанныеСубброкера.СчетДепо = втОстатки.СчетДепо
		|				И ОтветСубброкераНаРаскрытиеДанныеСубброкера.РазделСчетаДепо = втОстатки.РазделСчетаДепо
		|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ ДанныеРСВПоследниеЗапросы КАК ДанныеРСВПоследниеЗапросы
		|			ПО (ДанныеРСВПоследниеЗапросы.Клиент = ОтветСубброкераНаРаскрытиеДанныеСубброкера.Клиент)
		|				И (ДанныеРСВПоследниеЗапросы.ISIN = ОтветСубброкераНаРаскрытиеДанныеСубброкера.ЦеннаяБумага.ISIN)
		|		ПО ДанныеРСВПоследниеОтветы.Ссылка = ОтветСубброкераНаРаскрытиеДанныеСубброкера.Ссылка
		|ИТОГИ
		|	МАКСИМУМ(ЗапросНаРСВ),
		|	СУММА(Количество),
		|	МАКСИМУМ(Клиент),
		|	МАКСИМУМ(Договор),
		|	МАКСИМУМ(СчетДепо),
		|	МАКСИМУМ(ЦеннаяБумага)
		|ПО
		|	Субклиент";
	КонецЕсли;
	Возврат ТекстЗапроса;
КонецФункции

// Дополняет список владельцев по данным из последних ответов субброкера к РСВ, обновляет
// признак есть расхождения в строках
//
// Параметры:
//  МенеджерВременныхТаблиц - менеджер временных таблиц, в котором опеределена таблица ВТОстатки
//
Процедура ДополнитьСписокВладельцевПоОтветамСубброкераНаРСВ(МенеджерВременныхТаблиц) Экспорт
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	РаскрытиеСпискаВладельцевСписокВладельцев.Клиент,
	|	РаскрытиеСпискаВладельцевСписокВладельцев.Договор,
	|	РаскрытиеСпискаВладельцевСписокВладельцев.СчетДепо,
	|	РаскрытиеСпискаВладельцевСписокВладельцев.РазделСчетаДепо,
	|	РаскрытиеСпискаВладельцевСписокВладельцев.ЦеннаяБумага
	|ИЗ
	|	Документ.РаскрытиеСпискаВладельцев.СписокВладельцев КАК РаскрытиеСпискаВладельцевСписокВладельцев
	|ГДЕ
	|	РаскрытиеСпискаВладельцевСписокВладельцев.Ссылка = &РаскрытиеСпискаВладельцев
	|	И РаскрытиеСпискаВладельцевСписокВладельцев.СчетДепо.ТипСчетаДепо В(&ТипыСчетаДепоНДИНД)
	|");
	
	
	РСВСсылка = Ссылка;
	Если Не ЗначениеЗаполнено(РСВСсылка) Тогда 
		РСВСсылка = ПолучитьСсылкуНового();	
	КонецЕсли;
	Запрос.УстановитьПараметр("РаскрытиеСпискаВладельцев",РСВСсылка);
	Запрос.УстановитьПараметр("ТипыСчетаДепоНДИНД",БизнесПроцессы.ОбработкаWTRCСообщения.ТипыСчетовНДИНД());
	
	ВыборкаСтрок = Запрос.Выполнить().Выбрать();
	Пока ВыборкаСтрок.Следующий() Цикл 
		Отбор = Новый Структура("Клиент, Договор, СчетДепо,РазделСчетаДепо, ЦеннаяБумага");
		ЗаполнитьЗначенияСвойств(Отбор, ВыборкаСтрок);
		НайденныеСтроки = СписокВладельцев.НайтиСтроки(Отбор);
		Для Каждого НайденнаяСтрока Из НайденныеСтроки Цикл 
			НайденнаяСтрока.ЕстьРасхождения = НЕ ЗначениеЗаполнено(НайденнаяСтрока.ОтветНаРСВ);
		КонецЦикла;
	КонецЦикла;
	
	ЦБПодпадаетПодНалоговоеРегулированиеСША = Справочники.ЦенныеБумаги.ЦБПодпадаетПодНалоговоеРегулированиеСША(ЦеннаяБумага1);
	КодВидаКорпоративногоДействия = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ВидКорпоративногоДействия,"Код");
	ЭтоКорпоративноеДействиеWTRCПоАмериканскойЦБ = КодВидаКорпоративногоДействия = "WTRC" И ЦБПодпадаетПодНалоговоеРегулированиеСША;
	Запрос.Текст = ТекстЗапросаДополненияСпискаВладельцевПоОтветамСубброкераНаРСВ(ЭтоКорпоративноеДействиеWTRCПоАмериканскойЦБ);
	
	Запрос.УстановитьПараметр("РеференсКД", КДРеференс);
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Результат = Запрос.Выполнить();
	ВыборкаСубклиент = Результат.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "Субклиент");
	Пока ВыборкаСубклиент.Следующий() Цикл
		Если ЗначениеЗаполнено(ВыборкаСубклиент.Субклиент) Тогда	//Субклиенты с раздельными счетами депо
			Выборка = ВыборкаСубклиент.Выбрать();
			Пока Выборка.Следующий() Цикл
				Отбор = Новый Структура("Клиент, РазделСчетаДепо, СчетДепо, ЦеннаяБумага, Выгодоприобретатель");
				ЗаполнитьЗначенияСвойств(Отбор, Выборка);
				НайденныеСтроки = СписокВладельцев.НайтиСтроки(Отбор);
				Если НайденныеСтроки.Количество() > 1 Тогда
					ВызватьИсключение "Неоднозначное сопоставление строк РСВ с " + Выборка.ОтветНаРСВ + " по субклиенту " + Выборка.Субклиент;
				ИначеЕсли НайденныеСтроки.Количество() > 0 Тогда
					НайденныеСтроки[0].Количество = Выборка.Количество;
					ОтличаетсяКоличествоВПоручении = ЗначениеЗаполнено(Выборка.КоличествоВПоручении) 
													И Выборка.КоличествоВПоручении <> Выборка.Количество;
					Если Выборка.Количество = Выборка.Остаток 
						И НЕ ОтличаетсяКоличествоВПоручении Тогда
						НайденныеСтроки[0].ПоДаннымСубброкера = Истина;
						НайденныеСтроки[0].ЕстьРасхождения = Ложь;
					Иначе
						НайденныеСтроки[0].ПоДаннымСубброкера = Истина;
						НайденныеСтроки[0].ЕстьРасхождения = Истина;
						НайденныеСтроки[0].Количество = Выборка.Количество;
					КонецЕсли;
					НайденныеСтроки[0].ДатаПолученияОтветаНД = Выборка.ДатаПолученияОтветаНД;
					НайденныеСтроки[0].ОтветНаРСВ = Выборка.ОтветНаРСВ;
					НайденныеСтроки[0].НомерСчетаДепоКлиентаОтвета = Выборка.НомерСчетаДепоКлиентаОтвета;
				Иначе
					Если ЭтоКорпоративноеДействиеWTRCПоАмериканскойЦБ Или 
						Не Выборка.ЭтоРазделСубклиента Тогда
						
						ЕстьРасхождения = Выборка.КоличествоНаОбщемРазделе <> Выборка.Остаток;
						Отбор = Новый Структура("Клиент, РазделСчетаДепо, СчетДепо, ЦеннаяБумага, Выгодоприобретатель");
						ЗаполнитьЗначенияСвойств(Отбор, Выборка);
						Отбор.Выгодоприобретатель = Справочники.Субклиенты.ПустаяСсылка();
						НайденныеСтроки = СписокВладельцев.НайтиСтроки(Отбор);
						Для Каждого НайденнаяСтрока Из НайденныеСтроки Цикл 
							СписокВладельцев.Удалить(НайденнаяСтрока);
						КонецЦикла;
						
					Иначе
						
						ЕстьРасхождения = Ложь;
						
					КонецЕсли;
					
					НоваяСтрока = СписокВладельцев.Добавить();
					ЗаполнитьЗначенияСвойств(НоваяСтрока, Выборка);
					НоваяСтрока.ЕстьРасхождения = ЕстьРасхождения;
					НоваяСтрока.ПоДаннымСубброкера = Истина;
					
				КонецЕсли;
			КонецЦикла;
		Иначе //Субклиенты с общим разделом счета депо
			
			//Удаление строк по всем выгодоприобретателям, т.к. это либо общий остаток 
			//(заполняется функцией ДанныеСпискаВладельцев по остаткам)
			//либо строки из предыдущих ответов, которые уже неактуальны.
			Выборка = ВыборкаСубклиент.Выбрать();
			Пока Выборка.Следующий() Цикл
				
				Отбор = Новый Структура("Клиент, РазделСчетаДепо, СчетДепо, ЦеннаяБумага");
				ЗаполнитьЗначенияСвойств(Отбор, Выборка);
				НайденныеСтроки = СписокВладельцев.НайтиСтроки(Отбор);
				Для Каждого НаденнаяСтрока Из НайденныеСтроки Цикл 
					СписокВладельцев.Удалить(НаденнаяСтрока);
				КонецЦикла;
				
			КонецЦикла;
			
			Выборка.Сбросить();
			Пока Выборка.Следующий() Цикл
				
				НоваяСтрока = СписокВладельцев.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрока, Выборка);
				НоваяСтрока.ПоДаннымСубброкера = Истина;
				Если Выборка.Остаток <> Выборка.КоличествоНаОбщемРазделе ИЛИ Выборка.КоличествоНаОбщемРазделе = 0 Тогда 
					НоваяСтрока.ЕстьРасхождения = Истина;
				КонецЕсли;
				
			КонецЦикла;
			
		КонецЕсли;
	КонецЦикла;
	
	Если ЭтоКорпоративноеДействиеWTRCПоАмериканскойЦБ Тогда
		УстановитьПризнакПоДаннымСубброкераДляРазделовСубклиентов();
	КонецЕсли;
	
КонецПроцедуры

// Процедура - Установить признак по данным субброкера для разделов субклиентов
//  устанавливает признаки По данным субброкера и есть расхождения в списке владельцев
Процедура УстановитьПризнакПоДаннымСубброкераДляРазделовСубклиентов() Экспорт
	
	Для Каждого Строка Из СписокВладельцев Цикл
		Если ЗначениеЗаполнено(Строка.ОтветНаРСВ) Или Не Строка.РазделСчетаДепо.РазделСубклиента Тогда
			Продолжить;
		КонецЕсли;
		Строка.ПоДаннымСубброкера = Истина;
		Строка.ЕстьРасхождения = Ложь;
	КонецЦикла;
	
КонецПроцедуры

Функция ЕстьСубброкерВСпискеВладельцев() Экспорт
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	Контрагенты.Ссылка
	|ИЗ
	|	Справочник.Контрагенты КАК Контрагенты
	|ГДЕ
	|	Контрагенты.Ссылка В(&Клиенты)
	|	И Контрагенты.Субброкер");
	Запрос.УстановитьПараметр("Клиенты", СписокВладельцев.ВыгрузитьКолонку("Клиент"));
	Возврат НЕ Запрос.Выполнить().Пустой();
КонецФункции

Процедура ЗаполнитьСписокВладельцевПоОстаткам() Экспорт 
	
	МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц();
	СписокВладельцевПоОстаткам = ДанныеСпискаВладельцевПоОстаткам(МенеджерВременныхТаблиц,
		ТекстЗапросаДанныеСпискаВладельцевПоОстаткам());
	СписокВладельцев.Загрузить(СписокВладельцевПоОстаткам);

КонецПроцедуры

Процедура ЗаполнитьСписокВладельцевПоОстаткам_ЕстьФормаW8_НеНалогРаздел_ЕстьДлящеесяПоручение() Экспорт 
	
	МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц();
	СписокВладельцевПоОстаткам = ДанныеСпискаВладельцевПоОстаткам(МенеджерВременныхТаблиц,
		ТекстЗапросаДанныеСпискаВладельцевПоОстаткам_ЕстьФормаW8_НеНалогРаздел_ЕстьДлящеесяПоручение());
	СписокВладельцев.Загрузить(СписокВладельцевПоОстаткам);

КонецПроцедуры

Функция ДанныеСпискаВладельцев(МенеджерВременныхТаблиц = Неопределено) Экспорт
	
	Если МенеджерВременныхТаблиц = Неопределено Тогда
		МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	КонецЕсли;
	ЦБПодпадаетПодНалоговоеРегулированиеСША = Справочники.ЦенныеБумаги.ЦБПодпадаетПодНалоговоеРегулированиеСША(ЦеннаяБумага1);
	Если ЗначениеЗаполнено(КарточкаКД) И ЗначениеЗаполнено(СвязанныйВидКД1) И СвязанныйВидКД1.Код = "WTRC" И НЕ ЦБПодпадаетПодНалоговоеРегулированиеСША Тогда
		ДанныеСпискаВладельцевПоОстаткам(МенеджерВременныхТаблиц,ТекстЗапросаДанныеСпискаВладельцевПоОстаткам());
		ДепонентыРаскрытия = Документы.РаскрытиеСпискаВладельцев.ДепонентыСПоручениями1_10(КарточкаКД).Депоненты;
		Возврат ДепонентыРаскрытия;
	ИначеЕсли ЗначениеЗаполнено(КарточкаКД) И СвязанныйВидКД1.Код = "TREC" Тогда
		ДепонентыРаскрытия = Документы.РаскрытиеСпискаВладельцев.ДепонентыСПоручениями1_10TREC(КарточкаКД, МенеджерВременныхТаблиц);
		Возврат ДепонентыРаскрытия;
	Иначе
		ДанныеСпискаВладельцевПоОстаткам = ДанныеСпискаВладельцевПоОстаткам(МенеджерВременныхТаблиц,
			ТекстЗапросаДанныеСпискаВладельцевПоОстаткам());
		Возврат ДанныеСпискаВладельцевПоОстаткам;
	КонецЕсли;

КонецФункции

Функция ТекстЗапросаДанныеСпискаВладельцевПоОстаткам()
	
	Возврат
	"ВЫБРАТЬ
	|	Поручение.Депонент КАК Депонент,
	|	Поручение.КоличествоЦБ КАК КоличествоЦБ
	|ПОМЕСТИТЬ втКоличествоПоручения
	|ИЗ
	|	Документ.Поручение КАК Поручение
	|ГДЕ
	|	НЕ Поручение.ПометкаУдаления
	|	И Поручение.КарточкаКД = &КарточкаКД
	|	И ВЫРАЗИТЬ(Поручение.ВидОперацииД КАК Справочник.ВидыОпераций) = &ВидПорученийУчастие
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Остатки.СчетДепо.Владелец КАК Клиент,
	|	ВЫБОР
	|		КОГДА Остатки.СчетДепо.Владелец.Субброкер
	|				И Остатки.РазделСчетаДепо.РазделСубклиента
	|			ТОГДА Остатки.РазделСчетаДепо.Субклиент
	|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.Субклиенты.ПустаяСсылка)
	|	КОНЕЦ КАК Выгодоприобретатель,
	|	Остатки.СчетДепо.Владелец.Субброкер КАК Субброкер,
	|	Остатки.СчетДепо.Владелец.Наименование КАК КлиентНаименование,
	|	Остатки.СчетДепо КАК СчетДепо,
	|	Договоры.Ссылка КАК Договор,
	|	Остатки.ЦБ КАК ЦеннаяБумага,
	|	Остатки.КоличествоОстаток КАК Количество,
	|	Остатки.РазделСчетаДепо КАК РазделСчетаДепо,
	|	втКоличествоПоручения.КоличествоЦБ КАК КоличествоВПоручении
	|ПОМЕСТИТЬ втОстатки
	|ИЗ
	|	РегистрНакопления.ОстаткиЦБМестоРасчетов.Остатки(
	|			&Дата,
	|			ЦБ В (&ЦеннаяБумага)
	|				И &ОтборСчетДепоМХ) КАК Остатки
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ДоговорыКонтрагентов КАК Договоры
	|		ПО Остатки.СчетДепо.Владелец = Договоры.Владелец
	|			И (НЕ Договоры.ПометкаУдаления)
	|		ЛЕВОЕ СОЕДИНЕНИЕ втКоличествоПоручения КАК втКоличествоПоручения
	|		ПО Остатки.СчетДепо.Владелец = втКоличествоПоручения.Депонент
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	втОстатки.Клиент КАК Клиент,
	|	втОстатки.СчетДепо КАК СчетДепо,
	|	МАКСИМУМ(ЗапросСубброкеруНаРаскрытие.Дата) КАК ДатаЗапросаНаРСВ,
	|	втОстатки.Субброкер КАК Субброкер,
	|	втОстатки.КлиентНаименование КАК КлиентНаименование,
	|	втОстатки.Договор КАК Договор,
	|	втОстатки.ЦеннаяБумага КАК ЦеннаяБумага,
	|	втОстатки.Количество КАК Количество,
	|	втОстатки.РазделСчетаДепо КАК РазделСчетаДепо,
	|	втОстатки.Выгодоприобретатель КАК Выгодоприобретатель,
	|	втОстатки.КоличествоВПоручении КАК КоличествоВПоручении
	|ПОМЕСТИТЬ втДатыЗапросовСубброкеруНаРСВ
	|ИЗ
	|	втОстатки КАК втОстатки
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ЦенныеБумаги КАК ЦенныеБумагиОстатки
	|		ПО (ЦенныеБумагиОстатки.Ссылка = втОстатки.ЦеннаяБумага)
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ЗапросСубброкеруНаРаскрытие КАК ЗапросСубброкеруНаРаскрытие
	|			ЛЕВОЕ СОЕДИНЕНИЕ Документ.РаскрытиеСпискаВладельцев КАК РаскрытиеСпискаВладельцев
	|			ПО (РаскрытиеСпискаВладельцев.Ссылка = ЗапросСубброкеруНаРаскрытие.РСВ)
	|		ПО втОстатки.Клиент = ЗапросСубброкеруНаРаскрытие.Клиент
	|			И (РаскрытиеСпискаВладельцев.Ссылка = &РСВ)
	|			И (НЕ ЗапросСубброкеруНаРаскрытие.ПометкаУдаления)
	|			И (ЦенныеБумагиОстатки.ISIN = ЗапросСубброкеруНаРаскрытие.ISIN)
	|			И (ЦенныеБумагиОстатки.НомерРегистрации = ЗапросСубброкеруНаРаскрытие.ГосРегНомерВыпуска)
	|			И (ЦенныеБумагиОстатки.Ссылка В (РаскрытиеСпискаВладельцев.ЦеннаяБумага1, РаскрытиеСпискаВладельцев.ЦеннаяБумага2))
	|
	|СГРУППИРОВАТЬ ПО
	|	втОстатки.СчетДепо,
	|	втОстатки.Клиент,
	|	втОстатки.Субброкер,
	|	втОстатки.КлиентНаименование,
	|	втОстатки.Договор,
	|	втОстатки.ЦеннаяБумага,
	|	втОстатки.Количество,
	|	втОстатки.РазделСчетаДепо,
	|	втОстатки.Выгодоприобретатель,
	|	втОстатки.КоличествоВПоручении
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	втДатыЗапросовСубброкеруНаРСВ.Клиент КАК Клиент,
	|	втДатыЗапросовСубброкеруНаРСВ.СчетДепо КАК СчетДепо,
	|	втДатыЗапросовСубброкеруНаРСВ.Субброкер КАК Субброкер,
	|	втДатыЗапросовСубброкеруНаРСВ.КлиентНаименование КАК КлиентНаименование,
	|	втДатыЗапросовСубброкеруНаРСВ.Договор КАК Договор,
	|	втДатыЗапросовСубброкеруНаРСВ.ЦеннаяБумага КАК ЦеннаяБумага,
	|	втДатыЗапросовСубброкеруНаРСВ.Количество КАК Количество,
	|	втДатыЗапросовСубброкеруНаРСВ.РазделСчетаДепо КАК РазделСчетаДепо,
	|	втДатыЗапросовСубброкеруНаРСВ.Выгодоприобретатель КАК Выгодоприобретатель,
	|	ЗапросСубброкеруНаРаскрытие.Ссылка КАК ЗапросНаРСВ,
	|	ВЫБОР
	|		КОГДА НЕ ЗапросСубброкеруНаРаскрытие.Статус = &СтатусСформирован
	|			ТОГДА ЗапросСубброкеруНаРаскрытие.Дата
	|		ИНАЧЕ ДАТАВРЕМЯ(1, 1, 1, 0, 0, 0)
	|	КОНЕЦ КАК ДатаОтправкиЗапросаНД,
	|	втДатыЗапросовСубброкеруНаРСВ.КоличествоВПоручении КАК КоличествоВПоручении
	|ПОМЕСТИТЬ втОстаткиИДатыЗапросов
	|ИЗ
	|	втДатыЗапросовСубброкеруНаРСВ КАК втДатыЗапросовСубброкеруНаРСВ
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ЦенныеБумаги КАК ЦенныеБумагиОстатки
	|		ПО (ЦенныеБумагиОстатки.Ссылка = втДатыЗапросовСубброкеруНаРСВ.ЦеннаяБумага)
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ЗапросСубброкеруНаРаскрытие КАК ЗапросСубброкеруНаРаскрытие
	|			ЛЕВОЕ СОЕДИНЕНИЕ Документ.РаскрытиеСпискаВладельцев КАК РаскрытиеСпискаВладельцев
	|			ПО (РаскрытиеСпискаВладельцев.Ссылка = ЗапросСубброкеруНаРаскрытие.РСВ)
	|		ПО втДатыЗапросовСубброкеруНаРСВ.Клиент = ЗапросСубброкеруНаРаскрытие.Клиент
	|			И (РаскрытиеСпискаВладельцев.Ссылка = &РСВ)
	|			И втДатыЗапросовСубброкеруНаРСВ.ДатаЗапросаНаРСВ = ЗапросСубброкеруНаРаскрытие.Дата
	|			И (НЕ ЗапросСубброкеруНаРаскрытие.ПометкаУдаления)
	|			И (ЦенныеБумагиОстатки.ISIN = ЗапросСубброкеруНаРаскрытие.ISIN)
	|			И (ЦенныеБумагиОстатки.НомерРегистрации = ЗапросСубброкеруНаРаскрытие.ГосРегНомерВыпуска)
	|			И (ЦенныеБумагиОстатки.Ссылка В (РаскрытиеСпискаВладельцев.ЦеннаяБумага1, РаскрытиеСпискаВладельцев.ЦеннаяБумага2))
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Остатки.Клиент КАК Клиент
	|ИЗ
	|	втОстатки КАК Остатки
	|ГДЕ
	|	Остатки.Субброкер";
	
КонецФункции

Функция ТекстЗапросаДанныеСпискаВладельцевПоОстаткам_ЕстьФормаW8_НеНалогРаздел_ЕстьДлящеесяПоручение()
	
