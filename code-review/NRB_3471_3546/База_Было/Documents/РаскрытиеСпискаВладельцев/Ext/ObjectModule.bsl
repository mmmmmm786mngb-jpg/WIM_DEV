Функция ДанныеСпискаВладельцевПоОстаткам(МенеджерВременныхТаблиц, ТекстЗапроса)
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.Текст = ТекстЗапроса;

	Если ОстаткиНаУтро Тогда
		ГраницаРасчета	= Новый Граница(НачалоДня(ДатаФиксации), ВидГраницы.Исключая);
	Иначе
		ГраницаРасчета	= КонецДня(ДатаФиксации);
	КонецЕсли;
	
	РСВСсылка = Ссылка;
	Если Не ЗначениеЗаполнено(РСВСсылка) Тогда 
		РСВСсылка = ПолучитьСсылкуНового();	
	КонецЕсли;
	
	Запрос.УстановитьПараметр("Дата"		, ГраницаРасчета);
	Запрос.УстановитьПараметр("СчетДепоМХ"	, СчетДЕПО);
	Запрос.УстановитьПараметр("РСВ"			, РСВСсылка);
	Запрос.УстановитьПараметр("СтатусСформирован",Перечисления.СтатусыДокументаЗапросСубброкеруНаРаскрытие.Сформирован);
	Запрос.УстановитьПараметр("ФормаW8",	Справочники.ВидыДокументовУдостоверяющихПолномочия.ФормаW8BENE_W8BEN);
	Запрос.УстановитьПараметр("УсловноеДлящеесяПоручение", Справочники.ВидыДокументовУдостоверяющихПолномочия.УсловноеДлящеесяПоручение);
	Запрос.УстановитьПараметр("Налоговый",	Перечисления.ТипыРазделовСчетовДЕПО.Налоговый);
	Запрос.УстановитьПараметр("КарточкаКД", КарточкаКД);
	Запрос.УстановитьПараметр("ВидПорученийУчастие",	Справочники.ВидыОпераций.УчастиеВКД);	// Поручение 1.10
	
	ЦеннаяБумага = Новый СписокЗначений;
	Если ЗначениеЗаполнено(ЦеннаяБумага1) Тогда
		ЦеннаяБумага.Добавить(ЦеннаяБумага1);
	КонецЕсли;
	Если ЗначениеЗаполнено(ЦеннаяБумага2) Тогда
		ЦеннаяБумага.Добавить(ЦеннаяБумага2);
	КонецЕсли;
	Запрос.УстановитьПараметр("ЦеннаяБумага", ЦеннаяБумага);
	
	Если Документы.КорпоративноеДействие_Новый.ЭтоВидКДВыкупа(ВидКорпоративногоДействия) Тогда
		Если ЗначениеЗаполнено(КарточкаКД) И ЗначениеЗаполнено(КарточкаКД.МинимальноеКодичествоДляУчастияВКД) Тогда
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "//ТекстУсловия", " ГДЕ Остатки.КоличествоОстаток > "
				+ Формат(КарточкаКД.МинимальноеКодичествоДляУчастияВКД, "ЧРД=.; ЧН=; ЧГ="));
		КонецЕсли;
	КонецЕсли;
	
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "&ОтборСчетДепоМХ",
		?(ЗначениеЗаполнено(СчетДЕПО), "СчетДепоМХ = &СчетДепоМХ", "ИСТИНА"));
		
	Если Запрос.Выполнить().Пустой() Тогда
		// Субброкеров в остатках нет, детализация по выгодоприобретателю (субклиенту) не нужна
		Запрос.Текст =
		"ВЫБРАТЬ
		|	Остатки.Клиент КАК Клиент,
		|	Остатки.Клиент.Субброкер КАК Субброкер,
		|	Остатки.СчетДепо КАК СчетДепо,
		|	Остатки.РазделСчетаДепо КАК РазделСчетаДепо,
		|	Остатки.Договор КАК Договор,
		|	Остатки.ЦеннаяБумага КАК ЦеннаяБумага,
		|	Остатки.ЗапросНаРСВ КАК ЗапросНаРСВ,
		|	ЗНАЧЕНИЕ(Справочник.Субклиенты.ПустаяСсылка) КАК Выгодоприобретатель,
		|	Остатки.ДатаОтправкиЗапросаНД КАК ДатаОтправкиЗапросаНД,
		|	СУММА(Остатки.Количество) КАК Количество
		|ИЗ
		|	втОстаткиИДатыЗапросов КАК Остатки
		|
		|СГРУППИРОВАТЬ ПО
		|	Остатки.Клиент,
		|	Остатки.Клиент.Субброкер,
		|	Остатки.КлиентНаименование,
		|	Остатки.СчетДепо,
		|	Остатки.РазделСчетаДепо,
		|	Остатки.Договор,
		|	Остатки.ЗапросНаРСВ,
		|	Остатки.ДатаОтправкиЗапросаНД,
		|	Остатки.ЦеннаяБумага
		|
		|УПОРЯДОЧИТЬ ПО
		|	Остатки.КлиентНаименование";
	Иначе
		// Есть субброкер(ы), необходима детализация по выгодоприобретателю (субклиенту)
		Запрос.Текст =
		"ВЫБРАТЬ
		|	Остатки.Клиент КАК Клиент,
		|	Остатки.Клиент.Субброкер КАК Субброкер,
		|	Остатки.Выгодоприобретатель КАК Выгодоприобретатель,
		|	Остатки.СчетДепо КАК СчетДепо,
		|	Остатки.РазделСчетаДепо КАК РазделСчетаДепо,
		|	Остатки.Договор КАК Договор,
		|	Остатки.ЦеннаяБумага КАК ЦеннаяБумага,
		|	Остатки.ЗапросНаРСВ КАК ЗапросНаРСВ,
		|	Остатки.ДатаОтправкиЗапросаНД КАК ДатаОтправкиЗапросаНД,
		|	СУММА(Остатки.Количество) КАК Количество
		|ИЗ
		|	втОстаткиИДатыЗапросов КАК Остатки
		|
		|СГРУППИРОВАТЬ ПО
		|	Остатки.Клиент,
		|	Остатки.Клиент.Субброкер,
		|	Остатки.КлиентНаименование,
		|	Остатки.Выгодоприобретатель,
		|	Остатки.СчетДепо,
		|	Остатки.ЗапросНаРСВ,
		|	Остатки.ДатаОтправкиЗапросаНД,
		|	Остатки.РазделСчетаДепо,
		|	Остатки.Договор,
		|	Остатки.ЦеннаяБумага
		|
		|УПОРЯДОЧИТЬ ПО
		|	Остатки.КлиентНаименование";
	КонецЕсли;
	
	Результат = Запрос.Выполнить().Выгрузить();
	Возврат Результат;
	
КонецФункции

Процедура ПриЗаписи(Отказ)
	
	Если ЗначениеЗаполнено(КарточкаКД) Тогда
		РегистрыСведений.СостоянияКорпоративныхДействий.ОтразитьСостояниеКорпоративногоДействия(КарточкаКД, Отказ);
	КонецЕсли;
	
	Если ДополнительныеСвойства.Свойство("СтатусДокументаИзменен") И ДополнительныеСвойства.СтатусДокументаИзменен = Истина Тогда
		РегистрыСведений.СтатусыРаскрытияСписковВладельцев.ОтразитьСтатусРаскрытия(Ссылка);
	КонецЕсли;
	
КонецПроцедуры

Процедура ОбработкаПроведения(Отказ, РежимПроведения)
	Если ТребуетсяРаскрытиеПоСубклиентам
		И ЭтоОбязательноеКД()
		И ЕстьСтрокиПоСубклиентамНеПодтвержденныеСубброкером() Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Это обязательное КД и есть строки с заполненным "
			 + "выгодоприобретателем (субклиентом), которые неподтверждены субброкером. Проведение невозможно.");
		Отказ = Истина;
		Возврат;
	КонецЕсли;
	
	УдалитьСтарыеЗаписиВЭтапахКД();
	
	// Для типа загрузки PARTAD фиксируем входящее сообщения в этапах КД
	Если ТипЗагрузкиСписковРаскрытия = Перечисления.ТипЗагрузкиСписковРаскрытия.PARTAD Тогда
		НаборЗаписей = РегистрыСведений.ЭтапыКД.СоздатьНаборЗаписей();
		НаборЗаписей.Отбор.КД.Установить(Ссылка);
		НаборЗаписей.Отбор.ДокументКД.Установить(Ссылка);
		НаборЗаписей.Прочитать();
		
		НоваяЗапись = НаборЗаписей.Добавить();
		НоваяЗапись.Период = ВходящийДокументДата;
		НоваяЗапись.КД = Ссылка;
		НоваяЗапись.ДокументКД = Ссылка;
		НоваяЗапись.КодОтчета = Справочники.ЭтапыКД.ЗапросСпискаВФорматеPARTAD.Код;
		НоваяЗапись.НомерСообщения = ВходящийДокументНомер;
		НоваяЗапись.Исходящее = Ложь;
		НоваяЗапись.ТипУведомления = ТипУведомленияNEWM;
		НоваяЗапись.ЭтапКД = Справочники.ЭтапыКД.ЗапросСпискаВФорматеPARTAD;
		
		НаборЗаписей.Записать();
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ДатаИсполнения) Тогда
		ИсполнитьСвязанныеПоручения1_10();
	КонецЕсли;
КонецПроцедуры

Процедура ОбработкаУдаленияПроведения(Отказ)
	УдалитьСтарыеЗаписиВЭтапахКД();
КонецПроцедуры

Процедура УдалитьСтарыеЗаписиВЭтапахКД()
	НаборЗаписей = РегистрыСведений.ЭтапыКД.СоздатьНаборЗаписей();
	НаборЗаписей.Отбор.КД.Установить(Ссылка);
	НаборЗаписей.Отбор.ДокументКД.Установить(Ссылка);
	НаборЗаписей.Прочитать();
	
	КоличествоЗаписей = НаборЗаписей.Количество();
	Индекс = 0;
	Пока Индекс < КоличествоЗаписей Цикл
		Если НаборЗаписей[Индекс].ЭтапКД = Справочники.ЭтапыКД.ЗапросСпискаВФорматеPARTAD
			И НаборЗаписей[Индекс].ТипУведомления = ТипУведомленияNEWM
			И НЕ НаборЗаписей[Индекс].Исходящее
		Тогда
			НаборЗаписей.Удалить(Индекс);
			КоличествоЗаписей = КоличествоЗаписей - 1;
		Иначе
			Индекс = Индекс + 1;
		КонецЕсли;
	КонецЦикла;
	
	НаборЗаписей.Записать();
КонецПроцедуры

Процедура ИсполнитьСвязанныеПоручения1_10()
	Поручения1_10 = РегистрыСведений.Поручения1_10ПоРСВ.СвязанныеПоручения(Ссылка);
	Для Каждого Поручение Из Поручения1_10 Цикл
		ПоручениеОбъект = Поручение.ПолучитьОбъект();
		ПоручениеОбъект.ДатаИсполненияПоручения	= ДатаИсполнения;
		ПоручениеОбъект.КодОтчетаНРД			= REPORT_ID;//КодОтчетаВышестоящегоДепозитария;
		ПоручениеОбъект.Записать(РежимЗаписиДокумента.Проведение);
	КонецЦикла;
КонецПроцедуры

Функция ЭтоОбязательноеКД()
	ВидКД = ?(ЗначениеЗаполнено(ВидКорпоративногоДействия), ВидКорпоративногоДействия, СвязанныйВидКД1);
	Возврат ВидКД.ТипКорпоративныхДействий = Перечисления.ТипыКорпоративныхДействий.Обязательное;
КонецФункции

Функция ЕстьСтрокиПоСубклиентамНеПодтвержденныеСубброкером()
	ЕстьНеподтвержденныеСтроки = Ложь;
	Для Каждого Строка Из СписокВладельцев Цикл
		Если ЗначениеЗаполнено(Строка.Выгодоприобретатель) И НЕ Строка.ПоДаннымСубброкера Тогда
			ЕстьНеподтвержденныеСтроки = Истина;
			Прервать;
		КонецЕсли;
	КонецЦикла;	
	Возврат ЕстьНеподтвержденныеСтроки;
КонецФункции

Процедура ПриКопировании(ОбъектКопирования)
	
	Статус = Перечисления.СтатусыРаскрытияСписковВладельцев.ПустаяСсылка();
	Если WTRCСообщенияQI.ИспользоватьРегистрациюЗапросовСубброкера()
		И WTRCСообщенияQI.ТребуетсяЗапросСубброкеруНаРаскрытие(ВидКорпоративногоДействия) Тогда 
		КДРеференс = "";
		СвязанныйРеференсКД1 = "";
		СвязанныйРеференсКД2 = "";
		Если СписокВладельцев.Количество() > 0 Тогда
			МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц();
			ДанныеСпискаВладельцев = ДанныеСпискаВладельцев(МенеджерВременныхТаблиц);
			СписокВладельцев.Загрузить(ДанныеСпискаВладельцев);
		КонецЕсли;
	КонецЕсли;
	СтатусFCDRГлобальный = "";
	СтатусFCDRДетальный = "";
КонецПроцедуры

Процедура ЗаполнитьТабличныйДокументДляСводногоРСВ(ТабДок) Экспорт
	
	Макет = ПолучитьМакет("СводноеРаскрытиеСпискаВладельцев");
	ОбластьШапка = Макет.ПолучитьОбласть("Шапка");
	ОбластьШапка.Параметры.РеференсСвязанногоКД = СвязанныйРеференсКД2;
	ОбластьШапка.Параметры.ISIN = ЦеннаяБумага1.ISIN;
	ОбластьШапка.Параметры.НаименованиеЦБ = ЦеннаяБумага1;
	ОбластьШапка.Параметры.ДатаФиксации = ДатаФиксации;
	ОбластьШапка.Параметры.СчетМХ = СчетДЕПО;
	QI_EIN = WTRCСообщенияQI.QI_EINПоУмолчанию();
	Если ЗначениеЗаполнено(QI_EIN) Тогда
		ОбластьШапка.Параметры.QI_EIN = Лев(QI_EIN,2)+"-"+Сред(QI_EIN,3);
	КонецЕсли;
	ТабДок.Вывести(ОбластьШапка);
	
	ОбластьГруппировки = Макет.ПолучитьОбласть("Группировки");
	ОбластьСтрокиРасшифровки = Макет.ПолучитьОбласть("СтрокиРасшифровки");
	ОбластьЗаголовокДетализации = Макет.ПолучитьОбласть("ЗаголовокДетализация");
	
	ВыборкаРазделСчетаМХ = ВыборкаДанныхЗаполненияСводногоРСВ().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	Разделы = Новый СписокЗначений;
	Пока ВыборкаРазделСчетаМХ.Следующий() Цикл
		Разделы.Добавить(ВыборкаРазделСчетаМХ.РазделСчетаДепоМХ);
	КонецЦикла;
	ВыборкаРазделСчетаМХ.Сбросить();
	
	Запрос = Документы.ВыгрузкаРазделаРСВвВышестоящийДепозитарий.ЗапросСостоянийВыгрузкиРазделов(Ссылка, Разделы);
	СтатусыВФайловомШлюзе = Запрос.Выполнить().Выгрузить();
	
	Пока ВыборкаРазделСчетаМХ.Следующий() Цикл
		ОбластьГруппировкаРазделы = Макет.ПолучитьОбласть("ГруппировкаРазделСчетДепо");
		ОбластьГруппировкаРазделы.Параметры.РазделСчетаМХ = ВыборкаРазделСчетаМХ.РазделСчетаДепоМХКод;
		ОбластьГруппировкаРазделы.Параметры.КоличествоЦБ = ВыборкаРазделСчетаМХ.КоличествоЦБ;
		
		СтрокаСтатуса = СтатусыВФайловомШлюзе.Найти(ВыборкаРазделСчетаМХ.РазделСчетаДепоМХ, "Раздел");
		Если СтрокаСтатуса <> Неопределено Тогда
			ОбластьГруппировкаРазделы.Параметры.СтатусВФайловомШлюзе = СтрокаСтатуса.Статус;
		КонецЕсли;
		
		ТабДок.Вывести(ОбластьГруппировкаРазделы);
		ТабДок.НачатьГруппуСтрок("Разделы",Истина);
		ТабДок.Вывести(ОбластьЗаголовокДетализации);

		ВыборкаНалоговаяСтавка = ВыборкаРазделСчетаМХ.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		Пока ВыборкаНалоговаяСтавка.Следующий() Цикл
			ВыборкаСтатусПоГлаве4 = ВыборкаНалоговаяСтавка.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
			Пока ВыборкаСтатусПоГлаве4.Следующий() Цикл
				ОбластьГруппировки.Параметры.КоличествоЦБ = ВыборкаСтатусПоГлаве4.КоличествоЦБ;
				ОбластьГруппировки.Параметры.НалоговаяСтавка = Строка(ВыборкаСтатусПоГлаве4.НалоговаяСтавка) + " PCT";
				ОбластьГруппировки.Параметры.СтатусПоГлаве4 = ВыборкаСтатусПоГлаве4.СтатусПоГлаве4;
				ТабДок.Вывести(ОбластьГруппировки);
				ТабДок.НачатьГруппуСтрок(,Ложь);
				Выборка = ВыборкаСтатусПоГлаве4.Выбрать();
				Пока Выборка.Следующий() Цикл
					ОбластьСтрокиРасшифровки.Параметры.Заполнить(Выборка);
					ОбластьСтрокиРасшифровки.Параметры.W8BENE_W8NEN = Выборка.W8BENE_W8NEN;
					ОбластьСтрокиРасшифровки.Параметры.W8IMY = Выборка.W8IMY;
					ТабДок.Вывести(ОбластьСтрокиРасшифровки);
				КонецЦикла;
				ТабДок.ЗакончитьГруппуСтрок();
			КонецЦикла;
		КонецЦикла;
		ОбластьПодвал = Макет.ПолучитьОбласть("Подвал");
		ОбластьПодвал.Параметры.КоличествоЦБ = ВыборкаРазделСчетаМХ.КоличествоЦБ;
		ТабДок.Вывести(ОбластьПодвал);
		ТабДок.ЗакончитьГруппуСтрок();
		
	КонецЦикла;
	
	ТабДок.ФиксацияСверху = 1;
	
КонецПроцедуры

// Выполняет различные проверки сводного раскрытия
Процедура ПроверитьЗаполнениеСводногоРСВ() Экспорт
	
	ТекстПроверкаКоличестваРСВ = "";
	ТекстПроверкаФормW8BENE_W8NEN = "";
	ТекстПроверкаФормW8IMY = "";
	ТекстПроверкаСтатусПоГлаве4 = "";
	ТекстПроверкаСубклиентаДУ = "";
	ТекстПроверкаСубклиентаОбщегоРаздела = "";
	
	ВыводитьДанныеДляПроверки = Истина;
	ВыборкаРазделСчетаМХ = ВыборкаДанныхЗаполненияСводногоРСВ(ВыводитьДанныеДляПроверки).Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Пока ВыборкаРазделСчетаМХ.Следующий() Цикл
		ВыборкаНалоговаяСтавка = ВыборкаРазделСчетаМХ.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		Пока ВыборкаНалоговаяСтавка.Следующий() Цикл
			ВыборкаСтатусПоГлаве4 = ВыборкаНалоговаяСтавка.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
			Пока ВыборкаСтатусПоГлаве4.Следующий() Цикл
				Выборка = ВыборкаСтатусПоГлаве4.Выбрать();
				Пока Выборка.Следующий() Цикл
					Выгодоприобретатель = ?(ЗначениеЗаполнено(Выборка.Субклиент), Выборка.Субклиент, Выборка.Клиент);
					Если Выборка.СтатусПоГлаве4 = "" Тогда
						ТекстПроверкаСтатусПоГлаве4 = ТекстПроверкаСтатусПоГлаве4 + Выборка.Договор+" "+Выгодоприобретатель+";"+Символы.ПС;
					КонецЕсли;
					Если Выборка.КоличествоНесоответствие <> 0 Тогда
						ТекстПроверкаКоличестваРСВ = ТекстПроверкаКоличестваРСВ + Выборка.Договор+" "+Выгодоприобретатель;
						ТекстПроверкаКоличестваРСВ = ТекстПроверкаКоличестваРСВ + Символы.ПС+"Расхождение на количество: "+Выборка.КоличествоНесоответствие+";"+Символы.ПС;
					КонецЕсли;
					Если Выборка.ЕстьЗаписьW8BENE_W8NEN И (Выборка.W8BENE_W8NEN = Справочники.ФормыW8.ПустаяСсылка() Или Выборка.W8BENE_W8NEN.ПометкаУдаления)Тогда
						ТекстПроверкаФормW8BENE_W8NEN = ТекстПроверкаФормW8BENE_W8NEN + Выборка.Договор+" "+Выгодоприобретатель+";"+Символы.ПС;
					КонецЕсли;
					Если Не Выборка.ПрямойКлиент И Выборка.ЕстьЗаписьW8IMY И (Выборка.W8IMY = Справочники.ФормыW8.ПустаяСсылка() Или Выборка.W8IMY.ПометкаУдаления) Тогда
						ТекстПроверкаФормW8IMY = ТекстПроверкаФормW8IMY + Выборка.Договор+" "+Выгодоприобретатель+";"+Символы.ПС;
					КонецЕсли;
					Если Выборка.ДУ И Не ЗначениеЗаполнено(Выборка.СубклиентДУ) Тогда
						ТекстПроверкаСубклиентаДУ = ТекстПроверкаСубклиентаДУ + Выборка.Договор+" "+Выборка.Клиент+";"+Символы.ПС;
					КонецЕсли;
					Если Выборка.СубклиентОбщегоРаздела И Не Выборка.ЕстьЗаписьW8BENE_W8NEN И Не Выборка.КоличествоРаскрытиеБольшеВТБКБ Тогда
						ТекстПроверкаСубклиентаОбщегоРаздела = ТекстПроверкаСубклиентаОбщегоРаздела + Выборка.Договор+" "+Выборка.Клиент+";"+Символы.ПС;
					КонецЕсли;
				КонецЦикла;
			КонецЦикла;
		КонецЦикла;
	КонецЦикла;
	
	Если ПустаяСтрока(ТекстПроверкаКоличестваРСВ) И ПустаяСтрока(ТекстПроверкаФормW8BENE_W8NEN) И ПустаяСтрока(ТекстПроверкаФормW8IMY) И
			ПустаяСтрока(ТекстПроверкаСтатусПоГлаве4) И ПустаяСтрока(ТекстПроверкаСубклиентаДУ) И ПустаяСтрока(ТекстПроверкаСубклиентаОбщегоРаздела) Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("*Проверка завершена, расхождений не обнаружено");
	КонецЕсли;
	Если Не ПустаяСтрока(ТекстПроверкаСтатусПоГлаве4) Тогда
		ТекстПроверкаСтатусПоГлаве4 = Символы.ПС+"*Не заполнен Код НРД в справочнике Статус US TAX CODE глава 4:"+Символы.ПС+ТекстПроверкаСтатусПоГлаве4;
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстПроверкаСтатусПоГлаве4);
	КонецЕсли;
	Если Не ПустаяСтрока(ТекстПроверкаКоличестваРСВ) Тогда
		ТекстПроверкаКоличестваРСВ = Символы.ПС+"*Проверка количества ЦБ в сводном РСВ:"+Символы.ПС+ТекстПроверкаКоличестваРСВ;
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстПроверкаКоличестваРСВ);
	КонецЕсли;
	Если Не ПустаяСтрока(ТекстПроверкаФормW8BENE_W8NEN) Тогда
		ТекстПроверкаФормW8BENE_W8NEN = Символы.ПС+"*Есть запись по форме W8BENE\W8NEN, но форма не указана или помечена на удаление:"+Символы.ПС+ТекстПроверкаФормW8BENE_W8NEN;
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстПроверкаФормW8BENE_W8NEN);
	КонецЕсли;
	Если Не ПустаяСтрока(ТекстПроверкаФормW8IMY) Тогда
		ТекстПроверкаФормW8IMY = Символы.ПС+"*Есть запись по форме W8IMY, но форма не указана или помечена на удаление:"+Символы.ПС+ТекстПроверкаФормW8IMY;
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстПроверкаФормW8IMY);
	КонецЕсли;
	Если Не ПустаяСтрока(ТекстПроверкаСубклиентаДУ) Тогда
		ТекстПроверкаСубклиентаДУ = Символы.ПС+"*Отсутствуют данные о субклиенте ДУ:"+Символы.ПС+ТекстПроверкаСубклиентаДУ;
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстПроверкаСубклиентаДУ);
	КонецЕсли;
	Если Не ПустаяСтрока(ТекстПроверкаСубклиентаОбщегоРаздела) Тогда
		ТекстПроверкаСубклиентаОбщегоРаздела = Символы.ПС+"*Не найдены формы W8BENE\W8NEN для субклиентов общего раздела:"+Символы.ПС+ТекстПроверкаСубклиентаОбщегоРаздела;
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстПроверкаСубклиентаОбщегоРаздела);
	КонецЕсли;
	
	ОбрабатываемыеВидыКД = Новый Массив;
	ОбрабатываемыеВидыКД.Добавить("DVCA");
	ОбрабатываемыеВидыКД.Добавить("INTR");
	ОбрабатываемыеВидыКД.Добавить("MCAL");
	ОбрабатываемыеВидыКД.Добавить("CAPG");
	Если Не ЗначениеЗаполнено(СвязанныйВидКД2) Или ОбрабатываемыеВидыКД.Найти(СвязанныйВидКД2.Код) = Неопределено Тогда
		ТекстПроверкаВидаКД2 = Символы.ПС+"*Связанный вид КД 2 не обрабатывается, налоговая ставка будет определена некорректно";
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстПроверкаВидаКД2);
	КонецЕсли;
	
	НеисполненныеПоручения = ЗапросНеисполненныхПоручений().Выполнить().Выбрать();
	Если НеисполненныеПоручения.Количество() > 0 Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Обнаружены неисполненные поручения:");
		Пока НеисполненныеПоручения.Следующий() Цикл
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("	"+НеисполненныеПоручения.Ссылка+" ("+НеисполненныеПоручения.ВидОперацииД+")");
		КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры

//Возвращает результат запроса для заполнения Сводного раскрытия списка владельцев
//
// Параметры:
//  ВыводитьДанныеДляПроверки - Булево (по умолчанию: Ложь) - при указании значения Истина в выборку будут
// включены строки для анализа расхождений данных ВТБКБ и ответов на раскрытие
// 
// Возвращаемое значение:
//  РезультатЗапроса
//
Функция ВыборкаДанныхЗаполненияСводногоРСВ(ВыводитьДанныеДляПроверки = Ложь) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = ТекстЗапросаДанныеЗаполненияСводногоРСВ();
	
	Если ОстаткиНаУтро Тогда
		ГраницаРасчета	= Новый Граница(НачалоДня(ДатаФиксации), ВидГраницы.Исключая);
	Иначе
		ГраницаРасчета	= КонецДня(ДатаФиксации);
	КонецЕсли;
	Запрос.УстановитьПараметр("ДатаОстатков", ГраницаРасчета);
	Запрос.УстановитьПараметр("СчетДепоМХ"	, СчетДЕПО);
	
	ЦеннаяБумага = Новый СписокЗначений;
	Если ЗначениеЗаполнено(ЦеннаяБумага1) Тогда
		ЦеннаяБумага.Добавить(ЦеннаяБумага1);
	КонецЕсли;
	Если ЗначениеЗаполнено(ЦеннаяБумага2) Тогда
		ЦеннаяБумага.Добавить(ЦеннаяБумага2);
	КонецЕсли;
	Запрос.УстановитьПараметр("ЦеннаяБумага", ЦеннаяБумага);
	Запрос.УстановитьПараметр("СвязанныйВидКД", СвязанныйВидКД2.Код);
	Запрос.УстановитьПараметр("РезультатыПоРСВ", СписокВладельцев.Выгрузить());
	Запрос.УстановитьПараметр("ТипыСчетаДепоНДИНД", БизнесПроцессы.ОбработкаWTRCСообщения.ТипыСчетовНДИНД());
	Запрос.УстановитьПараметр("W8BENE_W8NEN", Справочники.ВидыДокументовУдостоверяющихПолномочия.ФормаW8BENE_W8BEN);
	Запрос.УстановитьПараметр("W8IMY", Справочники.ВидыДокументовУдостоверяющихПолномочия.ФормаW8IMY);
	Запрос.УстановитьПараметр("ФизЛицо", Перечисления.ЮрФизЛицо.ФизЛицо);
	Запрос.УстановитьПараметр("ТипФормыW8IMY", Перечисления.ТипыФормW8.ФормаW8IMY);
	Запрос.УстановитьПараметр("ДатаФиксации", ДатаФиксации);
	Запрос.УстановитьПараметр("ВыводитьДанныеДляПроверки", ВыводитьДанныеДляПроверки);
	Запрос.УстановитьПараметр("СубклиентПустаяСсылка", Справочники.Субклиенты.ПустаяСсылка());
	Запрос.УстановитьПараметр("DVCA", "DVCA");
	Запрос.УстановитьПараметр("INTR", "INTR");
	Запрос.УстановитьПараметр("MCAL", "MCAL");
	Запрос.УстановитьПараметр("NPFFI", "NPFFI");
	Запрос.УстановитьПараметр("INDV", "INDV");
	Запрос.УстановитьПараметр("CAPG", "CAPG");
	Запрос.УстановитьПараметр("ДатаРСВ", Дата);
	Запрос.УстановитьПараметр("ЮрЛицоПустаяСсылка", Справочники.ЮридическиеЛица.ПустаяСсылка());
	Запрос.УстановитьПараметр("ТипФормыW8BEN", Перечисления.ТипыФормW8.ФормаW8BEN);
	Запрос.УстановитьПараметр("ТипФормыW8BENE", Перечисления.ТипыФормW8.ФормаW8BENE);
	Запрос.УстановитьПараметр("ТекстREIT", "%REIT%");
	
	СтраныСНалоговойСтавкой30ПоREIT = Новый Массив;
	СтраныСНалоговойСтавкой30ПоREIT.Добавить(Справочники.КлассификаторСтранМира.РОССИЯ);
	СтраныСНалоговойСтавкой30ПоREIT.Добавить(Справочники.КлассификаторСтранМира.Украина());
	СтраныСНалоговойСтавкой30ПоREIT.Добавить(Справочники.КлассификаторСтранМира.Казахстан());
	Запрос.УстановитьПараметр("СтраныСНалоговойСтавкой30ПоREIT", СтраныСНалоговойСтавкой30ПоREIT);
	
	Возврат Запрос.Выполнить();

КонецФункции

Функция ТекстЗапросаДанныеЗаполненияСводногоРСВ()
	
	ТекстЗапроса =
	"ВЫБРАТЬ
	|	Договоры.Ссылка КАК Договор,
	|	Остатки.СчетДепо КАК СчетДепо,
	|	Остатки.РазделСчетаДепо КАК РазделСчетаДепо,
	|	Остатки.КоличествоОстаток КАК Количество,
	|	ВЫБОР
	|		КОГДА Остатки.СчетДепо.Владелец.Субброкер
	|				И Остатки.РазделСчетаДепо.РазделСубклиента
	|			ТОГДА Остатки.РазделСчетаДепо.Субклиент
	|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.Субклиенты.ПустаяСсылка)
	|	КОНЕЦ КАК Выгодоприобретатель,
	|	Остатки.СчетДепо.Владелец КАК Клиент,
	|	Остатки.СчетДепоМХ КАК СчетДепоМХ,
	|	Остатки.РазделСчетаДепоМХ КАК РазделСчетаДепоМХ
	|ПОМЕСТИТЬ ДанныеВТБКБ
	|ИЗ
	|	РегистрНакопления.ОстаткиЦБМестоРасчетов.Остатки(
	|			&ДатаОстатков,
	|			ЦБ В (&ЦеннаяБумага)
	|				И СчетДепоМХ = &СчетДепоМХ) КАК Остатки
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ДоговорыКонтрагентов КАК Договоры
	|		ПО Остатки.СчетДепо.Владелец = Договоры.Владелец
	|			И (НЕ Договоры.ПометкаУдаления)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВЫРАЗИТЬ(РезультатыПоРСВ.Договор КАК Справочник.ДоговорыКонтрагентов) КАК Договор,
	|	РезультатыПоРСВ.Количество КАК Количество,
	|	ВЫРАЗИТЬ(РезультатыПоРСВ.СчетДепо КАК Справочник.СчетаДепо) КАК СчетДепо,
	|	ВЫРАЗИТЬ(РезультатыПоРСВ.РазделСчетаДепо КАК Справочник.РазделыСчетаДепо) КАК РазделСчетаДепо,
	|	ВЫРАЗИТЬ(РезультатыПоРСВ.Выгодоприобретатель КАК Справочник.Субклиенты) КАК Выгодоприобретатель,
	|	ВЫРАЗИТЬ(РезультатыПоРСВ.Клиент КАК Справочник.Контрагенты) КАК Клиент,
	|	ВЫБОР
	|		КОГДА ВЫРАЗИТЬ(РезультатыПоРСВ.Клиент КАК Справочник.Контрагенты).Субброкер
	|			ТОГДА ВЫРАЗИТЬ(РезультатыПоРСВ.Выгодоприобретатель КАК Справочник.Субклиенты).Наименование
	|		ИНАЧЕ ВЫРАЗИТЬ(РезультатыПоРСВ.Клиент КАК Справочник.Контрагенты).Наименование
	|	КОНЕЦ КАК Бенефициар,
	|	РезультатыПоРСВ.ЕстьРасхождения КАК ЕстьРасхождения,
	|	ВЫРАЗИТЬ(РезультатыПоРСВ.ОтветНаРСВ КАК Документ.ОтветСубброкераНаРаскрытие) КАК ОтветНаРСВ,
	|	РезультатыПоРСВ.Выгодоприобретатель КАК ВыгодоприобретательОбщийРаздел
	|ПОМЕСТИТЬ ДанныеПоРаскрытию
	|ИЗ
	|	&РезультатыПоРСВ КАК РезультатыПоРСВ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ДанныеВТБКБ.Договор КАК Договор,
	|	ДанныеВТБКБ.СчетДепо КАК СчетДепо,
	|	ДанныеВТБКБ.РазделСчетаДепо КАК РазделСчетаДепо,
	|	ВЫБОР
	|		КОГДА ЕСТЬNULL(ДанныеРаскрытияПоОбщимРазделамИтогоНДИНД.Количество, 0) = ДанныеВТБКБ.Количество
	|			ТОГДА ДанныеВТБКБ.Количество
	|		КОГДА ЕСТЬNULL(ДанныеРаскрытияПоОбщимРазделамИтогоНДИНД.Количество, 0) < ДанныеВТБКБ.Количество
	|			ТОГДА ЕСТЬNULL(ДанныеРаскрытияПоОбщимРазделамИтогоНДИНД.Количество, 0)
	|		ИНАЧЕ 0
	|	КОНЕЦ КАК КоличествоРаскрытые,
	|	ВЫБОР
	|		КОГДА ЕСТЬNULL(ДанныеРаскрытияПоОбщимРазделамИтогоНДИНД.Количество, 0) > ДанныеВТБКБ.Количество
	|			ТОГДА ДанныеВТБКБ.Количество
	|		КОГДА ЕСТЬNULL(ДанныеРаскрытияПоОбщимРазделамИтогоНДИНД.Количество, 0) < ДанныеВТБКБ.Количество
	|			ТОГДА ДанныеВТБКБ.Количество - ЕСТЬNULL(ДанныеРаскрытияПоОбщимРазделамИтогоНДИНД.Количество, 0)
	|		ИНАЧЕ 0
	|	КОНЕЦ КАК КоличествоНераскрытые,
	|	ДанныеВТБКБ.Клиент КАК Клиент,
	|	ВЫБОР
	|		КОГДА ЕСТЬNULL(ДанныеРаскрытияПоОбщимРазделамИтогоНДИНД.Количество, 0) > ДанныеВТБКБ.Количество
	|			ТОГДА ЕСТЬNULL(ДанныеРаскрытияПоОбщимРазделамИтогоНДИНД.Количество, 0) - ДанныеВТБКБ.Количество
	|		КОГДА ЕСТЬNULL(ДанныеРаскрытияПоОбщимРазделамИтогоНДИНД.Количество, 0) < ДанныеВТБКБ.Количество
	|			ТОГДА ДанныеВТБКБ.Количество - ЕСТЬNULL(ДанныеРаскрытияПоОбщимРазделамИтогоНДИНД.Количество, 0)
	|		ИНАЧЕ 0
	|	КОНЕЦ КАК КоличествоНесоответствие,
	|	ЕСТЬNULL(ДанныеРаскрытияПоОбщимРазделамИтогоНДИНД.Количество, 0) = ДанныеВТБКБ.Количество КАК КоличествоРаскрытиеСоответствуетВТБКБ,
	|	ЕСТЬNULL(ДанныеРаскрытияПоОбщимРазделамИтогоНДИНД.Количество, 0) < ДанныеВТБКБ.Количество КАК КоличествоРаскрытиеМеньшеВТБКБ,
	|	ДанныеВТБКБ.Количество КАК Количество,
	|	ДанныеВТБКБ.СчетДепоМХ КАК СчетДепоМХ,
	|	ДанныеВТБКБ.РазделСчетаДепоМХ КАК РазделСчетаДепоМХ
	|ПОМЕСТИТЬ ДанныеВТБКБОбщиеРазделыОпределениеРаскрытых
	|ИЗ
	|	ДанныеВТБКБ КАК ДанныеВТБКБ
	|		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	|			РезультатыПоРСВ.Договор КАК Договор,
	|			РезультатыПоРСВ.Клиент КАК Клиент,
	|			РезультатыПоРСВ.СчетДепо КАК СчетДепо,
