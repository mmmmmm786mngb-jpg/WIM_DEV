Процедура СформироватьТекстСообщения() Экспорт
	ДатаКДПлан = КарточкаКД.ДатаПроведенияСобрания;
	ЗаголовокСообщения = "Поступила информация о регистрации списка владельцев ценных бумаг";
	ЗаполнитьТекстСообщенияУведомлениеОФактеРаскрытия();
КонецПроцедуры

Процедура ЗаполнитьТекстСообщенияУведомлениеОФактеРаскрытия()
	
	Подпись = Документы.УведомлениеКлиентам.ПодписьСообщения(Дата);
	
	ReplaceFields = Новый Структура;
	ReplaceFields.Вставить("Имя", "");
	ReplaceFields.Вставить("Фамилия", "");
	ReplaceFields.Вставить("НомерДоговора", "");
	ReplaceFields.Вставить("ДатаДоговора", "");
	ReplaceFields.Вставить("ВидКД", ФорматОбязательнойСтроки(КарточкаКД.ВидКД.Наименование));
	ReplaceFields.Вставить("НаименованиеЭмитента", Справочники.ЦенныеБумаги.НаименованиеЭмитента(КарточкаКД.ЦеннаяБумага1));
	ReplaceFields.Вставить("ISIN", КарточкаКД.ЦеннаяБумага1.ISIN);
	ReplaceFields.Вставить("КДРеференс", ФорматОбязательнойСтроки(КарточкаКД.КДРеференс));
	ReplaceFields.Вставить("ДатаКДПлан", ФорматОбязательнойДаты(ДатаКДПлан));
	ReplaceFields.Вставить("Подпись", Подпись);
	
	Data = Новый Структура();
	Data.Вставить("NotificationType", "Client");
	Data.Вставить("CrmClientId", Неопределено);
	Data.Вставить("Email", Неопределено);
	Data.Вставить("MailTemplateId", Неопределено);
	Data.Вставить("MailTemplateTitle", "ОРаскрытиеСпискаВладельцевЦБ");
	Data.Вставить("ReplaceFields", ReplaceFields); 
	
	MessageInfo = РаботаСJSON.СтруктураMessageInfo();
	MessageInfo.Вставить("MessageType", "Email");
	MessageInfo.Вставить("JsonVersion", "1.0.0");
	MessageInfo.Вставить("SystemSource", "Depo");
	MessageInfo.Вставить("ParentMessageId", Неопределено);
	MessageInfo.Вставить("ActionType", "INS");
	
	ТелоСообщения = РаботаСJSON.ТекстСообщенияJSON(MessageInfo, Data);
	
КонецПроцедуры

Функция ФорматОбязательнойСтроки(Стр)
	Если ЗначениеЗаполнено(Стр) Тогда
		Возврат	СокрЛП(Стр);
	Иначе
		Возврат "Данные отсутствуют";
	КонецЕсли;
КонецФункции

Функция ФорматОбязательнойДаты(Д)
	Если ЗначениеЗаполнено(Д) Тогда
		Возврат	Формат(Д, "ДЛФ=Д");
	Иначе
		Возврат "Данные отсутствуют";
	КонецЕсли;
КонецФункции

Процедура ПодготовитьУведомлениеОРаскрытииСпискаВладельцевЦБ() Экспорт
	Клиенты = СписокКлиентовДляОтправкиУведомлений();
	Ошибки = ОшибкиПроверкиВозможностиОтправкиУведомления(Клиенты.Количество());
	Если ЗначениеЗаполнено(Ошибки) Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Уведомление о раскрытии списка владельцев ЦБ не добавлено в регистр сведений ""Журнал исходящих сообщений Kafka"": "
		+ Ссылка + " по причине:" + Символы.ПС + Ошибки);
		ЗаписьЖурналаРегистрации("Уведомление о раскрытии списка владельцев ЦБ", УровеньЖурналаРегистрации.Предупреждение,,
		Ссылка, "Уведомление не добавлено в регистр сведений ""Журнал исходящих сообщений Kafka"" по причине: " + Ошибки);
	Иначе
		ВнешнийИсточник = ПланыВидовХарактеристик.ВнешниеИсточники.KafkaEmail;
		ПодготовитьУведомлениеИнформационное(Клиенты, ВнешнийИсточник);
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Уведомление о раскрытии списка владельцев ЦБ добавлено в регистр сведений ""Журнал исходящих сообщений Kafka"" " + Ссылка);
	КонецЕсли;
КонецПроцедуры

Процедура ОтправитьУведомлениеОРаскрытииСпискаВладельцевЦБ(ОбработкаВебСервисы = Неопределено) Экспорт
	Клиенты = СписокКлиентовДляОтправкиУведомлений();
	Ошибки = ОшибкиПроверкиВозможностиОтправкиУведомления(Клиенты.Количество());
	Если ЗначениеЗаполнено(Ошибки) Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не отправлено уведомление о раскрытии списка владельцев ЦБ: "
		+ Ссылка + " по причине:" + Символы.ПС + Ошибки);
		ЗаписьЖурналаРегистрации("Уведомление о раскрытии списка владельцев ЦБ", УровеньЖурналаРегистрации.Предупреждение,,
		Ссылка, "Уведомление не отправлено по причине: " + Ошибки);
	Иначе
		Успешно = ОтправитьУведомлениеИнформационное(ЗаголовокСообщения, ТелоСообщения, Клиенты, ОбработкаВебСервисы);
		
		Если Успешно Тогда
			ТекущийМомент = ТекущаяДата();
			РегистрыСведений.УведомленияОтправленныеЧерезЛичныйКабинет.ЗафиксироватьУведомления(ТекущийМомент, Ссылка, Клиенты);
			
			Запись = РегистрыСведений.ЭтапыКД.СоздатьМенеджерЗаписи();
			Запись.Период					= ТекущийМомент;
			Запись.КД						= Ссылка;
			Запись.КодОтчета				= "";
			Запись.НомерСообщения			= "";
			Запись.НомерСообщенияИсходный	= "";
			Запись.Исходящее				= Истина;
			Запись.ТипУведомления			= Справочники.ТипыУведомления.NEWM();
			Запись.ЭтапКД					= Справочники.ЭтапыКД.УведомлениеКлиентов;
			Запись.Записать();
			
			УведомлениеОтправлено = Истина;
			Записать();
			РезультатОтправки = "Отправлено";
		Иначе
			РезультатОтправки = "Не отправлено";
		КонецЕсли;
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(РезультатОтправки + " уведомление о раскрытии списка владельцев ЦБ " + Ссылка);
	КонецЕсли;
КонецПроцедуры

Функция ОшибкиПроверкиВозможностиОтправкиУведомления(КоличествоКлиентов)
	Ошибки = Новый Массив;
	
	Если УведомлениеОтправлено Тогда
		Ошибки.Добавить("Уведомление уже отправлено");
	КонецЕсли;
	
	Если ПометкаУдаления Тогда
		Ошибки.Добавить("Документ помечен на удаление");
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(ДатаИсполнения) Тогда
		Ошибки.Добавить("Не указана дата исполнения");
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(ДатаКДПлан) Тогда
		Ошибки.Добавить("Не указана дата КД (план)");
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(ЗаголовокСообщения) Тогда
		Ошибки.Добавить("Не заполнен заголовок сообщения");
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(ТелоСообщения) Тогда
		Ошибки.Добавить("Не заполнено тело сообщения");
	КонецЕсли;
	
	Если КоличествоКлиентов = 0 Тогда
		Ошибки.Добавить("Не указаны владельцы ЦБ");
	КонецЕсли;
	
	Возврат СтроковыеФункцииКлиентСервер.ПолучитьСтрокуИзМассиваПодстрок(Ошибки, Символы.ПС);
КонецФункции

Функция СписокКлиентовДляОтправкиУведомлений()
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	ТЗ.Клиент КАК Клиент,
	|	ТЗ.Договор КАК Договор,
	|	ТЗ.СчетДепо КАК СчетДепо,
	|	ТЗ.ЦеннаяБумага КАК ЦеннаяБумага,
	|	ТЗ.Количество КАК Количество
	|ПОМЕСТИТЬ втТЗ
	|ИЗ
	|	&ТЗ КАК ТЗ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТЗ.Клиент КАК Клиент,
	|	ТЗ.Договор КАК Договор,
	|	ТЗ.СчетДепо КАК СчетДепо,
	|	ТЗ.ЦеннаяБумага КАК ЦеннаяБумага,
	|	СУММА(ТЗ.Количество) КАК Количество
	|ПОМЕСТИТЬ втСписокВладельцев
	|ИЗ
	|	втТЗ КАК ТЗ
	|
	|СГРУППИРОВАТЬ ПО
	|	ТЗ.Клиент,
	|	ТЗ.Договор,
	|	ТЗ.СчетДепо,
	|	ТЗ.ЦеннаяБумага
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СписокВладельцев.Клиент КАК Клиент,
	|	СписокВладельцев.Клиент.СпособОтправкиОтчетов КАК СпособОтправкиОтчетов,
	|	СписокВладельцев.Договор КАК Договор,
	|	СписокВладельцев.СчетДепо КАК СчетДепо,
	|	&РазделСчетаДепо КАК РазделСчетаДепо,
	|	СписокВладельцев.ЦеннаяБумага КАК ЦеннаяБумага,
	|	СписокВладельцев.Количество КАК Количество,
	|	КодыЗагрузкиКлиента.Код КАК ClientId,
	|	СписокВладельцев.Договор.Код КАК НомерДоговора,
	|	СписокВладельцев.Договор.ДатаНачалоДействия КАК ДатаДоговора,
	|	ВЫБОР
	|		КОГДА СписокВладельцев.Клиент.ЮридическиеФизическиеЛица ССЫЛКА Справочник.ФизическиеЛица
	|			ТОГДА ЕСТЬNULL(ФИОФизЛицСрезПоследних.Фамилия, """")
	|		ИНАЧЕ ""клиент""
	|	КОНЕЦ КАК Фамилия,
	|	ВЫБОР
	|		КОГДА СписокВладельцев.Клиент.ЮридическиеФизическиеЛица ССЫЛКА Справочник.ФизическиеЛица
	|			ТОГДА ЕСТЬNULL(ФИОФизЛицСрезПоследних.Имя, """")
	|		ИНАЧЕ СписокВладельцев.Клиент.Наименование
	|	КОНЕЦ КАК Имя
	|ИЗ
	|	втСписокВладельцев КАК СписокВладельцев
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.КодыЗагрузки КАК КодыЗагрузкиКлиента
	|		ПО СписокВладельцев.Клиент.ЮридическиеФизическиеЛица = КодыЗагрузкиКлиента.Владелец
	|			И (НЕ КодыЗагрузкиКлиента.ПометкаУдаления)
	|			И (КодыЗагрузкиКлиента.Биржа = &КлассификаторыЗагрузкиКлиенты)
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ФИОФизЛиц.СрезПоследних(
	|				,
	|				ФизЛицо В
	|					(ВЫБРАТЬ
	|						втСписокВладельцев.Клиент.ЮридическиеФизическиеЛица КАК КлиентЮридическиеФизическиеЛица
	|					ИЗ
	|						втСписокВладельцев КАК втСписокВладельцев)) КАК ФИОФизЛицСрезПоследних
	|		ПО СписокВладельцев.Клиент.ЮридическиеФизическиеЛица = ФИОФизЛицСрезПоследних.ФизЛицо");
	Запрос.УстановитьПараметр("ТЗ", СписокВладельцев.Выгрузить());
	Запрос.УстановитьПараметр("РазделСчетаДепо", Справочники.РазделыСчетаДепо.ПустаяСсылка());
	Запрос.УстановитьПараметр("КлассификаторыЗагрузкиКлиенты", Справочники.КлассификаторыЗагрузки.Клиенты);
	Возврат Запрос.Выполнить().Выгрузить();
КонецФункции

Процедура ПодготовитьУведомлениеИнформационное(Клиенты, ВнешнийИсточник)
	
	ЧтениеJSON = Новый ЧтениеJSON;
	ЧтениеJSON.УстановитьСтроку(ТелоСообщения);
	ОбъектJSON = ПрочитатьJSON(ЧтениеJSON);
	ЧтениеJSON.Закрыть();
	
	ТаблицаКлиентов = Клиенты.Скопировать(, "ClientId, НомерДоговора, ДатаДоговора, Фамилия, Имя, СпособОтправкиОтчетов");
	ТаблицаКлиентов.Свернуть("ClientId, НомерДоговора, ДатаДоговора, Фамилия, Имя, СпособОтправкиОтчетов");
	ТаблицаКлиентов.Колонки.Добавить("MessageId");
	Для Каждого СтрокаТЗ Из ТаблицаКлиентов Цикл
		СтрокаТЗ.MessageId = Строка(Новый УникальныйИдентификатор());
	КонецЦикла;
	
	ИдентификаторыКлиентов = ОбщегоНазначения.ТаблицаЗначенийВМассив(ТаблицаКлиентов);
	
	Для Каждого ИдентификаторКлиента Из ИдентификаторыКлиентов Цикл
		Документы.УведомлениеКлиентам.ПоместитьСообщениеВРегистрКОтправке(ВнешнийИсточник, ИдентификаторКлиента, ОбъектJSON, Ссылка);
	КонецЦикла;
	
КонецПроцедуры

Функция ОтправитьУведомлениеИнформационное(ЗаголовокСообщения, ТекстСообщения, Клиенты, ОбработкаВебСервисы)
	// Каждое сообщение должно быть опубликовано в кабинете клиента только 1 раз
	ТаблицаКлиентов = Клиенты.Скопировать(, "ClientId");
	ТаблицаКлиентов.Свернуть("ClientId");
	ИдентификаторыКлиентов = ТаблицаКлиентов.ВыгрузитьКолонку("ClientId");
	
	Возврат ВебСервисыСервер.РезультатОтправкиУведомленияИнформационного(ИдентификаторыКлиентов, ЗаголовокСообщения,
				ТекстСообщения, Строка(Ссылка.УникальныйИдентификатор()), ОбработкаВебСервисы);
КонецФункции


Процедура СверкаСтавок() Экспорт
	
	СтавкиW8ПоДаннымДЕПО = ДанныеДляСверки();
	
	Если СтавкиW8ПоДаннымДЕПО.Пустой() тогда
		Возврат;
	КонецЕсли;
	
	Соединение = Неопределено;
	НастройкиСоединения = Неопределено;
	ТокенАвторизации = Неопределено;
	КэшНастроекСоединения = новый Соответствие;
	
	НастройкиСоединения = НастройкиСоединенияW8B(КэшНастроекСоединения, Перечисления.ТипыФормW8.ФормаW8BENE);
	НастройкиСоединенияIMY = НастройкиСоединенияW8B(КэшНастроекСоединения, Перечисления.ТипыФормW8.ФормаW8IMY);
	
	Если Не ЗначениеЗаполнено(НастройкиСоединения) Или  Не ЗначениеЗаполнено(НастройкиСоединенияIMY) Тогда
		ТекстСообщения = "Не заданы настройки соежинения для сервисов W8";
		ОбщегоНазначения.СообщитьОбОшибке(ТекстСообщения);
		Возврат;
	КонецЕсли;
	
	ПодключитьИсточник(Соединение, НастройкиСоединения, ТокенАвторизации);
	
	Если Соединение = Неопределено Тогда
		Возврат;
	КонецЕсли;
		
	Если ЗначениеЗаполнено(ТокенАвторизации) Тогда
		Заголовки = Новый Соответствие;
		Заголовки.Вставить("Authorization", "Bearer " + ТокенАвторизации);
	КонецЕсли;
	
	HTTPЗапрос = Новый HTTPЗапрос();
		
	Ошибки = Неопределено;
	Выборка = СтавкиW8ПоДаннымДЕПО.Выбрать();
	Пока Выборка.Следующий() Цикл
		
		ТипСервиса = (ТипЗнч(Выборка.Бенефициар) = Тип("СправочникСсылка.Субклиенты") или Выборка.УправляющаяКомпания);
		НастройкиСоединения = НастройкиСоединенияW8B(КэшНастроекСоединения, Выборка.ТипФормы, ТипСервиса);
		Если не ЗначениеЗаполнено(НастройкиСоединения) Тогда
			Продолжить;
		КонецЕсли;
			
		DocumentID = Выборка.DocumentID;
		DocumentID_IMY = Выборка.DocumentID_IMY;
								
		ДанныеСервисаW8 = ДанныеСервисаW8(DocumentID, Соединение, НастройкиСоединения, HTTPЗапрос, Заголовки);
		Если ДанныеСервисаW8 = Неопределено Тогда
			СообщениеОбОшибке =	СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку("N договора %1, конечный бенефициар %2. Форма не найдена в СУДК по id: %3",
				СокрЛП(Выборка.Договор), Выборка.Бенефициар, DocumentID);
			ОбщегоНазначенияКлиентСервер.ДобавитьОшибкуПользователю(Ошибки,,СообщениеОбОшибке);
			Продолжить;
		КонецЕсли;
		
		Если Выборка.ТипФормы <> Перечисления.ТипыФормW8.ФормаW8IMY Тогда
			
			СтавкаПоДивидендам = ДанныеСервисаW8.document.dividends;
			СтавкаПоКупону = ДанныеСервисаW8.document.interest;
			
			Если Выборка.СтавкаКупоны <> СтавкаПоКупону или Выборка.СтавкаДивиденды <> СтавкаПоДивидендам Тогда
				ТекстСообщения = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку("Выявлены расхождения в налоговых ставках для Договора %1, Конечный бенефициар %2.
					|	По данным СУДК ставка дивиденды/купоны '%3/%4', по данным 1С ставка дивиденды/купоны '%5/%6'", 
				СокрЛП(Выборка.Договор), Выборка.Бенефициар, СтавкаПоДивидендам, СтавкаПоКупону,Выборка.СтавкаДивиденды, Выборка.СтавкаКупоны);
				ОбщегоНазначенияКлиентСервер.ДобавитьОшибкуПользователю(Ошибки,,ТекстСообщения);
			КонецЕсли;
			
		КонецЕсли;
		
		Статус4 = СокрЛП(ДанныеСервисаW8.document.statusCodeChapter4);			
		Статус4ПоW8 = Формат(Выборка.СтатусПоГлаве4USTAXCODEКод, "ЧЦ=2; ЧВН=");
		
		Если Статус4ПоW8 <> Статус4 Тогда
			ТекстСообщения = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку("Выявлены расхождения по 'Статус по главе 4 US Tax Code' для Договора %1, Конечный бенефициар %2.
				|	По данным СУДК статус '%3', по данным 1С '%4'", 
			СокрЛП(Выборка.Договор), Выборка.Бенефициар, Статус4, Статус4ПоW8);
			ОбщегоНазначенияКлиентСервер.ДобавитьОшибкуПользователю(Ошибки,,ТекстСообщения);
		КонецЕсли;
		
		Если ЗначениеЗаполнено(DocumentID_IMY) Тогда 
			
			ДанныеСервисаW8IMY = ДанныеСервисаW8(DocumentID_IMY, Соединение, НастройкиСоединенияIMY, HTTPЗапрос, Заголовки);
			Если ДанныеСервисаW8IMY = Неопределено Тогда
				СообщениеОбОшибке = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку("Посредник %1. Форма не найдена в СУДК по id: %2",
					Выборка.Посредник, DocumentID_IMY);
				ОбщегоНазначенияКлиентСервер.ДобавитьОшибкуПользователю(Ошибки,,СообщениеОбОшибке);
			Иначе 
				Статус4IMY = СокрЛП(ДанныеСервисаW8IMY.document.statusCodeChapter4);			
				Статус4ПоW8IMY = Формат(Выборка.СтатусПоГлаве4USTAXCODEКод_IMY, "ЧЦ=2; ЧВН=");
				
				Если Статус4ПоW8IMY <> Статус4IMY Тогда
					ТекстСообщения = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку("Выявлены расхождения по 'Статус по главе 4 US Tax Code'. Посредник %1.
						|	По данным СУДК статус '%2', по данным 1С '%3'", 
					СокрЛП(Выборка.Посредник), Статус4IMY, Статус4ПоW8IMY);
					ОбщегоНазначенияКлиентСервер.ДобавитьОшибкуПользователю(Ошибки,,ТекстСообщения);
				КонецЕсли;
				
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЦикла;

	Если ЗначениеЗаполнено(Ошибки) Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьОшибкиПользователю(Ошибки)
	Иначе 
		ТекстСообщения = "Выполнена сверка - расхождений не выявлено";
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
	КонецЕсли;
	
КонецПроцедуры

Функция ДанныеДляСверки()
	
	ТипыКлиентов = Новый Массив;
	ТипыКлиентов.Добавить(Тип("СправочникСсылка.Контрагенты"));
	ТипыКлиентов.Добавить(Тип("СправочникСсылка.Субклиенты"));
	ТипыКлиентов.Добавить(Тип("СправочникСсылка.ЮридическиеЛица"));
	ТипыКлиентов.Добавить(Тип("СправочникСсылка.ФизическиеЛица"));

	ДанныеВТБ = Новый ТаблицаЗначений;
	ДанныеВТБ.Колонки.Добавить("Бенефициар", Новый ОписаниеТипов(ТипыКлиентов));
	ДанныеВТБ.Колонки.Добавить("Посредник", Новый ОписаниеТипов(ТипыКлиентов));
	ДанныеВТБ.Колонки.Добавить("Договор", Новый ОписаниеТипов("СправочникСсылка.ДоговорыКонтрагентов"));
	ДанныеВТБ.Колонки.Добавить("W8BENE_W8NEN", Новый ОписаниеТипов("СправочникСсылка.ФормыW8"));
	ДанныеВТБ.Колонки.Добавить("W8IMY", Новый ОписаниеТипов("СправочникСсылка.ФормыW8"));
	 
	Если СводноеРаскрытие.Количество() > 0 Тогда
		Для Каждого Строка Из СводноеРаскрытие Цикл
			Если ЗначениеЗаполнено(Строка.Бенефициар) И ЗначениеЗаполнено(Строка.W8BENE_W8NEN) Тогда
				ЗаполнитьЗначенияСвойств(ДанныеВТБ.Добавить(), Строка); 		
			КонецЕсли;
		КонецЦикла;
	Иначе
		РезультатЗапроса = ВыборкаДанныхЗаполненияСводногоРСВ();
		Выборка = РезультатЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "");
		Пока Выборка.Следующий() Цикл
			Если ЗначениеЗаполнено(Выборка.Бенефициар) И ЗначениеЗаполнено(Выборка.W8BENE_W8NEN) Тогда
				ЗаполнитьЗначенияСвойств(ДанныеВТБ.Добавить(), Выборка); 		
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	втДанные.Бенефициар КАК Бенефициар,
	|	втДанные.Посредник КАК Посредник,
	|	втДанные.Договор КАК Договор,
	|	втДанные.W8BENE_W8NEN КАК W8BENE_W8NEN,
	|	втДанные.W8IMY КАК W8IMY
	|ПОМЕСТИТЬ вт
	|ИЗ
	|	&втДанные КАК втДанные
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	вт.Бенефициар КАК Бенефициар,
	|	вт.Договор КАК Договор,
	|	вт.Посредник КАК Посредник,
	|	ВЫБОР
	|		КОГДА вт.Бенефициар ССЫЛКА Справочник.Контрагенты
	|			ТОГДА ВЫРАЗИТЬ(вт.Бенефициар КАК Справочник.Контрагенты).ЮрФизЛицо
	|		КОГДА вт.Бенефициар ССЫЛКА Справочник.Субклиенты
	|			ТОГДА ВЫРАЗИТЬ(вт.Бенефициар КАК Справочник.Субклиенты).ЮрФизЛицо
	|		КОГДА вт.Бенефициар ССЫЛКА Справочник.ФизическиеЛица
	|			ТОГДА ЗНАЧЕНИЕ(Перечисление.ЮрФизЛицо.ФизЛицо)
	|		КОГДА вт.Бенефициар ССЫЛКА Справочник.ЮридическиеЛица
	|			ТОГДА ЗНАЧЕНИЕ(Перечисление.ЮрФизЛицо.ЮрЛицо)
	|	КОНЕЦ КАК ТипКлиента,
	|	ФормыW8.СтавкаКупоны КАК СтавкаКупоны,
	|	ФормыW8.СтавкаДивиденды КАК СтавкаДивиденды,
	|	ФормыW8.DocumentID КАК DocumentID,
	|	ФормыW8.СтатусПоГлаве4USTAXCODE.Код КАК СтатусПоГлаве4USTAXCODEКод,
	|	ФормыW8.ТипФормы КАК ТипФормы,
	|	ЕСТЬNULL(ФормыW8_IMY.DocumentID, """") КАК DocumentID_IMY,
	|	ФормыW8_IMY.СтатусПоГлаве4USTAXCODE.Код КАК СтатусПоГлаве4USTAXCODEКод_IMY,
	|	ЕСТЬNULL(ВЫРАЗИТЬ(вт.Бенефициар КАК Справочник.Контрагенты).УправляющаяКомпания, ЛОЖЬ) КАК УправляющаяКомпания
	|ИЗ
	|	вт КАК вт
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ФормыW8 КАК ФормыW8
	|		ПО вт.W8BENE_W8NEN = ФормыW8.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ФормыW8 КАК ФормыW8_IMY
	|		ПО вт.W8IMY = ФормыW8_IMY.Ссылка";

	Запрос.УстановитьПараметр("втДанные",ДанныеВТБ); 
	РезультатЗапроса = Запрос.Выполнить();
	
	Возврат РезультатЗапроса;

КонецФункции

Функция НастройкиСоединенияW8B(КэшНастроекСоединения, ТипФормы, ИспользоватьСервисСубклиентов = Ложь)
	
	Если ТипФормы = Перечисления.ТипыФормW8.ФормаW8BEN Тогда
		Источник = ?(ИспользоватьСервисСубклиентов, ПланыВидовХарактеристик.ВнешниеИсточники.HTTPСервисДокументыW8BEN_Субклиенты, ПланыВидовХарактеристик.ВнешниеИсточники.HTTPСервисДокументыW8BEN);
	ИначеЕсли ТипФормы = Перечисления.ТипыФормW8.ФормаW8BENE Тогда
		Источник = ?(ИспользоватьСервисСубклиентов, ПланыВидовХарактеристик.ВнешниеИсточники.HTTPСервисДокументыW8BENE_Субклиенты, ПланыВидовХарактеристик.ВнешниеИсточники.HTTPСервисДокументыW8BENE);
	ИначеЕсли ТипФормы = Перечисления.ТипыФормW8.ФормаW8IMY Тогда
		Источник = ПланыВидовХарактеристик.ВнешниеИсточники.HTTPСервисДокументыW8IMY;
	КонецЕсли;
	
	НастройкиСоединения = КэшНастроекСоединения.Получить(Источник);
	Если НастройкиСоединения = Неопределено Тогда
		ПараметрыИсточника = ВнешниеДанные.ПолучитьПараметрыВнешнегоИсточника(Источник);
		НастройкиСоединения = ПараметрыИсточника.Настройка;		
		КэшНастроекСоединения.Вставить(Источник, НастройкиСоединения);		
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(НастройкиСоединения) Тогда
		ТекстОшибки = "Не установлены параметры источника: " + Источник;
		ОбщегоНазначения.СообщитьОбОшибке(ТекстОшибки);
	КонецЕсли;
		
	Возврат НастройкиСоединения;
КонецФункции

Процедура ПодключитьИсточник(HTTPСоединение, НастройкиСоединения,ТокенАвторизации);
				
	КодировкаТелаЗапроса = "windows-1251";
		
	HTTPСоединение = Новый HTTPСоединение(
			НастройкиСоединения.HTTPСервисАдресСервера,
			?(Не НастройкиСоединения.HTTPСервисПорт = 0, НастройкиСоединения.HTTPСервисПорт, Неопределено),
			,,,
			НастройкиСоединения.HTTPСервисТаймаут, ?(НастройкиСоединения.HTTPСервисЗащищенноеСоединение, Новый ЗащищенноеСоединениеOpenSSL(), Неопределено));
			
	Если ЗначениеЗаполнено(НастройкиСоединения.HTTPСервисАдресРесурсаАутентификации) Тогда
		ЛогинПароль = Новый Структура("Login,Password", НастройкиСоединения.HTTPСервисПользователь, НастройкиСоединения.HTTPСервисПароль);
		ТелоЗапроса = ОбщегоНазначенияКлиентСервер.ЗаписатьВТекстJSON(ЛогинПароль);

		Заголовки = НовыйЗаголовки(Неопределено,"application/json-patch+json");
		HTTPЗапрос = Новый HTTPЗапрос(НастройкиСоединения.HTTPСервисАдресРесурсаАутентификации, Заголовки);
		HTTPЗапрос.УстановитьТелоИзСтроки(ТелоЗапроса, КодировкаТелаЗапроса);
		
		HTTPОтвет = HTTPСоединение.ОтправитьДляОбработки(HTTPЗапрос);
		
		ОписаниеОшибки = "";
		Если НЕ HTTPЗапросВыполнен(HTTPОтвет, "Ошибка при аутентификации", ОписаниеОшибки) Тогда
			ОбщегоНазначения.СообщитьОбОшибке(ОписаниеОшибки);
			Возврат;
		КонецЕсли;
		
		ТелоОтвета = HTTPОтвет.ПолучитьТелоКакСтроку();
		Ответ = ОбщегоНазначенияКлиентСервер.ПрочитатьТекстJSON(ТелоОтвета);
		ТокенАвторизации = Ответ.Token;

	КонецЕсли;
		
КонецПроцедуры

Функция НовыйЗаголовки(ТокенАвторизации, ContentType=Неопределено)
	Заголовки = Новый Соответствие;
	Заголовки.Вставить("accept","*/*");
	Если ЗначениеЗаполнено(ТокенАвторизации) Тогда
		Заголовки.Вставить("Authorization","bearer "+ТокенАвторизации);
	КонецЕсли;
	Если ContentType<>Неопределено Тогда
		Заголовки.Вставить("Content-Type",ContentType);
	КонецЕсли;
	Возврат Заголовки;
КонецФункции

Функция HTTPЗапросВыполнен(HTTPОтвет, ЗаголовокОшибки, ОписаниеОшибки)
	Если HTTPОтвет.КодСостояния<>200 Тогда
		ОписаниеОшибки = ЗаголовокОшибки+" Код ошибки:"+HTTPОтвет.КодСостояния+Символы.ПС+HTTPОтвет.ПолучитьТелоКакСтроку();
		Результат = Ложь;
	Иначе
		Результат = Истина;
	КонецЕсли;	
	
	Возврат Результат;
КонецФункции

Функция ДанныеСервисаW8(DocumentID, Соединение, НастройкиСоединения, HTTPЗапрос, Заголовки)
	
	HTTPЗапрос.АдресРесурса = НастройкиСоединения.HTTPСервисАдресРесурса + "/" + DocumentID;
	HTTPЗапрос.Заголовки = Заголовки;
	
	HTTPОтвет = Соединение.Получить(HTTPЗапрос);
	
	ОписаниеОшибки = "";
	Если Не HTTPЗапросВыполнен(HTTPОтвет, "Ошибка при получении данных по W8 " + DocumentID, ОписаниеОшибки) Тогда
		Возврат Неопределено;
	КонецЕсли;
		
	ТелоОтвета = HTTPОтвет.ПолучитьТелоКакСтроку();
	
	Если Не ЗначениеЗаполнено(ТелоОтвета) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	ДанныеСервисаW8E =  ОбщегоНазначенияКлиентСервер.ПрочитатьТекстJSON(ТелоОтвета);
				
	ИдентификаторПолученный = ДанныеСервисаW8E.document.id;
	Если Не ЗначениеЗаполнено(ИдентификаторПолученный) или Не ЗначениеЗаполнено(СтрЗаменить(СтрЗаменить(ИдентификаторПолученный, "0", ""),"-", "")) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Возврат ДанныеСервисаW8E;

КонецФункции

// Заполнияет табличные части "Сводное раскрытие" и "Шапка сводного" для возможности ручной корректировки данных
Процедура ЗаполнитьСводноеРаскрытие() Экспорт
	
	НДЦ = Константы.КлассификаторЗагрузкиНДЦ.Получить();
	Код = Организация.QI_SWIFT;
	Если Не ПустаяСтрока(Код) Тогда
		Код = Лев(Код, 8) + "A" + Сред(Код, 9, 3) + "0000000000";
	КонецЕсли;
	
	Шапка = Новый Структура("SwiftCode,CorpActionNumber,SecurityCode,SecurityName,AccountNumber,DepositorCode,QI_EIN,RecordDate,AllocationType"
	, Код
	, СокрЛП(СвязанныйРеференсКД2)
	, СокрЛП(ЦеннаяБумага1.ISIN)
	, СтрЗаменить(СокрЛП(ЦеннаяБумага1.Наименование), "&", "d")
	, СокрЛП(СчетДЕПО.Код)
	, Справочники.Организации.КодЗагрузки(Организация, НДЦ, ДатаФиксации) // "MC0292900000"
	, Организация.QI_EIN // "980243432"
	, ДатаФиксации
	, "pooled"
	);
	
	ШапкаСводного.Очистить();
	Для Каждого Элемент Из Шапка Цикл
		ЗаполнитьЗначенияСвойств(ШапкаСводного.Добавить(), Элемент);
	КонецЦикла;
	
	РезультатЗапросаСводногоРаскрытия = ВыборкаДанныхЗаполненияСводногоРСВ();
	СводноеРаскрытие.Загрузить(РезультатЗапросаСводногоРаскрытия.Выгрузить());
	
	СводноеРаскрытиеРедактировалосьВручную = Ложь;
	
КонецПроцедуры

Функция ЗапросНеисполненныхПоручений()
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Поручения.ВидОперацииД КАК ВидОперацииД,
	|	Поручения.Ссылка КАК Ссылка,
	|	Поручения.ДатаИсполненияПоручения КАК ДатаИсполненияПоручения
	|ИЗ
	|	Документ.Поручение КАК Поручения
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.Поручение.ЦенныеБумагиСписываемые КАК ПоручениеЦенныеБумагиСписываемые
	|		ПО Поручения.Ссылка = ПоручениеЦенныеБумагиСписываемые.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СтатусыПоручений.СрезПоследних(&ДатаФиксации, ) КАК СтатусыПорученийСрезПоследних
	|		ПО Поручения.Ссылка = СтатусыПорученийСрезПоследних.Поручение
	|ГДЕ
	|	(Поручения.ЦБ В (&ЦБ)
	|			ИЛИ ПоручениеЦенныеБумагиСписываемые.ЦеннаяБумага В (&ЦБ))
	|	И Поручения.Дата <= &ДатаФиксации
	|	И Поручения.Проведен
	|	И НЕ ЕСТЬNULL(СтатусыПорученийСрезПоследних.СтатусПоручения, НЕОПРЕДЕЛЕНО) В (&Статусы)
	|
	|УПОРЯДОЧИТЬ ПО
	|	Поручения.Дата";
	Запрос.УстановитьПараметр("ЦБ", ЦеннаяБумага1);
	Запрос.УстановитьПараметр("ДатаФиксации", ?(ОстаткиНаУтро, ДатаФиксации, КонецДня(ДатаФиксации)));
	Запрос.УстановитьПараметр("Статусы", Новый Массив);
	Запрос.Параметры.Статусы.Добавить(Перечисления.СтатусыПоручений.Исполнено);
	Запрос.Параметры.Статусы.Добавить(Перечисления.СтатусыПоручений.Отменено);
	Запрос.Параметры.Статусы.Добавить(Перечисления.СтатусыПоручений.ОтказаноВИсполнении);
	Возврат Запрос;
КонецФункции

#Область РаботаСВыгрузкойISO

// Процедура выгружает раскрытие в формате ISO
//
Процедура ВыгрузитьРаскрытиеСпискаВладельцевISO() Экспорт
	
	ПроверитьЗаполнениеРСВДляВыгрузкиISO();
	BizMsgIdr = ОбщегоНазначенияКлиентСервер.Транслит(СокрЛП(Номер));
	// Подготовим запросы по информации клиента
	ЗапросСпискаКодовЗагрузкиЦБ	= Документы.РаскрытиеСпискаВладельцев.ЗапросДляСпискаКодовЗагрузкиЦБ(Дата);
	
	НеобходимоЗафиксироватьВыгрузкуЭтапа = Ложь;
	ПроверитьОшибкиПоКлиентам();
	// Сформируем файл по Цб 1 если она заполнена
	Префикс = 1;
	Если ЗначениеЗаполнено(ЦеннаяБумага1) Тогда
		ВыборкаПоЦБ = ДанныеПоРаскрытию(ЦеннаяБумага1);
		СформироватьФайлПоЦБ_ISO(BizMsgIdr, ЗапросСпискаКодовЗагрузкиЦБ, ЦеннаяБумага1, ВыборкаПоЦБ, Префикс,
			НеобходимоЗафиксироватьВыгрузкуЭтапа);
	КонецЕсли;
	
	Если НеобходимоЗафиксироватьВыгрузкуЭтапа Тогда
		BizMsgIdr_СПрефиксом = Документы.РаскрытиеСпискаВладельцев.BizMsgIdr_СПрефиксом(BizMsgIdr, Префикс);
		Документы.РаскрытиеСпискаВладельцев.ЗарегистрироватьЭтапКД(Ссылка, BizMsgIdr_СПрефиксом);
	КонецЕсли;
	
	НеобходимоЗафиксироватьВыгрузкуЭтапа = Ложь;
	
	// Сформируем файл по Цб 2 если она заполнена
	Префикс = 2;
	Если ЗначениеЗаполнено(ЦеннаяБумага2) Тогда
		ВыборкаПоЦБ = ДанныеПоРаскрытию(ЦеннаяБумага2);
		СформироватьФайлПоЦБ_ISO(BizMsgIdr, ЗапросСпискаКодовЗагрузкиЦБ, ЦеннаяБумага2, ВыборкаПоЦБ, Префикс,
			НеобходимоЗафиксироватьВыгрузкуЭтапа);
	КонецЕсли;
	
	Если НеобходимоЗафиксироватьВыгрузкуЭтапа Тогда
		BizMsgIdr_СПрефиксом = Документы.РаскрытиеСпискаВладельцев.BizMsgIdr_СПрефиксом(BizMsgIdr, Префикс);
		Документы.РаскрытиеСпискаВладельцев.ЗарегистрироватьЭтапКД(Ссылка, BizMsgIdr_СПрефиксом, 1);
	КонецЕсли;
	
КонецПроцедуры

// Процедура проверяет заполнение РСВ для выгрузки в формате ISO
//
Процедура ПроверитьЗаполнениеРСВДляВыгрузкиISO() Экспорт
	Если Не Проведен Тогда
		ВызватьИсключение "Файл раскрытия списка не сформирован - Не заполнен и не проведен документ!";
	КонецЕсли;
	// Если список владельцев пуст, то не формируем
	Если СписокВладельцев.Количество() = 0 Тогда
		ВызватьИсключение "Файл раскрытия списка не сформирован - список владельцев не заполнен!";
	КонецЕсли;
КонецПроцедуры

// Процедура формирует файлы раскрытия по ЦБ (xml, csv) в формате ISO 20022 и выгружает в каталог
//
// Параметры:
//  BizMsgIdr							 - Строка - BizMsgIdr
//  ЗапросСпискаКодовЗагрузкиЦБ			 - Запрос - подготовленный запрос для поиска кодов загрузки ЦБ
//  ЦеннаяБумага						 - СправочникСсылка.ЦенныеБумаги - ссылка на ЦБ
//  ВыборкаПоЦБ							 - ВыборкаИзРезультатаЗапроса - выборка с данными по выгружаемой ЦБ
//  Префикс								 - Строка - префикс
//  НеобходимоЗафиксироватьВыгрузкуЭтапа - Булево - флаг для установки необходимости зафиксировать выгрузку этапа в РС ЭтапыКД
//
Процедура СформироватьФайлПоЦБ_ISO(BizMsgIdr, ЗапросСпискаКодовЗагрузкиЦБ, ЦеннаяБумага, ВыборкаПоЦБ, Префикс,
	НеобходимоЗафиксироватьВыгрузкуЭтапа)
	
	ДанныеДляВыгрузки = ДанныеДляФормированияСообщенияПоЦБ_ISO(ЗапросСпискаКодовЗагрузкиЦБ, ЦеннаяБумага, ВыборкаПоЦБ, Префикс, , BizMsgIdr);
	
	ТекстXML = Новый ТекстовыйДокумент;
	ТекстXML.ДобавитьСтроку(ДанныеДляВыгрузки.СтрокаXML);
	ИмяФайла = Номер + "_" + Формат(ТекущаяДатаСеанса(), "ДФ=ddMMyyyy") + "_" + Префикс;
	КаталогВыгрузкиРаскрытияСпискаВладельцевISO = ПланыВидовХарактеристик.ВнешниеИсточники.КаталогВыгрузкиРаскрытияСпискаВладельцевISO;
	ПараметрыВнешнегоИсточника = ВнешниеДанные.ПолучитьПараметрыВнешнегоИсточника(КаталогВыгрузкиРаскрытияСпискаВладельцевISO);
	ПапкаДанных = СокрЛП(ПараметрыВнешнегоИсточника.Папка);
	ПолныйПутьКФайлу = ПапкаДанных + "\" + ИмяФайла + ".xml";
	Попытка
		ТекстXML.Записать(ПолныйПутьКФайлу);
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Сформирован файл " + ПолныйПутьКФайлу);
		НеобходимоЗафиксироватьВыгрузкуЭтапа = Истина;
	Исключение
		ОбщегоНазначения.СообщитьОбОшибке(
			"Не удалось записать файл!
			|
			|Возможно указанный в настройках каталог 'Каталог ISO' недоступен или путь некорректен!");
	КонецПопытки;
	
	ОбъектCSV = Новый ТекстовыйДокумент;
	ОбъектCSV.УстановитьТипФайла("windows-1251");
	ОбъектCSV.УстановитьТекст(ДанныеДляВыгрузки.СтрокаCSV);
	КаталогВыгрузкиРаскрытияСпискаВладельцевISOCSV = ПланыВидовХарактеристик.ВнешниеИсточники.КаталогВыгрузкиРаскрытияСпискаВладельцевISOCSV;
	ПапкаДанных = СокрЛП(ВнешниеДанные.ПолучитьПараметрыВнешнегоИсточника(КаталогВыгрузкиРаскрытияСпискаВладельцевISOCSV).Папка);
	ПолныйПутьКФайлу = ПапкаДанных + "\" + ИмяФайла + ".csv";
	Попытка
		ОбъектCSV.Записать(ПолныйПутьКФайлу);
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Сформирован файл " + ПолныйПутьКФайлу);
	Исключение
		ОбщегоНазначения.СообщитьОбОшибке(
			"Не удалось записать файл CSV!
			|
			|Возможно указанный в настройках каталог 'Каталог ISO для CSV' недоступен или путь некорректен!");
	КонецПопытки;
	
КонецПроцедуры

// Процедура формирует xml-файл раскрытия по ЦБ в формате ISO 20022 и выгружает в файловый шлюз
//
Процедура СформироватьФайлПоЦБвФШ_ISO() Экспорт
	
	ЕстьОшибкиЗаполнения = Не ЗначениеЗаполнено(ЦеннаяБумага1) Или ЗначениеЗаполнено(ЦеннаяБумага1) И ЗначениеЗаполнено(ЦеннаяБумага2);
	Если ЕстьОшибкиЗаполнения Тогда
		ВызватьИсключение "При выгрузке раскрытия по формату ISO20022 в файловый шлюз можно указать только ""Ценная Бумага 1""!";
	КонецЕсли;
	
	Префикс = 1;
	ЗапросСпискаКодовЗагрузкиЦБ = Документы.РаскрытиеСпискаВладельцев.ЗапросДляСпискаКодовЗагрузкиЦБ(Дата);
	ВыборкаПоЦБ = ДанныеПоРаскрытию(ЦеннаяБумага1);
	КодировкаXML = "windows-1251";
	ДанныеДляВыгрузки = ДанныеДляФормированияСообщенияПоЦБ_ISO(ЗапросСпискаКодовЗагрузкиЦБ, ЦеннаяБумага1,
		ВыборкаПоЦБ, Префикс, КодировкаXML);
	
	BizMsgIdr = ОбщегоНазначенияКлиентСервер.Транслит(СокрЛП(Номер));
	ИсходящийНомер = Обработки.ЭкспортПорученийВЛуч.ФорматИсходящегоНомера(BizMsgIdr, "RS");
	ТипТехническойОперации = "CA044";
	КодТехническойОперации = "MI";
	НомерТехническойОперации = "";
	Ошибка = Обработки.ЭкспортПорученийВЛуч.СформироватьИсходящийПакетВФайловыйШлюз(ИсходящийНомер, Дата, ТипТехническойОперации,
		КодТехническойОперации, Ссылка, ДанныеДляВыгрузки.СтрокаXML, НомерТехническойОперации);
	Если Ошибка = Неопределено Тогда
		Документы.РаскрытиеСпискаВладельцев.ЗарегистрироватьЭтапКД(Ссылка, НомерТехническойОперации);
	КонецЕсли;
	
КонецПроцедуры

// Функция возвращает данные по раскрытию по заданной ЦБ
//
// Параметры:
//  ЦеннаяБумага - СправочникСсылка.ЦенныеБумаги - ЦБ, по который требуется получить данные по раскрытию
// 
// Возвращаемое значение:
//  ВыборкаИзРезультатаЗапроса - выборка с данными по раскрытию
//
Функция ДанныеПоРаскрытию(ЦеннаяБумага) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	МАКСИМУМ(РаскрытиеСпискаВладельцевСписокВладельцев.Клиент) КАК Клиент,
	|	СУММА(РаскрытиеСпискаВладельцевСписокВладельцев.Количество) КАК Количество,
	|	МАКСИМУМ(РаскрытиеСпискаВладельцевСписокВладельцев.НомерСтроки) КАК НомерСтроки,
	|	МАКСИМУМ(ВЫРАЗИТЬ(ОтветСубброкераНаРаскрытиеДанныеСубброкера.АдресМестонахожденияРегистрацииАдрес КАК СТРОКА(1000))) КАК АдресМестонахожденияРегистрацииАдрес,
	|	МАКСИМУМ(ОтветСубброкераНаРаскрытиеДанныеСубброкера.АдресМестонахожденияРегистрацииИндекс) КАК АдресМестонахожденияРегистрацииИндекс,
	|	МАКСИМУМ(ОтветСубброкераНаРаскрытиеДанныеСубброкера.АдресМестонахожденияРегистрацииСтрана) КАК АдресМестонахожденияРегистрацииСтрана,
	|	МАКСИМУМ(ВЫРАЗИТЬ(ОтветСубброкераНаРаскрытиеДанныеСубброкера.АдресПочтовыйАдрес КАК СТРОКА(1000))) КАК АдресПочтовыйАдрес,
	|	МАКСИМУМ(ОтветСубброкераНаРаскрытиеДанныеСубброкера.АдресПочтовыйИндекс) КАК АдресПочтовыйИндекс,
	|	МАКСИМУМ(ОтветСубброкераНаРаскрытиеДанныеСубброкера.АдресПочтовыйСтрана) КАК АдресПочтовыйСтрана,
	|	МАКСИМУМ(ВЫБОР
	|			КОГДА ОтветСубброкераНаРаскрытиеДанныеСубброкера.ГражданствоФЛ = &КлассификаторСтранМираПустаяСсылка
	|				ТОГДА &РОССИЯ
	|			ИНАЧЕ ОтветСубброкераНаРаскрытиеДанныеСубброкера.ГражданствоФЛ
	|		КОНЕЦ) КАК ГражданствоФЛ,
	|	МАКСИМУМ(ОтветСубброкераНаРаскрытиеДанныеСубброкера.ДатаРожденияФЛ) КАК ДатаРожденияФЛ,
	|	МАКСИМУМ(ОтветСубброкераНаРаскрытиеДанныеСубброкера.ДокументВладельцаДатаВыдачи) КАК ДокументДатаВыдачи,
	|	МАКСИМУМ(ОтветСубброкераНаРаскрытиеДанныеСубброкера.ДокументВладельцаНомер) КАК ДокументНомер,
	|	МАКСИМУМ(ВЫРАЗИТЬ(ОтветСубброкераНаРаскрытиеДанныеСубброкера.ДокументВладельцаОрганВыдачи КАК СТРОКА(1000))) КАК ДокументОрганВыдачи,
	|	МАКСИМУМ(ОтветСубброкераНаРаскрытиеДанныеСубброкера.ДокументВладельцаСерия) КАК ДокументСерия,
	|	МАКСИМУМ(ОтветСубброкераНаРаскрытиеДанныеСубброкера.ДокументВладельцаТип) КАК ДокументВид,
	|	МАКСИМУМ(ОтветСубброкераНаРаскрытиеДанныеСубброкера.НомерСчетаДепоКлиента) КАК НомерСчетаДепоКлиента,
	|	МАКСИМУМ(ВЫРАЗИТЬ(ОтветСубброкераНаРаскрытиеДанныеСубброкера.ПолноеНаименованиеЮЛФЛСубклиента КАК СТРОКА(1000))) КАК ПолноеНаименование,
	|	МАКСИМУМ(ОтветСубброкераНаРаскрытиеДанныеСубброкера.ПолноеНаименованиеЛица) КАК Наименование,
	|	МАКСИМУМ(ВЫБОР
	|			КОГДА Субклиенты.ЮридическиеФизическиеЛица ЕСТЬ NULL
	|				ТОГДА &ФизическиеЛицаПустаяСсылка
	|			ИНАЧЕ Субклиенты.ЮридическиеФизическиеЛица
	|		КОНЕЦ) КАК ЮридическиеФизическиеЛица,
	|	МАКСИМУМ(ОтветСубброкераНаРаскрытиеДанныеСубброкера.ПризнакЮЛФЛ) КАК ЮрФизЛицо,
	|	МАКСИМУМ(ОтветСубброкераНаРаскрытиеДанныеСубброкера.Выгодоприобретатель) КАК Выгодоприобретатель,
	|	МАКСИМУМ(ОтветСубброкераНаРаскрытиеДанныеСубброкера.ДокументВладельцаТип.КодНРД) КАК ДокументВидКодНРД,
	|	МАКСИМУМ(ВЫБОР
	|			КОГДА ОтветСубброкераНаРаскрытиеДанныеСубброкера.СтатусНалогоплательщика = 2
	|				ТОГДА ИСТИНА
	|			ИНАЧЕ ЛОЖЬ
	|		КОНЕЦ) КАК Нерезидент,
	|	МАКСИМУМ(ВЫБОР
	|			КОГДА ОтветСубброкераНаРаскрытиеДанныеСубброкера.ДокументВладельцаТип = &OGRN
	|				ТОГДА ОтветСубброкераНаРаскрытиеДанныеСубброкера.ДокументВладельцаНомер
	|			ИНАЧЕ """"
	|		КОНЕЦ) КАК ОГРН,
	|	МАКСИМУМ(ВЫБОР
	|			КОГДА ОтветСубброкераНаРаскрытиеДанныеСубброкера.ДокументВладельцаТип = &REGN
	|				ТОГДА ОтветСубброкераНаРаскрытиеДанныеСубброкера.ДокументВладельцаНомер
	|			ИНАЧЕ """"
	|		КОНЕЦ) КАК ИНН,
	|	МАКСИМУМ(ВЫБОР
	|			КОГДА ОтветСубброкераНаРаскрытиеДанныеСубброкера.ДокументВладельцаТип = &REGN
	|				ТОГДА ОтветСубброкераНаРаскрытиеДанныеСубброкера.ДокументВладельцаНомер
	|			ИНАЧЕ """"
	|		КОНЕЦ) КАК РегНомер,
	|	"""" КАК TIN,
	|	ВЫБОР
	|		КОГДА РаскрытиеСпискаВладельцевСписокВладельцев.Клиент.Субброкер
	|			ТОГДА ОтветСубброкераНаРаскрытиеДанныеСубброкера.НомерСчетаДепоКлиента
	|		ИНАЧЕ РаскрытиеСпискаВладельцевСписокВладельцев.СчетДепо
	|	КОНЕЦ КАК КодКлиента
	|ИЗ
	|	Документ.РаскрытиеСпискаВладельцев.СписокВладельцев КАК РаскрытиеСпискаВладельцевСписокВладельцев
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ОтветСубброкераНаРаскрытие.ДанныеСубброкера КАК ОтветСубброкераНаРаскрытиеДанныеСубброкера
	|		ПО РаскрытиеСпискаВладельцевСписокВладельцев.ОтветНаРСВ = ОтветСубброкераНаРаскрытиеДанныеСубброкера.Ссылка
	|			И РаскрытиеСпискаВладельцевСписокВладельцев.Выгодоприобретатель = ОтветСубброкераНаРаскрытиеДанныеСубброкера.Выгодоприобретатель
	|			И РаскрытиеСпискаВладельцевСписокВладельцев.НомерСчетаДепоКлиентаОтвета = ОтветСубброкераНаРаскрытиеДанныеСубброкера.НомерСчетаДепоКлиента
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Субклиенты КАК Субклиенты
	|		ПО РаскрытиеСпискаВладельцевСписокВладельцев.Выгодоприобретатель = Субклиенты.Ссылка
	|ГДЕ
	|	РаскрытиеСпискаВладельцевСписокВладельцев.Ссылка = &РаскрытиеСпискаВладельцев
	|	И РаскрытиеСпискаВладельцевСписокВладельцев.ЦеннаяБумага = &ЦеннаяБумага
	|
	|СГРУППИРОВАТЬ ПО
	|	ВЫБОР
	|		КОГДА РаскрытиеСпискаВладельцевСписокВладельцев.Клиент.Субброкер
	|			ТОГДА ОтветСубброкераНаРаскрытиеДанныеСубброкера.НомерСчетаДепоКлиента
	|		ИНАЧЕ РаскрытиеСпискаВладельцевСписокВладельцев.СчетДепо
	|	КОНЕЦ
	|
	|УПОРЯДОЧИТЬ ПО
	|	НомерСтроки";
	
	Запрос.УстановитьПараметр("РаскрытиеСпискаВладельцев", Ссылка);
	Запрос.УстановитьПараметр("ЦеннаяБумага", ЦеннаяБумага);
	Запрос.УстановитьПараметр("ФизическиеЛицаПустаяСсылка", Справочники.ФизическиеЛица.ПустаяСсылка());
	Запрос.УстановитьПараметр("КлассификаторСтранМираПустаяСсылка", Справочники.КлассификаторСтранМира.ПустаяСсылка());
	Запрос.УстановитьПараметр("РОССИЯ", Справочники.КлассификаторСтранМира.РОССИЯ);
	Запрос.УстановитьПараметр("OGRN", Справочники.ДокументыЮридическихЛиц.OGRN);
	Запрос.УстановитьПараметр("REGN", Справочники.ДокументыЮридическихЛиц.REGN);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Возврат Выборка;
	
КонецФункции

// Процедура проверяет ошибки по клиентам, указанным в документе РСВ
//
Процедура ПроверитьОшибкиПоКлиентам() Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	РаскрытиеСпискаВладельцевСписокВладельцев.Выгодоприобретатель КАК Выгодоприобретатель,
	|	РаскрытиеСпискаВладельцевСписокВладельцев.НомерСтроки КАК НомерСтроки,
	|	РаскрытиеСпискаВладельцевСписокВладельцев.ОтветНаРСВ КАК ОтветНаРСВ,
	|	РаскрытиеСпискаВладельцевСписокВладельцев.НомерСчетаДепоКлиентаОтвета КАК НомерСчетаДепоКлиентаОтвета,
	|	РаскрытиеСпискаВладельцевСписокВладельцев.Клиент КАК Клиент
	|ПОМЕСТИТЬ СписокВладельцевСубброкеры
	|ИЗ
	|	Документ.РаскрытиеСпискаВладельцев.СписокВладельцев КАК РаскрытиеСпискаВладельцевСписокВладельцев
	|ГДЕ
	|	РаскрытиеСпискаВладельцевСписокВладельцев.Ссылка = &РаскрытиеСпискаВладельцев
	|	И РаскрытиеСпискаВладельцевСписокВладельцев.Клиент.Субброкер
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ ПЕРВЫЕ 1
	|	СписокВладельцевСубброкеры.Клиент КАК Клиент
	|ИЗ
	|	СписокВладельцевСубброкеры КАК СписокВладельцевСубброкеры
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ОтветСубброкераНаРаскрытие.ДанныеСубброкера КАК ОтветСубброкераНаРаскрытиеДанныеСубброкера
	|		ПО СписокВладельцевСубброкеры.ОтветНаРСВ = ОтветСубброкераНаРаскрытиеДанныеСубброкера.Ссылка
	|			И СписокВладельцевСубброкеры.Выгодоприобретатель = ОтветСубброкераНаРаскрытиеДанныеСубброкера.Выгодоприобретатель
	|			И СписокВладельцевСубброкеры.НомерСчетаДепоКлиентаОтвета = ОтветСубброкераНаРаскрытиеДанныеСубброкера.НомерСчетаДепоКлиента
	|ГДЕ
	|	ВЫБОР
	|			КОГДА СписокВладельцевСубброкеры.Выгодоприобретатель = """"
	|				ТОГДА ИСТИНА
	|			КОГДА СписокВладельцевСубброкеры.Выгодоприобретатель = ЗНАЧЕНИЕ(Справочник.Субклиенты.ПустаяСсылка)
	|				ТОГДА ИСТИНА
	|			ИНАЧЕ ЛОЖЬ
	|		КОНЕЦ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ ПЕРВЫЕ 1
	|	СписокВладельцевСубброкеры.Выгодоприобретатель КАК Выгодоприобретатель,
	|	СписокВладельцевСубброкеры.НомерСтроки КАК НомерСтроки
	|ИЗ
	|	СписокВладельцевСубброкеры КАК СписокВладельцевСубброкеры
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ОтветСубброкераНаРаскрытие.ДанныеСубброкера КАК ОтветСубброкераНаРаскрытиеДанныеСубброкера
	|		ПО СписокВладельцевСубброкеры.ОтветНаРСВ = ОтветСубброкераНаРаскрытиеДанныеСубброкера.Ссылка
	|			И СписокВладельцевСубброкеры.Выгодоприобретатель = ОтветСубброкераНаРаскрытиеДанныеСубброкера.Выгодоприобретатель
	|			И СписокВладельцевСубброкеры.НомерСчетаДепоКлиентаОтвета = ОтветСубброкераНаРаскрытиеДанныеСубброкера.НомерСчетаДепоКлиента
	|ГДЕ
	|	ОтветСубброкераНаРаскрытиеДанныеСубброкера.Ссылка ЕСТЬ NULL";
	
	Запрос.УстановитьПараметр("РаскрытиеСпискаВладельцев", Ссылка);
	РезультатыЗапроса = Запрос.ВыполнитьПакет();
	
	ВыборкаПроверкаВыгодоприобретателя = РезультатыЗапроса[1].Выбрать();
	Если ВыборкаПроверкаВыгодоприобретателя.Следующий() Тогда
		// BSLLS:Typo-off
		ВызватьИсключение "Для субброкера '" + ВыборкаПроверкаВыгодоприобретателя.Клиент
			+ "' не указан выгодоприобретатель (субклиент)!";
		// BSLLS:Typo-on
	КонецЕсли;
	
	ВыборкаПроверкаОтвета = РезультатыЗапроса[2].Выбрать();
	Если ВыборкаПроверкаОтвета.Следующий() Тогда
		// BSLLS:Typo-off
		ВызватьИсключение "Нет данных по субклиенту " + ВыборкаПроверкаОтвета.Выгодоприобретатель
			+ " (строка №" + ВыборкаПроверкаОтвета.НомерСтроки + ")";
		// BSLLS:Typo-on
	КонецЕсли;
	
КонецПроцедуры

Функция Новый_Fr(ТипыДляЗаголовка, IssrNSDR, КодЗагрузкиОрганизации)
	// {{ Fr
	_Fr					= ФабрикаXDTO.Создать(ТипыДляЗаголовка.Party9Choice_Тип);
		// {{ OrgId
		OrgId			= ФабрикаXDTO.Создать(ТипыДляЗаголовка.PartyIdentification42_Тип);
		OrgId.Nm		= ?(ЗначениеЗаполнено(Организация.НаименованиеПолное),
			СокрЛП(Организация.НаименованиеПолное), СокрЛП(Организация.Наименование));
			// {{ Id
			Id			= ФабрикаXDTO.Создать(ТипыДляЗаголовка.Party10Choice_Тип);
				// {{ OrgId
				IdOrgId	= ФабрикаXDTO.Создать(ТипыДляЗаголовка.OrganisationIdentification7_Тип);
					// {{ Othr
					Othr		= ФабрикаXDTO.Создать(ТипыДляЗаголовка.GenericOrganisationIdentification1_Тип);
					Othr.Id		= КодЗагрузкиОрганизации;
					Othr.Issr	= IssrNSDR;
					// }}
				IdOrgId.Othr.Добавить(Othr);
				// }}
			Id.OrgId	= IdOrgId;
			// }}
		OrgId.Id		= Id;
	// }}
	_Fr.OrgId		= OrgId;
	// }}
	Возврат _Fr;
КонецФункции

Функция Новый_To(ТипыДляЗаголовка, IssrNSDR)
	// {{ To
	_To					= ФабрикаXDTO.Создать(ТипыДляЗаголовка.Party9Choice_Тип);
		// {{ OrgId
		OrgId			= ФабрикаXDTO.Создать(ТипыДляЗаголовка.PartyIdentification42_Тип);
			// {{ Id
			Id			= ФабрикаXDTO.Создать(ТипыДляЗаголовка.Party10Choice_Тип);
				// {{ OrgId
				IdOrgId	= ФабрикаXDTO.Создать(ТипыДляЗаголовка.OrganisationIdentification7_Тип);
					// {{ Othr
					Othr		= ФабрикаXDTO.Создать(ТипыДляЗаголовка.GenericOrganisationIdentification1_Тип);
					Othr.Id		= "NDC000000000";
					Othr.Issr	= IssrNSDR;
					// }}
				IdOrgId.Othr.Добавить(Othr);
				// }}
			Id.OrgId	= IdOrgId;
			// }}
		OrgId.Id		= Id;
	// }}
	_To.OrgId		= OrgId;
	// }}
	Возврат _To;
КонецФункции

// Функция формирует сообщения в виде xml и csv для формата ISO 20022
//
// Параметры:
//  ЗапросСпискаКодовЗагрузкиЦБ	 - Запрос - подготовленный запрос для поиска кодов загрузки ЦБ
//  ЦеннаяБумага				 - СправочникСсылка.ЦенныеБумаги - ссылка на выгружаемую ЦБ
//  ВыборкаПоЦБ					 - ВыборкаИзРезультатаЗапроса - выборка с данными по выгружаемой ЦБ
//  Префикс						 - Число - префикс
//  КодировкаXML				 - Строка - кодировка для формирования xml
//  BizMsgIdr					 - Строка - BizMsgIdr
// 
// Возвращаемое значение:
//  Структура:
//        * СтрокаXML - Строка - сообщение в виде xml
//        * СтрокаCSV - Строка - сообщение в виде csv
//
Функция ДанныеДляФормированияСообщенияПоЦБ_ISO(ЗапросСпискаКодовЗагрузкиЦБ, ЦеннаяБумага,
	ВыборкаПоЦБ, Префикс = 1, КодировкаXML = "UTF-8", BizMsgIdr = "") Экспорт
	
	// Получим организацию
	Организация	= ОбщегоНазначенияПовтИсп.ЗначениеКонстанты("ОрганизацияПоУмолчанию");
	ФорматнаяСтрока = "ДФ=yyyy-MM-ddTHH:mm:ssZ";
	
	// Определим пространство имен
	ПространствоИмен	= "MeetingInstruction_ISO20022BMET";
	// Определим типы
	Party9Choice_Тип								= ФабрикаXDTO.Тип(ПространствоИмен, "Party9Choice");
	Party10Choice_Тип								= ФабрикаXDTO.Тип(ПространствоИмен, "Party10Choice");
	PartyIdentification42_Тип						= ФабрикаXDTO.Тип(ПространствоИмен, "PartyIdentification42");
	PartyIdentification9Choice_Тип					= ФабрикаXDTO.Тип(ПространствоИмен, "PartyIdentification9Choice");
	OrganisationIdentification7_Тип					= ФабрикаXDTO.Тип(ПространствоИмен, "OrganisationIdentification7");
	GenericOrganisationIdentification1_Тип			= ФабрикаXDTO.Тип(ПространствоИмен, "GenericOrganisationIdentification1");
	Instruction2_Тип								= ФабрикаXDTO.Тип(ПространствоИмен, "Instruction2");
	SafekeepingAccount4_Тип							= ФабрикаXDTO.Тип(ПространствоИмен, "SafekeepingAccount4");
	HoldingBalance5_Тип								= ФабрикаXDTO.Тип(ПространствоИмен, "HoldingBalance5");
	SecurityIdentification11_Тип					= ФабрикаXDTO.Тип(ПространствоИмен, "SecurityIdentification11");
	SecurityIdentification11Choice_Тип				= ФабрикаXDTO.Тип(ПространствоИмен, "SecurityIdentification11Choice");
	Document_MeetingInstruction_Тип					= ФабрикаXDTO.Тип(ПространствоИмен, "Document_MeetingInstruction");
