// Функция удаляет суффиксы HL/ML/TL из переданного референса КД
//
// Параметры:
//  КДРеференс	 - Строка - референс КД
// 
// Возвращаемое значение:
//  Строка - референс КД без суффикса
//
Функция КДРеференсБезСуффикса(КДРеференс) Экспорт
	ЗначениеРеференса = СтрЗаменить(КДРеференс, "HL", "");
	ЗначениеРеференса = СтрЗаменить(ЗначениеРеференса, "ML", "");
	ЗначениеРеференса = СтрЗаменить(ЗначениеРеференса, "TL", "");
	Возврат СокрЛП(ЗначениеРеференса);
КонецФункции

// Функция возвращает данные с контактами переданного юрлица клиента
//
// Параметры:
//  Клиент		 - СправочникСсылка.Контрагенты - клиент
//  ЮрФизЛицо	 - СправочникСсылка.ЮридическиеЛица - юрлицо клиента
//  ТипЛица		 - Перечисления.ЮрФизЛицо - тип лица (ФизЛицо/ЮрЛицо)
// 
// Возвращаемое значение:
//  Структура:
//        * АдресНеРФ - Булево
//        * Страна - СправочникСсылка.КлассификаторСтранМира
//        * Индекс - Строка
//        * ПредставлениеАдреса - Строка
//
Функция Контакты(Клиент, ЮрФизЛицо, ТипЛица) Экспорт
	Контакты = Новый Структура("АдресНеРФ, Страна, Индекс");
	Контакты.Вставить("ПредставлениеАдреса", "");
	
	ВидКИ = ?(ТипЛица = Перечисления.ЮрФизЛицо.ФизЛицо, Справочники.ВидыКонтактнойИнформации.ЮрАдресФизЛица,
				Справочники.ВидыКонтактнойИнформации.ФактАдресЮрЛица);
	КонтактыЮрФизЛица = РегистрыСведений.КонтактнаяИнформация.СрезПоследних(,
		Новый Структура("Вид, Тип, Объект", ВидКИ, Перечисления.ТипыКонтактнойИнформации.Адрес, ЮрФизЛицо));
		
	ВидКИ = Справочники.ВидыКонтактнойИнформации.ЮрАдресКонтрагента;
	КонтактыКлиента = РегистрыСведений.КонтактнаяИнформация.СрезПоследних(,
		Новый Структура("Вид, Тип, Объект", ВидКИ, Перечисления.ТипыКонтактнойИнформации.Адрес, Клиент));
		
	МассивКИ = Новый Массив;
	МассивКИ.Добавить(КонтактыЮрФизЛица);
	МассивКИ.Добавить(КонтактыКлиента);
	
	Для Каждого КИ Из МассивКИ Цикл
		Если КИ.Количество() > 0 Тогда
			Контакты.ПредставлениеАдреса = СокрЛП(КИ[0].Представление);
			Контакты.АдресНеРФ = Не КИ[0].ЭтоРоссийскийАдрес;
			Если Контакты.АдресНеРФ Тогда
				Контакты.Страна	= Справочники.КлассификаторСтранМира.НайтиПоНаименованию(КИ[0].Поле1, Истина);
			Иначе	
				Контакты.Индекс	= СокрЛП(КИ[0].Поле1);
				Контакты.Страна	= Справочники.КлассификаторСтранМира.РОССИЯ;
			КонецЕсли;
			
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	Если Не ЗначениеЗаполнено(Контакты.ПредставлениеАдреса) Тогда
		РеквизитыКлиента = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Клиент, "Код, Наименование");
		ТекстОшибки = СтрШаблон("Заполните адрес депонента %1 - %2. Выгрузка РСВ невозможна",
			СокрЛП(РеквизитыКлиента.Код), РеквизитыКлиента.Наименование);
		ВызватьИсключение ТекстОшибки;
	КонецЕсли;
	
	Возврат Контакты;
КонецФункции

// Функция разбивает строку адреса на строки не более 70 символов
// и возвращает их в виде массива строк
//
// Параметры:
//  Адрес	 - Строка - Исходная строка адреса
// 
// Возвращаемое значение:
//  Массив - массив строк адреса
//
Функция РазделенныйАдрес(Адрес) Экспорт
	
	РазделенныйАдресФиксированный = Новый Массив;
	РазделенныйАдрес = Новый Массив;
	РазделеннаяСтрокаАдреса = "";
	ДопустимаяДлинаСтроки = 70;
	
	СтрокиАдреса = СтрРазделить(Адрес, ",");
	Для Каждого СтрокаАдреса Из СтрокиАдреса Цикл
		ДлинаСтрокиДляВыгрузки = СтрДлина(РазделеннаяСтрокаАдреса) + СтрДлина(СтрокаАдреса) + 1;
		Если ДлинаСтрокиДляВыгрузки <= ДопустимаяДлинаСтроки Тогда
			РазделеннаяСтрокаАдреса = ?(ЗначениеЗаполнено(РазделеннаяСтрокаАдреса), РазделеннаяСтрокаАдреса + "," + СтрокаАдреса, СтрокаАдреса);
		Иначе
			ДлинаСтрокиДляВыгрузки = СтрДлина(РазделеннаяСтрокаАдреса);
			РазделеннаяСтрокаАдреса = ?(ДлинаСтрокиДляВыгрузки < ДопустимаяДлинаСтроки, РазделеннаяСтрокаАдреса + ",", РазделеннаяСтрокаАдреса);
			РазделенныйАдрес.Добавить(РазделеннаяСтрокаАдреса);
			
			СтрокаАдреса = ?(ДлинаСтрокиДляВыгрузки < ДопустимаяДлинаСтроки, СтрокаАдреса, "," + СтрокаАдреса);
			РазделеннаяСтрокаАдреса = СтрокаАдреса;
		КонецЕсли;
	КонецЦикла;
	
	Если ЗначениеЗаполнено(РазделеннаяСтрокаАдреса) Тогда
		РазделенныйАдрес.Добавить(РазделеннаяСтрокаАдреса);
	КонецЕсли;
	
	МаксимальноеКоличествоАдресов = 5;
	ТекущееКоличествоАдресов = РазделенныйАдрес.Количество();
	КоличествоАдресов = ?(ТекущееКоличествоАдресов > МаксимальноеКоличествоАдресов, МаксимальноеКоличествоАдресов, ТекущееКоличествоАдресов); 
	Для Индекс = 0 По КоличествоАдресов - 1 Цикл
		РазделенныйАдресФиксированный.Добавить(РазделенныйАдрес.Получить(Индекс));
	КонецЦикла;
	
	Возврат РазделенныйАдресФиксированный;
	
КонецФункции

// Функция возвращает данные по документу физлица
//
// Параметры:
//  ФизЛицо		 - СправочникСсылка.ФизическиеЛица - физлицо
//  ДатаЗапроса	 - Дата - дата, на которую необходимо получить данные
// 
// Возвращаемое значение:
//  ВыборкаИзРезультатаЗапроса - данные по документу физлица
//
Функция ПолучитьДанныеПоДокументуФизЛица(ФизЛицо, ДатаЗапроса) Экспорт
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	ПДФЛ.ДокументВид КАК ДокументВид,
	|	ПДФЛ.ДокументСерия КАК ДокументСерия,
	|	ПДФЛ.ДокументНомер КАК ДокументНомер,
	|	ПДФЛ.ДокументДатаВыдачи КАК ДокументДатаВыдачи,
	|	ПДФЛ.ДокументКемВыдан КАК ДокументКемВыдан,
	|	ПДФЛ.ДокументКодПодразделения КАК ДокументКодПодразделения,
	|	ПДФЛ.ДокументВид.КодНРД КАК ДокументВидКодНРД
	|ИЗ
	|	РегистрСведений.ПаспортныеДанныеФизЛиц.СрезПоследних(&ДатаЗапроса, ФизЛицо = &ФизЛицо) КАК ПДФЛ");
	
	Запрос.УстановитьПараметр("ДатаЗапроса"	, ДатаЗапроса);
	Запрос.УстановитьПараметр("ФизЛицо"		, ФизЛицо);
	
	Результат = Запрос.Выполнить();
	Если Результат.Пустой() Тогда
		Возврат Неопределено;
	Иначе
		Выборка = Результат.Выбрать();
		Выборка.Следующий();
		Возврат Выборка;
	КонецЕсли;
	
КонецФункции

// Процедура делает запись в РС ЭтапыКД по документам РСВ и КД
// Записи с одинаковыми КД+ДокументКД необходимо делать со сдвигом периода на СдвигПоВремениСек
//
// Параметры:
//  ДокументСсылка		 - ДокументСсылка.РаскрытиеСпискаВладельцев - ссылка на документ РСВ
//  BizMsgIdr			 - Строка - BizMsgIdr
//  СдвигПоВремениСек	 - Число - количество секунд для сдвига даты для периода
//
Процедура ЗарегистрироватьЭтапКД(ДокументСсылка, BizMsgIdr, СдвигПоВремениСек = 0) Экспорт
	
	Если ДокументСсылка.ТипЗагрузкиСписковРаскрытия = Перечисления.ТипЗагрузкиСписковРаскрытия.ISO20022
		И Не ЗначениеЗаполнено(ДокументСсылка.КарточкаКД) Тогда
		Возврат; // "Карточка КД" пишется в измерение КД только для вида загрузки ISO
	КонецЕсли;
	
	Этап 			= Справочники.ЭтапыКД.ИнструкцияДляУчастияВСобрании;
	ТипУведомления 	= "NEWM";
	
	ТипУведомления = Справочники.ТипыУведомления.НайтиПоКоду(ТипУведомления);
	Если Этап.Пустая() Тогда
		ЗаписьЖурналаРегистрации("Выгрузка 'Раскрытия списка владельцев'",
					УровеньЖурналаРегистрации.Ошибка, , ДокументСсылка,
					"Не найден тип уведомления " + ТипУведомления + ". Этап КД не выполнен");
		Возврат;
	КонецЕсли;
	
	ЗаписьЭтапаКД = РегистрыСведений.ЭтапыКД.СоздатьМенеджерЗаписи();
	Если ДокументСсылка.ТипЗагрузкиСписковРаскрытия = Перечисления.ТипЗагрузкиСписковРаскрытия.ISO20022 Тогда
		ЗаписьЭтапаКД.КД = ДокументСсылка.КарточкаКД;
	ИначеЕсли ДокументСсылка.ТипЗагрузкиСписковРаскрытия = Перечисления.ТипЗагрузкиСписковРаскрытия.PARTAD Тогда
		ЗаписьЭтапаКД.КД = ДокументСсылка;
	Иначе
		Возврат;
	КонецЕсли;
	ЗаписьЭтапаКД.ДокументКД 		= ДокументСсылка;
	ЗаписьЭтапаКД.Активность 		= Истина;
	ЗаписьЭтапаКД.Период 			= ДокументСсылка.Дата + СдвигПоВремениСек;
	ЗаписьЭтапаКД.ЭтапКД 			= Этап;
	ЗаписьЭтапаКД.КодОтчета 		= Этап.Код;
	ЗаписьЭтапаКД.НомерСообщения 	= BizMsgIdr;
	ЗаписьЭтапаКД.ТипУведомления	= ТипУведомления;
	ЗаписьЭтапаКД.Исходящее			= Истина;
	ЗаписьЭтапаКД.Записать();
	
	// Изменить статус документа раскрытия
	Если ДокументСсылка.Статус <> Перечисления.СтатусыРаскрытияСписковВладельцев.Выгружено Тогда
		мОбъект = ДокументСсылка.ПолучитьОбъект();
		мОбъект.Статус = Перечисления.СтатусыРаскрытияСписковВладельцев.Выгружено;
		мОбъект.Записать();
	КонецЕсли;

КонецПроцедуры

// Функция возвращает запрос для получения списка кодов загрузки ЦБ
//
// Параметры:
//  Дата	 - Дата - Текущая дата
// 
// Возвращаемое значение:
//  Запрос - объект запроса
//
Функция ЗапросДляСпискаКодовЗагрузкиЦБ(Дата) Экспорт
	Запрос = Новый Запрос(
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	КодыЗагрузки.Код КАК Код
	|ИЗ
	|	Справочник.КодыЗагрузки КАК КодыЗагрузки
	|ГДЕ
	|	НЕ КодыЗагрузки.ПометкаУдаления
	|	И КодыЗагрузки.Владелец = &Владелец
	|	И КодыЗагрузки.Биржа = &Биржа
	|	И ВЫБОР
	|			КОГДА НАЧАЛОПЕРИОДА(КодыЗагрузки.ДатаОкончанияДействия, ДЕНЬ) = ДАТАВРЕМЯ(1, 1, 1)
	|				ТОГДА ИСТИНА
	|			КОГДА НАЧАЛОПЕРИОДА(КодыЗагрузки.ДатаОкончанияДействия, ДЕНЬ) >= НАЧАЛОПЕРИОДА(&Дата, ДЕНЬ)
	|				ТОГДА ИСТИНА
	|			ИНАЧЕ ЛОЖЬ
	|		КОНЕЦ");

	Запрос.УстановитьПараметр("Биржа"	, Справочники.КлассификаторыЗагрузки.НДЦ());
	Запрос.УстановитьПараметр("Дата"	, Дата);
	Возврат Запрос;
КонецФункции

// Функция возвращает визуализацию раскрытия в виде текста html для формата раскрытия ISO 20022
//
// Параметры:
//  СтрокаДанных	 - Строка - текст xml с данными для визуализации
// 
// Возвращаемое значение:
//  Строка - визуализация раскрытия в виде текста html
//
Функция ВизуализацияHTML_ISO(СтрокаДанных) Экспорт
	Макет = ПолучитьМакет("ПреобразованиеXSL_ISO20022").ПолучитьТекст();
	Преобразование = Новый ПреобразованиеXSL;
	Преобразование.ЗагрузитьИзСтроки(Макет);
	Возврат Преобразование.ПреобразоватьИзСтроки(СтрокаДанных);
КонецФункции

// Возвращает признак того, что инициатор РСВ работает через транзитные W-пакеты
//
// Параметры:
//  ДокументРСВ	 - ДокументСсылка.РаскрытиеСпискаВладельцев	 - ссылка на документ раскрытия
// 
// Возвращаемое значение:
//   - Булево - Истина, если отправлять транзитный W-пакет
//
Функция ЭтоТранзитЧерезСЭДНРД(ДокументРСВ) Экспорт
	
	Если ТипЗнч(ДокументРСВ) <> Тип("ДокументСсылка.РаскрытиеСпискаВладельцев") Тогда
		Возврат Ложь;
	КонецЕсли;
	ИнициаторРСВ = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДокументРСВ, "Инициатор");
	Если ТипЗнч(ИнициаторРСВ) = Тип("СправочникСсылка.МестаХранения") Тогда
		ИнициаторТранзитЧерезСЭДНРД = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ИнициаторРСВ, "ТранзитЧерезСЭДНРД");
		Возврат ИнициаторТранзитЧерезСЭДНРД;
	Иначе
		Возврат Ложь;
	КонецЕсли;
	
КонецФункции

// Возвращает структуру с значениями параметров макет-шаблона ИсходящийШаблонТранзитWINF
//
// Параметры:
//  ДокументРСВ			 - ДокументСсылка.РаскрытиеСпискаВладельцев	 - Ссылка на документ раскрытия
//  ТехническаяОперация	 - ДокументСсылка.ТехническаяОперация		 - Ссылка на техническую операцию
//  ИмяКаталога			 - Строка									 - Имя каталога
//  ИмяФайлаXML			 - Строка									 - Имя основного файла (без расширения)
// 
// Возвращаемое значение:
//   - Структура - формирует и заполняет структуру [ORIGINATOR][RECIPIENT][GUID][DATE][TIME][DOC][NAME][FILE]
//
Функция ПараметрыТранзитаWINF(ДокументРСВ, ТехническаяОперация, ИмяКаталога, ИмяФайлаXML)
	
	ПараметрыТранзита = Новый Структура;
	КлассификаторНРД = Справочники.КлассификаторыЗагрузки.НДЦ();
	РеквизитыРСВ = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ДокументРСВ, "Организация,ДатаФиксации,Инициатор,Номер");
	ORIGINATOR = Справочники.Организации.КодЗагрузки(РеквизитыРСВ.Организация, КлассификаторНРД, РеквизитыРСВ.ДатаФиксации);
	ПараметрыТранзита.Вставить("ORIGINATOR", СокрЛП(ORIGINATOR));
	RECIPIENT = Справочники.КодыЗагрузки.НайтиПоВладельцуИБирже(РеквизитыРСВ.Инициатор, КлассификаторНРД);
	ПараметрыТранзита.Вставить("RECIPIENT", СокрЛП(RECIPIENT));
	GUID = XMLСтрока(ТехническаяОперация);
	ПараметрыТранзита.Вставить("GUID", GUID);
	DATE = Формат(ТехническаяОперация.Дата, "ДФ=dd.MM.yyyy");
	ПараметрыТранзита.Вставить("DATE", DATE);
	TIME = Формат(ТехническаяОперация.Дата, "ДФ=HH:mm:ss");
	ПараметрыТранзита.Вставить("TIME", TIME);
	DOC = СтрЗаменить(ОбщегоНазначенияКлиентСервер.Транслит(СокрЛП(РеквизитыРСВ.Номер)), "-", "");
	ПараметрыТранзита.Вставить("DOC", DOC);
	NAME = ИмяФайлаXML;
	ПараметрыТранзита.Вставить("NAME", NAME);
	FILE = ИмяФайлаXML + ".xml";
	ПараметрыТранзита.Вставить("FILE", FILE);
	
	Возврат ПараметрыТранзита;
	
КонецФункции

// Возвращает тело файла транзита WINF
//
// Параметры:
//  ДокументРСВ			 - ДокументСсылка.РаскрытиеСпискаВладельцев	 - Ссылка на документ раскрытия
//  ТехническаяОперация	 - ДокументСсылка.ТехническаяОперация		 - Ссылка на техническую операцию
//  ИмяКаталога			 - Строка									 - Имя каталога
//  ИмяФайлаXML			 - Строка									 - Имя основного файла
// 
// Возвращаемое значение:
//   - Строка - текст файла
//
Функция ТекстСообщенияТранзитаWINF(ДокументРСВ, ТехническаяОперация, ИмяКаталога, ИмяФайлаXML) Экспорт
	
	СтруктураПараметров = ПараметрыТранзитаWINF(ДокументРСВ, ТехническаяОперация, ИмяКаталога, ИмяФайлаXML);
	ТекстСообщения = ПолучитьМакет("ИсходящийШаблонТранзитWINF").ПолучитьТекст();
	Для Каждого Элемент Из СтруктураПараметров Цикл
		КлючПоиска = "[" + Элемент.Ключ + "]";
		ТекстСообщения = СтрЗаменить(ТекстСообщения, КлючПоиска, Элемент.Значение);
	КонецЦикла;
	
	Возврат ТекстСообщения;
	
КонецФункции


