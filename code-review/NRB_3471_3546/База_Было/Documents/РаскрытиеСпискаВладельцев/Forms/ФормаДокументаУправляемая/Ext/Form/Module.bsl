	мПараметры = Новый Структура("Отбор", Отбор);
	ОткрытьФорму("РегистрСведений.УведомленияОтправленныеЧерезЛичныйКабинет.ФормаСписка", мПараметры);
КонецПроцедуры

&НаКлиенте
Процедура ПроверитьСводноеРСВ(Команда)
	
	ПроверитьЗаполнениеСводногоРСВНаСервере();
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьСводноеРСВ(Команда)
	ЗаполнитьТаблицуСводногоРаскрытияСпискаВладельцев();
КонецПроцедуры

&НаКлиенте
Процедура ПроверкаСоотвествияСтавокСУДК(Команда)
	ПроверкаСоотвествияСтавокСУДКНаСервере();
	Сообщить("Выполнена сверка ставок");
КонецПроцедуры

&НаКлиенте
Процедура ВыгрузитьРаскрытиеВФайл(Команда)
	Если Не ЗначениеЗаполнено(Объект.Ссылка) Тогда
		ВызватьИсключение "Документ не записан!";
	ИначеЕсли НетПравНаОсобогоКлиента() Тогда
			ВызватьИсключение "Есть клиент с особыми условиями";
	ИначеЕсли Объект.ТипЗагрузкиСписковРаскрытия = ПредопределенноеЗначение("Перечисление.ТипЗагрузкиСписковРаскрытия.FCDR_2017_02") Тогда
		Диалог = Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.Сохранение);
		Диалог.Фильтр = "Файлы раскрытия (xml)|*.xml|Все файлы|*.*";
		Если Диалог.Выбрать() Тогда
			ФайлРаскрытия = Диалог.ПолноеИмяФайла;
			ВыгрузитьРаскрытиеВФайлFCDR(ФайлРаскрытия);
		КонецЕсли;
	ИначеЕсли Объект.ТипЗагрузкиСписковРаскрытия = ПредопределенноеЗначение("Перечисление.ТипЗагрузкиСписковРаскрытия.ISO20022") Тогда
		Диалог = Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.ВыборКаталога);
		Если Диалог.Выбрать() Тогда
			ВыгрузитьРаскрытиеВФайлISO(Диалог.Каталог);
		КонецЕсли;
	Иначе
		ВызватьИсключение СтрШаблон("Выгрузка типа загрузки %1 не поддерживается!", Объект.ТипЗагрузкиСписковРаскрытия);
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ВыгрузитьРаскрытиеВФайлПоУмолчанию(Команда)
	Если Не ЗначениеЗаполнено(Объект.Ссылка) Тогда
		ВызватьИсключение "Документ не записан!";
	ИначеЕсли НетПравНаОсобогоКлиента() Тогда
			ВызватьИсключение "Есть клиент с особыми условиями";
	ИначеЕсли Объект.ТипЗагрузкиСписковРаскрытия = ПредопределенноеЗначение("Перечисление.ТипЗагрузкиСписковРаскрытия.FCDR_2017_02") Тогда
		ВыгрузитьРаскрытиеВФайлПоУмолчаниюFCDR();
	ИначеЕсли Объект.ТипЗагрузкиСписковРаскрытия = ПредопределенноеЗначение("Перечисление.ТипЗагрузкиСписковРаскрытия.ISO20022") Тогда
		ВыгрузитьРаскрытиеВФайлПоУмолчаниюНаСервереISO();
	Иначе
		ВызватьИсключение СтрШаблон("Выгрузка типа загрузки %1 не поддерживается!", Объект.ТипЗагрузкиСписковРаскрытия);
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ПоказатьРаскрытие(Команда)
	Если Не ЗначениеЗаполнено(Объект.Ссылка) Тогда
		ВызватьИсключение "Документ не записан!";
	ИначеЕсли НетПравНаОсобогоКлиента() Тогда
			ВызватьИсключение "Есть клиент с особыми условиями";
	ИначеЕсли Объект.ТипЗагрузкиСписковРаскрытия = ПредопределенноеЗначение("Перечисление.ТипЗагрузкиСписковРаскрытия.FCDR_2017_02") Тогда
		ОписаниеОшибки = "";
		ТекстHTML = ПоказатьРаскрытиеFCDRНаСервере(Объект.Ссылка, ОписаниеОшибки);
		Если ЗначениеЗаполнено(ОписаниеОшибки) Тогда
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Текст = ОписаниеОшибки;
			Сообщение.Сообщить();
		КонецЕсли;
		Если ТекстHTML <> Неопределено Тогда
			ОткрытьФорму("Документ.РаскрытиеСпискаВладельцев.Форма.ВизуализацияHTML",
				Новый Структура("ЗначенияЗаполнения", ТекстHTML), ЭтотОбъект, ЭтотОбъект);
		КонецЕсли;
	ИначеЕсли Объект.ТипЗагрузкиСписковРаскрытия = ПредопределенноеЗначение("Перечисление.ТипЗагрузкиСписковРаскрытия.ISO20022") Тогда
		BizMsgIdr = ОбщегоНазначенияКлиентСервер.Транслит(СокрЛП(Объект.Номер));
		ПоказатьВизуализациюПоЦБISO(BizMsgIdr, Объект.ЦеннаяБумага1);
		ПоказатьВизуализациюПоЦБISO(BizMsgIdr, Объект.ЦеннаяБумага2);
	Иначе
		ВызватьИсключение СтрШаблон("Выгрузка типа загрузки %1 не поддерживается!", Объект.ТипЗагрузкиСписковРаскрытия);
	КонецЕсли;
КонецПроцедуры

&НаСервере
Функция НетПравНаОсобогоКлиента()
	НетПравНаОсобогоКлиента = Ложь;
	КлиентыСОсобымиУсловиями = Справочники.Контрагенты.ОсобыеУсловия(Объект.СписокВладельцев.Выгрузить(, "Клиент"), Истина);
	Если КлиентыСОсобымиУсловиями.Количество() > 0 
		И Не РегистрыСведений.ОтветственныеЛицаОрганизаций.ПользовательМожетРедактироватьОсобыеУсловия() Тогда
		Для Каждого Клиент Из КлиентыСОсобымиУсловиями Цикл
			НетПравНаОсобогоКлиента = Истина;
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Особые условия: " + Клиент
				+ ". Выполнение операции доступно Ответственному за особых клиентов");
		КонецЦикла;
	КонецЕсли;

	Возврат НетПравНаОсобогоКлиента;
	
КонецФункции

&НаКлиенте
Процедура ОбновитьСтатусы(Команда)
	ПолучитьСтатусыНаСервереFCDR();
КонецПроцедуры

&НаКлиенте
Процедура Выгрузить(Команда)
	Если Объект.Статус = ПредопределенноеЗначение("Перечисление.СтатусыРаскрытияСписковВладельцев.Принято") 
		И Вопрос("Документ в статусе 'Принято'! Вы уверены, что хотите повторить его выгрузку?", РежимДиалогаВопрос.ДаНет) = КодВозвратаДиалога.Нет Тогда
		Возврат;
	КонецЕсли;
	Если Модифицированность Или Объект.Ссылка.Пустая() Тогда
		Если Вопрос("Необходимо записать изменения документа, продолжать?", РежимДиалогаВопрос.ОКОтмена) = КодВозвратаДиалога.Отмена Тогда
			Возврат;
		КонецЕсли;
		Записать();
	КонецЕсли;
	ПрежнийСтатус = Объект.Статус;
	РезультатВыгрузки = ОткрытьФормуМодально("Документ.РаскрытиеСпискаВладельцев.Форма.ФормаВыгрузки", Новый Структура("Ключ", Объект.Ссылка), ЭтаФорма);
	Если ТипЗнч(РезультатВыгрузки) <> Тип("Структура") Тогда
		Возврат;
	КонецЕсли;
	ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Выгружено разделов: "+РезультатВыгрузки.КоличествоВыгруженных+", разделов с ошибками "+РезультатВыгрузки.КоличествоОшибок+".");
	Если ЗначениеЗаполнено(РезультатВыгрузки.ТекстОшибок) Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(РезультатВыгрузки.ТекстОшибок);
	Иначе // документ мог быть перезаписан
		Прочитать();
	КонецЕсли;
	ЗаполнитьТаблицуСводногоРаскрытияСпискаВладельцев();
	Если Объект.Статус <> ПрежнийСтатус Тогда
		ПоказатьПредупреждение(, "Документу присвоен статус '"+Объект.Статус+"'!", , "Выгрузка разделов в НРД");
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура РедактироватьСводноеРаскрытие(Команда)
	БылАвтоматическийРежим = ( Объект.СводноеРаскрытие.Количество() = 0 );
	Если БылАвтоматическийРежим Тогда
		Если Вопрос("Перейти в режии ручного заполнения сводного раскрытия?", РежимДиалогаВопрос.ДаНет) = КодВозвратаДиалога.Нет Тогда
			Возврат;
		КонецЕсли;
		ЗаполнитьСводноеРаскрытиеНаСервере();
	КонецЕсли;
	РезультатВыгрузки = ОткрытьФормуМодально("Документ.РаскрытиеСпискаВладельцев.Форма.ФормаРедактированияСводного", Новый Структура("Ключ", Объект.Ссылка), ЭтаФорма);
	Если РезультатВыгрузки = КодВозвратаДиалога.ОК Тогда
		Модифицированность = Истина;
		Объект.СводноеРаскрытиеРедактировалосьВручную = Истина;
		ВывестиДеревоСводногоРаскрытия();
	ИначеЕсли БылАвтоматическийРежим Тогда
		Объект.ШапкаСводного.Очистить();
		Объект.СводноеРаскрытие.Очистить();
	КонецЕсли;
	УстановитьВидимостьСводногоРаскрытия();
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьСводноеРаскрытие(Команда)
	Если Объект.СводноеРаскрытиеРедактировалосьВручную 
		И Вопрос("Сводное раскрытие редактировалось вручную, изменения будут утеряны!", РежимДиалогаВопрос.ОКОтмена) = КодВозвратаДиалога.Отмена Тогда
		Возврат;
	КонецЕсли;
	ЗаполнитьСводноеРаскрытиеНаСервере();
КонецПроцедуры

&НаКлиенте
Процедура ОтключитьРедактированиеСводногоРаскрытия(Команда)
	Если Вопрос("Вернуться к автоматическому заполнению сводного РСВ?", РежимДиалогаВопрос.ДаНет) = КодВозвратаДиалога.Да Тогда
		Модифицированность = Истина;
		Объект.ШапкаСводного.Очистить();
		Объект.СводноеРаскрытие.Очистить();
		УстановитьВидимостьСводногоРаскрытия();
	КонецЕсли;
КонецПроцедуры

////#КонецОбласти

