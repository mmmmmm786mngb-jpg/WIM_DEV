&НаКлиенте
Процедура ВыгрузитьРаскрытиеВФайлISO(Каталог)
	
	BizMsgIdr = ОбщегоНазначенияКлиентСервер.Транслит(СокрЛП(Объект.Номер));
	
	НеобходимоЗафиксироватьВыгрузкуЭтапа = Ложь;
	СформироватьФайлПоЦБ_ISO(Каталог, Объект.ЦеннаяБумага1, BizMsgIdr, 1, НеобходимоЗафиксироватьВыгрузкуЭтапа);
	Если НеобходимоЗафиксироватьВыгрузкуЭтапа Тогда
		ЗафиксироватьВыгрузкуЭтапаНаСервере(BizMsgIdr, 1);
	КонецЕсли;
	
	НеобходимоЗафиксироватьВыгрузкуЭтапа = Ложь;
	СформироватьФайлПоЦБ_ISO(Каталог, Объект.ЦеннаяБумага2, BizMsgIdr, 2, НеобходимоЗафиксироватьВыгрузкуЭтапа);
	Если НеобходимоЗафиксироватьВыгрузкуЭтапа Тогда
		ЗафиксироватьВыгрузкуЭтапаНаСервере(BizMsgIdr, 2, 1);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура СформироватьФайлПоЦБ_ISO(Каталог, ЦеннаяБумага, BizMsgIdr, Префикс, НеобходимоЗафиксироватьВыгрузкуЭтапа)
	
	Если Не ЗначениеЗаполнено(ЦеннаяБумага) Тогда
		Возврат;
	КонецЕсли;
	
	ДанныеДляВыгрузки = ДанныеДляФормированияСообщенияНаСервереISO(BizMsgIdr, ЦеннаяБумага);
	
	ТекстXML = Новый ТекстовыйДокумент;
	ТекстXML.ДобавитьСтроку(ДанныеДляВыгрузки.СтрокаXML);
	ИмяФайла = Объект.Номер + "_" + Формат(ОбщегоНазначенияВызовСервера.ДатаСеанса(), "ДФ=ddMMyyyy") + "_" + Префикс;
	ПолныйПутьКФайлу = Каталог + "\" + ИмяФайла + ".xml";
	Попытка
		ТекстXML.Записать(ПолныйПутьКФайлу);
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Сформирован файл " + ПолныйПутьКФайлу);
		НеобходимоЗафиксироватьВыгрузкуЭтапа = Истина;
	Исключение
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(
			"Не удалось записать файл!
			|
			|Возможно указанный в настройках каталог 'Каталог ISO' недоступен или путь некорректен!");
	КонецПопытки;
	
	ОбъектCSV = Новый ТекстовыйДокумент;
	ОбъектCSV.УстановитьТипФайла("windows-1251");
	ОбъектCSV.УстановитьТекст(ДанныеДляВыгрузки.СтрокаCSV);
	ПолныйПутьКФайлу = Каталог + "\" + ИмяФайла + ".csv";
	Попытка
		ОбъектCSV.Записать(ПолныйПутьКФайлу);
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Сформирован файл " + ПолныйПутьКФайлу);
	Исключение
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(
			"Не удалось записать файл CSV!
			|
			|Возможно указанный в настройках каталог 'Каталог ISO для CSV' недоступен или путь некорректен!");
	КонецПопытки;
	
КонецПроцедуры

&НаСервере
Функция ДанныеДляФормированияСообщенияНаСервереISO(BizMsgIdr, ЦеннаяБумага)
	ЗапросСпискаКодовЗагрузкиЦБ = Документы.РаскрытиеСпискаВладельцев.ЗапросДляСпискаКодовЗагрузкиЦБ(Объект.Дата);
	ДокументОбъект = Объект.Ссылка.ПолучитьОбъект();
	ДокументОбъект.ПроверитьЗаполнениеРСВДляВыгрузкиISO();
	ДокументОбъект.ПроверитьОшибкиПоКлиентам();
	ВыборкаПоЦБ = ДокументОбъект.ДанныеПоРаскрытию(ЦеннаяБумага);
	ДанныеДляВыгрузки = ДокументОбъект.ДанныеДляФормированияСообщенияПоЦБ_ISO(ЗапросСпискаКодовЗагрузкиЦБ,
		ЦеннаяБумага, ВыборкаПоЦБ, , , BizMsgIdr);
	Возврат ДанныеДляВыгрузки;
КонецФункции

&НаСервере
Процедура ЗафиксироватьВыгрузкуЭтапаНаСервере(BizMsgIdr, Префикс, СдвигПоВремениСек = 0)
	BizMsgIdr_СПрефиксом = Документы.РаскрытиеСпискаВладельцев.BizMsgIdr_СПрефиксом(BizMsgIdr, Префикс);
	Документы.РаскрытиеСпискаВладельцев.ЗарегистрироватьЭтапКД(Объект.Ссылка, BizMsgIdr_СПрефиксом, СдвигПоВремениСек);
КонецПроцедуры

&НаКлиенте
Процедура ВыгрузитьРаскрытиеВФайлПоУмолчаниюFCDR()
	ОписаниеОшибки = "";
	УКБезВыгодоприобретателей = "";
	СообщениеВНРД = ВыгрузитьРаскрытиеВФайлПоУмолчаниюFCDRНаСервере(Объект.Ссылка, ОписаниеОшибки, УКБезВыгодоприобретателей);
	СообщитьЕстьКлиентыБезВыгодоприобретателей(УКБезВыгодоприобретателей);
	Если СообщениеВНРД <> Неопределено Тогда
		ЗаписатьРаскрытиеВФайлПоУмолчаниюFCDRНаСервере(Объект.Ссылка, СообщениеВНРД, ОписаниеОшибки);
		Предупреждение("Файл сформирован");
	КонецЕсли;
	Если ЗначениеЗаполнено(ОписаниеОшибки) Тогда
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = ОписаниеОшибки;
		Сообщение.Сообщить();
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ВыгрузитьРаскрытиеВФайлFCDR(ФайлРаскрытия)
	ОписаниеОшибки = "";
	УКБезВыгодоприобретателей = "";
	СообщениеВНРД = ВыгрузитьРаскрытиеВФайлFCDRНаСервере(Объект.Ссылка, ОписаниеОшибки, УКБезВыгодоприобретателей);
	СообщитьЕстьКлиентыБезВыгодоприобретателей(УКБезВыгодоприобретателей);
	Если НЕ ЗначениеЗаполнено(ОписаниеОшибки) И ПустаяСтрока(УКБезВыгодоприобретателей) Тогда
		ЗаписьXML = Новый ЗаписьXML;
		ЗаписьXML.ОткрытьФайл(ФайлРаскрытия, "windows-1251");
		ЗаписьXML.ЗаписатьБезОбработки(СообщениеВНРД.ТекстДокумента);
		ЗаписьXML.Закрыть();
		УстановитьСтатусВыгруженоНаСервере(Объект.Ссылка);
		Предупреждение("Файл сформирован");
	КонецЕсли;
	Если ЗначениеЗаполнено(ОписаниеОшибки) Тогда
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = ОписаниеОшибки;
		Сообщение.Сообщить();
	КонецЕсли;
КонецПроцедуры

