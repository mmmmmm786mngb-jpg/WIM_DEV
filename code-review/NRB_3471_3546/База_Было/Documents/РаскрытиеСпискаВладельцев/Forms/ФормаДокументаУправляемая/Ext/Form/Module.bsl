	мПараметры = Новый Структура("Отбор", Отбор);
	ОткрытьФорму("РегистрСведений.ЭтапыКД.ФормаСписка", мПараметры);
КонецПроцедуры

&НаКлиенте
Процедура ОтправленныеУведомления(Команда)
