///////////////////////////////////////////////////////////////////////////////////
////#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	Если Объект.Ссылка.Пустая() Тогда
		Объект.Организация	= ?(Объект.Организация.Пустая(), Константы.ОрганизацияПоУмолчанию.Получить(), Объект.Организация);
		Объект.Автор		= ПараметрыСеанса.ТекущийПользователь;
		Объект.Изменил		= Справочники.Пользователи.ПустаяСсылка();
		Объект.Инициатор	= ?(НЕ ЗначениеЗаполнено(Объект.Инициатор), Константы.МестоХраненияПоУмолчанию.Получить(), Объект.Инициатор);
	КонецЕсли;
	ВыделятьСтрокиСЗаполненнымСубклиентомИНеподвтержденныеСубброкером();
	ЭмитентПриИзмененииНаСервере();
	УправлениеОтображениемРеквизитов();
	ПолучитьСтатусыНаСервереFCDR();
	Если Объект.СводноеРаскрытие.Количество() И НеобходимоВыводитьСводноеРСВ() Тогда
		ВывестиДеревоСводногоРаскрытия();
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура ПередЗаписьюНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	Если (ТекущийОбъект.ТипЗагрузкиСписковРаскрытия = Перечисления.ТипЗагрузкиСписковРаскрытия.PARTAD)
		И (ТекущийОбъект.ТипСписка.Пустая()) Тогда
		ОбщегоНазначения.СообщитьОбОшибке("Не заполнен 'Тип списка' для ПАРТАД!!!", Отказ);
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	Если НеобходимоВыводитьСводноеРСВ() Тогда
		УстановитьВидимостьСводногоРаскрытия();
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)

	Если (ИмяСобытия = "Документ.ЗапросСубброкеруНаРаскрытие.Изменен" И Параметр = Объект.Ссылка)
		Или (ИмяСобытия = "Документ.ЗапросСубброкеруНаРаскрытие.Отправлен" И Параметр = Объект.КДРеференс) Тогда 
		Прочитать();
		ЗаполнитьСписокВладельцевСервер();
		Модифицированность = Истина;
	КонецЕсли;
	
КонецПроцедуры

////#КонецОбласти

///////////////////////////////////////////////////////////////////////////////////
////#Область ОбработчикиКоманд

&НаКлиенте
Процедура ЗаполнитьСписокВладельцев(Команда)
	Модифицированность = Истина;
	ЗаполнитьСписокВладельцевСервер();
КонецПроцедуры

&НаКлиенте
Процедура ОчиститьСписокВладельцев(Команда)
