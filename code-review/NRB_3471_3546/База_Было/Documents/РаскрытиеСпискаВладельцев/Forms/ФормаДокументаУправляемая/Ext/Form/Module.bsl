&НаСервере
Процедура ПолучитьСтатусыНаСервереFCDR()
	дрв = Обработки.РаскрытиеСписковВладельцевFCDR_2017_02.ПолучитьДетальныеСтатусы(Объект.Ссылка);
	Для Каждого СтрДоговор Из дрв.Строки Цикл
		Статусы_Выгодоприобретатели = СтрДоговор.Строки;
		Для Каждого СтрВыгодоприобретатель Из СтрДоговор.Строки Цикл
			ОтборСтрок = Новый Структура("Договор",СтрДоговор.Договор);
			Если ЗначениеЗаполнено(СтрВыгодоприобретатель.Выгодоприобретатель) Тогда
				ОтборСтрок.Вставить("Выгодоприобретатель",СтрВыгодоприобретатель.Выгодоприобретатель);
			КонецЕсли;
			НайдСтр = Объект.СписокВладельцев.НайтиСтроки(ОтборСтрок);
			Для Каждого СтрДокумента Из НайдСтр Цикл
				Статусы = СтрВыгодоприобретатель.Строки;
				ТекСтатус = Статусы[0].Статус;
				Если ЗначениеЗаполнено(Статусы[0].СтатусОтказДопИнфо) Тогда
					ТекСтатус = ТекСтатус+" - "+Статусы[0].СтатусОтказДопИнфо;
				КонецЕсли;
				СтрДокумента.Статус = ТекСтатус;
				
				Для Каждого Стр Из Статусы Цикл
					НовСтр = СтрДокумента.ДанныеДляСтатуса.Добавить();
					ЗаполнитьЗначенияСвойств(НовСтр,Стр);
				КонецЦикла;
			КонецЦикла;
		КонецЦикла;
	КонецЦикла;
	
	ЗначениеВРеквизитФормы(дрв,"СтатусыСтрокРаскрытия");
КонецПроцедуры


Процедура ВывестиДеревоСводногоРаскрытия()
	
	ЭлементыРазделов = ДеревоСводногоРаскрытия.ПолучитьЭлементы();
	ЭлементыРазделов.Очистить();
	Таблица = Объект.ШапкаСводного.Выгрузить();
	ДобавитьЭлементШапкиСводногоРаскрытия(ЭлементыРазделов, Таблица, "CORPORATE ACTION NUMBER", "CorpActionNumber");
	ДобавитьЭлементШапкиСводногоРаскрытия(ЭлементыРазделов, Таблица, "SECURITY CODE (ISIN OR COMMON CODE)", "SecurityCode");
	ДобавитьЭлементШапкиСводногоРаскрытия(ЭлементыРазделов, Таблица, "SECURITY NAME", "SecurityName");
	ДобавитьЭлементШапкиСводногоРаскрытия(ЭлементыРазделов, Таблица, "DEPOSITOR CODE", "DepositorCode");
	ДобавитьЭлементШапкиСводногоРаскрытия(ЭлементыРазделов, Таблица, "QI-EIN NUMBER", "QI_EIN");
	ДобавитьЭлементШапкиСводногоРаскрытия(ЭлементыРазделов, Таблица, "TYPE OF ALLOCATION INFORMATION", "AllocationType");
	ДобавитьЭлементШапкиСводногоРаскрытия(ЭлементыРазделов, Таблица, "RECORD DATE", "RecordDate");
	ДобавитьЭлементШапкиСводногоРаскрытия(ЭлементыРазделов, Таблица, "SECURITIES CLEARANCE ACCOUNT NUMBER", "AccountNumber");
	
	Разделы = РаскрытиеСпискаВладельцев.РазделыСводногоРаскрытия(Объект);
	Запрос = Документы.ВыгрузкаРазделаРСВвВышестоящийДепозитарий.ЗапросСостоянийВыгрузкиРазделов(Объект.Ссылка, Разделы);
	СтатусыВФайловомШлюзе = Запрос.Выполнить().Выгрузить();
	
	Элемент = Неопределено;
	Для Каждого Строка Из Объект.СводноеРаскрытие Цикл
		Если Строка.НалоговаяСтавка = Неопределено Тогда // это итоговая запись по разделу
			СтрокаСтатуса = СтатусыВФайловомШлюзе.Найти(Строка.РазделСчетаДепоМХ, "Раздел");
			Если СтрокаСтатуса <> Неопределено Тогда
				Строка.СтатусВФайловомШлюзе = СтрокаСтатуса.Статус;
			КонецЕсли;
			ДобавитьЭлементСводногоРаскрытия(ЭлементыРазделов, Строка, "SUBACCOUNT NUMBER", "РазделСчетаДепоМХ");
			ДобавитьЭлементСводногоРаскрытия(ЭлементыРазделов, Строка, "TOTAL RECORD DATE BALANCE", "КоличествоЦБ");
			Элемент = ЭлементыРазделов.Добавить();
			Элемент.Название = "BREAKDOWN:";
			ЭлементыРаскрытия = Элемент.ПолучитьЭлементы();
			Продолжить;
		КонецЕсли;
		Если Строка.СтатусПоГлаве4 = Неопределено  // Группировкм по ставке и статусу выводятся вместе
			Или Элемент = Неопределено Тогда // Своное раскрытие заполнено некорректно
			Продолжить;
		КонецЕсли;
		Если Не ЗначениеЗаполнено(Строка.Договор) Тогда // заполненность договора - косвенный признак детальных записей; можно использовать другое неитоговое поле
			ДобавитьЭлементСводногоРаскрытия(ЭлементыРаскрытия, Строка, "QUANTITY OF SECURITIES", "КоличествоЦБ");
			ДобавитьЭлементСводногоРаскрытия(ЭлементыРаскрытия, Строка, "CHAPTER 3 OR CHAPTER 4 WITHHOLDING TAX RATE", "НалоговаяСтавка");
			ДобавитьЭлементСводногоРаскрытия(ЭлементыРаскрытия, Строка, "CHAPTER 4 WITHHOLDING RATE POOL", "СтатусПоГлаве4");
			ЭлементыДетализации = ЭлементыРаскрытия.Добавить().ПолучитьЭлементы();
			Продолжить;
		КонецЕсли;
		ДобавитьЭлементСводногоРаскрытия(ЭлементыДетализации, Строка);
	КонецЦикла;
	Элементы.СводноеРаскрытиеОтредакировано.Видимость = Объект.СводноеРаскрытиеРедактировалосьВручную;
	
КонецПроцедуры

Процедура ДобавитьЭлементШапкиСводногоРаскрытия(Элементы, Таблица, Название, ИмяПоля)
	Строка = Таблица.Найти(ИмяПоля, "Ключ");
	Если Строка = Неопределено Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не найден элемент шапки сводного раскрытия '"+ИмяПоля+"'");
		Возврат;
	КонецЕсли;
	Элемент = Элементы.Добавить();
	Элемент.Название = Название+":";
	Элемент.ИмяПоля = ИмяПоля;
	Элемент.Значение = Строка.Значение;
	Типы = Новый Массив;
	Типы.Добавить(ТипЗнч(Строка.Значение));
	Элемент.ТипЗначения = Новый ОписаниеТипов(Типы);
КонецПроцедуры

Процедура ДобавитьЭлементСводногоРаскрытия(Элементы, Строка, Название = "", ИмяПоля = "")
	Элемент = Элементы.Добавить();
	Если ПустаяСтрока(Название) Тогда // Детальные записи
		ЗаполнитьЗначенияСвойств(Элемент, Строка);
		ИмяПоля = "Договор";
		//Элемент.Значение = Строка[ИмяПоля];
	Иначе
		Элемент.Название = Название+":";
		Элемент.НомерСтроки = Строка.НомерСтроки;
	КонецЕсли;
	Если ЗначениеЗаполнено(ИмяПоля) Тогда
		Элемент.ИмяПоля = ИмяПоля;
		Элемент.Значение = Строка[ИмяПоля];
		Типы = Новый Массив;
		Типы.Добавить(ТипЗнч(Строка[ИмяПоля]));
		Элемент.ТипЗначения = Новый ОписаниеТипов(Типы);
		Если ТипЗнч(Элемент.Значение) = Тип("СправочникСсылка.РазделыСчетаДепоМХ") Тогда
			Элемент.СтатусВФайловомШлюзе = Строка.СтатусВФайловомШлюзе;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Функция ТекущаяСтрокаСводногоРаскрытия(ДанныеСтроки)
	Если ДанныеСтроки.НомерСтроки = 0 Тогда
		Строки = Объект.ШапкаСводного.НайтиСтроки(Новый Структура("Ключ", ДанныеСтроки.ИмяПоля));
		Если Строки.Количество() = 0 Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не найдено поле шапки сводного раскрытия '"+ДанныеСтроки.ИмяПоля+"'");
			Возврат Неопределено;
		КонецЕсли;
		Возврат Строки[0];
	Иначе
		Возврат Объект.СводноеРаскрытие[ДанныеСтроки.НомерСтроки-1];
	КонецЕсли;
КонецФункции

