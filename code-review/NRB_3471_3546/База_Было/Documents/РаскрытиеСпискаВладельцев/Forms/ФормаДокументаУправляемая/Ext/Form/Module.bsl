КонецПроцедуры

&НаКлиенте
Процедура СписокВладельцевСтатусОткрытие(Элемент, СтандартнаяОбработка)
	СтандартнаяОбработка = Ложь;
	ДанныеДляСтатуса = Новый Массив;
	Для Каждого Стр Из Элементы.СписокВладельцев.ТекущиеДанные.ДанныеДляСтатуса Цикл
		ДанныеДляСтатуса.Добавить(Новый Структура("Статус,СтатусОтказДопИнфо,НомерОтчетаНРД,ДатаОтчетаНРД,ОтчетОСтатусе",Стр.Статус,Стр.СтатусОтказДопИнфо,Стр.НомерОтчетаНРД,Стр.ДатаОтчетаНРД,Стр.ОтчетОСтатусе));
	КонецЦикла;
	
	Если ДанныеДляСтатуса.Количество()=0 Тогда
		Предупреждение("Нет данных о статусе");
	Иначе
		ОткрытьФорму("Обработка.РаскрытиеСписковВладельцевFCDR_2017_02.Форма.ДетализацияСтатусовСпискаРаскрытия",Новый Структура("ЗначенияЗаполнения",ДанныеДляСтатуса),ЭтаФорма,ЭтаФорма);
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ДеревоСводногоРаскрытияВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	Если Поле = Элементы.ДеревоСводногоРаскрытияНазвание Или Поле = Элементы.ДеревоСводногоРаскрытияЗначение Тогда
		Возврат;
	КонецЕсли;
	ПутьКДанным = ПутьКДаннымТекущегоПоля();
	Значение = Элемент.ТекущиеДанные[ПутьКДанным];
	Если ЗначениеЗаполнено(Значение) Тогда
		ОткрытьЗначение(Значение);
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ДеревоСводногоРаскрытияПередНачаломИзменения(Элемент, Отказ)
	ДанныеСтроки = Элементы.ДеревоСводногоРаскрытия.ТекущиеДанные;
	Если ПустаяСтрока(ДанныеСтроки.ИмяПоля) Тогда // это декоративная строка
		Отказ = Истина;
	ИначеЕсли ДанныеСтроки.ИмяПоля = "РазделСчетаДепоМХ" Или ДанныеСтроки.ИмяПоля = "НалоговаяСтавка" Тогда // структура редактируется только в диалоге
		Отказ = Истина;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ДеревоСводногоРаскрытияПередОкончаниемРедактирования(Элемент, НоваяСтрока, ОтменаРедактирования, Отказ)
	Если ОтменаРедактирования Тогда
		Возврат;
	КонецЕсли;
	ДанныеСтроки = Элементы.ДеревоСводногоРаскрытия.ТекущиеДанные;
	Если ПустаяСтрока(ДанныеСтроки.ИмяПоля) Тогда // это декоративная строка
		Возврат;
	ИначеЕсли Элемент.ТекущийЭлемент.Имя = "ДеревоСводногоРаскрытияЗначение" Тогда
		Строка = ТекущаяСтрокаСводногоРаскрытия(ДанныеСтроки);
		СтароеЗначение = ?(Строка.Свойство("Ключ"), Строка.Значение, Строка[ДанныеСтроки.ИмяПоля]);
		НовоеЗначение = ДанныеСтроки.ТипЗначения.ПривестиЗначение(ДанныеСтроки.Значение);
		Если Не ЗначениеЗаполнено(НовоеЗначение) И ДанныеСтроки.ИмяПоля <> "НалоговаяСтавка" Тогда // ставка может быть 0
			Отказ = Истина;
			ПоказатьПредупреждение( , "Введено неверное значение!");
		ИначеЕсли СтароеЗначение <> НовоеЗначение Тогда
			Если Вопрос("Изменить '"+СтароеЗначение+"' на '"+НовоеЗначение+"'?", РежимДиалогаВопрос.ДаНет) = КодВозвратаДиалога.Нет Тогда
				Отказ = Истина;
				Возврат;
			ИначеЕсли Строка.Свойство("Ключ") Тогда
				Строка.Значение = НовоеЗначение;
			Иначе
				Строка[ДанныеСтроки.ИмяПоля] = НовоеЗначение;
			КонецЕсли;
			Объект.СводноеРаскрытиеРедактировалосьВручную = Истина;
			Если Строка.Свойство("Изменен") Тогда // это строка шапки сводного
				Строка.Изменен = Истина;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ДеревоСводногоРаскрытияПриОкончанииРедактирования(Элемент, НоваяСтрока, ОтменаРедактирования)
	Если ОтменаРедактирования Тогда
		ДанныеСтроки = Элементы.ДеревоСводногоРаскрытия.ТекущиеДанные;
		Если ЗначениеЗаполнено(ДанныеСтроки.ИмяПоля) Тогда
			Строка = ТекущаяСтрокаСводногоРаскрытия(ДанныеСтроки);
			ДанныеСтроки.Значение = ?(Строка.Свойство("Ключ"), Строка.Значение, Строка[ДанныеСтроки.ИмяПоля]);
		КонецЕсли;
		Возврат;
	Иначе
		Модифицированность = Истина;
	КонецЕсли;
КонецПроцедуры

////#КонецОбласти

///////////////////////////////////////////////////////////////////////////////////
////#Область ВспомогательныеПроцедуры

&НаСервере
Процедура УправлениеОтображениемРеквизитов()
	// Видимость связанных КД
	Элементы.ГруппаКДСвязанноеВторое.Видимость	= ?(ЗначениеЗаполнено(Объект.СвязанныйВидКД1) И ЗначениеЗаполнено(Объект.СвязанныйРеференсКД1), Истина, Ложь);
	Если Не Элементы.ГруппаКДСвязанноеВторое.Видимость Тогда
		Объект.СвязанныйВидКД2		= Справочники.ВидыКорпоративныхДействий.ПустаяСсылка();
		Объект.СвязанныйРеференсКД2	= "";
	КонецЕсли;
	// Видимость второй ЦБ
	Элементы.ЦеннаяБумагаВторая.Видимость	= ?(ЗначениеЗаполнено(Объект.ЦеннаяБумага1), Истина, Ложь);
	Если НЕ Элементы.ЦеннаяБумагаВторая.Видимость Тогда
		Объект.ЦеннаяБумага2	= Справочники.ЦенныеБумаги.ПустаяСсылка();
	КонецЕсли;	
	
	Элементы.ГруппаДораскрытие.Видимость = Объект.Дораскрытие;
	
	Элементы.ГруппаКД.Доступность				= Не Объект.Дораскрытие;
	Элементы.ГруппаКДСвязанноеПервое.Доступность= Не Объект.Дораскрытие;
	Элементы.ГруппаКДСвязанноеВторое.Доступность= Не Объект.Дораскрытие;
	Элементы.ГруппаОрганизация.Доступность		= Не Объект.Дораскрытие;
	Элементы.ГруппаИнициатор.Доступность		= Не Объект.Дораскрытие;
	Элементы.ГруппаСчетДЕПО.Доступность			= Не Объект.Дораскрытие;
	Элементы.ГруппаБанковскийСчет.Доступность	= Не Объект.Дораскрытие;
	Элементы.ГруппаЦенныеБумаги.Доступность		= Не Объект.Дораскрытие;
	Элементы.ГруппаВходящийДокумент.Доступность	= Не Объект.Дораскрытие;
	Элементы.ДатаФиксации.Доступность			= Не Объект.Дораскрытие;
	Элементы.ДатаОкончанияПриема.Доступность	= Не Объект.Дораскрытие;
	
	Элементы.СписокВладельцевЦеннаяБумага.Видимость	= ЗначениеЗаполнено(Объект.ЦеннаяБумага2);

	КодыСобрания = Новый Массив;
	КодыСобрания.Добавить("BMET");
	КодыСобрания.Добавить("XMET");
	КодыСобрания.Добавить("MEET");
	
	Элементы.ГруппаДанныеСобрания.Видимость	= КодыСобрания.Найти(Объект.ВидКорпоративногоДействия.Код) <> Неопределено
		ИЛИ КодыСобрания.Найти(Объект.СвязанныйВидКД1.Код) <> Неопределено;
	Элементы.ГруппаБанковскийСчет.Видимость	= НЕ Элементы.ГруппаДанныеСобрания.Видимость;
		
	Элементы.ТипСписка.Видимость			= (Объект.ТипЗагрузкиСписковРаскрытия = Перечисления.ТипЗагрузкиСписковРаскрытия.PARTAD ИЛИ Объект.ТипЗагрузкиСписковРаскрытия = Перечисления.ТипЗагрузкиСписковРаскрытия.FCDR_2017_02);
	
	Если Объект.ТребуетсяРаскрытиеПоСубклиентам Тогда
		ЗаголовокНадписиРаскрытия	= "Требуется раскрытие по субклиентам!";
		ЦветТекстаНадписиРаскрытия	= WebЦвета.Черный;
		ШрифтТекстаНадписиРаскрытия	= Новый Шрифт(,, Истина);
	Иначе
		ЗаголовокНадписиРаскрытия	= "Не требуется раскрытие по субклиентам.";
		ЦветТекстаНадписиРаскрытия	= WebЦвета.ТемноСерый;
		ШрифтТекстаНадписиРаскрытия	= Новый Шрифт(,, Ложь);
	КонецЕсли;
	Элементы.ДекорацияРаскрытиеПоСубклиентам.Заголовок	= ЗаголовокНадписиРаскрытия;
	Элементы.ДекорацияРаскрытиеПоСубклиентам.ЦветТекста	= ЦветТекстаНадписиРаскрытия;
	Элементы.ДекорацияРаскрытиеПоСубклиентам.Шрифт		= ШрифтТекстаНадписиРаскрытия;
	
	Элементы.СписокВладельцевВыгодоприобретатель.Видимость	= Объект.ТребуетсяРаскрытиеПоСубклиентам;
	Элементы.СписокВладельцевПоДаннымСубброкера.Видимость	= Объект.ТребуетсяРаскрытиеПоСубклиентам;
	Элементы.СписокВладельцевДатаПолученияОтветаНД.Видимость= Объект.ТребуетсяРаскрытиеПоСубклиентам;
	
	ИспользоватьРегистрациюЗапросовСубброкера = WTRCСообщенияQI.ИспользоватьРегистрациюЗапросовСубброкера(Объект.Дата); 
	Элементы.СписокВладельцевДатаОтправкиЗапросаНД.Видимость = ИспользоватьРегистрациюЗапросовСубброкера;
	Элементы.СписокВладельцевЗапросыОтветы.Видимость = ИспользоватьРегистрациюЗапросовСубброкера;
	Элементы.СписокВладельцевРазделСчетаДепо.Видимость = ИспользоватьРегистрациюЗапросовСубброкера;
	Если НеобходимоВыводитьСводноеРСВ() Тогда
		Элементы.СтраницаСводноеРаскрытиеВладельцевЦБ.Видимость = Истина;
	Иначе
		Элементы.СтраницаСводноеРаскрытиеВладельцевЦБ.Видимость = Ложь;
	КонецЕсли;
	
	Элементы.ШаблонFCDR_2017_02.Видимость = Объект.ТипЗагрузкиСписковРаскрытия=Перечисления.ТипЗагрузкиСписковРаскрытия.FCDR_2017_02;

	Если Не ЗначениеЗаполнено(Объект.ДатаФиксации) Тогда
		ЖирныйШрифт = Новый Шрифт(, , Истина);
		Элементы.ДатаФиксации.ШрифтЗаголовка = ЖирныйШрифт;
	Иначе
		ОбычныйШрифт = Новый Шрифт;
		Элементы.ДатаФиксации.ШрифтЗаголовка = ОбычныйШрифт;
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьСписокВладельцевСервер()
	
	мОбъект = РеквизитФормыВЗначение("Объект");
	мОбъект.ЗаполнитьСписокВладельцев();
	ЗначениеВРеквизитФормы(мОбъект, "Объект");
	УправлениеОтображениемРеквизитов();
	Если НеобходимоВыводитьСводноеРСВ() Тогда
		ЗаполнитьТаблицуСводногоРаскрытияСпискаВладельцев();
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ДораскрытиеДокументПриИзмененииСервер()
	ДокументОбъект	= РеквизитФормыВЗначение("Объект");
	ДокументОбъект.Заполнить(Объект.ДораскрытиеДокумент);
	ЗначениеВРеквизитФормы(ДокументОбъект, "Объект");
КонецПроцедуры

&НаСервере
Процедура ЦеннаяБумагаПриИзмененииНаСервере(ИмяЭлемента)
	ДокументОбъект = РеквизитФормыВЗначение("Объект");
	
	Если ДокументОбъект.ЦеннаяБумага1 = ДокументОбъект.ЦеннаяБумага2 Тогда
		ДокументОбъект.ЦеннаяБумага2 = Справочники.ЦенныеБумаги.ПустаяСсылка();
	КонецЕсли;
	
	Если ИмяЭлемента = "ЦеннаяБумага1" Тогда
		Если Не ДокументОбъект.ЦеннаяБумага1.Пустая() Тогда
			ДокументОбъект.Эмитент = ДокументОбъект.ЦеннаяБумага1.Эмитент;
		КонецЕсли;
		
	ИначеЕсли ИмяЭлемента = "ЦеннаяБумага2" Тогда
		Если Не ДокументОбъект.ЦеннаяБумага2.Пустая() Тогда
			ДокументОбъект.Эмитент	= ДокументОбъект.ЦеннаяБумага2.Эмитент;
		КонецЕсли;
	КонецЕсли;
	
	ЗначениеВРеквизитФормы(ДокументОбъект, "Объект");
	
	ЭмитентПриИзмененииНаСервере();
	УправлениеОтображениемРеквизитов();
КонецПроцедуры

&НаСервере
Процедура УстановитьСвязиПоЭмитентуСервер()
	Если Не Объект.Эмитент.Пустая() Тогда
		НоваяСвязь	= Новый СвязьПараметраВыбора("Отбор.Эмитент", "Объект.Эмитент", РежимИзмененияСвязанногоЗначения.НеИзменять);
		НовыйМассив	= Новый Массив;
		НовыйМассив.Добавить(НоваяСвязь);
		НовыеСвязи	= Новый ФиксированныйМассив(НовыйМассив);
		Элементы.ЦеннаяБумага1.СвязиПараметровВыбора	= НовыеСвязи;
		Элементы.ЦеннаяБумага2.СвязиПараметровВыбора	= НовыеСвязи;
	Иначе
		Элементы.ЦеннаяБумага1.СвязиПараметровВыбора	= Новый ФиксированныйМассив(Новый Массив);
		Элементы.ЦеннаяБумага2.СвязиПараметровВыбора	= Новый ФиксированныйМассив(Новый Массив);
	КонецЕсли;	
КонецПроцедуры

&НаСервере
Процедура ЭмитентПриИзмененииНаСервере()
	ДокументОбъект = РеквизитФормыВЗначение("Объект");
	
	ЦенныеБумаги = Новый Массив;
	ЦенныеБумаги.Добавить("ЦеннаяБумага1");
	ЦенныеБумаги.Добавить("ЦеннаяБумага2");
	Для Каждого ЦБ Из ЦенныеБумаги Цикл
		Если ДокументОбъект[ЦБ].Эмитент <> ДокументОбъект.Эмитент Тогда
			ДокументОбъект[ЦБ] = Справочники.ЦенныеБумаги.ПустаяСсылка();
		КонецЕсли;
	КонецЦикла;
	
	ЗначениеВРеквизитФормы(ДокументОбъект, "Объект");
	
	УстановитьСвязиПоЭмитентуСервер();
	УправлениеОтображениемРеквизитов();
КонецПроцедуры

&НаСервере
Процедура ВыделятьСтрокиСЗаполненнымСубклиентомИНеподвтержденныеСубброкером()
	
	ИспользоватьРегистрациюЗапросовСубброкера =  WTRCСообщенияQI.ИспользоватьРегистрациюЗапросовСубброкера(Объект.Дата);
	
	ЭлементОформления = УсловноеОформление.Элементы.Добавить();
	ЭлементОформления.Использование = Истина;
	ЭлементОформления.Оформление.УстановитьЗначениеПараметра("ЦветТекста", WebЦвета.Кирпичный);
	
	ЭлементУсловия = ЭлементОформления.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ЭлементУсловия.ЛевоеЗначение	= Новый ПолеКомпоновкиДанных("Объект.ТребуетсяРаскрытиеПоСубклиентам");
	ЭлементУсловия.ВидСравнения		= ВидСравненияКомпоновкиДанных.Равно;
	ЭлементУсловия.ПравоеЗначение	= Истина;
	ЭлементУсловия.Использование	= Истина;
	
	ЭлементУсловия = ЭлементОформления.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ЭлементУсловия.ЛевоеЗначение	= Новый ПолеКомпоновкиДанных("Объект.СписокВладельцев.Субброкер");
	ЭлементУсловия.ВидСравнения		= ВидСравненияКомпоновкиДанных.Равно;
	ЭлементУсловия.ПравоеЗначение	= Истина;
	ЭлементУсловия.Использование	= Истина;

	ЭлементУсловия = ЭлементОформления.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ЭлементУсловия.ЛевоеЗначение	= Новый ПолеКомпоновкиДанных("Объект.СписокВладельцев.ПоДаннымСубброкера");
	ЭлементУсловия.ВидСравнения		= ВидСравненияКомпоновкиДанных.Равно;
	ЭлементУсловия.ПравоеЗначение	= Ложь;
	ЭлементУсловия.Использование	= Истина;
		
	Если ИспользоватьРегистрациюЗапросовСубброкера Тогда 
	
		ЭлементОформленияРасхождения = УсловноеОформление.Элементы.Добавить();
		ЭлементОформленияРасхождения.Использование = Истина;
		ЭлементОформленияРасхождения.Оформление.УстановитьЗначениеПараметра("ЦветТекста", WebЦвета.Кирпичный);
		
		ЭлементУсловия = ЭлементОформленияРасхождения.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
		ЭлементУсловия.ЛевоеЗначение	= Новый ПолеКомпоновкиДанных("Объект.СписокВладельцев.ЕстьРасхождения");
		ЭлементУсловия.ВидСравнения		= ВидСравненияКомпоновкиДанных.Равно;
		ЭлементУсловия.ПравоеЗначение	= Истина;
		ЭлементУсловия.Использование	= Истина;
	
    КонецЕсли;
	
	Для Каждого ТекЭлемент Из Элементы.СписокВладельцев.ПодчиненныеЭлементы Цикл
		ОформляемоеПоле = ЭлементОформления.Поля.Элементы.Добавить();
		ОформляемоеПоле.Поле = Новый ПолеКомпоновкиДанных(ТекЭлемент.Имя);
		
		Если ИспользоватьРегистрациюЗапросовСубброкера Тогда 
			ОформляемоеПоле = ЭлементОформленияРасхождения.Поля.Элементы.Добавить();
			ОформляемоеПоле.Поле = Новый ПолеКомпоновкиДанных(ТекЭлемент.Имя);
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьТаблицуСводногоРаскрытияСпискаВладельцев()
	
	ТДСводноеРСВ = Новый ТабличныйДокумент;
	Если Объект.Ссылка.Пустая() Или Модифицированность Тогда
		ТекущийОбъект = РеквизитФормыВЗначение("Объект");
	Иначе // если объект не заблокирован формой, он может быть перезаписан регламентынми заданиями
		ТекущийОбъект = Объект.Ссылка.ПолучитьОбъект();
	КонецЕсли;
	ТекущийОбъект.ЗаполнитьТабличныйДокументДляСводногоРСВ(ТДСводноеРСВ);
	СводноеРаскрытиеСпискаВладельцев.Очистить();
	СводноеРаскрытиеСпискаВладельцев.Вывести(ТДСводноеРСВ);
