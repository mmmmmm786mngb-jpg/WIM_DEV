&НаСервере
Процедура ВыгрузитьСписокСерверPARTADДепонентыССубклиентамиXLS(ДокументСсылка)
	// Контроль заполненности документа
	ТекстСообщенияОбОшибке = "";
	
	Если Не ДокументСсылка.Проведен Тогда
		ТекстСообщенияОбОшибке = ТекстСообщенияОбОшибке + "Не проведен документ." + Символы.ПС;
	КонецЕсли;
	
	МВТ = Новый МенеджерВременныхТаблиц;
	ПодготовитьВТ_СубклиентыСОтборомПоПериоду(ДокументСсылка, МВТ);
	
	Если КоличествоДепонентовССубклиентами(ДокументСсылка.СписокВладельцев.ВыгрузитьКолонку("Клиент"), МВТ) = 0 Тогда
		ТекстСообщенияОбОшибке = ТекстСообщенияОбОшибке + "В табличной части нет депонентов с субклиентами." + Символы.ПС;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ТекстСообщенияОбОшибке) Тогда
		ОбщегоНазначения.СообщитьОбОшибке("Файл раскрытия списка по субклиентам не сформирован:" + Символы.ПС
			+ ТекстСообщенияОбОшибке);
		Возврат;
	КонецЕсли; 
	
	ТаблицаXLS = Новый ТабличныйДокумент;
	Макет = ДокументСсылка.ПолучитьОбъект().ПолучитьМакет("РаскрытиеСпискаПоСубклиентам");
	
	// Вывод шапки
	ОбластьМакета = Макет.ПолучитьОбласть("Шапка");
	ТаблицаXLS.Вывести(ОбластьМакета);
	
	// Вывод табличной части
	ОбластьМакета = Макет.ПолучитьОбласть("Строка");
	
	CODE_SEC_Разделитель = Символы.ПС;
	ТаблицаПолей = ПоляВыгрузкиДепонентовССубклиентами(ДокументСсылка, МВТ, CODE_SEC_Разделитель);
	Для каждого Строка Из ТаблицаПолей Цикл
		ОбластьМакета.Параметры.Заполнить(Строка);
		ТаблицаXLS.Вывести(ОбластьМакета);
	КонецЦикла;
	
	Попытка
		ПапкаДанных	= СокрЛП(ВнешниеДанные.ПолучитьПараметрыВнешнегоИсточника(
			ПланыВидовХарактеристик.ВнешниеИсточники.КаталогВыгрузкиРаскрытияСпискаВладельцевССубклиентамиPartadXLS).Папка);
	Исключение
		ОбщегоНазначения.СообщитьОбОшибке(
		"Файл раскрытия списка по субклиентам не сформирован.
		|В плане видов характеристик ""Внешние источники"" у ""Выгрузка РСВ с субклиентами (Partad) XLS"" тип должен быть ""Папка"".
		|В регистре сведений ""Внешние источники"" для него необходимо указать папку выгрузки.");
		Возврат;							
	КонецПопытки;
	
	ИмяФайла = ПапкаДанных+"\"+ДокументСсылка.Номер+"_"+Формат(ТекущаяДата(), "ДФ=ddMMyyyy")+".xls";
	Попытка
		ТаблицаXLS.Записать(ИмяФайла, ТипФайлаТабличногоДокумента.XLS);
	Исключение
		ОбщегоНазначения.СообщитьОбОшибке(
		"Файл раскрытия списка по субклиентам не сформирован.
		|Не удалось записать файл " + ИмяФайла + Символы.ПС	+ОписаниеОшибки());
	КонецПопытки;
КонецПроцедуры

&НаСервере
Функция CODE_SEC_СКодамиЗагрузки(Поля, CODE_SEC_Разделитель)
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("КлассификаторЗагрузки", Справочники.КлассификаторыЗагрузки.НДЦ());
	Запрос.УстановитьПараметр("ЦеннаяБумага", Поля.ЦеннаяБумага);
	Запрос.УстановитьПараметр("ПустаяДата", Дата('00010101'));
	Запрос.Текст =
	"ВЫБРАТЬ
	|	КодыЗагрузки.Код КАК КодЗагрузки
	|ИЗ
	|	Справочник.КодыЗагрузки КАК КодыЗагрузки
	|ГДЕ
	|	КодыЗагрузки.Владелец = &ЦеннаяБумага
	|	И КодыЗагрузки.Биржа = &КлассификаторЗагрузки
	|	И КодыЗагрузки.ДатаОкончанияДействия = &ПустаяДата";
	Выборка = Запрос.Выполнить().Выбрать();
	КодыЗагрузки = "";
	КодыЗагрузки = КодыЗагрузки + ?(КодыЗагрузки <> "", CODE_SEC_Разделитель, "") + СокрЛП(Поля.ISIN);
	КодыЗагрузки = КодыЗагрузки + ?(КодыЗагрузки <> "", CODE_SEC_Разделитель, "") + СокрЛП(Поля.НомерРегистрации);
	Пока Выборка.Следующий() Цикл
		КодыЗагрузки = КодыЗагрузки + ?(КодыЗагрузки <> "", CODE_SEC_Разделитель, "") + СокрЛП(Выборка.КодЗагрузки);
	КонецЦикла;
    Возврат КодыЗагрузки;
КонецФункции
 
&НаСервере
Функция ПоляВыгрузкиДепонентовССубклиентами(ДокументСсылка, МВТ, CODE_SEC_Разделитель)
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МВТ;
	Запрос.УстановитьПараметр("ДокументСсылка", ДокументСсылка);
	Запрос.УстановитьПараметр("РазделительСерииНомера", " ");
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Субклиенты.Объект КАК Объект,
	|	ЕСТЬNULL(ЮридическиеЛица.ПолноеНаименование, Субклиенты.Клиент.Наименование) КАК BENEF_NAME,
	|	ВЫБОР
	|		КОГДА Субклиенты.Клиент ССЫЛКА Справочник.ЮридическиеЛица
	|				И НЕ Субклиенты.Клиент.НеРезидент
	|			ТОГДА ""OGRN""
	|		КОГДА Субклиенты.Клиент ССЫЛКА Справочник.ЮридическиеЛица
	|				И Субклиенты.Клиент.НеРезидент
	|			ТОГДА ""INCR""
	|		КОГДА Субклиенты.Клиент ССЫЛКА Справочник.ФизическиеЛица
	|			ТОГДА ПаспортныеДанныеФизЛицСрезПоследних.ДокументВид.КодНРД
	|	КОНЕЦ КАК DOCTYPE,
	|	ВЫБОР
	|		КОГДА Субклиенты.Клиент ССЫЛКА Справочник.ЮридическиеЛица
	|			ТОГДА Субклиенты.Клиент.ОГРН
	|		КОГДА Субклиенты.Клиент ССЫЛКА Справочник.ФизическиеЛица
	|			ТОГДА ПаспортныеДанныеФизЛицСрезПоследних.ДокументСерия + &РазделительСерииНомера + ПаспортныеДанныеФизЛицСрезПоследних.ДокументНомер
	|	КОНЕЦ КАК DOCNUM,
	|	ВЫБОР
	|		КОГДА Субклиенты.Клиент ССЫЛКА Справочник.ЮридическиеЛица
	|			ТОГДА Субклиенты.Клиент.ДатаГосРегистрации
	|		КОГДА Субклиенты.Клиент ССЫЛКА Справочник.ФизическиеЛица
	|			ТОГДА ПаспортныеДанныеФизЛицСрезПоследних.ДокументДатаВыдачи
	|	КОНЕЦ КАК DOCDATE
	|ПОМЕСТИТЬ ВТ_Субклиенты
	|ИЗ
	|	ВТ_СубклиентыСОтборомПоПериоду КАК Субклиенты
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ЮридическиеЛица КАК ЮридическиеЛица
	|		ПО (ЮридическиеЛица.Ссылка = Субклиенты.Клиент)
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ПаспортныеДанныеФизЛиц.СрезПоследних КАК ПаспортныеДанныеФизЛицСрезПоследних
	|		ПО (ПаспортныеДанныеФизЛицСрезПоследних.ФизЛицо = Субклиенты.Клиент)
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Субклиенты.Объект
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СписокВладельцев.ЦеннаяБумага.Ссылка КАК ЦеннаяБумага,
	|	СписокВладельцев.ЦеннаяБумага.ISIN КАК ISIN,
	|	СписокВладельцев.ЦеннаяБумага.НомерРегистрации КАК НомерРегистрации,
	|	СписокВладельцев.ЦеннаяБумага.Эмитент.ЮридическиеФизическиеЛица.Наименование КАК NAME_ISSUER,
	|	СписокВладельцев.Ссылка.ДатаФиксации КАК RECDATE,
	|	СписокВладельцев.Ссылка.Организация.LEI КАК LEI_DEP,
	|	СписокВладельцев.Клиент.Код КАК OWNER_ID,
	|	ЕСТЬNULL(ЮридическиеЛица.ПолноеНаименование, СписокВладельцев.Клиент.ЮридическиеФизическиеЛица.Наименование) КАК OWNER_NAME,
	|	1 КАК BENEF_TYPE,
	|	ВТ_Субклиенты.BENEF_NAME КАК BENEF_NAME,
	|	ВТ_Субклиенты.DOCTYPE КАК DOCTYPE,
	|	ВТ_Субклиенты.DOCNUM КАК DOCNUM,
	|	ВТ_Субклиенты.DOCDATE КАК DOCDATE,
	|	"""" КАК ADDRESS,
	|	СписокВладельцев.Количество КАК QTY,
	|	"""" КАК QTY_NOM,
	|	"""" КАК QTY_DENOM
	|ИЗ
	|	Документ.РаскрытиеСпискаВладельцев.СписокВладельцев КАК СписокВладельцев
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_Субклиенты КАК ВТ_Субклиенты
	|		ПО (ВТ_Субклиенты.Объект = СписокВладельцев.Клиент.Ссылка)
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ЮридическиеЛица КАК ЮридическиеЛица
	|		ПО (ЮридическиеЛица.Ссылка = СписокВладельцев.Клиент.ЮридическиеФизическиеЛица)
	|ГДЕ
	|	СписокВладельцев.Ссылка = &ДокументСсылка
	|";
    ТаблицаПолей = Запрос.Выполнить().Выгрузить();
	ТаблицаПолей.Колонки.Добавить("CODE_SEC");
	Для каждого Строка Из ТаблицаПолей Цикл
		Строка.CODE_SEC = CODE_SEC_СКодамиЗагрузки(Строка, CODE_SEC_Разделитель);
	КонецЦикла;
	Возврат ТаблицаПолей;
КонецФункции

&НаСервере
Функция КоличествоДепонентовССубклиентами(МассивКонтрагентов, МВТ)
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МВТ;
	Запрос.УстановитьПараметр("МассивКонтрагентов", МассивКонтрагентов);
	Запрос.Текст =
	"ВЫБРАТЬ
	|	КОЛИЧЕСТВО(ВложенныйЗапрос.Контрагент) КАК КоличествоДепонентовССубклиентами
	|ИЗ
	|	(ВЫБРАТЬ
	|		Контрагенты.Ссылка КАК Контрагент,
	|		СУММА(ВЫБОР
	|				КОГДА Субклиенты.Клиент ЕСТЬ NULL 
	|					ТОГДА 0
	|				ИНАЧЕ 1
	|			КОНЕЦ) КАК КоличествоСубклиентов
	|	ИЗ
	|		Справочник.Контрагенты КАК Контрагенты
	|			ЛЕВОЕ СОЕДИНЕНИЕ ВТ_СубклиентыСОтборомПоПериоду КАК Субклиенты
	|			ПО (Субклиенты.Объект = Контрагенты.Ссылка)
	|	ГДЕ
	|		Контрагенты.Ссылка В(&МассивКонтрагентов)
	|	
	|	СГРУППИРОВАТЬ ПО
	|		Контрагенты.Ссылка) КАК ВложенныйЗапрос
	|ГДЕ
	|	ВложенныйЗапрос.КоличествоСубклиентов > 0";
    Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.КоличествоДепонентовССубклиентами
	Иначе
		Возврат 0;
	КонецЕсли; 
КонецФункции

&НаСервере
Процедура ПодготовитьВТ_СубклиентыСОтборомПоПериоду(ДокументРаскрытия, МВТ)
	// Получить дату фиксации
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Документ", ДокументРаскрытия);
	Запрос.Текст =
	"ВЫБРАТЬ
	|	РаскрытиеСпискаВладельцев.ДатаФиксации
	|ИЗ
	|	Документ.РаскрытиеСпискаВладельцев КАК РаскрытиеСпискаВладельцев
	|ГДЕ
	|	РаскрытиеСпискаВладельцев.Ссылка = &Документ";
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		ДатаФиксации = Выборка.ДатаФиксации
	Иначе
		Возврат;
	КонецЕсли; 
	
	// Получить ВТ_СубклиентыСОтборомПоПериоду
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МВТ;
	Запрос.УстановитьПараметр("ДатаФиксации", ДатаФиксации);
	Запрос.УстановитьПараметр("ПустаяДата", Дата('00010101'));
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Субклиенты.Объект КАК Объект,
	|	Субклиенты.Клиент КАК Клиент
	|ПОМЕСТИТЬ ВТ_СубклиентыСОтборомПоПериоду
	|ИЗ
	|	РегистрСведений.Субклиенты КАК Субклиенты
	|ГДЕ
	|	Субклиенты.ДатаОбслуживанияНачало <= &ДатаФиксации
	|	И Субклиенты.ДатаОбслуживанияКонец >= &ДатаФиксации
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	Субклиенты.Объект,
	|	Субклиенты.Клиент
	|ИЗ
	|	РегистрСведений.Субклиенты КАК Субклиенты
	|ГДЕ
	|	Субклиенты.ДатаОбслуживанияНачало <= &ДатаФиксации
	|	И Субклиенты.ДатаОбслуживанияКонец = &ПустаяДата
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Субклиенты.Объект";
    Запрос.Выполнить();
КонецПроцедуры


