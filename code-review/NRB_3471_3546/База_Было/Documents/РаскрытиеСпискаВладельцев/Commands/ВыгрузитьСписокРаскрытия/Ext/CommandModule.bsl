Функция ФИО(Фамилия, Имя, Отчество)
	ФИО	= СокрЛП(Фамилия);
	ФИО	= СокрЛП(ФИО) + ?(ЗначениеЗаполнено(ФИО), " ", "") + СокрЛП(Имя);
	ФИО	= СокрЛП(ФИО) + ?(ЗначениеЗаполнено(ФИО), " ", "") + СокрЛП(Отчество);
