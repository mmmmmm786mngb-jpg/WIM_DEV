&НаСервере
Процедура ДобавитьАдресаЭлПочты(СписокEmail, ЗапросСпискаEmail, Клиент)
	ЗапросСпискаEmail.УстановитьПараметр("Объект", Клиент);
	EmailКлиента = ЗапросСпискаEmail.Выполнить().Выгрузить();
	Для Каждого СтрокаEmail ИЗ EmailКлиента Цикл
		email = СокрЛП(СтрокаEmail.Представление);
		Если ЗначениеЗаполнено(email) И СписокEmail.НайтиПоЗначению(email) = Неопределено Тогда
			СписокEmail.Добавить(email);
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

&НаСервере
Процедура ДобавитьПараметрыТелефонов(СписокПараметровТелефонов, ЗапросСпискаТелефонов, Клиент)
	ТипыТелефонов = Новый Соответствие;
	ТипыТелефонов.Вставить("ФАКС",	"FAXI");
	ТипыТелефонов.Вставить("МОБ",	"MOBI");
	ТипыТелефонов.Вставить("РАБ",	"BIZZ");
	ТипыТелефонов.Вставить("ДОМ",	"HOME");
	
	ЗапросСпискаТелефонов.УстановитьПараметр("Объект", Клиент);
	ТелефоныКлиента	= ЗапросСпискаТелефонов.Выполнить().Выгрузить();
	Для Каждого СтрокаТелефон Из ТелефоныКлиента Цикл
		Телефон			= СокрЛП(СтрокаТелефон.Представление);
		ВидТелефона		= ВРег(СтрокаТелефон.Вид);
		ТелефонПроверка	= СокрЛП(СтрЗаменить(Телефон, "(", ""));
		ТелефонПроверка	= СокрЛП(СтрЗаменить(ТелефонПроверка, ")", ""));
		Если ЗначениеЗаполнено(ТелефонПроверка) Тогда
			ПараметрыТелефона = Новый Соответствие;
			ПараметрыТелефона.Вставить("phone_num", Телефон);
			
			Для Каждого Элемент Из ТипыТелефонов Цикл
				Если Найти(ВидТелефона, Элемент.Ключ) > 0 Тогда
					ПараметрыТелефона.Вставить("phone_type", Элемент.Значение);
					Прервать;
				КонецЕсли;
			КонецЦикла;
			Если ПараметрыТелефона["phone_type"] = Неопределено Тогда
				ПараметрыТелефона.Вставить("phone_type", ТипыТелефонов["РАБ"]);
			КонецЕсли;
			
			СписокПараметровТелефонов.Добавить(ПараметрыТелефона);
		КонецЕсли;			
	КонецЦикла;
КонецПроцедуры

