//**************************************************************************************************
// ОБРАБОТЧИКИ СОБЫТИЙ
//**************************************************************************************************

&НаКлиенте
Процедура ОбработкаКоманды(ПараметрКоманды, ПараметрыВыполненияКоманды)
	ОбработкаКомандыНаСервере(ПараметрКоманды);
КонецПроцедуры

//**************************************************************************************************
// СЛУЖЕБНЫЕ ФУНКЦИИ
//**************************************************************************************************

&НаСервере
Процедура ОбработкаКомандыНаСервере(ПараметрКоманды)
	Для Каждого Документ ИЗ ПараметрКоманды Цикл
		Если Не ЗначениеЗаполнено(Документ) Тогда
			ОбщегоНазначения.СообщитьОбОшибке(
				"Выгрузка списка раскрытия возможна только для записанного документа без изменений!");
			Продолжить;
		КонецЕсли;
		
		Если НЕ ЗаполненыВсеНеобходимыеРеквизитыДокумента(Документ) Тогда
			ОбщегоНазначения.СообщитьОбОшибке(
				"Заполнены не все необходимые для формирования списка раскрытия реквизиты документа "+Документ);
			Продолжить;
		КонецЕсли;	
		
		Если Документ.ТипЗагрузкиСписковРаскрытия = Перечисления.ТипЗагрузкиСписковРаскрытия.PARTAD Тогда
			Если Документ.ВыгрузкаPARTADВCоответствииCоCтатьей8_6_1 Тогда
				ВыгрузитьСписокСерверPARTADДепонентыССубклиентамиXLS(Документ);
			КонецЕсли;
			ВыгрузитьСписокСерверPARTAD(Документ);	
			
		ИначеЕсли Документ.ТипЗагрузкиСписковРаскрытия = Перечисления.ТипЗагрузкиСписковРаскрытия.ISO20022 Тогда
			Если ВыполненыУсловияВыгрузкиПоИСО20022(Документ) Тогда
				ДокументОбъект = Документ.ПолучитьОбъект();
				ДокументОбъект.СформироватьФайлПоЦБвФШ_ISO();
			КонецЕсли;
		ИначеЕсли Документ.ТипЗагрузкиСписковРаскрытия = Перечисления.ТипЗагрузкиСписковРаскрытия.FCDR_2017_02 Тогда
			ОписаниеОшибки = "";
			Обработки.РаскрытиеСписковВладельцевFCDR_2017_02.ВыгрузитьРаскрытиеСпискаВ_ФШ(Документ,ОписаниеОшибки);
			Если ЗначениеЗаполнено(ОписаниеОшибки) Тогда
				ОбщегоНазначения.СообщитьОбОшибке(
					"Ошибка выгрузки списка раскрытия "+Документ+": "+ОписаниеОшибки);
			КонецЕсли;
			
		Иначе
			ОбщегоНазначения.СообщитьОбОшибке("Не определен тип используемой выгрузки для " + Документ);
		КонецЕсли;			
	КонецЦикла;
КонецПроцедуры

&НаСервере
Функция ЗаполненыВсеНеобходимыеРеквизитыДокумента(ПараметрПроверки)
	МетаданныеПроверка = ПараметрПроверки.Метаданные();
	
	Для Каждого Реквизит из МетаданныеПроверка.Реквизиты Цикл
		Если Реквизит.ПроверкаЗаполнения = ПроверкаЗаполнения.ВыдаватьОшибку Тогда
			Если НЕ ЗначениеЗаполнено(ПараметрПроверки[Реквизит.Имя]) Тогда
				Возврат Ложь;
			КонецЕсли;
		КонецЕсли;		
	КонецЦикла;
	
	Если ПараметрПроверки.Дораскрытие И НЕ ЗначениеЗаполнено(ПараметрПроверки.ДораскрытиеДокумент) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Возврат Истина;
КонецФункции

&НаСервере
Функция ВыполненыУсловияВыгрузкиПоИСО20022(Документ)
	МожноВыгружать = Ложь;
	Если ЗначениеЗаполнено(Документ.СвязанныйВидКД1) И Документ.СвязанныйВидКД1.Код = "WTRC" Тогда
		ОбщегоНазначения.СообщитьОбОшибке(
			"Подтверждение освобождения от налогов не требует выгрузки РСВ. 
			|	Используйте кнопку Выгрузить на вкладке Сводное раскрытие");
	ИначеЕсли Не Документ.Проведен Тогда
		ОписаниеОшибки = "Документ " + Документ + " не проведен. Файл раскрытия не может быть сформирован";
		ОбщегоНазначения.СообщитьОбОшибке("Ошибка выгрузки списка раскрытия " + Документ + ": " + ОписаниеОшибки);
	Иначе
		МожноВыгружать = Истина;
	КонецЕсли;
	Возврат МожноВыгружать;
КонецФункции

//**************************************************************************************************
// РАБОТА С XML ВЫГРУЗКОЙ ПАРТАД
//**************************************************************************************************

&НаСервере
Процедура ВыгрузитьСписокСерверPARTAD(ПараметрКоманды)
	// Контроль заполненности документа
	Если Не ПараметрКоманды.Проведен Тогда
		ОбщегоНазначения.СообщитьОбОшибке("Файл раскрытия списка не сформирован - Не заполнен и не проведен документ!");
	КонецЕсли;
	// Получим код LEI
	КодLEI = СокрЛП(ПараметрКоманды.Организация.LEI);
	Если Не ЗначениеЗаполнено(КодLEI) Тогда
		ОбщегоНазначения.СообщитьОбОшибке("Файл раскрытия списка не сформирован - Не заполнен LEI код у организации!");
		Возврат;
	КонецЕсли;	
	// Если список владельцев пуст, то не формируем
	Если ПараметрКоманды.СписокВладельцев.Количество()=0 Тогда
		ОбщегоНазначения.СообщитьОбОшибке("Файл раскрытия списка не сформирован - список владельцев не заполнен!");
		Возврат;
	КонецЕсли;	
	// Определим пространство имен
	ПространствоИмен = "PARTAD";
	// Объявим объект для записи XML
	ЗаписьXML = Новый ЗаписьXML;
	ЗаписьXML.УстановитьСтроку("UTF-8");
	ЗаписьXML.ЗаписатьОбъявлениеXML();
	// Подготовим запросы по информации клиента
	ЗапросКодНДЦЮрЛица			= ПодготовитьЗапросДляКодаЗагрузкиНДЦЮрЛица(ПараметрКоманды);
	ЗапросСпискаEmail			= ПодготовитьЗапросДляСпискаEmailКлиента(ПараметрКоманды);
	ЗапросСпискаТелефонов		= ПодготовитьЗапросДляСпискаТелефоновКлиента(ПараметрКоманды);
	ЗапросСпискаКодовЗагрузкиЦБ	= Документы.РаскрытиеСпискаВладельцев.ЗапросДляСпискаКодовЗагрузкиЦБ(ПараметрКоманды.Дата);
	//************************************************************************************
	// REGISTER_OF_SHAREHOLDERS
	//************************************************************************************
	REGISTER_OF_SHAREHOLDERS_Тип	= ФабрикаXDTO.Пакеты.Получить(ПространствоИмен).КорневыеСвойства.Получить(
		"REGISTER_OF_SHAREHOLDERS").Тип;
	REGISTER_OF_SHAREHOLDERS		= ФабрикаXDTO.Создать(REGISTER_OF_SHAREHOLDERS_Тип);
	//************************************************************************************
	// Заполним реквизиты базового типа REGISTER_OF_SHAREHOLDERS (version / header)	
	//************************************************************************************
	REGISTER_OF_SHAREHOLDERS_База_Тип	= ФабрикаXDTO.Тип(ПространствоИмен, "answer_doc_t");
	REGISTER_OF_SHAREHOLDERS_База		= ФабрикаXDTO.Создать(REGISTER_OF_SHAREHOLDERS_База_Тип);
	// version
	REGISTER_OF_SHAREHOLDERS_База.version	= "3";
	// header
	REGISTER_OF_SHAREHOLDERS_База_header	= ФабрикаXDTO.Создать(REGISTER_OF_SHAREHOLDERS_База_Тип.Свойства.Получить("header").Тип);
	// header - doc_num
	REGISTER_OF_SHAREHOLDERS_База_header.doc_num	= ОбщегоНазначенияКлиентСервер.Транслит(СокрЛП(ПараметрКоманды.Номер));
	// header - doc_date
	header_doc_date	= ФабрикаXDTO.Создать(ФабрикаXDTO.Тип(ПространствоИмен, "date_or_datetime_t"));
	header_doc_date.date	= ПараметрКоманды.Дата;
	
	REGISTER_OF_SHAREHOLDERS_База_header.doc_date	= header_doc_date;
	// header - link
	header_link	= ФабрикаXDTO.Создать(ФабрикаXDTO.Тип(ПространствоИмен, "doc_link_t"));
	// Исходящий номер и дата документа
	header_link.out_doc_num = ?(ЗначениеЗаполнено(ПараметрКоманды.ВходящийДокументНомер),
		СокрЛП(ПараметрКоманды.ВходящийДокументНомер), "NONREF");	
	header_link_out_doc_date = ФабрикаXDTO.Создать(ФабрикаXDTO.Тип(ПространствоИмен, "date_or_datetime_t"));
	header_link_out_doc_date.date = ?(ЗначениеЗаполнено(ПараметрКоманды.ВходящийДокументДата),
		ПараметрКоманды.ВходящийДокументДата, Дата(1900,1,1));
	header_link.out_doc_date = header_link_out_doc_date;
	// Входящий номер и дата документа
	header_link.in_doc_num = "UKWN";
	// заполним ссылку на документ
	REGISTER_OF_SHAREHOLDERS_База_header.link = header_link;
	
	REGISTER_OF_SHAREHOLDERS.header = REGISTER_OF_SHAREHOLDERS_База_header;
	//************************************************************************************
	// Реквизиты базового типа зполнены, заполняем остальные реквизиты по определению типа
	//************************************************************************************
	// issuer (тип XDTO: party_id_name_t)
	//************************************************************************************
	ПараметрыТега_ISSUER = Новый Соответствие;
	ПараметрыТега_ISSUER.Вставить("party_id_name", СокрЛП(ПараметрКоманды.Эмитент.ЮридическиеФизическиеЛица.Наименование));
	
	Список_ISSUER_ID = Новый СписокЗначений;
	
	ЗапросКодНДЦЮрЛица.УстановитьПараметр("Владелец", ПараметрКоманды.Эмитент.ЮридическиеФизическиеЛица);
	СписокКодовНДЦ	= ЗапросКодНДЦЮрЛица.Выполнить().Выгрузить();	
	Для Каждого СтрокаКодовНДЦ ИЗ СписокКодовНДЦ Цикл
		ПараметрыТега_ISSUER_ID	= Новый Соответствие;
		ПараметрыТега_ISSUER_ID.Вставить("id", СокрЛП(СтрокаКодовНДЦ.Код));
		Список_ISSUER_ID.Добавить(ПараметрыТега_ISSUER_ID);
	КонецЦикла;
	
	ПараметрыТега_ISSUER.Вставить("id_t", Список_ISSUER_ID);
	
	REGISTER_OF_SHAREHOLDERS.issuer.Добавить(РаскрытиеСпискаВладельцев.Partad_СформироватьТег_party_id_name_t(
		ПространствоИмен, ПараметрыТега_ISSUER));
	//************************************************************************************
	// account_dtls (тип XDTO: account_dtls_t)
	//************************************************************************************
	ПараметрыТега_account_dtls = Новый Соответствие;
	
	ПараметрыТега_account_dtls_ID = Новый Соответствие;
	ПараметрыТега_account_dtls_ID.Вставить("id", СокрЛП(ПараметрКоманды.СчетДЕПО.Код));
	
	ПараметрыТега_account_dtls.Вставить("id_t", ПараметрыТега_account_dtls_ID);
	
	REGISTER_OF_SHAREHOLDERS.account_dtls = РаскрытиеСпискаВладельцев.Partad_СформироватьТег_account_dtls_t(
		ПространствоИмен, ПараметрыТега_account_dtls);
	//************************************************************************************
	// account_holder (тип XDTO: party_dtls_t)
	//************************************************************************************
	ПараметрыТега_account_holder = Новый Соответствие;
	
	ПараметрыТега_account_holder_ID = Новый Соответствие;
	ПараметрыТега_account_holder_ID.Вставить("id", "MC0292900000");
	
	ПараметрыТега_account_holder.Вставить("id_t", ПараметрыТега_account_holder_ID);
	
	REGISTER_OF_SHAREHOLDERS.account_holder	= РаскрытиеСпискаВладельцев.Partad_СформироватьТег_party_dtls_t(
		ПространствоИмен, ПараметрыТега_account_holder);
	//************************************************************************************
	// corporate_action_code - Вид корпоративного действия/события
	//************************************************************************************
	REGISTER_OF_SHAREHOLDERS.corporate_action_code	= СокрЛП(ПараметрКоманды.ВидКорпоративногоДействия.Код);
	//************************************************************************************
	// corporate_action_reference - Ссылка на корп действие - текст
	//************************************************************************************
	Если ЗначениеЗаполнено(ПараметрКоманды.КДРеференс) Тогда
		REGISTER_OF_SHAREHOLDERS.corporate_action_reference_NDC	=
			Документы.РаскрытиеСпискаВладельцев.КДРеференсБезСуффикса(ПараметрКоманды.КДРеференс);
	КонецЕсли;
	//************************************************************************************
	// record_date - Дата, на окончание операционного дня, которой составлены данные
	//************************************************************************************
	REGISTER_OF_SHAREHOLDERS.record_date = ?(ЗначениеЗаполнено(ПараметрКоманды.ДатаФиксации),
		ПараметрКоманды.ДатаФиксации, ПараметрКоманды.Дата);
	//************************************************************************************
	// message_function - Назначение предоставляемой информации
	// NEWM - Первиный список;
	// AMND - Дораскрытие;
	//************************************************************************************
	REGISTER_OF_SHAREHOLDERS.message_function = ?(ПараметрКоманды.Дораскрытие, "AMND", "NEWM");
	//************************************************************************************
	// information_indicator - Тип предоставляемой информации (тип списка)
	//************************************************************************************
	REGISTER_OF_SHAREHOLDERS.information_indicator = СокрЛП(ПараметрКоманды.ТипСписка.Код);
	//************************************************************************************
	// doc_link - Связанные ссылки (сообщения)
	//************************************************************************************
	Если ПараметрКоманды.Дораскрытие Тогда
		ПараметрыТега_doc_link	= Новый Соответствие;
		
		ВходящийДокументДата = ?(ПараметрКоманды.Дораскрытие,
			ПараметрКоманды.ДораскрытиеДокумент.ВходящийДокументДата, ПараметрКоманды.ВходящийДокументДата);
		ВходящийДокументНомер = ?(ПараметрКоманды.Дораскрытие,
			ПараметрКоманды.ДораскрытиеДокумент.ВходящийДокументНомер, ПараметрКоманды.ВходящийДокументНомер);
		
		Если Не ЗначениеЗаполнено(ВходящийДокументДата) Тогда
			ВходящийДокументДата = Дата(1900,1,1,0,0,0);
		КонецЕсли;
		Если Не ЗначениеЗаполнено(ВходящийДокументНомер) Тогда
			ВходящийДокументНомер = "UKWN";
		КонецЕсли;
		
		ПараметрыТега_doc_link_in_reg_date	= Новый Соответствие;
		ПараметрыТега_doc_link_in_reg_date.Вставить("date"	, ВходящийДокументДата);
		
		ПараметрыТега_doc_link.Вставить("in_reg_date"	, ПараметрыТега_doc_link_in_reg_date);
		ПараметрыТега_doc_link.Вставить("in_doc_num"	, ВходящийДокументНомер);
		
		ДораскрытиеДата = ?(ЗначениеЗаполнено(ПараметрКоманды.ДораскрытиеДокумент.Дата),
			ПараметрКоманды.ДораскрытиеДокумент.Дата, Дата(1900,1,1,0,0,0));
		ДораскрытиеНомер = ОбщегоНазначенияКлиентСервер.Транслит(
			?(ЗначениеЗаполнено(ПараметрКоманды.ДораскрытиеДокумент.Номер),
				ПараметрКоманды.ДораскрытиеДокумент.Номер, "NONREF"));
		
		ПараметрыТега_doc_link_out_doc_date	= Новый Соответствие;
		ПараметрыТега_doc_link_out_doc_date.Вставить("date"	, ДораскрытиеДата);
		
		ПараметрыТега_doc_link.Вставить("out_doc_num"	, ДораскрытиеНомер);
		ПараметрыТега_doc_link.Вставить("out_doc_date"	, ПараметрыТега_doc_link_out_doc_date);
		
		REGISTER_OF_SHAREHOLDERS.doc_link = РаскрытиеСпискаВладельцев.Partad_СформироватьТег_doc_link_t(
			ПространствоИмен, ПараметрыТега_doc_link);
	КонецЕсли;
	//************************************************************************************
	// register_list - Список информации о владельцах ЦБ
	//************************************************************************************
	register_list_Тип	= REGISTER_OF_SHAREHOLDERS_Тип.Свойства.Получить("register_list").Тип;
	register_list		= ФабрикаXDTO.Создать(register_list_Тип);
	// Параметр register_list_category
	register_list.register_list_category	= "ADD";
	// Заполним список информации о владельцах
	ДанныеСпискаВладельцев = ПолучитьДанныеСпискаВладельцев(ПараметрКоманды.Ссылка);
	ВыборкаКлиенты = ДанныеСпискаВладельцев.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкамСИерархией);
	Пока ВыборкаКлиенты.Следующий() Цикл
		ВыборкаСубклиенты = ВыборкаКлиенты.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкамСИерархией);
		Пока ВыборкаСубклиенты.Следующий() Цикл
			ВыборкаДоговор = ВыборкаСубклиенты.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкамСИерархией);
			Пока ВыборкаДоговор.Следующий() Цикл
				Клиент = ВыборкаДоговор.Клиент;
				Если Клиент.Субброкер Тогда
					Если НЕ ЗначениеЗаполнено(ВыборкаСубклиенты.Субклиент) Тогда
						ОбщегоНазначения.СообщитьОбОшибке("Файл раскрытия списка не сформирован - "
							+ "не указан выгодоприобретатель (субклиент)!");
						Возврат;
					КонецЕсли;	
					ЮрФизЛицо = ВыборкаСубклиенты.Субклиент.ЮридическиеФизическиеЛица;
					ТипЛица = ВыборкаСубклиенты.Субклиент.ЮрФизЛицо;
				Иначе
					ЮрФизЛицо = Клиент.ЮридическиеФизическиеЛица;
					ТипЛица = Клиент.ЮрФизЛицо;
				КонецЕсли;
			
				//************************************************************************************
				// shareholder - Блок информации о владельце ЦБ
				//************************************************************************************
				shareholder_Тип	= register_list_Тип.Свойства.Получить("shareholder").Тип;
				shareholder		= ФабрикаXDTO.Создать(shareholder_Тип);
				// shareholder - shareholder_id
				ПараметрыТега__shareholder_id = Новый Соответствие;
			
				Если Клиент.Субброкер Тогда
					КодКлиента = СокрЛП(ВыборкаДоговор.Договор.Код) + ВыборкаСубклиенты.Субклиент.Код;
				Иначе
					КодКлиента = СокрЛП(Клиент.Код);
				КонецЕсли;
				ПараметрыТега__shareholder_id.Вставить("id", КодКлиента);			
			
				shareholder.shareholder_id	= РаскрытиеСпискаВладельцев.Partad_СформироватьТег_Id_t(ПространствоИмен,
					ПараметрыТега__shareholder_id);
				// shareholder - account_dtls
				ПараметрыТега_account_dtls = Новый Соответствие;
				ПараметрыТега_account_dtls.Вставить("id_t", ПараметрыТега__shareholder_id);
			
				ВыборкаТипСчетаДепо	= ВыборкаДоговор.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкамСИерархией);
				Пока ВыборкаТипСчетаДепо.Следующий() Цикл
					ПараметрыТега_account_dtls.Вставить("account_type", КодТипаСчетаДЕПО(ВыборкаТипСчетаДепо.ТипСчетаДепо));
					Если НЕ ЗначениеЗаполнено(ПараметрыТега_account_dtls["account_type"]) Тогда
						ОбщегоНазначения.СообщитьОбОшибке("Файл раскрытия списка не сформирован - "
							+ "не указан код типа счета депо!");
						Возврат;
					КонецЕсли;	
		        
					shareholder.account_dtls = РаскрытиеСпискаВладельцев.Partad_СформироватьТег_account_dtls_t(
						ПространствоИмен, ПараметрыТега_account_dtls);
					// shareholder - shareholder_info
				    shareholder_info_Тип= shareholder_Тип.Свойства.Получить("shareholder_info").Тип;
					shareholder_info	= ФабрикаXDTO.Создать(shareholder_info_Тип);
			        // inn
					Если ЗначениеЗаполнено(ЮрФизЛицо.ИНН) Тогда
						shareholder_info.inn = ЮрФизЛицо.ИНН;
					КонецЕсли;
					
					Если ТипЛица = Перечисления.ЮрФизЛицо.ФизЛицо Тогда
						// birthday
						Если ЗначениеЗаполнено(ЮрФизЛицо.ДатаРождения) Тогда
							shareholder_info.birthday = Формат(ЮрФизЛицо.ДатаРождения, "ДФ=yyyy-MM-dd");
						КонецЕсли;
						// ssn
						Если ЗначениеЗаполнено(ЮрФизЛицо.СтраховойНомерПФР) Тогда
							СтраховойНомерПФР		= СокрЛП(ЮрФизЛицо.СтраховойНомерПФР);
							СтраховойНомерПФР		= СтрЗаменить(СтраховойНомерПФР, " ", "");	// Удалить пробелы
							СтраховойНомерПФР		= СтрЗаменить(СтраховойНомерПФР, "-", "");	// Удалить дефисы
							shareholder_info.ssn	= СтраховойНомерПФР;
						КонецЕсли;
						// nationality
						ИнформацияОГражданстве	= РегистрыСведений.ГражданствоФизЛиц.СрезПоследних(,
							Новый Структура("ФизЛицо", ЮрФизЛицо));
						Если ИнформацияОГражданстве.Количество()>0 Тогда
							Гражданство	= СокрЛП(ИнформацияОГражданстве[0].Страна.КодАльфа2);
							Если ЗначениеЗаполнено(Гражданство) Тогда
								shareholder_info.nationality = Гражданство;
							КонецЕсли;
						КонецЕсли;
					Иначе
						// kpp
						Если ЗначениеЗаполнено(ЮрФизЛицо.КПП) Тогда
							shareholder_info.kpp = СокрЛП(ЮрФизЛицо.КПП);
						КонецЕсли;
						// okpo
						Если ЗначениеЗаполнено(ЮрФизЛицо.КодПоОКПО) Тогда
							shareholder_info.okpo = СокрЛП(ЮрФизЛицо.КодПоОКПО);
						КонецЕсли;	
						// okved
						Если ЗначениеЗаполнено(ЮрФизЛицо.КодПоОКВЭД) Тогда
							shareholder_info.okved = СокрЛП(ЮрФизЛицо.КодПоОКВЭД);
						КонецЕсли;
						// manager_info
						ФИОРуководителя = ФИО(Клиент.Руководитель.Фамилия, Клиент.Руководитель.Имя, Клиент.Руководитель.Отчество);
						Если ЗначениеЗаполнено(ФИОРуководителя) Тогда
							shareholder_info.manager_info = ФИОРуководителя;
						КонецЕсли;
					КонецЕсли;
					// shareholder - shareholder_info - postal_name
					Контакты = Документы.РаскрытиеСпискаВладельцев.Контакты(Клиент, ЮрФизЛицо, ТипЛица);
					ПараметрыТега_address_t = Новый Соответствие;
					Если ЗначениеЗаполнено(Контакты.Страна) Тогда
						Если Контакты.АдресНеРФ Тогда
							Адрес = Контакты.ПредставлениеАдреса;
						Иначе
							Если ЗначениеЗаполнено(Контакты.Индекс) Тогда
								Адрес = СокрЛП(СтрЗаменить(Контакты.ПредставлениеАдреса, Контакты.Индекс+",", ""));
							Иначе
								Адрес = Контакты.ПредставлениеАдреса;
							КонецЕсли;
						КонецЕсли;
						Если ЗначениеЗаполнено(Адрес) Тогда
							postal_name_тип	= shareholder_info_Тип.Свойства.Получить("postal_name").Тип;
							postal_name		= ФабрикаXDTO.Создать(postal_name_тип);
							postal_name.name= СокрЛП(ЮрФизЛицо.Наименование);
							
							ПараметрыТега_address_partad_t = Новый Соответствие;
							ПараметрыТега_address_partad_t.Вставить("country", СокрЛП(Контакты.Страна.КодАльфа2));
							ПараметрыТега_address_partad_t.Вставить("address", Адрес);
							Если ЗначениеЗаполнено(Контакты.Индекс) Тогда
								ПараметрыТега_address_partad_t.Вставить("index", Контакты.Индекс);
							КонецЕсли;
							
							ПараметрыТега_address_t.Вставить("partad", ПараметрыТега_address_partad_t);
							// address
							postal_name.address	= РаскрытиеСпискаВладельцев.Partad_СформироватьТег_address_t(
								ПространствоИмен, ПараметрыТега_address_t);
							
							shareholder_info.postal_name = postal_name;
						КонецЕсли;	
					КонецЕсли;
					// shareholder - shareholder_info - shareholder_dtls
					ПараметрыТега_shareholder_dtls_id = Новый СписокЗначений;
					
					ПараметрыТега_shareholder_dtls_id_Элемент = Новый Соответствие;
					ПараметрыТега_shareholder_dtls_id_Элемент.Вставить("id", КодКлиента);
					
					ПараметрыТега_shareholder_dtls_id.Добавить(ПараметрыТега_shareholder_dtls_id_Элемент);
					
					ПараметрыТега_shareholder_dtls_id_Элемент = Новый Соответствие;
					Если Клиент.Субброкер Тогда
						Если НЕ ЗначениеЗаполнено(Клиент.LEI) Тогда
							ВызватьИсключение "Для субброкера '" + Клиент + "' не указан код LEI!";
						КонецЕсли;						
						ПараметрыТега_shareholder_dtls_id_Элемент.Вставить("id",	Клиент.LEI);
					Иначе 
						ПараметрыТега_shareholder_dtls_id_Элемент.Вставить("id",	КодLEI);
					КонецЕсли;
					ПараметрыТега_shareholder_dtls_id_Элемент.Вставить("issuer","LEI");
					
					ПараметрыТега_shareholder_dtls_id.Добавить(ПараметрыТега_shareholder_dtls_id_Элемент);
					
					ПараметрыТега_shareholder_dtls = Новый Соответствие;
					Если ТипЛица = Перечисления.ЮрФизЛицо.ФизЛицо Тогда
						ПолноеНаименованиеКлиента = ЮрФизЛицо.Наименование;
					Иначе
						ПолноеНаименованиеКлиента = ?(ЗначениеЗаполнено(ЮрФизЛицо.ПолноеНаименование),
							ЮрФизЛицо.ПолноеНаименование, ЮрФизЛицо.Наименование);
					КонецЕсли;
					
					ПараметрыТега_shareholder_dtls.Вставить("id_t", ПараметрыТега_shareholder_dtls_id);
					ПараметрыТега_shareholder_dtls.Вставить("name", СокрЛП(ПолноеНаименованиеКлиента));
					
					Если ТипЛица = Перечисления.ЮрФизЛицо.ЮрЛицо
						И ЮрФизЛицо.Страна = Справочники.КлассификаторСтранМира.РОССИЯ Тогда
						
						ОГРН = ?(ЗначениеЗаполнено(ЮрФизЛицо.ОГРН), ЮрФизЛицо.ОГРН, Клиент.ОГРН);
						ПараметрыТега_shareholder_dtls.Вставить("ogrn", СокрЛП(ОГРН));
					КонецЕсли;
					
					Если ПараметрыТега_address_t.Количество() > 0 тогда
						ПараметрыТега_shareholder_dtls.Вставить("address_t", ПараметрыТега_address_t);
					КонецЕсли;
					
					ПараметрыТега_shareholder_dtls.Вставить("individual_or_entity",
						?(ТипЛица = Перечисления.ЮрФизЛицо.ФизЛицо, "INDV", "LEGL"));
					
					Если ТипЛица = Перечисления.ЮрФизЛицо.ФизЛицо Тогда
						//individual_document
						ПараметрыТега_individual_document = Новый Соответствие;
						
						ДанныеУдостоверения	= РегистрыСведений.ПаспортныеДанныеФизЛиц.СрезПоследних(,
							Новый Структура("ФизЛицо", ЮрФизЛицо));
						
						Если ДанныеУдостоверения.Количество() > 0 Тогда
							doc_type	= СокрЛП(ДанныеУдостоверения[0].ДокументВид.КодИМНС);
							
							doc_ser		= СокрЛП(ДанныеУдостоверения[0].ДокументСерия);
							doc_num		= СокрЛП(ДанныеУдостоверения[0].ДокументНомер);
							doc_date	= ДанныеУдостоверения[0].ДокументДатаВыдачи;
							org			= СокрЛП(ДанныеУдостоверения[0].ДокументКемВыдан);
							Если ЗначениеЗаполнено(doc_type) Тогда
								ПараметрыТега_doc_type	= Новый Соответствие;
								ПараметрыТега_doc_type.Вставить("individual_document_type_code", doc_type);
								
								ПараметрыТега_individual_document.Вставить("doc_type", ПараметрыТега_doc_type); 
								Если ЗначениеЗаполнено(doc_ser) Тогда
									ПараметрыТега_individual_document.Вставить("doc_ser", doc_ser); 
								КонецЕсли;
								Если ЗначениеЗаполнено(doc_num) Тогда
									ПараметрыТега_individual_document.Вставить("doc_num", doc_num); 
								КонецЕсли;
								Если ЗначениеЗаполнено(doc_date) Тогда
									ПараметрыТега_individual_document.Вставить("doc_date", doc_date); 
								КонецЕсли;
								Если ЗначениеЗаполнено(org) Тогда
									ПараметрыТега_individual_document.Вставить("org", org); 
								КонецЕсли;
								
								ПараметрыТега_shareholder_dtls.Вставить("individual_document",
									ПараметрыТега_individual_document); 
							КонецЕсли;
						КонецЕсли;
					Иначе
						// entity_reg_dtls	
						ПараметрыТега_reg_doc_type = Новый Соответствие;
						ПараметрыТега_reg_doc_type.Вставить("entity_reg_doc_type_code",
							?(ЮрФизЛицо.НеРезидент, "INCR", "OGRN"));
						
						ПараметрыТега_entity_reg_dtls = Новый Соответствие;
						Если ЗначениеЗаполнено(ЮрФизЛицо.РегНомер) ИЛИ ЗначениеЗаполнено(ЮрФизЛицо.ОГРН) Тогда
							ПараметрыТега_entity_reg_dtls.Вставить("reg_num",
								?(ЗначениеЗаполнено(ЮрФизЛицо.ОГРН), ЮрФизЛицо.ОГРН, ЮрФизЛицо.РегНомер));
						КонецЕсли;
						Если ЗначениеЗаполнено(ЮрФизЛицо.ДатаГосРегистрации) Тогда
							ПараметрыТега_entity_reg_dtls.Вставить("date_of_incorporation",
								ЮрФизЛицо.ДатаГосРегистрации);
						КонецЕсли;
						Если ЗначениеЗаполнено(ЮрФизЛицо.РегистрирующийОрган) Тогда
							ПараметрыТега_entity_reg_dtls.Вставить("reg_org", ЮрФизЛицо.РегистрирующийОрган);
						КонецЕсли;
						Если ПараметрыТега_entity_reg_dtls.Количество() > 0 Тогда
							ПараметрыТега_entity_reg_dtls.Вставить("reg_doc_type",		ПараметрыТега_reg_doc_type);
							ПараметрыТега_shareholder_dtls.Вставить("entity_reg_dtls",	ПараметрыТега_entity_reg_dtls); 
						КонецЕсли;
					КонецЕсли;
					
					shareholder_info.shareholder_dtls = РаскрытиеСпискаВладельцев.Partad_СформироватьТег_party_dtls_t(
						ПространствоИмен, ПараметрыТега_shareholder_dtls);
					
					shareholder.shareholder_info		= shareholder_info;
					// shareholder - shareholder_contacts
					ПараметрыТега_shareholder_contacts	= Новый Соответствие;
					СписокEmail							= Новый СписокЗначений;
					СписокПараметровТелефонов			= Новый СписокЗначений;				
					// обработаем почтовые адреса
					ДобавитьАдресаЭлПочты(СписокEmail, ЗапросСпискаEmail, Клиент);
					ДобавитьАдресаЭлПочты(СписокEmail, ЗапросСпискаEmail, ЮрФизЛицо);
					Если СписокEmail.Количество() > 0 Тогда
						ПараметрыТега_shareholder_contacts.Вставить("e_mail", СписокEmail);
					КонецЕсли;
					// обработаем телефонные номера
					ДобавитьПараметрыТелефонов(СписокПараметровТелефонов, ЗапросСпискаТелефонов, Клиент);
					ДобавитьПараметрыТелефонов(СписокПараметровТелефонов, ЗапросСпискаТелефонов, ЮрФизЛицо);					
					Если СписокПараметровТелефонов.Количество()>0 Тогда
						ПараметрыТега_shareholder_contacts.Вставить("phone_t", СписокПараметровТелефонов);
					КонецЕсли;
					
					Если ПараметрыТега_shareholder_contacts.Количество()>0 Тогда
						shareholder.shareholder_contacts = РаскрытиеСпискаВладельцев.Partad_СформироватьТег_party_contacts_t(
							ПространствоИмен, ПараметрыТега_shareholder_contacts);
					КонецЕсли;
					// shareholder - payment_from_nominee
					shareholder.payment_from_nominee	= "Yes";
					// shareholder - tax_category
					ПараметрыТега_tax_category	= Новый Соответствие;
					ПараметрыТега_tax_category.Вставить("tax_status_code"		, ?(Клиент.Резидент, 2, 1));
					ПараметрыТега_tax_category.Вставить("tax_exempt_indicator"	, "No");
					
					shareholder.tax_category = РаскрытиеСпискаВладельцев.Partad_СформироватьТег_tax_category_t(
						ПространствоИмен, ПараметрыТега_tax_category);
					// shareholder - security_balances
					ВыборкаЦБ = ВыборкаТипСчетаДепо.Выбрать();
					Пока ВыборкаЦБ.Следующий() Цикл
						security_balances = ФабрикаXDTO.Создать(shareholder_Тип.Свойства.Получить("security_balances").Тип);
						КоличествоЦБ = ВыборкаЦБ.Количество;
						//ВыборкаДоговор
						Параметры_security			= Новый Соответствие;
						Параметры_security_balance	= Новый Соответствие;
						// заполним параметры security
						Если ЗначениеЗаполнено(ВыборкаЦБ.ЦеннаяБумага.НомерРегистрации) Тогда
							Параметры_security.Вставить("state_reg_num", СокрЛП(ВыборкаЦБ.ЦеннаяБумага.НомерРегистрации));
						КонецЕсли;
						Если ЗначениеЗаполнено(ВыборкаЦБ.ЦеннаяБумага.ISIN) Тогда
							Параметры_security.Вставить("ISIN_identifier", СокрЛП(ВыборкаЦБ.ЦеннаяБумага.ISIN));
						КонецЕсли;
						
						ЗапросСпискаКодовЗагрузкиЦБ.УстановитьПараметр("Владелец", ВыборкаЦБ.ЦеннаяБумага);
						СписокКодовЗагрузкиЦБ = ЗапросСпискаКодовЗагрузкиЦБ.Выполнить().Выгрузить();
						Если СписокКодовЗагрузкиЦБ.Количество() > 0 Тогда
							Параметры_proprietary_security_code	= Новый Соответствие;
							
							Параметры_proprietary_security_code.Вставить("id"		, СокрЛП(СписокКодовЗагрузкиЦБ[0].Код));
							Параметры_proprietary_security_code.Вставить("issuer"	, "NADC");
							
							Параметры_security.Вставить("proprietary_security_code", Параметры_proprietary_security_code);
						КонецЕсли;
						
						Параметры_security_balance.Вставить("security", Параметры_security);
						// заполним параметры total
						Параметры_total	= Новый Соответствие;
						Параметры_total.Вставить("units", КоличествоЦБ);
						Параметры_security_balance.Вставить("total", Параметры_total);
						
						security_balances.security_balance.Добавить(РаскрытиеСпискаВладельцев.Partad_СформироватьТег_security_balance_t(ПространствоИмен, Параметры_security_balance));
						shareholder.security_balances.Добавить(security_balances);
					КонецЦикла;
					
					// shareholder - bank_prop_rub
					Параметры_bank_prop_rub		= Новый Соответствие;
					Параметры_cash_rub_dtls		= Новый Соответствие;
					Параметры_account			= Новый Соответствие;
					Параметры_bank_corr			= Новый Соответствие;
					
					Параметры_account.Вставить("id", СокрЛП(ПараметрКоманды.БанковскийСчет.НомерСчета));
					Параметры_bank_corr.Вставить("id", СокрЛП(ПараметрКоманды.БанковскийСчет.Банк.КоррСчет));
					
					Параметры_cash_rub_dtls.Вставить("account"	, Параметры_account);
					Параметры_cash_rub_dtls.Вставить("bank_name", СокрЛП(ПараметрКоманды.БанковскийСчет.Банк.Наименование));
					Параметры_cash_rub_dtls.Вставить("bank_city", СокрЛП(ПараметрКоманды.БанковскийСчет.Банк.Город));
					Параметры_cash_rub_dtls.Вставить("ruic"		, СокрЛП(ПараметрКоманды.БанковскийСчет.Банк.Код));
					Параметры_cash_rub_dtls.Вставить("bank_corr", Параметры_bank_corr);
					
					Параметры_bank_prop_rub.Вставить("pay_name"		, СокрЛП(ПараметрКоманды.Организация.Наименование));
					Параметры_bank_prop_rub.Вставить("inn"			, СокрЛП(ПараметрКоманды.Организация.ИНН));
					Параметры_bank_prop_rub.Вставить("cash_rub_dtls", Параметры_cash_rub_dtls);
					
					shareholder.bank_prop_rub = РаскрытиеСпискаВладельцев.Partad_СформироватьТег_bank_prop_rub_t(ПространствоИмен, Параметры_bank_prop_rub);
					// Параметр shareholder заполнен, добавим его в реквизит
					register_list.shareholder.Добавить(shareholder);
				КонецЦикла; // ТипСчетаДепо
			КонецЦикла; // Договор
		КонецЦикла; // Субклиенты
	КонецЦикла; // Клиенты
	
	// Параметр register_list заполнен, добавим его в реквизит
	REGISTER_OF_SHAREHOLDERS.register_list.Добавить(register_list);
	// </REGISTER_OF_SHAREHOLDERS> 
	ФабрикаXDTO.ЗаписатьXML(ЗаписьXML, REGISTER_OF_SHAREHOLDERS, "REGISTER_OF_SHAREHOLDERS");
	СтрокаXML = ЗаписьXML.Закрыть();
	
	СтрокаXML = СтрЗаменить(СтрокаXML,
		"<REGISTER_OF_SHAREHOLDERS xmlns=""PARTAD"" xmlns:xs=""http://www.w3.org/2001/XMLSchema"" xmlns:xsi=""http://www.w3.org/2001/XMLSchema-instance"">",
		"<REGISTER_OF_SHAREHOLDERS>");

	ТекстXML = Новый ТекстовыйДокумент;
	ТекстXML.ДобавитьСтроку(СтрокаXML);
	
	НеобходимоЗафиксироватьВыгрузкуЭтапа = Ложь;
	Попытка
		ПапкаДанных	= СокрЛП(ВнешниеДанные.ПолучитьПараметрыВнешнегоИсточника(
			ПланыВидовХарактеристик.ВнешниеИсточники.КаталогВыгрузкиРаскрытияСпискаВладельцевPartad).Папка);
		ТекстXML.Записать(ПапкаДанных+"\"+ПараметрКоманды.Номер+"_"+Формат(ТекущаяДата(), "ДФ=ddMMyyyy")+".xml");
		НеобходимоЗафиксироватьВыгрузкуЭтапа = Истина;
	Исключение
		ОбщегоНазначения.СообщитьОбОшибке(
			"Не удалось записать файл!
			|
			|Возможно указанный в настройках каталог 'Каталог ПАРТАД' недоступен или путь некорректен!");
	КонецПопытки;
	
	Если НеобходимоЗафиксироватьВыгрузкуЭтапа Тогда
		Документы.РаскрытиеСпискаВладельцев.ЗарегистрироватьЭтапКД(ПараметрКоманды, REGISTER_OF_SHAREHOLDERS_База_header.doc_num);
	КонецЕсли;
КонецПроцедуры

&НаСервере
Функция ПодготовитьЗапросДляКодаЗагрузкиНДЦЮрЛица(ПараметрКоманды)
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	Код
	|ИЗ
	|	Справочник.КодыЗагрузки КАК КодыЗагрузки
	|ГДЕ
	|	НЕ ПометкаУдаления
	|	И Биржа = &Биржа
	|	И Владелец = &Владелец
	|	И 
	|		(
	|		НАЧАЛОПЕРИОДА(ДатаОкончанияДействия, ДЕНЬ) = НАЧАЛОПЕРИОДА(ДАТАВРЕМЯ(1,1,1), ДЕНЬ)
	|		ИЛИ
	|		НАЧАЛОПЕРИОДА(ДатаОкончанияДействия, ДЕНЬ) >= НАЧАЛОПЕРИОДА(&Дата, ДЕНЬ)
	|		ИЛИ
	|		НАЧАЛОПЕРИОДА(ДатаОкончанияДействия, ДЕНЬ) >= НАЧАЛОПЕРИОДА(&ДатаФиксации, ДЕНЬ)
	|		)");

	Запрос.УстановитьПараметр("Биржа"			, Справочники.КлассификаторыЗагрузки.НДЦ());
	Запрос.УстановитьПараметр("Дата"			, ПараметрКоманды.Дата);
	Запрос.УстановитьПараметр("ДатаФиксации"	, ПараметрКоманды.ДатаФиксации);
	
	Возврат Запрос;
КонецФункции

