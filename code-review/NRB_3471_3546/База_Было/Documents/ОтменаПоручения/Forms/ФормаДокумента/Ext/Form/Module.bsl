	Выборка 	= Результат.Выбрать();
	
	Пока Выборка.Следующий() Цикл
		НоваяСтрока 			= ТаблицаЗначенийОбъектов.Добавить();
		НоваяСтрока.Объект 		= Выборка.Объект;
		НоваяСтрока.Пометка 	= Выборка.ПометкаУдаления;
	КонецЦикла; 		  
	Объект.СвязанныеОперации.Загрузить(ТаблицаЗначенийОбъектов);
