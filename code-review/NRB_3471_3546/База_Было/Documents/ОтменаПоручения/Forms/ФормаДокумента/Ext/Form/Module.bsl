&НаКлиентеНаСервереБезКонтекста
Процедура ВывестиРеквизитыДокументаОснования(Форма)
	
	Объект = Форма.Объект;
	Если ЗначениеЗаполнено(Объект.ДокументОснование) Тогда
		Форма.КодОтмены		= Объект.ДокументОснование.КодОтмены;
		Форма.ПричинаОтмены	= Объект.ДокументОснование.ПричинаОтмены;
		Форма.НачислитьКомиссиюЗаОтмену = Объект.ДокументОснование.НачислитьКомиссиюЗаОтмену;
	Иначе
		Форма.КодОтмены		= ПредопределенноеЗначение("Справочник.КодыОтменыПоручений.ПустаяСсылка");
		Форма.ПричинаОтмены	= "";
		Форма.НачислитьКомиссиюЗаОтмену = Ложь;
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура ОтменяемоеПоручениеПриИзмененииНадпись()
	
	Если ТипЗнч(Объект.ОтменяемоеПоручение) = Тип("ДокументСсылка.Поручение") Тогда
	
		ОперацияОтмена = Объект.ОтменяемоеПоручение.ВидОперацииД;
		ДепонентОтмена = Объект.ОтменяемоеПоручение.Инициатор;
		СчетДепоОтмена=  Объект.ОтменяемоеПоручение.СчетДепо;
	
	КонецЕсли; 
	ПоискСвязанныхОперацийОбъектов();

КонецПроцедуры

