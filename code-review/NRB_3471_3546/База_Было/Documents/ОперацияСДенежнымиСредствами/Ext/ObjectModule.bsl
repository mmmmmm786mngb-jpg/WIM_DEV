
Процедура ОбработкаПроведения(Отказ, Режим)
	Движения.ДенежныеСредства.Записывать = Истина;
	Движения.ДенежныеСредства.Очистить();
	
	Движение = Движения.ДенежныеСредства.ДобавитьРасход();
	Движение.Период			= Дата;
	Движение.БанковскийСчет	= БанковскийСчет;
	Движение.Депонент		= Депонент;
	Движение.Валюта			= Валюта;
	Движение.Сумма			= Сумма;
	Движение.ВалютнаяСумма	= Сумма;
	
	Движения.ДенежныеСредства.Записать();
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	ДенежныеСредстваОстатки.СуммаОстаток
	|ИЗ
	|	РегистрНакопления.ДенежныеСредства.Остатки(
	|			,
	|			БанковскийСчет = &БанковскийСчет
	|				И Валюта = &Валюта
	|				И Депонент = &Депонент) КАК ДенежныеСредстваОстатки
	|ГДЕ
	|	ДенежныеСредстваОстатки.СуммаОстаток < 0");
	
	Запрос.УстановитьПараметр("БанковскийСчет"	, БанковскийСчет);
	Запрос.УстановитьПараметр("Валюта"			, Валюта);
	Запрос.УстановитьПараметр("Депонент"		, Депонент);
	
	Результат = Запрос.Выполнить();
	
	Если Не Результат.Пустой() Тогда
		Отказ = Истина;
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "Образован отрицательный остаток ДС по счету " + БанковскийСчет + ". Операция не выполнена!";
		Сообщение.Поле = "";
		Сообщение.Сообщить();
	КонецЕсли;
КонецПроцедуры

Процедура ОбработкаЗаполнения(ДанныеЗаполнения, СтандартнаяОбработка)
	Если ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.ВводДивидендов") Тогда
		Основание		= ДанныеЗаполнения;
		БанковскийСчет	= ДанныеЗаполнения.БанковскийСчет;
		Валюта			= БанковскийСчет.ВалютаДенежныхСредств;
	ИначеЕсли ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.ПогашениеНКД") ИЛИ ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.ПогашениеЦБПолное") ИЛИ ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.ПогашениеЦБЧастичное") Тогда
		Основание		= ДанныеЗаполнения;
		БанковскийСчет	= ДанныеЗаполнения.ДокументОснование.БанковскийСчет;
		Валюта			= БанковскийСчет.ВалютаДенежныхСредств;
	ИначеЕсли ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.ГлобальнаяОперация") Тогда
		Основание		= ДанныеЗаполнения;
		БанковскийСчет	= ДанныеЗаполнения.БанковскийСчет;
		Валюта			= БанковскийСчет.ВалютаДенежныхСредств;
	Иначе
		Основание		= ДанныеЗаполнения;
	КонецЕсли;
КонецПроцедуры

Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
	Если ОбменДанными.Загрузка = Истина Тогда
		Возврат;
	КонецЕсли;
КонецПроцедуры

