// Процедура заполнения реквизитов в зависимости от вида операции
//
Процедура ЗаполнениеРеквизитовПоВидуОперации() Экспорт
	
	Если ВидОперацииД = Справочники.ВидыОпераций.Перевод Тогда
		
		МестоХраненияПолучатель 	= МестоХранения;
		СчетДепоМХПолучатель		= СчетДепоМХ;
		РазделСчетаДепоМХПолучатель	= РазделСчетаДепоМХ;
		
	ИначеЕсли ВидОперацииД = Справочники.ВидыОпераций.Перемещение
				ИЛИ ВидОперацииД = Справочники.ВидыОпераций.ПереводМеждуРазделамиСчетаДепо Тогда
		
		Получатель					= Инициатор;
		СчетДепоПолучатель			= СчетДепо;
		РазделСчетаДепоПолучатель 	= РазделСчетаДепо;
		
	КонецЕсли;

КонецПроцедуры // ЗаполнениеРеквизитовПоВидуОперации()
	
#Если Клиент Тогда
	
// Функция определения достаточности остатка на счете для списания 
//
Функция НеХватаетОстатка(выбРегистр, выбМомент, выбИзмерения, выбЗначение, КолСписываемыхСОбременением=0)
	
	Перем ЕстьОшибка;
	
	ЕстьОшибка = ЛОЖЬ;
	текОстаток = выбРегистр.Остатки(выбМомент, выбИзмерения,,"Количество");
	
	Если текОстаток.Количество() = 0 ИЛИ текОстаток.Итог("Количество") < выбЗначение Тогда
		
		ЕстьОшибка = ИСТИНА;
		Возврат ЕстьОшибка;
		
	КонецЕсли;
	
	Если выбРегистр = РегистрыНакопления.ОстаткиЦБ Тогда
		
		ОстатокСвободных 		= 0;
		ОстатокСОбременением 	= 0;
		
		Для каждого СтрокаОстаток Из текОстаток Цикл
			
			Если СтрокаОстаток.СтатусЦБ = Перечисления.СтатусыЦБ.Свободна Тогда
				
				ОстатокСвободных = СтрокаОстаток.Количество;
				
			КонецЕсли;
			
			Если СтрокаОстаток.СтатусЦБ = Перечисления.СтатусыЦБ.Обременена Тогда
				
				ОстатокСОбременением = СтрокаОстаток.Количество;
				
			КонецЕсли;
			
		КонецЦикла; 
	
		Если ОстатокСвободных + ОстатокСОбременением < выбЗначение Тогда
			
			ЕстьОшибка = ИСТИНА;
			Возврат ЕстьОшибка;
			
		КонецЕсли;
		
		Если ОстатокСвободных < выбЗначение Тогда
			
			Если Вопрос("Списывать ЦБ с обременением?", РежимДиалогаВопрос.ДаНет,,,) = КодВозвратаДиалога.Да Тогда
				
				КолСписываемыхСОбременением = выбЗначение - ОстатокСвободных;
				
			Иначе
				
				ЕстьОшибка =  Истина;
				
			КонецЕсли;
				
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат ЕстьОшибка;
	
КонецФункции // НеХватаетОстатка()

// Функция определения наличия ошибок 
//
Функция ЕстьОшибки()
	
	Перем ЕстьОшибка;
	
	ЕстьОшибка = ЛОЖЬ;
	КолСписЦБСОбрем = 0;
	
	//ПРИЕМ ЦЕННЫХ БУМАГ НА ХРАНЕНИЕ И УЧЕТ
	Если ВидОперацииД = Справочники.ВидыОпераций.Депонирование Тогда
		
		Если СчетДепо.СтатусСчетаДепо = Перечисления.СтатусыСчетовДепо.Закрыт Тогда
			
			Сообщить("Счет депо получателя закрыт!");
			ЕстьОшибка = ИСТИНА;
			
		ИначеЕсли СчетДепо.СтатусСчетаДепо = Перечисления.СтатусыСчетовДепо.НеОткрыт Тогда
			
			Сообщить("Счет депо получателя не открыт!");
			ЕстьОшибка = ИСТИНА;
			
		КонецЕсли;
		
	//СНЯТИЕ ЦЕННЫХ БУМАГ С ХРАНЕНИЯ И УЧЕТА
	ИначеЕсли ВидОперацииД = Справочники.ВидыОпераций.СнятиеСДепонирования Тогда
	
		Если НеХватаетОстатка(РегистрыНакопления.ОстаткиЦБ, МоментВремени(), Новый Структура("СчетДепо,РазделСчетаДепо,СчетДепоМХ,РазделСчетаДепоМХ,ЦБ",СчетДепо,РазделСчетаДепо,СчетДепоМХ,РазделСчетаДепоМХ,ЦБ), Количество, КолСписЦБСОбрем) Тогда
				
			Сообщить("Количество списания превышает остаток на счете клиента!");
			ЕстьОшибка = ИСТИНА;
				
		КонецЕсли;	
		
	//ПЕРЕВОД ЦЕННЫХ БУМАГ
	ИначеЕсли ВидОперацииД = Справочники.ВидыОпераций.Перевод Тогда
	
		Если СчетДепоПолучатель.СтатусСчетаДепо = Перечисления.СтатусыСчетовДепо.Закрыт Тогда
			
			Сообщить("Счет депо получателя закрыт!");
			ЕстьОшибка = ИСТИНА;
			
		ИначеЕсли СчетДепоПолучатель.СтатусСчетаДепо = Перечисления.СтатусыСчетовДепо.НеОткрыт Тогда
			
			Сообщить("Счет депо получателя не открыт!");
			ЕстьОшибка = ИСТИНА;
			
		КонецЕсли;		
		
		Если НеХватаетОстатка(РегистрыНакопления.ОстаткиЦБ, МоментВремени(), Новый Структура("СчетДепо,РазделСчетаДепо,СчетДепоМХ,РазделСчетаДепоМХ,ЦБ",СчетДепо,РазделСчетаДепо,СчетДепоМХ,РазделСчетаДепоМХ,ЦБ), Количество, КолСписЦБСОбрем) Тогда
				
			Сообщить("Количество списания превышает остаток на счете клиента!");
			ЕстьОшибка = ИСТИНА;
				
		КонецЕсли;
		
	//ПЕРЕМЕЩЕНИЕ ЦЕННЫХ БУМАГ
	ИначеЕсли ВидОперацииД = Справочники.ВидыОпераций.Перемещение
				ИЛИ ВидОперацииД = Справочники.ВидыОпераций.ПереводМеждуРазделамиСчетаДепо Тогда
	
		Если НеХватаетОстатка(РегистрыНакопления.ОстаткиЦБ, МоментВремени(), Новый Структура("СчетДепо,РазделСчетаДепо,СчетДепоМХ,РазделСчетаДепоМХ,ЦБ",СчетДепо,РазделСчетаДепо,СчетДепоМХ,РазделСчетаДепоМХ,ЦБ), Количество, КолСписЦБСОбрем) Тогда
				
			Сообщить("Количество списания превышает остаток на счете клиента!");
			ЕстьОшибка = ИСТИНА;
				
		КонецЕсли;	
		
	Иначе
		
		Сообщить("Данная операция документом Операция с ЦБ не производится!");
		ЕстьОшибка = ИСТИНА;
		
	КонецЕсли;		
	
	Возврат ЕстьОшибка;
	
КонецФункции // ЕстьОшибки()

#Конецесли
