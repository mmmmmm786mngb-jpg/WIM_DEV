Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
    
	Если ОбменДанными.Загрузка = Истина Тогда
		Возврат;
	КонецЕсли;
	
	#Если Клиент Тогда
	
	Если ВидОперацииД = Справочники.ВидыОпераций.ПустаяСсылка() Тогда
		
		Предупреждение("Не выбран вид операции");  
		Отказ = Истина;			
		
	КонецЕсли;	    
	
	//Если СпособХранения = Перечисления.СпособыХранения.ПустаяСсылка() Тогда
	//	
	//	Предупреждение("Не выбран способ хранения");  
	//	Отказ = Истина;			
	//	
	//КонецЕсли;
	
	Если СчетДепоМХ = Справочники.СчетаДепоМХ.ПустаяСсылка() Тогда
		
		Предупреждение("Не выбран счет депо хранилища");  
		Отказ = Истина;			
		
	КонецЕсли;
	
	Если СчетДепо = Справочники.СчетаДепо.ПустаяСсылка() Тогда
		
		Предупреждение("Не выбран счет депо депонента");  
		Отказ = Истина;			
		
	КонецЕсли;	     
	
	Если РазделСчетаДепоМХ = Справочники.РазделыСчетаДепоМХ.ПустаяСсылка() Тогда
		
		Предупреждение("Не выбран раздел счета депо хранилища");  
		Отказ = Истина;			
		
	КонецЕсли;	                                        
	
	Если РазделСчетаДепо = Справочники.РазделыСчетаДепо.ПустаяСсылка() Тогда
		
		Предупреждение("Не выбран раздел счета депо депонента");  
		Отказ = Истина;			
		
	КонецЕсли;
	
	Если Инициатор = Справочники.Контрагенты.ПустаяСсылка() Тогда
		
		Предупреждение("Не выбран депонент");  
		Отказ = Истина;			
		
	КонецЕсли;	
	
	Если МестоХранения = Справочники.МестаХранения.ПустаяСсылка() Тогда
		
		Предупреждение("Не выбрано хранилище");  
		Отказ = Истина;			
		
	КонецЕсли;	
	
	Если ЦБ = Справочники.ЦенныеБумаги.ПустаяСсылка() Тогда
		
		Предупреждение("Не выбрана ценная бумага");  
		Отказ = Истина;			
		
	КонецЕсли;	
	
	Если Количество = 0 Тогда
		
		Предупреждение("Не задано количество");  
		Отказ = Истина;			
		
	КонецЕсли;
	
	Если ВидОперацииД = Справочники.ВидыОпераций.Перевод
		ИЛИ ВидОперацииД = Справочники.ВидыОпераций.Перемещение
		ИЛИ ВидОперацииД = Справочники.ВидыОпераций.ПереводМеждуРазделамиСчетаДепо Тогда
		
		Если Получатель = Справочники.Контрагенты.ПустаяСсылка() Тогда
		
			Предупреждение("Не выбран депонент-получатель");  
			Отказ = Истина;			
		
		КонецЕсли;	
		
		Если СчетДепоПолучатель = Справочники.СчетаДепо.ПустаяСсылка() Тогда
		
			Предупреждение("Не выбран счет депо получателя");  
			Отказ = Истина;			
		
		КонецЕсли;	
		
		Если РазделСчетаДепоПолучатель = Справочники.РазделыСчетаДепо.ПустаяСсылка() Тогда
		
			Предупреждение("Не выбран раздел счета депо получателя");  
			Отказ = Истина;			
		
		КонецЕсли;	
		
		Если МестоХраненияПолучатель = Справочники.МестаХранения.ПустаяСсылка() Тогда
		
			Предупреждение("Не выбрано хранилище получателя");  
			Отказ = Истина;			
		
		КонецЕсли;	
		
		Если СчетДепоМХПолучатель = Справочники.СчетаДепоМХ.ПустаяСсылка() Тогда
		
			Предупреждение("Не выбран счет депо хранилища получателя");  
			Отказ = Истина;			
		
		КонецЕсли;	
		
		Если РазделСчетаДепоМХПолучатель = Справочники.РазделыСчетаДепоМХ.ПустаяСсылка() Тогда
		
			Предупреждение("Не выбран раздел счета депо хранилища получателя");  
			Отказ = Истина;			
		
		КонецЕсли;	
		
	КонецЕсли;
	
	#КонецЕсли

	УстановитьНовыйНомер();
КонецПроцедуры // ПередЗаписью()

Процедура ОбработкаЗаполнения(Основание) Экспорт
	
	Если ЗначениеЗаполнено(Основание) И Основание.ВидОперацииД.КлассОпераций = Перечисления.КлассыОпераций.Инвентарные Тогда 
			
		ДокументОснование 	= Основание.Ссылка;			
		ВидОперацииД	 	= Основание.ВидОперацииД;			
		Комментарий			= "Поручение № " + Основание.Номер + " от " + Основание.Дата;
		Инициатор			= Основание.Инициатор;
		СчетДепо			= Основание.СчетДепо;
		РазделСчетаДепо		= Основание.РазделСчетаДепо;
		МестоХранения		= Основание.МХДепонента;
		ЦБ					= Основание.ЦБ;
		Цена                = Основание.ЦенаСделкиЦБ;
		Сумма               = Основание.СуммаСделки;
		Дата				= ОбщегоНазначения.ДатаДокумента(Основание);
			
		ЗаполнениеРеквизитовПоВидуОперации();
					
	Иначе
			
		Проверка = Истина;
		ДокументОснование 	= Документы.Поручение.ПустаяСсылка();			
		Сообщить("На основании данного вида поручения нельзя создать документ ""Ценные бумаги в пути"". 
				  |Класс операции должен относиться к классу инвентарных операций!");
				  
		Возврат;	
			
	КонецЕсли;
	
КонецПроцедуры // ОбработкаЗаполнения

