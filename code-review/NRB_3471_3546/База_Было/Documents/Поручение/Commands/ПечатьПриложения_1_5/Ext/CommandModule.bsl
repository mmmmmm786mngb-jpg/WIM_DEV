КонецФункции

&НаСервере
Процедура ЗаполнитьДату(Текст, ЗаполняемаяДата, Префикс)
	
	Если ЗначениеЗаполнено(ЗаполняемаяДата) Тогда
		ЗаполняемаяДатаТекст = Формат(ЗаполняемаяДата, "ДФ=dd.MM.yyyy");
	Иначе
		ЗаполняемаяДатаТекст = "";
	КонецЕсли;
	
	Текст = СтрЗаменить(Текст, "[" + Префикс + "Д1]", Сред(ЗаполняемаяДатаТекст, 1, 1));
	Текст = СтрЗаменить(Текст, "[" + Префикс + "Д2]", Сред(ЗаполняемаяДатаТекст, 2, 1));
	Текст = СтрЗаменить(Текст, "[" + Префикс + "М1]", Сред(ЗаполняемаяДатаТекст, 4, 1));
	Текст = СтрЗаменить(Текст, "[" + Префикс + "М2]", Сред(ЗаполняемаяДатаТекст, 5, 1));
	Текст = СтрЗаменить(Текст, "[" + Префикс + "Г1]", Сред(ЗаполняемаяДатаТекст, 7, 1));
	Текст = СтрЗаменить(Текст, "[" + Префикс + "Г2]", Сред(ЗаполняемаяДатаТекст, 8, 1));
	Текст = СтрЗаменить(Текст, "[" + Префикс + "Г3]", Сред(ЗаполняемаяДатаТекст, 9, 1));
	Текст = СтрЗаменить(Текст, "[" + Префикс + "Г4]", Сред(ЗаполняемаяДатаТекст, 10, 1));
	
КонецПроцедуры

&НаСервере
Процедура ОчиститьНезаполненныеПараметры(Текст)
	
	ПараметрыСтрокой = "КодДепонента, НаименованиеДепонента, КодСчетаДепо, КодРазделаСчетаДепо, НаименованиеКонтрагента, "
	+ "НомерСчетаДепоКонтрагента, КодРазделаСчетаДепоКонтрагента, НаименованиеКлиентаКонтрагента, КодСчетаДепоКлиентаКонтрагента, "
	+ "Референс, Сумма, СуммаПрописью, Валюта, УполномоченноеЛицо, ЛицоДействующееОтИмениУполномоченногоЛица, "
	+ "Основание, ДопИнформация, НомерСтрокиЦБ, ISIN, НаименованиеЦБ, НомерРегистрации, КоличествоЦБ, КоличествоЦБПрописью, "
	+ "ЭтоПеревод, ЭтоЗачисление, ЭтоСписание, ЭтоБлокировка, ЭтоРазблокировка, СвободнаяСделка, ПоставкаПротивПлатежа, "
	+ "МРДепозитарийНРБ, МРНРД, МРDTC, МРИное, МРРеестр, МРЕвроклир, МРКлирСтрим, МРЕвроклирFundsettle";
	
	Параметры = СтрРазделить(ПараметрыСтрокой, ", ", Ложь);
	Для Каждого Параметр Из Параметры Цикл
		Текст = СтрЗаменить(Текст, "[" + Параметр + "]", "");
	КонецЦикла;
	
	ЗаполнитьДату(Текст, "", "С");
	ЗаполнитьДату(Текст, "", "Р");
	ЗаполнитьДату(Текст, "", "П");
	
КонецПроцедуры

&НаСервере
Функция ОписаниеОснования(ДанныеПоручения)
	Результат = "";
	
	СКД = ДанныеПоручения.ВидПоручения.СхемаКомпоновкиДанных.Получить();
	Если СКД = Неопределено Тогда
		Возврат Результат;
	КонецЕсли;
	
	НаборДанных = СКД.НаборыДанных.Найти("ТЧ_Документы");
	Если НаборДанных = Неопределено Тогда
		Возврат Результат;
	КонецЕсли;
	
	Запрос = Новый Запрос(НаборДанных.Запрос);
	Запрос.УстановитьПараметр("Сделка", ДанныеПоручения.Поручение);
	Запрос.УстановитьПараметр("Дата", ДанныеПоручения.Дата);
	ДанныеОснований = Запрос.Выполнить().Выбрать();
	
	Пока ДанныеОснований.Следующий() Цикл
		Если ЗначениеЗаполнено(ДанныеОснований.НомерДокумента) Или ЗначениеЗаполнено(ДанныеОснований.ДатаДокумента) Тогда
			ВидДоговора = Справочники.КодыВидаДоговоровОснованийОперацийДКУ.НайтиПоКоду(ДанныеОснований.КодДокументаНРД);
			Результат = Результат + ?(ЗначениеЗаполнено(Результат), "; ", "");
			Результат = Результат
			+ СтрШаблон("%1 №%2 от %3", ВидДоговора, СокрЛП(ДанныеОснований.НомерДокумента), Формат(ДанныеОснований.ДатаДокумента, "ДЛФ=Д"));
		КонецЕсли;
	КонецЦикла;
	
	Возврат Результат;
КонецФункции

&НаСервере
Функция ДопИнформация(ДанныеПоручения)
	ДокументЮрФизЛица =
	Справочники.ВидыИнвентарныхПоручений.ДанныеУдостоверяющихДокументовЮрФизЛица(ДанныеПоручения.ДепонентЮрФизЛицо);
	
	Если ТипЗнч(ДанныеПоручения.ДепонентЮрФизЛицо) = Тип("СправочникСсылка.ЮридическиеЛица") Тогда
		ТипДокумента = "свидетельство о регистрации";
	ИначеЕсли ДокументЮрФизЛица.ТипДокумента = "21" Тогда
		ТипДокумента = "паспорт";
	Иначе
		ТипДокумента = "";
	КонецЕсли;
	
	ТипСчетаДепоКонтрагента = ДанныеПоручения.ТипСчетаДепоКонтрагентаFCDR_2017_02;
	Результат = "Тип лицевого счета"
	+ ?(ЗначениеЗаполнено(ДанныеПоручения.НомерСчетаДепоКонтрагента), " " + ДанныеПоручения.НомерСчетаДепоКонтрагента, "")
	+ " в реестре" + ?(ЗначениеЗаполнено(ДанныеПоручения.МХКонтрагентНаименование), " " + ДанныеПоручения.МХКонтрагентНаименование, "")
	+ ?(ЗначениеЗаполнено(ТипСчетаДепоКонтрагента), "- " + ТипСчетаДепоКонтрагента, "") + ", "
	+ ?(ЗначениеЗаполнено(ТипДокумента), ТипДокумента + ":", "")
	+ ?(ЗначениеЗаполнено(ДокументЮрФизЛица.СерияДокумента), " " + ДокументЮрФизЛица.СерияДокумента, "")
	+ ?(ЗначениеЗаполнено(ДокументЮрФизЛица.НомерДокумента), " " + ДокументЮрФизЛица.НомерДокумента, "")
	+ ?(ЗначениеЗаполнено(ДокументЮрФизЛица.ДатаДокумента), ", дата документа: " + Формат(ДокументЮрФизЛица.ДатаДокумента, "ДЛФ=Д"), "")
	+ ?(ЗначениеЗаполнено(ДокументЮрФизЛица.ОрганРегистрации), " выдан: " + ДокументЮрФизЛица.ОрганРегистрации, "");
	
	Возврат Результат;
КонецФункции

&НаСервере
Процедура ЗаполнитьВидОперации(Текст, ДанныеПоручения)
	Если ДанныеПоручения.ВидОперацииД = Справочники.ВидыОпераций.ПереводМеждуРазделамиСчетаДепо
			Или ДанныеПоручения.ВидОперацииД = Справочники.ВидыОпераций.Перемещение Тогда
		Текст = СтрЗаменить(Текст, "[ЭтоПеревод]", "V");
	КонецЕсли;
	Если ДанныеПоручения.ВидОперацииД = Справочники.ВидыОпераций.СнятиеСДепонирования
			Или ЭтоПоручениеНаПереводТипаСписание(ДанныеПоручения) Тогда
		Текст = СтрЗаменить(Текст, "[ЭтоСписание]", "V");
	КонецЕсли;
	Если ДанныеПоручения.ВидОперацииД = Справочники.ВидыОпераций.Депонирование
			Или ЭтоПоручениеНаПереводТипаЗачисление(ДанныеПоручения) Тогда
		Текст = СтрЗаменить(Текст, "[ЭтоЗачисление]", "V");
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьМестоРасчетов(Текст, ДанныеПоручения)
	
	МХКонтрагентКод = СокрЛП(ДанныеПоручения.МХКонтрагентКод);
	
	Если ЭтоРеестр(ДанныеПоручения) Тогда
		Текст = СтрЗаменить(Текст, "[МРРеестр]", "V");
	ИначеЕсли ДанныеПоручения.ЭтоКлиентИзГруппыДепоненты Тогда
		Текст = СтрЗаменить(Текст, "[МРДепозитарийНРБ]", "V");
	ИначеЕсли МХКонтрагентКод = "НРД" Тогда
		Текст = СтрЗаменить(Текст, "[МРНРД]", "V");
	ИначеЕсли МХКонтрагентКод = "DTC" Тогда
		Текст = СтрЗаменить(Текст, "[МРDTC]", "V");
	ИначеЕсли МХКонтрагентКод = "MGTCBEBE" Тогда
		Текст = СтрЗаменить(Текст, "[МРЕвроклир]", "V");
	ИначеЕсли МХКонтрагентКод = "CEDELULL" Тогда
		Текст = СтрЗаменить(Текст, "[МРКлирстрим]", "V");
	Иначе
		Текст = СтрЗаменить(Текст, "[МРИное]", "V");
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьТипРасчетов(Текст, ДанныеПоручения)
	
	Если ЗначениеЗаполнено(ДанныеПоручения.ВидИсполненияDVP) Тогда
		Текст = СтрЗаменить(Текст, "[ПоставкаПротивПлатежа]", "V");
	Иначе
		Текст = СтрЗаменить(Текст, "[СвободнаяСделка]", "V");
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция ДанныеУполномоченногоЛица(ДанныеПоручения)
	Результат = Новый Структура("НаименованиеОрганизации, ОтветственноеЛицо", "", "");
	
	Организация = ОбщегоНазначенияПовтИсп.ОрганизацияПоУмолчанию();
	ОтветственныеЛица = ОбщегоНазначения.ОтветственныеЛица(Организация, ДанныеПоручения.Дата);
	Если ЗначениеЗаполнено(ОтветственныеЛица.ГенеральныйДиректорФИО)
		И ЗначениеЗаполнено(ОтветственныеЛица.ГенеральныйДиректорФИО.Фамилия) Тогда
		ПредставлениеОтветственногоЛица = ОтветственныеЛица.ГенеральныйДиректорФИО.Фамилия + " "
		+ ОтветственныеЛица.ГенеральныйДиректорФИО.Имя + " "
		+ ОтветственныеЛица.ГенеральныйДиректорФИО.Отчество;
	ИначеЕсли ЗначениеЗаполнено(ОтветственныеЛица.ГенеральныйДиректор) Тогда
		ПредставлениеОтветственногоЛица = ОтветственныеЛица.ГенеральныйДиректор;
	Иначе
		ПредставлениеОтветственногоЛица = "";
	КонецЕсли;
	
	Результат.НаименованиеОрганизации = СокрЛП(ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Организация, "Наименование"));
	Результат.ОтветственноеЛицо = ПредставлениеОтветственногоЛица;
	
	Возврат Результат;
КонецФункции

&НаСервере
Функция ЭтоПоручениеНаПереводТипаСписаниеНовогоОбразца(ДанныеПоручения)
	Возврат (ДанныеПоручения.ВидОперацииД = Справочники.ВидыОпераций.Перевод 
				И ДанныеПоручения.ТипПеревода = Перечисления.ТипыПереводов.Списание);
КонецФункции

&НаСервере
Функция ЭтоПоручениеНаПереводТипаСписаниеСтарогоОбразца(ДанныеПоручения)
	Возврат (ДанныеПоручения.ВидОперацииД = Справочники.ВидыОпераций.Перевод
				И Не ЗначениеЗаполнено(ДанныеПоручения.ТипПеревода)
				И ДанныеПоручения.ИнициаторомЯвляетсяДепонент);
КонецФункции

&НаСервере
Функция ЭтоПоручениеНаПереводТипаЗачислениеНовогоОбразца(ДанныеПоручения)
	Возврат (ДанныеПоручения.ВидОперацииД = Справочники.ВидыОпераций.Перевод
				И ДанныеПоручения.ТипПеревода = Перечисления.ТипыПереводов.Зачисление);
КонецФункции

&НаСервере
Функция ЭтоПоручениеНаПереводТипаЗачислениеСтарогоОбразца(ДанныеПоручения)
	Возврат (ДанныеПоручения.ВидОперацииД = Справочники.ВидыОпераций.Перевод
				И Не ЗначениеЗаполнено(ДанныеПоручения.ТипПеревода)
				И ДанныеПоручения.ИнициаторомЯвляетсяКонтрагент);
КонецФункции

&НаСервере
Функция ЭтоПоручениеНаПереводТипаСписание(ДанныеПоручения)
	Возврат ЭтоПоручениеНаПереводТипаСписаниеНовогоОбразца(ДанныеПоручения)
				Или ЭтоПоручениеНаПереводТипаСписаниеСтарогоОбразца(ДанныеПоручения);
КонецФункции

&НаСервере
Функция ЭтоПоручениеНаПереводТипаЗачисление(ДанныеПоручения)
	Возврат ЭтоПоручениеНаПереводТипаЗачислениеНовогоОбразца(ДанныеПоручения)
				Или ЭтоПоручениеНаПереводТипаЗачислениеСтарогоОбразца(ДанныеПоручения);
