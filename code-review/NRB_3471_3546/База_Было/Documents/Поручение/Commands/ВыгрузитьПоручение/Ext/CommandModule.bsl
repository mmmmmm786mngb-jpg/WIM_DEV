// ПРОЦЕДУРЫ И ФУНКЦИИ ПОЛУЧЕНИЯ ДАННЫХ

&НаСервере
Функция СтруктураИнформацииПоЦеннойБумаге(СтруктураВыгрузки)
	Поручение 			= СтруктураВыгрузки.ПоручениеСсылка;
	ЦеннаяБумага 		= Поручение.ЦБ;
	СтруктураИнформации = Новый Структура;
	ЗапросСпискаКодовЗагрузкиЦБ	= Новый Запрос(ТекстЗапросаПолученияКодаЗагрузкиЦБ());
	ЗапросСпискаКодовЗагрузкиЦБ.УстановитьПараметр("Владелец", ЦеннаяБумага);
	ЗапросСпискаКодовЗагрузкиЦБ.УстановитьПараметр("Биржа"	 , Константы.КлассификаторЗагрузкиНДЦ.Получить());
	ЗапросСпискаКодовЗагрузкиЦБ.УстановитьПараметр("Дата"	 , Поручение.Дата);
	СписокКодовЗагрузкиЦБ = ЗапросСпискаКодовЗагрузкиЦБ.Выполнить().Выгрузить();
	Если СписокКодовЗагрузкиЦБ.Количество()>0 Тогда
		КодЗагрузкиЦБ	= СокрЛП(СписокКодовЗагрузкиЦБ[0].Код);
	Иначе
		УстановитьСообщениеОбОшибке(СтруктураВыгрузки, "! Для 'Ценной бумаги' не найден код загрузки 'НДЦ'");
		Возврат Неопределено;
	КонецЕсли;
	НомерРегистрации = СокрЛП(ЦеннаяБумага.НомерРегистрации);
	Если НЕ ЗначениеЗаполнено(НомерРегистрации) Тогда 
		УстановитьСообщениеОбОшибке(СтруктураВыгрузки, "! Для 'Ценной бумаги' не заполнен регистрационный номер");
		Возврат Неопределено;
	КонецЕсли;
	ОписаниеЦБПоФормеНРД = КодЗагрузкиЦБ+"#"
							+ Лев(СокрЛП(ЦеннаяБумага.ISIN), 2)+"#"
							+ СокрЛП(ЦеннаяБумага.НомерРегистрации)+"#"
							+ СокрЛП(ЦеннаяБумага.Наименование);
	СтруктураИнформации.Вставить("ISIN",			СокрЛП(ЦеннаяБумага.ISIN));					// ISIN ценной бумаги
	СтруктураИнформации.Вставить("SctyDesc",		ОписаниеЦБПоФормеНРД);						// Описание ценной бумаги по форме НРД 
	СтруктураИнформации.Вставить("SctyNSDRId",		КодЗагрузкиЦБ);								// Код НРД
	СтруктураИнформации.Вставить("UndrlygSctyId",	НомерРегистрации);							// Гос номер
	СтруктураИнформации.Вставить("UndrlygSctyDesc",	СокрЛП(ЦеннаяБумага.Наименование));			// Наименование
	Возврат СтруктураИнформации;
КонецФункции

&НаСервере
Функция ТекстЗапросаПолученияКодаЗагрузкиЦБ()
	Возврат "ВЫБРАТЬ ПЕРВЫЕ 1
	        |	КодыЗагрузки.Код
	        |ИЗ
	        |	Справочник.КодыЗагрузки КАК КодыЗагрузки
	        |ГДЕ
	        |	НЕ КодыЗагрузки.ПометкаУдаления
	        |	И КодыЗагрузки.Владелец = &Владелец
	        |	И КодыЗагрузки.Биржа = &Биржа
	        |	И (НАЧАЛОПЕРИОДА(КодыЗагрузки.ДатаОкончанияДействия, ДЕНЬ) = ДАТАВРЕМЯ(1, 1, 1)
	        |			ИЛИ НАЧАЛОПЕРИОДА(КодыЗагрузки.ДатаОкончанияДействия, ДЕНЬ) >= НАЧАЛОПЕРИОДА(&Дата, ДЕНЬ))";
КонецФункции

&НаСервере
Функция СтруктураОбщейИнформацииОСообщении(СтруктураВыгрузки)
	
	ДокументСсылка = СтруктураВыгрузки.ПоручениеСсылка;
	
	ВидКД = ДокументСсылка.ВидКД;
	
	СтруктураИнформации = Новый Структура;
	
	СтруктураИнформации.Вставить("Issr",	"NSDR");											//Организация присвоившая код = НРД
	СтруктураИнформации.Вставить("FromId", 	"MC0292900000");									//Отправитель = "Код НРД депонента"
	СтруктураИнформации.Вставить("ToId", 	"NDC000000000");									//Получатель  = "Код НРД получателя"
	
	СтруктураИнформации.Вставить("BizMsgIdr",   ОбщегоНазначенияКлиентСервер.Транслит(СокрЛП(ДокументСсылка.Номер)));			//Идентификатор бизнес-сообщения, Исходящий номер инструкции
	СтруктураИнформации.Вставить("CreDtUTC0",   Формат(УниверсальноеВремя(ДокументСсылка.Дата), "ДФ=yyyy-MM-ddTHH:mm:ssZ"));	//Дата и время создания сообщения (универсальное)
	СтруктураИнформации.Вставить("CreDt", 		Формат(ДокументСсылка.Дата, "ДФ=yyyy-MM-ddTHH:mm:ssZ"));						//Дата и время создания сообщения
	КарточкаКД = ДокументСсылка.КарточкаКД;
	РеференсКД = КарточкаКД.КДРеференс;
	СтруктураИнформации.Вставить("MtgRefId",		РеференсКД);																//	Референс КД собрания
	СтруктураИнформации.Вставить("MtgDtAndTm",		КарточкаКД.ДатаПроведенияСобрания);											//	Дата проведения собрания
	СтруктураИнформации.Вставить("MtgTp",			СокрЛП(КарточкаКД.ТипСобрания.Код));										//	Тип собрания
	СтруктураИнформации.Вставить("ClssfctnCd",		СокрЛП(КарточкаКД.КлассСобрания.Код));										//	Классификация собрания
	СтруктураИнформации.Вставить("PrtryId",			СокрЛП(КарточкаКД.СчетДЕПО.Код));											//номер депозитарного счета в НРД, по которому направляется инструкция 
	СтруктураИнформации.Вставить("CorpActnEvtId",	РеференсКД);																//Референс КД выкупа
	СтруктураИнформации.Вставить("EvtTp",			СокрЛП(КарточкаКД.ВидКД.Код));												//Тип КД
	
	Если НЕ ЗначениеЗаполнено(РеференсКД) Тогда 
		УстановитьСообщениеОбОшибке(СтруктураВыгрузки, "! Не указан референс КД");
	КонецЕсли;
	
	Если ВидКДПринадлежитСписку(ВидКД, "BIDS,TEND,PRIO") Тогда
		
		СтруктураИнформации.Вставить("BizSvc", 		"CA331");							//Бизнес-сервис (код формы)
		СтруктураИнформации.Вставить("MsgDefIdr",	"seev.033.001.04");					//Тип сообщения ISO 20022
		СтруктураВыгрузки.КодОтчета = Справочники.ЭтапыКД.ИнструкцияПоКорпоративномуДействию;
		
		Если НЕ ЗначениеЗаполнено(СтруктураИнформации.EvtTp) Тогда 
			УстановитьСообщениеОбОшибке(СтруктураВыгрузки, "! Не указан тип КД в карточке КД");
		КонецЕсли;
		
	Иначе 
		
		СтруктураИнформации.Вставить("BizSvc", 		"CA044");							
		СтруктураИнформации.Вставить("MsgDefIdr",	"seev.004.001.04");	
		СтруктураВыгрузки.КодОтчета = Справочники.ЭтапыКД.ИнструкцияДляУчастияВСобрании;
				
		Если НЕ ЗначениеЗаполнено(СтруктураИнформации.MtgDtAndTm) Тогда 
			УстановитьСообщениеОбОшибке(СтруктураВыгрузки, "! Не указана дата проведения собрания в карточке КД");
		КонецЕсли;
		Если НЕ ЗначениеЗаполнено(СтруктураИнформации.MtgTp) Тогда 
			УстановитьСообщениеОбОшибке(СтруктураВыгрузки, "! Не указан тип собрания в карточке КД");
		КонецЕсли;
		Если НЕ ЗначениеЗаполнено(СтруктураИнформации.ClssfctnCd) Тогда 
			УстановитьСообщениеОбОшибке(СтруктураВыгрузки, "! Не указан класс собрания в карточке КД");
		КонецЕсли;
	
	КонецЕсли;
	
	Возврат СтруктураИнформации;
КонецФункции

&НаСервере
Функция РезультатЗапросаПоОтветамДокументаСобрания(Ссылка)
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	ПоручениеОтветыНаВопросыКГолосованию.НомерВопроса КАК IssrLabl,
	               |	ПоручениеОтветыНаВопросыКГолосованию.За КАК VoteFor,
	               |	ПоручениеОтветыНаВопросыКГолосованию.Против КАК VoteAgnst,
	               |	ПоручениеОтветыНаВопросыКГолосованию.Воздержался КАК VoteAbstn,
	               |	ПоручениеОтветыНаВопросыКГолосованию.Ссылка.СчетДепо КАК СчетДепо,
	               |	ПоручениеОтветыНаВопросыКГолосованию.За + ПоручениеОтветыНаВопросыКГолосованию.Против + ПоручениеОтветыНаВопросыКГолосованию.Воздержался КАК Unit
	               |ИЗ
	               |	Документ.Поручение.ОтветыНаВопросыКГолосованию КАК ПоручениеОтветыНаВопросыКГолосованию
	               |ГДЕ
	               |	ПоручениеОтветыНаВопросыКГолосованию.Ссылка = &Ссылка
	               |ИТОГИ
	               |	МАКСИМУМ(Unit)
	               |ПО
	               |	СчетДепо";
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	Возврат Запрос.Выполнить();
КонецФункции

&НаСервере
Функция РезультатЗапросаПоОпциямиДокументаВыкупа(Ссылка)
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	Поручение.СчетДепо.Код КАК SfkpgAcct,
	               |	Поручение.КарточкаКД.МинимальноеКодичествоДляУчастияВКД КАК CondlQty,
	               |	Поручение.НомерОпцииКДВыкуп КАК OptnNb,
	               |	ВЫБОР
	               |		КОГДА Поручение.НомерОпцииКДВыкуп = ""001""
	               |			ТОГДА ""CASH""
	               |		ИНАЧЕ ""NOAC""
	               |	КОНЕЦ КАК OptnTp,
	               |	Поручение.КоличествоЦБ КАК Unit
	               |ИЗ
	               |	Документ.Поручение КАК Поручение
	               |ГДЕ
	               |	Поручение.Ссылка = &Ссылка";
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	Возврат Запрос.Выполнить();
КонецФункции

/////////////////////////////////////////////////////////////////////////////////////////
// ПРОЦЕДУРЫ И ФУНКЦИИ РАБОТЫ С XDTO

&НаСервере
Функция НовыйОбъектXDTOCorporateActionsNSD(ИмяТипа)
	ПространствоИмен 	= "http://www.vtbcapital-broker.com/CorporateActionsNSD";
	ТипОбъекта 			= ФабрикаXDTO.Тип(ПространствоИмен, ИмяТипа);
	ОбъектXDTO 			= ФабрикаXDTO.Создать(ТипОбъекта);
	Возврат ОбъектXDTO;
КонецФункции

&НаСервере
Функция НовыйОбъектПоСвойствуXDTOCorporateActionsNSD(ОбъектРодитель, ИмяСвойства)
	Тип = ОбъектРодитель.Тип();
	НайденноеСвойство = Тип.Свойства.Получить(ИмяСвойства);
	Если НЕ НайденноеСвойство = Неопределено Тогда 
		ТипОбъекта = НайденноеСвойство.Тип;
		ОбъектXDTO = ФабрикаXDTO.Создать(ТипОбъекта);
		Возврат ОбъектXDTO;
	Иначе 
		ЗаписьЖурналаРегистрации(НСтр("ru = 'Выгрузка поручения о КД в НРД'"),
					УровеньЖурналаРегистрации.Информация,,, 
					"Не найдено свойство '" + ИмяСвойства + "' для типа XDTO '" + Тип + "'");
		Возврат Неопределено;
	КонецЕсли;
КонецФункции

/////////////////////////////////////////////////////////////////////////////////////////
// ВСПОМОГАТЕЛЬНЫЕ ПРОЦЕДУРЫ И ФУНКЦИИ

&НаСервере
Функция ВидКДПринадлежитСписку(ВидКД, СтрокаВидов)
	МассивВидовКД = Новый Массив;
	МассивКодов = СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(СтрокаВидов, ",");
	Для каждого Код из МассивКодов Цикл
		МассивВидовКД.Добавить(Справочники.ВидыКорпоративныхДействий.НайтиПоКоду(Код));
	КонецЦикла;
	Возврат НЕ МассивВидовКД.Найти(ВидКД) = Неопределено;
КонецФункции

&НаСервере
Процедура УстановитьСообщениеОбОшибке(СтруктураВыгрузки, Сообщение)
	СтруктураВыгрузки.ОшибкиВыгрузки = ?(СтруктураВыгрузки.ОшибкиВыгрузки = "", "", СтруктураВыгрузки.ОшибкиВыгрузки + Символы.ПС) + Сообщение;
КонецПроцедуры
