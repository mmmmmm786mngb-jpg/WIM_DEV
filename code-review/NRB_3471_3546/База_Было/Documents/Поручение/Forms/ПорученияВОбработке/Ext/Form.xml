	<Attributes>
		<Attribute name="Список" id="1">
			<Type>
				<v8:Type>cfg:DynamicList</v8:Type>
			</Type>
			<MainAttribute>true</MainAttribute>
			<UseAlways>
				<Field>Список.ПринятьВОбработку</Field>
			</UseAlways>
			<Settings xsi:type="DynamicList">
				<ManualQuery>true</ManualQuery>
				<DynamicDataRead>true</DynamicDataRead>
				<QueryText>ВЫБРАТЬ
	ДокументПоручение.Ссылка КАК Ссылка,
	ДокументПоручение.Номер КАК Номер,
	ДокументПоручение.Дата КАК Дата,
	ДокументПоручение.ВидОперацииД КАК ВидОперацииД,
	ДокументПоручение.ДатаСделки КАК ДатаСделки,
	ДокументПоручение.Депонент КАК Депонент,
	ДокументПоручение.Контрагент КАК Контрагент,
	ДокументПоручение.ПланируемаяДатаРасчетов КАК ПланируемаяДатаРасчетов,
	ДокументПоручение.СуммаСделки КАК СуммаСделки,
	ДокументПоручение.СчетДепо КАК СчетДепо,
	ДокументПоручение.ЦБ КАК ЦБ,
	Этапы.Период КАК ДатаНачалаТекущегоЭтапа,
	Этапы.Этап КАК ТекущийЭтап,
	Этапы.Статус КАК Статус,
	ДокументПоручение.КоличествоЦБ КАК КоличествоЦБ,
	ВЫБОР
		КОГДА ДокументПоручение.ВидОперацииД = ЗНАЧЕНИЕ(Справочник.ВидыОпераций.Депонирование)
			ТОГДА ВЫБОР
					КОГДА ДокументПоручение.СуммаСделки = 0
						ТОГДА ЗНАЧЕНИЕ(Перечисление.ТипыОбработкиПоручений.FOPЗачислениеЦБ)
					ИНАЧЕ ЗНАЧЕНИЕ(Перечисление.ТипыОбработкиПоручений.DVPЗачислениеЦБ)
				КОНЕЦ
		КОГДА ДокументПоручение.ВидОперацииД = ЗНАЧЕНИЕ(Справочник.ВидыОпераций.СнятиеСДепонирования)
			ТОГДА ВЫБОР
					КОГДА ДокументПоручение.СуммаСделки = 0
						ТОГДА ЗНАЧЕНИЕ(Перечисление.ТипыОбработкиПоручений.FOPСписаниеЦБ)
					ИНАЧЕ ЗНАЧЕНИЕ(Перечисление.ТипыОбработкиПоручений.DVPСписаниеЦБ)
				КОНЕЦ
	КОНЕЦ КАК ТипОбработки,
	Этапы.ДатаОкончания КАК ДатаОкончания,
	Операции.Ссылка КАК Операция,
	Этапы.ДатаПоследнегоВыполнения КАК ДатаПоследнегоВыполнения,
	ДокументПоручение.ПринятьВОбработку КАК ПринятьВОбработку
ИЗ
	Документ.Поручение КАК ДокументПоручение
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ЭтапыОбработкиПоручений.СрезПоследних(, ) КАК Этапы
		ПО ДокументПоручение.Ссылка = Этапы.Поручение
		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
			ОперацииЦБ.ДокументОснование КАК ДокументОснование,
			МИНИМУМ(ОперацииЦБ.Ссылка) КАК Ссылка
		ИЗ
			Документ.ОперацииЦБ КАК ОперацииЦБ
		
		СГРУППИРОВАТЬ ПО
			ОперацииЦБ.ДокументОснование) КАК Операции
		ПО ДокументПоручение.Ссылка = Операции.ДокументОснование
ГДЕ
	(&amp;ОтображатьВсеПоручения
			ИЛИ ДокументПоручение.ПринятьВОбработку)
	И ДокументПоручение.Проведен
	И (ДокументПоручение.ВидОперацииД = &amp;Депонирование
			ИЛИ ДокументПоручение.ВидОперацииД = &amp;СнятиеСДепонирования)</QueryText>
				<MainTable>Document.Поручение</MainTable>
				<ListSettings>
					<dcsset:filter>
						<dcsset:viewMode>Normal</dcsset:viewMode>
						<dcsset:userSettingID>dfcece9d-5077-440b-b6b3-45a5cb4538eb</dcsset:userSettingID>
					</dcsset:filter>
					<dcsset:order>
						<dcsset:viewMode>Normal</dcsset:viewMode>
						<dcsset:userSettingID>88619765-ccb3-46c6-ac52-38e9c992ebd4</dcsset:userSettingID>
					</dcsset:order>
					<dcsset:conditionalAppearance>
						<dcsset:viewMode>Normal</dcsset:viewMode>
						<dcsset:userSettingID>b75fecce-942b-4aed-abc9-e6a02e460fb3</dcsset:userSettingID>
					</dcsset:conditionalAppearance>
				</ListSettings>
			</Settings>
		</Attribute>
		<Attribute name="ОтображатьВсеПоручения" id="2">
			<Title>
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Отображать все поручения</v8:content>
				</v8:item>
			</Title>
			<Type>
				<v8:Type>xs:boolean</v8:Type>
			</Type>
		</Attribute>
		<ConditionalAppearance>
			<dcsset:item>
				<dcsset:selection>
					<dcsset:item>
						<dcsset:field>Список</dcsset:field>
					</dcsset:item>
				</dcsset:selection>
				<dcsset:filter>
					<dcsset:item xsi:type="dcsset:FilterItemComparison">
						<dcsset:left xsi:type="dcscor:Field">Список.ПринятьВОбработку</dcsset:left>
						<dcsset:comparisonType>Equal</dcsset:comparisonType>
						<dcsset:right xsi:type="xs:boolean">false</dcsset:right>
					</dcsset:item>
					<dcsset:item xsi:type="dcsset:FilterItemComparison">
						<dcsset:left xsi:type="dcscor:Field">ОтображатьВсеПоручения</dcsset:left>
						<dcsset:comparisonType>Equal</dcsset:comparisonType>
						<dcsset:right xsi:type="xs:boolean">true</dcsset:right>
					</dcsset:item>
				</dcsset:filter>
				<dcsset:appearance>
					<dcscor:item xsi:type="dcsset:SettingsParameterValue">
						<dcscor:use>false</dcscor:use>
						<dcscor:parameter>ЦветФона</dcscor:parameter>
						<dcscor:value xsi:type="v8ui:Color">#CCFFCC</dcscor:value>
					</dcscor:item>
					<dcscor:item xsi:type="dcsset:SettingsParameterValue">
						<dcscor:parameter>ЦветТекста</dcscor:parameter>
						<dcscor:value xsi:type="v8ui:Color">web:DimGray</dcscor:value>
					</dcscor:item>
				</dcsset:appearance>
			</dcsset:item>
		</ConditionalAppearance>
	</Attributes>
