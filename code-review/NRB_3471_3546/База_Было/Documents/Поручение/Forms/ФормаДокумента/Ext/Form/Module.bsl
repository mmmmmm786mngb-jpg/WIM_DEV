&НаКлиенте
Процедура ВидПорученияПриИзменении(Элемент)
	УстановитьВидимостьРеквизитовДляВидовПоручений352Паи362Паи();
	УстановитьВидимостьУИН();
	
	Если Объект.ВидПоручения = ПредопределенноеЗначение("Справочник.ВидыИнвентарныхПоручений.П35_2") Тогда
		Объект.ПаиТипЗаявки = ПредопределенноеЗначение("Перечисление.ПаиТипыЗаявок.SINGLE_BUY");
	ИначеЕсли Объект.ВидПоручения = ПредопределенноеЗначение("Справочник.ВидыИнвентарныхПоручений.П36_2") Тогда
		Объект.ПаиТипЗаявки = ПредопределенноеЗначение("Перечисление.ПаиТипыЗаявок.REDEMPTION");
	Иначе
		Объект.ПаиТипЗаявки = ПредопределенноеЗначение("Перечисление.ПаиТипыЗаявок.ПустаяСсылка");
	КонецЕсли;
	
	УстановитьВидимостьДополнительнойИнформации();
	Если Не ПустаяСтрока(Объект.ДополнительнаяИнформацияДляНРД) Тогда
		ПреобразоватьДополнительнуюИнформацию(Объект.ДополнительнаяИнформацияДляНРД, ТекущийВидПоручения, Объект.ВидПоручения);
	КонецЕсли;
	ТекущийВидПоручения = Объект.ВидПоручения;
КонецПроцедуры

