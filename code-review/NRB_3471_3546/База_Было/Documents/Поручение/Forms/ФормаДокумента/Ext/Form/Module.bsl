&НаКлиенте
Процедура ОтменаПроведения(Команда)
	
	ЭтоОтменаИсполненногоПорученияПоДвижениюЦБ = Объект.Проведен И СтатусПоручения = "Исполнено" И ЭтоПоручениеПоДвижениюЦБ(Объект.ВидОперацииД);
	
	Если ЭтоОтменаИсполненногоПорученияПоДвижениюЦБ Тогда
		ТекстСообщения = "Отмена проведения " + Объект.Ссылка + " по движениям ЦБ в статусе Исполнено запрещено, обратитесь в команду Поддержки!";
		ОбщегоНазначения.СообщитьОбОшибке(ТекстСообщения, Истина);
		Возврат;
	КонецЕсли;
	
	Если Объект.Проведен Тогда
		Режим = РежимДиалогаВопрос.ДаНет;
		Ответ = Вопрос(НСтр("ru = 'Отменить проведение документа?'"), Режим, 0);
		Если Ответ = КодВозвратаДиалога.Нет Тогда
			Отказ = Истина;
			Возврат;
		Иначе
			ОтменитьПроведениеНаСервере();
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ОтменитьПроведениеНаСервере()
	
	МетаданныеПоручение = Метаданные.Документы.Поручение;
	Если НЕ ПравоДоступа("ОтменаПроведения", МетаданныеПоручение) Тогда
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Текст = "Не установлено право Отмены проведения для документов Поручение!";
			Сообщение.Сообщить();
		Возврат;
	КонецЕсли;

	Попытка
		Поручение = Объект.Ссылка.ПолучитьОбъект();
		Поручение.Записать(РежимЗаписиДокумента.ОтменаПроведения);
	Исключение
		МенеджерОшибок = Новый МенеджерОбработкиОшибок;
		ТекстСообщения = МенеджерОшибок.КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не удалось отменить проведение - " + ТекстСообщения);
	КонецПопытки;
	
КонецПроцедуры

