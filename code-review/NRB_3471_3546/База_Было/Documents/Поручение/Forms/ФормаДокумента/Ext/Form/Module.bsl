			И (Объект.ВидОперацииД = Справочники.ВидыОпераций.Депонирование
				ИЛИ Объект.ВидОперацииД = Справочники.ВидыОпераций.СнятиеСДепонирования) Тогда
		Объект.КраткийКодНРД = Объект.РазделСчетаДепоКонтрагента.КраткийКодНРД;
	КонецЕсли;
КонецПроцедуры

