// ОБРАБОТЧИКИ СОБЫТИЙ ФОРМЫ

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	УстановитьТипИнициатораНаСервере();
	ОбновитьСтатусПоручения();
	
	Если Объект.Ссылка.Пустая() Тогда
		Объект.Автор	= ПараметрыСеанса.ТекущийПользователь;
		Объект.Изменил	= Справочники.Пользователи.ПустаяСсылка();
	КонецЕсли;
	ДлинаКомментария = ОбщаяДлинаКомментария();
	Если Не Объект.ВидПредставителяСчетаДепоПодпись.Пустая() Тогда
		ОбновитьПредставителяСчетаДепо();
	КонецЕсли;
	
	ИмяСтраницы = ИмяСтраницыПоОперации(Объект.ВидОперацииД);
	Элементы.Страницы.ТекущаяСтраница = Элементы.Страницы.ПодчиненныеЭлементы[ИмяСтраницы];		
	ОграничитьТипЭлементовДепонентНаСервере();
	УстановитьВидимостьПризнакаНачислитьКомиссиюЗаОтменуНаСервере();
	
	РеквизитыИнвентарныхПорученийСервер.ЗаполнитьРеквизитыПоручения(Объект.Ссылка, ЭтотОбъект);
	
	Элементы.НеПроверятьНаличиеКарточкиКД.Доступность = РольДоступна(Метаданные.Роли.ПолныеПрава);

	// СтандартныеПодсистемы.ВерсионированиеОбъектов
	ВерсионированиеОбъектов.ПриСозданииНаСервере(ЭтотОбъект);
	// Конец СтандартныеПодсистемы.ВерсионированиеОбъектов
	
	ПроверитьКвалифицированногоИнвестора();
	
	ДокументыИсполненияПоручения.Параметры.УстановитьЗначениеПараметра("Поручение", Объект.Ссылка);

	Элементы.ОшибкаЗаполненияДепонентов.Видимость = ЗначениеЗаполнено(Объект.ОшибкаЗаполненияДепонентов);
	
	УстановитьВидимостьПоТипуЦБ();
	УстановитьВидимостьТЧ();
	УстановитьВидимостьВидаИнициатора();
	
	УстановитьВидимостьРеквизитовВидаДоговораОснованияДКУ();
	УстановитьВидимостьИногоНаименованияОснованияОперацииДКУ();
	УстановитьВидимостьРеквизитовДляВидовПоручений352Паи362Паи();
	УстановитьВидимостьСчетаДепоМХ();
	УстановитьВидимостьMessageId();
	УстановитьВидимостьИдентификаторДействияВQUIK();
	УстановитьВидимостьЭлементаТипПеревода();
	УстановитьВидимостьДополнительнойИнформации();
	УстановитьВидимостьУИН();
	
	УстановитьУсловноеОформление();

КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	ПересчитатьКоэффициент();
	РасчетнымМетодомПриИзменении();
	ОтображатьНалогиПоВыплате = ЭтоВидОперацииПоВыплатеСНалогооблажением();
	ОбработатьВидОперации(Истина);
	ОформитьЭлементКомандыУправленияПризнакомОбмена();
	Элементы.ФормаОтправитьУведомление.Доступность = НЕ Объект.УведомлениеСУДКОтправлено;
	ОбновитьДанныеФормыНаКлиенте();
	УстановитьВидимостьПоДате();
	УстановитьВидимостьТабличнойЧастиЦБДляСводныхПоручений();
КонецПроцедуры

&НаСервере
Процедура ПриЧтенииНаСервере(ТекущийОбъект)
	НачислитьКомиссиюДепо = РегистрыСведений.ДокументыКНачислениюКомиссииДепо.НеобходимоНачислитьКомиссию(Объект.Ссылка);
	ТекущийВидПоручения = ТекущийОбъект.ВидПоручения;
	Оболочки.ПриЧтенииНаСервереДокумента(ЭтотОбъект, ТекущийОбъект);
КонецПроцедуры

&НаКлиенте
Процедура ПередЗаписью(Отказ, ПараметрыЗаписи)
	
	Если ПараметрыЗаписи.РежимЗаписи = РежимЗаписиДокумента.Проведение Тогда
		Если НЕ ПроверкаСуммыИПДПройдена() Тогда
			Отказ = Истина;
			ОбщегоНазначения.СообщитьОбОшибке("Проведение документа невозможно");
		КонецЕсли;
	КонецЕсли;

	Для Каждого Строка Из Объект.ЦенныеБумагиСписываемые Цикл
		Если НЕ ЗначениеЗаполнено(Строка.ЦеннаяБумага) Тогда
			Строка.ЦеннаяБумага	= Объект.ЦБ;
		КонецЕсли;
	КонецЦикла;

	// Для правильного отображения количества в списке документов:
	// Сохранить в КоличествоЦБ итог по таблице для страниц, где отображаются таблицы
	// Очистить КоличествоЦБ для страниц, где оно не используется
	ТекущаяСтраница = Элементы.Страницы.ТекущаяСтраница.Имя;
	Если ТекущаяСтраница = "Конвертация" Тогда
		Объект.КоличествоЦБ = Объект.Списание.Итог("Количество");
		
	ИначеЕсли ТекущаяСтраница = "СписаниеЦБ" ИЛИ ТекущаяСтраница = "Погашение" Тогда
		Объект.КоличествоЦБ = Объект.ЦенныеБумагиСписываемые.Итог("Количество");
		
	ИначеЕсли ТекущаяСтраница <> "ОперацияЦБ" И ТекущаяСтраница <> "КорпоративноеДействие" Тогда
		Объект.КоличествоЦБ = 0;
	КонецЕсли;
КонецПроцедуры

&НаСервере
Функция ПроверкаСуммыИПДПройдена()
	
	НеобходимаПроверка = (Объект.ВидОперацииД = Справочники.ВидыОпераций.НачислениеДивидендов 
		ИЛИ Объект.ВидОперацииД = Справочники.ВидыОпераций.ПогашениеНКД
		ИЛИ Объект.ВидОперацииД = Справочники.ВидыОпераций.ПогашениеЦБПолное
		ИЛИ Объект.ВидОперацииД = Справочники.ВидыОпераций.ПогашениеЦБЧастичное
		ИЛИ Объект.ВидОперацииД = Справочники.ВидыОпераций.Выкуп
		ИЛИ Объект.ВидОперацииД = Справочники.ВидыОпераций.НачислениеДоходаПрочие);
	ОшибкаВХодеПроверки = Ложь;
	Если НеобходимаПроверка Тогда
		
		РеквизитыЦБ = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Объект.ЦБ, "ВидЦБ, ВидЦББанкаРоссии");
		РасчетПоИностраннойЦБ = Справочники.ВидыЦББанкаРоссии.ЭтоВидИностраннойЦБ(РеквизитыЦБ.ВидЦББанкаРоссии);     

		Если НЕ РасчетПоИностраннойЦБ И Объект.СуммаИПД <> (Объект.ЦенныеБумагиСписываемые.Итог("Сумма") 
																- Объект.ЦенныеБумагиСписываемые.Итог("СуммаНалога")) Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(Строка(Объект.Ссылка)
																+ ": итоговая сумма к выплате не соответствует сумме в ИПД!");
			ОшибкаВХодеПроверки = Истина;
		КонецЕсли;
		
		Документы.Поручение.ПроверитьДлинуКомментария(Объект, ОшибкаВХодеПроверки);
		
	КонецЕсли;
	
	Возврат Не ОшибкаВХодеПроверки;
	
КонецФункции

&НаСервере
Процедура ПередЗаписьюНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	ТекущийОбъект.ДополнительныеСвойства.Вставить("ВведеноИнтерактивно", Истина);
КонецПроцедуры

&НаСервере
Процедура ПослеЗаписиНаСервере(ТекущийОбъект, ПараметрыЗаписи)
	РеквизитыИнвентарныхПорученийСервер.ЗаполнитьРеквизитыПоручения(ТекущийОбъект.Ссылка, ЭтотОбъект);
	УстановитьВидимостьРеквизитовДляВидовПоручений352Паи362Паи();
	ЗаполнитьСписокСчетовДЕПОДепонента();
КонецПроцедуры

&НаКлиенте
Процедура ПослеЗаписи(ПараметрыЗаписи)
	ОбновитьСтатусПоручения();
	
	Если ПараметрыЗаписи.РежимЗаписи = РежимЗаписиДокумента.Проведение И Объект.ВидОперацииД = ПредопределенноеЗначение("Справочник.ВидыОпераций.Перевод") Тогда 
		Прочитать();
	КонецЕсли;
	
	ОбновитьДанныеФормыНаКлиенте();
	
КонецПроцедуры

&НаСервере
Процедура ПриЗаписиНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	Если ТекущийОбъект.ДополнительныеСвойства.Свойство("ФлагНачислитьКомиссиюДепоИзмененАвтоматически") Тогда
		ФлагНачислитьКомиссиюДепоИзмененАвтоматически = ТекущийОбъект.ДополнительныеСвойства.ФлагНачислитьКомиссиюДепоИзмененАвтоматически;
		ТекущийОбъект.ДополнительныеСвойства.Удалить("ФлагНачислитьКомиссиюДепоИзмененАвтоматически");
	Иначе
		ФлагНачислитьКомиссиюДепоИзмененАвтоматически = Ложь;
	КонецЕсли;
	Если Не ФлагНачислитьКомиссиюДепоИзмененАвтоматически Тогда
		РегистрыСведений.ДокументыКНачислениюКомиссииДепо.УстановитьЗначение(ТекущийОбъект.Ссылка, НачислитьКомиссиюДепо);
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаВыбора(ВыбранноеЗначение, ИсточникВыбора)
	Если ЗначениеЗаполнено(ВыбранноеЗначение) 
			И ТипЗнч(ВыбранноеЗначение) = Тип("СправочникСсылка.КодыДляЗаверенияОбОбособленииЦБ") Тогда
		Объект.ДополнительнаяИнформацияДляНРД = ПолучитьСтрокуДополнительнойИнформации(ВыбранноеЗначение, Объект.ВидПоручения);
	КонецЕсли;
КонецПроцедуры

/////////////////////////////////////////////////////////////////////
// ОБРАБОТЧИКИ СОБЫТИЙ ЭЛЕМЕНТОВ ФОРМЫ

&НаКлиенте
Процедура ДатаПриИзменении(Элемент)
	УстановитьВидимостьПоДате();
	ЗаполнитьСписокСчетовДЕПОДепонента();
КонецПроцедуры

&НаКлиенте
Процедура ПланируемаяДатаРасчетовПриИзменении(Элемент)
	Если ТипЗнч(Объект.ВидОперацииД) = Тип("СправочникСсылка.ВидыОпераций")
		И ОбщегоНазначения.ПолучитьЗначениеРеквизита(Объект.ВидОперацииД, "ВыплатаДоходаВДенежнойФорме")
		И ИспользоватьРасчетНДФЛПоПрогрессивнойШкале(Объект.Дата)
		И Объект.ЦенныеБумагиСписываемые.Количество() > 0 Тогда
		
		Ответ = Вопрос("Пересчитать плановую дату расчетов в табличной части?", РежимДиалогаВопрос.ДаНет, 0);
		Если Ответ = КодВозвратаДиалога.Да Тогда
			Для Каждого Строка Из Объект.ЦенныеБумагиСписываемые Цикл
				Строка.ПлановаяДатаРасчетов = Объект.ПланируемаяДатаРасчетов;
			КонецЦикла;
		КонецЕсли;
		ЗаполнитьПризнакУчетаНаСчетеТипаС();
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ВидОперацииДПриИзменении(Элемент)
	УстановитьПанельПоВидуОперации();
	УстановитьВидимостьТЧ();
	ОбработатьВидОперации();
	ОчиститьЗависимыеОтВидаОперацииРеквизитыНаСервере();
	Объект.ТипКонвертации = ТипКонвертации(Объект.ВидОперацииД);
	ОбновитьДанныеФормыНаКлиенте();
	УстановитьВидимостьТабличнойЧастиЦБДляСводныхПоручений();
	УстановитьВидимостьЭлементаТипПеревода();
	УстановитьВидимостьДополнительнойИнформации();
	УстановитьВидимостьУИН();
КонецПроцедуры

&НаКлиенте
Процедура ИнициаторПриИзменении(Элемент)
	ИнициаторПриИзмененииСервер();
	ОбновитьДанныеФормыНаКлиенте();
КонецПроцедуры

&НаКлиенте
Процедура ВидПредставителяСчетаДепоПодписьПриИзменении(Элемент)
	ОбновитьПредставителяСчетаДепо();
КонецПроцедуры

&НаКлиенте
Процедура ЦенныеБумагиСписываемыеПриИзменении(Элемент)
	ПересчитатьКоэффициент();
КонецПроцедуры

&НаКлиенте
Процедура ЦенныеБумагиЗачисляемыеПриИзменении(Элемент)
	ПересчитатьКоэффициент();
КонецПроцедуры

&НаКлиенте
Процедура ЦБОбработкаВыбора(Элемент, ВыбранноеЗначение, СтандартнаяОбработка)
	ПроверкаВыбораЦеннойБумаги(ВыбранноеЗначение, СтандартнаяОбработка);
КонецПроцедуры

&НаКлиенте
Процедура ЦенныеБумагиСписываемыеЦеннаяБумагаОбработкаВыбора(Элемент, ВыбранноеЗначение, СтандартнаяОбработка)
	ПроверкаВыбораЦеннойБумаги(ВыбранноеЗначение, СтандартнаяОбработка);
КонецПроцедуры

&НаКлиенте
Процедура ЦенныеБумагиЗачисляемыеЦеннаяБумагаОбработкаВыбора(Элемент, ВыбранноеЗначение, СтандартнаяОбработка)
	ПроверкаВыбораЦеннойБумаги(ВыбранноеЗначение, СтандартнаяОбработка);
КонецПроцедуры

&НаКлиенте
Процедура РасчетнымМетодомПриИзменении(Элемент = Неопределено)
	Элементы.СуммаИПД.ТолькоПросмотр = Объект.РасчетнымМетодом;
КонецПроцедуры

&НаКлиенте
Процедура СуммаИПДПриИзменении()
	РаспределитьИПДПоДепонентамЦенныеБумагиСписываемые();
КонецПроцедуры

&НаКлиенте
Процедура СуммаИПДНалогаВИностраннойЮрисдикцииПриИзменении(Элемент)
	РаспределитьИПДПоДепонентамЦенныеБумагиСписываемые();
КонецПроцедуры

&НаКлиенте
Процедура ПогашениеСуммаПриИзменении(Элемент = Неопределено)
	ОбновитьДанныеФормыНаКлиенте();
КонецПроцедуры

&НаКлиенте
Процедура ЦеннаяБумагаВыкуп1ПриИзменении(Элемент)
	Объект.Контрагент = ЭмитентЦБ(Объект.ЦБ);
	УстановитьВидимостьПоТипуЦБ();
	УстановитьНачислениеНалогаНаФорме();
КонецПроцедуры

&НаКлиенте
Процедура ВидОперацииДОчистка(Элемент, СтандартнаяОбработка)
	Элементы.ВидОперацииД.ВыбиратьТип = Истина;
	УстановитьПанельПоВидуОперации();
	ОбработатьВидОперации();
КонецПроцедуры

&НаКлиенте
Процедура ИнициаторНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	Элементы.Инициатор.ВыбиратьТип = Не ЗначениеЗаполнено(Объект.Инициатор);
КонецПроцедуры

&НаКлиенте
Процедура ЦенныеБумагиСписываемыеПередНачаломДобавления(Элемент, Отказ, Копирование, Родитель, Группа)
	Если Объект.ЦенныеБумагиСписываемые.Количество() > 0 Тогда
		Отказ = Истина;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ЦенныеБумагиЗачисляемыеПередНачаломДобавления(Элемент, Отказ, Копирование, Родитель, Группа)
	Если Объект.ЦенныеБумагиЗачисляемые.Количество() > 0 Тогда
		Отказ = Истина;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ТипКонвертацииПриИзменении(Элемент)
	ОбработатьВидОперации();
КонецПроцедуры

&НаКлиенте
Процедура ЦБУведомлениеПриИзменении(Элемент)
	Если НЕ Объект.ЦБУведомление.Пустая() Тогда
		Эмитент = ЭмитентЦБ(Объект.ЦБУведомление);
		Если Объект.ЭмитентУведомление <> Эмитент Тогда
			Объект.ЭмитентУведомление = Эмитент;
		КонецЕсли;
	КонецЕсли;	
КонецПроцедуры

&НаКлиенте
Процедура ЦБВыпискаПриИзменении(Элемент)
	Если НЕ Объект.ЦБВыписка.Пустая() Тогда
		Эмитент = ЭмитентЦБ(Объект.ЦБВыписка);
		Если Объект.ЭмитентВыписка <> Эмитент Тогда
			Объект.ЭмитентВыписка = Эмитент;
		КонецЕсли;
	КонецЕсли;	
КонецПроцедуры

&НаКлиенте
Процедура КодОтменыПриИзменении(Элемент)
	УстановитьПричинуОтмены();
КонецПроцедуры

&НаКлиенте
Процедура РазделСчетаДепоКонтрагентаПриИзменении(Элемент)
	УстановитьКраткийКодНРД();
	УстановитьЗалогодержателя(Объект.РазделСчетаДепоКонтрагента);
КонецПроцедуры

&НаКлиенте
Процедура РазделСчетаДепоПриИзменении(Элемент)
	УстановитьЗалогодержателя(Объект.РазделСчетаДепо);
	УстановитьВидимостьУИН();
КонецПроцедуры

&НаКлиенте
Процедура КарточкаКДПриИзменении(Элемент)
	ЗаполнитьРеквизитыУчастияВКДПоКарточкеНаСервере();
	ОбработатьВидОперации();
КонецПроцедуры

&НаКлиенте
Процедура ВидКДПриИзменении(Элемент)
	ОбработатьВидОперации();
КонецПроцедуры

&НаКлиенте
Процедура ДекорацияПоручениеНаИзменениеАнкетныхДанныхНажатие(Элемент)
	
	Файлы = ОбменДаннымиПереопределяемый.ПолучитьФайлыДокумента(Объект.ИдентификаторЗагрузки);
	
	Для Каждого СтрокаФайл Из Файлы Цикл
		
		ИмяВременногоФайла = ПолучитьИмяВременногоФайла(СтрокаФайл.РасширениеФайла);
		СтрокаФайл.Данные.Записать(ИмяВременногоФайла);
		ЗапуститьПриложение(ИмяВременногоФайла, , Истина);
		УдалитьФайлы(ИмяВременногоФайла);
		
	КонецЦикла;
	
КонецПроцедуры

