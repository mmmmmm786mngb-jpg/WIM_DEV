&НаКлиенте
Процедура УстановитьПанельПоВидуОперации()
	ИмяСтраницы = ИмяСтраницыПоОперации(Объект.ВидОперацииД);
	Элементы.Страницы.ТекущаяСтраница = Элементы.Страницы.ПодчиненныеЭлементы[ИмяСтраницы];
КонецПроцедуры

&НаСервереБезКонтекста
Функция ИмяСтраницыПоОперации(ВидОперацииД)
	Операции = Справочники.ВидыОпераций;
	
	СтраницыПоОперации = Новый Соответствие;
	СтраницыПоОперации.Вставить(Операции.Депонирование						, "ОперацияЦБ");
	СтраницыПоОперации.Вставить(Операции.СнятиеСДепонирования				, "ОперацияЦБ");
	СтраницыПоОперации.Вставить(Операции.Перевод							, "ОперацияЦБ");
	СтраницыПоОперации.Вставить(Операции.Перемещение						, "ОперацияЦБ");
	СтраницыПоОперации.Вставить(Операции.ПереводМеждуРазделамиСчетаДепо		, "ОперацияЦБ");
	СтраницыПоОперации.Вставить(Операции.ОтменаПоручения					, "ОперацияЦБ");
	
	СтраницыПоОперации.Вставить(Операции.ОткрытиеСчетаДепо					, "ОткрытиеСчетаДепо");
	СтраницыПоОперации.Вставить(Операции.ОткрытиеРазделаСчетаДепо			, "ОткрытиеРазделаСчетаДепо");
	СтраницыПоОперации.Вставить(Операции.ЗакрытиеРазделаСчетаДепо			, "ЗакрытиеРазделаСчетаДепо");
	
	СтраницыПоОперации.Вставить(Операции.НазначениеОператораСчетаДепо		, "ПредставительСчетаДепо");
	СтраницыПоОперации.Вставить(Операции.ОтменаОператораСчетаДепо			, "ПредставительСчетаДепо");
	СтраницыПоОперации.Вставить(Операции.НазначениеПопечителяСчетаДепо		, "ПредставительСчетаДепо");
	СтраницыПоОперации.Вставить(Операции.ОтзывПопечителяСчетаДепо			, "ПредставительСчетаДепо");
	СтраницыПоОперации.Вставить(Операции.НазначениеРаспорядителяСчетаДепо	, "ПредставительСчетаДепо");
	СтраницыПоОперации.Вставить(Операции.ОтменаРаспорядителяСчетаДепо		, "ПредставительСчетаДепо");
	
	СтраницыПоОперации.Вставить(Операции.ЗакрытиеСчетаДепо					, "КорректировкаЗакрытие");
	СтраницыПоОперации.Вставить(Операции.КорректировкаРеквизитовСчетаДепо	, "КорректировкаЗакрытие");
	СтраницыПоОперации.Вставить(Операции.ПредоставлениеУведомления			, "КорректировкаЗакрытие");
	СтраницыПоОперации.Вставить(Операции.ВидОперацииИзменениеАнкетныхДанных(), "КорректировкаЗакрытие");
	СтраницыПоОперации.Вставить(Операции.ОтменаПоручения					, "ОтменаПоручения");
	
	СтраницыПоОперации.Вставить(Операции.Конвертация						, "Конвертация");
	
	СтраницыПоОперации.Вставить(Операции.Выкуп								, "СписаниеЦБ");
	СтраницыПоОперации.Вставить(Операции.Погашение							, "СписаниеЦБ");
	СтраницыПоОперации.Вставить(Операции.СписаниеАкцийПриЛиквидацииЭмитента	, "СписаниеЦБ");
	СтраницыПоОперации.Вставить(Операции.СписаниеОбесценившихсяЦенныхБумаг	, "СписаниеЦБ");
	СтраницыПоОперации.Вставить(Операции.ВыкупСписаниеЦБ					, "СписаниеЦБ");
	
	СтраницыПоОперации.Вставить(Операции.НачислениеДоходовЦБ				, "НачислениеДоходовЦБ");
	
	ДобавитьОперацииВыплатыДоходаВДенежнойФормеНаСервере(СтраницыПоОперации, "Погашение");
	
	ОтчетыВид = Перечисления.ВидыОтчетов;
	
	СтраницыПоОперации.Вставить(ОтчетыВид.Выписка							, "Отчет");
	СтраницыПоОперации.Вставить(ОтчетыВид.ОтчетОбОперацияхПоСчетуДЕПО		, "Отчет");
	СтраницыПоОперации.Вставить(ОтчетыВид.ВыпискаОСостоянииСчетаДЕПО		, "Отчет");
	СтраницыПоОперации.Вставить(ОтчетыВид.Отчет								, "Отчет");
	СтраницыПоОперации.Вставить(ОтчетыВид.Уведомление						, "Отчет");
	СтраницыПоОперации.Вставить(ОтчетыВид.Другой							, "Отчет");
	СтраницыПоОперации.Вставить(ОтчетыВид.СводныйОтчетОСовершеннойОперации	, "Отчет");
	
	СтраницыПоОперации.Вставить(Операции.УчастиеВКД							, "КорпоративноеДействие");
	
	ИмяСтраницы = СтраницыПоОперации[ВидОперацииД];
	Если ИмяСтраницы = Неопределено Тогда
		ИмяСтраницы = "ОперацияЦБ";
	КонецЕсли;
	
	Возврат ИмяСтраницы;
КонецФункции

&НаСервереБезКонтекста
Процедура ДобавитьОперацииВыплатыДоходаВДенежнойФормеНаСервере(СтраницыПоОперации, ИмяСтраницы)
	Операции = Справочники.ВидыОпераций.ОперацииВыплатыДоходаВДенежнойФорме();
	Для Каждого Операция Из Операции Цикл
		СтраницыПоОперации.Вставить(Операция, ИмяСтраницы);
	КонецЦикла;
КонецПроцедуры

&НаСервере
Процедура УстановитьДоверенноеЛицоНаСервере()
	
	Отбор = Новый Структура("Депонент", Объект.Инициатор);
	СтруктураДЛ = РегистрыСведений.ДоверенныеЛица.ПолучитьПоследнее(Объект.Дата, Отбор);
	
	Если Не ЗначениеЗаполнено(СтруктураДЛ.ДоверенноеЛицо) Тогда
		
		ДоверенноеЛицо = "Не определено.";
		
	Иначе
		
		ДоверенноеЛицо = Строка(СтруктураДЛ.ДоверенноеЛицо) + " №" + Строка(СтруктураДЛ.НомерДоверенности) + " от " + Формат(СтруктураДЛ.ДатаНачала,"ДФ=dd.MM.yyyy");
		Если Не (СтруктураДЛ.ДатаОкончания >= Объект.Дата) Тогда
			
			Элементы.ДоверенноеЛицо.ЦветТекста = WebЦвета.Красный;
			
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ИнициаторПриИзмененииСервер()
	УстановитьТипИнициатораНаСервере();
	
	ЭтоИнвентарныеОперации = ТипЗнч(Объект.ВидОперацииД) = Тип("СправочникСсылка.ВидыОпераций")
		И Объект.ВидОперацииД.КлассОпераций = Перечисления.КлассыОпераций.Инвентарные;
		
	Если ЭтоИнвентарныеОперации
		И НЕ ЗначениеЗаполнено(Объект.Депонент)
		И ТипЗнч(Объект.Инициатор) = Тип("СправочникСсылка.Контрагенты") Тогда
		мОбъект = РеквизитФормыВЗначение("Объект");
		мОбъект.Депонент = мОбъект.Инициатор;
		ЗначениеВРеквизитФормы(мОбъект, "Объект");
		ОчиститьСчетИРазделСчетаДепоСервер();
	КонецЕсли;
	УстановитьВидимостьПризнакаНачислитьКомиссиюЗаОтменуНаСервере();
	УстановитьВидимостьВидаИнициатора();
КонецПроцедуры

&НаСервере
Процедура УстановитьТипИнициатораНаСервере()
	Документ = РеквизитФормыВЗначение("Объект");
	
	Если Не ЗначениеЗаполнено(Документ.Инициатор) Тогда 		 
		Возврат;
	КонецЕсли;
	
	ЭтоИнвентарныеОперации = ТипЗнч(Объект.ВидОперацииД) = Тип("СправочникСсылка.ВидыОпераций")
		И Объект.ВидОперацииД.КлассОпераций = Перечисления.КлассыОпераций.Инвентарные;
		
	Если ТипЗнч(Документ.Инициатор) = Тип("СправочникСсылка.МестаХранения") Тогда
		ТипИнициатора = "Место хранения";
		Если НЕ ЭтоИнвентарныеОперации
			И (Документ.ЭтоНовый() ИЛИ (Не ЗначениеЗаполнено(Документ.СчетДепо) И Документ.СчетДепо <> Справочники.СчетаДепоМХ.ПустаяСсылка())) Тогда
			Документ.СчетДепо = Справочники.СчетаДепоМХ.ПустаяСсылка();
		КонецЕсли;
	ИначеЕсли ТипЗнч(Документ.Инициатор) = Тип("СправочникСсылка.Контрагенты") Тогда
		Если НЕ ЭтоИнвентарныеОперации
			И (Документ.ЭтоНовый() ИЛИ (Не ЗначениеЗаполнено(Документ.СчетДепо) И Документ.СчетДепо <> Справочники.СчетаДепо.ПустаяСсылка())) Тогда
			Документ.СчетДепо = Справочники.СчетаДепо.ПустаяСсылка();			
		КонецЕсли; 
		ТипИнициатора = ПолучитьПредставлениеТипаЛица(Документ.Инициатор.ЮрФизЛицо);
	КонецЕсли;	
	
	ЗначениеВРеквизитФормы(Документ, "Объект");
	УстановитьДоверенноеЛицоНаСервере();
КонецПроцедуры

&НаСервере
Функция ПолучитьПредставлениеТипаЛица(ТипЛица)
	Если ТипЛица = Перечисления.ЮрФизЛицо.ФизЛицо Тогда
		Возврат "Физическое лицо";
	ИначеЕсли ТипЛица = Перечисления.ЮрФизЛицо.ЮрЛицо Тогда
		Возврат "Юридическое лицо";
	КонецЕсли;
КонецФункции

&НаСервере
Процедура ОбновитьСтатусПоручения()
	Статус = РегистрыСведений.СтатусыПоручений.СтатусПоручения(Объект.Ссылка);
	СтатусПоручения = ?(ЗначениеЗаполнено(Статус), Статус, "Не определен");
КонецПроцедуры

&НаСервере
Процедура ОбновитьПредставителяСчетаДепо()
	
	Если Не ЗначениеЗаполнено(Объект.СчетДепо) Тогда
		Возврат;
	КонецЕсли;	
	
	Отбор = Новый Структура("СчетДепо,ВидПредставителя", Объект.СчетДепо, Объект.ВидПредставителяСчетаДепоПодпись);
	СтруктураПСД = РегистрыСведений.ПредставителиСчетаДепо.ПолучитьПоследнее(, Отбор);
	
	Если СтруктураПСД.Представитель = Справочники.Контрагенты.ПустаяСсылка() Тогда
		
		НадписьДанныеПСД = "Не определен."; 
		Элементы.НадписьДанныеПСД.ЦветТекста = WebЦвета.Черный;
		
	Иначе
		
		НадписьДанныеПСД = Строка(СтруктураПСД.Представитель) + " " + Строка(СтруктураПСД.СтатусПредставителя) + " №" + Строка(СтруктураПСД.НомерДоверенности) + " от " + Формат(СтруктураПСД.ДатаНачалаДействияДоворенности,"ДФ=dd.MM.yyyy");
		
		Если Не (СтруктураПСД.ДатаОкончанияДействияДоверенности >= Объект.Дата) 
			ИЛИ СтруктураПСД.СтатусПредставителя = Перечисления.СтатусыПредставителей.Отменен Тогда
			
			Элементы.НадписьДанныеПСД.ЦветТекста = WebЦвета.Красный;	
			
		Иначе	
			
			Элементы.НадписьДанныеПСД.ЦветТекста = WebЦвета.Черный;
			
		КонецЕсли; 							  		
		
	КонецЕсли; 					
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьВыкупНаСервере()
	
	ДокументОбъект = РеквизитФормыВЗначение("Объект");
	
	Если ДокументОбъект.ЭтоНовый() Тогда
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "Для заполнения необходимо сначала записать документ!";
		Сообщение.Сообщить();
		Возврат;
	КонецЕсли;
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	ОстаткиЦБОстатки.СчетДепо КАК СчетДепо,
	|	ОстаткиЦБОстатки.РазделСчетаДепо КАК РазделСчетаДепо,
	|	ОстаткиЦБОстатки.ЦБ КАК ЦеннаяБумага,
	|	ОстаткиЦБОстатки.КоличествоОстаток КАК Количество,
	|	ОстаткиЦБОстатки.СчетДепоМХ,
	|	ОстаткиЦБОстатки.РазделСчетаДепоМХ
	|ИЗ
	|	РегистрНакопления.ОстаткиЦБ.Остатки(&Период, ЦБ = &ЦеннаяБумага И &ОтборПоСчетуДепоМХ) КАК ОстаткиЦБОстатки
	|УПОРЯДОЧИТЬ ПО
	|	ОстаткиЦБОстатки.СчетДепо.Владелец.Наименование,
	|	ОстаткиЦБОстатки.СчетДепо,
	|	ОстаткиЦБОстатки.РазделСчетаДепо
	|");
	Запрос.УстановитьПараметр("Период", Новый МоментВремени(Объект.Дата, Объект.Ссылка));
	Запрос.УстановитьПараметр("ЦеннаяБумага", Объект.ЦБ);
	
	Если Элементы.СчетДепоМХДокумента.Видимость И ЗначениеЗаполнено(Объект.СчетДепоМХДокумента) Тогда
		СтрокаУсловия = "СчетДепоМХ = &СчетДепоМХ";
		Запрос.УстановитьПараметр("СчетДепоМХ", Объект.СчетДепоМХДокумента);
	Иначе
		СтрокаУсловия = "ИСТИНА";
	КонецЕсли;
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "&ОтборПоСчетуДепоМХ", СтрокаУсловия);
	
	Результат = Запрос.Выполнить();
	Если Результат.Пустой() Тогда
		Возврат;
	КонецЕсли;
	
	Объект.ЦенныеБумагиСписываемые.Загрузить(Результат.Выгрузить());
	
КонецПроцедуры

&НаКлиенте
Процедура ПересчитатьКоэффициент()
	КоличествоИсходныхИтог = Объект.ЦенныеБумагиСписываемые.Итог("Количество");
	Если КоличествоИсходныхИтог <> 0 Тогда
		КоэффициентКонвертации = Объект.ЦенныеБумагиЗачисляемые.Итог("Количество") / КоличествоИсходныхИтог;
	Иначе
		КоэффициентКонвертации = 0;
	КонецЕсли; 
КонецПроцедуры

&НаСервере
Процедура ОбработатьВидОперации(ВызовИзПриОткрытии = Ложь)
	Если Объект.ВидОперацииД = Справочники.ВидыОпераций.ПогашениеНКД 
		ИЛИ Объект.ВидОперацииД = Справочники.ВидыОпераций.Выкуп Тогда
		Элементы.РасчетнымМетодом.Доступность	= Истина;
	ИначеЕсли Объект.ВидОперацииД = Справочники.ВидыОпераций.ПогашениеЦБПолное 
		ИЛИ Объект.ВидОперацииД = Справочники.ВидыОпераций.ПогашениеЦБЧастичное
		Тогда
		Элементы.РасчетнымМетодом.Доступность	= Ложь;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Объект.ВидОперацииД) Тогда
		Элементы.ВидОперацииД.ВыбиратьТип	= Ложь;
	Иначе
		Элементы.ВидОперацииД.ВыбиратьТип	= Истина;
	КонецЕсли;
		
	Элементы.СчетДепо1.ОграничениеТипа	= Новый ОписаниеТипов("СправочникСсылка.СчетаДепо");
	Элементы.СчетДепо1.ВыбиратьТип		= Ложь;
	
	Элементы.СчетДепо3.ОграничениеТипа	= Новый ОписаниеТипов("СправочникСсылка.СчетаДепо");
	Элементы.СчетДепо3.ВыбиратьТип		= Ложь;
	
	Элементы.СчетДепо4.ОграничениеТипа	= Новый ОписаниеТипов("СправочникСсылка.СчетаДепо");
	Элементы.СчетДепо4.ВыбиратьТип		= Ложь;
	
	Элементы.СчетДепо.ОграничениеТипа	= Новый ОписаниеТипов("СправочникСсылка.СчетаДепо");
	Элементы.СчетДепо.ВыбиратьТип		= Ложь;
	
	Элементы.ПериодНачисления.Видимость		= Объект.ВидОперацииД = Справочники.ВидыОпераций.НачислениеДивидендов
		ИЛИ Объект.ВидОперацииД = Справочники.ВидыОпераций.НачислениеДоходаПрочие;
	Элементы.ДатаКонПериода.Видимость		= Не (Объект.ВидОперацииД = Перечисления.ВидыОтчетов.ВыпискаОСостоянииСчетаДЕПО);
	Элементы.ВыборПериодаОтчета.Видимость	= Не (Объект.ВидОперацииД = Перечисления.ВидыОтчетов.ВыпискаОСостоянииСчетаДЕПО);
	Элементы.ДатаНачПериода.Заголовок		= ?(Объект.ВидОперацииД = Перечисления.ВидыОтчетов.ВыпискаОСостоянииСчетаДЕПО, "Уведомление о состоянии счета депо на", "Уведомление о движении ЦБ по счету депо за период");
	
	Элементы.Уведомление.Видимость			= Не (Объект.ВидОперацииД = Перечисления.ВидыОтчетов.ВыпискаОСостоянииСчетаДЕПО);
	
	Элементы.ДокументОперацииСводногоОтчета.Видимость = (Объект.ВидОперацииД = Перечисления.ВидыОтчетов.СводныйОтчетОСовершеннойОперации);
	
	ВидОперацииЯвляетсяСсылкойНаСправочникВидыОпераций = (ТипЗнч(Объект.ВидОперацииД) = Тип("СправочникСсылка.ВидыОпераций"));
	
	ЭтоИнвентарнаяОперация = ВидОперацииЯвляетсяСсылкойНаСправочникВидыОпераций
		И Объект.ВидОперацииД.КлассОпераций = Перечисления.КлассыОпераций.Инвентарные;
		
	ЭтоОткрытиеЗалоговогоРаздела = Объект.ВидОперацииД = Справочники.ВидыОпераций.ОткрытиеРазделаСчетаДепо
		И Объект.ТипРазделаСчетаДЕПО = Перечисления.ТипыРазделовСчетовДЕПО.БлокированоВЗалоге;
		
	Элементы.Залогодержатель.Видимость			= ЭтоИнвентарнаяОперация ИЛИ ЭтоОткрытиеЗалоговогоРаздела;
	Элементы.ГруппаРеквизитыСделки.Видимость	= ЭтоИнвентарнаяОперация;
	
	Если НЕ ЭтоИнвентарнаяОперация Тогда
		Если НЕ ЭтоОткрытиеЗалоговогоРаздела Тогда
			Объект.Залогодержатель = Справочники.Контрагенты.ПустаяСсылка();
		КонецЕсли;
		Объект.ДатаСделки	= Дата(1,1,1);
		Объект.Референс		= "";
	КонецЕсли;
	
	Элементы.ФормаРассчитатьКонвертацию.Видимость	= (Объект.ВидОперацииД = Справочники.ВидыОпераций.Конвертация);
	
	Если (Объект.ВидОперацииД = Справочники.ВидыОпераций.Конвертация) Тогда
		Если (Объект.ТипКонвертации = Перечисления.ТипыКонвертаций.Аннулирование) Тогда
			Элементы.ЦенныеБумагиЗачисляемые.Видимость	= Ложь;
			Элементы.Зачисление.Видимость				= Ложь;
			Элементы.КоэффициентКонвертации.Доступность	= Ложь;
			Элементы.ЦенныеБумагиСписываемые.Видимость	= Истина;
			Если Объект.ЦенныеБумагиЗачисляемые.Количество()>0 Тогда
				Объект.ЦенныеБумагиЗачисляемые.Очистить();
			КонецЕсли;
			Если Объект.Зачисление.Количество()>0 Тогда
				Объект.Зачисление.Очистить();
			КонецЕсли;
			Объект.КоэффициентКонвертации				= 1;
		Иначе
			Элементы.ЦенныеБумагиЗачисляемые.Видимость	= Истина;
			Элементы.ЦенныеБумагиСписываемые.Видимость	= Истина;
			Элементы.Зачисление.Видимость				= Истина;
			Элементы.КоэффициентКонвертации.Доступность	= Истина;
		КонецЕсли;
	КонецЕсли;
	
	Элементы.ПереключательЭлементФормы.Видимость	= (Объект.ВидОперацииД = Перечисления.ВидыОтчетов.ВыпискаОСостоянииСчетаДЕПО);
	
	ВыпискаОСостоянииОтчетОбОперациях = Объект.ВидОперацииД = Перечисления.ВидыОтчетов.ВыпискаОСостоянииСчетаДЕПО
		ИЛИ Объект.ВидОперацииД = Перечисления.ВидыОтчетов.ОтчетОбОперацияхПоСчетуДЕПО
		ИЛИ Объект.ВидОперацииД = Перечисления.ВидыОтчетов.СводныйОтчетОСовершеннойОперации
		;
	
	Элементы.ГруппаСпособОтправки.Видимость	= ВыпискаОСостоянииОтчетОбОперациях;
	Элементы.ЦБУведомление.Видимость		= ВыпискаОСостоянииОтчетОбОперациях;
	Элементы.ЦБВыписка.Видимость			= ВыпискаОСостоянииОтчетОбОперациях;
	
	Элементы.КодОтмены.Видимость		= (Объект.ВидОперацииД = Справочники.ВидыОпераций.ОтменаПоручения);
	Элементы.ПричинаОтмены.Видимость	= (Объект.ВидОперацииД = Справочники.ВидыОпераций.ОтменаПоручения);
	
	Элементы.ГруппаКоэффициентыД.Видимость	= Объект.ВидОперацииД = Справочники.ВидыОпераций.НачислениеДивидендов Или Объект.ВидОперацииД = Справочники.ВидыОпераций.НачислениеДоходаПрочие;
	
	ЭтоИзменениеКатегорииСчетовДепонента = (Объект.ВидОперацииД = Справочники.ВидыОпераций.ИзменениеКатегорииСчетовДепонента);
	
	СнятиеПрием = Объект.ВидОперацииД = Справочники.ВидыОпераций.СнятиеЦБсОбслуживания Или Объект.ВидОперацииД = Справочники.ВидыОпераций.ПриемЦБНаОбслуживание;
	Элементы.Колонки.Видимость					= НЕ СнятиеПрием;
	Элементы.ГруппаКоличество.Видимость			= НЕ СнятиеПрием;
	Элементы.ПланируемаяДатаРасчетов.Видимость  = НЕ СнятиеПрием И Не ЭтоИзменениеКатегорииСчетовДепонента;
	
	ИспользованиеМХКонтрагента = ( Объект.ВидОперацииД = Справочники.ВидыОпераций.Перемещение
									Или Объект.ВидОперацииД = Справочники.ВидыОпераций.ПереводМеждуРазделамиСчетаДепо
									Или Объект.ВидОперацииД = Справочники.ВидыОпераций.Перевод
									Или Объект.ВидОперацииД = Справочники.ВидыОпераций.ВозвратИзЗалога
									Или Объект.ВидОперацииД = Справочники.ВидыОпераций.ПередачаВЗалог );
	Элементы.СчетДепоМХКонтрагента.Видимость						= ИспользованиеМХКонтрагента;
	Элементы.СчетДепоМХКонтрагента.АвтоОтметкаНезаполненного		= ИспользованиеМХКонтрагента;
	Элементы.РазделСчетаДепоМХКонтрагента.Видимость					= ИспользованиеМХКонтрагента;
	Элементы.РазделСчетаДепоМХКонтрагента.АвтоОтметкаНезаполненного	= ИспользованиеМХКонтрагента;
	Элементы.МХКонтрагент.АвтоОтметкаНезаполненного					= ИспользованиеМХКонтрагента;
	
	ЭтоВидКДСобрания = ЭтоВидКДСобранияНаСервере(Объект.ВидКД);
	Элементы.ГруппаКоличествоКД.Видимость = НЕ ЭтоВидКДСобрания;
	Элементы.ОтветыНаВопросыКГолосованию.Видимость = ЭтоВидКДСобрания;
	
	Элементы.ФормаДокументПоручениеВыгрузитьПоручение.Доступность = Объект.ВидОперацииД = Справочники.ВидыОпераций.УчастиеВКД И НЕ Объект.УведомлениеОтправлено;
		
	Элементы.ДополнительныеДатыИсполнения.Видимость = Ложь;
	Если ВидОперацииЯвляетсяСсылкойНаСправочникВидыОпераций И Объект.ВидОперацииД.ДвижениеПоЦБ Тогда
		Элементы.ДополнительныеДатыИсполнения.Видимость = Истина;
	КонецЕсли;
	
	Элементы.ПлатежныйАгент.Видимость = ВидОперацииЯвляетсяСсылкойНаСправочникВидыОпераций
		И Объект.ВидОперацииД.КлассОпераций = Перечисления.КлассыОпераций.Глобальные
		И Объект.ВидОперацииД.ВыплатаДоходаВДенежнойФорме;
		
	УстановитьВидимостьГруппыНалогиПоВыплате();
		
	ОперацияИзмененияАнкетныхДанных = Объект.ВидОперацииД = Справочники.ВидыОпераций.ВидОперацииИзменениеАнкетныхДанных();
	ЕстьИдентификаторЭлектронногоПоручения = ЗначениеЗаполнено(Объект.ИдентификаторЗагрузки);
	Элементы.ДекорацияПоручениеНаИзменениеАнкетныхДанных.Видимость = ОперацияИзмененияАнкетныхДанных
		И ЕстьИдентификаторЭлектронногоПоручения;
	Элементы.ИзменениеАнкетныхДанныхДепонент.Видимость = ОперацияИзмененияАнкетныхДанных;
	
	Элементы.ИнвентарныеОперацииДепонент.Видимость = (ВидОперацииЯвляетсяСсылкойНаСправочникВидыОпераций
														И Объект.ВидОперацииД.КлассОпераций = Перечисления.КлассыОпераций.Инвентарные)
														Или ЭтоИзменениеКатегорииСчетовДепонента;
		
	Элементы.СчетДепоМХДокумента.Видимость = ВидОперацииЯвляетсяСсылкойНаСправочникВидыОпераций
		И Объект.ВидОперацииД.КлассОпераций = Перечисления.КлассыОпераций.Глобальные;
		
	Элементы.СнятьЦеннуюБумагуСОбслуживания_Конвертация.Видимость =
		Объект.ВидОперацииД = Справочники.ВидыОпераций.Конвертация;
		
	Элементы.СнятьЦеннуюБумагуСОбслуживания_СписаниеЦБ.Видимость =
		Объект.ВидОперацииД = Справочники.ВидыОпераций.ВыкупСписаниеЦБ
		ИЛИ Объект.ВидОперацииД = Справочники.ВидыОпераций.Погашение
		ИЛИ Объект.ВидОперацииД = Справочники.ВидыОпераций.СписаниеАкцийПриЛиквидацииЭмитента
		ИЛИ Объект.ВидОперацииД = Справочники.ВидыОпераций.СписаниеОбесценившихсяЦенныхБумаг;
		
	Элементы.ФормаОтправитьУведомление.Видимость = Документы.Поручение.ВозможноУведомлениеСУДКПоОперации(Объект.ВидОперацииД);
	
	ЭтоОперацияДепонированияСнятия = ( Объект.ВидОперацииД = Справочники.ВидыОпераций.Депонирование Или Объект.ВидОперацииД = Справочники.ВидыОпераций.СнятиеСДепонирования );
	
	Элементы.КраткийКодНРД.Видимость = ЭтоОперацияДепонированияСнятия;
	Элементы.ГруппаБанковскийСчетДепонированиеСнятие.Видимость = ЭтоОперацияДепонированияСнятия;
	Элементы.ИдентификаторЗагрузки.Видимость = ЭтоОперацияДепонированияСнятия;
	Если Элементы.ПринятьВОбработку.Видимость <> ЭтоОперацияДепонированияСнятия Тогда
		Элементы.ПринятьВОбработку.Видимость = ЭтоОперацияДепонированияСнятия;
		ОчиститьФлагПринятьВОбработку();
	КонецЕсли;
	Элементы.ТипСвертки.Видимость = ЭтоОперацияДепонированияСнятия;

	Элементы.НомерСчета.Видимость = (Объект.ВидОперацииД = Справочники.ВидыОпераций.ОткрытиеСчетаДепо И ТипЗнч(Объект.Депонент) = Тип("СправочникСсылка.МестаХранения"));
	
	ЭтоОткрытиеРазделаСчетаДепо = Объект.ВидОперацииД = Справочники.ВидыОпераций.ОткрытиеРазделаСчетаДепо;
	ОграничитьТипЭлементовРазделСчетаДепоМХНаСервере();
	УстановитьСвязиПараметровВыбораСчетаИРазделаДепоМХ(ЭтоОткрытиеРазделаСчетаДепо);
	Элементы.Брокер.Видимость = ЭтоОткрытиеРазделаСчетаДепо
		И Объект.ТипРазделаСчетаДЕПО = Перечисления.ТипыРазделовСчетовДЕПО.ОбеспеченияДержатель;
	
	ЗначениеПризнака = (ЭтоОткрытиеРазделаСчетаДепо И ТипЗнч(Объект.Депонент) = Тип("СправочникСсылка.Контрагенты"));
	Элементы.ОткрытьВМХ.Доступность					= ЗначениеПризнака;
	Элементы.ОткрытиеРазделаСчетДепоМХ.Видимость	= ЗначениеПризнака И Объект.ОткрытьВМХ;
	Элементы.НомерРазделаСчетаДепоМХ.Видимость		= ЗначениеПризнака И Объект.ОткрытьВМХ;
	УстановитьВидимостьДоступностьСубклиента();
	
	ЭтоЗакрытиеРазделаСчетаДепо = (Объект.ВидОперацииД = Справочники.ВидыОпераций.ЗакрытиеРазделаСчетаДепо);
	ЗначениеПризнака = (ЭтоЗакрытиеРазделаСчетаДепо И ТипЗнч(Объект.Депонент) = Тип("СправочникСсылка.Контрагенты"));
	Элементы.ЗакрытьВМХ.Доступность					= ЗначениеПризнака;
	Элементы.ЗакрытиеРазделаТипРазделаРазделСчетаДепоМХ.Видимость = ЭтоЗакрытиеРазделаСчетаДепо И Объект.ЗакрытьВМХ;
	Элементы.ЗакрытиеРазделаСчетДепоМХ.Видимость = 
		ЭтоЗакрытиеРазделаСчетаДепо И Объект.ЗакрытьВМХ И ТипЗнч(Объект.Депонент) <> Тип("СправочникСсылка.МестаХранения");
	Элементы.ЗакрытиеРазделаРазделСчетаДепо.Видимость = ЗначениеПризнака;
	Элементы.ДатаИсполненияПоручения.ТолькоПросмотр = Объект.ЗакрытьВМХ;
	Элементы.КодОтчетаНРД.ТолькоПросмотр = Объект.ЗакрытьВМХ;
	ПустойМассив = Новый ФиксированныйМассив(Новый Массив);
	Если Элементы.ЗакрытиеРазделаСчетДепоМХ.СвязиПараметровВыбора.Количество() > 0 Тогда
		Элементы.ЗакрытиеРазделаСчетДепоМХ.СвязиПараметровВыбора = ПустойМассив;
	КонецЕсли;
	
	Элементы.КвалифицированныйИнвесторПо11_8_пзн.Видимость = (Объект.ВидОперацииД = Справочники.ВидыОпераций.Депонирование);
	
	ВидимостьФлажка = (Объект.ВидОперацииД = Справочники.ВидыОпераций.УчастиеВКД И Объект.ВидКД.Код = "WTRC");
	Элементы.УсловноеДлящеесяПоручение.Видимость = ВидимостьФлажка;
	
	Если ЭтоИзменениеКатегорииСчетовДепонента Тогда
		ОрганизацияПоУмолчанию = ОбщегоНазначенияПовтИсп.ОрганизацияПоУмолчанию();
		Если Не ЗначениеЗаполнено(Объект.ДатаИсполненияПоручения) И Не ВызовИзПриОткрытии Тогда
			Объект.ДатаИсполненияПоручения = НачалоДня(ТекущаяДатаСеанса());
		КонецЕсли;
		Если Объект.Инициатор <> ОрганизацияПоУмолчанию И Не ВызовИзПриОткрытии Тогда
			Объект.Инициатор = ОрганизацияПоУмолчанию;
		КонецЕсли;
		УстановитьВидимостьВидаИнициатора();
		Если Объект.ВидИнициатора <> 0 И Не ВызовИзПриОткрытии Тогда
			Объект.ВидИнициатора = 0; // ВидИнициатора - Депозитарий
		КонецЕсли;
		ТребуемыйКомментарий = "Указ Президента РФ №95 от 05.03.2022; Решение Совета Директоров БР от 21.11.22 г.";
		Если Объект.Комментарий <> ТребуемыйКомментарий И Не ВызовИзПриОткрытии Тогда
			Объект.Комментарий = ТребуемыйКомментарий;
		КонецЕсли;
		ЗаполнитьСписокСчетовДЕПОДепонента();
	КонецЕсли;
	Элементы.Инициатор.ТолькоПросмотр = ЭтоИзменениеКатегорииСчетовДепонента;
	Элементы.ВидИнициатора.ТолькоПросмотр = ЭтоИзменениеКатегорииСчетовДепонента;
	Элементы.ВидПоручения.Видимость = Не ЭтоИзменениеКатегорииСчетовДепонента;
	Элементы.КодОтчетаНРД.Видимость = Не ЭтоИзменениеКатегорииСчетовДепонента;
	Элементы.Проверено.Видимость = Не ЭтоИзменениеКатегорииСчетовДепонента;
	Элементы.ТипИнициатора.Видимость = Не ЭтоИзменениеКатегорииСчетовДепонента;
	Элементы.МХ_ПоУмолчанию.Видимость = Не ЭтоИзменениеКатегорииСчетовДепонента;
	Элементы.НачислитьКомиссиюДепо.Видимость = Не ЭтоИзменениеКатегорииСчетовДепонента;
	Элементы.СуммаСделки1.Видимость = Не ЭтоИзменениеКатегорииСчетовДепонента;
	Элементы.ПланируемаяДатаРасчетов.Видимость = Не ЭтоИзменениеКатегорииСчетовДепонента;
	Элементы.ВходящаяИнформация.Видимость = Не ЭтоИзменениеКатегорииСчетовДепонента;
	Элементы.Подписи.Видимость = Не ЭтоИзменениеКатегорииСчетовДепонента;
	Элементы.ДанныеОснования.Видимость = Не ЭтоИзменениеКатегорииСчетовДепонента;
	Элементы.ДокументыИсполнения.Видимость = Не ЭтоИзменениеКатегорииСчетовДепонента;
	Элементы.КолонкаКонтрагент.Видимость = Не ЭтоИзменениеКатегорииСчетовДепонента;
	Элементы.ГруппаПараметрыDVP.Видимость = Не ЭтоИзменениеКатегорииСчетовДепонента;
	Элементы.СчетДепо1.Видимость = Не ЭтоИзменениеКатегорииСчетовДепонента;
	Элементы.Декорация1.Видимость = Не ЭтоИзменениеКатегорииСчетовДепонента;
	Элементы.РазделСчетаДепо.Видимость = Не ЭтоИзменениеКатегорииСчетовДепонента;
	Элементы.МХДепонента.Видимость = Не ЭтоИзменениеКатегорииСчетовДепонента;
	Элементы.СчетДепоМХ.Видимость = Не ЭтоИзменениеКатегорииСчетовДепонента;
	Элементы.РазделСчетаДепоМХ.Видимость = Не ЭтоИзменениеКатегорииСчетовДепонента;
	Элементы.ГруппаИмеетСчетаТипаC.Видимость = ЭтоИзменениеКатегорииСчетовДепонента;
	Элементы.СчетаДепоДепонента.Видимость = ЭтоИзменениеКатегорииСчетовДепонента;
КонецПроцедуры

&НаСервере
Процедура УстановитьВидимостьТЧ()
	Элементы.ГруппаЦенныеБумагиВыкупПогашение.Видимость = Ложь;
	
	Если Объект.ВидОперацииД = Справочники.ВидыОпераций.Выкуп
		Или Объект.ВидОперацииД = Справочники.ВидыОпераций.НачислениеДивидендов
		Или Объект.ВидОперацииД = Справочники.ВидыОпераций.НачислениеДоходаПрочие
		Или Объект.ВидОперацииД = Справочники.ВидыОпераций.ПогашениеНКД
		Или Объект.ВидОперацииД = Справочники.ВидыОпераций.ПогашениеЦБПолное
		Или Объект.ВидОперацииД = Справочники.ВидыОпераций.ПогашениеЦБЧастичное Тогда
		
		Элементы.ГруппаЦенныеБумагиВыкупПогашение.Видимость = Истина;
	КонецЕсли;
КонецПроцедуры

