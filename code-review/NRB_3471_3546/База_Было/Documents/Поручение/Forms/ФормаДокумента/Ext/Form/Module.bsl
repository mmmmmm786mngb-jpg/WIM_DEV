КонецПроцедуры

&НаКлиенте
Процедура ОткрытиеРазделаТипРазделаРазделСчетаДепоМХАвтоПодбор(Элемент, Текст, ДанныеВыбора, ПараметрыПолученияДанных,
	Ожидание, СтандартнаяОбработка)
	
	ДанныеВыбора = РаботаСДиалогамиКлиент.ДанныеВыбораСУчетомТипаРаздела(
	Объект.ТипРазделаСчетаДЕПО, ПараметрыПолученияДанных, СтандартнаяОбработка);
	
КонецПроцедуры

&НаСервере
Функция СоздатьНаОснованииНаСервере(ТекущиеДанныеСчетДепо)
	
	Основание = Документы.Поручение.ДанныеДляСозданияДокументовПоНалогам(Объект.Ссылка, ТекущиеДанныеСчетДепо);
	СтруктураЗначения = ОбщегоНазначения.СтрокаТаблицыЗначенийВСтруктуру(Основание[0]);
	НеобходимРасчетНалога = Документы.НачисленныйНалог.РасчетНалогаРазрешен(Объект.ВидОперацииД);
	СтруктураЗначения.Вставить("РасчетНалога", НеобходимРасчетНалога);
	
	ПараметрыФормы = Новый Структура("Основание, СчетДепо", СтруктураЗначения, ТекущиеДанныеСчетДепо);
	
	Возврат ПараметрыФормы;
	
КонецФункции

&НаКлиенте
Процедура СоздатьНаОсновании(Команда)
	
	Если Не Элементы.ЦенныеБумагиВыкуп1.ТекущиеДанные.НачислитьНалог Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Для создания начисления налога необходимо проставить признак ""НачислитьНалог""");
		Возврат;	
	КонецЕсли;
	
	Если Модифицированность Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Необходимо записать поручение прежде чем создавать начисление налога");
		Возврат;
	КонецЕсли;
	
	ПараметрыФормы = СоздатьНаОснованииНаСервере(Элементы.ЦенныеБумагиВыкуп1.ТекущиеДанные.СчетДепо);
	ОткрытьФорму("Документ.НачисленныйНалог.ФормаОбъекта", ПараметрыФормы);

КонецПроцедуры

&НаКлиенте
Процедура ПодтвердитьНалог(Команда)
	ПараметрыОтбора = Новый Структура("Поручение", Объект.Ссылка);
	ОткрытьФорму("Документ.НачисленныйНалог.Форма.ФормаДляПодтвержденияНалога", ПараметрыОтбора, , Новый УникальныйИдентификатор);
КонецПроцедуры

&НаКлиенте
Процедура ДокументОперацииСводногоОтчетаПриИзменении(Элемент)
	ДокументОперацииСводногоОтчетаПриИзмененииНаСервере();
КонецПроцедуры

&НаСервере
Процедура ДокументОперацииСводногоОтчетаПриИзмененииНаСервере()
	Объект.ДатаНачПериода = Объект.ДокументОперацииСводногоОтчета.Дата;
	Объект.ДатаКонПериода = Объект.ДокументОперацииСводногоОтчета.Дата;
КонецПроцедуры

&НаКлиенте
Процедура РегистрСведенийУведомленияОтправленныеЧерезКК(Команда)
	Если ЗначениеЗаполнено(Объект.Ссылка) Тогда
		Отбор = Новый Структура("КД", Объект.Ссылка);
		ПараметрыФормы = Новый Структура("Отбор", Отбор);
		ОткрытьФорму("РегистрСведений.УведомленияОтправленныеЧерезЛичныйКабинет.ФормаСписка", ПараметрыФормы, ЭтотОбъект,
			УникальныйИдентификатор);
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура КомментарийПриИзменении(Элемент)
	ДлинаКомментария = ОбщаяДлинаКомментария();
КонецПроцедуры

&НаСервере
Процедура УстановитьВидимостьСчетаДепоМХ()
	Элементы.ОткрытиеСчетаСчетДепоМХ.Видимость = ТипЗнч(Объект.Депонент) = Тип("СправочникСсылка.Контрагенты");
КонецПроцедуры

&НаСервере
Функция ОбщаяДлинаКомментария()
	
	ДлинаКомментария = СтрДлина(Объект.Комментарий);
	ДлинаКомментарияДоп = 0;
	Для Каждого Строка Из Объект.ЦенныеБумагиСписываемые Цикл
		ДлинаКомментарияДоп = Макс(ДлинаКомментарияДоп, СтрДлина(Строка.Комментарий));
	КонецЦикла;
	ДлинаКомментария = ДлинаКомментария + ДлинаКомментарияДоп;
	
	Возврат ДлинаКомментария;
	
КонецФункции

&НаСервере
Процедура БанковскийСчетДепонированиеСнятиеПриИзмененииНаСервере()
	ВидПоручения352ПаиИли362Паи = (Объект.ВидПоручения = Справочники.ВидыИнвентарныхПоручений.П35_2
		Или Объект.ВидПоручения = Справочники.ВидыИнвентарныхПоручений.П36_2);
	Если ВидПоручения352ПаиИли362Паи И ЗначениеЗаполнено(Объект.БанковскийСчет) Тогда
		ЗаполнитьЗначенияСвойств(Объект, Справочники.БанковскиеСчета.БанковскиеРеквизитыПаи(Объект.БанковскийСчет));
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура БанковскийСчетДепонированиеСнятиеПриИзменении(Элемент)
	БанковскийСчетДепонированиеСнятиеПриИзмененииНаСервере();
КонецПроцедуры

&НаКлиенте
Процедура ИсточникЗагрузкиПриИзменении(Элемент)
	УстановитьВидимостьMessageId();
	УстановитьВидимостьИдентификаторДействияВQUIK();
КонецПроцедуры

&НаСервере
Процедура УстановитьВидимостьMessageId()
	ЭтоПоручениеЗагруженоИзПанда = (Объект.ИсточникЗагрузки = Перечисления.ИсточникиЗагрузки.Панда);
	ПоказыватьMessageId = ЭтоПоручениеЗагруженоИзПанда И ЭтоАдминистратор();
	Элементы.DepoMessageId.Видимость = ПоказыватьMessageId;
	Элементы.KafkaMessageId.Видимость = ПоказыватьMessageId;
КонецПроцедуры

&НаСервере
Процедура УстановитьВидимостьИдентификаторДействияВQUIK()
	ЭтоПоручениеЗагруженоИзQUIK = (Объект.ИсточникЗагрузки = Перечисления.ИсточникиЗагрузки.QUIK);
	ПоказыватьИдентификаторДействияВQUIK = ЭтоПоручениеЗагруженоИзQUIK И ЭтоАдминистратор();
	Элементы.ЦенныеБумагиСводногоПорученияИдентификаторДействияВQUIK.Видимость = ПоказыватьИдентификаторДействияВQUIK;
КонецПроцедуры

&НаСервереБезКонтекста
Функция ЭтоАдминистратор()
	ЭтоАдминистратор = ПравоДоступа("Администрирование", Метаданные);
	
	Возврат ЭтоАдминистратор;
КонецФункции

&НаСервере
Процедура УстановитьВидимостьДополнительнойИнформации()
	ВидимостьДопИнформации = ТребуютсяКодыДляЗаверенияОбОбособленииЦБ(Объект.ВидОперацииД, Объект.ВидПоручения);
	Элементы.ДополнительнаяИнформацияДляНРД.Видимость = ВидимостьДопИнформации;
КонецПроцедуры

&НаСервереБезКонтекста
Функция ТребуютсяКодыДляЗаверенияОбОбособленииЦБ(ВидОперацииД, ВидПоручения)
	Если ВидПоручения = Справочники.ВидыИнвентарныхПоручений.П16 Тогда
		ЭтоИнвентарнаяОперация = ТипЗнч(ВидОперацииД) = Тип("СправочникСсылка.ВидыОпераций")
									И ВидОперацииД.КлассОпераций = Перечисления.КлассыОпераций.Инвентарные;
		ТребуютсяКоды = ЭтоИнвентарнаяОперация;
	ИначеЕсли ВидПоручения = Справочники.ВидыИнвентарныхПоручений.П36_Реестр Тогда
		ТребуютсяКоды = (ВидОперацииД = Справочники.ВидыОпераций.СнятиеСДепонирования);
	Иначе
		ТребуютсяКоды = Ложь;
	КонецЕсли;
	
	Возврат ТребуютсяКоды;
КонецФункции

&НаСервереБезКонтекста
Функция ПолучитьСтрокуДополнительнойИнформации(КодДляЗаверенияОбОбособленииЦБ, ВидПоручения)
	П16 = (ВидПоручения = Справочники.ВидыИнвентарныхПоручений.П16);
	ДополнительнаяИнформацияСтрокой = ?(П16, "[", "") + СокрЛП(КодДляЗаверенияОбОбособленииЦБ.Код) + ?(П16, "]", "");
	
	Возврат ДополнительнаяИнформацияСтрокой;
КонецФункции

&НаСервереБезКонтекста
Процедура ПреобразоватьДополнительнуюИнформацию(ДополнительнаяИнформацияДляНРД, ТекущийВидПоручения, НовыйВидПоручения)
	Если ТекущийВидПоручения = Справочники.ВидыИнвентарныхПоручений.П16
			И НовыйВидПоручения = Справочники.ВидыИнвентарныхПоручений.П36_Реестр Тогда
		УбратьКвадратныеСкобкиУКодаДляЗаверенияОбОбособленииЦБ(ДополнительнаяИнформацияДляНРД);
	КонецЕсли;
	Если ТекущийВидПоручения = Справочники.ВидыИнвентарныхПоручений.П36_Реестр
			И НовыйВидПоручения = Справочники.ВидыИнвентарныхПоручений.П16 Тогда
		ДобавитьКвадратныеСкобкиУКодаДляЗаверенияОбОбособленииЦБ(ДополнительнаяИнформацияДляНРД);
	КонецЕсли;
КонецПроцедуры

&НаСервереБезКонтекста
Процедура УбратьКвадратныеСкобкиУКодаДляЗаверенияОбОбособленииЦБ(Строка)
	МассивКодов = Справочники.КодыДляЗаверенияОбОбособленииЦБ.ВсеКоды();
	ВторойСимвол = 2;
	Для Каждого Элемент Из МассивКодов Цикл
		Код = СокрЛП(Элемент);
		ПозицияКода = СтрНайти(Строка, Код);
		Если ПозицияКода = ВторойСимвол Тогда
			ДлинаСтроки = СтрДлина(Строка);
			ДлинаКода = СтрДлина(Код);
			Если (ПозицияКода + ДлинаКода) <= ДлинаСтроки
					И Лев(Строка, 1) = "[" 
					И Сред(Строка, ПозицияКода + ДлинаКода, 1) = "]" Тогда
				Строка = Код + Прав(Строка, ДлинаСтроки - ПозицияКода - ДлинаКода);
				Прервать;
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

&НаСервереБезКонтекста
Процедура ДобавитьКвадратныеСкобкиУКодаДляЗаверенияОбОбособленииЦБ(Строка)
	МассивКодов = Справочники.КодыДляЗаверенияОбОбособленииЦБ.ВсеКоды();
	ДлинаСтроки = СтрДлина(Строка);
	Для Каждого Элемент Из МассивКодов Цикл
		Код = СокрЛП(Элемент);
		ПозицияКода = СтрНайти(Строка, Код); 
		Если ПозицияКода = 1 Тогда
			ДлинаКода = СтрДлина(Код);
			Строка = "[" + Лев(Строка, ДлинаКода) + "]" + Прав(Строка, ДлинаСтроки - ДлинаКода);
			Прервать;
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

&НаКлиенте
Процедура РедактироватьКомментарий(Команда)
	Если Объект.Проведен = Истина И СтатусПоручения = "Исполнено" И ЭтоПоручениеВыкупСписаниеЦБ(Объект.ВидОперацииД) Тогда
		ОповещениеОЗакрытии = Новый ОписаниеОповещения("ОповеститьОЗакрытииФормыРедактированияКомментария", ЭтотОбъект);
		ПараметрыФормы = Новый Структура;
		ПараметрыФормы.Вставить("Комментарий", СокрЛП(Объект.Комментарий));
		ПараметрыФормы.Вставить("Ссылка", Объект.Ссылка);
		ОткрытьФорму("ОбщаяФорма.ФормаРедактированияКомментария", ПараметрыФормы, , , , , ОповещениеОЗакрытии,
						РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ОповеститьОЗакрытииФормыРедактированияКомментария(Результат, ДополнительныеПараметры) Экспорт
	Прочитать();
КонецПроцедуры

