Процедура ОчиститьЗависимыеОтВидаОперацииРеквизитыНаСервере()
	ДокументОбъект = РеквизитФормыВЗначение("Объект");
	ДокументОбъект.ОчиститьЗависимыеОтВидаОперацииРеквизиты();
	ЗначениеВРеквизитФормы(ДокументОбъект, "Объект");	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьПогашениеНаСервере()
	ДокументОбъект = РеквизитФормыВЗначение("Объект");
	
	Если Элементы.СчетДепоМХДокумента.Видимость И ЗначениеЗаполнено(Объект.СчетДепоМХДокумента) Тогда
		пСчетДепоМХДокумента = Объект.СчетДепоМХДокумента;
	Иначе
		пСчетДепоМХДокумента = Неопределено;
	КонецЕсли;
	
	ДокументОбъект.ЗаполнитьПогашаемыеОблигацииКупоны(
		Объект.ВидОперацииД = Справочники.ВидыОпераций.ПогашениеНКД
		ИЛИ Объект.ВидОперацииД = Справочники.ВидыОпераций.Выкуп,
		пСчетДепоМХДокумента);
	ЗначениеВРеквизитФормы(ДокументОбъект, "Объект");
	
КонецПроцедуры

&НаСервере
Функция ПолучитьДанныеДляРасчетаКонвертации()
	ДокПоручение	= РеквизитФормыВЗначение("Объект");
	МоментВремени	= ДокПоручение.МоментВремени();
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	СчетДепо,
	|	РазделСчетаДепо,
	|	СчетДепоМХ,
	|	РазделСчетаДепоМХ,
	|	СтатусЦБ,
	|	КоличествоОстаток КАК Количество
	|ИЗ
	|	РегистрНакопления.ОстаткиЦБ.Остатки(&Период, ЦБ = &ЦеннаяБумага)
	|ГДЕ
	|	КоличествоОстаток > 0
	|УПОРЯДОЧИТЬ ПО
	|	СчетДепо,
	|	РазделСчетаДепо,
	|	СчетДепоМХ,
	|	РазделСчетаДепоМХ,
	|	СтатусЦБ");
	Запрос.УстановитьПараметр("ЦеннаяБумага", Объект.ЦенныеБумагиСписываемые[0].ЦеннаяБумага);
	Запрос.УстановитьПараметр("Период"		, МоментВремени);
	Возврат Запрос.Выполнить();
КонецФункции

&НаСервере
Процедура РассчитатьДляДробныхЗачисленийСервер()
	Объект.Списание.Очистить();
	Объект.Зачисление.Очистить();
	Результат	= ПолучитьДанныеДляРасчетаКонвертации();	
	Выборка		= Результат.Выбрать();
	Пока Выборка.Следующий() Цикл
		Если Выборка.Количество <= 0 Тогда
			Продолжить;
		КонецЕсли; 
		КоличествоЗачисления		= Выборка.Количество * Объект.КоэффициентКонвертации - Цел(Выборка.Количество * Объект.КоэффициентКонвертации);
		КоличествоСписания			= КоличествоЗачисления / Объект.КоэффициентКонвертации;
		
		СтрокаСписание				= Объект.Списание.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаСписание, Выборка);
		СтрокаСписание.Количество	= КоличествоСписания;
		СтрокаСписание.ЦеннаяБумага	= Объект.ЦенныеБумагиСписываемые[0].ЦеннаяБумага;
		
		Для Каждого Элемент Из Объект.ЦенныеБумагиЗачисляемые Цикл
			СтрокаЗачисление			= Объект.Зачисление.Добавить();
			ЗаполнитьЗначенияСвойств(СтрокаЗачисление, Выборка);
			СтрокаЗачисление.Количество	= КоличествоЗачисления;
			СтрокаЗачисление.ЦеннаяБумага	= Элемент.ЦеннаяБумага;
		КонецЦикла;
	КонецЦикла;
КонецПроцедуры

&НаСервере
Процедура РассчитатьДляЦелыхЗачисленийСервер()
	Объект.Списание.Очистить();
	Объект.Зачисление.Очистить();
	Результат	= ПолучитьДанныеДляРасчетаКонвертации();	
	Выборка		= Результат.Выбрать();
	Пока Выборка.Следующий() Цикл
		Если Выборка.Количество <= 0 Тогда
			Продолжить;
		КонецЕсли; 
		КоличествоЗачисления		= Цел(Выборка.Количество * Объект.КоэффициентКонвертации);
		КоличествоСписания			= КоличествоЗачисления / Объект.КоэффициентКонвертации;
		
		СтрокаСписание				= Объект.Списание.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаСписание, Выборка);
		СтрокаСписание.Количество	= КоличествоСписания;
		СтрокаСписание.ЦеннаяБумага	= Объект.ЦенныеБумагиСписываемые[0].ЦеннаяБумага;
		
		Для Каждого Элемент Из Объект.ЦенныеБумагиЗачисляемые Цикл
			СтрокаЗачисление				= Объект.Зачисление.Добавить();
			ЗаполнитьЗначенияСвойств(СтрокаЗачисление, Выборка);
			СтрокаЗачисление.Количество 	= КоличествоЗачисления;
			СтрокаЗачисление.ЦеннаяБумага	= Элемент.ЦеннаяБумага;
		КонецЦикла;
	КонецЦикла;
КонецПроцедуры

&НаСервере
Процедура РассчитатьБезОкругленияСервер()
	Объект.Списание.Очистить();
	Объект.Зачисление.Очистить();
	Результат	= ПолучитьДанныеДляРасчетаКонвертации();	
	Выборка		= Результат.Выбрать();
	Пока Выборка.Следующий() Цикл
		Если Выборка.Количество <= 0 Тогда
			Продолжить;
		КонецЕсли; 
		
		СтрокаСписание = Объект.Списание.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаСписание, Выборка);
		СтрокаСписание.ЦеннаяБумага	= Объект.ЦенныеБумагиСписываемые[0].ЦеннаяБумага;
		
		Для Каждого Элемент Из Объект.ЦенныеБумагиЗачисляемые Цикл
			СтрокаЗачисление				= Объект.Зачисление.Добавить();
			ЗаполнитьЗначенияСвойств(СтрокаЗачисление, Выборка);
			СтрокаЗачисление.Количество		= Выборка.Количество * Объект.КоэффициентКонвертации;
			СтрокаЗачисление.ЦеннаяБумага	= Элемент.ЦеннаяБумага;
		КонецЦикла;
	КонецЦикла;
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьРеквизитыУчастияВКДПоКарточкеНаСервере()
	Объект.ВидКД 	= Объект.КарточкаКД.ВидКД;
	Объект.ЦБ 		= Объект.КарточкаКД.ЦеннаяБумага1;
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьДанныеФормыНаКлиенте()
	Если ИспользоватьРасчетНДФЛПоПрогрессивнойШкале(Объект.Дата) Тогда
		ОбновитьПоляФормыПоПрогрессивнойШкалеНаСервере();
	Иначе
		КоэффициентУчетаНалога = КоэффициентУчетаНалога(Объект.Валюта);
		ДанныеДляРасчетаНалога = ДанныеДляРасчетаНалога(Объект);
		НужноНачислитьНДФЛНаЕврооблигацию = НужноНачислитьНДФЛНаЕврооблигацию(ДанныеДляРасчетаНалога);
		Если НужноНачислитьНДФЛНаЕврооблигацию Тогда 
			СтруктураКурсаВалюты = ОбщегоНазначения.ПолучитьКурсВалюты(ДанныеДляРасчетаНалога.ВалютаНоминала, ДанныеДляРасчетаНалога.ДатаПогашения);
			ВалютаРегламентированногоУчета = ВалютаРегламентированногоУчета();
		КонецЕсли;
		Для Каждого СтрокаОбъекта Из Объект.ЦенныеБумагиСписываемые Цикл
			Если НужноНачислитьНДФЛНаЕврооблигацию Тогда 
				СуммаНалогаВВалюте = ОбщегоНазначения.ПересчитатьИзВалютыВВалюту(СтрокаОбъекта.СуммаНалога, ВалютаРегламентированногоУчета,
					ДанныеДляРасчетаНалога.ВалютаНоминала, 1, СтруктураКурсаВалюты.Курс, 1, СтруктураКурсаВалюты.Кратность);
				СтрокаОбъекта.СуммаКВыплате = СтрокаОбъекта.Сумма - СуммаНалогаВВалюте;
			Иначе
				СтрокаОбъекта.СуммаКВыплате = СтрокаОбъекта.Сумма - ?(СтрокаОбъекта.НачислитьНалог, КоэффициентУчетаНалога * СтрокаОбъекта.СуммаНалога, 0);
			КонецЕсли;
		КонецЦикла;
		ИтогСуммаКВыплате = Объект.ЦенныеБумагиСписываемые.Итог("СуммаКВыплате");
	КонецЕсли;

	Если СтатусПоручения = "Исполнено" И Объект.Проведен Тогда
		ТолькоПросмотр = Истина;
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура ОбновитьПоляФормыПоПрогрессивнойШкалеНаСервере()
	ДанныеИнфоПолей = Документы.Поручение.ДанныеНалоговыхДокументов(Объект.Ссылка);
	Для Каждого СтрокаОбъекта Из Объект.ЦенныеБумагиСписываемые Цикл
		Отбор = Новый Структура("СчетДепо, РазделСчетаДепо", СтрокаОбъекта.СчетДепо, СтрокаОбъекта.РазделСчетаДепо);
		НайденныеСтроки = ДанныеИнфоПолей.НайтиСтроки(Отбор);
		Если НайденныеСтроки.Количество() > 0 Тогда
			ЗаполнитьЗначенияСвойств(СтрокаОбъекта, НайденныеСтроки[0],
				"СуммаОбязательствПоУплатеНалога, СуммаНалогаПоСтавке15СПревышения, ДатаПередачиДоходаКлиенту, "
				+ "ДатаУплатыНалога, СтавкаНалогаНачисленныйНалог, "
				+ "СуммаКВыплатеПоОсновнаяСтавка, СуммаКВыплатеПоПовышеннаяСтавка, СтавкаНалогаПовышеннаяНачисленныйНалог");
		КонецЕсли;
		Если СтрокаОбъекта.НДФЛУдержан Тогда
			СтрокаОбъекта.СуммаКВыплате = СтрокаОбъекта.Сумма - СтрокаОбъекта.СуммаНалога;
			СтрокаОбъекта.СтавкаНалогаНачисленныйНалог = СтрокаОбъекта.СтавкаНалога;
			
		ИначеЕсли ЭтоЕврооблигацияМинфина(Объект.ЦБ, Объект.Валюта) Тогда
			СтрокаОбъекта.СуммаКВыплате = СтрокаОбъекта.Сумма;
			
		Иначе
			СтрокаОбъекта.СуммаКВыплате = СтрокаОбъекта.Сумма
				- (СтрокаОбъекта.СуммаОбязательствПоУплатеНалога + СтрокаОбъекта.СуммаНалогаПоСтавке15СПревышения);
		КонецЕсли;
	КонецЦикла;
	ИтогСуммаКВыплате = Объект.ЦенныеБумагиСписываемые.Итог("СуммаКВыплате");
	ЗаполнитьПризнакУчетаНаСчетеТипаС();
КонецПроцедуры

&НаСервереБезКонтекста
