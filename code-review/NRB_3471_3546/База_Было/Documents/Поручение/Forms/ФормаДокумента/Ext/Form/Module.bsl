// ПРОЦЕДУРЫ И ФУНКЦИИ РАСЧЕТА НДФЛ

&НаКлиенте
Процедура ПогашениеНачислитьНалогПриИзменении(Элемент)
	ТекущиеДанные = Элементы.ЦенныеБумагиВыкуп1.ТекущиеДанные;
	Если НЕ ВозможноНачислениеНалогаПоЦеннойБумаге() Тогда
		ТекущиеДанные.НачислитьНалог = Ложь;
		ОбщегоНазначения.СообщитьОбОшибке("Невозможно начислить налог. Указана государственная облигация. Действие отменено");
	КонецЕсли;
	Если НЕ ВозможноНачислениеДляДепонента(ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ТекущиеДанные.СчетДепо, "Владелец")) 
		И ТекущиеДанные.НачислитьНалог = Истина Тогда
		ТекущиеДанные.НачислитьНалог = Ложь;
		ОбщегоНазначения.СообщитьОбОшибке("Невозможно начислить налог для данного депонента (не н/а). Действие отменено");
	КонецЕсли;
	Если ТекущиеДанные.НачислитьНалог = Истина Тогда 	
		Если НЕ ЗначениеЗаполнено(ТекущиеДанные.СуммаНалога) Тогда
			СтавкаНалога 				= ТекущиеДанные.СтавкаНалога;
			Резидент 					= ТекущиеДанные.Резидент;
			НалогооблагаемаяБаза		= ТекущиеДанные.Сумма;
			СтатьиНКРФСоглашения		= ТекущиеДанные.СтатьиНКРФСоглашения;
			Количество					= ТекущиеДанные.Количество;
			ТекущиеДанные.СуммаНалога 	= РассчитатьНалогНаДоход(ТекущиеДанные.СчетДепо, ТекущиеДанные.РазделСчетаДепо,
				НалогооблагаемаяБаза, Количество, СтавкаНалога, Резидент, СтатьиНКРФСоглашения);
			ТекущиеДанные.СтавкаНалога  = СтавкаНалога;
			ТекущиеДанные.Резидент  	= Резидент;
			Если Не ИспользоватьРасчетНДФЛПоПрогрессивнойШкале(Объект.Дата) Тогда
				ТекущиеДанные.СуммаОсвобожденнаяОтНалога = ТекущиеДанные.Сумма - НалогооблагаемаяБаза;
			КонецЕсли;
			ТекущиеДанные.СтатьиНКРФСоглашения = СтатьиНКРФСоглашения;
		КонецЕсли;
	Иначе 
		ТекущиеДанные.СуммаНалога  					= 0;
		ТекущиеДанные.СтавкаНалога 					= 0;
		ТекущиеДанные.СуммаОсвобожденнаяОтНалога 	= 0;
		ТекущиеДанные.СтатьиНКРФСоглашения			= "";
	КонецЕсли;
	ОбновитьДанныеФормыНаКлиенте();
КонецПроцедуры

&НаСервере 
Функция РассчитатьНалогНаДоход(Знач СчетДепо, РазделСчетаДепо, Сумма, Количество, СтавкаНалога, Резидент, СтатьиНКРФСоглашения)
	
	СтруктураКурсаВалютаДокумента 	= ОбщегоНазначения.ПолучитьКурсВалюты(Объект.Валюта, Объект.Дата);
	Сумма 							= ОбщегоНазначения.ПересчитатьИзВалютыВВалюту(Сумма,
											Объект.Валюта, Константы.ВалютаРегламентированногоУчета.Получить(),
											СтруктураКурсаВалютаДокумента.Курс,1,
											СтруктураКурсаВалютаДокумента.Кратность,1);
												
	Депонент						= СчетДепо.Владелец;
	Резидент 						= ДанныеФизлиц.ЯвляетсяНалоговымРезидентом(Объект.Дата, Депонент);
	
	СтруктураНачисленияНалога		= Документы.Поручение.СтруктураНачисленияНалогаПоВыплатеДохода(Объект);
	Документы.Поручение.ЗаполнитьСтавкуИСуммуНалогаВСтруктуреНачисления(СтруктураНачисленияНалога, Резидент, Сумма, Количество,
		СчетДепо, РазделСчетаДепо);
	
	СтавкаНалога					= СтруктураНачисленияНалога.СтавкаНалога;
	СуммаНалога 					= СтруктураНачисленияНалога.СуммаНалога;
	СтатьиНКРФСоглашения			= СтруктураНачисленияНалога.СтатьиНКРФСоглашения;
			
	Возврат СуммаНалога;
	
КонецФункции

&НаСервере 
Функция ВозможноНачислениеНалогаПоЦеннойБумаге()
	Возврат Объект.ЦБ.ВидЦБ <> Перечисления.ВидыОблигаций.Государственная 
		Или (Объект.ВидОперацииД = Справочники.ВидыОпераций.ПогашениеНКД И Объект.ЦБ.ВидЦБ = Перечисления.ВидыОблигаций.Государственная И Объект.Дата >= Константы.ДатаНачалаНачисленияНДФЛНаГособлигации.Получить());
КонецФункции

&НаСервере
Функция ВозможноНачислениеДляДепонента(ВладелецСчета)
	Если ЗначениеЗаполнено(ВладелецСчета) И НЕ ВладелецСчета.УправляющаяКомпания Тогда
		Возврат Истина;
	КонецЕсли;
	Возврат Ложь;
КонецФункции

&НаКлиенте
Процедура ОткрытиеРазделаТипРазделаПриИзменении(Элемент)
	РаботаСДиалогамиКлиент.ТипРазделаСчетаДЕПОПриИзменении(Элемент, ЭтотОбъект);
	ОбработатьВидОперации();
КонецПроцедуры

&НаКлиенте
Процедура ОтправитьУведомление(Команда)
	Если ИспользоватьРасчетНДФЛПоПрогрессивнойШкале(Объект.Дата) Тогда
		Если Модифицированность Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Документ был изменён. Перед отправкой уведомлений запишите документ.");
			Возврат;
		КонецЕсли;
		ОтправитьУведомлениеПоПрогрессивнойШкалеНаСервере();
		Возврат;
	КонецЕсли;
	
	Если Объект.УведомлениеСУДКОтправлено И Вопрос("Уведомления по данному поручение уже отправлены, вы уверены, что хотите его повторить?", РежимДиалогаВопрос.ДаНет) = КодВозвратаДиалога.Нет Тогда
		Возврат;
	КонецЕсли;
	Если Модифицированность И Вопрос("Документ был изменён и будет записан, продолжать?", РежимДиалогаВопрос.ДаНет) = КодВозвратаДиалога.Нет Тогда
		Возврат;
	КонецЕсли;
	ОтправитьУведомлениеНаСервере();
	Элементы.ФормаОтправитьУведомление.Доступность = НЕ Объект.УведомлениеСУДКОтправлено;
КонецПроцедуры

&НаСервере
Процедура ОтправитьУведомлениеНаСервере()
	Если Не Документы.Поручение.ВозможноУведомлениеСУДКПоОперации(Объект.ВидОперацииД) Тогда
		Возврат;
	КонецЕсли;
	Документ = РеквизитФормыВЗначение("Объект");
	Документ.ОтправитьУведомлениеСУДК();
	ЗначениеВРеквизитФормы(Документ, "Объект");
КонецПроцедуры

&НаКлиенте
Процедура ПровереноПриИзменении(Элемент)
	Если Объект.Проверено Тогда
		Объект.Проверено = ОбязательныеРеквизитыЗаполнены();
	КонецЕсли; 
КонецПроцедуры

&НаКлиенте
Функция ОбязательныеРеквизитыЗаполнены()
	Результат = Истина;
	
	МассивОбязательныхРеквизитов = ТаблицаРеквизитов.НайтиСтроки(Новый Структура("Обязательный", Истина));
	Для Каждого Реквизит Из МассивОбязательныхРеквизитов Цикл
		Если СтрНайти(Реквизит.Родитель, "Таблица") = 0 Тогда
			РеквизитЗаполнен = ЗначениеЗаполнено(ЭтотОбъект[Реквизит.ИмяЭлемента]);
		Иначе
			РеквизитЗаполнен = ЗначениеВТаблицеЗаполнено(Реквизит.Родитель, Реквизит.ИмяЭлемента);
		КонецЕсли;
		
		Если Не РеквизитЗаполнен Тогда
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Текст = "Не заполнен обязательный реквизит """ + Реквизит.Заголовок + """";
			Сообщение.Поле = Реквизит.ПутьКДанным;
			Сообщение.Сообщить();
			
			Результат = Ложь;
		КонецЕсли;
	КонецЦикла;
	
	Возврат Результат;
КонецФункции // ОбязательныеРеквизитыЗаполнены()

&НаСервере
Функция ЗначениеВТаблицеЗаполнено(ИмяТаблицы, ИмяПроверяемойКолонки)
	
	ТЧ = РеквизитФормыВЗначение(ИмяТаблицы);
	Если ТЧ.Колонки.Найти(ИмяПроверяемойКолонки) = Неопределено Тогда
		Возврат Ложь;
	КонецЕсли;
	
	РеквизитЗаполнен = Истина;
	Для Каждого СтрокаТЧ Из ТЧ Цикл
		Если Не ЗначениеЗаполнено(СтрокаТЧ[ИмяПроверяемойКолонки]) Тогда
			РеквизитЗаполнен = Ложь;
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	Возврат РеквизитЗаполнен;
	
КонецФункции

&НаСервереБезКонтекста
Функция ЭтоИностраннаяЦБ(ЦеннаяБумага)
	ВидЦББанкаРоссии = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ЦеннаяБумага, "ВидЦББанкаРоссии");
	Если ЗначениеЗаполнено(ВидЦББанкаРоссии) Тогда
		Возврат Справочники.ВидыЦББанкаРоссии.ЭтоВидИностраннойЦБ(ВидЦББанкаРоссии);
	Иначе
		Возврат Ложь;
	КонецЕсли;
КонецФункции

&НаКлиенте
Процедура ЦенныеБумагиВыкуп1ПриАктивизацииПоля(Элемент)
	Если Элемент.ТекущийЭлемент.Имя = "ПрогрессивнаяШкалаПлановаяДатаРасчетов" Тогда
		Элемент.ТекущийЭлемент.ТолькоПросмотр = ПроведенаПлатежнаяОперация(Объект.Ссылка, Элемент.ТекущиеДанные.СчетДепо,
			Элемент.ТекущиеДанные.РазделСчетаДепо);
	КонецЕсли;
КонецПроцедуры

&НаСервереБезКонтекста
Функция ПроведенаПлатежнаяОперация(Поручение, СчетДепо, РазделСчетаДепо)
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ПлатежнаяОперация.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.ПлатежнаяОперация КАК ПлатежнаяОперация
	|ГДЕ
	|	ПлатежнаяОперация.Основание = &Основание
	|	И ПлатежнаяОперация.СчетДепо = &СчетДепо
	|	И ПлатежнаяОперация.РазделСчетаДепо = &РазделСчетаДепо
	|	И ПлатежнаяОперация.Проведен";
	Запрос.УстановитьПараметр("Основание", Поручение);
	Запрос.УстановитьПараметр("СчетДепо", СчетДепо);
	Запрос.УстановитьПараметр("РазделСчетаДепо", РазделСчетаДепо);
	Возврат Не Запрос.Выполнить().Пустой();
КонецФункции

&НаКлиенте
Процедура ЗакрытиеРазделаДепонентОчистка(Элемент, СтандартнаяОбработка)
	ОчиститьСчетИРазделСчетаДепоСервер();
КонецПроцедуры   

&НаКлиенте
Процедура ЗакрытиеРазделаДепонентПриИзменении(Элемент)  		
	
	Если ТипЗнч(Объект.Депонент) = Тип("СправочникСсылка.Контрагенты") Тогда
		Элементы.ЗакрытиеРазделаТипРазделаРазделСчетаДепоМХ.ОграничениеТипа	= Новый ОписаниеТипов("СправочникСсылка.РазделыСчетаДепоМХ");
		Элементы.ЗакрытиеРазделаТипРазделаРазделСчетаДепоМХ.ВыбиратьТип		= Ложь;
	ИначеЕсли ТипЗнч(Объект.Депонент) = Тип("СправочникСсылка.МестаХранения") Тогда
		Элементы.ЗакрытиеРазделаТипРазделаРазделСчетаДепоМХ.ОграничениеТипа	= Новый ОписаниеТипов("Строка");
		Элементы.ЗакрытиеРазделаТипРазделаРазделСчетаДепоМХ.ВыбиратьТип		= Ложь;
	Иначе
		Элементы.ЗакрытиеРазделаТипРазделаРазделСчетаДепоМХ.ОграничениеТипа	= Новый ОписаниеТипов();
		Элементы.ЗакрытиеРазделаТипРазделаРазделСчетаДепоМХ.ВыбиратьТип		= Истина;
	КонецЕсли;
	
	ЗначениеПризнака = ТипЗнч(Объект.Депонент) = Тип("СправочникСсылка.Контрагенты");
	Элементы.ЗакрытьВМХ.Доступность	= ЗначениеПризнака;
	Элементы.ЗакрытиеРазделаРазделСчетаДепо.Видимость	= ЗначениеПризнака;
	
	Если Не ЗначениеПризнака Тогда
		Объект.ЗакрытьВМХ = Ложь;
		Объект.СчетДепоМХ = ПредопределенноеЗначение("Справочник.СчетаДепоМХ.ПустаяСсылка");
	КонецЕсли;    
	
	Элементы.ЗакрытиеРазделаСчетДепоМХ.Видимость	= ЗначениеПризнака И Объект.ЗакрытьВМХ;
	
КонецПроцедуры 

&НаКлиенте
Процедура ЗакрытиеРазделаСчетДепоНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	СтандартнаяОбработка = Ложь;
	
	Если ТипЗнч(Объект.Депонент) = Тип("СправочникСсылка.МестаХранения") Тогда
		ОтборВладелец = "МестоХранения";
	Иначе
		ОтборВладелец = "Депонент"; 	
	КонецЕсли;

	ОткрытьФормуВыбораСчетаДепо(Элементы.ЗакрытиеРазделаСчетДепо, ОтборВладелец);
КонецПроцедуры 

&НаКлиенте
Процедура ЗакрытьВМХПриИзменении(Элемент)
	
	ЗначениеПризнака = Объект.ЗакрытьВМХ;
	Элементы.ЗакрытиеРазделаСчетДепоМХ.Видимость	= ЗначениеПризнака;
	Элементы.ЗакрытиеРазделаТипРазделаРазделСчетаДепоМХ.Видимость	= ЗначениеПризнака;
	Элементы.ДатаИсполненияПоручения.ТолькоПросмотр = ЗначениеПризнака;
	Элементы.КодОтчетаНРД.ТолькоПросмотр = ЗначениеПризнака;
	Если Не ЗначениеПризнака Тогда
		Объект.СчетДепоМХ = ПредопределенноеЗначение("Справочник.СчетаДепоМХ.ПустаяСсылка");
		Объект.РазделСчетаДепоМХ = ПредопределенноеЗначение("Справочник.РазделыСчетаДепоМХ.ПустаяСсылка");
	КонецЕсли;
	
КонецПроцедуры

