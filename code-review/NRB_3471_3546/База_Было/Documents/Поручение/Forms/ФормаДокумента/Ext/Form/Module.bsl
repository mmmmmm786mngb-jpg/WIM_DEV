&НаСервере
Процедура УстановитьУсловноеОформление()
	
	ТипЭлементОтбораКомпоновкиДанных = Тип("ЭлементОтбораКомпоновкиДанных");
	
	ЭлементУО = УсловноеОформление.Элементы.Добавить();
	
	ПолеЭлемента = ЭлементУО.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных("ЦенныеБумагиВыкуп1");
	
	ЭлементОтбора = ЭлементУО.Отбор.Элементы.Добавить(ТипЭлементОтбораКомпоновкиДанных);
	ЭлементОтбора.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("Объект.ЦенныеБумагиСписываемые.ЕстьСчетТипаС");
	ЭлементОтбора.ВидСравнения = ВидСравненияКомпоновкиДанных.Равно;
	ЭлементОтбора.ПравоеЗначение = Истина;
	ЭлементОтбора.Использование = Истина;
	
	Шрифт = Новый Шрифт(WindowsШрифты.ШрифтДиалоговИМеню,,, Истина, Истина);
	ЭлементУО.Оформление.УстановитьЗначениеПараметра("Шрифт", Шрифт);
	
	ЭлементУсловногоОформления = УсловноеОформление.Элементы.Добавить();
	ГруппаОтбора = ЭлементУсловногоОформления.Отбор.Элементы.Добавить(Тип("ГруппаЭлементовОтбораКомпоновкиДанных"));
	ГруппаОтбора.ТипГруппы = ТипГруппыЭлементовОтбораКомпоновкиДанных.ГруппаИ;
	ГруппаОтбора.Использование = Истина;
	ЭлементОтбораДлинаКомментария = ГруппаОтбора.Элементы.Добавить(ТипЭлементОтбораКомпоновкиДанных);
	ЭлементОтбораДлинаКомментария.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("ДлинаКомментария");
	ЭлементОтбораДлинаКомментария.ВидСравнения = ВидСравненияКомпоновкиДанных.Больше;
	ЭлементОтбораДлинаКомментария.Использование = Истина;
	МаксимальнаяДлинаКомментарияВПорученииВыплатаДоходаВДенежнойФорме =
		ОбщегоНазначенияПовтИсп.ЗначениеГлобальногоПараметра("913.МаксимальнаяДлинаКомментарияВПорученииВыплатаДоходаВДенежнойФорме", 210);
	ЭлементОтбораДлинаКомментария.ПравоеЗначение = МаксимальнаяДлинаКомментарияВПорученииВыплатаДоходаВДенежнойФорме;
	ЭлементОтбораВидОперации = ГруппаОтбора.Элементы.Добавить(ТипЭлементОтбораКомпоновкиДанных);
	ЭлементОтбораВидОперации.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("Объект.ВидОперацииД");
	ЭлементОтбораВидОперации.ВидСравнения = ВидСравненияКомпоновкиДанных.ВСписке;
	ЭлементОтбораВидОперации.ПравоеЗначение = Документы.Поручение.СписокОперацийВыплатыДоходаВДенежнойФорме();
	ЭлементОтбораВидОперации.Использование = Истина;
	ПолеОформления = ЭлементУсловногоОформления.Поля.Элементы.Добавить();
	ПолеОформления.Использование = Истина;
	ПолеОформления.Поле          = Новый ПолеКомпоновкиДанных("Комментарий");
	ЭлементУсловногоОформления.Оформление.УстановитьЗначениеПараметра("ЦветФона", WebЦвета.ОранжевоКрасный);
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьПризнакУчетаНаСчетеТипаС()
	Если Объект.ЦенныеБумагиСписываемые.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ЦенныеБумагиСписываемые", Объект.ЦенныеБумагиСписываемые.Выгрузить());
	Запрос.УстановитьПараметр("ПустойБанковскийСчет", Справочники.БанковскиеСчета.ПустаяСсылка());
	Запрос.УстановитьПараметр("ПланируемаяДатаРасчетов", Объект.ПланируемаяДатаРасчетов);
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ЦенныеБумагиСписываемые.СчетДепо КАК СчетДепо,
	|	ЦенныеБумагиСписываемые.ПлановаяДатаРасчетов КАК ПлановаяДатаРасчетов
	|ПОМЕСТИТЬ втЦенныеБумагиСписываемые
	|ИЗ
	|	&ЦенныеБумагиСписываемые КАК ЦенныеБумагиСписываемые
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	втЦенныеБумагиСписываемые.СчетДепо КАК СчетДепо,
	|	втЦенныеБумагиСписываемые.ПлановаяДатаРасчетов КАК ПлановаяДатаРасчетов,
	|	ВЫБОР
	|		КОГДА втЦенныеБумагиСписываемые.ПлановаяДатаРасчетов = ДАТАВРЕМЯ(1, 1, 1)
	|			ТОГДА &ПланируемаяДатаРасчетов
	|		ИНАЧЕ втЦенныеБумагиСписываемые.ПлановаяДатаРасчетов
	|	КОНЕЦ КАК ПлановаяДатаРасчетовДляСреза,
	|	СчетаДепо.Владелец КАК Владелец
	|ПОМЕСТИТЬ втСчетаДепоСВладельцами
	|ИЗ
	|	втЦенныеБумагиСписываемые КАК втЦенныеБумагиСписываемые
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.СчетаДепо КАК СчетаДепо
	|		ПО втЦенныеБумагиСписываемые.СчетДепо = СчетаДепо.Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	втСчетаДепоСВладельцами.СчетДепо КАК СчетДепо,
	|	втСчетаДепоСВладельцами.Владелец КАК Владелец,
	|	втСчетаДепоСВладельцами.ПлановаяДатаРасчетов КАК ПлановаяДатаРасчетов,
	|	МАКСИМУМ(ЕСТЬNULL(КлиентыСУчетомНаСчетахТипаC.Период, ДАТАВРЕМЯ(1, 1, 1))) КАК Период
	|ПОМЕСТИТЬ втПериодыИзмененияУчетаНаСчетахТипаС
	|ИЗ
	|	втСчетаДепоСВладельцами КАК втСчетаДепоСВладельцами
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.КлиентыСУчетомНаСчетахТипаC КАК КлиентыСУчетомНаСчетахТипаC
	|		ПО втСчетаДепоСВладельцами.Владелец = КлиентыСУчетомНаСчетахТипаC.Клиент
	|			И (НАЧАЛОПЕРИОДА(втСчетаДепоСВладельцами.ПлановаяДатаРасчетовДляСреза, ДЕНЬ) >= КлиентыСУчетомНаСчетахТипаC.Период)
	|
	|СГРУППИРОВАТЬ ПО
	|	втСчетаДепоСВладельцами.СчетДепо,
	|	втСчетаДепоСВладельцами.ПлановаяДатаРасчетов,
	|	втСчетаДепоСВладельцами.Владелец
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	втСчетаДепоСВладельцами.Владелец КАК Владелец,
	|	втСчетаДепоСВладельцами.ПлановаяДатаРасчетов КАК ПлановаяДатаРасчетов,
	|	МАКСИМУМ(ЕСТЬNULL(СчетаДляВыплатыКД.Период, ДАТАВРЕМЯ(1, 1, 1))) КАК Период
	|ПОМЕСТИТЬ втПериодыИзмененияСчетовДляВыплатыКД
	|ИЗ
	|	втСчетаДепоСВладельцами КАК втСчетаДепоСВладельцами
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СчетаДляВыплатыКД КАК СчетаДляВыплатыКД
	|		ПО втСчетаДепоСВладельцами.Владелец = СчетаДляВыплатыКД.Клиент
	|			И (НАЧАЛОПЕРИОДА(втСчетаДепоСВладельцами.ПлановаяДатаРасчетовДляСреза, ДЕНЬ) >= СчетаДляВыплатыКД.Период)
	|СГРУППИРОВАТЬ ПО
	|	втСчетаДепоСВладельцами.ПлановаяДатаРасчетов,
	|	втСчетаДепоСВладельцами.Владелец
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	втПериодыИзмененияУчетаНаСчетахТипаС.СчетДепо КАК СчетДепо,
	|	втПериодыИзмененияУчетаНаСчетахТипаС.ПлановаяДатаРасчетов КАК ПлановаяДатаРасчетов,
	|	ЕСТЬNULL(КлиентыСУчетомНаСчетахТипаC.ФлагАктивности, ЛОЖЬ)
	|		И ЕСТЬNULL(СчетаДляВыплатыКД.Счет, &ПустойБанковскийСчет) <> &ПустойБанковскийСчет КАК ЕстьСчетТипаС
	|ИЗ
	|	втПериодыИзмененияУчетаНаСчетахТипаС КАК втПериодыИзмененияУчетаНаСчетахТипаС
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.КлиентыСУчетомНаСчетахТипаC КАК КлиентыСУчетомНаСчетахТипаC
	|		ПО втПериодыИзмененияУчетаНаСчетахТипаС.Владелец = КлиентыСУчетомНаСчетахТипаC.Клиент
	|			И втПериодыИзмененияУчетаНаСчетахТипаС.Период = КлиентыСУчетомНаСчетахТипаC.Период
	|		ЛЕВОЕ СОЕДИНЕНИЕ втПериодыИзмененияСчетовДляВыплатыКД
	|		ПО втПериодыИзмененияУчетаНаСчетахТипаС.Владелец = втПериодыИзмененияСчетовДляВыплатыКД.Владелец
	|			И втПериодыИзмененияУчетаНаСчетахТипаС.ПлановаяДатаРасчетов = втПериодыИзмененияСчетовДляВыплатыКД.ПлановаяДатаРасчетов
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СчетаДляВыплатыКД КАК СчетаДляВыплатыКД
	|			ПО втПериодыИзмененияСчетовДляВыплатыКД.Владелец = СчетаДляВыплатыКД.Клиент
	|			И втПериодыИзмененияСчетовДляВыплатыКД.Период = СчетаДляВыплатыКД.Период
	|";
	Выборка = Запрос.Выполнить().Выбрать();
	Отбор = Новый Структура;
	Пока Выборка.Следующий() Цикл
		Отбор.Вставить("СчетДепо", Выборка.СчетДепо);
		Отбор.Вставить("ПлановаяДатаРасчетов", Выборка.ПлановаяДатаРасчетов);
		СтрокиПоСчетуДепо = Объект.ЦенныеБумагиСписываемые.НайтиСтроки(Отбор);
		Для Каждого СтрокаДокумента Из СтрокиПоСчетуДепо Цикл
			СтрокаДокумента.ЕстьСчетТипаС = Выборка.ЕстьСчетТипаС;
		КонецЦикла;
	КонецЦикла;
КонецПроцедуры

&НаКлиенте
Процедура ПрогрессивнаяШкалаПлановаяДатаРасчетовПриИзменении(Элемент)
	ТекДанные = Элементы.ЦенныеБумагиВыкуп1.ТекущиеДанные;
	Если Не ЗначениеЗаполнено(ТекДанные.СчетДепо) Тогда
		ТекДанные.ЕстьСчетТипаС = Ложь;
	Иначе
		ПлановаяДатаРасчетов = ?(ЗначениеЗаполнено(ТекДанные.ПлановаяДатаРасчетов), ТекДанные.ПлановаяДатаРасчетов, Объект.ПланируемаяДатаРасчетов);
		Если ЗначениеЗаполнено(ПлановаяДатаРасчетов) Тогда
			ТекДанные.ЕстьСчетТипаС = УВладельцаСчетаДепоЕстьСчетТипаС(ТекДанные.СчетДепо, ПлановаяДатаРасчетов);
		Иначе
			ТекДанные.ЕстьСчетТипаС = Ложь;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

&НаСервереБезКонтекста
Функция УВладельцаСчетаДепоЕстьСчетТипаС(СчетДепо, ПлановаяДатаРасчетов)
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ПлановаяДатаРасчетов", ПлановаяДатаРасчетов);
	Запрос.УстановитьПараметр("СчетДепо", СчетДепо);
	Запрос.УстановитьПараметр("ПустойБанковскийСчет", Справочники.БанковскиеСчета.ПустаяСсылка());
	Запрос.Текст =
	"ВЫБРАТЬ
	|	СчетаДепо.Владелец КАК Клиент
	|ПОМЕСТИТЬ ВТКлиенты
	|ИЗ
	|	Справочник.СчетаДепо КАК СчетаДепо
	|ГДЕ
	|	СчетаДепо.Ссылка = &СчетДепо
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ ПЕРВЫЕ 1
	|	ЕСТЬNULL(КлиентыСУчетомНаСчетахТипаCСрезПоследних.ФлагАктивности, ЛОЖЬ)
	|		И ЕСТЬNULL(СчетаДляВыплатыКДСрезПоследних.Счет, &ПустойБанковскийСчет) <> &ПустойБанковскийСчет КАК ЕстьСчетТипаС
	|ИЗ
	|	РегистрСведений.КлиентыСУчетомНаСчетахТипаC.СрезПоследних(
	|			&ПлановаяДатаРасчетов,
	|			Клиент В
	|				(ВЫБРАТЬ
	|					ВТКлиенты.Клиент КАК Клиент
	|				ИЗ
	|					ВТКлиенты)) КАК КлиентыСУчетомНаСчетахТипаCСрезПоследних
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СчетаДляВыплатыКД.СрезПоследних(
	|				&ПлановаяДатаРасчетов,
	|				Клиент В
	|					(ВЫБРАТЬ
	|						ВТКлиенты.Клиент КАК Клиент
	|					ИЗ
	|						ВТКлиенты)) КАК СчетаДляВыплатыКДСрезПоследних
	|		ПО КлиентыСУчетомНаСчетахТипаCСрезПоследних.Клиент = СчетаДляВыплатыКДСрезПоследних.Клиент";
	Результат = Запрос.Выполнить();
	Если Результат.Пустой() Тогда
		ЕстьСчетТипаС = Ложь;
	Иначе
		Выборка = Результат.Выбрать();
		Выборка.Следующий();
		ЕстьСчетТипаС = Выборка.ЕстьСчетТипаС;
	КонецЕсли;
	
	Возврат ЕстьСчетТипаС;
КонецФункции

&НаКлиенте
Процедура ОткрытиеРазделаТипРазделаРазделСчетаДепоМХНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
