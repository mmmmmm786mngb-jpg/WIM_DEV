&НаКлиенте
Процедура ОтображатьНалоги(Команда)
	ОтображатьНалогиПоВыплате = НЕ ОтображатьНалогиПоВыплате;
	УстановитьВидимостьГруппыНалогиПоВыплате();
КонецПроцедуры

&НаСервере
Процедура УстановитьВидимостьГруппыНалогиПоВыплате()
	Элементы.ЦенныеБумагиВыкуп1ОтображатьНалоги.Пометка = ОтображатьНалогиПоВыплате;
	Элементы.ПогашениеГруппаНалог.Видимость				= ОтображатьНалогиПоВыплате;
	Элементы.ПогашениеГруппа2Налог.Видимость			= ОтображатьНалогиПоВыплате;
	
	КодДохода = Документы.НачисленныйНалог.КодДоходаПоВидуОперации(Объект.ВидОперацииД);
	РазрешенНалог1530 = КодДохода = Справочники.ДоходыНДФЛ.Код1530
		И ОбщегоНазначенияПовтИсп.ЗначениеКонстанты("РасчетНалогаПоКупонамВСистеме");
	Элементы.ЦенныеБумагиВыкуп1БанковскийСчетТипНазначения.Видимость = РазрешенНалог1530;
	
КонецПроцедуры

&НаСервере
Функция ЭтоВидОперацииПоВыплатеСНалогооблажением()
	
	МассивОперацийСНалогооблажением = Новый Массив;
	МассивОперацийСНалогооблажением.Добавить(Справочники.ВидыОпераций.НачислениеДивидендов);
	МассивОперацийСНалогооблажением.Добавить(Справочники.ВидыОпераций.НачислениеДоходаПрочие);
	МассивОперацийСНалогооблажением.Добавить(Справочники.ВидыОпераций.ПогашениеНКД);
	МассивОперацийСНалогооблажением.Добавить(Справочники.ВидыОпераций.ПогашениеЦБПолное);
	МассивОперацийСНалогооблажением.Добавить(Справочники.ВидыОпераций.Выкуп);
		                                               
	Возврат НЕ МассивОперацийСНалогооблажением.Найти(Объект.ВидОперацииД) = Неопределено;
	
КонецФункции

&НаСервереБезКонтекста
Функция ЭтоВидКДСобранияНаСервере(ВидКД)
	Возврат Документы.КорпоративноеДействие_Новый.ЭтоВидКДСобрания(ВидКД);
КонецФункции

