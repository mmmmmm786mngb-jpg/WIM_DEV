&НаСервере
Процедура ОчиститьСчетИРазделСчетаДепоСервер()
	мОбъект = РеквизитФормыВЗначение("Объект");
	мОбъект.СчетДепо = Справочники.СчетаДепо.ПустаяСсылка();
	мОбъект.РазделСчетаДепо = Справочники.РазделыСчетаДепо.ПустаяСсылка();
	Если Элементы.Страницы.ТекущаяСтраница.Имя = "ОткрытиеРазделаСчетаДепо" Тогда
		мОбъект.РазделСчетаДепоМХ = Неопределено;
	КонецЕсли;
	ЗначениеВРеквизитФормы(мОбъект, "Объект");
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьФормуВыбораСчетаДепо(ВладелецФормы, ОтборВладелец = "")
	ИмяФормыВыбора = "СчетаДепо";
	ПараметрыОтбора = Новый Структура;
	Если ОтборВладелец = "Депонент" ИЛИ ЭтоИнвентарныйКлассОпераций(Объект.ВидОперацииД) Тогда
		ПараметрыОтбора.Вставить("Владелец", Объект.Депонент);
		
	ИначеЕсли ОтборВладелец = "МестоХранения" Тогда
		ПараметрыОтбора.Вставить("Владелец", Объект.Депонент);
		ИмяФормыВыбора = "СчетаДепоМХ";
	Иначе
		ПараметрыОтбора.Вставить("Владелец", Объект.Инициатор);
		Если ТипЗнч(Объект.Инициатор) = Тип("СправочникСсылка.МестаХранения") Тогда
			ИмяФормыВыбора = "СчетаДепоМХ";
		КонецЕсли;
	КонецЕсли;
	
	Если ОтборВладелец = "Депонент"	И ТипЗнч(Объект.Депонент) = Тип("СправочникСсылка.Организации") Тогда
		ИмяФормыВыбора = "СчетаДепоМХ";
		ПараметрыОтбора.Удалить("Владелец");
	КонецЕсли;
	
	// Установить требуемый тип счета депо
	ВладелецФормы.ОграничениеТипа = Новый ОписаниеТипов("СправочникСсылка." + ИмяФормыВыбора);
	
	мПараметры = Новый Структура("Отбор", ПараметрыОтбора);
	ОткрытьФорму("Справочник." + ИмяФормыВыбора + ".ФормаВыбора", мПараметры, ВладелецФормы);
КонецПроцедуры

&НаСервере
Процедура УстановитьОсновнойСчетДепоСервер()
	мОбъект = РеквизитФормыВЗначение("Объект");
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	СчетаДепо.Ссылка КАК СчетаДепоОсновной
	|ИЗ
	|	Справочник.СчетаДепо КАК СчетаДепо
	|ГДЕ
	|	СчетаДепо.Владелец = &Владелец
	|	И СчетаДепо.Код = &Код");
	Запрос.УстановитьПараметр("Владелец",	мОбъект.Депонент);
	Запрос.УстановитьПараметр("Код",		мОбъект.Депонент.Код);
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		мОбъект.СчетДепо = Выборка.СчетаДепоОсновной;
	КонецЕсли;
	ЗначениеВРеквизитФормы(мОбъект, "Объект");
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьНачислениеДоходовЦБНаСервере()
	Если НЕ ЗначениеЗаполнено(Объект.ДатаФиксации) Тогда
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "Для заполнения необходимо указать дату фиксации!";
		Сообщение.Сообщить();
		Возврат;
	КонецЕсли;
	
	ДокументОбъект = РеквизитФормыВЗначение("Объект");
	
	Если ДокументОбъект.ЭтоНовый() Тогда
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "Для заполнения необходимо сначала записать документ!";
		Сообщение.Сообщить();
		Возврат;
	КонецЕсли;
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	ОстаткиЦБОстатки.СчетДепо КАК СчетДепо,
	|	ОстаткиЦБОстатки.РазделСчетаДепо КАК РазделСчетаДепо,
	|	ОстаткиЦБОстатки.ЦБ КАК ЦеннаяБумага,
	|	ОстаткиЦБОстатки.КоличествоОстаток КАК КоличествоБазовойЦБ,
	|	ОстаткиЦБОстатки.КоличествоОстаток * &ВыплатаНа1ЦБ КАК Количество,
	|	ОстаткиЦБОстатки.СчетДепоМХ,
	|	ОстаткиЦБОстатки.РазделСчетаДепоМХ
	|ИЗ
	|	РегистрНакопления.ОстаткиЦБ.Остатки(&Период, ЦБ = &ЦеннаяБумага И &ОтборПоСчетуДепоМХ) КАК ОстаткиЦБОстатки
	|УПОРЯДОЧИТЬ ПО
	|	ОстаткиЦБОстатки.СчетДепо.Владелец.Наименование,
	|	ОстаткиЦБОстатки.СчетДепо,
	|	ОстаткиЦБОстатки.РазделСчетаДепо
	|");
	Запрос.УстановитьПараметр("Период",			Новый Граница(КонецДня(Объект.ДатаФиксации), ВидГраницы.Включая));
	Запрос.УстановитьПараметр("ЦеннаяБумага",	Объект.ЦББазовая);
	Запрос.УстановитьПараметр("ВыплатаНа1ЦБ",	Объект.ВыплатаНа1ЦБ);
	
	Если Элементы.СчетДепоМХДокумента.Видимость И ЗначениеЗаполнено(Объект.СчетДепоМХДокумента) Тогда
		СтрокаУсловия = "СчетДепоМХ = &СчетДепоМХ";
		Запрос.УстановитьПараметр("СчетДепоМХ", Объект.СчетДепоМХДокумента);
	Иначе
		СтрокаУсловия = "ИСТИНА";
	КонецЕсли;
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "&ОтборПоСчетуДепоМХ", СтрокаУсловия);
	
	Результат = Запрос.Выполнить();
	Если Результат.Пустой() Тогда
		Возврат;
	КонецЕсли;
	
	Объект.ЦенныеБумагиСписываемые.Загрузить(Результат.Выгрузить());
КонецПроцедуры

&НаКлиенте
Процедура ИзменитьПризнакИсключенияИзОбмена(Команда)
	Объект.ИсключитьИзОбменаДанными = НЕ Объект.ИсключитьИзОбменаДанными;
	ОформитьЭлементКомандыУправленияПризнакомОбмена();
КонецПроцедуры

&НаКлиенте
Процедура ОформитьЭлементКомандыУправленияПризнакомОбмена()
	Элементы.КомандаУправленияПризнакомОбмена.Пометка = Объект.ИсключитьИзОбменаДанными;
КонецПроцедуры

&НаКлиенте
Процедура ОтчетПоОстаткамБумаг(Команда)
	СписокРегистров = Новый СписокЗначений;
	СписокРегистров.Добавить("ОстаткиЦБ");
	СписокРегистров.Добавить("ОстаткиЦБДепозитарийМХ");
	СписокРегистров.Добавить("ОстаткиЦБМестоРасчетов");
	ОповещениеПослеВыбораРегистра = Новый ОписаниеОповещения("ОтчетПоОстаткамБумагЗавершение", ЭтотОбъект);
	СписокРегистров.ПоказатьВыборЭлемента(ОповещениеПослеВыбораРегистра);
КонецПроцедуры

&НаКлиенте
Процедура ОтчетПоОстаткамБумагЗавершение(ВыбранныйЭлемент, ДополнительныеПараметры) Экспорт
	
	Если ВыбранныйЭлемент = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ДатаОтчета = ?(ЗначениеЗаполнено(Объект.ДатаИсполненияПоручения), Объект.ДатаИсполненияПоручения, Объект.Дата);
	
	Если ЭтоНеторговоеПоручениеСоСпискомЦБ() Тогда
		ЦенныеБумагиДляОтчета = Новый СписокЗначений;
		Для Каждого Строка Из Объект.ЦенныеБумагиСписываемые Цикл
			ЦенныеБумагиДляОтчета.Добавить(Строка.ЦеннаяБумага);
		КонецЦикла;
	Иначе
		ЦенныеБумагиДляОтчета = Объект.ЦБ;
	КонецЕсли;
	
	СтруктураОтбора = Новый Структура();
	СтруктураОтбора.Вставить("ЦБ", ЦенныеБумагиДляОтчета);
	СтруктураОтбора.Вставить("СчетДепо", Объект.СчетДепо);
	СтруктураОтбора.Вставить("РазделСчетаДепо", Объект.РазделСчетаДепо);
	СтруктураОтбора.Вставить("СчетДепоМХ", Объект.СчетДепоМХ);
	СтруктураОтбора.Вставить("РазделСчетаДепоМХ", Объект.РазделСчетаДепоМХ);
	
	ИмяОтчета = "ОстаткиИОбороты";
	ПараметрыОткрытия = ПараметрыОткрытияОтчета(ИмяОтчета, СтруктураОтбора);
	ПараметрыОткрытия.Вставить("Раздел", ВыбранныйЭлемент.Значение);
	ПараметрыОткрытия.Вставить("ДатаНачала", ДатаОтчета);
	ПараметрыОткрытия.Вставить("ДатаОкончания", ДатаОтчета);
	ПараметрыОткрытия.Вставить("ФормированиеИзПоручения", Истина);
	
	ОткрытьФорму("Отчет." + ИмяОтчета + ".Форма.ФормаОтчетаПрограммная", ПараметрыОткрытия);
КонецПроцедуры

&НаСервереБезКонтекста
Функция ПараметрыОткрытияОтчета(ИмяОтчета, СтруктураОтбора)
	ОтчетОбъект = Отчеты[ИмяОтчета].Создать();
	
	КомпоновщикНастроек = ОтчетОбъект.КомпоновщикНастроек;
	Для Каждого Отбор Из СтруктураОтбора Цикл
		ВидСравненияКомпоновки = ?(ТипЗнч(Отбор.Значение) = Тип("СписокЗначений"),
			ВидСравненияКомпоновкиДанных.ВСписке,
			ВидСравненияКомпоновкиДанных.Равно);
		УстановитьЭлементПользовательскогоОтбораСКД(КомпоновщикНастроек, ВидСравненияКомпоновки, Отбор.Ключ, Отбор.Значение);
	КонецЦикла;
	ПараметрыОткрытия = Новый Структура();
	ПараметрыОткрытия.Вставить("СформироватьПриОткрытии", Истина);
	ПараметрыОткрытия.Вставить("Вариант", КомпоновщикНастроек.Настройки);
	ПараметрыОткрытия.Вставить("ПользовательскиеНастройки", КомпоновщикНастроек.ПользовательскиеНастройки);
	
	Возврат ПараметрыОткрытия;
КонецФункции

&НаСервереБезКонтекста
Процедура УстановитьЭлементПользовательскогоОтбораСКД(КомпоновщикНастроек, ВидСравнения, ИмяПоля, Значение)
	ЭлементОтбораПользовательский = КомпоновщикНастроек.Настройки.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ЭлементОтбораПользовательский.ВидСравнения = ВидСравнения;
	ЭлементОтбораПользовательский.ЛевоеЗначение = Новый ПолеКомпоновкиДанных(ИмяПоля);
	ЭлементОтбораПользовательский.ПравоеЗначение = Значение;
	ЭлементОтбораПользовательский.Использование = Истина;
КонецПроцедуры

&НаСервере
Процедура УстановитьЗалогодержателя(РазделСчетаДепо)
	Если РазделСчетаДепо.ТипРазделаСчетаДЕПО = Перечисления.ТипыРазделовСчетовДЕПО.БлокированоВЗалоге
		И НЕ ЗначениеЗаполнено(Объект.Залогодержатель) Тогда
		Объект.Залогодержатель = РазделСчетаДепо.Залогодержатель;
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура ОграничитьТипЭлементовДепонентНаСервере()
	
	ДепонентыСТипомКонтрагент = Новый Массив;
	ДепонентыСТипомКонтрагент.Добавить("ИнвентарныеОперацииДепонент");
	ДепонентыСТипомКонтрагент.Добавить("ИзменениеАнкетныхДанныхДепонент");
	ДепонентыСТипомКонтрагент.Добавить("Депонент");
	Для Каждого ИмяЭлемента Из ДепонентыСТипомКонтрагент Цикл
		Элементы[ИмяЭлемента].ОграничениеТипа = Новый ОписаниеТипов("СправочникСсылка.Контрагенты");
		Элементы[ИмяЭлемента].ВыбиратьТип = Ложь;
	КонецЦикла;
	
	РазрешенныеТипы = Новый Массив;
	РазрешенныеТипы.Добавить(Тип("СправочникСсылка.Контрагенты"));
	РазрешенныеТипы.Добавить(Тип("СправочникСсылка.МестаХранения"));
	Элементы.ОткрытиеРазделаДепонент.ОграничениеТипа = Новый ОписаниеТипов(РазрешенныеТипы);
	Элементы.ОткрытиеСчетаДепонент.ОграничениеТипа = Новый ОписаниеТипов(РазрешенныеТипы);
	
КонецПроцедуры

&НаСервере
Процедура ОграничитьТипЭлементовРазделСчетаДепоМХНаСервере()
	
	ТекущаяСтраница = Элементы.Страницы.ТекущаяСтраница.Имя;
	
	Если ТекущаяСтраница = "ОткрытиеРазделаСчетаДепо" Тогда
		Если ТипЗнч(Объект.Депонент) = Тип("СправочникСсылка.Контрагенты") Тогда
			Элементы.ОткрытиеРазделаТипРазделаРазделСчетаДепоМХ.ОграничениеТипа	= Новый ОписаниеТипов("СправочникСсылка.РазделыСчетаДепоМХ");
			Элементы.ОткрытиеРазделаТипРазделаРазделСчетаДепоМХ.ВыбиратьТип		= Ложь;
		ИначеЕсли ТипЗнч(Объект.Депонент) = Тип("СправочникСсылка.МестаХранения") Тогда
			Элементы.ОткрытиеРазделаТипРазделаРазделСчетаДепоМХ.ОграничениеТипа	= Новый ОписаниеТипов("Строка");
			Элементы.ОткрытиеРазделаТипРазделаРазделСчетаДепоМХ.ВыбиратьТип		= Ложь;
		Иначе
			Элементы.ОткрытиеРазделаТипРазделаРазделСчетаДепоМХ.ОграничениеТипа	= Новый ОписаниеТипов();
			Элементы.ОткрытиеРазделаТипРазделаРазделСчетаДепоМХ.ВыбиратьТип		= Истина;
		КонецЕсли;
	ИначеЕсли ТекущаяСтраница = "ОперацияЦБ" Тогда
		Элементы.РазделСчетаДепоМХ.ОграничениеТипа = Новый ОписаниеТипов("СправочникСсылка.РазделыСчетаДепоМХ");
		Элементы.РазделСчетаДепоМХ.ВыбиратьТип = Ложь;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура УстановитьСвязиПараметровВыбораСчетаИРазделаДепоМХ(ЭтоОткрытиеРазделаСчетаДепо)
	
	Если ЭтоОткрытиеРазделаСчетаДепо Тогда
		ПустойМассив = Новый ФиксированныйМассив(Новый Массив);
		Если Элементы.ОткрытиеРазделаСчетДепоМХ.СвязиПараметровВыбора.Количество() > 0 Тогда
			Элементы.ОткрытиеРазделаСчетДепоМХ.СвязиПараметровВыбора = ПустойМассив;
		КонецЕсли;
		
		Если Элементы.РазделСчетаДепоМХ.СвязиПараметровВыбора.Количество() > 0 Тогда
			Элементы.РазделСчетаДепоМХ.СвязиПараметровВыбора = ПустойМассив;
		КонецЕсли;
	Иначе
		Если Элементы.РазделСчетаДепоМХ.СвязиПараметровВыбора.Количество() = 0 Тогда
			СвязьПараметраВыбора = Новый Массив;
			СвязьПараметраВыбора.Добавить(Новый СвязьПараметраВыбора("Отбор.Владелец", "Объект.СчетДепоМХ"));
			Элементы.РазделСчетаДепоМХ.СвязиПараметровВыбора = Новый ФиксированныйМассив(СвязьПараметраВыбора);
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура УстановитьВидимостьПолейРазделаСчетДепоМХ(ЗначениеПризнака)
	
	Элементы.ОткрытиеРазделаСчетДепоМХ.Видимость	= ЗначениеПризнака;
	Элементы.НомерРазделаСчетаДепоМХ.Видимость		= ЗначениеПризнака;
	Если Не ЗначениеПризнака Тогда
		Объект.СчетДепоМХ = ПредопределенноеЗначение("Справочник.СчетаДепоМХ.ПустаяСсылка");
		Объект.НомерРазделаСчетаДепоМХ = "";
	КонецЕсли;
	
КонецПроцедуры

Процедура УстановитьВидимостьДоступностьСубклиента()
	
	Элементы.ГруппаСубклиент.Доступность = ТипЗнч(Объект.Депонент) = Тип("СправочникСсылка.Контрагенты") //И Объект.Депонент.Субброкер
	И ТипЗнч(Объект.СчетДепо) = Тип("СправочникСсылка.СчетаДепо") 
	И Перечисления.ТипыСчетовДепо.НоминальныхДержателей().Найти(Объект.СчетДепо.ТипСчетаДепо) <> Неопределено;
	
	Элементы.Субклиент.Доступность = Объект.РазделСубклиента;
	Элементы.Субклиент.ОтметкаНезаполненного = Объект.РазделСубклиента;
	Элементы.Субклиент.АвтоОтметкаНезаполненного = Объект.РазделСубклиента;
	
КонецПроцедуры

&НаСервере
Процедура УстановитьВидимостьПризнакаНачислитьКомиссиюЗаОтменуНаСервере()
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	КОЛИЧЕСТВО(Поручение.Ссылка) КАК КоличествоПорученийСДепонентомИнициатором
	|ИЗ
	|	Документ.Поручение КАК Поручение
	|ГДЕ
	|	Поручение.Ссылка = &ОтменяемоеПоручение
	|	И Поручение.СчетДепо.Владелец = &Инициатор");
	Запрос.УстановитьПараметр("ОтменяемоеПоручение", Объект.ОтменяемоеПоручение);
	Запрос.УстановитьПараметр("Инициатор", Объект.Инициатор);
	Выборка = Запрос.Выполнить().Выбрать();
	Выборка.Следующий();
	Если Выборка.КоличествоПорученийСДепонентомИнициатором = 1 Тогда
		Элементы.НачислитьКомиссиюЗаОтмену.Видимость = Истина;
	Иначе
		Элементы.НачислитьКомиссиюЗаОтмену.Видимость = Ложь;
		Объект.НачислитьКомиссиюЗаОтмену = Ложь;
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура ПроверитьКвалифицированногоИнвестора()
	
	Если Не ЗначениеЗаполнено(Объект.Ссылка)
		Или Объект.ВидОперацииД <> Справочники.ВидыОпераций.Депонирование
		Или Объект.ЦенныеБумагиСписываемые.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	ДанныеДепонента = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Объект.Депонент, "ЮридическиеФизическиеЛица, Код");
	ЮрФизЛицо = ДанныеДепонента.ЮридическиеФизическиеЛица;
	НомерДоговораДепонента = СокрЛП(ДанныеДепонента.Код);
	ЭтоКвалифицированныйИнвестор = РегистрыСведений.РеестрКвалифицированныхИнвесторовПоЗакону.ЕстьКИПОЗакону(ЮрФизЛицо, ТекущаяДатаСеанса());
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ЦенныеБумаги.ВидЦББанкаРоссии.ВидИнструмента КАК ВидИнструмента,
	|	ЦенныеБумаги.ДляКвалифицированныхИнвесторов КАК ДляКвалифицированныхИнвесторов,
	|	ЦенныеБумаги.Представление КАК ЦБ,
	|	ЦенныеБумаги.ISIN КАК ISIN
	|ИЗ
	|	Справочник.ЦенныеБумаги КАК ЦенныеБумаги
	|ГДЕ
	|	ЦенныеБумаги.Ссылка В(&ЦБДляПроверки)
	|	И ЦенныеБумаги.ДляКвалифицированныхИнвесторов";
	
	Запрос.УстановитьПараметр("ЦБДляПроверки", Объект.ЦенныеБумагиСписываемые.Выгрузить(, "ЦеннаяБумага").ВыгрузитьКолонку("ЦеннаяБумага"));
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() Тогда
		Если ЭтоКвалифицированныйИнвестор Тогда
			ТекстСообщения = СтрШаблон("Депонент %1 является КИ и ценные бумаги поручения не предназначены для квалифицированных инвесторов",
			НомерДоговораДепонента);
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
		КонецЕсли;
		Возврат;
	КонецЕсли;
	
	ВыборкаЦБ = РезультатЗапроса.Выбрать();
	Если ЭтоКвалифицированныйИнвестор Тогда
		СписокЦБ = "";
		Пока ВыборкаЦБ.Следующий() Цикл
			СписокЦБ = СписокЦБ + ?(ЗначениеЗаполнено(СписокЦБ), ", ", "") + ВыборкаЦБ.ЦБ + " (" + ВыборкаЦБ.ISIN + ")";
		КонецЦикла;
		ТекстСообщения = СтрШаблон("Депонент %1 является КИ и ценные бумаги %2 предназначены для квалифицированных инвесторов",
		НомерДоговораДепонента, СписокЦБ);
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
	Иначе
		Пока ВыборкаЦБ.Следующий() Цикл
			ЕстьКвалификацияИнвестора = РегистрыСведений.РеестрКвалифицированныхИнвесторовРОФР.ЕстьКвалификацияИнвестора(
			ЮрФизЛицо, ВыборкаЦБ.ВидИнструмента, ТекущаяДатаСеанса());
			Если ЕстьКвалификацияИнвестора Тогда
				ТекстСообщения = СтрШаблон("Депонент %1 является КИ по %2 и ЦБ %3 (%4) предназначена для квалифицированных инвесторов",
				НомерДоговораДепонента, ВыборкаЦБ.ВидИнструмента, ВыборкаЦБ.ЦБ, ВыборкаЦБ.ISIN);
			Иначе
				ТекстСообщения = СтрШаблон("!!! Депонент %1 не является КИ по %2 и ЦБ %3 (%4) предназначена для квалифицированных инвесторов",
				НомерДоговораДепонента, ВыборкаЦБ.ВидИнструмента, ВыборкаЦБ.ЦБ, ВыборкаЦБ.ISIN);
			КонецЕсли;
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
		КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры

Процедура УстановитьВидимостьПоТипуЦБ()
	Если ЭтоИностраннаяЦБ(Объект.ЦБ) Тогда
		Элементы.СтатусПоГлаве4.Видимость = Истина;
		Элементы.ПогашениеСуммаКВыплатеПоИПД.Видимость = Истина;
		Элементы.ПогашениеСуммаКВыплате.Видимость = Ложь;
		Элементы.ПогашениеСуммаКомиссий.Видимость = Истина;
	Иначе
		Элементы.СтатусПоГлаве4.Видимость = Ложь;
		Элементы.ПогашениеСуммаКВыплатеПоИПД.Видимость = Ложь;
		Элементы.ПогашениеСуммаКВыплате.Видимость = Истина;
		Элементы.ПогашениеСуммаКомиссий.Видимость = Ложь;
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура УстановитьВидимостьВидаИнициатора()
	
	УстановитьВидимость = Ложь;
	
	Если ТипЗнч(Объект.Инициатор) = Тип("СправочникСсылка.Организации") Тогда
		УстановитьВидимость = Истина;
	КонецЕсли;
	
	Элементы.ГруппаВидИнициатора.Видимость = УстановитьВидимость;
	
КонецПроцедуры

&НаСервере
Процедура УстановитьВидимостьРеквизитовВидаДоговораОснованияДКУ()
	
	ВидимостьРеквизитовВидаДоговораОснованияДКУ =
		(ТипЗнч(Объект.ДокументОснование) = Тип("СправочникСсылка.КодыВидаДоговоровОснованийОперацийДКУ"));
	Элементы.ДоговорОснованияДКУНомер.Видимость = ВидимостьРеквизитовВидаДоговораОснованияДКУ;
	Элементы.ДоговорОснованияДКУДата.Видимость = ВидимостьРеквизитовВидаДоговораОснованияДКУ;
	
КонецПроцедуры

&НаСервере
Процедура УстановитьВидимостьИногоНаименованияОснованияОперацииДКУ()
	
	ЭтоИноеНаименование = (Объект.ОснованиеОперацииДКУ = Справочники.КодыОснованияОперацийДКУ.TR39);
	Элементы.ОснованиеОперацииДКУИноеНаименование.Видимость = ЭтоИноеНаименование;
	Если Не ЭтоИноеНаименование Тогда
		Объект.ОснованиеОперацииДКУИноеНаименование = "";
	КонецЕсли;
	
КонецПроцедуры
	
&НаСервере
Процедура УстановитьВидимостьРеквизитовДляВидовПоручений352Паи362Паи()
	
	ВидПоручения352ПаиИли362Паи = (Объект.ВидПоручения = Справочники.ВидыИнвентарныхПоручений.П35_2
		Или Объект.ВидПоручения = Справочники.ВидыИнвентарныхПоручений.П36_2);
	
	Элементы.ПаиБанковскиеРеквизиты.Видимость = ВидПоручения352ПаиИли362Паи;
	
КонецПроцедуры

&НаСервере
Процедура УстановитьВидимостьТабличнойЧастиЦБДляСводныхПоручений() 
	ЭтоНеторговоеПоручениеСоСпискомЦБ = ЭтоНеторговоеПоручениеСоСпискомЦБ();
	ЭтоИзменениеКатегорииСчетовДепонента = (Объект.ВидОперацииД = Справочники.ВидыОпераций.ИзменениеКатегорииСчетовДепонента);
	
	Элементы.ГруппаЦенныеБумагиСводногоПоручения.Видимость = ЭтоНеторговоеПоручениеСоСпискомЦБ;
	Элементы.ГруппаЦБ.Видимость = Не ЭтоНеторговоеПоручениеСоСпискомЦБ И Не ЭтоИзменениеКатегорииСчетовДепонента;
	Элементы.ГруппаКоличество.Видимость = Не ЭтоНеторговоеПоручениеСоСпискомЦБ И Не ЭтоИзменениеКатегорииСчетовДепонента;
КонецПроцедуры

&НаСервере
Процедура УстановитьВидимостьЭлементаТипПеревода()
	Элементы.ТипПеревода.Видимость = (Объект.ВидОперацииД = Справочники.ВидыОпераций.Перевод);
КонецПроцедуры

&НаКлиенте
Процедура ПроверитьКорректностьНомераСчета(НомерСчета, ЭлементФормыНомерСчета)
	
	Если Не ЗначениеЗаполнено(Объект.ПаиБИК) Или Не ЗначениеЗаполнено(НомерСчета) Тогда
		Возврат;
	КонецЕсли;
	
	НомерСчетаКорректен =
		РегламентированныеДанныеКлиентСервер.КонтрольныйКлючЛицевогоСчетаСоответствуетТребованиям(НомерСчета, Объект.ПаиБИК, Истина);
		
	Если НомерСчетаКорректен Тогда
		ЭлементФормыНомерСчета.ЦветТекста = Новый Цвет;
	Иначе
		ЭлементФормыНомерСчета.ЦветТекста = WebЦвета.Красный;
	КонецЕсли;
		
КонецПроцедуры

&НаСервере
Функция ЭтоНеторговоеПоручениеСоСпискомЦБ()
	Результат = Ложь;
	ДанныеПоручения = Новый Структура("ВидОперацииД", Объект.ВидОперацииД);
	Возврат Документы.Поручение.ЭтоНеторговоеПоручениеСоСпискомЦБ(ДанныеПоручения);
КонецФункции

&НаСервере
Процедура ЗаполнитьСписокСчетовДЕПОДепонента(УстановитьФлагСтатусаСчетов = Ложь)
	Если Объект.ВидОперацииД <> Справочники.ВидыОпераций.ИзменениеКатегорииСчетовДепонента Тогда
		Возврат;
	ИначеЕсли Не ЗначениеЗаполнено(Объект.Депонент) Тогда
		СчетаДепоДепонента.Очистить();
	Иначе
		Запрос = Новый Запрос;
		Запрос.Текст =
		"ВЫБРАТЬ
		|	СчетаДепо.Ссылка КАК СчетДепо,
		|	СчетаДепо.ВидСчетаДепо КАК ВидСчетаДепо,
		|	СчетаДепо.ТипСчетаДепо КАК ТипСчетаДепо
		|ИЗ
		|	Справочник.СчетаДепо КАК СчетаДепо
		|ГДЕ
		|	СчетаДепо.Владелец = &Депонент
		|	И НЕ СчетаДепо.ПометкаУдаления
		|	И ВЫБОР
		|			КОГДА СчетаДепо.ДатаОткрытияСчета > &ДатаВыборки
		|				ТОГДА ЛОЖЬ
		|			КОГДА СчетаДепо.ДатаЗакрытияСчета <= &ДатаВыборки
		|					И СчетаДепо.ДатаЗакрытияСчета <> ДАТАВРЕМЯ(1, 1, 1)
		|				ТОГДА ЛОЖЬ
		|			ИНАЧЕ ИСТИНА
		|		КОНЕЦ";
		Запрос.УстановитьПараметр("Депонент", Объект.Депонент);
		ДатаВыборки = ?(ЗначениеЗаполнено(Объект.Дата), Объект.Дата, ТекущаяДатаСеанса());
		Запрос.УстановитьПараметр("ДатаВыборки", НачалоДня(ДатаВыборки) );
		ТЗСчетаДепо = Запрос.Выполнить().Выгрузить();
		СчетаДепоДепонента.Загрузить(ТЗСчетаДепо);
		Если УстановитьФлагСтатусаСчетов Тогда
			Объект.ИмеетСчетаТипаC = РегистрыСведений.КлиентыСУчетомНаСчетахТипаC.ЦБКлиентаУчитываютсяНаСчетеТипаС(Объект.Дата, Объект.Депонент);
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

