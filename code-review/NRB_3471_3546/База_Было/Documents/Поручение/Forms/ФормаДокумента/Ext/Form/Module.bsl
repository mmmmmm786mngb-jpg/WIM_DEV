// ВСПОМОГАТЕЛЬНЫЕ ФУНКЦИИ

&НаСервере
Процедура РаспределитьИПДПоДепонентамЦенныеБумагиСписываемые(ИмяКолонкиБазыРаспределения = "Количество")
	
	ЦенныеБумагиСписываемые = Объект.ЦенныеБумагиСписываемые;
	Если ЦенныеБумагиСписываемые.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	ЭтоИностраннаяЦБ = ЭтоИностраннаяЦБ(Объект.ЦБ);
	
	РаспределяемаяТаблица = ЦенныеБумагиСписываемые.Выгрузить();
	КоэффициентыРаспределения = РаспределяемаяТаблица.ВыгрузитьКолонку(ИмяКолонкиБазыРаспределения);
	
	ИтогиРаспределенияНалога =
		ОбщегоНазначения.РаспределитьСуммуПропорциональноКоэффициентам(Объект.СуммаИПДНалогаВИностраннойЮрисдикции, КоэффициентыРаспределения);
	Если ИтогиРаспределенияНалога <> Неопределено Тогда
		РаспределяемаяТаблица.ЗагрузитьКолонку(ИтогиРаспределенияНалога, "СуммаНалогаВИностраннойЮрисдикции");
	КонецЕсли;
	
	ИтогиРаспределенияСуммы = ОбщегоНазначения.РаспределитьСуммуПропорциональноКоэффициентам(Объект.СуммаИПД, КоэффициентыРаспределения);
	Если ИтогиРаспределенияСуммы <> Неопределено Тогда
		РаспределяемаяТаблица.ЗагрузитьКолонку(ИтогиРаспределенияСуммы, "Сумма");
	КонецЕсли;
	
	ЦенныеБумагиСписываемые.Загрузить(РаспределяемаяТаблица);
	
	Если ЭтоИностраннаяЦБ Тогда
		СтоПроцентов = 100;
		Если Объект.СуммаИПД > 0 Тогда
			Объект.СтавкаИПДНалогаВИностраннойЮрисдикции = Окр(СтоПроцентов * Объект.СуммаИПДНалогаВИностраннойЮрисдикции / Объект.СуммаИПД);
		КонецЕсли;
		Для Каждого Строка Из ЦенныеБумагиСписываемые Цикл
			Строка.СуммаКВыплатеПоИПД = Строка.Сумма - Строка.СуммаНалогаВИностраннойЮрисдикции;
			Строка.Сумма = Строка.Сумма + Строка.СуммаКомиссий + Строка.ДополнительныеУдержания;
			Строка.Комментарий = Документы.НачисленныйНалог.КомментарийОНалогеУдержанномВИностраннойЮрисдикции(
				Строка.СуммаНалогаВИностраннойЮрисдикции,
				Строка.ВалютаНалога,
				Объект.СтавкаИПДНалогаВИностраннойЮрисдикции);
		КонецЦикла;
		Объект.СуммаСделки = ЦенныеБумагиСписываемые.Итог("СуммаКВыплатеПоИПД");
	КонецЕсли;
	ДлинаКомментария = ОбщаяДлинаКомментария();
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ИспользоватьРасчетНДФЛПоПрогрессивнойШкале(Дата)
	Возврат Документы.НачисленныйНалог.ИспользоватьРасчетНДФЛПоПрогрессивнойШкале(Дата);
КонецФункции

&НаСервере
Процедура УстановитьВидимостьПоДате()
	ИспользоватьПрогрессивнуюШкалу = ИспользоватьРасчетНДФЛПоПрогрессивнойШкале(Объект.Дата);
	Элементы.ЦенныеБумагиВыкуп1СтатьиНКРФСоглашения.Видимость = Не ИспользоватьПрогрессивнуюШкалу;
	Элементы.ПогашениеСтавкаНалога.Видимость = Не ИспользоватьПрогрессивнуюШкалу;
	// Обычные колонки
	Элементы.ПрогрессивнаяШкалаПлановаяДатаРасчетов.Видимость = ИспользоватьПрогрессивнуюШкалу;
	Элементы.ПрогрессивнаяШкалаВалютаНалога.Видимость = ИспользоватьПрогрессивнуюШкалу;
	Элементы.ПрогрессивнаяШкалаКомментарий.Видимость = ИспользоватьПрогрессивнуюШкалу;
	// Только для просмотра
	Элементы.ПрогрессивнаяШкалаСуммаОбязательствПоУплатеНалога.Видимость = ИспользоватьПрогрессивнуюШкалу;
	Элементы.ПрогрессивнаяШкалаСуммаОбязательствПоУплатеНалога.ТолькоПросмотр = Истина;
	Элементы.ПрогрессивнаяШкалаСуммаНалогаПоСтавке15СПревышения.Видимость = ИспользоватьПрогрессивнуюШкалу;
	Элементы.ПрогрессивнаяШкалаСуммаНалогаПоСтавке15СПревышения.ТолькоПросмотр = Истина;
	Элементы.ПрогрессивнаяШкалаДатаПередачиДоходаКлиенту.Видимость = ИспользоватьПрогрессивнуюШкалу;
	Элементы.ПрогрессивнаяШкалаДатаПередачиДоходаКлиенту.ТолькоПросмотр = Истина;
	Элементы.ПрогрессивнаяШкалаДатаУплатыНалога.Видимость = ИспользоватьПрогрессивнуюШкалу;
	Элементы.ПрогрессивнаяШкалаДатаУплатыНалога.ТолькоПросмотр = Истина;
	Элементы.ПрогрессивнаяШкалаСтавкаНалогаНачисленныйНалог.Видимость = ИспользоватьПрогрессивнуюШкалу;
	Элементы.ПрогрессивнаяШкалаСтавкаНалогаНачисленныйНалог.ТолькоПросмотр = Истина;
	Элементы.ПрогрессивнаяШкалаГруппаСуммыКВыплате.Видимость = ИспользоватьПрогрессивнуюШкалу;
	Элементы.ПрогрессивнаяШкалаГруппаСуммыКВыплате.ТолькоПросмотр = Истина;
	Элементы.ПрогрессивнаяШкалаСтавкаНалогаПовышеннаяНачисленныйНалог.Видимость = ИспользоватьПрогрессивнуюШкалу;
	Элементы.ПрогрессивнаяШкалаСтавкаНалогаПовышеннаяНачисленныйНалог.ТолькоПросмотр = Истина;
КонецПроцедуры

&НаКлиенте
