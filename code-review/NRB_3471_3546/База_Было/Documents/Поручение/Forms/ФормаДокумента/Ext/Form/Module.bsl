&НаКлиенте
Процедура ВыборПериодаОтчета(Команда)
	#Если ТолстыйКлиентОбычноеПриложение ИЛИ ТолстыйКлиентУправляемоеПриложение Тогда 
		НастройкаПериода = Новый НастройкаПериода;
		НастройкаПериода.УстановитьПериод(Объект.ДатаНачПериода, ?(Объект.ДатаКонПериода=Дата("00010101"),
			Объект.ДатаКонПериода, КонецДня(Объект.ДатаКонПериода)));
		НастройкаПериода.РедактироватьКакПериод = Истина;
		НастройкаПериода.ВариантНастройки 		= ВариантНастройкиПериода.Период;
		
		Если НастройкаПериода.Редактировать() Тогда
			Объект.ДатаНачПериода = НастройкаПериода.ПолучитьДатуНачала();
			Объект.ДатаКонПериода = НастройкаПериода.ПолучитьДатуОкончания();
		КонецЕсли;	
	#Иначе
		Диалог = Новый ДиалогРедактированияСтандартногоПериода();
		Диалог.Период = Новый СтандартныйПериод(Объект.ДатаНачПериода, ?(Объект.ДатаКонПериода=Дата("00010101"),
			Объект.ДатаКонПериода, КонецДня(Объект.ДатаКонПериода)));
		Если Диалог.Редактировать() Тогда 
			Объект.ДатаНачПериода = Диалог.Период.ДатаНачала;
			Объект.ДатаКонПериода = Диалог.Период.ДатаОкончания;
		КонецЕсли;
	#КонецЕсли
КонецПроцедуры

