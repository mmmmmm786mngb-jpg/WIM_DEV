/////////////////////////////////////////////////////////////////////
// ОБРАБОТЧИКИ СОБЫТИЙ ФОРМЫ
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	ОбщегоНазначения.ПриСозданииНаСервере(ЭтотОбъект);
КонецПроцедуры

////////////////////////////////////////////////////////////////////////////////
// ОБРАБОТЧИКИ КОМАНД ФОРМЫ

&НаКлиенте
Процедура ЭкспортВЛуч(Команда)
	ПовторнаяВыгрузка = ПоручениеУжеВыгружалось(Элементы.Список.ТекущаяСтрока);
	Если ПовторнаяВыгрузка Тогда
		Текст = "Поручение было выгружено ранее. Повторить выгрузку?";
		Ответ = Вопрос(Текст, РежимДиалогаВопрос.ДаНет, 0);
		Если Ответ = КодВозвратаДиалога.Нет Тогда
			Возврат;
		КонецЕсли;
	КонецЕсли;
	ЭкспортВЛучНаСервере(Элементы.Список.ТекущаяСтрока);
КонецПроцедуры

&НаКлиенте
Процедура РегистрСведенийДокументыВыгруженныеВЛуч(Команда)
	Если ЗначениеЗаполнено(Элементы.Список.ТекущаяСтрока) Тогда
		Отбор = Новый Структура("ДокументОснование", Элементы.Список.ТекущаяСтрока);
		ПараметрыФормы = Новый Структура("Отбор", Отбор);
		ОткрытьФорму("РегистрСведений.ДокументыВыгруженныеВЛуч.ФормаСписка", ПараметрыФормы, ЭтотОбъект, УникальныйИдентификатор);
	КонецЕсли; 
КонецПроцедуры

&НаКлиенте
Процедура НеттоПоручение(Команда)
	Если ЗначениеЗаполнено(Элементы.Список.ТекущаяСтрока) Тогда
		Отбор = Новый Структура("Поручение", Элементы.Список.ТекущаяСтрока);
		ПараметрыФормы = Новый Структура("Отбор", Отбор);
		ОткрытьФорму("Документ.НеттоПоручение.Форма.ФормаСпискаСОтбором", ПараметрыФормы, ЭтотОбъект, УникальныйИдентификатор);
	КонецЕсли; 
КонецПроцедуры

&НаКлиенте
Процедура ОтборПоЦБПриИзменении(Элемент)
	Если ЗначениеЗаполнено(ЦеннаяБумага) Тогда
		УстановитьОтборПоЦБ();
	Иначе
		УдалитьОтборПоЦБ();
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ОтменаПроведения(Команда)
	МассивПоручений = Команда.ИспользуемаяТаблица.ВыделенныеСтроки;
	
	Поручение = МассивПоручений[0];
	Если МассивПоручений.Количество() = 1 И Не ПолучитьСтатусПоручения(Поручение) Тогда
		Возврат;
	КонецЕсли;
	
	Если  МассивПоручений.Количество() = 1 Тогда
		ТекстВопроса = "ru = 'Отменить проведение документа?'";
	Иначе
		ТекстВопроса = "ru = 'Отменить проведение документов?'";
	КонецЕсли;
	
	Если МассивПоручений.Количество() > 0 Тогда
		Режим = РежимДиалогаВопрос.ДаНет;
		Ответ = Вопрос(НСтр(ТекстВопроса), Режим, 0);
		Если Ответ = КодВозвратаДиалога.Нет Тогда
			Возврат;
		Иначе
			ОтменитьПроведениеНаСервере(МассивПоручений);
			Элементы.Список.Обновить();
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПометитьНаУдалениеСнятьПометку(Команда)
	
	МассивПоручений = Команда.ИспользуемаяТаблица.ВыделенныеСтроки;
	
	Поручение = МассивПоручений[0];
	Если МассивПоручений.Количество() = 1 И ПоручениеПроведено(Поручение) Тогда
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "Пометить на удаление можно только Поручение, у которого отменено проведение!";
		Сообщение.Сообщить();
		Возврат;
	КонецЕсли;
	
	Если  МассивПоручений.Количество() = 1 Тогда
		ТекстВопроса = "ru = 'Пометить на удаление / снять пометку " + МассивПоручений[0] + "?'";
	Иначе
		ТекстВопроса = "ru = 'Пометить на удаление / снять пометки у массива документов ?'";
	КонецЕсли;
	
	Если МассивПоручений.Количество() > 0 Тогда
		Режим = РежимДиалогаВопрос.ДаНет;
		Ответ = Вопрос(НСтр(ТекстВопроса), Режим, 0);
		Если Ответ = КодВозвратаДиалога.Нет Тогда
			Возврат;
		Иначе
			ПометитьНаУдалениеСнятьПометкуНаСервере(МассивПоручений);
			Элементы.Список.Обновить();
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

////////////////////////////////////////////////////////////////////////////////
// ВСПОМОГАТЕЛЬНЫЕ ПРОЦЕДУРЫ

&НаСервереБезКонтекста
Функция ПоручениеУжеВыгружалось(Ссылка)
	Возврат РегистрыСведений.ДокументыВыгруженныеВЛуч.ДокументВыгружен(Ссылка);
КонецФункции

&НаСервере
Процедура ЭкспортВЛучНаСервере(Поручение)
	Документы.Поручение.ВыгрузитьПоручение(Поручение);
КонецПроцедуры

&НаКлиенте
Процедура СтатусыВСЭД(Команда)
	ОткрытьФорму("РегистрСведений.СтатусыПорученийВСЭД.ФормаСписка", Новый Структура("Отбор", Новый Структура("Поручение", Элементы.Список.ВыделенныеСтроки)));
КонецПроцедуры

&НаСервере
Процедура СписокПередЗагрузкойПользовательскихНастроекНаСервере(Элемент, Настройки, ИспользуютсяСтандартныеНастройки)
	
	ОбщегоНазначения.СписокПередЗагрузкойПользовательскихНастроекНаСервере(ЭтотОбъект, Настройки);
	
КонецПроцедуры

&НаКлиенте
Процедура УстановитьОтборПоЦБ()
	
	ГруппаОтбораПоЦБ = ОтборыСписковКлиентСервер.НайтиЭлементОтбораПоПредставлению(Список.Отбор.Элементы, "Отбор по ЦБ");
	Если ГруппаОтбораПоЦБ = Неопределено Тогда
		ГруппаОтбораПоЦБ = Список.Отбор.Элементы.Добавить(Тип("ГруппаЭлементовОтбораКомпоновкиДанных"));
		ГруппаОтбораПоЦБ.ТипГруппы = ТипГруппыЭлементовОтбораКомпоновкиДанных.ГруппаИли;
		ГруппаОтбораПоЦБ.Представление = "Отбор по ЦБ";
	Иначе
		ГруппаОтбораПоЦБ.Элементы.Очистить();
	КонецЕсли;
	
	ОбщегоНазначенияКлиентСервер.ДобавитьЭлементКомпоновки(ГруппаОтбораПоЦБ,
	"ЦБ", ВидСравненияКомпоновкиДанных.Равно, ЦеннаяБумага);
	ОбщегоНазначенияКлиентСервер.ДобавитьЭлементКомпоновки(ГруппаОтбораПоЦБ,
	"ЦеннаяБумага", ВидСравненияКомпоновкиДанных.Равно, ЦеннаяБумага);
	
КонецПроцедуры

&НаКлиенте
Процедура УдалитьОтборПоЦБ()
	ГруппаОтбораПоЦБ = ОтборыСписковКлиентСервер.НайтиЭлементОтбораПоПредставлению(Список.Отбор.Элементы, "Отбор по ЦБ");
	Если ГруппаОтбораПоЦБ <> Неопределено Тогда
		Список.Отбор.Элементы.Удалить(ГруппаОтбораПоЦБ);
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура ОтменитьПроведениеНаСервере(МассивПоручений)
	
	МетаданныеПоручение = Метаданные.Документы.Поручение;
	Если НЕ ПравоДоступа("ОтменаПроведения", МетаданныеПоручение) Тогда
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Текст = "Не установлено право Отмены проведения для документов Поручение!";
			Сообщение.Сообщить();
		Возврат;
	КонецЕсли;
	
	Попытка
		Для Каждого стр Из МассивПоручений Цикл
			Поручение = стр.ПолучитьОбъект();
			СтатусПоручения = РегистрыСведений.СтатусыПоручений.СтатусПоручения(стр);
			ЭтоОтменаИсполненногоПорученияПоДвижениюЦБ = Поручение.Проведен И СтатусПоручения = Перечисления.СтатусыПоручений.Исполнено И ЭтоПоручениеПоДвижениюЦБ(Поручение.ВидОперацииД);
			Если ЭтоОтменаИсполненногоПорученияПоДвижениюЦБ Тогда
				ТекстСообщения = "Отмена проведения " + Поручение + " по движениям ЦБ в статусе Исполнено запрещено, обратитесь в команду Поддержки!";
				ОбщегоНазначения.СообщитьОбОшибке(ТекстСообщения, Истина);
				Продолжить;
			КонецЕсли;
			
			Поручение.Записать(РежимЗаписиДокумента.ОтменаПроведения);
		КонецЦикла;
	Исключение
		МенеджерОшибок = Новый МенеджерОбработкиОшибок;
		ТекстСообщения = МенеджерОшибок.КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не удалось отменить проведение " + Поручение + " - " + ТекстСообщения);
	КонецПопытки;
	
КонецПроцедуры

&НаСервере
Процедура ПометитьНаУдалениеСнятьПометкуНаСервере(МассивПоручений)
	
	МетаданныеПоручение = Метаданные.Документы.Поручение;
	Если НЕ ПравоДоступа("Удаление", МетаданныеПоручение) Тогда
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Текст = "Не установлено право Удаления для документов Поручение!";
			Сообщение.Сообщить();
		Возврат;
	КонецЕсли;
	
	Попытка
		Для Каждого стр Из МассивПоручений Цикл
			Поручение = стр.ПолучитьОбъект();
			Если Поручение.Проведен Тогда
				Сообщение = Новый СообщениеПользователю;
				Сообщение.Текст = "Поручение " + Поручение + " проведено!" + Символы.ВК
									+ "Пометить на удаление можно только Поручение, у которого отменено проведение !";
				Сообщение.Сообщить(); 
				Продолжить;
			КонецЕсли;
			Если Поручение.ПометкаУдаления Тогда
				Поручение.УстановитьПометкуУдаления(Ложь);
			Иначе
				Поручение.УстановитьПометкуУдаления(Истина);
			КонецЕсли;
			Поручение.Записать(РежимЗаписиДокумента.Запись);
		КонецЦикла;
	Исключение
		МенеджерОшибок = Новый МенеджерОбработкиОшибок;
		ТекстСообщения = МенеджерОшибок.КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не удалось пометить / снять пометку " + Поручение + " - " + ТекстСообщения);
	КонецПопытки;
	
КонецПроцедуры

&НаСервере
Функция ПолучитьСтатусПоручения(Поручение)
	
	Возврат Поручение.Проведен;
	
КонецФункции

&НаСервереБезКонтекста
Функция ЭтоПоручениеПоДвижениюЦБ(ВидОперации)
	Возврат Документы.Поручение.ЭтоПоручениеПоДвижениюЦБ(ВидОперации);
КонецФункции

&НаСервере
Функция ПоручениеПроведено(Поручение)
	
	Возврат Поручение.Проведен;
	
КонецФункции
