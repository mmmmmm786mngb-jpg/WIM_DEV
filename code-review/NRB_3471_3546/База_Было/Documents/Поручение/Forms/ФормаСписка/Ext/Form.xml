			<MainAttribute>true</MainAttribute>
			<Settings xsi:type="DynamicList">
				<ManualQuery>true</ManualQuery>
				<DynamicDataRead>true</DynamicDataRead>
				<QueryText>ВЫБРАТЬ РАЗЛИЧНЫЕ
	ДокументПоручение.Ссылка,
	ДокументПоручение.ПометкаУдаления,
	ДокументПоручение.Номер,
	ДокументПоручение.Дата,
	ДокументПоручение.Проведен,
	ДокументПоручение.Автор,
	ДокументПоручение.ВидОперацииД,
	ДокументПоручение.ТипКонвертации,
	ДокументПоручение.ВидПредставителяСчетаДепо,
	ДокументПоручение.ВидПредставителяСчетаДепоПодпись,
	ДокументПоручение.ВходящийНомерПоручения,
	ДокументПоручение.ДатаКонПериода,
	ДокументПоручение.ДатаНачалаДоверенности,
	ДокументПоручение.ДатаНачПериода,
	ДокументПоручение.ДатаОкончанияДоверенности,
	ДокументПоручение.ДатаПриема,
	ДокументПоручение.ДокументОснование,
	ДокументПоручение.Изменил,
	ДокументПоручение.Инициатор,
	ДокументПоручение.КоличествоЦБ,
	ВЫРАЗИТЬ(ДокументПоручение.Комментарий КАК СТРОКА(1000)) КАК Комментарий,
	ДокументПоручение.Контрагент,
	ДокументПоручение.МХ_ПоУмолчанию,
	ДокументПоручение.МХДепонента,
	ДокументПоручение.МХКонтрагент,
	ДокументПоручение.НомерДоверенностиПредставителя,
	ДокументПоручение.ОснованиеОтмены,
	ДокументПоручение.ОтменяемоеПоручение,
	ДокументПоручение.ПредставительСчетаДепо,
	ДокументПоручение.РазделСчетаДепо,
	ДокументПоручение.РазделСчетаДепоКонтрагента,
	ДокументПоручение.СпособПриемаПоручений,
	ДокументПоручение.СуммаСделки,
	ДокументПоручение.СчетДепо,
	ДокументПоручение.СчетДепоКонтрагента,
	ДокументПоручение.ТипСчетаДепо,
	ДокументПоручение.ЦБ,
	ДокументПоручение.ЦенаСделкиЦБ,
	ДокументПоручение.ЭмитентВыписка,
	ДокументПоручение.ЭмитентУведомление,
	ДокументПоручение.Валюта,
	ДокументПоручение.РучнойВвод,
	ДокументПоручение.ДатаИсполненияПоручения,
	ДокументПоручение.ТипРазделаСчетаДЕПО,
	ДокументПоручение.ИдентификаторЗагрузки,
	ДокументПоручение.МоментВремени,
	СтатусыПорученийСрезПоследних.СтатусПоручения,
	ВЫБОР
		КОГДА ДокументПоручение.СчетДепо = НЕОПРЕДЕЛЕНО
				ИЛИ ДокументПоручение.СчетДепо = ЗНАЧЕНИЕ(Справочник.СчетаДепо.)
				ИЛИ ДокументПоручение.СчетДепо = ЗНАЧЕНИЕ(Справочник.СчетаДепоМХ.)
			ТОГДА ДокументПоручение.Депонент
		ИНАЧЕ ДокументПоручение.СчетДепо.Владелец
	КОНЕЦ КАК Депонент,
	ДокументПоручение.УведомлениеОтправлено,
	ЕСТЬNULL(СостоянияДокументовВФайловомШлюзеСрезПоследних.Статус, СостоянияДокументовВФайловомШлюзеСрезПоследнихНетто.Статус) КАК СтатусФайловыйШлюз
ИЗ
	Документ.Поручение КАК ДокументПоручение
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СтатусыПоручений.СрезПоследних КАК СтатусыПорученийСрезПоследних
		ПО (СтатусыПорученийСрезПоследних.Поручение = ДокументПоручение.Ссылка)
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СостоянияДокументовВФайловомШлюзе.СрезПоследних(, ) КАК СостоянияДокументовВФайловомШлюзеСрезПоследних
		ПО СостоянияДокументовВФайловомШлюзеСрезПоследних.Документ В (ВЫБРАТЬ ПЕРВЫЕ 1 Ссылка ИЗ Документ.ТехническаяОперация ГДЕ ДОкументОснование = ДокументПоручение.Ссылка УПОРЯДОЧИТЬ ПО Дата УБЫВ)
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СостоянияДокументовВФайловомШлюзе.СрезПоследних(, ) КАК СостоянияДокументовВФайловомШлюзеСрезПоследнихНетто
		ПО СостоянияДокументовВФайловомШлюзеСрезПоследнихНетто.Документ В (ВЫБРАТЬ ПЕРВЫЕ 1 Ссылка ИЗ Документ.ТехническаяОперация ГДЕ ДОкументОснование В (ВЫБРАТЬ РАЗЛИЧНЫЕ Ссылка ИЗ Документ.НеттоПоручение.Поручения ГДЕ Поручение = ДокументПоручение.Ссылка И Ссылка.Проведен) УПОРЯДОЧИТЬ ПО Дата УБЫВ)
		{ЛЕВОЕ СОЕДИНЕНИЕ Документ.Поручение.ЦенныеБумагиСписываемые КАК ПоручениеЦенныеБумагиСписываемые
		ПО ДокументПоручение.Ссылка = ПоручениеЦенныеБумагиСписываемые.Ссылка}
{ГДЕ
	ПоручениеЦенныеБумагиСписываемые.ЦеннаяБумага.*}</QueryText>
				<MainTable>Document.Поручение</MainTable>
				<ListSettings>
					<dcsset:filter>
						<dcsset:viewMode>Normal</dcsset:viewMode>
						<dcsset:userSettingID>dfcece9d-5077-440b-b6b3-45a5cb4538eb</dcsset:userSettingID>
					</dcsset:filter>
					<dcsset:order>
