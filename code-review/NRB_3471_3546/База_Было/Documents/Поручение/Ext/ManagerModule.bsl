// РАСЧЕТ И НАЧИСЛЕНИЕ НАЛОГОВ ДЛЯ ОПЕРАЦИИ ВЫПЛАТЫ ДОХОДОВ

Процедура ЗаполнитьСтавкуИСуммуНалогаВСтруктуреНачисления(СтруктураНачисленияНалога, ДепонентЯвляетсяРезидентом,
	СуммаДляРасчетаНалога, Количество, СчетДепо, РазделСчетаДепо) Экспорт
	
	ЭтоДивиденды 	= СтруктураНачисленияНалога.ЭтоДивиденды;
	ЭтоКупоны 		= СтруктураНачисленияНалога.ЭтоКупоны;
	КоэффициентД1 	= СтруктураНачисленияНалога.КоэффициентД1;
	КоэффициентД2 	= СтруктураНачисленияНалога.КоэффициентД2;
	
	СтруктураНачисленияНалога.КодДохода			= ?(ЭтоДивиденды, Справочники.ДоходыНДФЛ.Код1010, Справочники.ДоходыНДФЛ.Код1100);
	СтруктураНачисленияНалога.НачислитьНалог 	= Истина;
		
	КоэффициентДляБазы = 1;
	
	Если ЭтоКупоны Тогда
		УточнитьСуммуДляРасчетаНалога(СуммаДляРасчетаНалога, Количество, СтруктураНачисленияНалога);
	ИначеЕсли ЭтоДивиденды И ДепонентЯвляетсяРезидентом Тогда
		КоэффициентДляБазы = (КоэффициентД1 - КоэффициентД2) / ?(КоэффициентД1 > 0, КоэффициентД1, 1);
	КонецЕсли;				
	
	ДанныеПоНалогам = РегистрыСведений.ПодтвержденияСубброкераПоРСВ.ДанныеПоНалогам(
		СтруктураНачисленияНалога.КарточкаКД, СтруктураНачисленияНалога.ЦеннаяБумага, СчетДепо, РазделСчетаДепо);
	Если ДанныеПоНалогам <> Неопределено Тогда
		СтавкаНДФЛ = ДанныеПоНалогам.НалоговаяСтавка;
		СтатьиНКРФСоглашения = ДанныеПоНалогам.НаличиеНалоговыхЛьгот;
	Иначе
		СтавкаНДФЛ = ?(ДепонентЯвляетсяРезидентом, СтруктураНачисленияНалога.КодДохода.РазмерСтавкиРезидента,
			СтруктураНачисленияНалога.КодДохода.РазмерСтавкиНерезидента);
		СтатьиНКРФСоглашения = "";
	КонецЕсли;
	
	СтруктураНачисленияНалога.СтавкаНалога = СтавкаНДФЛ;
	СтруктураНачисленияНалога.СуммаНалога = Окр(СуммаДляРасчетаНалога * КоэффициентДляБазы * СтавкаНДФЛ / 100, 0);
	СтруктураНачисленияНалога.СтатьиНКРФСоглашения = СтатьиНКРФСоглашения;
	
КонецПроцедуры


Процедура УточнитьСуммуДляРасчетаНалога(СуммаДляРасчетаНалога, Количество, СтруктураНачисленияНалога)
	// Возможно уменьшение налоговой базы согласно ФЗ от 03.04.2017 N 58-ФЗ "О внесении изменений в главу 23 части второй Налогового кодекса Российской Федерации".
	// в ред. Федерального закона от 30.09.2017 N 286-ФЗ
	ЦеннаяБумага = СтруктураНачисленияНалога.ЦеннаяБумага;
	ДатаПогашения = СтруктураНачисленияНалога.ДатаПогашения;
	Если ДатаПогашения < ДатаНачалаДействияФЗСИзменениями() Тогда
		Возврат;
	КонецЕсли;
	Если ВыполненыУсловияДляИзмененияНалоговойБазы(ЦеннаяБумага, СтруктураНачисленияНалога.ДатаПогашения) Тогда 
		СтруктураНачисленияНалога.КодДохода = Справочники.ДоходыНДФЛ.Код3023;
		СведенияПоКупону = ПогашаемыйКупон(ЦеннаяБумага, ДатаПогашения);
		Если ДостаточноСведенийПоКупону(ЦеннаяБумага, СведенияПоКупону) Тогда
			СуммаДляРасчетаНалога = СуммаДоходаПоКупону(СведенияПоКупону, СуммаДляРасчетаНалога, Количество);
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

Функция ДатаНачалаДействияФЗСИзменениями()
	Возврат Дата(2018,1,1);
КонецФункции

Функция ВыполненыУсловияДляИзмененияНалоговойБазы(ЦБ, ДатаДокумента)
	Если ЦБ.ВалютаНоминала = Справочники.Валюты.Рубль()
		И НЕ ЦБ.Эмитент.Резидент = Истина    // реквизит контрагента назван "Резидент" ошибочно
		И ЦБ.ДатаРазмещения >= Дата(2017,1,1)
		И ДатаДокумента < Константы.ДатаНачалаНачисленияНДФЛНаГособлигации.Получить() Тогда 
		Возврат Истина;
	КонецЕсли;
	Возврат Ложь;
КонецФункции

Функция ПогашаемыйКупон(ЦБ, ДатаПогашения)
	СтруктураКупона = Новый Структура("Ставка, ДатаВыпуска, ДатаПогашения, СрокОбращения");
	КупонВДатуПогашения = ЦБ.Купоны.Найти(НачалоДня(ДатаПогашения), "ДатаПогашения");
	Если НЕ КупонВДатуПогашения = Неопределено Тогда
		ЗаполнитьЗначенияСвойств(СтруктураКупона, КупонВДатуПогашения);
	Иначе 
		ЗаполнитьСтруктуруКупонаБлижайшимДляПогашения(СтруктураКупона, ЦБ, ДатаПогашения);
	КонецЕсли;
	СтруктураКупона.Вставить("ЦеннаяБумага", ЦБ); 
	Возврат СтруктураКупона;
КонецФункции

Функция СуммаДоходаПоКупону(СведенияПоКупону, СуммаКупонногоДохода, Количество)
	Запрос = Новый Запрос(ТекстЗапросаДляОпределенияНалогооблагаемойБазы());
	Запрос.УстановитьПараметр("ДатаВыпуска", НачалоДня(СведенияПоКупону.ДатаВыпуска));
	Запрос.УстановитьПараметр("ДатаПогашения", НачалоДня(СведенияПоКупону.ДатаПогашения) - 1);
	Запрос.УстановитьПараметр("Сумма", СуммаКупонногоДохода);
	Запрос.УстановитьПараметр("СтавкаКупона", СведенияПоКупону.Ставка);
	Запрос.УстановитьПараметр("ЦеннаяБумага", СведенияПоКупону.ЦеннаяБумага);
	Запрос.УстановитьПараметр("СрокОбращения", 365);
	Запрос.УстановитьПараметр("Количество", Количество);
	Результат = Запрос.Выполнить();
	Если Результат.Пустой() Тогда
		СообщениеПоОшибке = "Не удалось определить ставку рефинансирования за период с %1 по %2.";
		ПолныйТекстСообщения = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(СообщениеПоОшибке, Формат(СведенияПоКупону.ДатаВыпуска, "ДФ=dd.MM.yyyy"), Формат(СведенияПоКупону.ДатаПогашения, "ДФ=dd.MM.yyyy"));
		СообщитьИЗаписатьПредупреждение(ПолныйТекстСообщения);
		Возврат СуммаКупонногоДохода;
	КонецЕсли;
	ВыборкаИтогов = Результат.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	ВыборкаИтогов.Следующий();
	Возврат ВыборкаИтогов.СуммаНалогооблагаемая;
КонецФункции

Функция ТекстЗапросаДляОпределенияНалогооблагаемойБазы()
	Возврат "ВЫБРАТЬ
	        |	Календарь.Период КАК Период
	        |ПОМЕСТИТЬ втВсеДаты
	        |ИЗ
	        |	РегистрСведений.Календарь КАК Календарь
	        |ГДЕ
	        |	Календарь.Период МЕЖДУ &ДатаВыпуска И &ДатаПогашения
	        |;
	        |
	        |////////////////////////////////////////////////////////////////////////////////
	        |ВЫБРАТЬ
	        |	ПериодКупона.Период КАК ДатаПериодаКупона,
	        |	МАКСИМУМ(СтавкиРефинансирования.Период) КАК ПериодСтавкиРефинансирования,
	        |	МАКСИМУМ(НоминалЦБ.Период) КАК ПериодНоминала
	        |ПОМЕСТИТЬ втДатыПериодаКупона
	        |ИЗ
	        |	втВсеДаты КАК ПериодКупона
	        |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.СтавкиРефинансирования КАК СтавкиРефинансирования
	        |		ПО ПериодКупона.Период >= СтавкиРефинансирования.Период
	        |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.НоминалЦБ КАК НоминалЦБ
	        |		ПО ПериодКупона.Период >= НоминалЦБ.Период
	        |			И (НоминалЦБ.ЦеннаяБумага = &ЦеннаяБумага)
	        |
	        |СГРУППИРОВАТЬ ПО
	        |	ПериодКупона.Период
	        |;
	        |
	        |////////////////////////////////////////////////////////////////////////////////
	        |ВЫБРАТЬ
	        |	ДатыПериодаКупона.ДатаПериодаКупона КАК ДатаПериодаКупона,
	        |	ДатыПериодаКупона.ПериодСтавкиРефинансирования КАК ПериодСтавкиРефинансирования,
	        |	ЕСТЬNULL(СтавкиРефинансирования.Ставка, 0) КАК СтавкаРефинансирования,
	        |	&Сумма / ВсеДаты.Количество КАК СуммаКупонаНаДень,
	        |	ЕСТЬNULL(НоминалЦБ.Сумма, 0) / &СрокОбращения КАК ДоляНоминалаНаДень
	        |ПОМЕСТИТЬ втДанныеДляРасчета
	        |ИЗ
	        |	втДатыПериодаКупона КАК ДатыПериодаКупона
	        |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СтавкиРефинансирования КАК СтавкиРефинансирования
	        |		ПО ДатыПериодаКупона.ПериодСтавкиРефинансирования = СтавкиРефинансирования.Период
	        |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.НоминалЦБ КАК НоминалЦБ
	        |		ПО ДатыПериодаКупона.ПериодНоминала = НоминалЦБ.Период
	        |			И (НоминалЦБ.ЦеннаяБумага = &ЦеннаяБумага)
	        |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	        |			КОЛИЧЕСТВО(РАЗЛИЧНЫЕ втВсеДаты.Период) КАК Количество
	        |		ИЗ
	        |			втВсеДаты КАК втВсеДаты) КАК ВсеДаты
	        |		ПО (ВсеДаты.Количество > 0)
	        |;
	        |
	        |////////////////////////////////////////////////////////////////////////////////
	        |ВЫБРАТЬ
	        |	втДанныеДляРасчета.СтавкаРефинансирования КАК СтавкаРефинансирования,
	        |	СУММА(втДанныеДляРасчета.СуммаКупонаНаДень) КАК СуммаКупонаНаДень,
	        |	СУММА(ВЫБОР
	        |			КОГДА втДанныеДляРасчета.СтавкаРефинансирования + 5 < &СтавкаКупона
	        |				ТОГДА (втДанныеДляРасчета.СтавкаРефинансирования + 5) * втДанныеДляРасчета.ДоляНоминалаНаДень / 100
	        |			ИНАЧЕ &СтавкаКупона * втДанныеДляРасчета.ДоляНоминалаНаДень / 100
	        |		КОНЕЦ) КАК СуммаЛьготы,
	        |	СУММА(ВЫБОР
	        |			КОГДА втДанныеДляРасчета.СтавкаРефинансирования + 5 < &СтавкаКупона
	        |				ТОГДА (&СтавкаКупона - втДанныеДляРасчета.СтавкаРефинансирования - 5) * втДанныеДляРасчета.ДоляНоминалаНаДень / 100
	        |			ИНАЧЕ 0
	        |		КОНЕЦ) КАК СуммаНалогооблагаемая
	        |ПОМЕСТИТЬ втИтогиРасчета
	        |ИЗ
	        |	втДанныеДляРасчета КАК втДанныеДляРасчета
	        |
	        |СГРУППИРОВАТЬ ПО
	        |	втДанныеДляРасчета.СтавкаРефинансирования
	        |;
	        |
	        |////////////////////////////////////////////////////////////////////////////////
	        |ВЫБРАТЬ
	        |	втИтогиРасчета.СтавкаРефинансирования КАК СтавкаРефинансирования,
	        |	втИтогиРасчета.СуммаКупонаНаДень КАК СуммаКупонаНаДень,
	        |	(ВЫРАЗИТЬ(втИтогиРасчета.СуммаЛьготы КАК ЧИСЛО(20, 2))) * &Количество КАК СуммаОсвобожденнаяОтНалога,
	        |	(ВЫРАЗИТЬ(втИтогиРасчета.СуммаНалогооблагаемая КАК ЧИСЛО(20, 2))) * &Количество КАК СуммаНалогооблагаемая
	        |ИЗ
	        |	втИтогиРасчета КАК втИтогиРасчета
	        |ИТОГИ
	        |	СУММА(СуммаОсвобожденнаяОтНалога),
	        |	СУММА(СуммаНалогооблагаемая)
	        |ПО
	        |	ОБЩИЕ";
КонецФункции

Процедура ЗаполнитьСтруктуруКупонаБлижайшимДляПогашения(СтруктураКупона, ЦБ, ДатаПогашения)
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	ЦенныеБумагиКупоны.ДатаПогашения КАК ДатаПогашения,
	|	РАЗНОСТЬДАТ(ЦенныеБумагиКупоны.ДатаПогашения, &ДатаДокумента, ДЕНЬ) * ВЫБОР
	|		КОГДА РАЗНОСТЬДАТ(ЦенныеБумагиКупоны.ДатаПогашения, &ДатаДокумента, ДЕНЬ) > 0
	|			ТОГДА 1
	|		ИНАЧЕ -1
	|	КОНЕЦ КАК РазностьДат,
	|	ЦенныеБумагиКупоны.Ставка КАК Ставка,
	|	ЦенныеБумагиКупоны.ДатаВыпуска КАК ДатаВыпуска,
	|	ЦенныеБумагиКупоны.СрокОбращения КАК СрокОбращения
	|ПОМЕСТИТЬ вт_АнализКупоновЦБ
	|ИЗ
	|	Справочник.ЦенныеБумаги.Купоны КАК ЦенныеБумагиКупоны
	|ГДЕ
	|	ЦенныеБумагиКупоны.Ссылка = &ЦеннаяБумага
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	вт_АнализКупоновЦБ.ДатаПогашения КАК ДатаПогашения,
	|	вт_АнализКупоновЦБ.РазностьДат КАК РазностьДат,
	|	вт_АнализКупоновЦБ.Ставка КАК Ставка,
	|	вт_АнализКупоновЦБ.ДатаВыпуска КАК ДатаВыпуска,
	|	вт_АнализКупоновЦБ.СрокОбращения
	|ИЗ
	|	вт_АнализКупоновЦБ КАК вт_АнализКупоновЦБ
	|ГДЕ
	|	вт_АнализКупоновЦБ.РазностьДат <= 365
	|
	|УПОРЯДОЧИТЬ ПО
	|	РазностьДат,
	|	ДатаПогашения";
	Запрос.УстановитьПараметр("ЦеннаяБумага", ЦБ);
	Запрос.УстановитьПараметр("ДатаДокумента", ДатаПогашения);
	Результат = Запрос.Выполнить();
	Если НЕ Результат.Пустой() Тогда
		ВыборкаКупонов = Результат.Выбрать();
		ВыборкаКупонов.Следующий();
		ЗаполнитьЗначенияСвойств(СтруктураКупона, ВыборкаКупонов);
	КонецЕсли;
КонецПроцедуры

Функция ДостаточноСведенийПоКупону(ЦеннаяБумага, СведенияПоКупону)
	ЕстьОшибки = Ложь;
	Если СведенияПоКупону.Ставка = 0 Тогда
		СообщениеПоОшибке = "Не удалось определить ставку купона для ценной бумаги %1 на дату %2. Налоговая база не пересчитана.";
		ПолныйТекстСообщения = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(СообщениеПоОшибке, ЦеннаяБумага, Формат(СведенияПоКупону.ДатаПогашения, "ДФ=dd.MM.yyyy"));
		СообщитьИЗаписатьПредупреждение(ПолныйТекстСообщения);
		ЕстьОшибки = Истина;
	КонецЕсли;
	Если НЕ ЗначениеЗаполнено(СведенияПоКупону.ДатаВыпуска) Тогда
		СообщениеПоОшибке = "Не удалось определить период купона для ценной бумаги %1 на дату погашения %2. Налоговая база не пересчитана.";
		ПолныйТекстСообщения = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(СообщениеПоОшибке, ЦеннаяБумага, Формат(СведенияПоКупону.ДатаПогашения, "ДФ=dd.MM.yyyy"));
		СообщитьИЗаписатьПредупреждение(ПолныйТекстСообщения);
		ЕстьОшибки = Истина;
	КонецЕсли;
	Возврат ЕстьОшибки = Ложь;
КонецФункции

Процедура СообщитьИЗаписатьПредупреждение(ПолныйТекстСообщения)
	ОбщегоНазначения.СообщитьОбОшибке(ПолныйТекстСообщения);
	ЗаписьЖурналаРегистрации("Пересчет налоговой базы при погашении купона", УровеньЖурналаРегистрации.Предупреждение,,,ПолныйТекстСообщения);		
КонецПроцедуры

Функция СтруктураНачисленияНалогаПоВыплатеДохода(ДокументПоручение) Экспорт
	СтруктураНачисления = Новый Структура("НачислитьНалог, СтавкаНалога, СуммаНалога, КодДохода, СтатьиНКРФСоглашения");
	СтруктураНачисления.Вставить("ЭтоДивиденды", ДокументПоручение.ВидОперацииД = Справочники.ВидыОпераций.НачислениеДивидендов);
	СтруктураНачисления.Вставить("ЭтоКупоны", ДокументПоручение.ВидОперацииД = Справочники.ВидыОпераций.ПогашениеНКД);
	СтруктураНачисления.Вставить("КоэффициентД1", ДокументПоручение.КоэффициентД1);
	СтруктураНачисления.Вставить("КоэффициентД2", ДокументПоручение.КоэффициентД2);
	СтруктураНачисления.Вставить("ЦеннаяБумага", ДокументПоручение.ЦБ);
	СтруктураНачисления.Вставить("ДатаПогашения", ДокументПоручение.Дата);
	СтруктураНачисления.Вставить("КарточкаКД", ДокументПоручение.КарточкаКД);	
	ПереченьРеквизитов = "ВалютаНоминала, ВидЦБ, ВидЦББанкаРоссии";
	РеквизитыЦБ = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ДокументПоручение.ЦБ, ПереченьРеквизитов);
	СтруктураНачисления.Вставить("ВалютаНоминала", РеквизитыЦБ.ВалютаНоминала);
	СтруктураНачисления.Вставить("ЭтоГосОблигация", РеквизитыЦБ.ВидЦБ = Перечисления.ВидыОблигаций.Государственная);
	ЭтоПаиРезидентов = РеквизитыЦБ.ВидЦББанкаРоссии = ОбщегоНазначенияПовтИсп.ВидЦББанкаРоссииПаиРезидентов();
	СтруктураНачисления.Вставить("ЭтоПаиРезидентов", ЭтоПаиРезидентов);
	
	Возврат СтруктураНачисления;
КонецФункции

Функция ЯвляемсяНалоговымАгентомДляДепонента(Контрагент, СтруктураНачисленияНалога) Экспорт
	НалоговыйАгент = Ложь;
	ЭтоФизическоеЛицо = Контрагент.ЮрФизЛицо = Перечисления.ЮрФизЛицо.ФизЛицо;
	ЭтоДивиденды = СтруктураНачисленияНалога.ЭтоДивиденды;
	ЭтоКупоны = СтруктураНачисленияНалога.ЭтоКупоны;
	ЭтоПаиРезидентов = СтруктураНачисленияНалога.ЭтоПаиРезидентов;
	Если ЭтоФизическоеЛицо Тогда
		НалоговыйАгент = ЭтоДивиденды Или ЭтоКупоны Или ЭтоПаиРезидентов;
	Иначе 
		НалоговыйАгент = ЭтоДивиденды И НЕ Контрагент.УправляющаяКомпания;
	КонецЕсли;
	Возврат НалоговыйАгент;
КонецФункции

