Процедура УведомлениеПисьмом_КарточкаКД_НеЗаполнена(Сообщение) Экспорт
	
	ДокументОбъект = Сообщение.Документ;
	ДатаПроведения = Сообщение.ДатаПроведения;
	
	НастройкиОбмена = ВнешниеДанные.ПолучитьПараметрыВнешнегоИсточника(ПланыВидовХарактеристик.ВнешниеИсточники.РассылкаУведомленийОНезаполненнойКарточкеКДВПоручении).Настройка;
	Если Не ЗначениеЗаполнено(НастройкиОбмена) Тогда
		ОписаниеОшибки = "Не заполнены параметры внешнего источника '"+ПланыВидовХарактеристик.ВнешниеИсточники.РассылкаУведомленийОНезаполненнойКарточкеКДВПоручении+"'. Выполните обновление информационной базы для задачи 4490.";
		ЗаписьЖурналаРегистрации("Уведомление о не заполненной карточке КД в поручении",
		УровеньЖурналаРегистрации.Ошибка,
		Метаданные.Документы.Поручение,
		ДокументОбъект.Ссылка,
		ОписаниеОшибки);
		Возврат;
	КонецЕсли;
	
	ТемаПисьма = "Поручение без карточки КД";
	ТекстПисьма = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку("Коллеги,
		|%3 произошла попытка проведения %1 (%2) без карточки КД.
		|Проверьте корректность данного поручения и поставьте галку «Не проверять наличие карточки КД», либо, если карточка КД должна быть в системе, обратитесь к 1S_servicedesk@vtbcapital-broker.com.
		|", ДокументОбъект.Ссылка, ДокументОбъект.ВидОперацииД, Формат(ДатаПроведения,"ДЛФ=DDT"));
	
	Вложения = Новый Соответствие;
	ПараметрыУведомления = Новый Соответствие;
	ПараметрыУведомления.Вставить("НастройкиОбмена"		, НастройкиОбмена);
	ПараметрыУведомления.Вставить("ТемаПисьма"			, ТемаПисьма);
	ПараметрыУведомления.Вставить("ТекстПисьма"			, ТекстПисьма);
	ПараметрыУведомления.Вставить("ТипТекстаПисьма"		, ТипТекстаПочтовогоСообщения.ПростойТекст);
	ПараметрыУведомления.Вставить("Кодировка"			, "UTF-8");
	ПараметрыУведомления.Вставить("Важность"			, ВажностьИнтернетПочтовогоСообщения.Обычная);
	РегистрыСведений.УведомленияКОтправке.ДобавитьУведомлениеКотправке(ПараметрыУведомления);

КонецПроцедуры

Функция ПоместитьСообщениеВОчередь(ИдОчереди, Сообщение)
	
	КаталогОчередиИмя = КаталогВременныхФайлов() + "ОчередьСообщений\" + ИдОчереди;
	КаталогОчереди = Новый Файл(КаталогОчередиИмя);
	Если НЕ КаталогОчереди.Существует() Тогда
		СоздатьКаталог(КаталогОчередиИмя);
	КонецЕсли;
	ИмяФайла = КаталогОчередиИмя + "\" + Формат(ТекущаяДатаСеанса(),"ДФ=ггггММдд_ЧЧммсс_");
	ИмяФайла = ИмяФайла + Строка(Новый УникальныйИдентификатор);
	ИмяФайла = ИмяФайла + ".xml";
	
	Данные = Новый Структура("Очередь, Сообщение", ИдОчереди, Сообщение);
	ЗаписьXML = Новый ЗаписьXML;
	ЗаписьXML.УстановитьСтроку();
	ЗаписьXML.ЗаписатьОбъявлениеXML();
	СериализаторXDTO.ЗаписатьXML(ЗаписьXML, Данные, НазначениеТипаXML.Явное);
	Файл = Новый ЗаписьТекста(ИмяФайла, КодировкаТекста.UTF8);
	Файл.Записать(ЗаписьXML.Закрыть());
	Файл.Закрыть();
	
	Файл = Новый Файл(ИмяФайла);
	Если Файл.Существует() Тогда
		Возврат Файл.ИмяБезРасширения;
	Иначе
		Возврат Неопределено;
	КонецЕсли; 
КонецФункции

Функция ПолучитьСообщенияИзОчереди(ИдОчереди)

	Очередь = Новый Массив;
	КаталогОчередиИмя = КаталогВременныхФайлов()+"ОчередьСообщений\"+ИдОчереди;
	КаталогОчереди = Новый Файл(КаталогОчередиИмя);
	Если НЕ КаталогОчереди.Существует() Тогда
		Возврат Очередь;
	КонецЕсли;
	Файлы = НайтиФайлы(КаталогОчередиИмя,"*.xml");
	
	Для каждого Файл Из Файлы Цикл
		ЧтениеТекста = Новый ЧтениеТекста(Файл.ПолноеИмя, КодировкаТекста.UTF8);
		Текст = ЧтениеТекста.Прочитать();
		ЧтениеТекста.Закрыть();
		
		ЧтениеXML = Новый ЧтениеXML;
		ЧтениеXML.УстановитьСтроку(Текст);
		Данные = СериализаторXDTO.ПрочитатьXML(ЧтениеXML);
		Если ТипЗнч(Данные)<>Тип("Структура") Тогда
		    Продолжить;
		КонецЕсли;
		ДанныеИдОчереди = Неопределено;
		Если НЕ Данные.Свойство("Очередь", ДанныеИдОчереди) Тогда
			Продолжить;
		КонецЕсли;
		Если ДанныеИдОчереди <> ИдОчереди Тогда
			Продолжить;
		КонецЕсли;
		Сообщение = Неопределено;
		Если НЕ Данные.Свойство("Сообщение", Сообщение) Тогда
			Продолжить;
		КонецЕсли;
		Очередь.Добавить(Новый Структура("Сообщение,ИдСообщения", Сообщение, Файл.ИмяБезРасширения));
	КонецЦикла; 
	Возврат Очередь;
КонецФункции 

Процедура УдалитьСообщениеИзОчереди(ИдОчереди, ИдСообщения)
	КаталогОчередиИмя = КаталогВременныхФайлов()+"ОчередьСообщений\"+ИдОчереди;
	КаталогОчереди = Новый Файл(КаталогОчередиИмя);
	Если НЕ КаталогОчереди.Существует() Тогда
		Возврат;
	КонецЕсли;
	Файл = Новый Файл(КаталогОчередиИмя + "\" + ИдСообщения + ".xml");
	Если Файл.Существует() Тогда
		УдалитьФайлы(Файл.ПолноеИмя);
	КонецЕсли; 
КонецПроцедуры

