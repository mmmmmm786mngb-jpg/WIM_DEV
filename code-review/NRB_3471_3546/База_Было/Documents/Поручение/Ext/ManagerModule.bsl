Функция ТекстУведомленияОбОтсутствииВыгрузкиВСЭДдляИнвентарныхПоручений(РезультатЗапроса, Дата) Экспорт
	
	Строки = Новый Массив;
	
	Текст = "<p>За %1 обнаружены неотправленные в СЭД исполненные инвентарные поручения:</p>";
	Текст = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(Текст, Формат(Дата, "ДФ=dd.MM.yyyy"));
	Строки.Добавить(Текст);
	
	Строки.Добавить("<table border=""1"" cellpadding=""5"" cellspacing=""0"" bordercolor=""gray"">");
	Строки.Добавить(
	"<tr>
	|<td>Документ</td>
	|<td>Раздел счета депо</td>
	|<td>Ценная бумага</td>
	|<td>ISIN</td>
	|<td>Вид операции</td>
	|</tr>");
	
	
	Выборка = РезультатЗапроса.Выбрать();
	Пока Выборка.Следующий() Цикл
		
		Текст =
		"<tr>
		|<td>%1</td>
		|<td>%2</td>
		|<td>%3</td>
		|<td>%4</td>
		|<td>%5</td>
		|</tr>";
		Строки.Добавить(СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(Текст,
		СокрЛП(СтроковыеФункцииКлиентСервер.HTMLСтрока(Выборка.Ссылка)),
		СокрЛП(СтроковыеФункцииКлиентСервер.HTMLСтрока(Выборка.РазделСчетаДепо)),
		СокрЛП(СтроковыеФункцииКлиентСервер.HTMLСтрока(Выборка.ЦБ)),
		СокрЛП(СтроковыеФункцииКлиентСервер.HTMLСтрока(Выборка.ISIN)),
		СокрЛП(СтроковыеФункцииКлиентСервер.HTMLСтрока(Выборка.ВидОперации))
		));
		
	КонецЦикла;
	
	Строки.Добавить("</table>");	
	Возврат СтроковыеФункцииКлиентСервер.ПолучитьСтрокуИзМассиваПодстрок(Строки, Символы.ПС);
	
КонецФункции

Функция НужноНачислитьНДФЛНаЕврооблигацию(СтруктураНачисленияНалога) Экспорт 
	
	Если СтруктураНачисленияНалога.ДатаПогашения >= Константы.ДатаНачалаНачисленияНДФЛНаГособлигации.Получить()
		И СтруктураНачисленияНалога.ЭтоКупоны
		И СтруктураНачисленияНалога.ЭтоГосОблигация
		И Не СтруктураНачисленияНалога.ВалютаНоминала = Константы.ВалютаРегламентированногоУчета.Получить() Тогда 
		Возврат Истина;
	КонецЕсли;
	
	Возврат Ложь;
	
КонецФункции

Функция ДанныеДляСозданияДокументовПоНалогам(Поручение, ТекущиеДанныеСчетДепо = Неопределено) Экспорт
	
	СписокФизЮрЛиц = Новый СписокЗначений();
	СписокФизЮрЛиц.Добавить(Перечисления.ЮрФизЛицо.ФизЛицо);
	СписокФизЮрЛиц.Добавить(Перечисления.ЮрФизЛицо.ЮрЛицо);
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ПоручениеЦенныеБумагиСписываемые.Ссылка КАК Основание,
		|	СчетаДепо.Владелец КАК Депонент,
		|	ПоручениеЦенныеБумагиСписываемые.ВалютаНалога КАК Валюта,
		|	1 КАК КурсВалюты,
		|	1 КАК КратностьВалюты,
		|	Поручение.КоэффициентД1 КАК КоэффициентД1,
		|	Поручение.КоэффициентД2 КАК КоэффициентД2,
		|	Поручение.СтавкаИПДНалогаВИностраннойЮрисдикции КАК СтавкаИПДНалогаВИностраннойЮрисдикции,
		|	ПоручениеЦенныеБумагиСписываемые.ПлановаяДатаРасчетов КАК Дата,
		|	ПоручениеЦенныеБумагиСписываемые.Резидент КАК Резидент,
		|	ПоручениеЦенныеБумагиСписываемые.Сумма КАК СуммаВыплаты,
		|	ПоручениеЦенныеБумагиСписываемые.СуммаНалогаВИностраннойЮрисдикции КАК СуммаНалогаВИностраннойЮрисдикции,
		|	НачисленныйНалог.Ссылка КАК СсылкаНаНачисленныйНалог,
		|	ВЫБОР
		|		КОГДА Поручение.КоэффициентД1 <> НачисленныйНалог.КоэффициентД1
		|				ИЛИ Поручение.КоэффициентД2 <> НачисленныйНалог.КоэффициентД2
		|				ИЛИ Поручение.СтавкаИПДНалогаВИностраннойЮрисдикции <> НачисленныйНалог.СтавкаИПДНалогаВИностраннойЮрисдикции
		|				ИЛИ ПоручениеЦенныеБумагиСписываемые.ПлановаяДатаРасчетов <> НАЧАЛОПЕРИОДА(НачисленныйНалог.Дата, ДЕНЬ)
		|				ИЛИ ПоручениеЦенныеБумагиСписываемые.Сумма <> НачисленныйНалог.СуммаВыплаты
		|				ИЛИ ПоручениеЦенныеБумагиСписываемые.Резидент <> НачисленныйНалог.Резидент
		|				ИЛИ ПоручениеЦенныеБумагиСписываемые.СуммаНалогаВИностраннойЮрисдикции <> НачисленныйНалог.СуммаНалогаВИностраннойЮрисдикции
		|			ТОГДА ИСТИНА
		|		ИНАЧЕ ЛОЖЬ
		|	КОНЕЦ КАК Перезаполнить,
		|	ПоручениеЦенныеБумагиСписываемые.СчетДепо КАК СчетДепо,
		|	ПоручениеЦенныеБумагиСписываемые.РазделСчетаДепо КАК РазделСчетаДепо,
		|	Поручение.ЦБ.Эмитент КАК Эмитент
		|ИЗ
		|	Документ.Поручение.ЦенныеБумагиСписываемые КАК ПоручениеЦенныеБумагиСписываемые
		|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.НачисленныйНалог КАК НачисленныйНалог
		|		ПО ПоручениеЦенныеБумагиСписываемые.Ссылка = НачисленныйНалог.Основание
		|			И ПоручениеЦенныеБумагиСписываемые.СчетДепо = НачисленныйНалог.СчетДепо
		|			И (НЕ НачисленныйНалог.ПометкаУдаления)
		|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.Поручение КАК Поручение
		|		ПО ПоручениеЦенныеБумагиСписываемые.Ссылка = Поручение.Ссылка
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.СчетаДепо КАК СчетаДепо
		|		ПО ПоручениеЦенныеБумагиСписываемые.СчетДепо = СчетаДепо.Ссылка
		|ГДЕ
		|	ПоручениеЦенныеБумагиСписываемые.Ссылка = &Ссылка
		|	И ПоручениеЦенныеБумагиСписываемые.ПлановаяДатаРасчетов = &ПлановаяДатаРасчетов
		|	И ВЫБОР
		|			КОГДА &КодДохода = &ПустойКодДохода
		|				ТОГДА ЛОЖЬ
		|			ИНАЧЕ ПоручениеЦенныеБумагиСписываемые.НачислитьНалог
		|		КОНЕЦ
		|	И СчетаДепо.Владелец.ЮрФизЛицо В(&ЮрФизЛицо)";
	
	Запрос.УстановитьПараметр("Ссылка", Поручение);
	Запрос.УстановитьПараметр("ЮрФизЛицо", СписокФизЮрЛиц);
	КодДохода = Документы.НачисленныйНалог.КодДоходаПоВидуОперации(Поручение.ВидОперацииД);
	Запрос.УстановитьПараметр("КодДохода"				, КодДохода);
	Запрос.УстановитьПараметр("КодДоходаПогашениеНКД"	, Справочники.ДоходыНДФЛ.Код1530);
	Запрос.УстановитьПараметр("ПустойКодДохода"			, Справочники.ДоходыНДФЛ.ПустаяСсылка());
	Запрос.УстановитьПараметр("ПлановаяДатаРасчетов", НачалоДня(ТекущаяДатаСеанса()));
	
	РезультатЗапроса = Запрос.Выполнить().Выгрузить();
	
	Если ТекущиеДанныеСчетДепо <> Неопределено Тогда
		Возврат РезультатЗапроса.НайтиСтроки(Новый Структура("СчетДепо", ТекущиеДанныеСчетДепо));	
	Иначе	
		Возврат РезультатЗапроса;
	КонецЕсли;
	
КонецФункции

// Функция - Это поручение прошло контроль по указу 520
// Проверяет поручение по указу 520
// Параметры:
//  Поручение	 - ДокументОбъект.Поручение - Поручение к проверке контроля
// 
// Возвращаемое значение:
//   - Булево
//
Функция ЭтоПоручениеПрошлоКонтрольПоУказу520(Поручение) Экспорт
	
	Если ТипЗнч(Поручение.ВидОперацииД) = Тип("СправочникСсылка.ВидыОпераций") Тогда
		БезПереходаПраваСобственности = Поручение.ОснованиеОперацииДКУ <> Справочники.КодыОснованияОперацийДКУ.TR01;
		КлассОперации = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Поручение.ВидОперацииД, "КлассОпераций");
		Если БезПереходаПраваСобственности И КлассОперации = Перечисления.КлассыОпераций.Инвентарные Тогда
			
			КатегорияДепонент = РегистрыСведений.КатегорииРолейКлиентовСогласноУказов81и95.КатегорияРолиКлиента(Поручение.Депонент, Поручение.Дата);
			КатегорияКонтрагент = РегистрыСведений.КатегорииРолейКлиентовСогласноУказов81и95.КатегорияРолиКлиента(Поручение.Контрагент, Поручение.Дата);
			ДепонентПодНадзором = Справочники.КатегорииРолейКлиентовСогласноУказов81и95.ПоднадзорнаяКатегория(КатегорияДепонент);
			КонтрагентПодНадзором = Справочники.КатегорииРолейКлиентовСогласноУказов81и95.ПоднадзорнаяКатегория(КатегорияКонтрагент);
			
			Если (ДепонентПодНадзором Или КонтрагентПодНадзором) Тогда
				
				Если Поручение.ВидОперацииД = Справочники.ВидыОпераций.Перевод Тогда
					ЭмитентыЦенныхБумаг = Справочники.Контрагенты.ЭмитентыЦенныхБумаг(Поручение.ЦБ);
				Иначе
					ЭмитентыЦенныхБумаг = Справочники.Контрагенты.ЭмитентыЦенныхБумаг(Поручение.ЦенныеБумагиСписываемые.ВыгрузитьКолонку("ЦеннаяБумага"));
				КонецЕсли;
				ЕстьЗапрещенныеЭмитенты = РегистрыСведений.ЭмитентыЗапрещенныеДляНедружественныхНерезидентов.ЭмитентЯвляетсяЗапрещенным(ЭмитентыЦенныхБумаг, Поручение.Дата);
				
				Если ЕстьЗапрещенныеЭмитенты Тогда
					ОбщегоНазначенияКлиентСервер.СообщитьПользователю( "По поручению № " + Поручение.Номер + " от "
						+ Поручение.Дата + " не пройден контроль по Указу № 520");
					Возврат Ложь;
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	Возврат Истина;
	
КонецФункции

/////////////////////////////////////////////////////////////////
// Создание/обновление документов ГлобальнаяОперация

// Создает/обновляет глобальные операции и выписки, подчиненные поручению.
// Если в отборе указан депонент, то только по данному депоненту.
//
// Параметры:
//  Поручение	 - ДокументСсылка.Поручение
//  Отказ		 - Булево - возвращает Ложь, если были ошибки
//  ДатаГО		 - Дата - новая дата документа ГлобальнаяОперация
//  Отбор		 - Структура, Неопределено - если Неопределено, то отбираются все документы, подчиненные поручению.
//                 если в структуре задан Депонент, то отбираются все документы, подчиненные поручению, по депоненту.
//    * Депонент - СправочникСсылка.Контрагенты - в случае отбора документов ГО и выписок по депоненту
//
Процедура СоздатьОбновитьДокументыГО(Поручение, Отказ, ДатаГО, Отбор = Неопределено) Экспорт
	// Получить документы ГлобальнаяОперация и Выписка, подчиненные данному поручению
	СтарыеДокументы = ДокументыГОВыпискаПодчиненныеПоручению(Поручение, Отбор);
	
	// Создать и/или обновить документы ГО, вернуть список актуальных документов ГО
	Если Поручение.ВидОперацииД = Справочники.ВидыОпераций.Конвертация Тогда
		АктуальныеДокументыГО = СоздатьОбновитьДокументыГОКонвертация(Поручение, Отказ, ДатаГО);
	ИначеЕсли ТипЗнч(Поручение.ВидОперацииД) = Тип("СправочникСсылка.ВидыОпераций") Тогда
		АктуальныеДокументыГО = СоздатьОбновитьДокументыГОСтандартные(Поручение, Отказ, ДатаГО, Отбор);
	Иначе
		Возврат;
	КонецЕсли;
	
	// Оставить только актуальные подчиненные документы, удалить лишние
	Если НЕ Отказ Тогда
		УдалитьЛишниеПодчиненныеДокументы(СтарыеДокументы, АктуальныеДокументыГО, Отказ);
	КонецЕсли;
КонецПроцедуры

Функция ДокументыГОВыпискаПодчиненныеПоручению(Поручение, Отбор)
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ГОперация.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.ГлобальнаяОперация КАК ГОперация
	|ГДЕ
	|	ГОперация.ДокументОснование = &ДокументОснование
	|	И &УсловиеОтбораГО
	|
	|ДЛЯ ИЗМЕНЕНИЯ
	|	Документ.ГлобальнаяОперация
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	Выписка.Ссылка
	|ИЗ
	|	Документ.Выписка КАК Выписка
	|ГДЕ
	|	Выписка.ДокументОснование = &ДокументОснование
	|	И &УсловиеОтбораВыписки
	|
	|ДЛЯ ИЗМЕНЕНИЯ
	|	Документ.Выписка";
	Запрос.УстановитьПараметр("ДокументОснование", Поручение);
	Если ТипЗнч(Отбор) = Тип("Структура") И Отбор.Свойство("Депонент") Тогда
		УсловиеОтбораГО = "ГОперация.СчетДепо.Владелец = &Депонент";
		УсловиеОтбораВыписки = "ВЫРАЗИТЬ(Выписка.СчетДепо КАК Справочник.СчетаДепо).Владелец = &Депонент";
		Запрос.УстановитьПараметр("Депонент", Отбор.Депонент);
	Иначе
		УсловиеОтбораГО = "Истина";
		УсловиеОтбораВыписки = "Истина";
	КонецЕсли;
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеОтбораГО", УсловиеОтбораГО);
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеОтбораВыписки", УсловиеОтбораВыписки);
	
	Возврат Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка");
КонецФункции

Функция СоздатьОбновитьДокументыГОКонвертация(Поручение, Отказ, ДатаГО)
	АктуальныеДокументы = Новый Массив;
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	ПоручениеСписание.СчетДепо			КАК СчетДепо,
	|	ПоручениеСписание.Ссылка			КАК Ссылка,
	|	ПоручениеСписание.РазделСчетаДепо	КАК РазделСчетаДепо,
	|	ПоручениеСписание.СчетДепоМХ		КАК СчетДепоМХ,
	|	ПоручениеСписание.РазделСчетаДепоМХ	КАК РазделСчетаДепоМХ,
	|	ПоручениеСписание.СтатусЦБ			КАК СтатусЦБ,
	|	ПоручениеСписание.ЦеннаяБумага		КАК ЦеннаяБумага,
	|	ПоручениеСписание.Количество		КАК Списание,
	|	0									КАК Зачисление
	|ПОМЕСТИТЬ Конвертация
	|ИЗ
	|	Документ.Поручение.Списание КАК ПоручениеСписание
	|ГДЕ
	|	ПоручениеСписание.Ссылка = &Ссылка
	|
	|ОБЪЕДИНИТЬ
	|
	|ВЫБРАТЬ
	|	ПоручениеЗачисление.СчетДепо,
	|	ПоручениеЗачисление.Ссылка,
	|	ПоручениеЗачисление.РазделСчетаДепо,
	|	ПоручениеЗачисление.СчетДепоМХ,
	|	ПоручениеЗачисление.РазделСчетаДепоМХ,
	|	ПоручениеЗачисление.СтатусЦБ,
	|	ПоручениеЗачисление.ЦеннаяБумага,
	|	0,
	|	ПоручениеЗачисление.Количество
	|ИЗ
	|	Документ.Поручение.Зачисление КАК ПоручениеЗачисление
	|ГДЕ
	|	ПоручениеЗачисление.Ссылка = &Ссылка
	|;
	|	
	|//////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Конвертация.СчетДепо			КАК СчетДепо,
	|	Глобальные.Ссылка				КАК ГОперация,
	|	Конвертация.РазделСчетаДепо		КАК РазделСчетаДепо,
	|	Конвертация.СчетДепоМХ			КАК СчетДепоМХ,
	|	Конвертация.РазделСчетаДепоМХ	КАК РазделСчетаДепоМХ,
	|	Конвертация.ЦеннаяБумага		КАК ЦеннаяБумага,
	|	Конвертация.СтатусЦБ			КАК СтатусЦБ,
	|	СУММА(Конвертация.Списание)		КАК Списание,
	|	СУММА(Конвертация.Зачисление)	КАК Зачисление
	|ИЗ
	|	Конвертация КАК Конвертация
	|	ЛЕВОЕ СОЕДИНЕНИЕ Документ.ГлобальнаяОперация КАК Глобальные
	|	ПО 
	|		Глобальные.ДокументОснование = Конвертация.Ссылка
	|		И Глобальные.СчетДепо = Конвертация.СчетДепо
	|
	|СГРУППИРОВАТЬ ПО
	|	Конвертация.СчетДепо,
	|	Глобальные.Ссылка,
	|	Конвертация.РазделСчетаДепо,
	|	Конвертация.СчетДепоМХ,
	|	Конвертация.РазделСчетаДепоМХ,
	|	Конвертация.ЦеннаяБумага,
	|	Конвертация.СтатусЦБ
	|
	|ДЛЯ ИЗМЕНЕНИЯ
	|	Документ.ГлобальнаяОперация
	|
	|ИТОГИ ПО
	|	Конвертация.СчетДепо,
	|	Глобальные.Ссылка
	|");
	Запрос.УстановитьПараметр("Ссылка", Поручение);
	ВыборкаСчетДепо = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Пока ВыборкаСчетДепо.Следующий() Цикл
		Выборка = ВыборкаСчетДепо.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		Пока Выборка.Следующий() Цикл
			// Получим объект
			Если ЗначениеЗаполнено(Выборка.ГОперация) Тогда
				ГОперация = Выборка.ГОперация.ПолучитьОбъект();
			Иначе
				ГОперация = Документы.ГлобальнаяОперация.СоздатьДокумент();
			КонецЕсли;
			// Очистим данные объекта перед заполненим
			ОчиститьДокументОтДанных(ГОперация);
			// Создадим краткую ссылку на основание
			Основание = Поручение;	
			// Заполним объект
			ГОперация.Дата							= ДатаГО;
			ГОперация.ВидГлобальнойОперации			= Основание.ВидОперацииД;
			ГОперация.Инициатор						= Основание.Инициатор;
			ГОперация.ДокументОснование				= Основание.Ссылка;			
			ГОперация.СчетДепо						= Выборка.СчетДепо;
			ГОперация.ТипКонвертации				= Основание.ТипКонвертации;
			ГОперация.ТарифныйПлан					= Константы.ОсновнойТарифныйПлан.Получить();
			ГОперация.Комментарий					= Основание.Комментарий;
			ГОперация.Автор							= ПараметрыСеанса.ТекущийПользователь;
			ГОперация.ДатаИсполненияВДепозитарииМХ	= Основание.ДатаИсполненияПорученияВДепозитарииМХ;
			ГОперация.ДатаИсполненияВМестеРасчетов	= Основание.ДатаИсполненияПорученияВМестеРасчетов;
			ГОперация.ДатаФиксации					= Основание.ДатаФиксации;
			ГОперация.ДатаВнесенияЗаписиВЕГРЮЛ		= Основание.ДатаВнесенияЗаписиВЕГРЮЛ;
			
			// Обойдем подстроки запроса и заполним ТЧ ГО
			ВыборкаСтроки = Выборка.Выбрать();
			Пока ВыборкаСтроки.Следующий() Цикл
				// Таблица списания
				Если ВыборкаСтроки.Списание <> 0 Тогда
					СтрокаСписания	= ГОперация.Списание.Добавить();
					
					СтрокаСписания.РазделСчетаДепо		= ВыборкаСтроки.РазделСчетаДепо;
					СтрокаСписания.СчетДепоМХ			= ВыборкаСтроки.СчетДепоМХ;
					СтрокаСписания.РазделСчетаДепоМХ	= ВыборкаСтроки.РазделСчетаДепоМХ;
					СтрокаСписания.ЦеннаяБумага			= ВыборкаСтроки.ЦеннаяБумага;
					СтрокаСписания.СтатусЦБ				= ВыборкаСтроки.СтатусЦБ;
					СтрокаСписания.Количество			= ВыборкаСтроки.Списание;
				КонецЕсли;
				// Таблица зачисления
				Если ВыборкаСтроки.Зачисление <> 0 Тогда
					СтрокаЗачисление= ГОперация.Зачисление.Добавить();
					
					СтрокаЗачисление.РазделСчетаДепо	= ВыборкаСтроки.РазделСчетаДепо;
					СтрокаЗачисление.СчетДепоМХ			= ВыборкаСтроки.СчетДепоМХ;
					СтрокаЗачисление.РазделСчетаДепоМХ	= ВыборкаСтроки.РазделСчетаДепоМХ;
					СтрокаЗачисление.ЦеннаяБумага		= ВыборкаСтроки.ЦеннаяБумага;
					СтрокаЗачисление.СтатусЦБ			= ВыборкаСтроки.СтатусЦБ;
					СтрокаЗачисление.Количество			= ВыборкаСтроки.Зачисление;
				КонецЕсли;
			КонецЦикла;
			// Запишем операцию
			ГОперация.Записать(РежимЗаписиДокумента.Проведение);
			
			// Добавим операцию в список актуальных
			АктуальныеДокументы.Добавить(ГОперация.Ссылка);
		КонецЦикла;	
	КонецЦикла;	
	Возврат АктуальныеДокументы;
КонецФункции

Функция СоздатьОбновитьДокументыГОСтандартные(Поручение, Отказ, ДатаГО, Отбор)
	АктуальныеДокументы = Новый Массив;
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	Поручение.Ссылка КАК Поручение,
	|	Глобальные.Ссылка КАК ГОперация,
	|	Поручение.СчетДепо КАК СчетДепо,
	|	Поручение.РазделСчетаДепо КАК РазделСчетаДепо,
	|	Поручение.СчетДепоМХ КАК СчетДепоМХ,
	|	Поручение.РазделСчетаДепоМХ КАК РазделСчетаДепоМХ,
	|	ВЫРАЗИТЬ(Поручение.Комментарий КАК СТРОКА(512)) КАК КомментарийВСтроке,
	|	СУММА(Поручение.Количество) КАК Количество,
	|	СУММА(Поручение.КоличествоБазовойЦБ) КАК КоличествоБазовойЦБ,
	|	СУММА(Поручение.Сумма) КАК Сумма,
	|	СУММА(Поручение.СуммаНалога) КАК СуммаНалога,
	|	СУММА(Поручение.СуммаКВыплатеПоИПД) КАК СуммаКВыплатеПоИПД,
	|	МАКСИМУМ(Поручение.НДФЛУдержан) КАК НДФЛУдержан
	|ИЗ
	|	Документ.Поручение.ЦенныеБумагиСписываемые КАК Поручение
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ГлобальнаяОперация.ЦенныеБумаги КАК Глобальные
	|		ПО (Глобальные.Ссылка.ДокументОснование = Поручение.Ссылка)
	|			И (Глобальные.Ссылка.СчетДепо = Поручение.СчетДепо)
	|			И (Глобальные.РазделСчетаДепо = Поручение.РазделСчетаДепо)
	|			И (Глобальные.СчетДепоМХ = Поручение.СчетДепоМХ)
	|			И (Глобальные.РазделСчетаДепоМХ = Поручение.РазделСчетаДепоМХ)
	|ГДЕ
	|	Поручение.Ссылка = &Ссылка
	|	И &УсловиеОтбора
	|
	|СГРУППИРОВАТЬ ПО
	|	Поручение.Ссылка,
	|	Глобальные.Ссылка,
	|	Поручение.СчетДепо,
	|	Поручение.РазделСчетаДепо,
	|	Поручение.СчетДепоМХ,
	|	Поручение.РазделСчетаДепоМХ,
	|	ВЫРАЗИТЬ(Поручение.Комментарий КАК СТРОКА(512))
	|
	|ДЛЯ ИЗМЕНЕНИЯ
	|	Документ.ГлобальнаяОперация
	|ИТОГИ ПО
	|	СчетДепо,
	|	ГОперация");
	Запрос.УстановитьПараметр("Ссылка", Поручение);
	
	Если ТипЗнч(Отбор) = Тип("Структура") И Отбор.Свойство("Депонент") Тогда
		УсловиеОтбора = "Поручение.СчетДепо.Владелец = &Депонент";
		Запрос.УстановитьПараметр("Депонент", Отбор.Депонент);
	Иначе
		УсловиеОтбора = "Истина";
	КонецЕсли;
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеОтбора", УсловиеОтбора);
	
	ВыборкаСчетДепо = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		
	РеквизитыЦБ = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Поручение.ЦБ,
		Новый Структура("ЮридическоеЛицо, ВидЦББанкаРоссии, ВидЦБ, ТипЦБ",
			"Эмитент.ЮридическиеФизическиеЛица",
			"ВидЦББанкаРоссии", "ВидЦБ", "ТипЦБ"));
	ЭтоМК = РегистрыСведений.ЮридическиеЛицаМеждународныеКомпании.ЭтоМК(ДатаГО, РеквизитыЦБ.ЮридическоеЛицо);
	ЭтоИностраннаяЦеннаяБумага = Справочники.ВидыЦББанкаРоссии.ЭтоВидИностраннойЦБ(РеквизитыЦБ.ВидЦББанкаРоссии) И Не ЭтоМК;
	ВалютаДенежныхСредств = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Поручение.БанковскийСчет, "ВалютаДенежныхСредств");
		
	ЭтоВыплатаДоходаПоПрогрессивнойШкалеНДФЛ = ЭтоВыплатаДоходаПоПрогрессивнойШкалеНДФЛ(Поручение);
	Если ЭтоВыплатаДоходаПоПрогрессивнойШкалеНДФЛ Тогда
		ДанныеИнфоПолей = ДанныеНалоговыхДокументов(Поручение);
	КонецЕсли;
	
	Пока ВыборкаСчетДепо.Следующий() Цикл
		Выборка = ВыборкаСчетДепо.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		Пока Выборка.Следующий() Цикл
	
			// Получим объект
			Если ЗначениеЗаполнено(Выборка.ГОперация) Тогда
				ГОперация = Выборка.ГОперация.ПолучитьОбъект();
			Иначе
				ГОперация = Документы.ГлобальнаяОперация.СоздатьДокумент();
			КонецЕсли;
			
			// Очистим данные объекта перед заполненим
			ОчиститьДокументОтДанных(ГОперация);
			
			// Создадим краткую ссылку на основание
			Основание = Поручение;
			
			// Заполним объект
			ГОперация.Дата							= ДатаГО;
			ГОперация.ВидГлобальнойОперации			= Основание.ВидОперацииД;
			ГОперация.Инициатор						= Основание.Инициатор;
			ГОперация.ДокументОснование				= Основание.Ссылка;			
			ГОперация.ЦеннаяБумага					= Основание.ЦБ;
			ГОперация.СчетДепо						= Выборка.СчетДепо;
			ГОперация.Автор							= ПараметрыСеанса.ТекущийПользователь;
			ГОперация.ДатаИсполненияВДепозитарииМХ	= Основание.ДатаИсполненияПорученияВДепозитарииМХ;
			ГОперация.ДатаИсполненияВМестеРасчетов	= Основание.ДатаИсполненияПорученияВМестеРасчетов;
			ГОперация.ДатаФиксации					= Основание.ДатаФиксации;
			ГОперация.ВыплатаНа1ЦБ					= Основание.ВыплатаНа1ЦБ;
			ГОперация.ПлатежныйАгент				= Основание.ПлатежныйАгент;
			ГОперация.ЦеннаяБумагаБазовая			= Основание.ЦББазовая;
			
			// Заполним реквизиты по типу операции
			Если Основание.ВидОперацииД = Справочники.ВидыОпераций.НачислениеДивидендов
				ИЛИ Основание.ВидОперацииД = Справочники.ВидыОпераций.НачислениеДоходовЦБ
				ИЛИ Основание.ВидОперацииД = Справочники.ВидыОпераций.НачислениеДоходаПрочие Тогда
				ГОперация.БанковскийСчет	= Основание.БанковскийСчет;
				
			ИначеЕсли Основание.ВидОперацииД = Справочники.ВидыОпераций.Погашение 
				ИЛИ Основание.ВидОперацииД = Справочники.ВидыОпераций.СписаниеАкцийПриЛиквидацииЭмитента
				ИЛИ Основание.ВидОперацииД = Справочники.ВидыОпераций.СписаниеОбесценившихсяЦенныхБумаг
				ИЛИ Основание.ВидОперацииД = Справочники.ВидыОпераций.ВыкупСписаниеЦБ Тогда 
				ГОперация.Инициатор		= Основание.Инициатор;
				ГОперация.Комментарий	= Строка(Основание);
				
			ИначеЕсли Основание.ВидОперацииД = Справочники.ВидыОпераций.ПогашениеНКД
				ИЛИ Основание.ВидОперацииД = Справочники.ВидыОпераций.Выкуп
				ИЛИ	Основание.ВидОперацииД = Справочники.ВидыОпераций.ПогашениеЦБПолное
				ИЛИ Основание.ВидОперацииД = Справочники.ВидыОпераций.ПогашениеЦБЧастичное
				Тогда
				ГОперация.БанковскийСчет = Основание.БанковскийСчет;
				
				ВалютаРегламентированногоУчета = Константы.ВалютаРегламентированногоУчета.Получить();
				Если Поручение.БанковскийСчет.ВалютаДенежныхСредств = ВалютаРегламентированногоУчета Тогда
					ГОперация.Биржа	= Справочники.Биржи.MICEX;
				Иначе
					ГОперация.Биржа	= Справочники.Биржи.Внебирж;
				КонецЕсли;
				
			Иначе
				ОбщегоНазначения.СообщитьОбОшибке("На основании данного вида поручения нельзя создать документ ""Глобальная операция"". 
				|Вид операции не соответствует документу!", Отказ);
				Возврат АктуальныеДокументы;	
			КонецЕсли;
			
			// Обойдем подстроки запроса и заполним ТЧ ЦенныеБумаги
			ВыборкаСтроки = Выборка.Выбрать();
			Пока ВыборкаСтроки.Следующий() Цикл
				НоваяСтрокаЦБ = ГОперация.ЦенныеБумаги.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрокаЦБ, ВыборкаСтроки);
				
				Если Не ВыборкаСтроки.НДФЛУдержан И ЭтоВыплатаДоходаПоПрогрессивнойШкалеНДФЛ Тогда
					Отбор = Новый Структура("СчетДепо, РазделСчетаДепо", ВыборкаСтроки.СчетДепо, ВыборкаСтроки.РазделСчетаДепо);
					НайденныеСтроки = ДанныеИнфоПолей.НайтиСтроки(Отбор);
					Если НайденныеСтроки.Количество() > 0 Тогда
						НоваяСтрокаЦБ.СуммаНалога = НайденныеСтроки[0].СуммаОбязательствПоУплатеНалога
							+ НайденныеСтроки[0].СуммаНалогаПоСтавке15СПревышения;
					КонецЕсли;
				КонецЕсли;
				
				Если РеквизитыЦБ.ТипЦБ = Перечисления.ТипыЦБ.Облигация
					И РеквизитыЦБ.ВидЦБ = Перечисления.ВидыОблигаций.Государственная
					И ВалютаДенежныхСредств <> Константы.ВалютаРегламентированногоУчета.Получить() Тогда
					НоваяСтрокаЦБ.СуммаБезНалога = НоваяСтрокаЦБ.Сумма;
				ИначеЕсли ЭтоИностраннаяЦеннаяБумага Тогда
					НоваяСтрокаЦБ.СуммаБезНалога = ВыборкаСтроки.СуммаКВыплатеПоИПД;
				Иначе 
					НоваяСтрокаЦБ.СуммаБезНалога = НоваяСтрокаЦБ.Сумма - НоваяСтрокаЦБ.СуммаНалога;
				КонецЕсли;
				
				НоваяСтрокаЦБ.ЦеннаяБумага = Основание.ЦБ;
				
				Если ТипЗнч(Основание.ВидОперацииД) = Тип("СправочникСсылка.ВидыОпераций")
					И Основание.ВидОперацииД.ВыплатаДоходаВДенежнойФорме Тогда
					ГОперация.Комментарий = СтрШаблон("%1%2%3",
						СокрЛП(Основание.Комментарий),
						?(ЗначениеЗаполнено(ВыборкаСтроки.КомментарийВСтроке), " ", ""),
						СокрЛП(ВыборкаСтроки.КомментарийВСтроке));
				КонецЕсли;
			КонецЦикла;
			
			// Запишем операцию
			ГОперация.Записать(РежимЗаписиДокумента.Проведение);
			
			// Добавим операцию в список актуальных
			АктуальныеДокументы.Добавить(ГОперация.Ссылка);
		КонецЦикла;
	КонецЦикла;
	Возврат АктуальныеДокументы;
КонецФункции

Процедура УдалитьЛишниеПодчиненныеДокументы(СтарыеДокументы, АктуальныеДокументы, Отказ)
	// Дополнить список АктуальныеДокументы связанными документами Выписка
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Выписка.Ссылка
	|ИЗ
	|	Документ.Выписка КАК Выписка
	|ГДЕ
	|	ВЫРАЗИТЬ(Выписка.ОперацияЦБ КАК Документ.ГлобальнаяОперация) В (&ГлобальныеОперации)";
	Запрос.УстановитьПараметр("ГлобальныеОперации", АктуальныеДокументы);
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		АктуальныеДокументы.Добавить(Выборка.Ссылка);
	КонецЦикла;
	
	// Удалить документы из СтарыеДокументы, не попавшие в АктуальныеДокументы
	Сообщение = Новый СообщениеПользователю();
	Для Каждого СтарыйДокумент из СтарыеДокументы Цикл
		Если АктуальныеДокументы.Найти(СтарыйДокумент) = Неопределено Тогда
			ДокументОбъект = СтарыйДокумент.ПолучитьОбъект();
			Если ДокументОбъект <> Неопределено Тогда
				Сообщение.Текст = Сообщение.Текст + "Удален документ: " + ДокументОбъект + Символы.ПС;
				ДокументОбъект.Удалить();
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;	
	Если ЗначениеЗаполнено(Сообщение.Текст) Тогда
		Сообщение.Сообщить();
	КонецЕсли;
КонецПроцедуры

Процедура ОчиститьДокументОтДанных(ДокументОбъект)
	МетаданныеОбъекта = ДокументОбъект.Метаданные();
	// Ревизиты простые
	Для Каждого Реквизит Из МетаданныеОбъекта.Реквизиты Цикл
		ДокументОбъект[Реквизит.Имя] = "";
	КонецЦикла;
	// Табличные части
	Для Каждого МетаТЧ Из МетаданныеОбъекта.ТабличныеЧасти Цикл
		ДокументОбъект[МетаТЧ.Имя].Очистить();
	КонецЦикла;
КонецПроцедуры

// Возвращает максимальные допустимые плановые даты расчетов для переданных счетов Депо.
//
// Параметры:
//  ДатаПоручения - Дата - Дата поручения
//  СчетаДепо	 - Массив - Массив элементов СправочникСсылка.СчетДепо
// 
// Возвращаемое значение:
//  Соответствие:
//    Ключ - СправочникСсылка.СчетДепо
//    Значение - Дата - максимальная плановая дата расчетов
//
Функция МаксимальныеПлановыеДатыРасчетов(ДатаПоручения, СчетаДепо) Экспорт
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	СчетаДепо.Ссылка КАК СчетДепо,
	|	ВЫБОР
	|		КОГДА СчетаДепо.ТипСчетаДепо В (&ТипСчетаДепоТ1)
	|			ТОГДА &ДатаТ1
	|		ИНАЧЕ &ДатаТ7
	|	КОНЕЦ КАК МаксПлановаяДата
	|ИЗ
	|	Справочник.СчетаДепо КАК СчетаДепо
	|ГДЕ
	|	СчетаДепо.Ссылка В (&СчетаДепо)";
	ТипСчетаДепоТ1 = Новый Массив;
	ТипСчетаДепоТ1.Добавить(Перечисления.ТипыСчетовДепо.ДоверительногоУправляющего);
	ТипСчетаДепоТ1.Добавить(Перечисления.ТипыСчетовДепо.ДоверительногоУправляющегоТорговый);
	ТипСчетаДепоТ1.Добавить(Перечисления.ТипыСчетовДепо.НоминальногоДержателя);
	ТипСчетаДепоТ1.Добавить(Перечисления.ТипыСчетовДепо.НоминальногоДержателяТорговый);
	Запрос.УстановитьПараметр("ТипСчетаДепоТ1", ТипСчетаДепоТ1);
	Запрос.УстановитьПараметр("СчетаДепо", СчетаДепо);
	Запрос.УстановитьПараметр("ДатаТ1", ОбщегоНазначения.ДобавитьРабочийДень(НачалоДня(ДатаПоручения), РегистрыСведений.ПараметрыГлобальные.ЗначениеПараметра("МаксимальныйПериодВыплатыДУ",1)));
	Запрос.УстановитьПараметр("ДатаТ7", ОбщегоНазначения.ДобавитьРабочийДень(НачалоДня(ДатаПоручения),  РегистрыСведений.ПараметрыГлобальные.ЗначениеПараметра("МаксимальныйПериодВыплаты",7)));
	
	Результат = Новый Соответствие;
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		Результат.Вставить(Выборка.СчетДепо, Выборка.МаксПлановаяДата);
	КонецЦикла;
	Возврат результат;
КонецФункции

// Заполняет в переданной табличной части поле ВалютаНалога расчитанным значением.
//
// Параметры:
//  Поручение	 - ДокументСсылка.Поручение	 - Ссылка на документ Поручение
//  ТабличнаяЧасть	 - Табличная часть	 - Табличная часть ЦенныеБумагиСписываемые документа Поручение
//
Процедура ЗаполнитьВалютуНалога(Поручение, ТабличнаяЧасть) Экспорт
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ВЫБОР
	|		КОГДА Поручение.БанковскийСчет.ВалютаДенежныхСредств = &Рубль
	|				ИЛИ Поручение.ЦБ.ТипЦБ = &ТипыЦБОблигации
	|					И (ВЫРАЗИТЬ(Поручение.ЦБ.ВидЦБ КАК Перечисление.ВидыОблигаций)) = &ВидыОблигацийГосударственная
	|			ТОГДА &Рубль
	|		ИНАЧЕ Поручение.БанковскийСчет.ВалютаДенежныхСредств
	|	КОНЕЦ КАК ВалютаНалога
	|ИЗ
	|	Документ.Поручение КАК Поручение
	|ГДЕ
	|	Поручение.Ссылка = &Ссылка";
	Запрос.УстановитьПараметр("Рубль", Справочники.Валюты.Рубль());
	Запрос.УстановитьПараметр("ТипыЦБОблигации", Перечисления.ТипыЦБ.Облигация);
	Запрос.УстановитьПараметр("ВидыОблигацийГосударственная", Перечисления.ВидыОблигаций.Государственная);
	Запрос.УстановитьПараметр("Ссылка", Поручение);
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		ВалютаНалога = Выборка.ВалютаНалога;
	Иначе
		ВалютаНалога = Поручение.Валюта;
	КонецЕсли;
	Для Каждого Строка Из ТабличнаяЧасть Цикл
		Строка.ВалютаНалога = ВалютаНалога;
	КонецЦикла;
КонецПроцедуры

// Заполняет в переданной табличной части поле ПлановаяДатаРасчетов.
//
// Параметры:
//  Поручение		 - ДокументСсылка.Поручение	 - Ссылка на документ Поручение
//  ТабличнаяЧасть	 - Табличная часть	 - Табличная часть ЦенныеБумагиСписываемые документа Поручение
//
Процедура ЗаполнитьПлановуюДатуРасчетов(Поручение, ТабличнаяЧасть) Экспорт
	Для Каждого Строка Из ТабличнаяЧасть Цикл
		Строка.ПлановаяДатаРасчетов = Поручение.ПланируемаяДатаРасчетов;
	КонецЦикла;
КонецПроцедуры

// Возвращает данные налоговых документов, подчиненных поручению.
//
// Параметры:
//  Поручение			 - ДокументСсылка.Поручение	 - Поручение, для которого выбираются данные.
//  КлючСтрокиПоручения	 - Структура				 - Структура с ключами: СчетДепо, РазделСчетаДепо (Неопределено - по всему поручению в целом)
//  БезПлатежей			 - Булево					 - Выбирать только данные налоговых документов
// 
// Возвращаемое значение:
//  Таблица - значений:
//  * СчетДепо - СправочникСсылка.СчетаДепо
//  * РазделСчетаДепо - СправочникСсылка.РазделыСчетаДепо
//  * СуммаОбязательствПоУплатеНалога - Число
//  * СуммаНалогаПоСтавке15СПревышения - Число
//  * Ставка - Число
//  * СуммаКВыплатеПоОсновнаяСтавка - Число
//  * СуммаКВыплатеПоПовышеннаяСтавка - Число
//  * СтавкаНалогаПовышенная - Число
//  * ДатаПередачиДоходаКлиенту - Дата
//  * ДатаУплатыНалога - Дата
//  * СуммаОплаченногоНалога - Число
//
Функция ДанныеНалоговыхДокументов(Поручение, КлючСтрокиПоручения = Неопределено, БезПлатежей = Ложь) Экспорт
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	НачисленныйНалог.СчетДепо КАК СчетДепо,
	|	НачисленныйНалог.РазделСчетаДепо КАК РазделСчетаДепо,
	|	НачисленныйНалог.СуммаНалога КАК СуммаОбязательствПоУплатеНалога,
	|	НачисленныйНалог.СуммаНалогаПоСтавке15СПревышения КАК СуммаНалогаПоСтавке15СПревышения,
	|	НачисленныйНалог.Ставка КАК Ставка,
	|	НачисленныйНалог.СуммаКВыплатеПоОсновнаяСтавка КАК СуммаКВыплатеПоОсновнаяСтавка,
	|	НачисленныйНалог.СуммаКВыплатеПоПовышеннаяСтавка КАК СуммаКВыплатеПоПовышеннаяСтавка,
	|	НачисленныйНалог.СтавкаНалогаПовышенная КАК СтавкаНалогаПовышенная,
	|	ДАТАВРЕМЯ(1, 1, 1) КАК ДатаПередачиДоходаКлиенту,
	|	ДАТАВРЕМЯ(1, 1, 1) КАК ДатаУплатыНалога,
	|	0 КАК СуммаОплаченногоНалога
	|ПОМЕСТИТЬ втДанные
	|ИЗ
	|	Документ.НачисленныйНалог КАК НачисленныйНалог
	|ГДЕ
	|	НачисленныйНалог.Основание = &Поручение
	|	И ВЫБОР
	|			КОГДА &ПоВсемСчетамИРазделам
	|				ТОГДА ИСТИНА
	|			ИНАЧЕ НачисленныйНалог.СчетДепо = &СчетДепо
	|					И НачисленныйНалог.РазделСчетаДепо = &РазделСчетаДепо
	|		КОНЕЦ
	|	И НЕ НачисленныйНалог.ПометкаУдаления
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ПлатежнаяОперацияВыплатаДохода.СчетДепо,
	|	ПлатежнаяОперацияВыплатаДохода.РазделСчетаДепо,
	|	0,
	|	0,
	|	NULL,
	|	0,
	|	0,
	|	NULL,
	|	НАЧАЛОПЕРИОДА(ПлатежнаяОперацияВыплатаДохода.Дата, ДЕНЬ),
	|	ДАТАВРЕМЯ(1, 1, 1),
	|	0
	|ИЗ
	|	Документ.ПлатежнаяОперация КАК ПлатежнаяОперацияВыплатаДохода
	|ГДЕ
	|	&БезПлатежей = ЛОЖЬ
	|	И ПлатежнаяОперацияВыплатаДохода.Основание = &Поручение
	|	И ПлатежнаяОперацияВыплатаДохода.ВидОперации = &ВыплатаДохода
	|	И ВЫБОР
	|			КОГДА &ПоВсемСчетамИРазделам
	|				ТОГДА ИСТИНА
	|			ИНАЧЕ ПлатежнаяОперацияВыплатаДохода.СчетДепо = &СчетДепо
	|					И ПлатежнаяОперацияВыплатаДохода.РазделСчетаДепо = &РазделСчетаДепо
	|		КОНЕЦ
	|	И ПлатежнаяОперацияВыплатаДохода.Проведен
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ПлатежнаяОперацияОплатаНалога.СчетДепо,
	|	ПлатежнаяОперацияОплатаНалога.РазделСчетаДепо,
	|	0,
	|	0,
	|	NULL,
	|	0,
	|	0,
	|	NULL,
	|	ДАТАВРЕМЯ(1, 1, 1),
	|	НАЧАЛОПЕРИОДА(ПлатежнаяОперацияОплатаНалога.Дата, ДЕНЬ),
	|	ПлатежнаяОперацияОплатаНалога.Сумма
	|ИЗ
	|	Документ.ПлатежнаяОперация КАК ПлатежнаяОперацияОплатаНалога
	|ГДЕ
	|	&БезПлатежей = ЛОЖЬ
	|	И ПлатежнаяОперацияОплатаНалога.Основание = &Поручение
	|	И ПлатежнаяОперацияОплатаНалога.ВидОперации = &ОплатаНалога
	|	И ВЫБОР
	|			КОГДА &ПоВсемСчетамИРазделам
	|				ТОГДА ИСТИНА
	|			ИНАЧЕ ПлатежнаяОперацияОплатаНалога.СчетДепо = &СчетДепо
	|					И ПлатежнаяОперацияОплатаНалога.РазделСчетаДепо = &РазделСчетаДепо
	|		КОНЕЦ
	|	И ПлатежнаяОперацияОплатаНалога.Проведен
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	втДанные.СчетДепо КАК СчетДепо,
	|	втДанные.РазделСчетаДепо КАК РазделСчетаДепо,
	|	СУММА(втДанные.СуммаОбязательствПоУплатеНалога) КАК СуммаОбязательствПоУплатеНалога,
	|	СУММА(втДанные.СуммаНалогаПоСтавке15СПревышения) КАК СуммаНалогаПоСтавке15СПревышения,
	|	СУММА(втДанные.СуммаКВыплатеПоОсновнаяСтавка) КАК СуммаКВыплатеПоОсновнаяСтавка,
	|	СУММА(втДанные.СуммаКВыплатеПоПовышеннаяСтавка) КАК СуммаКВыплатеПоПовышеннаяСтавка,
	|	МАКСИМУМ(втДанные.ДатаПередачиДоходаКлиенту) КАК ДатаПередачиДоходаКлиенту,
	|	МАКСИМУМ(втДанные.ДатаУплатыНалога) КАК ДатаУплатыНалога,
	|	МАКСИМУМ(втДанные.Ставка) КАК СтавкаНалогаНачисленныйНалог,
	|	МАКСИМУМ(втДанные.СтавкаНалогаПовышенная) КАК СтавкаНалогаПовышеннаяНачисленныйНалог,
	|	СУММА(втДанные.СуммаОплаченногоНалога) КАК СуммаОплаченногоНалога
	|ИЗ
	|	втДанные КАК втДанные
	|
	|СГРУППИРОВАТЬ ПО
	|	втДанные.СчетДепо,
	|	втДанные.РазделСчетаДепо";
	
	Если КлючСтрокиПоручения = Неопределено Тогда
		Запрос.УстановитьПараметр("ПоВсемСчетамИРазделам", Истина);
		Запрос.УстановитьПараметр("СчетДепо", Неопределено);
		Запрос.УстановитьПараметр("РазделСчетаДепо", Неопределено);
	Иначе
		Запрос.УстановитьПараметр("ПоВсемСчетамИРазделам", Ложь);
		Запрос.УстановитьПараметр("СчетДепо", КлючСтрокиПоручения.СчетДепо);
		Запрос.УстановитьПараметр("РазделСчетаДепо", КлючСтрокиПоручения.РазделСчетаДепо);
	КонецЕсли;
	Запрос.УстановитьПараметр("БезПлатежей", БезПлатежей);
	Запрос.УстановитьПараметр("Поручение", Поручение);
	Запрос.УстановитьПараметр("ВыплатаДохода", Перечисления.ВидыПлатежныхОпераций.ВыплатаДохода);
	Запрос.УстановитьПараметр("ОплатаНалога", Перечисления.ВидыПлатежныхОпераций.ОплатаНалога);
	Возврат Запрос.Выполнить().Выгрузить();
КонецФункции

// Заполняет в переданной табличной части поле СуммаНалога расчитанным значением.
//
// Параметры:
//  Поручение	 - ДокументСсылка.Поручение	 - Ссылка на документ Поручение
//  ТабличнаяЧасть	 - Табличная часть	 - Табличная часть ЦенныеБумагиСписываемые документа Поручение
//
Процедура ЗаполнитьСуммуНалога(Поручение, ТабличнаяЧасть) Экспорт
	ДанныеИнфоПолей = ДанныеНалоговыхДокументов(Поручение);
	Для Каждого Строка Из ТабличнаяЧасть Цикл
		Если Строка.НДФЛУдержан Тогда
			Продолжить;
		КонецЕсли;
		
		Отбор = Новый Структура("СчетДепо, РазделСчетаДепо", Строка.СчетДепо, Строка.РазделСчетаДепо);
		НайденныеСтроки = ДанныеИнфоПолей.НайтиСтроки(Отбор);
		Если НайденныеСтроки.Количество() > 0 Тогда
			Строка.СуммаНалога = НайденныеСтроки[0].СуммаОплаченногоНалога;
		Иначе
			Строка.СуммаНалога = 0;
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

// Удаляет документы, созданные на основании поручения
//
// Параметры:
//  Поручение					 - ДокументСсылка.Поручение
//  УдалятьПодчиненныеПоручения	 - Булево - Истина, если нужно также удалять и подчиненные поручения.
//  Отбор	- Структура:
//    * Депонент - СправочникСсылка.Контрагенты - если определен, то удаляются только подчиненные
//                 глобальные операции и выписки с данным владельцем счета депо
//
Процедура УдалитьДокументыНаОснованииПоручения(Поручение, УдалятьПодчиненныеПоручения, Отбор = Неопределено) Экспорт
	Сообщение = Новый СообщениеПользователю();
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	ДокументыПоПоручению.Ссылка КАК Ссылка
	|ИЗ
	|	КритерийОтбора.СтруктураПодчиненности(&Ссылка) КАК ДокументыПоПоручению
	|ГДЕ
	|	НЕ ДокументыПоПоручению.Ссылка.ПометкаУдаления
	|	И НЕ ДокументыПоПоручению.Ссылка ССЫЛКА Документ.ТехническаяОперация
	|	И НЕ ДокументыПоПоручению.Ссылка ССЫЛКА Документ.УведомлениеКлиентам
	|	И (&УдалятьПодчиненныеПоручения
	|			ИЛИ НЕ ДокументыПоПоручению.Ссылка ССЫЛКА Документ.Поручение)
	|	И &ОтборВыписокГлобальныхОпераций");
	Запрос.УстановитьПараметр("Ссылка", Поручение);
	Запрос.УстановитьПараметр("УдалятьПодчиненныеПоручения", УдалятьПодчиненныеПоручения);
	
	Если ТипЗнч(Отбор) = Тип("Структура") И Отбор.Свойство("Депонент") Тогда
		УсловиеОтбора =
		"(ВЫРАЗИТЬ(Ссылка КАК Документ.ГлобальнаяОперация).СчетДепо.Владелец = &Депонент
		|	ИЛИ ВЫРАЗИТЬ(Ссылка КАК Документ.Выписка).СчетДепо.Владелец = &Депонент)";
		Запрос.УстановитьПараметр("Депонент", Отбор.Депонент);
	Иначе
		УсловиеОтбора = "Истина";
	КонецЕсли;
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "&ОтборВыписокГлобальныхОпераций", УсловиеОтбора);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		ДокументОбъект = Выборка.Ссылка.ПолучитьОбъект();
		Если ДокументОбъект <> Неопределено Тогда
			Сообщение.Текст = Сообщение.Текст + "Удален документ: " + ДокументОбъект + Символы.ПС;
			ДокументОбъект.Удалить();
		КонецЕсли;
	КонецЦикла;
	
	Если ЗначениеЗаполнено(Сообщение.Текст) Тогда
		Сообщение.Сообщить();
	КонецЕсли;
КонецПроцедуры

#Область CSDR_Поручение

// Функция - Получить номер поручения в выгрузке ВНРД
//
// Параметры:
//  Поручение - 	 - 
// 
// Возвращаемое значение: Строка - номер связанной с Поручением тех.операции
//   - 
//
Функция НомерПорученияВВыгрузкеВНРД(Поручение) Экспорт
	Результат = "";
	
	Если Не ЗначениеЗаполнено(Поручение) Тогда
		Возврат Результат;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Поручение",Поручение);
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	ТехОперация.Номер КАК Номер
	|ИЗ
	|	Документ.ТехническаяОперация КАК ТехОперация
	|ГДЕ
	|	ТехОперация.ДокументОснование = &Поручение
	|	И НЕ ТехОперация.ПометкаУдаления";
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда // только 1 запись  (или 0)
		Результат = ВыборкаДетальныеЗаписи.Номер;
	КонецЕсли;
	
	Возврат Результат;
КонецФункции

// Функция - Передавать в бэк офис CSDR
//
// Параметры:
//  Поручение - 	 - 
//  ВидОтвета	 - 	 - "ВидОперацииДдляCSDR" - вместо Истина возвращать ВидОперацииД Поручения, вместо Ложь - Неопределено
// 
// Возвращаемое значение: Истина\Ложь (т.е. надо передавать или нет Поручение в ИЦ), с учетом входящего параметра ВидОтвета
//   - 
//
Функция ПередаватьВБэкОфисCSDR(Поручение, ВидОтвета = "ВидОперацииДдляCSDR") Экспорт
	Если ВидОтвета = "ВидОперацииДдляCSDR" Тогда
		Результат = Неопределено;
	Иначе
		Результат = Ложь;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(Поручение) Тогда
		Возврат Результат;
	КонецЕсли;
	
	спВидовПорученийCSDR = Новый СписокЗначений;
	спВидовПорученийCSDR.Добавить(Справочники.ВидыИнвентарныхПоручений.П37);
	спВидовПорученийCSDR.Добавить(Справочники.ВидыИнвентарныхПоручений.П36);
	спВидовПорученийCSDR.Добавить(Справочники.ВидыИнвентарныхПоручений.П36_2);
	спВидовПорученийCSDR.Добавить(Справочники.ВидыИнвентарныхПоручений.П36_Реестр);
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Поручение", Поручение);
	Запрос.УстановитьПараметр("спВидовПорученийCSDR", спВидовПорученийCSDR);
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ТехОперация.ДокументОснование КАК Поручение
	|ПОМЕСТИТЬ втТехОперацияПоПоручению
	|ИЗ
	|	Документ.ТехническаяОперация КАК ТехОперация
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.СостоянияДокументовВФайловомШлюзе КАК Состояния
	|		ПО ТехОперация.Ссылка = Состояния.Документ
	|ГДЕ
	|	ТехОперация.ДокументОснование = &Поручение
	|	И НЕ ТехОперация.ПометкаУдаления
	|	И Состояния.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыДокументовФайловыйШлюз.ВыгруженоФайловыйШлюз)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ДокументыПоручение.ВидОперацииД КАК ВидОперацииД
	|ИЗ
	|	втТехОперацияПоПоручению КАК втТехОперацияПоПоручению
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.Поручение КАК ДокументыПоручение
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.МестаХранения КАК МХКонтрагента
	|			ПО ДокументыПоручение.МХКонтрагент = МХКонтрагента.Ссылка
	|		ПО втТехОперацияПоПоручению.Поручение = ДокументыПоручение.Ссылка
	|ГДЕ
	|	ДокументыПоручение.СуммаСделки = 0
	|	И ДокументыПоручение.НомерПорученияВБО = """"
	|	И ДокументыПоручение.ВидПоручения В(&спВидовПорученийCSDR)
	|	И МХКонтрагента.МестоРасчетов В (ЗНАЧЕНИЕ(Перечисление.МестоРасчетов.Евроклир), ЗНАЧЕНИЕ(Перечисление.МестоРасчетов.Клирстрим))";
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда
		Если ВидОтвета = "ВидОперацииДдляCSDR" Тогда
			Результат = ВыборкаДетальныеЗаписи.ВидОперацииД;
		Иначе
			Результат = Истина;
		КонецЕсли;
	КонецЕсли;
	
	Возврат Результат;
КонецФункции

#КонецОбласти

// Находит строку в таб. части ЦенныеБумагиСписываемые основания и возвращает из нее значение флажка НачислитьНалог.
//
// Параметры:
//  Основание		 - ДокументСсылка.Поручение - поручение
//  СчетДепо		 - СправочникСсылка.СчетаДепо - счет депо для поиска строки таб. части ЦенныеБумагиСписываемые
//  РазделСчетаДепо	 - СправочникСсылка.РазделыСчетаДепо - раздел счета депо для поиска строки таб. части ЦенныеБумагиСписываемые
// 
// Возвращаемое значение:
//  Булево - значение флажка НачислитьНалог в строке таб.части основания
//
Функция ЦБСписываемыеНачислитьНалог(Основание, СчетДепо, РазделСчетаДепо) Экспорт
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ПоручениеЦБСписываемые.НачислитьНалог КАК НачислитьНалог
	|ИЗ
	|	Документ.Поручение.ЦенныеБумагиСписываемые КАК ПоручениеЦБСписываемые
	|ГДЕ
	|	ПоручениеЦБСписываемые.Ссылка = &Основание
	|	И ПоручениеЦБСписываемые.СчетДепо = &СчетДепо
	|	И ПоручениеЦБСписываемые.РазделСчетаДепо = &РазделСчетаДепо";
	Запрос.УстановитьПараметр("Основание", Основание);
	Запрос.УстановитьПараметр("СчетДепо", СчетДепо);
	Запрос.УстановитьПараметр("РазделСчетаДепо", РазделСчетаДепо);
	Результат = Запрос.Выполнить();
	Если Результат.Пустой() Тогда
		Возврат Ложь;
	Иначе
		Выборка = Результат.Выбрать();
		Выборка.Следующий();
		Возврат Выборка.НачислитьНалог;
	КонецЕсли;
КонецФункции

// Добавляет запись с поручением в РС Уведомления отправленные через личный кабинет
//
// Параметры:
//  Поручение					 - ДокументСсылка.Поручение
//  ДатаЗаписи					 - Дата - Дата для записи, в случае, если это первая запись по документу
//  ДанныеКлиента				 - Структура:
//    * Клиент - СправочникСсылка.Контрагенты
//    * СчетДепо - СправочникСсылка.СчетаДепо
//    * ЦеннаяБумага - СправочникСсылка.ЦенныеБумаги
//    * Количество - Число - Количество ЦБ
// Статус - ПеречислениеСсылка.СтатусыДоставкиУведомленийВКабинетКлиента - Новый статус документа
Процедура ЗаписатьУведомлениеДляКабинетаКлиента(Поручение, ДатаЗаписи, ДанныеКлиента, Статус) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	УведомленияОтправленныеЧерезЛичныйКабинет.Период КАК Период,
		|	УведомленияОтправленныеЧерезЛичныйКабинет.КД КАК КД,
		|	УведомленияОтправленныеЧерезЛичныйКабинет.Клиент КАК Клиент,
		|	УведомленияОтправленныеЧерезЛичныйКабинет.СчетДепо КАК СчетДепо,
		|	УведомленияОтправленныеЧерезЛичныйКабинет.ЦеннаяБумага КАК ЦеннаяБумага,
		|	УведомленияОтправленныеЧерезЛичныйКабинет.ИдентификаторУведомления КАК ИдентификаторУведомления,
		|	УведомленияОтправленныеЧерезЛичныйКабинет.Количество КАК Количество,
		|	УведомленияОтправленныеЧерезЛичныйКабинет.СтатусДоставкиУведомления КАК СтатусДоставкиУведомления
		|ИЗ
		|	РегистрСведений.УведомленияОтправленныеЧерезЛичныйКабинет КАК УведомленияОтправленныеЧерезЛичныйКабинет
		|ГДЕ
		|	УведомленияОтправленныеЧерезЛичныйКабинет.КД = &КД
		|	И УведомленияОтправленныеЧерезЛичныйКабинет.Клиент = &Клиент
		|	И УведомленияОтправленныеЧерезЛичныйКабинет.ЦеннаяБумага = &ЦеннаяБумага";
	
	Запрос.УстановитьПараметр("КД", Поручение);
	Запрос.УстановитьПараметр("Клиент", ДанныеКлиента.Клиент);
	Запрос.УстановитьПараметр("ЦеннаяБумага", ДанныеКлиента.ЦеннаяБумага);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	МенеджерЗаписи = РегистрыСведений.УведомленияОтправленныеЧерезЛичныйКабинет.СоздатьМенеджерЗаписи();
	
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда
		ЗаполнитьЗначенияСвойств(МенеджерЗаписи, ВыборкаДетальныеЗаписи);
	Иначе
		ЗаполнитьЗначенияСвойств(МенеджерЗаписи, ДанныеКлиента);
		МенеджерЗаписи.КД = Поручение;
		МенеджерЗаписи.Период = ДатаЗаписи;
		МенеджерЗаписи.ИдентификаторУведомления = Строка(Новый УникальныйИдентификатор);
	КонецЕсли;
	
	Если Статус = Перечисления.СтатусыДоставкиУведомленийВКабинетКлиента.ВыгруженИз1С Тогда
		ДанныеКлиента.messageId = МенеджерЗаписи.ИдентификаторУведомления;
	КонецЕсли;
	
	МенеджерЗаписи.СтатусДоставкиУведомления = Статус;
	МенеджерЗаписи.Записать();
	
КонецПроцедуры

// Возвращает информацию, что поручение с видом инвентарной операции П35_2 содержит тип заявки MULTI_BUY
//
// Параметры:
//  Поручение	 - ДокументСсылка.Поручение	 - Проверяемое поручение
// 
// Возвращаемое значение:
//   - Булево - это МультиПоручениеП35_2
//
Функция ЭтоМультиПоручениеП35_2(Поручение) Экспорт
	
	РеквизитыПоручения = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Поручение, "ВидПоручения, ПаиТипЗаявки");
	ЭтоМультиПоручение352 = РеквизитыПоручения.ВидПоручения = Справочники.ВидыИнвентарныхПоручений.П35_2
		И РеквизитыПоручения.ПаиТипЗаявки = Перечисления.ПаиТипыЗаявок.MULTI_BUY;
	
	Возврат ЭтоМультиПоручение352;
	
КонецФункции
