// ФУНКЦИИ ИНТЕРФЕЙСА

Функция ЭтоПоручениеНФИ(ДокументПоручение) Экспорт
	Если ТипЗнч(ДокументПоручение) <> Тип("ДокументСсылка.Поручение") Или Не ЗначениеЗаполнено(ДокументПоручение) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	Поручение.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.Поручение КАК Поручение
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.Поручение.ЦенныеБумагиСписываемые КАК ПоручениеЦенныеБумагиСписываемые
	|		ПО Поручение.Ссылка = ПоручениеЦенныеБумагиСписываемые.Ссылка
	|ГДЕ
	|	Поручение.Ссылка = &Ссылка
	|	И (Поручение.ЦБ.НФИ = &ПризнакНФИ
	|			ИЛИ ПоручениеЦенныеБумагиСписываемые.ЦеннаяБумага.НФИ = &ПризнакНФИ
	|			ИЛИ Поручение.ВидСчетаДепо = &СчетНФИ
	|			ИЛИ Поручение.СчетДепо ССЫЛКА Справочник.СчетаДепо
	|				И Поручение.СчетДепо.ВидСчетаДепо = &СчетНФИ)";
	
	Запрос.УстановитьПараметр("Ссылка", ДокументПоручение);
	Запрос.УстановитьПараметр("СчетНФИ", Перечисления.ВидыСчетовДепо.СчетНФИ);
	Запрос.УстановитьПараметр("ПризнакНФИ", 1);
	
	РезультатЗапроса = Запрос.Выполнить();
	Возврат Не РезультатЗапроса.Пустой();
КонецФункции

Функция ЭтоПоручениеПоДвижениюЦБ(ВидОперации) Экспорт
	Возврат ВидОперации = Справочники.ВидыОпераций.Депонирование Или ВидОперации = Справочники.ВидыОпераций.СнятиеСДепонирования
			Или ВидОперации = Справочники.ВидыОпераций.ВыкупСписаниеЦБ Или ВидОперации = Справочники.ВидыОпераций.Погашение
			Или Справочники.ВидыОпераций.ЭтоПереводЦБ(ВидОперации);
КонецФункции

Функция ЭтоПоручениеВыкупСписаниеЦБ(ВидОперации) Экспорт
	Возврат ВидОперации = Справочники.ВидыОпераций.ВыкупСписаниеЦБ;
КонецФункции

Функция ВозможноУведомлениеСУДКПоОперации(ВидОперацииД) Экспорт
	Возврат ВидОперацииД = Справочники.ВидыОпераций.Выкуп Или ВидОперацииД = Справочники.ВидыОпераций.ПогашениеНКД
		Или ВидОперацииД = Справочники.ВидыОпераций.ПогашениеЦБПолное Или ВидОперацииД = Справочники.ВидыОпераций.ПогашениеЦБЧастичное
		Или ВидОперацииД = Справочники.ВидыОпераций.НачислениеДивидендов Или ВидОперацииД = Справочники.ВидыОпераций.НачислениеДоходаПрочие;
КонецФункции

// Возвращает список операций выплаты дохода в денежной форме
// 
// Возвращаемое значение:
//   - СписокЗначений - Список операций
//
Функция СписокОперацийВыплатыДоходаВДенежнойФорме() Экспорт
	
	СписокОпераций = Новый СписокЗначений;
	Операции = Справочники.ВидыОпераций.ОперацииВыплатыДоходаВДенежнойФорме();
	СписокОпераций.ЗагрузитьЗначения(Операции);
	
	Возврат СписокОпераций;
	
КонецФункции

// Проверяет допустимость длины комментария в поручении
//
// Параметры:
//  ДокументПоручение							 - ДокументСсылка.Поручение	 - Поручение
//  ЕстьОшибка									 - Булево					 - Признак ошибки проверки
//  ВывестиСообщениеОПревышенииДопустимойДлины	 - Булево					 - Истина, вывести сообщение о превышении допустимой длины комментария
//
Процедура ПроверитьДлинуКомментария(ДокументПоручение, ЕстьОшибка, ВывестиСообщениеОПревышенииДопустимойДлины = Истина) Экспорт
	
	Если ЕстьОшибка Тогда
		Возврат;
	КонецЕсли;
	ЕстьОшибка = Ложь;
	
	Если ТипЗнч(ДокументПоручение.ВидОперацииД) = Тип("СправочникСсылка.ВидыОпераций")
		И ДокументПоручение.ВидОперацииД.ВыплатаДоходаВДенежнойФорме Тогда
		ДлинаКомментария = СтрДлина(ДокументПоручение.Комментарий);
		МаксимальнаяДлинаКомментарияВПорученииВыплатаДоходаВДенежнойФорме =
			ОбщегоНазначенияПовтИсп.ЗначениеГлобальногоПараметра("913.МаксимальнаяДлинаКомментарияВПорученииВыплатаДоходаВДенежнойФорме", 210);
		Если ДлинаКомментария > МаксимальнаяДлинаКомментарияВПорученииВыплатаДоходаВДенежнойФорме Тогда
			ШаблонСообщения = "%1: превышена длина Комментария! [%2\%3]";
			СообщениеОПревышенииДопустимойДлины = СтрШаблон(ШаблонСообщения,
				Строка(ДокументПоручение), ДлинаКомментария, МаксимальнаяДлинаКомментарияВПорученииВыплатаДоходаВДенежнойФорме);
			СообщениеОПревышенииДопустимойДлины = СообщениеОПревышенииДопустимойДлины + Символы.ПС;
			ШаблонСообщения = "Для выгрузки платежных операций по поручению требуется уменьшить комментарий до %1 символов";
			СообщениеОПревышенииДопустимойДлины = СообщениеОПревышенииДопустимойДлины
				+ СтрШаблон(ШаблонСообщения, МаксимальнаяДлинаКомментарияВПорученииВыплатаДоходаВДенежнойФорме);
			Если ВывестиСообщениеОПревышенииДопустимойДлины Тогда
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю(СообщениеОПревышенииДопустимойДлины);
			КонецЕсли;
			ЕстьОшибка = Истина;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

Функция ОперацияБлокирована(ДокументПоручение) Экспорт
	
	ЭтоВнешняяОперация = НЕ ЗначениеЗаполнено(ДокументПоручение.НомерПорученияВБО);
		
	Возврат ЗначениеЗаполнено(ДокументПоручение.Инициатор)
				И ТипЗнч(ДокументПоручение.Инициатор) = Тип("СправочникСсылка.Контрагенты")
				И ДокументПоручение.Инициатор.Блокирован
				И ЭтоВнешняяОперация
				И ТипЗнч(ДокументПоручение.ВидОперацииД) = Тип("СправочникСсылка.ВидыОпераций")
				И ДокументПоручение.ВидОперацииД.КлассОпераций = Перечисления.КлассыОпераций.Инвентарные;
	
КонецФункции

// Возвращает Истина, если переданное поручение - это инвентарное поручение, у него указано исполнение и
// поручение введено после наступления даты ввода частичного исполнения. Иначе - Ложь.
//
// Параметры:
//  Поручение - ДокументСсылка.Поручение
// 
// Возвращаемое значение:
//  Булево
//
Функция ЭтоИнвентарноеПоручениеСИсполнениемВРежимеЧастичногоИсполнения(Поручение) Экспорт
	Если ТипЗнч(Поручение) <> Тип("ДокументСсылка.Поручение") Тогда
		Возврат Ложь;
	КонецЕсли;
	
	ДатаВвода = Константы.ДатаВводаЧастичногоИсполненияИнвентарныхПоручений.Получить();
	РеквизитыПоручения = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Поручение, "Исполнение, ВидОперацииД, Дата");
	Возврат ЗначениеЗаполнено(РеквизитыПоручения.Исполнение)
		И (РеквизитыПоручения.ВидОперацииД = Справочники.ВидыОпераций.Депонирование
			ИЛИ РеквизитыПоручения.ВидОперацииД = Справочники.ВидыОпераций.СнятиеСДепонирования)
		И ЗначениеЗаполнено(ДатаВвода) И РеквизитыПоручения.Дата >= ДатаВвода;
КонецФункции

// Функция возвращает строку описания параметров DVP3
//
// Параметры:
//  Поручение - ДокументСсылка.Поручение, ДокументОбъект.Поручение - 
// 
// Возвращаемое значение:
//  Строка - описание параметров пула в формате "%ВидDVP% / %НомерПула% / %ВидПула% / %НомерВПУле% / %КоличествоВПуле%"
//
Функция ОписаниеПараметровDVP3(Поручение) Экспорт
	
	Результат = "";
	
	Если ТипЗнч(Поручение) = Тип("ДокументСсылка.Поручение") Тогда
		ИменаРеквизитовDVP = "ВидИсполненияDVP,НомерПулаDVP3,ВидПулаDVP3,КоличествоВПулеDVP3,ПорядковыйНомерВПулеDVP3";
		ПараметрыDVP3 = ОбщегоНазначения.ПолучитьЗначенияРеквизитов(Поручение, ИменаРеквизитовDVP);
	ИначеЕсли ТипЗнч(Поручение) = Тип("ДокументОбъект.Поручение") Тогда
		ПараметрыDVP3 = Поручение;
	Иначе
		Возврат "";
	КонецЕсли;
	
	Если Не ПараметрыDVP3.ВидИсполненияDVP = Перечисления.ВидыИсполненийDVP.DVP3 Тогда
		Возврат Результат;
	КонецЕсли;
	
	ШаблонТекст = "%1 / %2 / %3 / %4 / %5";
	
	Результат = СтрШаблон(ШаблонТекст,
	                      ПараметрыDVP3.ВидИсполненияDVP,
	                      ПараметрыDVP3.НомерПулаDVP3,
	                      ПараметрыDVP3.ВидПулаDVP3,
	                      ПараметрыDVP3.ПорядковыйНомерВПулеDVP3,
	                      ПараметрыDVP3.КоличествоВПулеDVP3);
	
	
	Возврат Результат;
	
КонецФункции

// Возвращает Истина, если поручение имеет вид операции с флагом "Выплата дохода в денежной форме"
// и дата поручения >= дате ввода расчета НДФЛ по прогрессивной шкале.
//
// Параметры:
//  Поручение - ДокументСсылка.Поручение
// 
// Возвращаемое значение:
//  Булево 
//
Функция ЭтоВыплатаДоходаПоПрогрессивнойШкалеНДФЛ(Поручение) Экспорт
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Поручение.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.Поручение КАК Поручение
	|ГДЕ
	|	Поручение.Ссылка = &Ссылка
	|	И Поручение.ВидОперацииД ССЫЛКА Справочник.ВидыОпераций
	|	И Поручение.ВидОперацииД.ВыплатаДоходаВДенежнойФорме
	|	И Поручение.Дата >= &ДатаВвода";
	Запрос.УстановитьПараметр("Ссылка", Поручение);
	Запрос.УстановитьПараметр("ДатаВвода", ОбщегоНазначенияПовтИсп.ЗначениеКонстанты("ДатаВводаРасчетаНДФЛПоПрогрессивнойШкале"));
	Возврат Не Запрос.Выполнить().Пустой();
КонецФункции

// Возвращает расчетную дату исполнения поручения.
// Если выполнены все условия для исполнения поручения выплаты дохода по алгоритмам прогрессивной шкалы НДФЛ,
// то возвращает максимальную дату платежной операции выплаты дохода. Иначе возвращает пустую дату.
//
// Параметры:
//  Поручение - ДокументСсылка.Поручение
// 
// Возвращаемое значение:
//  Дата - расчетная дата исполнения поручения.
//
Функция ДатаИсполненияПорученияВыплатыДоходаПоПрогрессивнойШкалеНДФЛ(Поручение) Экспорт
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ПлатежнаяОперация.Ссылка КАК Ссылка,
	|	ПлатежнаяОперация.СчетДепо КАК СчетДепо,
	|	ПлатежнаяОперация.РазделСчетаДепо КАК РазделСчетаДепо,
	|	ПлатежнаяОперация.Дата КАК Дата
	|ПОМЕСТИТЬ втПлатежныеОперации
	|ИЗ
	|	Документ.ПлатежнаяОперация КАК ПлатежнаяОперация
	|ГДЕ
	|	ПлатежнаяОперация.ВидОперации = &ВыплатаДохода
	|	И ПлатежнаяОперация.Основание = &Поручение
	|	И ПлатежнаяОперация.Проведен
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЕСТЬNULL(втПлатежныеОперации.Дата, ДАТАВРЕМЯ(1, 1, 1)) КАК ПлатежнаяОперацияДата,
	|	ВЫБОР
	|		КОГДА НЕ ПоручениеЦБСписываемые.НачислитьНалог
	|				ИЛИ НЕ НачисленныйНалог.Ссылка ЕСТЬ NULL
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК ВыполненоУсловиеПоНачисленномуНалогу
	|ИЗ
	|	Документ.Поручение.ЦенныеБумагиСписываемые КАК ПоручениеЦБСписываемые
	|		ЛЕВОЕ СОЕДИНЕНИЕ втПлатежныеОперации КАК втПлатежныеОперации
	|		ПО ПоручениеЦБСписываемые.СчетДепо = втПлатежныеОперации.СчетДепо
	|			И ПоручениеЦБСписываемые.РазделСчетаДепо = втПлатежныеОперации.РазделСчетаДепо
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.НачисленныйНалог КАК НачисленныйНалог
	|		ПО ПоручениеЦБСписываемые.Ссылка = НачисленныйНалог.Основание
	|			И ПоручениеЦБСписываемые.СчетДепо = НачисленныйНалог.СчетДепо
	|			И ПоручениеЦБСписываемые.РазделСчетаДепо = НачисленныйНалог.РазделСчетаДепо
	|			И (НачисленныйНалог.Проведен)
	|ГДЕ
	|	ПоручениеЦБСписываемые.Ссылка = &Поручение
	|	И ПоручениеЦБСписываемые.Ссылка.ВидОперацииД ССЫЛКА Справочник.ВидыОпераций
	|	И ПоручениеЦБСписываемые.Ссылка.ВидОперацииД.ВыплатаДоходаВДенежнойФорме
	|	И ПоручениеЦБСписываемые.Ссылка.Дата >= &ДатаВвода";
	Запрос.УстановитьПараметр("ВыплатаДохода", Перечисления.ВидыПлатежныхОпераций.ВыплатаДохода);
	Запрос.УстановитьПараметр("ДатаВвода", ОбщегоНазначенияПовтИсп.ЗначениеКонстанты("ДатаВводаРасчетаНДФЛПоПрогрессивнойШкале"));
	Запрос.УстановитьПараметр("Поручение", Поручение);
	Выборка = Запрос.Выполнить().Выбрать();
	
	ЕстьВсеПлатежныеОперации = Истина;
	ВыполненыВсеУсловияПоНачисленномуНалогу = Истина;
	МаксДата = '00010101';
	
	Пока Выборка.Следующий() Цикл
		Если Не ЗначениеЗаполнено(Выборка.ПлатежнаяОперацияДата) Тогда
			ЕстьВсеПлатежныеОперации = Ложь;
			Прервать;
		КонецЕсли;
		Если Не Выборка.ВыполненоУсловиеПоНачисленномуНалогу Тогда
			ВыполненыВсеУсловияПоНачисленномуНалогу = Ложь;
			Прервать;
		КонецЕсли;
		МаксДата = Макс(МаксДата, Выборка.ПлатежнаяОперацияДата);
	КонецЦикла;
	
	Если ЕстьВсеПлатежныеОперации И ВыполненыВсеУсловияПоНачисленномуНалогу Тогда
		Возврат МаксДата;
	Иначе
		Возврат '00010101';
	КонецЕсли;
КонецФункции

// Устанавливает признак начислить комиссию депо в переданном поручении
//
// Параметры:
//  Поручение			 - 	 - ДокументСсылка.Поручение
//  ПодчиненныйДокумент	 - 	 - ДокументСсылка.ОперацияЦБ, ДокументСсылка.УчастиеВКД, ДокументСсылка.ОтменаПоручения
//
Процедура УстановитьПризнакНачислитьКомиссиюДепо(Поручение, ПодчиненныйДокумент) Экспорт
	
	ОрганизацияПоУмолчанию = ОбщегоНазначенияПовтИсп.ОрганизацияПоУмолчанию();
	МестоХраненияПоУмолчанию = ОбщегоНазначенияПовтИсп.ЗначениеКонстанты("МестоХраненияПоУмолчанию");
	ВидыОперацийКНачислениюКомиссий = ВидыОперацийКНачислениюКомиссий(ПодчиненныйДокумент);
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Поручение.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.Поручение КАК Поручение
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ДокументыКНачислениюКомиссииДепо КАК ДокументыКНачислениюКомиссииДепо
	|		ПО Поручение.Ссылка = ДокументыКНачислениюКомиссииДепо.Документ
	|ГДЕ
	|	Поручение.Ссылка = &Поручение
	|	И Поручение.Инициатор <> &ОрганизацияПоУмолчанию
	|	И Поручение.Инициатор <> &МестоХраненияПоУмолчанию
	|	И Поручение.ВидОперацииД В(&ВидыОпераций)
	|	И ДокументыКНачислениюКомиссииДепо.Документ ЕСТЬ NULL";
	
	Запрос.УстановитьПараметр("Поручение", Поручение);
	Запрос.УстановитьПараметр("ВидыОпераций", ВидыОперацийКНачислениюКомиссий);
	Запрос.УстановитьПараметр("ОрганизацияПоУмолчанию", ОрганизацияПоУмолчанию);
	Запрос.УстановитьПараметр("МестоХраненияПоУмолчанию", МестоХраненияПоУмолчанию);
	
	ТребуетсяУстановкаПризнака = Не Запрос.Выполнить().Пустой();
	
	Если ТребуетсяУстановкаПризнака Тогда
		РегистрыСведений.ДокументыКНачислениюКомиссииДепо.Добавить(Поручение);
	КонецЕсли;
	
КонецПроцедуры

// Убирает признак начислить комиссию депо в переданном поручении, если нет других подчиненных документов
//
// Параметры:
//  Поручение			 - 	 - ДокументСсылка.Поручение
//  ПодчиненныйДокумент	 - 	 - ДокументСсылка.ОперацияЦБ, ДокументСсылка.УчастиеВКД, ДокументСсылка.ОтменаПоручения
//
Процедура ОтменитьПризнакНачислитьКомиссиюДепо(Поручение, ПодчиненныйДокумент) Экспорт
	
	ОрганизацияПоУмолчанию = ОбщегоНазначенияПовтИсп.ОрганизацияПоУмолчанию();
	МестоХраненияПоУмолчанию = ОбщегоНазначенияПовтИсп.ЗначениеКонстанты("МестоХраненияПоУмолчанию");
	ВидыОперацийКНачислениюКомиссий = ВидыОперацийКНачислениюКомиссий(ПодчиненныйДокумент);
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Поручение.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.Поручение КАК Поручение
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ДокументыКНачислениюКомиссииДепо КАК ДокументыКНачислениюКомиссииДепо
	|		ПО Поручение.Ссылка = ДокументыКНачислениюКомиссииДепо.Документ
	|		ЛЕВОЕ СОЕДИНЕНИЕ #ИмяТаблицы КАК ПодчиненныеДокументы
	|		ПО (ПодчиненныеДокументы.ДокументОснование = Поручение.Ссылка
	|				ИЛИ &УсловиеПоДокументуОснованиюВстречному)
	|			И (ПодчиненныеДокументы.Проведен)
	|			И (ПодчиненныеДокументы.Ссылка <> &ПодчиненныйДокумент)
	|ГДЕ
	|	Поручение.Ссылка = &Поручение
	|	И Поручение.Инициатор <> &ОрганизацияПоУмолчанию
	|	И Поручение.Инициатор <> &МестоХраненияПоУмолчанию
	|	И Поручение.ВидОперацииД В(&ВидыОпераций)
	|	И ДокументыКНачислениюКомиссииДепо.Документ ЕСТЬ НЕ NULL 
	|	И ПодчиненныеДокументы.Ссылка ЕСТЬ NULL";
	
	Запрос.УстановитьПараметр("Поручение", Поручение);
	Запрос.УстановитьПараметр("ВидыОпераций", ВидыОперацийКНачислениюКомиссий);
	Запрос.УстановитьПараметр("ОрганизацияПоУмолчанию", ОрганизацияПоУмолчанию);
	Запрос.УстановитьПараметр("МестоХраненияПоУмолчанию", МестоХраненияПоУмолчанию);
	Запрос.УстановитьПараметр("ПодчиненныйДокумент", ПодчиненныйДокумент);
	
	Если ТипЗнч(ПодчиненныйДокумент) = Тип("ДокументСсылка.ОперацииЦБ") Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "#ИмяТаблицы", "Документ.ОперацииЦБ");
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеПоДокументуОснованиюВстречному",
			"ПодчиненныеДокументы.ДокументОснованиеВстречный = Поручение.Ссылка");
	ИначеЕсли ТипЗнч(ПодчиненныйДокумент) = Тип("ДокументСсылка.УчастиеВКД") Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "#ИмяТаблицы", "Документ.УчастиеВКД");
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеПоДокументуОснованиюВстречному", "ЛОЖЬ");
	ИначеЕсли ТипЗнч(ПодчиненныйДокумент) = Тип("ДокументСсылка.ОтменаПоручения") Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "#ИмяТаблицы", "Документ.ОтменаПоручения");
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеПоДокументуОснованиюВстречному", "ЛОЖЬ");
	КонецЕсли;
	
	ТребуетсяОтменаПризнака = Не Запрос.Выполнить().Пустой();
	
	Если ТребуетсяОтменаПризнака Тогда
		РегистрыСведений.ДокументыКНачислениюКомиссииДепо.Удалить(Поручение);
	КонецЕсли;
	
КонецПроцедуры

// Возвращает признак использования списка ЦБ в неторговом поручении
//
// Параметры:
//  Поручение - ДокументСсылка.Поручение, ДокументОбъект.Поручение, Структура, ВыборкаИзРезультатаЗапроса - Поручение,
//    либо стурктура данных, содержащая поле ВидОперацииД
// 
// Возвращаемое значение:
//  Булево - Истина, если в поручении используется список ЦБ (ТЧ ЦенныеБумагиСписываемые)
//
Функция ЭтоНеторговоеПоручениеСоСпискомЦБ(Поручение) Экспорт
	Если ТипЗнч(Поручение) = Тип("ДокументСсылка.Поручение") Тогда
		ДанныеПоручения = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Поручение, "ВидОперацииД");
	ИначеЕсли ТипЗнч(Поручение) = Тип("ДокументОбъект.Поручение")
		Или ТипЗнч(Поручение) = Тип("ВыборкаИзРезультатаЗапроса")
		Или ТипЗнч(Поручение) = Тип("Структура") Тогда
		ДанныеПоручения = Поручение;
	Иначе
		Возврат Ложь;
	КонецЕсли;
	
	ВидыНеторговыхОперацийСоСпискомЦБ = ВидыНеторговыхОперацийСоСпискомЦБ();
	ЭтоНеторговоеПоручениеСоСпискомЦБ = (ВидыНеторговыхОперацийСоСпискомЦБ.Найти(ДанныеПоручения.ВидОперацииД) <> Неопределено);
	Возврат ЭтоНеторговоеПоручениеСоСпискомЦБ;
КонецФункции

// Возвращает виды неторговых операций ЦБ в поручениях по которым используется список ЦБ
// 
// Возвращаемое значение:
//  Массив - виды операций
//
Функция ВидыНеторговыхОперацийСоСпискомЦБ() Экспорт
	Результат = Новый Массив;
	Результат.Добавить(Справочники.ВидыОпераций.Депонирование);
	Результат.Добавить(Справочники.ВидыОпераций.СнятиеСДепонирования);
	Результат.Добавить(Справочники.ВидыОпераций.ПереводМеждуРазделамиСчетаДепо);
	Результат.Добавить(Справочники.ВидыОпераций.Перемещение);
	Возврат Результат;
КонецФункции

// BSLLS:NumberOfOptionalParams-off

// Создаёт или перезаполняет операции ЦБ по списку из ТЧ ЦенныеБумагиСписываемые на основании данных поручения
//
// Параметры:
//  Поручение					 - ДокументСсылка.Поручение	 - Поручение
//  РежимЗаписи					 - РежимЗаписиДокумента		 - РежимЗаписиДокумента
//  ДатаОпераций				 - Дата						 - Дата операции
//  Комментарий					 - Строка					 - Комментарий
//  КодОтчетаНРД				 - Строка					 - Код отчета НРД
//  ЗначенияПараметровОперацииЦБ - Структура				 - см. ПараметрыОперацииЦБ
//
Процедура СоздатьОбновитьОперацииЦБ(Поручение, РежимЗаписи, ДатаОпераций = Неопределено, Комментарий = "",
	КодОтчетаНРД = "", ЗначенияПараметровОперацииЦБ = Неопределено) Экспорт
	ПараметрыОперацииЦБ = Новый Структура("ДокументОснование, ЦБ, КоличествоЦБ, ЦенаСделкиЦБ, СуммаСделки", Поручение);
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ПоручениеЦенныеБумагиСписываемые.ЦеннаяБумага КАК ЦБ,
	|	ПоручениеЦенныеБумагиСписываемые.Количество КАК КоличествоЦБ,
	|	ПоручениеЦенныеБумагиСписываемые.Цена КАК ЦенаСделкиЦБ,
	|	ПоручениеЦенныеБумагиСписываемые.Сумма КАК СуммаСделки,
	|	ОперацииЦБ.Ссылка КАК ОперацияЦБ
	|ИЗ
	|	Документ.Поручение.ЦенныеБумагиСписываемые КАК ПоручениеЦенныеБумагиСписываемые
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ОперацииЦБ КАК ОперацииЦБ
	|		ПО ПоручениеЦенныеБумагиСписываемые.Ссылка = ОперацииЦБ.ДокументОснование
	|			И ПоручениеЦенныеБумагиСписываемые.ЦеннаяБумага = ОперацииЦБ.ЦБ
	|			И (ВЫБОР
	|				КОГДА &ЭтоМультиПоручениеП35_2
	|					ТОГДА ОперацииЦБ.КодОтчетаНРД = &КодОтчетаНРД
	|				ИНАЧЕ ИСТИНА
	|			КОНЕЦ)
	|ГДЕ
	|	ПоручениеЦенныеБумагиСписываемые.Ссылка = &Поручение
	|	И ВЫБОР
	|			КОГДА &ЭтоМультиПоручениеП35_2
	|					И &ТребуетсяПоискЦеннойБумаги
	|					И &ЦБ <> НЕОПРЕДЕЛЕНО
	|				ТОГДА ПоручениеЦенныеБумагиСписываемые.ЦеннаяБумага = &ЦБ
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ОперацииЦБ.Ссылка КАК ОперацияЦБ,
	|	Выписка.Ссылка КАК Выписка
	|ИЗ
	|	Документ.ОперацииЦБ КАК ОперацииЦБ
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.Поручение.ЦенныеБумагиСписываемые КАК ПоручениеЦенныеБумагиСписываемые
	|		ПО ОперацииЦБ.ДокументОснование = ПоручениеЦенныеБумагиСписываемые.Ссылка
	|			И ОперацииЦБ.ЦБ = ПоручениеЦенныеБумагиСписываемые.ЦеннаяБумага
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.Выписка КАК Выписка
	|		ПО ОперацииЦБ.Ссылка = Выписка.ОперацияЦБ
	|ГДЕ
	|	ОперацииЦБ.ДокументОснование = &Поручение
	|	И ПоручениеЦенныеБумагиСписываемые.ЦеннаяБумага ЕСТЬ NULL";
	Запрос.УстановитьПараметр("Поручение", Поручение);
	Запрос.УстановитьПараметр("ТребуетсяПоискЦеннойБумаги", Поручение.ЦенныеБумагиСписываемые.Количество() > 1);
	Запрос.УстановитьПараметр("КодОтчетаНРД", КодОтчетаНРД);
	ЭтоМультиПоручениеП35_2 = Документы.Поручение.ЭтоМультиПоручениеП35_2(Поручение);
	Запрос.УстановитьПараметр("ЭтоМультиПоручениеП35_2", ЭтоМультиПоручениеП35_2);
	Если ТипЗнч(ЗначенияПараметровОперацииЦБ) = Тип("Структура") И ЗначенияПараметровОперацииЦБ.Свойство("ЦБ") Тогда
		Запрос.УстановитьПараметр("ЦБ", ЗначенияПараметровОперацииЦБ.ЦБ);
	Иначе
		Запрос.УстановитьПараметр("ЦБ", Неопределено);
	КонецЕсли;
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	
	ДанныеДляОперацийЦБ = РезультатЗапроса[0].Выбрать();
	Пока ДанныеДляОперацийЦБ.Следующий() Цикл
		Если ЗначениеЗаполнено(ДанныеДляОперацийЦБ.ОперацияЦБ) Тогда
			ОперацияЦБОбъект = ДанныеДляОперацийЦБ.ОперацияЦБ.ПолучитьОбъект();
			Комментарий = "Инвентарная операция перезаполнена";
		Иначе
			ОперацияЦБОбъект = Документы.ОперацииЦБ.СоздатьДокумент();
			Комментарий = "Создана инвентарная операция";
		КонецЕсли;
		
		Если ОперацияЦБОбъект.ПометкаУдаления Тогда
			ОперацияЦБОбъект.УстановитьПометкуУдаления(Ложь);
		КонецЕсли;
		ЗаполнитьЗначенияСвойств(ПараметрыОперацииЦБ, ДанныеДляОперацийЦБ);
		ДозаполнитьПараметрыОперацииЦБ(ПараметрыОперацииЦБ, ЗначенияПараметровОперацииЦБ, ЭтоМультиПоручениеП35_2);
		ОперацияЦБОбъект.Заполнить(ПараметрыОперацииЦБ);
		ПерезаполнитьРеквизитыОперацииЦБ(ОперацияЦБОбъект, ДатаОпераций, КодОтчетаНРД, ЗначенияПараметровОперацииЦБ, ЭтоМультиПоручениеП35_2);
		ОперацияЦБОбъект.Записать(РежимЗаписи);
	КонецЦикла;
	
	ОперацииЦБПоУдаленнымСтрокам = РезультатЗапроса[1].Выбрать();
	Пока ОперацииЦБПоУдаленнымСтрокам.Следующий() Цикл
		ОперацияЦБОбъект = ОперацииЦБПоУдаленнымСтрокам.ОперацияЦБ.ПолучитьОбъект();
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Удален документ: " + ОперацияЦБОбъект);
		ОперацияЦБОбъект.Удалить();
		Если ЗначениеЗаполнено(ОперацииЦБПоУдаленнымСтрокам.Выписка) Тогда
			ВыпискаОбъект = ОперацииЦБПоУдаленнымСтрокам.Выписка.ПолучитьОбъект();
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Удален документ: " + ВыпискаОбъект);
			ВыпискаОбъект.Удалить();
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры
// BSLLS:NumberOfOptionalParams-on

// Процедура - Найти и провести поручения с отложенными платежами и налогами
//
// Параметры:
//  Период			 - Дата	 - Текущая дата
//  НайденоПоручений - Число - Количество найденных документов
//
Процедура НайтиИПровестиПорученияСОтложеннымиПлатежамиИНалогами(Период = Неопределено, НайденоПоручений = 0) Экспорт
	Если ЗначениеЗаполнено(Период) Тогда
		ТекущаяДата = НачалоДня(Период);
	Иначе
		ТекущаяДата = НачалоДня(ТекущаяДатаСеанса());
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Поручение.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.Поручение.ЦенныеБумагиСписываемые КАК ПоручениеЦенныеБумагиСписываемые
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.Поручение КАК Поручение
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ВидыОпераций КАК ВидыОпераций
	|			ПО Поручение.ВидОперацииД = ВидыОпераций.Ссылка
	|				И (ВидыОпераций.ВыплатаДоходаВДенежнойФорме)
	|		ПО ПоручениеЦенныеБумагиСписываемые.Ссылка = Поручение.Ссылка
	|			И (ПоручениеЦенныеБумагиСписываемые.ПлановаяДатаРасчетов = &ТекущаяДата)
	|			И (Поручение.Проведен)
	|			И (Поручение.Дата < &ТекущаяДата)
	|
	|СГРУППИРОВАТЬ ПО
	|	Поручение.Ссылка
	|
	|УПОРЯДОЧИТЬ ПО
	|	Поручение.Дата";
	Запрос.УстановитьПараметр("ТекущаяДата", ТекущаяДата);
	РезультатЗапроса = Запрос.Выполнить();
	Если Не РезультатЗапроса.Пустой() Тогда
		ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
		НайденоПоручений = ВыборкаДетальныеЗаписи.Количество();
		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			ПоручениеОбъект = ВыборкаДетальныеЗаписи.Ссылка.ПолучитьОбъект();
			ПоручениеОбъект.Записать(РежимЗаписиДокумента.Проведение, РежимПроведенияДокумента.Неоперативный);
		КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры

// Процедура выгружает поручение при помощи функционала обработки ЭкспортПорученийВЛуч
//
// Параметры:
//  Поручение	 - ДокументСсылка.Поручение - Выгружаемое поручение
//
Процедура ВыгрузитьПоручение(Поручение) Экспорт
	
	Обработка = Обработки.ЭкспортПорученийВЛуч.Создать();
	Обработка.ДатаВыгрузки = Поручение.Дата;
	Обработка.ЗаполнитьПоручения(Поручение);
	Если Обработка.Поручения.Количество() = 0 Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Документ не подлежит выгрузке.");
		Возврат;
	КонецЕсли;
	Результат = Обработка.РезультатВыгрузкиПоручений();
	ИмяСобытия = "Экспорт поручений в Луч";
	Если ЗначениеЗаполнено(Результат) Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(Результат.СообщениеПользователю);
		ЗаписьЖурналаРегистрации(ИмяСобытия, УровеньЖурналаРегистрации.Ошибка, , Результат.Данные,
			Результат.СообщениеВЖурнал);
	Иначе
		Сообщение = "Файл сформирован";
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(Сообщение);
		ЗаписьЖурналаРегистрации(ИмяСобытия, УровеньЖурналаРегистрации.Информация, , , Сообщение);
	КонецЕсли;
	
КонецПроцедуры

// Функция определяет, требуется ли, чтобы для поручения был сформирован УИН
// Параметры:
//	ВидОперацииД - СправочникСсылка.ВидыОпераций
//	ВидПоручения - СправочникСсылка.ВидыИнвентарныхПоручений
//	РазделСчетаДепо - СправочникСсылка.РазделыСчетаДепо
// Возвращаемое значение:
//	- Булево
Функция ТребуетсяУИН(ВидОперацииД, ВидПоручения, РазделСчетаДепо) Экспорт
	Требуется = ВидОперацииД = Справочники.ВидыОпераций.СнятиеСДепонирования
				И (ВидПоручения = Справочники.ВидыИнвентарныхПоручений.П16
					ИЛИ ВидПоручения = Справочники.ВидыИнвентарныхПоручений.П36
					ИЛИ ВидПоручения = Справочники.ВидыИнвентарныхПоручений.П36_Реестр)
				И (
					РазделСчетаДепо.ТипРазделаСчетаДЕПО = Перечисления.ТипыРазделовСчетовДЕПО.БлокированоОбособленный
					ИЛИ РазделСчетаДепо.ТипРазделаСчетаДЕПО = Перечисления.ТипыРазделовСчетовДЕПО.БлокированоОбособленныйПоПредписаниямБР);
	
	Возврат Требуется;
КонецФункции


