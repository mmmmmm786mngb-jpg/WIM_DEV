КонецФункции

Функция ВстречноеПоручениеПеревод(Поручение) Экспорт
	Запрос = Новый Запрос(
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	ОсновноеПоручение.Ссылка КАК ОсновноеПоручение,
	|	ЕСТЬNULL(ВстречноеПоручение.Ссылка, ЗНАЧЕНИЕ(Документ.Поручение.ПустаяСсылка)) КАК ВстречноеПоручение,
	|	ВЫБОР
	|		КОГДА РАЗНОСТЬДАТ(ОсновноеПоручение.Дата, ВстречноеПоручение.Дата, СЕКУНДА) > 0
	|			ТОГДА РАЗНОСТЬДАТ(ОсновноеПоручение.Дата, ВстречноеПоручение.Дата, СЕКУНДА)
	|		ИНАЧЕ -1 * РАЗНОСТЬДАТ(ОсновноеПоручение.Дата, ВстречноеПоручение.Дата, СЕКУНДА)
	|	КОНЕЦ КАК Разность
	|ИЗ
	|	Документ.Поручение КАК ОсновноеПоручение
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.Поручение КАК ВстречноеПоручение
	|		ПО ОсновноеПоручение.Ссылка <> ВстречноеПоручение.Ссылка
	|			И (ОсновноеПоручение.ВидОперацииД = &ВидОперацииПередача)
	|			И (ВстречноеПоручение.ВидОперацииД = &ВидОперацииПередача)
	|			И (ВстречноеПоручение.Дата > ДОБАВИТЬКДАТЕ(ОсновноеПоручение.Дата, МЕСЯЦ, -1))
	|			И (ВстречноеПоручение.Дата < ДОБАВИТЬКДАТЕ(ОсновноеПоручение.Дата, МЕСЯЦ, 1))
	|			И ОсновноеПоручение.ЦБ = ВстречноеПоручение.ЦБ
	|			И ОсновноеПоручение.Депонент = ВстречноеПоручение.Депонент
	|			И ОсновноеПоручение.Контрагент = ВстречноеПоручение.Контрагент
	|			И ОсновноеПоручение.ДатаСделки = ВстречноеПоручение.ДатаСделки
	|			И ОсновноеПоручение.КоличествоЦБ = ВстречноеПоручение.КоличествоЦБ
	|			И ОсновноеПоручение.ПланируемаяДатаРасчетов = ВстречноеПоручение.ПланируемаяДатаРасчетов
	|ГДЕ
	|	ОсновноеПоручение.Ссылка = &Поручение
	|	И ВстречноеПоручение.Проведен = Истина
	|	И ОсновноеПоручение.Проведен = Истина
	|
	|УПОРЯДОЧИТЬ ПО
	|	Разность");
	Запрос.Параметры.Вставить("Поручение", Поручение);
	Запрос.Параметры.Вставить("ВидОперацииПередача", Справочники.ВидыОпераций.Перевод);
	Результат = Запрос.Выполнить();
	Если Результат.Пустой() Тогда
		Возврат Документы.Поручение.ПустаяСсылка();
	КонецЕсли;
	Выборка = Результат.Выбрать();
	Выборка.Следующий();
	Возврат Выборка.ВстречноеПоручение;
КонецФункции

