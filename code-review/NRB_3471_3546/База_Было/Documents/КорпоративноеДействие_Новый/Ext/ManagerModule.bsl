Функция ТекстЗапросаИсточникаРаскрытияИзКД()
	
	Возврат "ВЫБРАТЬ
	        |	ОстаткиЦБОстатки.СчетДепо.Владелец КАК Клиент,
	        |	ОстаткиЦБОстатки.СчетДепо КАК СчетДепо,
	        |	ОстаткиЦБОстатки.РазделСчетаДепо КАК РазделСчетаДепо,
	        |	ОстаткиЦБОстатки.КоличествоОстаток КАК Количество,
	        |	ВЫБОР
	        |		КОГДА ОстаткиЦБОстатки.РазделСчетаДепо.РазделСубклиента
	        |			ТОГДА ОстаткиЦБОстатки.РазделСчетаДепо.Субклиент
	        |		ИНАЧЕ """"
	        |	КОНЕЦ КАК Выгодоприобретатель
	        |ПОМЕСТИТЬ втДанныеСпискаВладельцев
	        |ИЗ
	        |	РегистрНакопления.ОстаткиЦБ.Остатки(
	        |			&Период,
	        |			СчетДепоМХ = &СчетДепоМХ
	        |				И ЦБ В (&СписокЦенныхБумаг)) КАК ОстаткиЦБОстатки
	        |;
	        |
	        |////////////////////////////////////////////////////////////////////////////////
	        |ВЫБРАТЬ
	        |	втДанныеСпискаВладельцев.Клиент КАК Субброкер,
	        |	втДанныеСпискаВладельцев.СчетДепо КАК СчетДепо,
	        |	втДанныеСпискаВладельцев.РазделСчетаДепо КАК РазделСчетаДепо,
	        |	КорпоративноеДействие.КДРеференс КАК КДРеференс,
	        |	КорпоративноеДействие.ВидКД.Наименование КАК ТипКД,
	        |	КорпоративноеДействие.ВидКД.Код КАК КодТипаКД,
	        |	ВЫБОР
	        |		КОГДА КорпоративноеДействие.ВидКД.ТипКорпоративныхДействий = &Доход
	        |			ТОГДА ИСТИНА
	        |		ИНАЧЕ ЛОЖЬ
	        |	КОНЕЦ КАК ВидКДВыплатаДоходов,
	        |	КорпоративноеДействие.ВидКД.КодДохода КАК КодДоходовНДФЛ,
	        |	ИСТИНА КАК ЗаполнятьЗаявленнуюНалоговуюСтавку,
	        |	КорпоративноеДействие.ДатаФиксации КАК ДатаФиксации,
	        |	КорпоративноеДействие.ЦеннаяБумага1 КАК ЦеннаяБумага,
	        |	втДанныеСпискаВладельцев.Выгодоприобретатель КАК Субклиент,
	        |	ВЫБОР
	        |		КОГДА втДанныеСпискаВладельцев.СчетДепо В (&ТипыСчетовНД)
	        |			ТОГДА ""02""
	        |		КОГДА втДанныеСпискаВладельцев.СчетДепо В (&ТипыСчетовИНД)
	        |			ТОГДА ""20""
	        |		ИНАЧЕ ""01""
	        |	КОНЕЦ КАК ТипСчета,
	        |	втДанныеСпискаВладельцев.Количество КАК Количество,
	        |	КорпоративноеДействие.Дата КАК ДатаДокументаРаскрытия,
	        |	КорпоративноеДействие.Организация КАК Организация,
	        |	КорпоративноеДействие.Организация.Наименование КАК НаименованиеЮЛОрганизации,
	        |	КорпоративноеДействие.ЦеннаяБумага1.НаименованиеВыпуска КАК НаименованиеВыпуска,
	        |	КорпоративноеДействие.ДатаОкончанияПриемаИнструкцийВТБКБ КАК ДатаОкончанияПриемаИнструкцийВТБКБ,
	        |	ИСТИНА КАК ВыводитьСтрокиТаблицы,
	        |	КорпоративноеДействие.Дата КАК ДатаДокументаЗапроса
	        |ПОМЕСТИТЬ втИсточникДляРаскрытия
	        |ИЗ
	        |	Документ.КорпоративноеДействие_Новый КАК КорпоративноеДействие
	        |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ втДанныеСпискаВладельцев КАК втДанныеСпискаВладельцев
	        |		ПО (ИСТИНА)
	        |ГДЕ
	        |	ВЫРАЗИТЬ(втДанныеСпискаВладельцев.Клиент КАК Справочник.Контрагенты).Субброкер
	        |	И КорпоративноеДействие.Ссылка = &КорпоративноеДействиеСсылка";
	
КонецФункции

// Процедура - Добавить источник для раскрытия из КД
// Добавляет в менеджер временных таблиц втИсточникДляРаскрытия с информацией необходимой для заполнения запроса субброкеру на раскрытие
// Параметры:
//  МВТ							 - МенеджерВременныхТаблиц
//  КорпоративноеДействиеСсылка	 - ДокументСсылка.КорпоративноеДействие_Новый
//  Клиенты						 - Массив	 - Не обязательно. Массив клиентов, по которым будет добавлена информация, если не указано то по всем клиентам.
//
Процедура ДобавитьИсточникДляРаскрытияИзКД(МВТ, КорпоративноеДействиеСсылка, Клиенты = Неопределено) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МВТ;
	Запрос.Текст = ТекстЗапросаИсточникаРаскрытияИзКД();
	Запрос.УстановитьПараметр("КорпоративноеДействиеСсылка", КорпоративноеДействиеСсылка);
	Запрос.УстановитьПараметр("Доход", Перечисления.ТипыКорпоративныхДействий.Доход);
	
	РеквизитыКорпоративногоДействия = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(КорпоративноеДействиеСсылка,"ДатаФиксации, СчетДепо, ЦеннаяБумага1, ЦеннаяБумага2");
	Если КорпоративноеДействиеСсылка.ДатаФиксации >= ТекущаяДатаСеанса() Тогда 
		Период = ТекущаяДатаСеанса();
	Иначе 
		Период = РеквизитыКорпоративногоДействия.ДатаФиксации;
	КонецЕсли;

	СписокЦенныхБумаг = Новый Массив();
	Если ЗначениеЗаполнено(РеквизитыКорпоративногоДействия.ЦеннаяБумага1) Тогда 
		СписокЦенныхБумаг.Добавить(РеквизитыКорпоративногоДействия.ЦеннаяБумага1);
	КонецЕсли;
	Если ЗначениеЗаполнено(РеквизитыКорпоративногоДействия.ЦеннаяБумага2) Тогда 
		СписокЦенныхБумаг.Добавить(РеквизитыКорпоративногоДействия.ЦеннаяБумага2);
	КонецЕсли;

	Запрос.УстановитьПараметр("Период", Период);
	Запрос.УстановитьПараметр("СчетДепоМХ", РеквизитыКорпоративногоДействия.СчетДепо);
	Запрос.УстановитьПараметр("СписокЦенныхБумаг", СписокЦенныхБумаг);
	Запрос.УстановитьПараметр("ТипыСчетовНД", БизнесПроцессы.ОбработкаWTRCСообщения.ТипыСчетовНД());
	Запрос.УстановитьПараметр("ТипыСчетовИНД", БизнесПроцессы.ОбработкаWTRCСообщения.ТипыСчетовИНД());
	
	Если ЗначениеЗаполнено(Клиенты) Тогда 
		
		Запрос.Текст = Запрос.Текст + "
		|И втДанныеСпискаВладельцев.Клиент В(&СписокКлиентов)";
		Запрос.УстановитьПараметр("СписокКлиентов", Клиенты);
		
	КонецЕсли;
	
	Запрос.Выполнить();
	
КонецПроцедуры
