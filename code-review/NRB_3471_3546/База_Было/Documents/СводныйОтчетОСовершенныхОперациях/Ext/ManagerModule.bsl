
#Область СлужебныйПрограммныйИнтерфейс

// Формирует печатную форму для СводныйОтчетОСовершенныхОперациях.
//
// Параметры:
//  ДокументОСовершенныхОперациях				 - ДокументСсылка	 - Документ для печати
//  ОперацииДокумента							 - ТаблицаЗначений	 - Таблица операций документа
//  ВыводитьФаксимилеВОтчетах					 - Булево			 - Признак вывода факсимиле в печатную форму
//  УникальныйИдентификатор						 - УникальныйИдентификатор	 - УИД документа
// 
// Возвращаемое значение:
//   - Структура -
//  Ошибка, если не удалось сформировать печатную форму
//  Заголовок - заголовок печатной формы
//  Адрес  - адрес печатной формы во временном хранилище формы с УникальныйИдентификатор
//
Функция АдресПечатнойФормы(
	ДокументОСовершенныхОперациях,
	Знач ОперацииДокумента,
	ВыводитьФаксимилеВОтчетах,
	УникальныйИдентификатор) Экспорт
	
	Если Не ЗначениеЗаполнено(ДокументОСовершенныхОперациях) Тогда
		Описатель = Новый Структура;
		Описатель.Вставить("Ошибка", "Не указан документ ДокументСводныйОтчетОСовершенныхОперациях.");
		Возврат ПоместитьВоВременноеХранилище(Описатель, УникальныйИдентификатор);
	Иначе
		Если Не ЗначениеЗаполнено(ОперацииДокумента) Тогда
			Попытка
				ОперацииДокумента = ДокументОСовершенныхОперациях.Операции.Выгрузить();
			Исключение
				ОперацииДокумента = Неопределено;
			КонецПопытки;
		КонецЕсли;
		
		Если Не ЗначениеЗаполнено(ОперацииДокумента) Тогда
			Описатель = Новый Структура;
			Описатель.Вставить("Ошибка", "Нет операций для документа " + ДокументОСовершенныхОперациях);
			Возврат ПоместитьВоВременноеХранилище(Описатель, УникальныйИдентификатор);
		КонецЕсли;
		
		Возврат АдресПечатнойФормыОперации(
			ДокументОСовершенныхОперациях,
			ОперацииДокумента,
			ВыводитьФаксимилеВОтчетах,
			УникальныйИдентификатор);
			
	КонецЕсли;
	
КонецФункции

// Процедура - Исполнить поручение выпиской
//
// Параметры:
//  ДокументОперации					 - ДокументСсылка	 - Документ, на основании которого исполняется поручение
//  ИсключитьИзменениеВремениИсполнения	 - Булево			 - Исключить исполнение поручение из-за изменении времени документа
//  ЭтоВстречноеИсполнение				 - Булево			 - Это встречное исполнение для поручения с видом Перевод
//
Процедура ИсполнитьПоручениеВыпиской(ДокументОперации, ИсключитьИзменениеВремениИсполнения = Ложь, ЭтоВстречноеИсполнение = Ложь) Экспорт
	
	ДокументОснование = ДокументОснованиеИсполнения(ДокументОперации, ЭтоВстречноеИсполнение);
	Если ТипЗнч(ДокументОснование) <> Тип("ДокументСсылка.Поручение") Тогда
		Возврат;
	КонецЕсли;
	
	ДатаОперации = ДокументОперации.Дата;
	
	Если Документы.Поручение.ЭтоВыплатаДоходаПоПрогрессивнойШкалеНДФЛ(ДокументОснование) Тогда
		ДатаИсполненияПоручения = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДокументОснование, "ДатаИсполненияПоручения");
		Если Не ЗначениеЗаполнено(ДатаИсполненияПоручения) Тогда
			НоваяДатаИсполнения = Документы.Поручение.ДатаИсполненияПорученияВыплатыДоходаПоПрогрессивнойШкалеНДФЛ(ДокументОснование);
			Если ЗначениеЗаполнено(НоваяДатаИсполнения) Тогда
				ДокументПоручение = ДокументОснование.ПолучитьОбъект();
				ДокументПоручение.ДатаИсполненияПоручения = НоваяДатаИсполнения;
				РегистрыСведений.СтатусыПоручений.УстановитьСтатус(ДокументПоручение.Движения, ДокументОснование,
				НоваяДатаИсполнения, Перечисления.СтатусыПоручений.Исполнено);
				ДокументПоручение.Записать(РежимЗаписиДокумента.Запись);
			КонецЕсли;
		КонецЕсли;
		
	ИначеЕсли Не СуществуетИсполнениеПоручения(ДокументОснование)
		И ЗначениеЗаполнено(ДокументОснование)
		И ОбщегоНазначения.ЕстьРеквизитДокумента("ДатаИсполненияПоручения", ДокументОснование.Метаданные())
		И ДокументОснование.ДатаИсполненияПоручения <> ДатаОперации И Не ИсключитьИзменениеВремениИсполнения Тогда
		
		ДокументПоручение = ДокументОснование.ПолучитьОбъект();
		ДокументПоручение.ДатаИсполненияПоручения = ДатаОперации;
		ДокументПоручение.Записать(РежимЗаписиДокумента.Запись);
	Иначе
		Возврат;
	КонецЕсли;
	
КонецПроцедуры

// Возвращает признак того, что документ был отправлен ВЭДО
//
// Параметры:
//  ДокументОСовершенныхОперациях				 - ДокументСсылка	 - Проверяемый документ
// 
// Возвращаемое значение:
//   - Булево- Истина, если был отправлен ранее
//
Функция БылОтправленВЭДО(ДокументОСовершенныхОперациях) Экспорт
	
	// Отправка в ЭДО (0) или в Kafka (1)
	ВыгрузкаВЭДО = ОбщегоНазначенияПовтИсп.ЗначениеГлобальногоПараметра("83.СводныеОтчетыВЭДОилиВKafka", 1) = 0;
	
	Запрос = Новый Запрос;
	
	Если ВыгрузкаВЭДО Тогда
		
		Запрос.Текст =
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	РегистрацияДокументовВЭДО.Идентификатор КАК Идентификатор
		|ИЗ
		|	РегистрСведений.РегистрацияДокументовВЭДО КАК РегистрацияДокументовВЭДО
		|ГДЕ
		|	РегистрацияДокументовВЭДО.Документ = &Документ";
		
	Иначе
		
		Запрос.Текст =
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	ЖурналИсходящихСообщенийKafka.Идентификатор КАК Идентификатор
		|ИЗ
		|	РегистрСведений.ЖурналИсходящихСообщенийKafka КАК ЖурналИсходящихСообщенийKafka
		|ГДЕ
		|	ЖурналИсходящихСообщенийKafka.ОтправляемыйОбъект = &Документ
		|	И ЖурналИсходящихСообщенийKafka.Отправлено
		|	И НЕ ЖурналИсходящихСообщенийKafka.ОшибкаОтправки";
		
	КонецЕсли;
	
	Запрос.УстановитьПараметр("Документ", ДокументОСовершенныхОперациях.Ссылка);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Возврат Не РезультатЗапроса.Пустой();
	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция АдресПечатнойФормыОперации(
	ДокументОСовершенныхОперациях,
	ОперацииДокумента,
	ВыводитьФаксимилеВОтчетах,
	УникальныйИдентификатор)
	
	ФормированиеОтчетовОСовершенныхОперациях = Обработки.ФормированиеОтчетовОСовершенныхОперациях.Создать();
	
	ПараметрыПечати = Новый Структура;
	ПараметрыПечати.Вставить("Период"					, ОперацииДокумента[0].ДатаОперации);
	ПараметрыПечати.Вставить("ДатаОтчета"				, ДокументОСовершенныхОперациях.Дата);
	ПараметрыПечати.Вставить("СчетДепо"					, ДокументОСовершенныхОперациях.СчетДепо);
	ПараметрыПечати.Вставить("ДокументОснование"		, ДокументОСовершенныхОперациях);
	ПараметрыПечати.Вставить("Клиент"					, ДокументОСовершенныхОперациях.СчетДепо.Владелец);
	ПараметрыПечати.Вставить("ОтчетыНаАнглийскомЯзыке"	, ДокументОСовершенныхОперациях.СчетДепо.Владелец.ОтчетыНаАнглийскомЯзыке);
	ПараметрыПечати.Вставить("ТаблицаОпераций"			, ОперацииДокумента);
	ПараметрыПечати.Вставить("ВыводитьФаксимилеВОтчетах", ВыводитьФаксимилеВОтчетах);
	
	ТабДок = ФормированиеОтчетовОСовершенныхОперациях.СформироватьПечатнуюФорму(ПараметрыПечати);
	
	Описатель = Новый Структура;
	Описатель.Вставить("ТабДок", ТабДок);
	Описатель.Вставить("Заголовок", "Приложение к РДО");
	Возврат ПоместитьВоВременноеХранилище(Описатель, УникальныйИдентификатор);
	
КонецФункции

Функция СуществуетИсполнениеПоручения(ДокументОснование)
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Поручение.Исполнение КАК ИсполнениеПоручения
	|ИЗ
	|	Документ.Поручение КАК Поручение
	|ГДЕ
	|	Поручение.Ссылка = &Поручение
	|	И Поручение.Исполнение <> ЗНАЧЕНИЕ(Документ.ИсполнениеПоручения.ПустаяСсылка)";
	Запрос.УстановитьПараметр("Поручение", ДокументОснование);
	Результат = Запрос.Выполнить();
	Возврат Не Результат.Пустой();
	
КонецФункции

Функция ДокументОснованиеИсполнения(ДокументОперации, ЭтоВстречноеИсполнение)
	
	ТипОснования = ТипЗнч(ДокументОперации);
	Если ТипОснования = Тип("ДокументСсылка.Поручение") Или ТипОснования = Тип("ДокументОбъект.Поручение") Тогда
		ДокументОснование = ДокументОперации.Ссылка;
	Иначе
		Если ЭтоВстречноеИсполнение Тогда
			ДокументОснование = ДокументОперации.ДокументОснованиеВстречный;
		Иначе
			ДокументОснование = ДокументОперации.ДокументОснование;
		КонецЕсли;
	КонецЕсли;
	
	Возврат ДокументОснование;
	
КонецФункции

#КонецОбласти
