Перем УслугаОперации;
Перем Тариф;

// Проверка на существование документа созданного на основании
// переданного через параметр.
//
// Параметры
//  Основание  – Документ.Поручение
//                 
// Возвращаемое значение:
//   Булево.Истина   – если уже есть докумнт созданный на переданном основании.
//
Функция ПроверкаНаСозданныеДокументыНаОснованииТекущего(Основание)
	ДокументСозданныйНаОсновании = Документы.ПогашениеЦБ.НайтиПоРеквизиту("ДокументОснование", Основание);
	
	Возврат Ссылка <> ДокументСозданныйНаОсновании И НЕ ДокументСозданныйНаОсновании.Пустая();
КонецФункции

