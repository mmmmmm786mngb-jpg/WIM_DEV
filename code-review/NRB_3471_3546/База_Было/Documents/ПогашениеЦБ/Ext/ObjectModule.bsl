// ПРОЦЕДУРЫ И ФУНКЦИИ ДЛЯ ОБЕСПЕЧЕНИЯ ПРОВЕДЕНИЯ ДОКУМЕНТА

Процедура СформироватьВыпискиПоПогашениюЦБ()
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	ПогашениеЦБЦенныеБумаги.Депонент	КАК Депонент,
	|	ПогашениеЦБЦенныеБумаги.Количество	КАК Остаток,
	|	Выписка.Ссылка КАК ВыпискаСсылка,
	|	ПогашениеЦБЦенныеБумаги.СчетДепо КАК СчетДепо,
	|	ПогашениеЦБЦенныеБумаги.СчетДепо.Владелец КАК СчетДепоВладелец
	|ИЗ
	|	Документ.ПогашениеЦБ.ЦенныеБумаги КАК ПогашениеЦБЦенныеБумаги
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.Выписка КАК Выписка
	|		ПО ПогашениеЦБЦенныеБумаги.Депонент = Выписка.СчетДепо.Владелец
	|			И ПогашениеЦБЦенныеБумаги.Ссылка = Выписка.ОперацияЦБ
	|ГДЕ
	|	ПогашениеЦБЦенныеБумаги.Ссылка = &Ссылка");
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	Результат = Запрос.Выполнить();
	Если Результат.Пустой() Тогда
		Возврат;
	КонецЕсли; 
	
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		
		Если ЗначениеЗаполнено(Выборка.ВыпискаСсылка) Тогда
			ВыпискаОбъект = Выборка.ВыпискаСсылка.ПолучитьОбъект();
		Иначе
			ВыпискаОбъект = Документы.Выписка.СоздатьДокумент();
		КонецЕсли;
		
		Если ВыпискаОбъект.ПометкаУдаления Тогда
			ВыпискаОбъект.ПометкаУдаления = Ложь;
			ВыпискаОбъект.Записать(РежимЗаписиДокумента.Запись);
		КонецЕсли;	
		
		ВыпискаОбъект.ОперацияЦБ = Ссылка;
		ВыпискаОбъект.Дата = Дата;
		ВыпискаОбъект.ВидОтчета = Перечисления.ВидыОтчетов.Отчет;
		ВыпискаОбъект.ДокументОснование = ДокументОснование;
		ВыпискаОбъект.СчетДепо = Выборка.СчетДепо;
		ВыпискаОбъект.ВладелецСчета = Выборка.СчетДепоВладелец;
		ВыпискаОбъект.ПометкаУдаления = Ложь;
		ВыпискаОбъект.Записать(РежимЗаписиДокумента.Проведение);
		
	КонецЦикла;
	
КонецПроцедуры

Функция СформироватьЗапросПоРегиструОстаткиЦБ()
	
	Запрос = Новый Запрос;
	
	Запрос.Текст = "ВЫБРАТЬ
	|	ОстаткиЦБОстатки.СчетДепо,
	|	ОстаткиЦБОстатки.РазделСчетаДепо,
	|	ОстаткиЦБОстатки.СчетДепоМХ,
	|	ОстаткиЦБОстатки.РазделСчетаДепоМХ,
	|	ОстаткиЦБОстатки.ЦБ,
	|	ОстаткиЦБОстатки.СтатусЦБ,
	|	ОстаткиЦБОстатки.КоличествоОстаток
	|ИЗ
	|	РегистрНакопления.ОстаткиЦБ.Остатки(&выбДата, ЦБ = &выбЦБ) КАК ОстаткиЦБОстатки";
	
	Запрос.УстановитьПараметр("выбДата", Дата);
	Запрос.УстановитьПараметр("выбЦБ", ЦБ);
	
	Результат = Запрос.Выполнить();
	
	Возврат Результат.Выгрузить();
	
КонецФункции

Функция СформироватьЗапросПоРегиструЦБВПути()
	
	Запрос = Новый Запрос;
	
	Запрос.Текст = "ВЫБРАТЬ
	|	ЦБВПутиОстатки.СчетДепо КАК СчетДепо,
	|	ЦБВПутиОстатки.РазделСчетаДепо КАК РазделСчетаДепо,
	|	ЦБВПутиОстатки.СчетДепоМХ КАК СчетДепоМХ,
	|	ЦБВПутиОстатки.РазделСчетаДепоМХ КАК РазделСчетаДепоМХ,
	|	ЦБВПутиОстатки.ЦБ КАК ЦБ,
	|	ЦБВПутиОстатки.КоличествоОстаток КАК КоличествоОстаток
	|ИЗ
	|	РегистрНакопления.ЦБВПути.Остатки(&выбДата, ЦБ = &выбЦБ) КАК ЦБВПутиОстатки";
	
	Запрос.УстановитьПараметр("выбДата", Дата);
	Запрос.УстановитьПараметр("выбЦБ", ЦБ);
	
	Результат = Запрос.Выполнить();
	
	Возврат Результат.Выгрузить();
	
КонецФункции

// По строке выборки результата запроса по документу формируем движения по регистрам
//
// Параметры: 
//  ВыборкаПоШапкеДокумента                  - выборка из результата запроса по шапке документа.
//	ВыборкаПоРаботники					     - выборка из результата запроса ТЧ "Работники".									
//  СтруктураПроведенияПоРегистрамНакопления - структура, содержащая имена регистров 
//                                             накопления по которым надо проводить документ
//  СтруктураПараметров                      - структура параметров проведения.
//
// Возвращаемое значение:
//  Нет.
//
Процедура ДобавитьСтрокуВДвиженияПоРегистрамНакопления(текДвижения, табЦБ, флДелатьДвиженияПоРегиструУслуг)
	
	Для Каждого СтрокаЦБ Из табЦБ Цикл
		
		Движение = текДвижения.ДобавитьРасход();
		Движение.Период = Дата;
		Движение.СчетДепо = СтрокаЦБ.СчетДепо;
		Движение.РазделСчетаДепо = СтрокаЦБ.РазделСчетаДепо;
		Движение.ЦБ = СтрокаЦБ.ЦБ;
		Движение.СчетДепоМХ = СтрокаЦБ.СчетДепоМХ;
		Движение.РазделСчетаДепоМХ = СтрокаЦБ.РазделСчетаДепоМХ;
		
		Если текДвижения = Движения.ОстаткиЦБ Тогда
			
			Движение.СтатусЦБ = СтрокаЦБ.СтатусЦБ;
			
		КонецЕсли;
		
		Движение.Количество = СтрокаЦБ.КоличествоОстаток;
		
		Если флДелатьДвиженияПоРегиструУслуг Тогда
			
			ДепозитарийКлиент.СоздатьДвиженияДокумента(Дата,Движения,СтрокаЦБ.СчетДепо.Владелец,УслугаОперации,Тариф);
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

