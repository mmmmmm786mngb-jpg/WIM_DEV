//// ОБРАБОТЧИКИ СОБЫТИЙ

Процедура ОбработкаПроведения(Отказ, Режим)
	табОстаткиЦБ = СформироватьЗапросПоРегиструОстаткиЦБ();
	табЦБВПути   = СформироватьЗапросПоРегиструЦБВПути();
	
	Если табОстаткиЦБ.Количество() = 0 И табЦБВПути.Количество() Тогда
		Сообщить("Указанных ценных бумаг нет ни на одном из счетов депо.");
		Отказ = Истина;
	КонецЕсли;
	
	флУслуги = Ложь;
	
	Если НЕ Отказ Тогда
		ДобавитьСтрокуВДвиженияПоРегистрамНакопления(Движения.ОстаткиЦБ, табОстаткиЦБ, флУслуги);
		ДобавитьСтрокуВДвиженияПоРегистрамНакопления(Движения.ЦБВПути, табЦБВПути, флУслуги);
	КонецЕсли;
	
	СформироватьВыпискиПоПогашениюЦБ();
КонецПроцедуры

Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
	
	Если ОбменДанными.Загрузка = Истина Тогда
		Возврат;
	КонецЕсли;
	
	Если ОбщегоНазначения.ЗначениеНеЗаполнено(ЦБ) Тогда
		
		Сообщить("Не выбрана ценная бумаги");  
		Отказ = Истина;			
		
	КонецЕсли;	
	
	Если ОбщегоНазначения.ЗначениеНеЗаполнено(Инициатор) Тогда
		
		Сообщить("Не выбран эмитент");  
		Отказ = Истина;			
		
	КонецЕсли;	
	
	УстановитьНовыйНомер();
	
КонецПроцедуры

Процедура ОбработкаЗаполнения(Основание) Экспорт
	Если Основание = Неопределено Тогда
		Возврат;
	КонецЕсли; 
	
	Если ПроверкаНаСозданныеДокументыНаОснованииТекущего(Основание) Тогда
		Проверка = Истина;
		Сообщить("На основании данного поручения уже есть введенный документ!!!");
		Возврат;
	КонецЕсли;
	
	Если Основание.ВидОперацииД = Справочники.ВидыОпераций.Погашение
		ИЛИ Основание.ВидОперацииД = Справочники.ВидыОпераций.СписаниеАкцийПриЛиквидацииЭмитента
		ИЛИ Основание.ВидОперацииД = Справочники.ВидыОпераций.СписаниеОбесценившихсяЦенныхБумаг
		Тогда 
		Инициатор = Основание.Инициатор;
		ДокументОснование = Основание.Ссылка;			
		Комментарий = Строка(Основание);
		ЦБ = Основание.ЦБ;
		Дата = ОбщегоНазначения.ДатаДокумента(Основание);
		ЦенныеБумаги.Очистить();
		Для каждого СтрокаТаблицы Из Основание.ЦенныеБумагиСписываемые Цикл
			НоваяСтрока = ЦенныеБумаги.Добавить();
			НоваяСтрока.СчетДепо						= СтрокаТаблицы.СчетДепо;
			НоваяСтрока.Депонент						= СтрокаТаблицы.СчетДепо.Владелец;
			НоваяСтрока.РазделСчетаДепо					= СтрокаТаблицы.РазделСчетаДепо;
			НоваяСтрока.СчетДепоМестаХранения			= СтрокаТаблицы.СчетДепоМХ;
			НоваяСтрока.РазделСчетаДепоМестаХранения	= СтрокаТаблицы.РазделСчетаДепоМХ;
			НоваяСтрока.Количество						= СтрокаТаблицы.Количество;
		КонецЦикла;
	Иначе
		Проверка			= Истина;
		ДокументОснование 	= Документы.Поручение.ПустаяСсылка();			
		Сообщить("На основании данного вида поручения нельзя создать документ ""Погашение ценных бумаг"". 
				|Вид операции должен быть ""Погашение ЦБ"", ""Списание акций при ликвидации эмитента"""
				+ " или ""Списание обесценившихся ценных бумаг""!");
		Возврат;	
	КонецЕсли;
	
КонецПроцедуры

Процедура ПриУстановкеНовогоНомера(СтандартнаяОбработка, Префикс)
	
	СтандартнаяОбработка = Ложь;
	
	Если Проверка Тогда
		Возврат;
	КонецЕсли;
	
	Префикс = НумераторыОбъектов.ПолучитьПрефиксНомера(ЭтотОбъект);
	
	Номер = НумераторыОбъектов.ПолучитьНомерДокумента(ЭтотОбъект, Префикс);
	
КонецПроцедуры

