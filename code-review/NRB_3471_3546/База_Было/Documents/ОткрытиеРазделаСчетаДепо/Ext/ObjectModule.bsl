// Возвращает доступные варианты печати документа
//
// Вовращаемое значение:
//  Струткура, каждая строка которой соответствует одному из вариантов печати
// 
Функция ПолучитьСтруктуруПечатныхФорм() Экспорт
	СтруктураПечатныхФорм = Новый Структура;
	Возврат СтруктураПечатныхФорм;
КонецФункции // ПолучитьСтруктуруПечатныхФорм()

#Если Клиент Тогда
	
// Процедура осуществляет печать документа. Можно направить печать на 
// экран или принтер, а также распечатать необходмое количество копий.
//
//  Название макета печати передается в качестве параметра,
// по переданному названию находим имя макета в соответствии.
//
// Параметры:
//  НазваниеМакета - строка, название макета.
//
Процедура Печать(ИмяМакета, КоличествоЭкземпляров = 1, НаПринтер = Ложь, НепосредственнаяПечать = Ложь) Экспорт
КонецПроцедуры

#КонецЕсли

Функция СозданиеРазделаСчетаДепоДепонента()
	
	Если ТипЗнч(СчетДепо) = Тип("СправочникСсылка.СчетаДепоМХ") Тогда
		ТипСпр = "РазделыСчетаДепоМХ";
	Иначе
		ТипСпр = "РазделыСчетаДепо";
	КонецЕсли;
	
	Если ЗначениеЗаполнено(РазделСчетаДепо) Тогда
		НовыйОбъект	= РазделСчетаДепо.ПолучитьОбъект();
		Если НовыйОбъект.ПометкаУдаления Тогда
			НовыйОбъект.ПометкаУдаления = Ложь;
		КонецЕсли;
	Иначе
		НовыйОбъект = Справочники[ТипСпр].СоздатьЭлемент();
		НовыйОбъект.Код = Справочники.ПравилаФормированияКодовРазделовСчетовДепо.КодРаздела(ТипРазделаСчетаДЕПО, НаименованиеРазделаСчетаДепо, СчетДепо, Субклиент);
			
		СообщениеОбОшибке = Новый СообщениеПользователю;
		СообщениеОбОшибке.Текст = "Не удалось создать раздел счета депо" + ?(ТипСпр = "РазделыСчетаДепоМХ", " МХ.", ".");
		Если НЕ ЗначениеЗаполнено(НовыйОбъект.Код) Тогда
			СообщениеОбОшибке.Текст = СообщениеОбОшибке.Текст
			+ " Не найдено правило формирования кода для типа раздела " + ТипРазделаСчетаДЕПО;
			СообщениеОбОшибке.Сообщить();
			Возврат Ложь;
		КонецЕсли;		
		Если НайденКодРаздела(ТипСпр, НовыйОбъект.Код, СчетДепо) Тогда
			СообщениеОбОшибке.Текст = СообщениеОбОшибке.Текст
			+ " Уже существует раздел с кодом " + СокрЛП(НовыйОбъект.Код);
			СообщениеОбОшибке.Сообщить();
			Возврат Ложь;
		КонецЕсли;
		
		НовыйОбъект.Наименование = Справочники.РазделыСчетаДепо.НаименованиеРазделаСчетаДепоПоТипу(
			ТипРазделаСчетаДЕПО, Залогодержатель, Дата);
			
		Если ТипРазделаСчетаДЕПО = Перечисления.ТипыРазделовСчетовДЕПО.ОбеспеченияДержатель
			И ТипЗнч(НовыйОбъект) = Тип("СправочникОбъект.РазделыСчетаДепо") Тогда
			НовыйОбъект.Брокер = Брокер;
		КонецЕсли;
		Если ТипСпр = "РазделыСчетаДепо" Тогда
			НовыйОбъект.Залогодержатель = Залогодержатель;
		КонецЕсли;
		НовыйОбъект.Владелец = СчетДепо;
		НовыйОбъект.ТипРазделаСчетаДЕПО = ТипРазделаСчетаДЕПО;
	КонецЕсли;
	
	Если ТипЗнч(СчетДепо) = Тип("СправочникСсылка.СчетаДепо") Тогда
		НовыйОбъект.РазделСубклиента = РазделСубклиента;
		НовыйОбъект.Субклиент = Субклиент;
		
		ДатаНачалаСвязиРазделовСчетаДепоИМХ = Константы.ДатаНачалаОбменаНеторговымиОперациями.Получить();
		ПрименяетсяСвязьРазделовСчетаДепоИМХ = ЗначениеЗаполнено(ДатаНачалаСвязиРазделовСчетаДепоИМХ) И Дата >= ДатаНачалаСвязиРазделовСчетаДепоИМХ;
		Если ПрименяетсяСвязьРазделовСчетаДепоИМХ Тогда
			НовыйОбъект.РазделСчетаДепоМХ = РазделСчетаДепоМХ;
		КонецЕсли;
	КонецЕсли;
	
	НовыйОбъект.ВходящийНомерПоручения = ДокументОснование;
	НовыйОбъект.ДатаОткрытияСчета = Дата;  	
	НовыйОбъект.СтатусСчетаДепо = Перечисления.СтатусыСчетовДепо.Открыт;
	НовыйОбъект.ПроверитьЗаполнение();
	НовыйОбъект.Записать();
	
	Если Не ЗначениеЗаполнено(РазделСчетаДепо) Тогда
		РазделСчетаДепо = НовыйОбъект.Ссылка;
	КонецЕсли;
	
	СчетДепоОбъект = СчетДепо.ПолучитьОбъект();
	Если ТипРазделаСчетаДЕПО = Перечисления.ТипыРазделовСчетовДЕПО.Основной И Не РазделСубклиента Тогда
		
		Если ТипЗнч(СчетДепо) = Тип("СправочникСсылка.СчетаДепоМХ") Тогда
			СчетДепоОбъект.ОсновнойРазделСчета = НовыйОбъект.Ссылка;
		Иначе
			СчетДепоОбъект.ОсновнойРазделСчетаДепо = НовыйОбъект.Ссылка;
		КонецЕсли;
		
	КонецЕсли;
	
	СчетДепоОбъект.Записать();
	Возврат Истина;
КонецФункции // СозданиеСчетаДепоДепонента()

Функция НайденКодРаздела(ТипСпр, НовыйКод, СчетДепо)
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	СправочникРазделы.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.РазделыСчетаДепоМХ КАК СправочникРазделы
	|ГДЕ
	|	СправочникРазделы.Код = &Код
	|	И СправочникРазделы.Владелец = &СчетДепо
	|ДЛЯ ИЗМЕНЕНИЯ
	|	Справочник.РазделыСчетаДепоМХ";
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "РазделыСчетаДепоМХ", ТипСпр);
	Запрос.УстановитьПараметр("Код", НовыйКод);
	Запрос.УстановитьПараметр("СчетДепо", СчетДепо);
	Возврат НЕ Запрос.Выполнить().Пустой();
КонецФункции

Процедура ОбработкаПроверкиЗаполнения(Отказ, ПроверяемыеРеквизиты)
	Если ТипЗнч(СчетДепо) = Тип("СправочникСсылка.СчетаДепо")
		И Перечисления.ТипыСчетовДепо.НоминальныхДержателей().Найти(СчетДепо.ТипСчетаДепо) <> Неопределено Тогда
		Если РазделСубклиента Тогда
			ПроверяемыеРеквизиты.Добавить("Субклиент");
		ИначеЕсли ЗначениеЗаполнено(Субклиент) И Не РазделСубклиента Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не установлен флаг ""Раздел субклиента"" при заполненном поле ""Субклиент""");
			Отказ = Истина;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

