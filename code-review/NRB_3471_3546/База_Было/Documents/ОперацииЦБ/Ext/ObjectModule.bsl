Процедура ПередУдалением(Отказ)
	// Удаление движений приемки / снятия ЦБ на обслуживании при соответствующем виде операций
	Если (Ссылка.ВидОперацииД = Справочники.ВидыОпераций.ПриемЦБНаОбслуживание ИЛИ Ссылка.ВидОперацииД = Справочники.ВидыОпераций.СнятиеЦБсОбслуживания) И Ссылка.Проведен Тогда
		УдалитьСтарыйДвиженияПримекиСнятияОбслуживания();
	КонецЕсли;
	Если ТипЗнч(ДокументОснование) = Тип("ДокументСсылка.Поручение") Тогда
		Документы.Поручение.ОтменитьПризнакНачислитьКомиссиюДепо(ДокументОснование, Ссылка);
	КонецЕсли;
	Если ЗначениеЗаполнено(ДокументОснованиеВстречный) Тогда
		Документы.Поручение.ОтменитьПризнакНачислитьКомиссиюДепо(ДокументОснованиеВстречный, Ссылка);
	КонецЕсли;
КонецПроцедуры

Процедура УдалитьСтарыйДвиженияПримекиСнятияОбслуживания()
	Если ВидОперацииД = Справочники.ВидыОпераций.ПриемЦБНаОбслуживание Тогда
		ЦБОбъект	= ЦБ.ПолучитьОбъект();
		ЦБОбъект.ДатаПриемаНаОбслуживание		= Дата(1,1,1);
		ЦБОбъект.ДокументПриемаНаОбслуживание	= Документы.ОперацииЦБ.ПустаяСсылка();
		ЦБОбъект.Записать();
	ИначеЕсли ВидОперацииД = Справочники.ВидыОпераций.СнятиеЦБсОбслуживания Тогда
		ЦБОбъект	= ЦБ.ПолучитьОбъект();
		ЦБОбъект.ДатаСнятияСОбслуживания		= Дата(1,1,1);
		ЦБОбъект.ДокументСнятияСОбслуживания	= Документы.ОперацииЦБ.ПустаяСсылка();
		ЦБОбъект.Записать();
	КонецЕсли;
КонецПроцедуры

// Добавляет движения в регистр накопления ОстаткиЦБ, а для видов операции с установленным флажком ДвижениеПоЦБ
// с определенной даты также и в регистры накопления ОстаткиЦБДепозитарийМХ и ОстаткиЦБМестоРасчетов.
// При этом в движениях по этим регистрам в качестве периода используются ДатаИсполненияВДепозитарииМХ
// и ДатаИсполненияВМестеРасчетов соответственно (из этих реквизитов берется дата, из "Дата" берется время).
Процедура ДобавитьДвиженияВОстаткиЦБ(ВидДвижения, СтатусЦБ, Количество, ПоРеквизитамПолучателям = Ложь, пРазделСчетаДепо = Неопределено)
	Если ПоРеквизитамПолучателям Тогда
		пСчетДепо			= СчетДепоПолучатель;
		пРазделСчетаДепо	= РазделСчетаДепоПолучатель;
		пСчетДепоМХ			= СчетДепоМХПолучатель;
		пРазделСчетаДепоМХ	= РазделСчетаДепоМХПолучатель;
	Иначе
		пСчетДепо			= СчетДепо;
		Если пРазделСчетаДепо = Неопределено Тогда
			пРазделСчетаДепо	= РазделСчетаДепо;
		КонецЕсли;
		пСчетДепоМХ			= СчетДепоМХ;
		пРазделСчетаДепоМХ	= РазделСчетаДепоМХ;
	КонецЕсли;
		
	Движение = Движения.ОстаткиЦБ.Добавить(); 
	Движение.ВидДвижения		= ВидДвижения;
	Движение.Период				= Дата;		// По основному регистру движение делается на дату документа
	Движение.СчетДепо			= пСчетДепо;
	Движение.РазделСчетаДепо	= пРазделСчетаДепо;
	Движение.ЦБ					= ЦБ;
	Движение.СчетДепоМХ			= пСчетДепоМХ;
	Движение.РазделСчетаДепоМХ	= пРазделСчетаДепоМХ;
	Движение.СтатусЦБ			= СтатусЦБ;
	Движение.Количество			= Количество;
	
	Если ВидОперацииД.ДвижениеПоЦБ Тогда
		Движение = Движения.ОстаткиЦБДепозитарийМХ.Добавить(); 
		Движение.ВидДвижения		= ВидДвижения;
		Движение.Период				= ОбъединениеДатыВремени(ДатаИсполненияВДепозитарииМХ, Дата);	// Дата - специальная дата, время - из стандартной даты
		Движение.СчетДепо			= пСчетДепо;
		Движение.РазделСчетаДепо	= пРазделСчетаДепо;
		Движение.ЦБ					= ЦБ;
		Движение.СчетДепоМХ			= пСчетДепоМХ;
		Движение.РазделСчетаДепоМХ	= пРазделСчетаДепоМХ;
		Движение.СтатусЦБ			= СтатусЦБ;
		Движение.Количество			= Количество;
		
		Движение = Движения.ОстаткиЦБМестоРасчетов.Добавить(); 
		Движение.ВидДвижения		= ВидДвижения;
		Движение.Период				= ОбъединениеДатыВремени(ДатаИсполненияВМестеРасчетов, Дата);	// Дата - специальная дата, время - из стандартной даты
		Движение.СчетДепо			= пСчетДепо;
		Движение.РазделСчетаДепо	= пРазделСчетаДепо;
		Движение.ЦБ					= ЦБ;
		Движение.СчетДепоМХ			= пСчетДепоМХ;
		Движение.РазделСчетаДепоМХ	= пРазделСчетаДепоМХ;
		Движение.СтатусЦБ			= СтатусЦБ;
		Движение.Количество			= Количество;
	КонецЕсли;
КонецПроцедуры

