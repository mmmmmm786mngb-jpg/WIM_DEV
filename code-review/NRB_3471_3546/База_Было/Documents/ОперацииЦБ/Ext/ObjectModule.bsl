Перем КолСписЦБСОбрем;		// Количество ЦБ с обременением для списания
Перем ВидыОпераций;
Перем ЗаблокированноеКоличествоЦБ;

////////////////////////////////////////////////////////////////////////////////
// ОБРАБОТЧИКИ СОБЫТИЙ

// BSLLS:CognitiveComplexity-off
// BSLLS:CyclomaticComplexity-off

Процедура ОбработкаПроведения(Отказ, Режим)
	
	Если ЗначениеЗаполнено(БлокировочныйРазделСчетаДепо)
		Или РазделСчетаДепо.ТипРазделаСчетаДЕПО = Перечисления.ТипыРазделовСчетовДЕПО.БлокированоРасчеты 
	Тогда
		ЗаблокированноеКоличествоЦБ = ЗаблокированноеКоличествоЦБ();
	Иначе
		ЗаблокированноеКоличествоЦБ = 0;
	КонецЕсли;
	
	Отказ = ЕстьОшибки();
	
	// Проконтроллируем не был ли это документ приемки / снятия ЦБ на обслуживании ранее и если да, то уберем старые движения
	Если (Ссылка.ВидОперацииД = Справочники.ВидыОпераций.ПриемЦБНаОбслуживание
			ИЛИ Ссылка.ВидОперацииД = Справочники.ВидыОпераций.СнятиеЦБсОбслуживания)
		И Ссылка.Проведен Тогда
		УдалитьСтарыйДвиженияПримекиСнятияОбслуживания();
	КонецЕсли;	
	
	Если ТипЗнч(ДокументОснование) = Тип("ДокументСсылка.ЦБВПути") Тогда
		Если ВидОперацииД = ВидыОпераций.Депонирование ИЛИ ВидОперацииД = ВидыОпераций.НачислениеДоходовЦБ Тогда
			Движение 					= Движения.ЦБВПути.ДобавитьРасход();
			Движение.Период 			= Дата;
			Движение.СчетДепо 			= СчетДепо;
			Движение.РазделСчетаДепо 	= РазделСчетаДепо;
			Движение.ЦБ 				= ЦБ;
			Движение.СчетДепоМХ 		= СчетДепоМХ;
			Движение.РазделСчетаДепоМХ 	= РазделСчетаДепоМХ;
			Движение.Количество 		= Количество;
			
			ДобавитьДвиженияВОстаткиЦБ(ВидДвиженияНакопления.Приход, Перечисления.СтатусыЦБ.Свободна, Количество);
				
		ИначеЕсли ВидОперацииД = ВидыОпераций.СнятиеСДепонирования Тогда
			Движение 					= Движения.ЦБВПути.ДобавитьРасход();
			Движение.Период 			= Дата;
			Движение.СчетДепо 			= СчетДепо;
			Движение.РазделСчетаДепо 	= РазделСчетаДепо;
			Движение.ЦБ 				= ЦБ;
			Движение.СчетДепоМХ 		= СчетДепоМХ;
			Движение.РазделСчетаДепоМХ 	= РазделСчетаДепоМХ;
			Движение.Количество 		= Количество;
			
		ИначеЕсли ВидОперацииД 	= ВидыОпераций.Перевод
			ИЛИ ВидОперацииД = ВидыОпераций.Перемещение
			ИЛИ ВидОперацииД = ВидыОпераций.ПереводМеждуРазделамиСчетаДепо Тогда
			Движение 					= Движения.ЦБВПути.ДобавитьРасход();
			Движение.Период 			= Дата;
			Движение.СчетДепо 			= СчетДепоПолучатель;
			Движение.РазделСчетаДепо 	= РазделСчетаДепоПолучатель;
			Движение.ЦБ 				= ЦБ;
			Движение.СчетДепоМХ 		= СчетДепоМХПолучатель;
			Движение.РазделСчетаДепоМХ 	= РазделСчетаДепоМХПолучатель;
			Движение.Количество 		= Количество;
			
			ДобавитьДвиженияВОстаткиЦБПолучатель(ВидДвиженияНакопления.Приход, Перечисления.СтатусыЦБ.Свободна,
				Количество);
		КонецЕсли;
		
	Иначе
		Если ВидОперацииД = ВидыОпераций.Депонирование ИЛИ 
			ВидОперацииД = ВидыОпераций.НачислениеДоходовЦБ Тогда
			ДобавитьДвиженияВОстаткиЦБ(ВидДвиженияНакопления.Приход, Перечисления.СтатусыЦБ.Свободна, Количество);
			
		ИначеЕсли ВидОперацииД = ВидыОпераций.СнятиеСДепонирования Или ВидОперацииД = ВидыОпераций.Выкуп Тогда
			
			Если ВидОперацииД = ВидыОпераций.СнятиеСДепонирования И РасчетыНаDMA Тогда
				
				ДобавитьДвиженияВОстаткиЦБ(ВидДвиженияНакопления.Расход, Перечисления.СтатусыЦБ.Свободна, Количество - ЗаблокированноеКоличествоЦБ, , РазделСчетаДепо);
				Если ЗаблокированноеКоличествоЦБ > 0 Тогда
					ДобавитьДвиженияВОстаткиЦБ(ВидДвиженияНакопления.Расход, Перечисления.СтатусыЦБ.Свободна, ЗаблокированноеКоличествоЦБ, , БлокировочныйРазделСчетаДепо);
				КонецЕсли;
				
			Иначе
				Если Количество > КолСписЦБСОбрем Тогда
					ДобавитьДвиженияВОстаткиЦБ(ВидДвиженияНакопления.Расход, Перечисления.СтатусыЦБ.Свободна,
						Количество - КолСписЦБСОбрем);
				КонецЕсли;
				
				Если КолСписЦБСОбрем > 0 Тогда
					ДобавитьДвиженияВОстаткиЦБ(ВидДвиженияНакопления.Расход, Перечисления.СтатусыЦБ.Обременена,
						КолСписЦБСОбрем);
				КонецЕсли;
			КонецЕсли;

		ИначеЕсли ВидОперацииД = ВидыОпераций.Перевод
			ИЛИ ВидОперацииД = ВидыОпераций.Перемещение
			ИЛИ ВидОперацииД = ВидыОпераций.ПереводМеждуРазделамиСчетаДепо Тогда
			
			Если Количество > КолСписЦБСОбрем Тогда
				ДобавитьДвиженияВОстаткиЦБ(ВидДвиженияНакопления.Расход, Перечисления.СтатусыЦБ.Свободна,
					Количество - КолСписЦБСОбрем);
			КонецЕсли;
			
			Если КолСписЦБСОбрем > 0 Тогда
				ДобавитьДвиженияВОстаткиЦБ(ВидДвиженияНакопления.Расход, Перечисления.СтатусыЦБ.Обременена,
					КолСписЦБСОбрем);
			КонецЕсли;
			
			ДобавитьДвиженияВОстаткиЦБПолучатель(ВидДвиженияНакопления.Приход, Перечисления.СтатусыЦБ.Свободна,
				Количество);
				
		ИначеЕсли 	ВидОперацииД = ВидыОпераций.Блокирование 		ИЛИ
			ВидОперацииД = ВидыОпераций.ВозвратИзЗалога 	ИЛИ
			ВидОперацииД = ВидыОпераций.Обременение			ИЛИ
			ВидОперацииД = ВидыОпераций.ПередачаВЗалог 		ИЛИ
			ВидОперацииД = ВидыОпераций.Разблокирование 	ИЛИ
			ВидОперацииД = ВидыОпераций.СнятиеОбременения	Тогда
			
			СтатусРасход = СтатусПоВидуОперации("РАСХОД",ВидОперацииД);		
			СтатусПриход = СтатусПоВидуОперации("ПРИХОД",ВидОперацииД);		
			
			Если Количество > КолСписЦБСОбрем Тогда
				ДобавитьДвиженияВОстаткиЦБ(ВидДвиженияНакопления.Расход, СтатусРасход, Количество - КолСписЦБСОбрем);
			КонецЕсли;
			
			Если КолСписЦБСОбрем > 0 Тогда
				ДобавитьДвиженияВОстаткиЦБ(ВидДвиженияНакопления.Расход, Перечисления.СтатусыЦБ.Обременена, КолСписЦБСОбрем);
			КонецЕсли;
			
			Если ВидОперацииД = ВидыОпераций.ВозвратИзЗалога
				ИЛИ ВидОперацииД = ВидыОпераций.ПередачаВЗалог Тогда
				
				ДобавитьДвиженияВОстаткиЦБПолучатель(ВидДвиженияНакопления.Приход, СтатусПриход, Количество);
			Иначе
				ДобавитьДвиженияВОстаткиЦБ(ВидДвиженияНакопления.Приход, СтатусПриход, Количество);
			КонецЕсли;
			
		КонецЕсли;
	КонецЕсли;
	
	// Записываем движения регистров
	ЗаписатьДвиженияОстатковЦБ();
	Движения.ЦБВПути.Записать();
	
	Если НЕ(Контрагент = Справочники.Биржи.MICEX ИЛИ НЕ(ЗначениеЗаполнено(Контрагент))) Тогда
		РасчетныеПараметры = РасчетТарифов.РасчетСтоимостиУслуги(
			Дата,
			Справочники.ДоговорыКонтрагентов.НайтиПоКоду(Лев(СокрЛП(СчетДЕПО.Код),7)),
			Новый Структура("Операция, МестоХранения1, МестоХранения2",				
				ВидОперацииД,
				
				?(ВидОперацииД = ВидыОпераций.Депонирование
					ИЛИ ВидОперацииД = ВидыОпераций.СнятиеСДепонирования
					ИЛИ ВидОперацииД = ВидыОпераций.Перевод
					ИЛИ ВидОперацииД = ВидыОпераций.Перемещение
					ИЛИ ВидОперацииД = ВидыОпераций.ПереводМеждуРазделамиСчетаДепо,
				МестоХранения, Неопределено),
				
				?(ВидОперацииД = ВидыОпераций.Депонирование
					ИЛИ ВидОперацииД = ВидыОпераций.СнятиеСДепонирования
					ИЛИ ВидОперацииД = ВидыОпераций.Перевод
					ИЛИ ВидОперацииД = ВидыОпераций.Перемещение
					ИЛИ ВидОперацииД = ВидыОпераций.ПереводМеждуРазделамиСчетаДепо,
				МестоХраненияПолучатель, Неопределено)
				)
			);
		Если РасчетныеПараметры <> Неопределено Тогда
			Движение = Движения.УслугиДепозитария.ДобавитьПриход();
			Движение.Период = Дата;
			Движение.Инициатор = Справочники.ДоговорыКонтрагентов.НайтиПоКоду(Лев(СокрЛП(СчетДЕПО.Код),7));
			Движение.МестоХранения = МестоХранения;
			Движение.Услуга = РасчетныеПараметры.Услуга;
			Движение.СтавкаНДС = Перечисления.СтавкиНДС.НДС18_118;
			Движение.Валюта = РасчетныеПараметры.Валюта;
			Движение.Сумма = РасчетныеПараметры.Сумма;
			Движение.СуммаВВалюте = Конвертации.КонвертацияВалюты(Дата, Движение.Сумма, РасчетныеПараметры.Валюта);
			Движение.СуммаНДС = РасчетТарифов.РТ_РасчетНДС(Движение.СтавкаНДС, Движение.Сумма);
			Движение.СуммаВсего = РасчетТарифов.РТ_ОбщаяСумма(Движение.СтавкаНДС,Движение.Сумма,Движение.СуммаНДС);
			Движение.Сумма = Движение.СуммаВсего - Движение.СуммаНДС;
			Движение.ТипТарифа = РасчетныеПараметры.ТипТарифа;
			Движение.Тариф = РасчетныеПараметры.Тариф;
			Движения.УслугиДепозитария.Записать();
		КонецЕсли; 	
		Если ВидОперацииД = ВидыОпераций.Перевод Тогда
			РасчетныеПараметры = РасчетТарифов.РасчетСтоимостиУслуги(
				Дата,
				Справочники.ДоговорыКонтрагентов.НайтиПоКоду(Лев(СокрЛП(СчетДЕПОПолучатель.Код),7)),
				Новый Структура("Операция, МестоХранения1, МестоХранения2",
					ВидОперацииД, МестоХранения, МестоХраненияПолучатель));
			Если РасчетныеПараметры <> Неопределено Тогда
				Движение = Движения.УслугиДепозитария.ДобавитьПриход();
				Движение.Период = Дата;
				Движение.Инициатор = Справочники.ДоговорыКонтрагентов.НайтиПоКоду(Лев(СокрЛП(СчетДЕПОПолучатель.Код),7));
				Движение.МестоХранения = МестоХраненияПолучатель;
				Движение.Услуга = РасчетныеПараметры.Услуга;
				Движение.СтавкаНДС = Перечисления.СтавкиНДС.НДС18_118;
				Движение.Валюта = РасчетныеПараметры.Валюта;
				Движение.Сумма = РасчетныеПараметры.Сумма;
				Движение.СуммаВВалюте = Конвертации.КонвертацияВалюты(Дата, Движение.Сумма, РасчетныеПараметры.Валюта);
				Движение.СуммаНДС = РасчетТарифов.РТ_РасчетНДС(Движение.СтавкаНДС, Движение.Сумма);
				Движение.СуммаВсего = РасчетТарифов.РТ_ОбщаяСумма(Движение.СтавкаНДС,Движение.Сумма,Движение.СуммаНДС);
				Движение.Сумма = Движение.СуммаВсего - Движение.СуммаНДС;
				Движение.ТипТарифа = РасчетныеПараметры.ТипТарифа;
				Движение.Тариф = РасчетныеПараметры.Тариф;
				Движения.УслугиДепозитария.Записать();
			КонецЕсли; 	
		КонецЕсли;
	КонецЕсли; 	
	
	Если ВидОперацииД = ВидыОпераций.Перевод Тогда
		ЗаполнитьДатыИсполненияВПоручении(ДокументОснование, Отказ);
	КонецЕсли;
	
	Документы.СводныйОтчетОСовершенныхОперациях.ИсполнитьПоручениеВыпиской(Ссылка);
	
	Если ВидОперацииД = ВидыОпераций.Перевод Тогда
		ЗаполнитьДатыИсполненияВПоручении(ДокументОснованиеВстречный, Отказ);
		ЭтоВстречноеИсполнение = Истина;
		Документы.СводныйОтчетОСовершенныхОперациях.ИсполнитьПоручениеВыпиской(Ссылка, , ЭтоВстречноеИсполнение);
	КонецЕсли;
	
	// Движения по справочнику ЦБ при Снятии или Приемке ЦБ на обслуживание
	Если ВидОперацииД = Справочники.ВидыОпераций.ПриемЦБНаОбслуживание Тогда
		Если ЗначениеЗаполнено(ЦБ.ДатаСнятияСОбслуживания) И (ЦБ.ДатаСнятияСОбслуживания < Дата) Тогда
			ОбщегоНазначения.СообщитьОбОшибке("Невозможно принять на обслуживание бумаги, которые были сняты с обслуживания ранее!!!", Отказ);
			Возврат;
		ИначеЕсли ЗначениеЗаполнено(ЦБ.ДатаПриемаНаОбслуживание) И (НЕ ЦБ.ДокументПриемаНаОбслуживание = Ссылка) Тогда
			ОбщегоНазначения.СообщитьОбОшибке("Невозможно принять бумаги на обслуживание повторно!!!", Отказ);
			Возврат;
		КонецЕсли;
		ЦБОбъект	= ЦБ.ПолучитьОбъект();
		ЦБОбъект.ДатаПриемаНаОбслуживание		= Дата;
		ЦБОбъект.ДокументПриемаНаОбслуживание	= Ссылка;
		ЦБОбъект.Записать();
	ИначеЕсли ВидОперацииД = Справочники.ВидыОпераций.СнятиеЦБсОбслуживания Тогда
		Если ЗначениеЗаполнено(ЦБ.ДатаСнятияСОбслуживания) И (НЕ ЦБ.ДокументСнятияСОбслуживания = Ссылка) Тогда
			ОбщегоНазначения.СообщитьОбОшибке("Невозможно снять с обслуживания бумаги, которые уже были сняты с обслуживания!!!", Отказ);
			Возврат;
		КонецЕсли;
		ЦБОбъект	= ЦБ.ПолучитьОбъект();
		ЦБОбъект.ДатаСнятияСОбслуживания		= Дата;
		ЦБОбъект.ДокументСнятияСОбслуживания	= Ссылка;
		ЦБОбъект.Записать();
	КонецЕсли;	
	
	СформироватьДвиженияПоРегиструЗаблокированныеЦБ(Отказ);
	
	Если Документы.Поручение.ЭтоИнвентарноеПоручениеСИсполнениемВРежимеЧастичногоИсполнения(ДокументОснование) Тогда
		ДанныеИсполнения = Документы.ИсполнениеПоручения.ДанныеИсполненияПоручения(ДокументОснование);
		Если ЗначениеЗаполнено(ДанныеИсполнения.Статус) Тогда
			РегистрыСведений.СтатусыПоручений.УстановитьСтатус(Движения, ДокументОснование, Дата, ДанныеИсполнения.Статус, Количество);
		КонецЕсли;
	КонецЕсли;
	
	Если ТипЗнч(ДокументОснование) = Тип("ДокументСсылка.Поручение") Тогда
		ОтключитьЗаполнениеПризнакаНачислитьКомиссию =
			ДополнительныеСвойства.Свойство("ОтключитьЗаполнениеПризнакаНачислитьКомиссию")
			И ДополнительныеСвойства.ОтключитьЗаполнениеПризнакаНачислитьКомиссию = Истина;
		Если Не ОтключитьЗаполнениеПризнакаНачислитьКомиссию Тогда
			Документы.Поручение.УстановитьПризнакНачислитьКомиссиюДепо(ДокументОснование, Ссылка);
			Если ЗначениеЗаполнено(ДокументОснованиеВстречный) Тогда
				Документы.Поручение.УстановитьПризнакНачислитьКомиссиюДепо(ДокументОснованиеВстречный, Ссылка);
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

// BSLLS:CognitiveComplexity-on
// BSLLS:CyclomaticComplexity-on

Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
	
	Если ОбменДанными.Загрузка = Истина Тогда
		Возврат;
	КонецЕсли;
	
	Если Не ТипЗнч(ДокументОснование) = Тип("ДокументСсылка.иц_СводноеПоручение") Тогда
		ЭтоПерепроведение = РежимЗаписи = РежимЗаписиДокумента.Проведение И Ссылка.Проведен;
		ЭтоОтменаПроведения = РежимЗаписи = РежимЗаписиДокумента.ОтменаПроведения И Ссылка.Проведен;
		
		Если ЭтоПерепроведение Или ЭтоОтменаПроведения Тогда
			ТекстСообщения = "Повторное проведение или отмена проведения " + Ссылка + " запрещена, обратитесь в команду Поддержки!";
			ОбщегоНазначения.СообщитьОбОшибке(ТекстСообщения, Отказ);
		КонецЕсли;
	КонецЕсли;
	
	Если ВидОперацииД <> ВидыОпераций.СнятиеЦБсОбслуживания И ВидОперацииД <> ВидыОпераций.ПриемЦБНаОбслуживание Тогда
		Если Не ЗначениеЗаполнено(ВидОперацииД) Тогда
			Сообщить("Не выбран вид операции",СтатусСообщения.Важное);  
			Отказ = Истина;			
		ИначеЕсли ВидОперацииД.КлассОпераций<>Перечисления.КлассыОпераций.ПустаяСсылка() Тогда
			КлассОпераций = ВидОперацииД.КлассОпераций;
		КонецЕсли;	    
		
		Если Не ЗначениеЗаполнено(СчетДепоМХ) Тогда
			Сообщить("Не выбран счет депо хранилища",СтатусСообщения.Важное);  
			Отказ = Истина;			
		КонецЕсли;
		
		Если Не ЗначениеЗаполнено(СчетДепо) Тогда
			Сообщить("Не выбран счет депо депонента",СтатусСообщения.Важное);  
			Отказ = Истина;			
		КонецЕсли;	     
		
		Если Не ЗначениеЗаполнено(РазделСчетаДепоМХ) Тогда
			Сообщить("Не выбран раздел счета депо хранилища",СтатусСообщения.Важное);  
			Отказ = Истина;			
		КонецЕсли;	                                        
		
		Если Не ЗначениеЗаполнено(РазделСчетаДепо) Тогда
			Сообщить("Не выбран раздел счета депо депонента",СтатусСообщения.Важное);  
			Отказ = Истина;			
		КонецЕсли;
		
		Если Не ЗначениеЗаполнено(Инициатор) Тогда
			Сообщить("Не выбран депонент",СтатусСообщения.Важное);  
			Отказ = Истина;			
		КонецЕсли;	
		
		Если Не ЗначениеЗаполнено(МестоХранения) Тогда
			Сообщить("Не выбрано хранилище",СтатусСообщения.Важное);  
			Отказ = Истина;			
		КонецЕсли;	
		
		Если Не ЗначениеЗаполнено(ЦБ) Тогда
			Сообщить("Не выбрана ценная бумага",СтатусСообщения.Важное);  
			Отказ = Истина;			
		КонецЕсли;	
		
		Если Не ЗначениеЗаполнено(Количество) Тогда
			Сообщить("Не задано количество",СтатусСообщения.Важное);  
			Отказ = Истина;			
		КонецЕсли;
	КонецЕсли;
	
	Если ВидОперацииД = ВидыОпераций.Перевод
		ИЛИ ВидОперацииД = ВидыОпераций.Перемещение
		ИЛИ ВидОперацииД = ВидыОпераций.ПереводМеждуРазделамиСчетаДепо Тогда
		Если Не ЗначениеЗаполнено(Получатель) Тогда
			Сообщить("Не выбран депонент-получатель",СтатусСообщения.Важное);  
			Отказ = Истина;			
		КонецЕсли;	
		
		Если Не ЗначениеЗаполнено(СчетДепоПолучатель) Тогда
			Сообщить("Не выбран счет депо получателя",СтатусСообщения.Важное);  
			Отказ = Истина;			
		КонецЕсли;	
		
		Если Не ЗначениеЗаполнено(РазделСчетаДепоПолучатель) Тогда
			Сообщить("Не выбран раздел счета депо получателя",СтатусСообщения.Важное);  
			Отказ = Истина;			
		КонецЕсли;	
		
		Если Не ЗначениеЗаполнено(МестоХраненияПолучатель) Тогда
			Сообщить("Не выбрано хранилище получателя",СтатусСообщения.Важное);  
			Отказ = Истина;			
		КонецЕсли;	
		
		Если Не ЗначениеЗаполнено(СчетДепоМХПолучатель) Тогда
			Сообщить("Не выбран счет депо хранилища получателя",СтатусСообщения.Важное);  
			Отказ = Истина;			
		КонецЕсли;	
		
		Если Не ЗначениеЗаполнено(РазделСчетаДепоМХПолучатель) Тогда
			Сообщить("Не выбран раздел счета депо хранилища получателя",СтатусСообщения.Важное);  
			Отказ = Истина;			
		КонецЕсли;	
		
	КонецЕсли;
	
	Если ВидОперацииД = ВидыОпераций.Перевод Тогда
		Если НЕ ЗначениеЗаполнено(ДокументОснованиеВстречный) Тогда
			ОбщегоНазначения.СообщитьОбОшибке("Не выбран документ-основание (встречный)!", Отказ);
		КонецЕсли;		
		
		Если НЕ ЗначениеЗаполнено(ИнициаторВстречный) Тогда
			ОбщегоНазначения.СообщитьОбОшибке("Не выбран Инициатор (встречный)!", Отказ);
		КонецЕсли;	
		
		Если РежимЗаписи = РежимЗаписиДокумента.Проведение ИЛИ РежимЗаписи = РежимЗаписиДокумента.ОтменаПроведения Тогда 
			УстановитьНовыйНомер();	
		КонецЕсли;
		
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(Основание) И ЗначениеЗаполнено(ДокументОснование) Тогда
		Основание = ДокументОснование;
	КонецЕсли;
	
	Если НЕ РучнойВвод Тогда
		УстановитьНовыйНомер();
	КонецЕсли;
	// Установим автора или ответственного за изменения документа
	Если Не ЭтоНовый() Тогда
		Изменил	= ПараметрыСеанса.ТекущийПользователь;
	Иначе
		Автор	= ПараметрыСеанса.ТекущийПользователь;
	КонецЕсли;
	
	Если РежимЗаписи = РежимЗаписиДокумента.Проведение И ВидОперацииД.ДвижениеПоЦБ Тогда
		Если НЕ ЗначениеЗаполнено(ДатаИсполненияВДепозитарииМХ)	ИЛИ НЕ ЗначениеЗаполнено(ДатаИсполненияВМестеРасчетов) Тогда
			ОбщегоНазначения.СообщитьОбОшибке("Необходимо указывать даты исполнения в депозитарии МХ и в месте расчетов!", Отказ);
			Возврат;
		КонецЕсли;
	КонецЕсли;
	
	БлокированоВЗалоге = Перечисления.ТипыРазделовСчетовДЕПО.БлокированоВЗалоге;
	Если ВидОперацииД = ВидыОпераций.ПередачаВЗалог
		И РазделСчетаДепоПолучатель.ТипРазделаСчетаДЕПО <> БлокированоВЗалоге Тогда
			ОбщегоНазначения.СообщитьОбОшибке("При передаче в залог раздел счета депо получателя должен иметь тип '"
			+ БлокированоВЗалоге + "'", Отказ);
			Возврат;
	КонецЕсли;
	
	Если ВидОперацииД = ВидыОпераций.ВозвратИзЗалога
		И РазделСчетаДепо.ТипРазделаСчетаДЕПО <> БлокированоВЗалоге Тогда
			ОбщегоНазначения.СообщитьОбОшибке("При возврате из залога раздел счета депо депонента должен иметь тип '"
			+ БлокированоВЗалоге + "'", Отказ);
			Возврат;
	КонецЕсли;
		
	Если РежимЗаписи = РежимЗаписиДокумента.Проведение Тогда
		CrmContractNumber = Справочники.КодыЗагрузки.НайтиПоВладельцуИБирже(Депонент, Справочники.КлассификаторыЗагрузки.CrmContractNumber);
		ИсключитьИзОбменаДанными = Не ЗначениеЗаполнено(CrmContractNumber);
	КонецЕсли;
	
КонецПроцедуры

Процедура ЗаполнитьОперациюНаОснованииПорученияИСвязатьПоручения(ДокОснование) Экспорт  
	
	ЗаполнитьОперациюНаОснованииПоручения(ДокОснование);
	
	ВстречноеПоручение = Документы.Поручение.ВстречноеПоручениеПеревод(ДокОснование);
	Если Не ЗначениеЗаполнено(ВстречноеПоручение) Тогда
		ОбщегоНазначения.СообщитьОбОшибке("Встречное поручение не найдено и не будет заполнено");
		Если ТранзакцияАктивна()Тогда 
			ОтменитьТранзакцию();
		КонецЕсли;
	Иначе
		ЭтотОбъект.Основание = ДокОснование.Ссылка;
		ЭтотОбъект.ДокументОснованиеВстречный = ВстречноеПоручение.Ссылка;
		ЭтотОбъект.Основание = Строка(ДокОснование);
		ЭтотОбъект.НомерВходящегоПоручения = ДокОснование.Номер;
		Если Инициатор = ДокОснование.Депонент Тогда 
			ЭтотОбъект.ИнициаторВстречный = ДокОснование.Контрагент;
		Иначе 
			ЭтотОбъект.ИнициаторВстречный = ДокОснование.Депонент;
		КонецЕсли;
		
		Если ДокОснование.ДатаИсполненияПоручения <> Дата(1,1,1) 
			И ДокОснование.ДатаИсполненияПорученияВДепозитарииМХ <> Дата(1,1,1)
			И ДокОснование.ДатаИсполненияПорученияВМестеРасчетов <> Дата(1,1,1) Тогда 
			ДатаИсполненияПоручения = ДокОснование.ДатаИсполненияПоручения;
			ДатаИсполненияПорученияВДепозитарииМХ = ДокОснование.ДатаИсполненияПорученияВДепозитарииМХ;
			ДатаИсполненияПорученияВМестеРасчетов = ДокОснование.ДатаИсполненияПорученияВМестеРасчетов;
		Иначе 
			ДатаИсполненияПоручения = ВстречноеПоручение.ДатаИсполненияПоручения;
			ДатаИсполненияПорученияВДепозитарииМХ = ВстречноеПоручение.ДатаИсполненияПорученияВДепозитарииМХ;
			ДатаИсполненияПорученияВМестеРасчетов = ВстречноеПоручение.ДатаИсполненияПорученияВМестеРасчетов;
		КонецЕсли;

		
		Если ДокОснование.СчетДепоМХ = ДокОснование.СчетДепоМХКонтрагента И ДокОснование.РазделСчетаДепоМХ = ДокОснование.РазделСчетаДепоМХКонтрагента Тогда
	     	// Если перевод внутри ВТКБ датой исполнения будет дата ОперацииЦБ
			ДатаИсполненияПоручения = ТекущаяДатаСеанса();
			ЭтотОбъект.Дата = ДатаИсполненияПоручения;
			ЭтотОбъект.ДатаИсполненияВДепозитарииМХ = ДатаИсполненияПоручения;
			ЭтотОбъект.ДатаИсполненияВМестеРасчетов = ДатаИсполненияПоручения;
		ИначеЕсли ДатаИсполненияПоручения <> Дата(1,1,1) Тогда
			ЭтотОбъект.Дата = ДатаИсполненияПоручения;
			ЭтотОбъект.ДатаИсполненияВДепозитарииМХ = ДатаИсполненияПорученияВДепозитарииМХ;
			ЭтотОбъект.ДатаИсполненияВМестеРасчетов = ДатаИсполненияПорученияВМестеРасчетов;
		КонецЕсли
		
	
	КонецЕсли;
		
КонецПроцедуры

Процедура ЗаполнитьОперациюНаОснованииПоручения(Основание, ДанныеЦБ = Неопределено)
	
	Если Основание.ВидОперацииД.КлассОпераций = Перечисления.КлассыОпераций.Инвентарные
		ИЛИ Основание.ВидОперацииД.КлассОпераций = Перечисления.КлассыОпераций.Комплексные
		ИЛИ Основание.ВидОперацииД.КлассОпераций = Перечисления.КлассыОпераций.Глобальные
		Тогда 
		Дата = ?(ЗначениеЗаполнено(Основание.ДатаИсполненияПоручения), Основание.ДатаИсполненияПоручения, Основание.Дата);
		ДокументОснование			= Основание.Ссылка;	
		НомерВходящегоПоручения		= Основание.ВходящийНомерПоручения;
		ВидОперацииД				= Основание.ВидОперацииД;
		Комментарий					= "Поручение № " + Основание.Номер + " от " + Основание.Дата;
		Инициатор					= Основание.Инициатор;
		Депонент					= Основание.СчетДепо.Владелец;
		СчетДепо					= Основание.СчетДепо;
		
		Если Основание.ВидОперацииД = Справочники.ВидыОпераций.Депонирование
			ИЛИ Основание.ВидОперацииД = Справочники.ВидыОпераций.СнятиеСДепонирования Тогда
			РасчетыНаDMA = Основание.РасчетыНаDMA;
		Иначе
			РасчетыНаDMA = Ложь;
		КонецЕсли;
		
		Если Основание.ВидОперацииД = Справочники.ВидыОпераций.СнятиеСДепонирования Тогда
			РазделСчетаДепо			= РазделСчетаДепоПоСтруктуреПодчиненностиПоручения(Основание);
			Если РазделСчетаДепо <> Основание.РазделСчетаДепо И РасчетыНаDMA Тогда
				БлокировочныйРазделСчетаДепо = РазделСчетаДепо;
				РазделСчетаДепо = Основание.РазделСчетаДепо;
			КонецЕсли;
		Иначе
			РазделСчетаДепо 		= Основание.РазделСчетаДепо;
		КонецЕсли;
		МестоХранения				= Основание.МХДепонента;
		СчетДЕПОМХ					= Основание.СчетДепоМХ;
		РазделСчетаДепоМХ			= Основание.РазделСчетаДепоМХ;
		Контрагент					= Основание.Контрагент;
		ДатаСделки					= Основание.ДатаСделки;
		Референс					= Основание.Референс;
		
		ИсточникДанныхЦБ = ?(ЗначениеЗаполнено(ДанныеЦБ), ДанныеЦБ, Основание);
		ЦБ = ИсточникДанныхЦБ.ЦБ;
		Цена = ИсточникДанныхЦБ.ЦенаСделкиЦБ;
		Если Не ДополнительныеСвойства.Свойство("ОставитьБезИзмененийКоличествоСуммуОперацииЦБ") Тогда
			Количество = ИсточникДанныхЦБ.КоличествоЦБ;
			Сумма = ИсточникДанныхЦБ.СуммаСделки;
		КонецЕсли;
		
		Если Основание.ВидОперацииД.КлассОпераций = Перечисления.КлассыОпераций.Инвентарные Тогда
			Залогодержатель			= Основание.Залогодержатель;
		КонецЕсли;
		
		ДатаИсполненияВДепозитарииМХ = Основание.ДатаИсполненияПорученияВДепозитарииМХ;
		ДатаИсполненияВМестеРасчетов = Основание.ДатаИсполненияПорученияВМестеРасчетов;
		
		ЗаполнениеРеквизитовПоВидуОперации();
		
	ИначеЕсли Основание.ВидОперацииД = Справочники.ВидыОпераций.СнятиеЦБсОбслуживания
		ИЛИ Основание.ВидОперацииД = Справочники.ВидыОпераций.ПриемЦБНаОбслуживание Тогда
		Дата = ?(ЗначениеЗаполнено(Основание.ДатаИсполненияПоручения), Основание.ДатаИсполненияПоручения, Основание.Дата);
		ДокументОснование			= Основание.Ссылка;	
		НомерВходящегоПоручения		= Основание.ВходящийНомерПоручения;
		ВидОперацииД				= Основание.ВидОперацииД;
		Комментарий					= "Поручение № " + Основание.Номер + " от " + Основание.Дата;
		Инициатор					= Основание.Инициатор;
		ЦБ							= Основание.ЦБ;
		ДатаСделки					= Основание.ДатаСделки;
		Референс					= Основание.Референс;
		ДатаИсполненияВДепозитарииМХ = Основание.ДатаИсполненияПорученияВДепозитарииМХ;
		ДатаИсполненияВМестеРасчетов = Основание.ДатаИсполненияПорученияВМестеРасчетов;
		
	Иначе
		Проверка = Истина;
		ДокументОснование = Документы.Поручение.ПустаяСсылка();			
		Сообщить("На основании данного вида поручения нельзя создать документ 'Операции с ценными бумагами'.
		|'Класс операции' должен относиться к классу 'Инвентарных' или 'Комплексных' операций!
		|Либо 'Вид операции' должен быть 'Прием ЦБ на обслуживание' или 'Снятие ЦБ с обслуживания'");
		
		Возврат;
	КонецЕсли;	
КонецПроцедуры

Процедура ОбработкаЗаполнения(ДанныеЗаполнения, СтандартнаяОбработка)
	
	Если ДанныеЗаполнения = Неопределено Тогда
		ОбщегоНазначения.ЗаполнитьШапкуДокумента(ЭтотОбъект, Пользователи.ТекущийПользователь(), , );
		Возврат;
	ИначеЕсли ТипЗнч(ДанныеЗаполнения) = Тип("Структура") Тогда
		ДокументОснование = ДанныеЗаполнения.ДокументОснование;
		ДанныеЦБ = ДанныеЗаполнения;
	Иначе
		ДокументОснование = ДанныеЗаполнения;
		ДанныеЦБ = Неопределено;
	КонецЕсли;
	
	Если ТипЗнч(ДокументОснование) = Тип("ДокументСсылка.ЦБВПути") Тогда
		ЗаполнитьЗначенияСвойств(ЭтотОбъект, ДокументОснование, , "Автор,Изменил,Комментарий,Дата,Номер,ДокументОснование");
		Если ЗначениеЗаполнено(ДокументОснование.ДокументОснование) Тогда
			Комментарий = "Поручение № " + СокрП(ДокументОснование.ДокументОснование.Номер) + " от " + ДокументОснование.ДокументОснование.Дата;
		КонецЕсли;		
		Дата = ОбщегоНазначения.ДатаДокумента(ДокументОснование);
		
	ИначеЕсли ТипЗнч(ДокументОснование) = Тип("ДокументСсылка.иц_СводноеПоручение") Тогда
		Дата						= ДокументОснование.Дата;
		
		ДатаИсполненияВДепозитарииМХ = ДокументОснование.Дата;
		ДатаИсполненияВМестеРасчетов = ДокументОснование.Дата;
		
		СтрокаОснования				= ДокументОснование.СоставПоручения[НомерСтрокиОснования];
		ВидОперацииД				= СтрокаОснования.ВидОперацииД;
		Инициатор					= ДокументОснование.Инициатор;
		Депонент					= СтрокаОснования.Депонент;
		СчетДепо					= СтрокаОснования.СчетДепо;
		РазделСчетаДепо				= СтрокаОснования.РазделСчетаДепо;
		МестоХранения				= СтрокаОснования.МестоХранения;
		СчетДепоМХ					= СтрокаОснования.СчетДепоМХ;
		РазделСчетаДепоМХ			= СтрокаОснования.РазделСчетаДепоМХ;
		Контрагент					= СтрокаОснования.Контрагент;
		ЦБ							= СтрокаОснования.ЦеннаяБумага;
		Количество					= СтрокаОснования.Количество;
		Сумма						= СтрокаОснования.Сумма;
		Цена						= СтрокаОснования.Цена;
		СпособХранения				= СтрокаОснования.СпособХранения;
		Комментарий					= "Сводное поручение № " + ДокументОснование.Номер + " от " + ДокументОснование.Дата;
		Получатель					= СтрокаОснования.Получатель;
		СчетДепоПолучатель			= СтрокаОснования.СчетДепоПолучатель;
		РазделСчетаДепоПолучатель	= СтрокаОснования.РазделСчетаДепоПолучатель;
		МестоХраненияПолучатель		= СтрокаОснования.МестоХраненияПолучатель;
		СчетДепоМХПолучатель		= СтрокаОснования.СчетДепоМХПолучатель;
		РазделСчетаДепоМХПолучатель = СтрокаОснования.РазделСчетаДепоМХПолучатель;
		НомерВходящегоПоручения		= ДокументОснование.ВходящийНомерПоручения;
		
	ИначеЕсли ТипЗнч(ДокументОснование) = Тип("ДокументСсылка.Поручение")
		И ДокументОснование.ВидОперацииД = Справочники.ВидыОпераций.Перевод Тогда
		
		ЗаполнитьОперациюНаОснованииПорученияИСвязатьПоручения(ДокументОснование);
		
	Иначе
		
		ЗаполнитьОперациюНаОснованииПоручения(ДокументОснование, ДанныеЦБ);
		
	КонецЕсли;
КонецПроцедуры

Процедура ОбработкаУдаленияПроведения(Отказ)
	Выписка = Документы.Выписка.Выбрать(,,Новый Структура("ОперацияЦБ",Ссылка));
	Пока Выписка.Следующий() Цикл
		ДокВыписка = Выписка.ПолучитьОбъект();
		ДокВыписка.Удалить();
	КонецЦикла;
	// Удаление движений приемки / снятия ЦБ на обслуживании при соответствующем виде операций
	Если Ссылка.ВидОперацииД = Справочники.ВидыОпераций.ПриемЦБНаОбслуживание ИЛИ Ссылка.ВидОперацииД = Справочники.ВидыОпераций.СнятиеЦБсОбслуживания Тогда
		УдалитьСтарыйДвиженияПримекиСнятияОбслуживания();
	КонецЕсли;	
	
	Если ТипЗнч(ДокументОснование) = Тип("ДокументСсылка.Поручение") Тогда
		Документы.Поручение.ОтменитьПризнакНачислитьКомиссиюДепо(ДокументОснование, Ссылка);
	КонецЕсли;
	Если ЗначениеЗаполнено(ДокументОснованиеВстречный) Тогда
		Документы.Поручение.ОтменитьПризнакНачислитьКомиссиюДепо(ДокументОснованиеВстречный, Ссылка);
	КонецЕсли;
	
КонецПроцедуры

