// Возвращает значение, содержащее дату и время из соответствующих источников
Функция ОбъединениеДатыВремени(ИсточникДаты, ИсточникВремени)
	Возврат Дата(Год(ИсточникДаты), Месяц(ИсточникДаты), День(ИсточникДаты),
		Час(ИсточникВремени), Минута(ИсточникВремени), Секунда(ИсточникВремени));
КонецФункции

Процедура ПриКопировании(ОбъектКопирования)
	ИсключитьИзОбменаДанными = Ложь;
КонецПроцедуры

Процедура ЗаполнитьДатыИсполненияВПоручении(ДокументПоручение, Отказ)
	Если ТипЗнч(ДокументПоручение) <> Тип("ДокументСсылка.Поручение") Тогда
		ОбщегоНазначения.СообщитьОбОшибке("В основании должен быть указан документ 'Поручение'", Отказ);
		Возврат;
	КонецЕсли;
	
	Если ДокументПоручение.ВидОперацииД <> Справочники.ВидыОпераций.Перевод Тогда
		ОбщегоНазначения.СообщитьОбОшибке("Документ-основание и документ-основание (встречный) должны иметь вид операции 'Перевод'", Отказ);
		Возврат;
	КонецЕсли;
	
	ДокОбъект = ДокументПоручение.ПолучитьОбъект();
	ДокОбъект.ДатаИсполненияПоручения = Дата;

	Если ВидОперацииД.ДвижениеПоЦБ Тогда
		ДокОбъект.ДатаИсполненияПорученияВДепозитарииМХ = ДатаИсполненияВДепозитарииМХ;
		ДокОбъект.ДатаИсполненияПорученияВМестеРасчетов = ДатаИсполненияВМестеРасчетов;
	КонецЕсли;
	ДокОбъект.ДополнительныеСвойства.Вставить("ОперацияЦБ",Ссылка);
	ДокОбъект.Записать(?(ДокОбъект.Проведен, РежимЗаписиДокумента.Проведение, РежимЗаписиДокумента.Запись));
КонецПроцедуры

Функция РазделСчетаДепоПоСтруктуреПодчиненностиПоручения(Основание)
	Запрос = Новый Запрос(
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	Поручение.Ссылка КАК Поручение
	|ПОМЕСТИТЬ втПоручениеНаПеревод
	|ИЗ
	|	Документ.Поручение КАК Поручение
	|ГДЕ
	|	Поручение.Проведен
	|	И Поручение.ДокументОснование = &Основание
	|	И Поручение.ВидОперацииД = &ПереводМеждуРазделами
	|;
	|/////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Операция.РазделСчетаДепоПолучатель КАК БлокировочныйРаздел
	|ИЗ
	|	Документ.ОперацииЦБ КАК Операция
	|	ВНУТРЕННЕЕ СОЕДИНЕНИЕ втПоручениеНаПеревод КАК ПоручениеНаПеревод
	|	ПО Операция.ДокументОснование = ПоручениеНаПеревод.Поручение
	|ГДЕ
	|	Операция.Проведен
	|	И Операция.РазделСчетаДепоПолучатель.ТипРазделаСчетаДЕПО = &БлокированоРасчеты
	|");
	Запрос.УстановитьПараметр("Основание",				Основание);
	Запрос.УстановитьПараметр("ПереводМеждуРазделами",	Справочники.ВидыОпераций.ПереводМеждуРазделамиСчетаДепо);
	Запрос.УстановитьПараметр("БлокированоРасчеты",		Перечисления.ТипыРазделовСчетовДЕПО.БлокированоРасчеты);
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.БлокировочныйРаздел;
	Иначе
		Возврат Основание.РазделСчетаДепо;
	КонецЕсли;
КонецФункции

Процедура СформироватьДвиженияПоРегиструЗаблокированныеЦБ(Отказ)
	
	Если ВидОперацииД = Справочники.ВидыОпераций.ПереводМеждуРазделамиСчетаДепо
		Или ВидОперацииД = Справочники.ВидыОпераций.СнятиеСДепонирования Тогда
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	ОперацииЦБ.РазделСчетаДепо.ТипРазделаСчетаДЕПО КАК ТипРазделаСчетаДЕПО,
		|	ОперацииЦБ.РазделСчетаДепоПолучатель.ТипРазделаСчетаДЕПО КАК ТипРазделаСчетаДЕПОПолучатель,
		|	ЕСТЬNULL(ЕСТЬNULL(ЕСТЬNULL(ПоручениеСписание.Дата, ПоручениеПереводОснование.Дата),
		|		ПоручениеПереводПоОтмене.ДокументОснование.ОтменяемоеПоручение.Дата), ДАТАВРЕМЯ(1, 1, 1)) КАК ПоручениеДата
		|ИЗ
		|	Документ.ОперацииЦБ КАК ОперацииЦБ
		|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.Поручение КАК ПоручениеСписание
		|		ПО ОперацииЦБ.ДокументОснование = ПоручениеСписание.Ссылка
		|			И (ПоручениеСписание.ВидОперацииД = &СнятиеСДепонирования)
		|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.Поручение КАК ПоручениеПеревод
		|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.Поручение КАК ПоручениеПереводОснование
		|			ПО ПоручениеПеревод.ДокументОснование = ПоручениеПереводОснование.Ссылка
		|				И (ПоручениеПереводОснование.ВидОперацииД = &СнятиеСДепонирования)
		|		ПО ОперацииЦБ.ДокументОснование = ПоручениеПеревод.Ссылка
		|			И (ПоручениеПеревод.ВидОперацииД = &ПереводМеждуРазделамиСчетаДепо)
		|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.Поручение КАК ПоручениеПереводПоОтмене
		|		ПО ОперацииЦБ.ДокументОснование = ПоручениеПереводПоОтмене.Ссылка
		|			И (ПоручениеПереводПоОтмене.ВидОперацииД = &ПереводМеждуРазделамиСчетаДепо)
		|			И (ПоручениеПереводПоОтмене.ДокументОснование.ВидОперацииД = &ОтменаПоручения)
		|			И (ПоручениеПереводПоОтмене.ДокументОснование.ОтменяемоеПоручение.ВидОперацииД = &СнятиеСДепонирования)
		|ГДЕ
		|	ОперацииЦБ.Ссылка = &Ссылка";
		
		Запрос.УстановитьПараметр("Ссылка", Ссылка);
		Запрос.УстановитьПараметр("СнятиеСДепонирования", Справочники.ВидыОпераций.СнятиеСДепонирования);
		Запрос.УстановитьПараметр("ПереводМеждуРазделамиСчетаДепо", Справочники.ВидыОпераций.ПереводМеждуРазделамиСчетаДепо);
		Запрос.УстановитьПараметр("ОтменаПоручения", Справочники.ВидыОпераций.ОтменаПоручения);
		Выборка = Запрос.Выполнить().Выбрать();
		Выборка.Следующий();
		
		ТипыРазделовСчетовДЕПО = Перечисления.ТипыРазделовСчетовДЕПО;
		
		Если ВидОперацииД = Справочники.ВидыОпераций.ПереводМеждуРазделамиСчетаДепо
			И Выборка.ТипРазделаСчетаДЕПОПолучатель = ТипыРазделовСчетовДЕПО.БлокированоРасчеты Тогда
			ВидДвижения = ВидДвиженияНакопления.Приход;
		ИначеЕсли Выборка.ТипРазделаСчетаДЕПО = ТипыРазделовСчетовДЕПО.БлокированоРасчеты
			Или ЗначениеЗаполнено(БлокировочныйРазделСчетаДепо) Тогда
			ВидДвижения = ВидДвиженияНакопления.Расход;
		КонецЕсли;
		
		ДатаПереходаНаНовыйМеханизмБлокировокЦБ =
			РегистрыСведений.ПараметрыГлобальные.ЗначениеПараметра("5577.ДатаПереходаНаНовыйМеханизмБлокировокЦБ");
			
		Если ЗначениеЗаполнено(ДатаПереходаНаНовыйМеханизмБлокировокЦБ)
			И Выборка.ПоручениеДата >= ДатаПереходаНаНовыйМеханизмБлокировокЦБ Тогда
			
			Если ВидДвижения = ВидДвиженияНакопления.Расход Тогда
				ВыполнитьКонтрольОтрицательныхОстатковПоРегиструЗаблокированныеЦБ(Отказ, ТекущаяДатаСеанса());
			КонецЕсли;
			
		Иначе
			
			Если ВидДвижения = ВидДвиженияНакопления.Приход Тогда
				
				МХКонтрагент = МХКонтрагентОснованияВторогоУровня();
				Если ЗначениеЗаполнено(МХКонтрагент) И МХКонтрагент <> Константы.МестоХраненияПоУмолчанию.Получить() Тогда
					Движение = Движения.ЗаблокированныеЦБвВышестоящемДепозитарии.Добавить();
					Движение.ВидДвижения					= ВидДвижения;
					Движение.Период							= Дата;
					Движение.ЦеннаяБумага					= ЦБ;
					Движение.СчетДепо						= СчетДепоПолучатель;
					Движение.МестоХранения					= МестоХраненияПолучатель;
					Движение.СчетДепоМХ						= СчетДепоМХПолучатель;
					Движение.РазделСчетаДепоМХ				= РазделСчетаДепоМХПолучатель;
					Движение.БлокировочныйРазделСчетаДепоМХ	= СчетДепоМХПолучатель.БлокировочныйРазделСчета;
					Движение.Количество						= Количество;
				КонецЕсли;
				
			ИначеЕсли ВидДвижения = ВидДвиженияНакопления.Расход Тогда
				
				Если ВидОперацииД = Справочники.ВидыОпераций.ПереводМеждуРазделамиСчетаДепо Тогда
					МХКонтрагент = МХКонтрагентОтменяемогоПоручения();
				Иначе
					МХКонтрагент = МХКонтрагентОснования();
				КонецЕсли;
				
				Если ЗначениеЗаполнено(МХКонтрагент) И МХКонтрагент <> Константы.МестоХраненияПоУмолчанию.Получить() Тогда
					Движение = Движения.ЗаблокированныеЦБвВышестоящемДепозитарии.Добавить();
					Движение.ВидДвижения					= ВидДвижения;
					Движение.Период							= Дата;
					Движение.ЦеннаяБумага					= ЦБ;
					Движение.СчетДепо						= СчетДепо;
					Движение.МестоХранения					= МестоХранения;
					Движение.СчетДепоМХ						= СчетДепоМХ;
					Движение.РазделСчетаДепоМХ				= РазделСчетаДепоМХ;
					Движение.БлокировочныйРазделСчетаДепоМХ	= СчетДепоМХ.БлокировочныйРазделСчета;
					Движение.Количество						= ЗаблокированноеКоличествоЦБ;
					
					Движения.ЗаблокированныеЦБвВышестоящемДепозитарии.Записывать = Истина;
					Движения.ЗаблокированныеЦБвВышестоящемДепозитарии.Записать();
					
					ГраницаКонтроля = Новый Граница(МоментВремени(), ВидГраницы.Включая);
					ВыполнитьКонтрольОтрицательныхОстатковПоРегиструЗаблокированныеЦБ(Отказ, ГраницаКонтроля);
				КонецЕсли;
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

Функция ЗаблокированноеКоличествоЦБ()
	Если Не РасчетыНаDMA Тогда
		Возврат Количество;
	КонецЕсли;
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	НеттоПоручение.Ссылка КАК Ссылка,
	|	НеттоПоручение.ВидОперации КАК ВидОперации,
	|	НеттоПоручение.Количество КАК Количество
	|ИЗ
	|	Документ.НеттоПоручение КАК НеттоПоручение
	|ГДЕ
	|	НеттоПоручение.Поручения.Поручение = &Поручение";
	Запрос.УстановитьПараметр("Поручение", ДокументОснование);
	Результат = Запрос.Выполнить();
	Если Результат.Пустой() Тогда
		Возврат Количество;
	КонецЕсли;
	Выборка = Результат.Выбрать();
	Выборка.Следующий();
	Если Выборка.ВидОперации = Справочники.ВидыОпераций.СнятиеСДепонирования Тогда
		Возврат Выборка.Количество;
	Иначе // такого не долно случиться, поэтому возвращаем заведомо невыполнимое количество, которое приведёт к ошибке проведения
		Возврат Количество;
	КонецЕсли;
КонецФункции

Функция МХКонтрагентОснованияВторогоУровня()
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	ЕСТЬNULL(ВЫРАЗИТЬ(Поручение.ДокументОснование КАК Документ.Поручение).МХКонтрагент, &ПустоеМХ) КАК МХКонтрагент
	|ИЗ
	|	Документ.Поручение КАК Поручение
	|ГДЕ
	|	Поручение.Ссылка = &Ссылка");
	Запрос.УстановитьПараметр("Ссылка", ДокументОснование);
	Запрос.УстановитьПараметр("ПустоеМХ", Справочники.МестаХранения.ПустаяСсылка());
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.МХКонтрагент;
	Иначе
		Возврат Запрос.Параметры.ПустоеМХ;
	КонецЕсли;	
КонецФункции

Функция МХКонтрагентОснования()
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	Поручение.МХКонтрагент КАК МХКонтрагент
	|ИЗ
	|	Документ.Поручение КАК Поручение
	|ГДЕ
	|	Поручение.Ссылка = &Ссылка");
	Запрос.УстановитьПараметр("Ссылка", ДокументОснование);
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.МХКонтрагент;
	Иначе
		Возврат Справочники.МестаХранения.ПустаяСсылка();
	КонецЕсли;	
КонецФункции

Функция МХКонтрагентОтменяемогоПоручения()
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	ЕСТЬNULL(ВЫРАЗИТЬ(ВЫРАЗИТЬ(Поручение.ДокументОснование КАК Документ.Поручение).ОтменяемоеПоручение КАК Документ.Поручение).МХКонтрагент, &ПустоеМХ) КАК МХКонтрагент
	|ИЗ
	|	Документ.Поручение КАК Поручение
	|ГДЕ
	|	Поручение.Ссылка = &Ссылка");
	Запрос.УстановитьПараметр("Ссылка", ДокументОснование);
	Запрос.УстановитьПараметр("ПустоеМХ", Справочники.МестаХранения.ПустаяСсылка());
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.МХКонтрагент;
	Иначе
		Возврат Запрос.Параметры.ПустоеМХ;
	КонецЕсли;	
КонецФункции

Процедура ВыполнитьКонтрольОтрицательныхОстатковПоРегиструЗаблокированныеЦБ(Отказ, ГраницаКонтроля)
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	-Остатки.КоличествоОстаток КАК Дефицит
	|ИЗ
	|	РегистрНакопления.ЗаблокированныеЦБвВышестоящемДепозитарии.Остатки(
	|			&ГраницаКонтроля,
	|			ЦеннаяБумага = &ЦеннаяБумага
	|				И СчетДепо = &СчетДепо
	|				И МестоХранения = &МестоХранения
	|				И СчетДепоМХ = &СчетДепоМХ
	|				И РазделСчетаДепоМХ = &РазделСчетаДепоМХ
	|				И БлокировочныйРазделСчетаДепоМХ = &БлокировочныйРазделСчетаДепоМХ) КАК Остатки
	|ГДЕ
	|	Остатки.КоличествоОстаток < 0");
	
	Запрос.УстановитьПараметр("ГраницаКонтроля",	ГраницаКонтроля);
	Запрос.УстановитьПараметр("ЦеннаяБумага",		ЦБ);
	Запрос.УстановитьПараметр("СчетДепо",			СчетДепо);
	Запрос.УстановитьПараметр("МестоХранения",		МестоХранения);
	Запрос.УстановитьПараметр("СчетДепоМХ",			СчетДепоМХ);
	Запрос.УстановитьПараметр("РазделСчетаДепоМХ",	РазделСчетаДепоМХ);
	Запрос.УстановитьПараметр("БлокировочныйРазделСчетаДепоМХ", СчетДепоМХ.БлокировочныйРазделСчета);
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Текст = "Недостаточно ЦБ в количестве " + Выборка.Дефицит + " шт. для списания по регистру заблокированных ЦБ.";
		ОбщегоНазначения.СообщитьОбОшибке(Текст, Отказ);
		ЗаписьЖурналаРегистрации("Проведение по регистру ""Заблокированные ЦБ в НРД""",
			УровеньЖурналаРегистрации.Ошибка, Метаданные(), Ссылка, Текст);
	КонецЕсли;
КонецПроцедуры

