Процедура ЗаполнениеРеквизитовПоВидуОперации() Экспорт
	Если ВидОперацииД = ВидыОпераций.Перевод Тогда
		МестоХраненияПолучатель 	= ДокументОснование.МХКонтрагент;
		СчетДепоМХПолучатель		= ДокументОснование.СчетДепоМХКонтрагента;
		РазделСчетаДепоМХПолучатель = ДокументОснование.РазделСчетаДепоМХКонтрагента;
		// Дозаполняем данные для поручений на перевод ЦБ
		Получатель					= ДокументОснование.Контрагент;
		СчетДепоПолучатель			= ДокументОснование.СчетДепоКонтрагента;
		РазделСчетаДепоПолучатель	= ДокументОснование.РазделСчетаДепоКонтрагента;
		
	ИначеЕсли ВидОперацииД = ВидыОпераций.Перемещение
		ИЛИ ВидОперацииД = ВидыОпераций.ПереводМеждуРазделамиСчетаДепо
		ИЛИ ВидОперацииД = ВидыОпераций.ПередачаВЗалог
		ИЛИ ВидОперацииД = ВидыОпераций.ВозвратИзЗалога Тогда
		Получатель					= ДокументОснование.Контрагент;
		СчетДепоПолучатель			= ДокументОснование.СчетДепоКонтрагента;
		РазделСчетаДепоПолучатель	= ДокументОснование.РазделСчетаДепоКонтрагента;
		МестоХраненияПолучатель 	= ДокументОснование.МХКонтрагент;
		СчетДепоМХПолучатель		= ДокументОснование.СчетДепоМХКонтрагента;
		РазделСчетаДепоМХПолучатель = ДокументОснование.РазделСчетаДепоМХКонтрагента;
	КонецЕсли;
КонецПроцедуры

Функция СтатусПоВидуОперации(ВидСтатуса, ВидОперации)
	
	Перем СтатусыЦБ;
	СтатусыЦБ = Перечисления.СтатусыЦБ;
	ЭтоПриход = ВидСтатуса = "ПРИХОД";
	
	Если ВидОперации = ВидыОпераций.Блокирование Тогда
		
		Возврат ?(ЭтоПриход, СтатусыЦБ.Блокирована, СтатусыЦБ.Свободна);
		
	ИначеЕсли ВидОперации = ВидыОпераций.ВозвратИзЗалога Тогда
		
		Возврат ?(ЭтоПриход, СтатусыЦБ.Свободна, СтатусыЦБ.Заложена);
		
	ИначеЕсли ВидОперации = ВидыОпераций.Обременение Тогда
		
		Возврат ?(ЭтоПриход, СтатусыЦБ.Обременена, СтатусыЦБ.Свободна);
		
	ИначеЕсли ВидОперации = ВидыОпераций.ПередачаВЗалог Тогда
		
		Возврат ?(ЭтоПриход, СтатусыЦБ.Заложена, СтатусыЦБ.Свободна);
		
	ИначеЕсли ВидОперации = ВидыОпераций.Разблокирование Тогда
		
		Возврат ?(ЭтоПриход, СтатусыЦБ.Свободна, СтатусыЦБ.Блокирована);
		
	ИначеЕсли ВидОперации = ВидыОпераций.СнятиеОбременения Тогда
		
		Возврат ?(ЭтоПриход, СтатусыЦБ.Свободна, СтатусыЦБ.Обременена);
		
	КонецЕсли;
	
КонецФункции

// Возвращает Истина, если остаток на счете по регистру ЦБВПути достаточен для списания.
// Иначе - Ложь.
Функция ДостаточноОстаткаПоЦБВПути(ВыбИзмерения, ВыбЗначение)
	ТекОстаток = РегистрыНакопления.ЦБВПути.Остатки(МоментВремени(), ВыбИзмерения,, "Количество");
	Возврат НЕ ( ТекОстаток.Количество() = 0 ИЛИ ТекОстаток.Итог("Количество") < ВыбЗначение );
КонецФункции

// Возвращает Истина, если остаток на счете по регистру ОстаткиЦБ достаточен для списания.
// Начиная с даты доп. движений также проверяются остатки по регистрам ОстаткиЦБДепозитарийМХ
// и ОстаткиЦБМестоРасчетов на соответствующие даты.
// Если хотя бы по одному регистру остатка не достаточно, возвращает Ложь и заполненный ШаблонОшибки.
Функция ДостаточноОстаткаПоРегистрамОстаткиЦБ(ВыбИзмерения, ВыбЗначение, ШаблонОшибки)
	
	Если ВыбЗначение = 0 Тогда
		Возврат Истина;
	КонецЕсли;
	
	ШаблонОшибки = "Количество списания {Кол} превышает остаток {Ост} на счете клиента (регистр ""{ИмяРег}"" на {Дата})
		|ЦБ: {ЦБ}  ISIN: {ISIN}
		|Счет ДЕПО: {СчетДепо}
		|Раздел счета ДЕПО: {РазделСчетаДепо}
		|Счет ДЕПО места хранения: {СчетДепоМХ}
		|Раздел счета ДЕПО места хранения: {РазделСчетаДепоМХ}";
	
	ОстатокЦБ = РегистрыНакопления.ОстаткиЦБ.Остатки(МоментВремени(), ВыбИзмерения,, "Количество");
	ОстатковДостаточно = ДостаточноОстатковПоТаблице(ОстатокЦБ, ВыбЗначение, ШаблонОшибки, 
		Метаданные.РегистрыНакопления.ОстаткиЦБ.Синоним, Дата);
		
	Если ОстатковДостаточно И ВидОперацииД.ДвижениеПоЦБ Тогда // Нужно проверять дополнительные регистры
		
		ДатаВремяМХ = ОбъединениеДатыВремени(ДатаИсполненияВДепозитарииМХ, Дата);
		ОстатокМХ = РегистрыНакопления.ОстаткиЦБДепозитарийМХ.Остатки(Новый Граница(ДатаВремяМХ, ВидГраницы.Включая), ВыбИзмерения,, "Количество");
		ОстатковДостаточно = ДостаточноОстатковПоТаблице(ОстатокМХ, ВыбЗначение, ШаблонОшибки, 
			Метаданные.РегистрыНакопления.ОстаткиЦБДепозитарийМХ.Синоним, ДатаВремяМХ);
			
		Если ОстатковДостаточно Тогда
			ДатаВремяМР = ОбъединениеДатыВремени(ДатаИсполненияВМестеРасчетов, Дата);
			ОстатокМР = РегистрыНакопления.ОстаткиЦБМестоРасчетов.Остатки(Новый Граница(ДатаВремяМР, ВидГраницы.Включая), ВыбИзмерения,, "Количество");
			ОстатковДостаточно = ДостаточноОстатковПоТаблице(ОстатокМР, ВыбЗначение, ШаблонОшибки, 
				Метаданные.РегистрыНакопления.ОстаткиЦБМестоРасчетов.Синоним, ДатаВремяМР);
		КонецЕсли;
	КонецЕсли;
	
	// Дополнительный контроль остатков ЦБ по статусам
	Если ОстатковДостаточно
		И (ВидОперацииД = ВидыОпераций.СнятиеСДепонирования
			ИЛИ ВидОперацииД = ВидыОпераций.Перевод
			ИЛИ ВидОперацииД = ВидыОпераций.Перемещение
			ИЛИ ВидОперацииД = ВидыОпераций.ПереводМеждуРазделамиСчетаДепо
			ИЛИ ВидОперацииД = ВидыОпераций.Блокирование
			ИЛИ ВидОперацииД = ВидыОпераций.Обременение
			ИЛИ ВидОперацииД = ВидыОпераций.ПередачаВЗалог) Тогда
		
		ШаблонОшибки = "Количество списания {Кол} превышает свободный остаток или сумму свободного и обремененного остатков
			|на счете клиента (регистр ""{ИмяРег}"" на {Дата})
			|ЦБ: {ЦБ} ISIN: {ISIN}
			|Счет ДЕПО: {СчетДепо}
			|Раздел счета ДЕПО: {РазделСчетаДепо}
			|Счет ДЕПО места хранения: {СчетДепоМХ}
			|Раздел счета ДЕПО места хранения: {РазделСчетаДепоМХ}";
	
		ОстатковДостаточно = ДостаточноОстатковПоСтатусам(ОстатокЦБ, ВыбЗначение, ШаблонОшибки, 
			Метаданные.РегистрыНакопления.ОстаткиЦБ.Синоним, Дата);
		Если ОстатковДостаточно И ВидОперацииД.ДвижениеПоЦБ Тогда // Нужно проверять дополнительные регистры
			
			ОстатковДостаточно = ДостаточноОстатковПоСтатусам(ОстатокМХ, ВыбЗначение, ШаблонОшибки, 
				Метаданные.РегистрыНакопления.ОстаткиЦБДепозитарийМХ.Синоним, ОбъединениеДатыВремени(ДатаИсполненияВДепозитарииМХ, Дата));
				
			Если ОстатковДостаточно Тогда
				ОстатковДостаточно = ДостаточноОстатковПоСтатусам(ОстатокМР, ВыбЗначение, ШаблонОшибки, 
					Метаданные.РегистрыНакопления.ОстаткиЦБМестоРасчетов.Синоним, ОбъединениеДатыВремени(ДатаИсполненияВМестеРасчетов, Дата));
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	// Общие параметры для шаблонов
	ШаблонОшибки = СтрЗаменить(ШаблонОшибки, "{ЦБ}",				ВыбИзмерения.ЦБ);
	ШаблонОшибки = СтрЗаменить(ШаблонОшибки, "{ISIN}",				ВыбИзмерения.ЦБ.ISIN);
	ШаблонОшибки = СтрЗаменить(ШаблонОшибки, "{СчетДепо}",			ВыбИзмерения.СчетДепо);
	ШаблонОшибки = СтрЗаменить(ШаблонОшибки, "{РазделСчетаДепо}",	ВыбИзмерения.РазделСчетаДепо);
	ШаблонОшибки = СтрЗаменить(ШаблонОшибки, "{СчетДепоМХ}",		ВыбИзмерения.СчетДепоМХ);
	ШаблонОшибки = СтрЗаменить(ШаблонОшибки, "{РазделСчетаДепоМХ}",	ВыбИзмерения.РазделСчетаДепоМХ);
	
	Возврат ОстатковДостаточно;
	
КонецФункции

Функция ДостаточноОстатковПоТаблице(Остаток, ВыбЗначение, ШаблонОшибки, ИмяРег, Дата)
	Если Остаток.Количество() = 0 ИЛИ Остаток.Итог("Количество") < ВыбЗначение Тогда
		ШаблонОшибки = СтрЗаменить(ШаблонОшибки, "{Кол}",	ВыбЗначение);		
		ШаблонОшибки = СтрЗаменить(ШаблонОшибки, "{Ост}",	Остаток.Итог("Количество"));
		ШаблонОшибки = СтрЗаменить(ШаблонОшибки, "{ИмяРег}",ИмяРег);
		ШаблонОшибки = СтрЗаменить(ШаблонОшибки, "{Дата}",	Дата);
		Возврат Ложь;
	Иначе
		Возврат Истина;
	КонецЕсли;
КонецФункции

Функция ДостаточноОстатковПоСтатусам(ТабОстатков, ВыбЗначение, ШаблонОшибки, ИмяРег, Дата)
	ОстаткиСвободна = 0;
	ОстаткиОбременена = 0;
	Для каждого СтрокаОстаток Из ТабОстатков Цикл
		Если СтрокаОстаток.СтатусЦБ = Перечисления.СтатусыЦБ.Свободна Тогда
			ОстаткиСвободна = СтрокаОстаток.Количество;
		КонецЕсли;
		Если СтрокаОстаток.СтатусЦБ = Перечисления.СтатусыЦБ.Обременена Тогда
			ОстаткиОбременена = СтрокаОстаток.Количество;
		КонецЕсли;
	КонецЦикла; 

	Если ОстаткиСвободна + ОстаткиОбременена < ВыбЗначение
		ИЛИ ОстаткиСвободна < ВыбЗначение Тогда
		ШаблонОшибки = СтрЗаменить(ШаблонОшибки, "{Кол}",	ВыбЗначение);		
		ШаблонОшибки = СтрЗаменить(ШаблонОшибки, "{ИмяРег}",ИмяРег);
		ШаблонОшибки = СтрЗаменить(ШаблонОшибки, "{Дата}",	Дата);
		Возврат Ложь;
	Иначе
		Возврат Истина;
	КонецЕсли;
КонецФункции

Функция ЕстьОшибки()
	
	ЕстьОшибка = Ложь;
	ТекстОшибки = "";
	КолСписЦБСОбрем = 0;
	
	Измерения = Новый Структура("СчетДепо, РазделСчетаДепо, СчетДепоМХ, РазделСчетаДепоМХ, ЦБ",
		СчетДепо, РазделСчетаДепо, СчетДепоМХ, РазделСчетаДепоМХ, ЦБ);
		
	ИзмеренияСоСтатусомЦБ = Новый Структура("СчетДепо, РазделСчетаДепо, СчетДепоМХ, РазделСчетаДепоМХ, ЦБ, СтатусЦБ",
		СчетДепо, РазделСчетаДепо, СчетДепоМХ, РазделСчетаДепоМХ, ЦБ, СтатусПоВидуОперации("РАСХОД", ВидОперацииД));
		
	ИзмеренияПолучатель = Новый Структура("СчетДепо, РазделСчетаДепо, СчетДепоМХ, РазделСчетаДепоМХ, ЦБ",
		СчетДепоПолучатель, РазделСчетаДепоПолучатель, СчетДепоМХПолучатель, РазделСчетаДепоМХПолучатель, ЦБ);
	
	Если ВидОперацииД = ВидыОпераций.Депонирование ИЛИ 
		ВидОперацииД = ВидыОпераций.НачислениеДоходовЦБ Тогда
		
		Если СчетДепо.СтатусСчетаДепо = Перечисления.СтатусыСчетовДепо.Закрыт Тогда
			ОбщегоНазначения.СообщитьОбОшибке("Счет депо получателя закрыт!", ЕстьОшибка);
			
		ИначеЕсли СчетДепо.СтатусСчетаДепо = Перечисления.СтатусыСчетовДепо.НеОткрыт Тогда
			ОбщегоНазначения.СообщитьОбОшибке("Счет депо получателя не открыт!", ЕстьОшибка);
		КонецЕсли;
		
		Если ТипЗнч(ДокументОснование) = Тип("ДокументСсылка.ЦБВПути") Тогда
			Если НЕ ДостаточноОстаткаПоЦБВПути(Измерения, Количество) Тогда
				ОбщегоНазначения.СообщитьОбОшибке("Количество списания превышает остаток на счете клиента (в пути)!", ЕстьОшибка);
			КонецЕсли;	
		КонецЕсли;
		
	ИначеЕсли ВидОперацииД = ВидыОпераций.СнятиеСДепонирования Тогда
		Если ТипЗнч(ДокументОснование) = Тип("ДокументСсылка.ЦБВПути") Тогда
			Если НЕ ДостаточноОстаткаПоЦБВПути(Измерения, Количество) Тогда
				ОбщегоНазначения.СообщитьОбОшибке("Количество списания превышает остаток на счете клиента (в пути)!", ЕстьОшибка);
			КонецЕсли;	
		ИначеЕсли РасчетыНаDMA Тогда
			Если Не ДостаточноОстаткаПоРегистрамОстаткиЦБ(Измерения, Количество - ЗаблокированноеКоличествоЦБ, ТекстОшибки) Тогда
				ОбщегоНазначения.СообщитьОбОшибке(ТекстОшибки, ЕстьОшибка);
			КонецЕсли;	
		Иначе
			Если НЕ ДостаточноОстаткаПоРегистрамОстаткиЦБ(Измерения, Количество, ТекстОшибки) Тогда
				ОбщегоНазначения.СообщитьОбОшибке(ТекстОшибки, ЕстьОшибка);
			КонецЕсли;	
		КонецЕсли;
		
	ИначеЕсли ВидОперацииД = ВидыОпераций.Перевод Тогда
		Если СчетДепоПолучатель.СтатусСчетаДепо = Перечисления.СтатусыСчетовДепо.Закрыт Тогда
			ОбщегоНазначения.СообщитьОбОшибке("Счет депо получателя закрыт!", ЕстьОшибка);
			
		ИначеЕсли СчетДепоПолучатель.СтатусСчетаДепо = Перечисления.СтатусыСчетовДепо.НеОткрыт Тогда
			ОбщегоНазначения.СообщитьОбОшибке("Счет депо получателя не открыт!", ЕстьОшибка);
		КонецЕсли;		
		
		Если ТипЗнч(ДокументОснование) = Тип("ДокументСсылка.ЦБВПути") Тогда
			Если НЕ ДостаточноОстаткаПоЦБВПути(ИзмеренияПолучатель, Количество) Тогда
				ОбщегоНазначения.СообщитьОбОшибке("Количество списания превышает остаток на счете клиента (в пути)!", ЕстьОшибка);
			КонецЕсли;
			
		Иначе
			Если НЕ ДостаточноОстаткаПоРегистрамОстаткиЦБ(Измерения, Количество, ТекстОшибки) Тогда
				ОбщегоНазначения.СообщитьОбОшибке(ТекстОшибки, ЕстьОшибка);
			КонецЕсли;
		КонецЕсли;	
		
	ИначеЕсли ВидОперацииД = ВидыОпераций.Перемещение
				ИЛИ ВидОперацииД = ВидыОпераций.ПереводМеждуРазделамиСчетаДепо Тогда
		Если ТипЗнч(ДокументОснование) = Тип("ДокументСсылка.ЦБВПути") Тогда
			Если НЕ ДостаточноОстаткаПоЦБВПути(ИзмеренияПолучатель, Количество) Тогда
				ОбщегоНазначения.СообщитьОбОшибке("Количество списания превышает остаток на счете клиента (в пути)!", ЕстьОшибка);
			КонецЕсли;	
			
		Иначе
			Если НЕ ДостаточноОстаткаПоРегистрамОстаткиЦБ(Измерения, Количество, ТекстОшибки) Тогда
				ОбщегоНазначения.СообщитьОбОшибке(ТекстОшибки, ЕстьОшибка);
			КонецЕсли;	
		КонецЕсли;
		
	ИначеЕсли ВидОперацииД = ВидыОпераций.Блокирование 
		ИЛИ ВидОперацииД = ВидыОпераций.Обременение
		ИЛИ ВидОперацииД = ВидыОпераций.ПередачаВЗалог Тогда
		
		Если СчетДепоПолучатель.СтатусСчетаДепо = Перечисления.СтатусыСчетовДепо.Закрыт Тогда
			ОбщегоНазначения.СообщитьОбОшибке("Счет депо получателя закрыт!", ЕстьОшибка);
			
		ИначеЕсли СчетДепоПолучатель.СтатусСчетаДепо = Перечисления.СтатусыСчетовДепо.НеОткрыт Тогда
			ОбщегоНазначения.СообщитьОбОшибке("Счет депо получателя не открыт!", ЕстьОшибка);
		КонецЕсли;		
		
		Если НЕ ДостаточноОстаткаПоРегистрамОстаткиЦБ(Измерения, Количество, ТекстОшибки) Тогда
			ОбщегоНазначения.СообщитьОбОшибке(ТекстОшибки, ЕстьОшибка);
		КонецЕсли;
		
	ИначеЕсли ВидОперацииД = ВидыОпераций.ВозвратИзЗалога
		ИЛИ ВидОперацииД = ВидыОпераций.Разблокирование
		ИЛИ ВидОперацииД = ВидыОпераций.СнятиеОбременения Тогда
		
		Если СчетДепоПолучатель.СтатусСчетаДепо = Перечисления.СтатусыСчетовДепо.Закрыт Тогда
			ОбщегоНазначения.СообщитьОбОшибке("Счет депо получателя закрыт!", ЕстьОшибка);
			
		ИначеЕсли СчетДепоПолучатель.СтатусСчетаДепо = Перечисления.СтатусыСчетовДепо.НеОткрыт Тогда
			ОбщегоНазначения.СообщитьОбОшибке("Счет депо получателя не открыт!", ЕстьОшибка);
		КонецЕсли;		
		
		Если НЕ ДостаточноОстаткаПоРегистрамОстаткиЦБ(ИзмеренияСоСтатусомЦБ, Количество, ТекстОшибки) Тогда
			ОбщегоНазначения.СообщитьОбОшибке(ТекстОшибки, ЕстьОшибка);
		КонецЕсли;
		
	ИначеЕсли ВидОперацииД = ВидыОпераций.СнятиеЦБсОбслуживания Тогда
		// Без проверки
	ИначеЕсли ВидОперацииД = ВидыОпераций.ПриемЦБНаОбслуживание Тогда
		// Без проверки
	ИначеЕсли ВидОперацииД = ВидыОпераций.Выкуп Тогда
		Если НЕ ДостаточноОстаткаПоРегистрамОстаткиЦБ(Измерения, Количество, ТекстОшибки) Тогда
			ОбщегоНазначения.СообщитьОбОшибке(ТекстОшибки, ЕстьОшибка);
		КонецЕсли;
		
	Иначе
		ОбщегоНазначения.СообщитьОбОшибке("Данная операция документом ""Операция с ЦБ"" не производится!", ЕстьОшибка);
	КонецЕсли;		
	
	Возврат ЕстьОшибка;
	
КонецФункции


