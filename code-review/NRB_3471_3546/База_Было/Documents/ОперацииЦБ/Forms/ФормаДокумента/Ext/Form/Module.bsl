//////////////////////////////////////////////////////////////////////////////////
// ОБРАБОТЧИКИ СОБЫТИЙ ФОРМЫ

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	Если Объект.Ссылка.Пустая() Тогда 
		Если Объект.Проверка Тогда
			Отказ = Истина;
			Возврат;
		КонецЕсли;
		
		ЗаполнитьШапкуДокументаСервер();
		
		Если Не ЗначениеЗаполнено(Объект.Инициатор) Тогда
			Если Объект.ВидОперацииД = Справочники.ВидыОпераций.Депонирование
				ИЛИ Объект.ВидОперацииД = Справочники.ВидыОпераций.СнятиеСДепонирования Тогда
				Объект.Инициатор = Справочники.Организации.ПустаяСсылка();
			Иначе
				Объект.Инициатор = Справочники.Контрагенты.ПустаяСсылка();
			КонецЕсли;
		КонецЕсли;
		УстановитьНомерДокументаСервер();
	КонецЕсли;
	
	УправлениеДиалогомСервер();
	
	Если Объект.Проведен Тогда
		ТолькоПросмотр = Истина;
	КонецЕсли;
	
	// СтандартныеПодсистемы.ВерсионированиеОбъектов
	ВерсионированиеОбъектов.ПриСозданииНаСервере(ЭтаФорма);
	// Конец СтандартныеПодсистемы.ВерсионированиеОбъектов
	
КонецПроцедуры

&НаСервере
Процедура ПриЧтенииНаСервере(ТекущийОбъект)
	Оболочки.ПриЧтенииНаСервереДокумента(ЭтотОбъект, ТекущийОбъект);
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	ОформитьЭлементКомандыУправленияПризнакомОбмена();
КонецПроцедуры

&НаКлиенте
Процедура ВидОперацииДПриИзменении(Элемент)
	ВидОперацииДПриИзмененииСервер();
КонецПроцедуры

&НаКлиенте
Процедура ПриИзмененииДанныхДепонента(Элемент)
	ПриИзмененииДанныхДепонентаСервер(Элемент.Имя);
КонецПроцедуры

&НаКлиенте
Процедура ПриИзмененииДанныхПолучателя(Элемент)
	ПриИзмененииДанныхПолучателяСервер(Элемент.Имя);
КонецПроцедуры

&НаКлиенте
Процедура ПриИзмененииДанныхМХДепонента(Элемент)
	ПриИзмененииДанныхМХДепонентаСервер(Элемент.Имя);
КонецПроцедуры

&НаКлиенте
Процедура ПриИзмененииДанныхМХПолучателя(Элемент)
	ПриИзмененииДанныхМХПолучателяСервер(Элемент.Имя);
КонецПроцедуры

&НаКлиенте
Процедура ДокументОснованиеПриИзменении(Элемент)
	Если ЗначениеЗаполнено(Объект.ДокументОснование) Тогда
		ДокументОснованиеПриИзмененииСервер();
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура СуммаПриИзменении(Элемент)
	Если Объект.Количество <> 0 Тогда
		Объект.Цена = Объект.Сумма / Объект.Количество;
	Иначе
		ОбщегоНазначения.СообщитьОбОшибке("Указано нулевое количество! Цена не пересчитана!");
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ЦенаКоличествоПриИзменении(Элемент)
	Объект.Сумма = Объект.Цена * Объект.Количество;
КонецПроцедуры

&НаКлиенте
Процедура ЦБПриИзменении(Элемент)
	Котировка = ЦБКотировкаСервер();
	Если Котировка = Неопределено Тогда
		Объект.Цена	= 0;
	Иначе
		Объект.Цена	= Котировка.РыночнаяЦена;
	КонецЕсли;
	Объект.Сумма = Объект.Количество * Объект.Цена;
КонецПроцедуры

&НаКлиенте
Процедура ЦБОбработкаВыбора(Элемент, ВыбранноеЗначение, СтандартнаяОбработка)
	СтандартнаяОбработка	= Ложь;
	ДатаПроверки			= ?(Объект.Ссылка.Пустая(), ТекущаяДата(), Объект.Дата);
	ЦенныеБумагиКлиент.ЦеннаяБумагаПроверкаВыборка(ВыбранноеЗначение, ДатаПроверки, СтандартнаяОбработка);
КонецПроцедуры

&НаКлиенте
Процедура ДокументОснованиеВстречныйПриИзменении(Элемент)
	ДокументОснованиеВстречныйПриИзмененииСервер();
КонецПроцедуры

//////////////////////////////////////////////////////////////////////////////////
// СЛУЖЕБНЫЕ ПРОЦЕДУРЫ И ФУНКЦИИ

&НаСервере
Процедура ВидОперацииДПриИзмененииСервер()
	Если Объект.ВидОперацииД.КлассОпераций <> Перечисления.КлассыОпераций.Инвентарные
		И Объект.ВидОперацииД.КлассОпераций <> Перечисления.КлассыОпераций.Комплексные
		И Объект.ВидОперацииД.КлассОпераций <> Перечисления.КлассыОпераций.Глобальные
		И Объект.ВидОперацииД <> Справочники.ВидыОпераций.ПриемЦБНаОбслуживание
		И Объект.ВидОперацииД <> Справочники.ВидыОпераций.СнятиеЦБсОбслуживания Тогда 
		
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "Данная операция документом 'Операция с ЦБ' не производится!";
		Сообщение.Сообщить();
		
		Объект.ВидОперацииД = Справочники.ВидыОпераций.Депонирование;
	КонецЕсли;
	ЗаполнениеРеквизитовПоВидуОперацииСервер();
	УправлениеДиалогомСервер();
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьШапкуДокументаСервер()
	ТекущийОбъект = РеквизитФормыВЗначение("Объект");
	ОбщегоНазначения.ЗаполнитьШапкуДокумента(ТекущийОбъект, ПараметрыСеанса.ТекущийПользователь, , );
	ЗначениеВРеквизитФормы(ТекущийОбъект, "Объект");
КонецПроцедуры

&НаСервере
Процедура УстановитьНомерДокументаСервер()
	ТекущийОбъект = РеквизитФормыВЗначение("Объект");
	ТекущийОбъект.УстановитьНовыйНомер();
	ЗначениеВРеквизитФормы(ТекущийОбъект, "Объект");
КонецПроцедуры

&НаСервере
Процедура УправлениеДиалогомСервер()
	Если Объект.ВидОперацииД = Справочники.ВидыОпераций.Перевод Тогда
		Элементы.ГруппаПолучатель.Видимость				= Истина;
		
		Элементы.Получатель.Доступность					= Истина;
		Элементы.СчетДепоПолучатель.Доступность			= Истина;
		Элементы.РазделСчетаДепоПолучатель.Доступность	= Истина;
		
		Элементы.МестоХраненияПолучатель.Доступность	= Ложь;
		Элементы.СчетДепоМХПолучатель.Доступность		= Ложь;
		Элементы.РазделСчетаДепоМХПолучатель.Доступность= Ложь;
		
		Элементы.ГруппаДепонент.Видимость				= Истина;
		Элементы.ГруппаСтраницыДокумента.Видимость		= Истина;
		
		Элементы.ГруппаВстречныеРеквизиты.Видимость		= Истина;
		Элементы.РасчетыНаDMA.Видимость					= Ложь;
		
	ИначеЕсли Объект.ВидОперацииД = Справочники.ВидыОпераций.Перемещение
		ИЛИ Объект.ВидОперацииД = Справочники.ВидыОпераций.ПереводМеждуРазделамиСчетаДепо
		ИЛИ Объект.ВидОперацииД = Справочники.ВидыОпераций.ПередачаВЗалог
		ИЛИ Объект.ВидОперацииД = Справочники.ВидыОпераций.ВозвратИзЗалога Тогда
		
		Элементы.ГруппаПолучатель.Видимость				= Истина;
		
		Элементы.Получатель.Доступность					= Ложь;
		Элементы.СчетДепоПолучатель.Доступность			= Истина;
		Элементы.РазделСчетаДепоПолучатель.Доступность	= Истина;
		
		Элементы.МестоХраненияПолучатель.Доступность	= Истина;
		Элементы.СчетДепоМХПолучатель.Доступность		= Истина;
		Элементы.РазделСчетаДепоМХПолучатель.Доступность= Истина;
		
		Элементы.ГруппаДепонент.Видимость				= Истина;
		Элементы.ГруппаСтраницыДокумента.Видимость		= Истина;
		
		Элементы.ГруппаВстречныеРеквизиты.Видимость		= Ложь;
		Элементы.РасчетыНаDMA.Видимость					= Ложь;
		
	ИначеЕсли Объект.ВидОперацииД = Справочники.ВидыОпераций.Депонирование
		ИЛИ Объект.ВидОперацииД = Справочники.ВидыОпераций.СнятиеСДепонирования Тогда
		Элементы.ГруппаПолучатель.Видимость				= Истина;
		
		Элементы.Получатель.Доступность					= Ложь;
		Элементы.СчетДепоПолучатель.Доступность			= Ложь;
		Элементы.РазделСчетаДепоПолучатель.Доступность	= Ложь;
		
		Элементы.МестоХраненияПолучатель.Доступность	= Истина;
		Элементы.СчетДепоМХПолучатель.Доступность		= Ложь;
		Элементы.РазделСчетаДепоМХПолучатель.Доступность= Ложь;
		
		Элементы.ГруппаДепонент.Видимость				= Истина;
		Элементы.ГруппаСтраницыДокумента.Видимость		= Истина;
		
		Элементы.ГруппаВстречныеРеквизиты.Видимость		= Ложь;
		Элементы.РасчетыНаDMA.Видимость					= Истина;
		
	ИначеЕсли Объект.ВидОперацииД = Справочники.ВидыОпераций.ПриемЦБНаОбслуживание
		ИЛИ Объект.ВидОперацииД = Справочники.ВидыОпераций.СнятиеЦБсОбслуживания Тогда
		Элементы.ГруппаПолучатель.Видимость				= Ложь;
		
		Элементы.Получатель.Доступность					= Ложь;
		Элементы.СчетДепоПолучатель.Доступность			= Ложь;
		Элементы.РазделСчетаДепоПолучатель.Доступность	= Ложь;
		
		Элементы.МестоХраненияПолучатель.Доступность	= Ложь;
		Элементы.СчетДепоМХПолучатель.Доступность		= Ложь;
		Элементы.РазделСчетаДепоМХПолучатель.Доступность= Ложь;
		
		Элементы.ГруппаДепонент.Видимость				= Ложь;
		Элементы.ГруппаСтраницыДокумента.Видимость		= Ложь;
		
		Элементы.ГруппаВстречныеРеквизиты.Видимость		= Ложь;
		Элементы.РасчетыНаDMA.Видимость					= Ложь;
		
	Иначе
		Элементы.ГруппаПолучатель.Видимость				= Ложь;
		
		Элементы.Получатель.Доступность					= Ложь;
		Элементы.СчетДепоПолучатель.Доступность			= Ложь;
		Элементы.РазделСчетаДепоПолучатель.Доступность	= Ложь;
		
		Элементы.МестоХраненияПолучатель.Доступность	= Ложь;
		Элементы.СчетДепоМХПолучатель.Доступность		= Ложь;
		Элементы.РазделСчетаДепоМХПолучатель.Доступность= Ложь;
		
		Элементы.ГруппаДепонент.Видимость				= Истина;
		Элементы.ГруппаСтраницыДокумента.Видимость		= Истина;
		
		Элементы.ГруппаВстречныеРеквизиты.Видимость		= Ложь;
		Элементы.РасчетыНаDMA.Видимость					= Ложь;
	КонецЕсли;
	
	Если Объект.ВидОперацииД.КлассОпераций = Перечисления.КлассыОпераций.Инвентарные Тогда
		Элементы.ГруппаИнвентарныеРеквизиты.Видимость = Истина;
	Иначе
		Элементы.ГруппаИнвентарныеРеквизиты.Видимость = Ложь;
		
		Объект.Залогодержатель	= Справочники.Контрагенты.ПустаяСсылка();
		Объект.ДатаСделки		= Дата(1,1,1);
		Объект.Референс			= "";
	КонецЕсли;
	
	Элементы.ДополнительныеДатыИсполнения.Видимость = Ложь;
	Если Объект.ВидОперацииД.ДвижениеПоЦБ Тогда
		Элементы.ДополнительныеДатыИсполнения.Видимость = Истина;
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура ЗаполнениеРеквизитовПоВидуОперацииСервер() Экспорт
	Если Объект.ВидОперацииД = Справочники.ВидыОпераций.Перевод Тогда
		Объект.МестоХраненияПолучатель 		= Объект.МестоХранения;
		Объект.СчетДепоМХПолучатель			= Объект.СчетДепоМХ;
		Объект.РазделСчетаДепоМХПолучатель	= Объект.РазделСчетаДепоМХ;
		
		// Дозаполняем данные для поручений на перевод ЦБ
		Объект.Получатель					= Объект.ДокументОснование.Контрагент;
		Объект.СчетДепоПолучатель			= Объект.ДокументОснование.СчетДепоКонтрагента;
		Объект.РазделСчетаДепоПолучатель	= Объект.ДокументОснование.РазделСчетаДепоКонтрагента;
		
	ИначеЕсли Объект.ВидОперацииД = Справочники.ВидыОпераций.Перемещение
				ИЛИ Объект.ВидОперацииД = Справочники.ВидыОпераций.ПереводМеждуРазделамиСчетаДепо Тогда
		Объект.Получатель					= Объект.Инициатор;
		Объект.СчетДепоПолучатель			= Объект.СчетДепо;
		Объект.РазделСчетаДепоПолучатель	= Объект.РазделСчетаДепо;
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура ДокументОснованиеПриИзмененииСервер()
	ТекущийОбъект	= РеквизитФормыВЗначение("Объект");
	ТекущийОбъект.Заполнить(Объект.ДокументОснование);
	ЗначениеВРеквизитФормы(ТекущийОбъект, "Объект");
КонецПроцедуры

&НаСервере
Функция ЦБКотировкаСервер()
	Котировка = РегистрыСведений.Котировки.СрезПоследних(ТекущаяДата(), Новый Структура("ЦеннаяБумага, Биржа, РежимТоргов", Объект.ЦБ, Справочники.Биржи.MICEX, Справочники.РежимыТоргов.Рыночный));
	Если Котировка.Количество()>0 Тогда
		Возврат Котировка[0];
	Иначе
		Возврат Неопределено;
	КонецЕсли;
КонецФункции

&НаСервере
Процедура УстановитьСвязьПараметровВыбора(ИмяЭлемента, ИмяСвязующегоЭлемента)
	НоваяСвязь	= Новый СвязьПараметраВыбора("Отбор.Владелец", "Объект."+ИмяСвязующегоЭлемента);
	НовыйМассив	= Новый Массив;
	НовыйМассив.Добавить(НоваяСвязь);
	НовыеСвязи	= Новый ФиксированныйМассив(НовыйМассив);
	Элементы[ИмяЭлемента].СвязиПараметровВыбора	= НовыеСвязи;
КонецПроцедуры

&НаСервере
Процедура УдалитьСвязьПараметровВыбора(ИмяЭлемента)
	НовыеСвязи	= Новый ФиксированныйМассив(Новый Массив);
	Элементы[ИмяЭлемента].СвязиПараметровВыбора	= НовыеСвязи;
КонецПроцедуры

&НаСервере
Процедура ПриИзмененииДанныхДепонентаСервер(ИмяЭлемента)
	Если ИмяЭлемента = "Депонент" Тогда
		Если НЕ Объект.Депонент.Пустая() Тогда
			УстановитьСвязьПараметровВыбора("СчетДепо", "Депонент");
		Иначе
			УдалитьСвязьПараметровВыбора("СчетДепо");
		КонецЕсли;
		Если Объект.СчетДепо.Владелец <> Объект.Депонент Тогда
			Объект.СчетДепо = Справочники.СчетаДепо.ПустаяСсылка();
		КонецЕсли;
		Если Объект.РазделСчетаДепо.Владелец <> Объект.СчетДепо Тогда
			Объект.РазделСчетаДепо = Справочники.РазделыСчетаДепо.ПустаяСсылка();
		КонецЕсли;
		
		Если Объект.ВидОперацииД = Справочники.ВидыОпераций.Перемещение
				ИЛИ Объект.ВидОперацииД = Справочники.ВидыОпераций.ПереводМеждуРазделамиСчетаДепо Тогда
			Объект.Получатель = Объект.Депонент;
			ПриИзмененииДанныхПолучателяСервер("Получатель");
		КонецЕсли;
		
	ИначеЕсли ИмяЭлемента = "СчетДепо" Тогда
		Если Не Объект.СчетДепо.Пустая() Тогда
			УстановитьСвязьПараметровВыбора("РазделСчетаДепо", "СчетДепо");
		Иначе	
			УдалитьСвязьПараметровВыбора("РазделСчетаДепо");
		КонецЕсли;
		Если Объект.СчетДепо.Владелец <> Объект.Депонент И НЕ Объект.СчетДепо.Пустая() Тогда
			Объект.Депонент	= Объект.СчетДепо.Владелец;
		КонецЕсли;
		Если Объект.РазделСчетаДепо.Владелец <> Объект.СчетДепо Тогда
			Объект.РазделСчетаДепо	= Справочники.РазделыСчетаДепо.ПустаяСсылка();
		КонецЕсли;
		
		Если Объект.ВидОперацииД = Справочники.ВидыОпераций.Перемещение
				ИЛИ Объект.ВидОперацииД = Справочники.ВидыОпераций.ПереводМеждуРазделамиСчетаДепо Тогда
			Объект.СчетДепоПолучатель = Объект.СчетДепо;
			ПриИзмененииДанныхПолучателяСервер("СчетДепоПолучатель");
		КонецЕсли;
		
	ИначеЕсли ИмяЭлемента = "РазделСчетаДепо" Тогда
		Если Объект.РазделСчетаДепо.Владелец <> Объект.СчетДепо И НЕ Объект.РазделСчетаДепо.Пустая() Тогда
			Объект.СчетДепо	= Объект.РазделСчетаДепо.Владелец;
		КонецЕсли;
		Если Объект.СчетДепо.Владелец <> Объект.Депонент И Не Объект.СчетДепо.Пустая() Тогда
			Объект.Депонент	= Объект.СчетДепо.Владелец;
		КонецЕсли;
		
		Если Объект.ВидОперацииД = Справочники.ВидыОпераций.Перемещение
				ИЛИ Объект.ВидОперацииД = Справочники.ВидыОпераций.ПереводМеждуРазделамиСчетаДепо Тогда
			Объект.РазделСчетаДепоПолучатель = Объект.РазделСчетаДепо;
			ПриИзмененииДанныхПолучателяСервер("РазделСчетаДепоПолучатель");
		КонецЕсли;
	КонецЕсли;
	
	Если Объект.Инициатор.Пустая() Тогда
		Объект.Инициатор = Объект.СчетДепо.Владелец;
	КонецЕсли;		
КонецПроцедуры

&НаСервере
Процедура ПриИзмененииДанныхМХДепонентаСервер(ИмяЭлемента)
	Если ИмяЭлемента = "МестоХранения" Тогда
		Если НЕ Объект.МестоХранения.Пустая() Тогда
			УстановитьСвязьПараметровВыбора("СчетДепоМХ", "МестоХранения");
		Иначе
			УдалитьСвязьПараметровВыбора("СчетДепоМХ");
		КонецЕсли;
		Если Объект.СчетДепоМХ.Владелец <> Объект.МестоХранения Тогда
			Объект.СчетДепоМХ = Справочники.СчетаДепоМХ.ПустаяСсылка();
		КонецЕсли;
		Если Объект.РазделСчетаДепоМХ.Владелец <> Объект.СчетДепоМХ Тогда
			Объект.РазделСчетаДепоМХ = Справочники.РазделыСчетаДепоМХ.ПустаяСсылка();
		КонецЕсли;
		
	ИначеЕсли ИмяЭлемента = "СчетДепоМХ" Тогда
		Если НЕ Объект.СчетДепоМХ.Пустая() Тогда
			УстановитьСвязьПараметровВыбора("РазделСчетаДепоМХ", "СчетДепоМХ");
		Иначе	
			УдалитьСвязьПараметровВыбора("РазделСчетаДепоМХ");
		КонецЕсли;
		Если Объект.СчетДепоМХ.Владелец <> Объект.МестоХранения И НЕ Объект.СчетДепоМХ.Пустая() Тогда
			Объект.МестоХранения = Объект.СчетДепоМХ.Владелец;
		КонецЕсли;
		Если Объект.РазделСчетаДепоМХ.Владелец <> Объект.СчетДепоМХ Тогда
			Объект.РазделСчетаДепоМХ = Справочники.РазделыСчетаДепоМХ.ПустаяСсылка();
		КонецЕсли;
		
	ИначеЕсли ИмяЭлемента = "РазделСчетаДепоМХ" Тогда
		Если Объект.РазделСчетаДепоМХ.Владелец <> Объект.СчетДепоМХ И НЕ Объект.РазделСчетаДепоМХ.Пустая() Тогда
			Объект.СчетДепоМХ = Объект.РазделСчетаДепоМХ.Владелец;
		КонецЕсли;
		Если Объект.СчетДепоМХ.Владелец <> Объект.МестоХранения И НЕ Объект.СчетДепоМХ.Пустая() Тогда
			Объект.МестоХранения = Объект.СчетДепоМХ.Владелец;
		КонецЕсли;
	КонецЕсли;
	
	// Для операций перевода переносим данные из МХ по депоненту в получатели
	Если Объект.ВидОперацииД = Справочники.ВидыОпераций.Перевод Тогда
        Объект.МестоХраненияПолучатель		= Объект.МестоХранения;
		Объект.СчетДепоМХПолучатель			= Объект.СчетДепоМХ;
		Объект.РазделСчетаДепоМХПолучатель	= Объект.РазделСчетаДепоМХ;
	КонецЕсли;
КонецПроцедуры

