&НаКлиенте
Процедура ЗаполнитьДивиденды(Команда)
	
	ЗаполнитьДивидендыНаСервере();
	
	ДивидендПриИзменении(Элементы.СуммаИПД);
	
КонецПроцедуры

&НаКлиенте
Процедура ДивидендПриИзменении(Элемент)
	Перем СуммаДивидендов;
	
	ВсегоБумаг = Объект.ТаблицаДивиденды.Итог("Количество");
	Если ВсегоБумаг > 0 Тогда
		Для Каждого ЭлементСтроки Из Объект.ТаблицаДивиденды Цикл
			ЭлементСтроки.Сумма = Объект.СуммаИПД * ЭлементСтроки.Количество / ВсегоБумаг;
		КонецЦикла;
	КонецЕсли;
	
	СуммаДивидендов = Объект.ТаблицаДивиденды.Итог("Сумма");
	Если СуммаДивидендов <> Объект.СуммаИПД Тогда
		Объект.ТаблицаДивиденды[Объект.ТаблицаДивиденды.Количество()-1].Сумма = 
			Объект.ТаблицаДивиденды[Объект.ТаблицаДивиденды.Количество()-1].Сумма
			+ Объект.СуммаИПД - СуммаДивидендов;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ОчиститьДивиденды(Команда)
	Объект.ТаблицаДивиденды.Очистить();
	Объект.СуммаИПД	= 0;
КонецПроцедуры

&НаКлиенте
Процедура ЦеннаяБумагаОбработкаВыбора(Элемент, ВыбранноеЗначение, СтандартнаяОбработка)
	СтандартнаяОбработка	= Ложь;
	
	ДатаПроверки	= ?(Объект.Ссылка.Пустая(), ТекущаяДата(), Объект.Дата);
	
	ЦенныеБумагиКлиент.ЦеннаяБумагаПроверкаВыборка(ВыбранноеЗначение, ДатаПроверки, СтандартнаяОбработка);
КонецПроцедуры

&НаКлиенте
Процедура ТаблицаДивидендыПриИзменении(Элемент)
	ДивидендПриИзменении(Элементы.СуммаИПД);
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьДивидендыНаСервере()
	
	Объект.ТаблицаДивиденды.Очистить();
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	СчетДепо.Владелец			КАК Депонент,
	|	СчетДепо					КАК СчетДепо,
	|	СУММА(КоличествоОстаток)	КАК Количество
	|ИЗ
	|	РегистрНакопления.ОстаткиЦБ.Остатки(&ДатаОстатков, ЦБ = &ЦеннаяБумага)
	|СГРУППИРОВАТЬ ПО
	|	СчетДепо,
	|	СчетДепо.Владелец
	|ИМЕЮЩИЕ
	|	СУММА(КоличествоОстаток) > 0";
	Граница = Новый Граница(КонецДня(Объект.ДатаФиксации), ВидГраницы.Включая);
	Запрос.УстановитьПараметр("ДатаОстатков", Граница);
	Запрос.УстановитьПараметр("ЦеннаяБумага", Объект.ЦеннаяБумага);
	
	Результат = Запрос.Выполнить();
	Выборка = Результат.Выбрать();
	Пока Выборка.Следующий() Цикл
		СтрокаТабличнойЧасти = Объект.ТаблицаДивиденды.Добавить();
		СтрокаТабличнойЧасти.Депонент 		= Выборка.Депонент;
		СтрокаТабличнойЧасти.СчетДЕПО 		= Выборка.СчетДепо;
		СтрокаТабличнойЧасти.ЦеннаяБумага	= Объект.ЦеннаяБумага;
		СтрокаТабличнойЧасти.Количество 	= Выборка.Количество;
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ПриЧтенииНаСервере(ТекущийОбъект)
	Оболочки.ПриЧтенииНаСервереДокумента(ЭтотОбъект, ТекущийОбъект);
КонецПроцедуры
