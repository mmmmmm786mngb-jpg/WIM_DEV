Функция ТаблицаОстаткиЦБДляСписания(Дата, ИмяРегистраНакопления)
	Запрос = Новый Запрос;
	
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ОстаткиЦБ.СчетДепо КАК СчетДепо,
	|	ОстаткиЦБ.РазделСчетаДепо КАК РазделСчетаДепо,
	|	ОстаткиЦБ.ЦБ КАК ЦБ,
	|	ОстаткиЦБ.СчетДепоМХ КАК СчетДепоМХ,
	|	ОстаткиЦБ.РазделСчетаДепоМХ КАК РазделСчетаДепоМХ,
	|	ОстаткиЦБ.СтатусЦБ КАК СтатусЦБ,
	|	ОстаткиЦБ.КоличествоОстаток КАК Количество
	|ПОМЕСТИТЬ ВТ_ОстаткиЦБ
	|ИЗ
	|	РегистрНакопления.ОстаткиЦБ.Остатки(&выбДата,
	|		ЦБ = &выбЦБ
	|		И (&выбСчетДепо = ЗНАЧЕНИЕ(Справочник.СчетаДепо.ПустаяСсылка) ИЛИ СчетДепо = &выбСчетДепо)) КАК ОстаткиЦБ
	|;
	|
	|////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЦенныеБумаги.Ссылка.СчетДепо КАК СчетДепо,
	|	ЦенныеБумаги.РазделСчетаДепо КАК РазделСчетаДепо,
	|	ЦенныеБумаги.ЦеннаяБумага КАК ЦБ,
	|	ЦенныеБумаги.СчетДепоМХ КАК СчетДепоМХ,
	|	ЦенныеБумаги.РазделСчетаДепоМХ КАК РазделСчетаДепоМХ,
	|	ЕСТЬNULL(ВТ_ОстаткиЦБ.СтатусЦБ, &СтатусЦБПоУмолчанию) КАК СтатусЦБ,
	|	СУММА(ЦенныеБумаги.Количество) КАК КоличествоОстаток,
	|	СУММА(ЕСТЬNULL(ВТ_ОстаткиЦБ.Количество, 0)) КАК КоличествоНаОстаткахЦБ
	|
	|ИЗ
	|	Документ.ГлобальнаяОперация.ЦенныеБумаги КАК ЦенныеБумаги
	|	ЛЕВОЕ СОЕДИНЕНИЕ
	|		ВТ_ОстаткиЦБ КАК ВТ_ОстаткиЦБ
	|	ПО
	|		ЦенныеБумаги.Ссылка.СчетДепо = ВТ_ОстаткиЦБ.СчетДепо 
	|		И ЦенныеБумаги.РазделСчетаДепо = ВТ_ОстаткиЦБ.РазделСчетаДепо 
	|		И ЦенныеБумаги.ЦеннаяБумага = ВТ_ОстаткиЦБ.ЦБ 
	|		И ЦенныеБумаги.СчетДепоМХ = ВТ_ОстаткиЦБ.СчетДепоМХ 
	|		И ЦенныеБумаги.РазделСчетаДепоМХ = ВТ_ОстаткиЦБ.РазделСчетаДепоМХ 
	|ГДЕ
	|	ЦенныеБумаги.Ссылка = &Ссылка
	|СГРУППИРОВАТЬ ПО
	|	ЦенныеБумаги.Ссылка.СчетДепо,
	|	ЦенныеБумаги.РазделСчетаДепо,
	|	ЦенныеБумаги.ЦеннаяБумага,
	|	ЦенныеБумаги.СчетДепоМХ,
	|	ЦенныеБумаги.РазделСчетаДепоМХ,
	|	ЕСТЬNULL(ВТ_ОстаткиЦБ.СтатусЦБ, &СтатусЦБПоУмолчанию)
	|";
	
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "РегистрНакопления.ОстаткиЦБ", "РегистрНакопления."+ИмяРегистраНакопления);
	
	Запрос.УстановитьПараметр("выбДата", Дата);
	Запрос.УстановитьПараметр("выбЦБ", ЦеннаяБумага);
	Запрос.УстановитьПараметр("выбСчетДепо", СчетДепо);
	Запрос.УстановитьПараметр("СтатусЦБПоУмолчанию", Перечисления.СтатусыЦБ.Свободна);
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	
	Возврат Запрос.Выполнить().Выгрузить();
КонецФункции

Функция ТаблицаЦБДляНачисления()
	Запрос = Новый Запрос;
	
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ЦенныеБумаги.Ссылка.СчетДепо КАК СчетДепо,
	|	ЦенныеБумаги.РазделСчетаДепо КАК РазделСчетаДепо,
	|	ЦенныеБумаги.ЦеннаяБумага КАК ЦБ,
	|	ЦенныеБумаги.СчетДепоМХ КАК СчетДепоМХ,
	|	ЦенныеБумаги.РазделСчетаДепоМХ КАК РазделСчетаДепоМХ,
	|	&СтатусЦБПоУмолчанию КАК СтатусЦБ,
	|	СУММА(ЦенныеБумаги.Количество) КАК КоличествоОстаток
	|ИЗ
	|	Документ.ГлобальнаяОперация.ЦенныеБумаги КАК ЦенныеБумаги
	|ГДЕ
	|	ЦенныеБумаги.Ссылка = &Ссылка
	|СГРУППИРОВАТЬ ПО
	|	ЦенныеБумаги.Ссылка.СчетДепо,
	|	ЦенныеБумаги.РазделСчетаДепо,
	|	ЦенныеБумаги.ЦеннаяБумага,
	|	ЦенныеБумаги.СчетДепоМХ,
	|	ЦенныеБумаги.РазделСчетаДепоМХ,
	|	&СтатусЦБПоУмолчанию
	|";
	
	Запрос.УстановитьПараметр("СтатусЦБПоУмолчанию", Перечисления.СтатусыЦБ.Свободна);
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	
	Возврат Запрос.Выполнить().Выгрузить();
КонецФункции

// Возвращает Истина, если остаток в ТаблицаОстатковЦБ достаточен для списания.
// Начиная с даты доп. движений также проверяются остатки по регистрам ОстаткиЦБДепозитарийМХ
// и ОстаткиЦБМестоРасчетов на соответствующие даты.
// Если хотя бы по одному регистру остатка не достаточно, возвращает Ложь и выводит сообщение об ошибке.
Функция ДостаточноОстатковЦБДляСписания(ТаблицаОстатковЦБ)
	ШаблонОшибки = "Количество списания ценных бумаг {Кол} превышает остаток {Ост} на счете клиента {Комментарий}
		|(регистр ""{ИмяРег}"" на {Дата})
		|ЦБ: {ЦБ}  ISIN: {ISIN}  Статус ЦБ: {СтатусЦБ}
		|Счет ДЕПО: {СчетДепо}
		|Раздел счета ДЕПО: {РазделСчетаДепо}
		|Счет ДЕПО места хранения: {СчетДепоМХ}
		|Раздел счета ДЕПО места хранения: {РазделСчетаДепоМХ}";
	
	// Проверим остатки 
	ОстатковДостаточно = ДостаточноОстатковПоТаблице(ТаблицаОстатковЦБ, ШаблонОшибки, "на дату глобальной операции",
		Метаданные.РегистрыНакопления.ОстаткиЦБ.Синоним, Дата);
	
	// Если нужно, проверим остатки по другим регистрам: ОстаткиЦБДепозитарийМХ и ОстаткиЦБМестоРасчетов 
	Если ОстатковДостаточно
		И ТипЗнч(ВидГлобальнойОперации) = Тип("СправочникСсылка.ВидыОпераций") И ВидГлобальнойОперации.ДвижениеПоЦБ Тогда
		// Проверим остатки по регистру накопления ОстаткиЦБДепозитарийМХ
		ДатаВремяМХ = ОбъединениеДатыВремени(ДатаИсполненияВДепозитарииМХ, Дата);
		ТаблицаОстатковМХ = ТаблицаОстаткиЦБДляСписания(ДатаВремяМХ, "ОстаткиЦБДепозитарийМХ");
		ОстатковДостаточно = ДостаточноОстатковПоТаблице(ТаблицаОстатковМХ, ШаблонОшибки, "на дату исполнения в депозитарии МХ",
			Метаданные.РегистрыНакопления.ОстаткиЦБДепозитарийМХ.Синоним, ДатаВремяМХ);
		
		Если ОстатковДостаточно Тогда
			// Проверим остатки по регистру накопления ОстаткиЦБМестоРасчетов
			ДатаВремяМР = ОбъединениеДатыВремени(ДатаИсполненияВМестеРасчетов, Дата);
			ТаблицаОстатковМР = ТаблицаОстаткиЦБДляСписания(ДатаВремяМР, "ОстаткиЦБМестоРасчетов");
			ОстатковДостаточно = ДостаточноОстатковПоТаблице(ТаблицаОстатковМР, ШаблонОшибки, "на дату исполнения в месте расчетов",
				Метаданные.РегистрыНакопления.ОстаткиЦБМестоРасчетов.Синоним, ДатаВремяМР);
		КонецЕсли;
	КонецЕсли;
	
	Если ОстатковДостаточно Тогда
		Возврат Истина;
	Иначе
		ОбщегоНазначения.СообщитьОбОшибке(ШаблонОшибки);
		Возврат Ложь;
	КонецЕсли;
КонецФункции

// Возвращает Истина, если остаток в ТаблицаОстатков достаточен для списания.
// Иначе - Ложь и заполняется шаблон ошибки
Функция ДостаточноОстатковПоТаблице(ТаблицаОстатков, ШаблонОшибки, Комментарий, ИмяРег, Дата)
	Для каждого Строка из ТаблицаОстатков Цикл
		Если Строка.КоличествоОстаток > Строка.КоличествоНаОстаткахЦБ Тогда
			ШаблонОшибки = СтрЗаменить(ШаблонОшибки, "{Кол}",				Строка.КоличествоОстаток);
			ШаблонОшибки = СтрЗаменить(ШаблонОшибки, "{Ост}",				Строка.КоличествоНаОстаткахЦБ);
			ШаблонОшибки = СтрЗаменить(ШаблонОшибки, "{Комментарий}",		Комментарий);
			ШаблонОшибки = СтрЗаменить(ШаблонОшибки, "{ИмяРег}",			ИмяРег);
			ШаблонОшибки = СтрЗаменить(ШаблонОшибки, "{Дата}",				Дата);
			ШаблонОшибки = СтрЗаменить(ШаблонОшибки, "{ЦБ}",				Строка.ЦБ);
			ШаблонОшибки = СтрЗаменить(ШаблонОшибки, "{ISIN}",				Строка.ЦБ.ISIN);
			ШаблонОшибки = СтрЗаменить(ШаблонОшибки, "{СтатусЦБ}",			Строка.СтатусЦБ);
			ШаблонОшибки = СтрЗаменить(ШаблонОшибки, "{СчетДепо}",			Строка.СчетДепо);
			ШаблонОшибки = СтрЗаменить(ШаблонОшибки, "{РазделСчетаДепо}",	Строка.РазделСчетаДепо);
			ШаблонОшибки = СтрЗаменить(ШаблонОшибки, "{СчетДепоМХ}",		Строка.СчетДепоМХ);
			ШаблонОшибки = СтрЗаменить(ШаблонОшибки, "{РазделСчетаДепоМХ}",	Строка.РазделСчетаДепоМХ);
			Возврат Ложь;
		КонецЕсли;
	КонецЦикла;
	Возврат Истина;
КонецФункции

Процедура ЗагрузитьДвиженияРегистровГруппыОстаткиЦБИзТаблицы(ТабДвижений, флДелатьДвиженияПоРегиструУслуг, ВидДвижения)
	Для Каждого СтрокаЦБ Из ТабДвижений Цикл
		ДобавитьДвиженияВОстаткиЦБ(ВидДвижения,
			СтрокаЦБ.СчетДепо, СтрокаЦБ.РазделСчетаДепо, СтрокаЦБ.ЦБ,
			СтрокаЦБ.СчетДепоМХ, СтрокаЦБ.РазделСчетаДепоМХ, СтрокаЦБ.СтатусЦБ, СтрокаЦБ.КоличествоОстаток);
		
		Если флДелатьДвиженияПоРегиструУслуг Тогда
			ДепозитарийКлиент.СоздатьДвиженияДокумента(Дата, Движения, СтрокаЦБ.СчетДепо.Владелец ,УслугаОперации, Тариф);
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

// Добавляет движения в регистр накопления ОстаткиЦБ, а для видов операции с установленным флажком ДвижениеПоЦБ
// начиная с даты доп. движений также и в регистры накопления ОстаткиЦБДепозитарийМХ и ОстаткиЦБМестоРасчетов.
// При этом в движениях по этим регистрам в качестве периода используются ДатаИсполненияВДепозитарииМХ
// и ДатаИсполненияВМестеРасчетов соответственно (из этих реквизитов берется дата, из "Дата" берется время).
Процедура ДобавитьДвиженияВОстаткиЦБ(ВидДвижения, СчетДепо, РазделСчетаДепо, ЦБ, СчетДепоМХ, РазделСчетаДепоМХ,
	СтатусЦБ, Количество)
	
	Движение = Движения.ОстаткиЦБ.Добавить(); 
	Движение.ВидДвижения		= ВидДвижения;
	Движение.Период				= Дата;		// По основному регистру движение делается на дату документа
	Движение.СчетДепо			= СчетДепо;
	Движение.РазделСчетаДепо	= РазделСчетаДепо;
	Движение.ЦБ					= ЦБ;
	Движение.СчетДепоМХ			= СчетДепоМХ;
	Движение.РазделСчетаДепоМХ	= РазделСчетаДепоМХ;
	Движение.СтатусЦБ			= СтатусЦБ;
	Движение.Количество			= Количество;
	
	Если ТипЗнч(ВидГлобальнойОперации) = Тип("СправочникСсылка.ВидыОпераций") И ВидГлобальнойОперации.ДвижениеПоЦБ Тогда
		Движение = Движения.ОстаткиЦБДепозитарийМХ.Добавить(); 
		Движение.ВидДвижения		= ВидДвижения;
		Движение.Период				= ОбъединениеДатыВремени(ДатаИсполненияВДепозитарииМХ, Дата);	// Дата - специальная дата, время - из стандартной даты
		Движение.СчетДепо			= СчетДепо;
		Движение.РазделСчетаДепо	= РазделСчетаДепо;
		Движение.ЦБ					= ЦБ;
		Движение.СчетДепоМХ			= СчетДепоМХ;
		Движение.РазделСчетаДепоМХ	= РазделСчетаДепоМХ;
		Движение.СтатусЦБ			= СтатусЦБ;
		Движение.Количество			= Количество;
		
		Движение = Движения.ОстаткиЦБМестоРасчетов.Добавить(); 
		Движение.ВидДвижения		= ВидДвижения;
		Движение.Период				= ОбъединениеДатыВремени(ДатаИсполненияВМестеРасчетов, Дата);	// Дата - специальная дата, время - из стандартной даты
		Движение.СчетДепо			= СчетДепо;
		Движение.РазделСчетаДепо	= РазделСчетаДепо;
		Движение.ЦБ					= ЦБ;
		Движение.СчетДепоМХ			= СчетДепоМХ;
		Движение.РазделСчетаДепоМХ	= РазделСчетаДепоМХ;
		Движение.СтатусЦБ			= СтатусЦБ;
		Движение.Количество			= Количество;
	КонецЕсли;
КонецПроцедуры

//////////////////////////////////////////////////////////////////////
// ОБЩИЕ ПРОЦЕДУРЫ И ФУНКЦИИ ДЛЯ КОНВЕРТАЦИИ						//
//////////////////////////////////////////////////////////////////////

Процедура ВыполнитьДвиженияКонвертации(Тариф, Услуги, Отказ)
	// Списание ЦБ
	Для Каждого СтрокаСписания Из Списание Цикл
		ДобавитьДвиженияВОстаткиЦБ(ВидДвиженияНакопления.Расход,
			СчетДепо, СтрокаСписания.РазделСчетаДепо, СтрокаСписания.ЦеннаяБумага,
			СтрокаСписания.СчетДепоМХ, СтрокаСписания.РазделСчетаДепоМХ, СтрокаСписания.СтатусЦБ,
			СтрокаСписания.Количество);
	КонецЦикла;
	
	// Зачисление ЦБ
	Для Каждого СтрокаЗачисления Из Зачисление Цикл

		ДобавитьДвиженияВОстаткиЦБ(ВидДвиженияНакопления.Приход,
			СчетДепо, СтрокаЗачисления.РазделСчетаДепо, СтрокаЗачисления.ЦеннаяБумага,
			СтрокаЗачисления.СчетДепоМХ, СтрокаЗачисления.РазделСчетаДепоМХ, СтрокаЗачисления.СтатусЦБ,
			СтрокаЗачисления.Количество);

	КонецЦикла;
КонецПроцедуры

// Возвращает значение, содержащее дату и время из соответствующих источников
Функция ОбъединениеДатыВремени(ИсточникДаты, ИсточникВремени)
	Возврат Дата(Год(ИсточникДаты), Месяц(ИсточникДаты), День(ИсточникДаты),
		Час(ИсточникВремени), Минута(ИсточникВремени), Секунда(ИсточникВремени));
КонецФункции