Функция ПолучитьРезультатЗапросаПоДивидендам(Ссылка, ВидДвижения)
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	Ссылка										КАК Ссылка,
	|	Ссылка.Дата									КАК Период,
	|	Ссылка.ЦеннаяБумага 						КАК ЦеннаяБумага,
	|	Ссылка.СчетДепо.Владелец					КАК Депонент,
	|	Количество									КАК Количество,
	|	Сумма										КАК Сумма,
	|	Ссылка.ЦеннаяБумага.ВалютаНоминала			КАК ВалютаНоминала,
	|	Ссылка.БанковскийСчет						КАК БанковскийСчет,
	|	&ВидДвижения								КАК ВидДвижения,
	|	Ссылка.БанковскийСчет.ВалютаДенежныхСредств КАК Валюта
	|ИЗ
	|	Документ.ГлобальнаяОперация.ЦенныеБумаги
	|ГДЕ
	|	Ссылка = &Ссылка");
	
	Запрос.УстановитьПараметр("Ссылка"		, Ссылка);
	Запрос.УстановитьПараметр("ВидДвижения"	, ВидДвижения);
	
	Возврат Запрос.Выполнить();
КонецФункции

