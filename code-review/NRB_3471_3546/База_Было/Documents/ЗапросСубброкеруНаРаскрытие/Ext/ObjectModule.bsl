	Номер = НумераторыОбъектов.ПолучитьНомерДокумента(ЭтотОбъект, "");
	
КонецПроцедуры

Процедура ПриКопировании(ОбъектКопирования)
	
	ПовторныйЗапрос = Истина;
	Статус = Перечисления.СтатусыДокументаЗапросСубброкеруНаРаскрытие.ОтправленПовторно;
	
КонецПроцедуры

// Выполняет формирование и отправку файлов раскрытия(Excel + PDF)
Процедура Отправить() Экспорт 
	
	РеквизитыКорпоративногоДействия = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(КД,"ДатаФиксации");
	ТекстСообщенияОЗаблокированномДокументе  = "Не удалось изменить документ %1, возможно он открыт. Закройте документ и повторите попытку.";
	
	Если Не ЗначениеЗаполнено(ЗаголовокСообщения)
		ИЛИ Не ЗначениеЗаполнено(ТелоСообщения) Тогда 
		Сообщение = Новый СообщениеПользователю();
		Сообщение.Текст = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку("Нет текста уведомления в запросе %1 ",Ссылка);
		Сообщение.Сообщить();
		Возврат;
	КонецЕсли;
	НачатьТранзакцию();
	ИспользоватьРегистрациюЗапросовСубброкера = WTRCСообщенияQI.ИспользоватьРегистрациюЗапросовСубброкераДляДокумента(КД);
	МВТ = Новый МенеджерВременныхТаблиц;
	Документы.ЗапросСубброкеруНаРаскрытие.ДобавитьИсточникДляРаскрытияИзЗапросаНаРСВ(МВТ, Ссылка);
	Если ИспользоватьРегистрациюЗапросовСубброкера Тогда 
		Данные = WTRCСообщенияQI.ДанныеДляЗаполненияЗапросовНаРаскрытиеПоСубклиентам(МВТ, РеквизитыКорпоративногоДействия.ДатаФиксации);
	Иначе 
		Данные = WTRCСообщенияQI.ДанныеДляЗаполненияЗапросовНаРаскрытиеПоСубклиентам_БезДокументовЗапросов(МВТ, РеквизитыКорпоративногоДействия.ДатаФиксации);
	КонецЕсли;
	Если КодТипаКорпоративногоДействия = "WTRC" Тогда
		ЭтоАмериканскаяЦБ = Ложь;
		Если Не ЗначениеЗаполнено(КД.ЦеннаяБумага2) Тогда 
			ЭтоАмериканскаяЦБ = Справочники.ЦенныеБумаги.ЦБПодпадаетПодНалоговоеРегулированиеСША(КД.ЦеннаяБумага1)
		ИначеЕсли Справочники.ЦенныеБумаги.ЦБПодпадаетПодНалоговоеРегулированиеСША(КД.ЦеннаяБумага1) = Истина 
			И Справочники.ЦенныеБумаги.ЦБПодпадаетПодНалоговоеРегулированиеСША(КД.ЦеннаяБумага2) = Истина Тогда 
			ЭтоАмериканскаяЦБ = Истина;
		Иначе
			ВызватьИсключение "Режим налогового регулирования США для Ценной бумаги 1 и Ценной бумаги 2, отличаются!";
		КонецЕсли;
		Если ЭтоАмериканскаяЦБ Тогда 
			ФайлРасшифровки = WTRCСообщенияQI.ФайлРасшифровкиЗапросаНаРаскрытиеПоСубклиентамЦБСША(Данные,ИспользоватьРегистрациюЗапросовСубброкера);
		Иначе 
			ФайлРасшифровки = WTRCСообщенияQI.ФайлРасшифровкиЗапросаСубброкераНаРаскрытие(Данные,ИспользоватьРегистрациюЗапросовСубброкера);
		КонецЕсли;
	Иначе
		ФайлРасшифровки = WTRCСообщенияQI.ФайлРасшифровкиЗапросаСубброкераНаРаскрытие(Данные, ИспользоватьРегистрациюЗапросовСубброкера);
	КонецЕсли;
	
	Документы.РаскрытиеСпискаВладельцев.ПрисоединитьФайлКЗапросуНаРСВ(Ссылка, ФайлРасшифровки, "Раскрытие списка владельцев.xlsx", ".xlsx");
	ФайлЗапроса = WTRCСообщенияQI.ФайлЗапросаНаРаскрытиеПоСубклиентамПриложение2_5(Данные, Ссылка);
	Документы.РаскрытиеСпискаВладельцев.ПрисоединитьФайлКЗапросуНаРСВ(Ссылка, ФайлЗапроса, "Приложение 02.5. Запрос на раскрытие списка владельцев ценных бумаг.pdf", ".pdf");
	Успешно = Документы.РаскрытиеСпискаВладельцев.РезультатОтправкиЗапросаПоЭлПочте(Данные[0], ФайлЗапроса, ФайлРасшифровки);
	
	Если Не Успешно Тогда
		Если ТранзакцияАктивна() Тогда 
			ОтменитьТранзакцию();
		КонецЕсли;
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не удалось отправить запрос субброкера.");
		ЗаписьЖурналаРегистрации("Отправка запроса субброкеру на раскрытие",УровеньЖурналаРегистрации.Предупреждение,Метаданные.Документы.ЗапросСубброкеруНаРаскрытие,Ссылка,ОписаниеОшибки());
		Возврат;
	КонецЕсли;

	ДатаВремяОтправкиЗапроса = ТекущаяДатаСеанса();
	Если Статус = Перечисления.СтатусыДокументаЗапросСубброкеруНаРаскрытие.Отправлен 
		ИЛИ Статус = Перечисления.СтатусыДокументаЗапросСубброкеруНаРаскрытие.ОтправленПовторно 
		ИЛИ Статус = Перечисления.СтатусыДокументаЗапросСубброкеруНаРаскрытие.ПолученОтвет Тогда
		Статус = Перечисления.СтатусыДокументаЗапросСубброкеруНаРаскрытие.ОтправленПовторно;
	Иначе
		Статус = Перечисления.СтатусыДокументаЗапросСубброкеруНаРаскрытие.Отправлен;
	КонецЕсли;
	Записать();
	ЗафиксироватьТранзакцию();
	
	Если КодТипаКорпоративногоДействия = "WTRC" Тогда
		Документы.РаскрытиеСпискаВладельцев.ДополнитьСписокВладельцевЗапросамиСубброкера(КД);
	ИначеЕсли ЗначениеЗаполнено(РСВ) Тогда 
		РСВОбъект = РСВ.ПолучитьОбъект();
		Попытка
			РСВОбъект.Заблокировать();
		Исключение
			ТекстОшибки = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(ТекстСообщенияОЗаблокированномДокументе, РСВОбъект.Ссылка);
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстОшибки);
			Возврат;
		КонецПопытки;
		РСВОбъект.ЗаполнитьСписокВладельцев();
		РСВОбъект.Записать();
		РСВОбъект.Разблокировать();
	КонецЕсли;
	       				
КонецПроцедуры

Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
	Если ЗначениеЗаполнено(ВидКД) Тогда 
		КодТипаКорпоративногоДействия = ВидКД.Код;
	Иначе 
		КодТипаКорпоративногоДействия = "";
	КонецЕсли;
КонецПроцедуры

