
// Создает временную таблицу втИсточникДляРаскрытия и заполняет ее по данным документа запроса субброкера
//
// Параметры:
//  МВТ			 - МенеджерВременныхТаблиц	- менеджер в котором будет создана временная таблица втИсточникДляРаскрытия
//  ЗапросНаРСВ	 - ДокументСсылка.ЗапросСубброкеруНаРаскрытие	- запрос по которому создается ВТ
//
Процедура ДобавитьИсточникДляРаскрытияИзЗапросаНаРСВ(МВТ, ЗапросНаРСВ) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МВТ;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ЗапросСубброкеруНаРаскрытие.Клиент КАК Субброкер,
	|	ЗапросСубброкеруНаРаскрытиеДанныеСубброкера.РазделСчетаДепо КАК РазделСчетаДепо,
	|	ЗапросСубброкеруНаРаскрытие.СчетДЕПО КАК СчетДепо,
	|	ВЫБОР
	|		КОГДА ЗапросСубброкеруНаРаскрытие.ВидКД.Код <> &WTRC
	|				И ЗапросСубброкеруНаРаскрытие.РеференсКДСвязанный <> """"
	|			ТОГДА ЗапросСубброкеруНаРаскрытие.РеференсКДСвязанный
	|		ИНАЧЕ ЗапросСубброкеруНаРаскрытие.РеференсКД
	|	КОНЕЦ КАК КДРеференс,
	|	ВЫБОР
	|		КОГДА ЗапросСубброкеруНаРаскрытие.ВидКД.Код <> &WTRC
	|				И ЗапросСубброкеруНаРаскрытие.РеференсКДСвязанный <> """"
	|			ТОГДА ЗапросСубброкеруНаРаскрытие.ВидКДСвязанный.Наименование
	|		ИНАЧЕ ЗапросСубброкеруНаРаскрытие.ВидКД.Наименование
	|	КОНЕЦ КАК ТипКД,
	|	ВЫБОР
	|		КОГДА ЗапросСубброкеруНаРаскрытие.ВидКД.Код <> &WTRC
	|				И ЗапросСубброкеруНаРаскрытие.РеференсКДСвязанный <> """"
	|			ТОГДА ЗапросСубброкеруНаРаскрытие.ВидКДСвязанный.Код
	|		ИНАЧЕ ЗапросСубброкеруНаРаскрытие.ВидКД.Код
	|	КОНЕЦ КАК КодТипаКД,
	|	ВЫБОР
	|		КОГДА ВЫБОР
	|				КОГДА ЗапросСубброкеруНаРаскрытие.ВидКД.Код <> &WTRC
	|						И ЗапросСубброкеруНаРаскрытие.РеференсКДСвязанный <> """"
	|					ТОГДА ЗапросСубброкеруНаРаскрытие.ВидКДСвязанный.ТипКорпоративныхДействий
	|				ИНАЧЕ ЗапросСубброкеруНаРаскрытие.ВидКД.ТипКорпоративныхДействий
	|			КОНЕЦ = &Доход
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК ВидКДВыплатаДоходов,
	|	ВЫБОР
	|		КОГДА ЗапросСубброкеруНаРаскрытие.ВидКД.Код <> &WTRC
	|				И ЗапросСубброкеруНаРаскрытие.РеференсКДСвязанный <> """"
	|			ТОГДА ЗапросСубброкеруНаРаскрытие.ВидКДСвязанный.КодДохода
	|		ИНАЧЕ ЗапросСубброкеруНаРаскрытие.ВидКД.КодДохода
	|	КОНЕЦ КАК КодДоходовНДФЛ,
	|	ИСТИНА КАК ЗаполнятьЗаявленнуюНалоговуюСтавку,
	|	ЕСТЬNULL(КорпоративноеДействие_Новый.ДатаФиксации, РаскрытиеСпискаВладельцев.ДатаФиксации) КАК ДатаФиксации,
	|	ЕСТЬNULL(ЦеннаяБумагаЗапроса.Ссылка, ЗНАЧЕНИЕ(Справочник.ЦенныеБумаги.ПустаяСсылка)) КАК ЦеннаяБумага,
	|	ЗапросСубброкеруНаРаскрытиеДанныеСубброкера.Выгодоприобретатель КАК Субклиент,
	|	""01"" КАК ТипСчета,
	|	ЗапросСубброкеруНаРаскрытиеДанныеСубброкера.Количество КАК Количество,
	|	ЗапросСубброкеруНаРаскрытие.РСВ.Дата КАК ДатаДокументаРаскрытия,
	|	ЗапросСубброкеруНаРаскрытие.РСВ.Организация КАК Организация,
	|	КодыЗагрузкиОрганизации.Код КАК КодЗагрузкиНДЦОрганизации,
	|	ЕСТЬNULL(РаскрытиеСпискаВладельцев.Организация.Наименование, КорпоративноеДействие_Новый.Организация.Наименование) КАК НаименованиеЮЛОрганизации,
	|	ЕСТЬNULL(ЦеннаяБумагаЗапроса.НаименованиеВыпуска, """") КАК НаименованиеВыпуска,
	|	ЕСТЬNULL(РаскрытиеСпискаВладельцев.ДатаОкончанияПриемаИнструкцийВТБКБ, КорпоративноеДействие_Новый.ДатаОкончанияПриемаИнструкцийВТБКБ) КАК ДатаОкончанияПриемаИнструкцийВТБКБ,
	|	ИСТИНА КАК ВыводитьСтрокиТаблицы,
	|	ЗапросСубброкеруНаРаскрытие.Дата КАК ДатаДокументаЗапроса
	|ПОМЕСТИТЬ втИсточникДляРаскрытия
	|ИЗ
	|	Документ.ЗапросСубброкеруНаРаскрытие.ДанныеСубброкера КАК ЗапросСубброкеруНаРаскрытиеДанныеСубброкера
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЗапросСубброкеруНаРаскрытие КАК ЗапросСубброкеруНаРаскрытие
	|		ПО ЗапросСубброкеруНаРаскрытиеДанныеСубброкера.Ссылка = ЗапросСубброкеруНаРаскрытие.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.КодыЗагрузки КАК КодыЗагрузкиОрганизации
	|		ПО (КодыЗагрузкиОрганизации.Владелец = ЕСТЬNULL(ЗапросСубброкеруНаРаскрытие.РСВ.Организация.ЮридическоеЛицо, ЗапросСубброкеруНаРаскрытие.КД.Организация.ЮридическоеЛицо))
	|			И ((ВЫРАЗИТЬ(КодыЗагрузкиОрганизации.Биржа КАК Справочник.КлассификаторыЗагрузки)) = &НДЦ)
	|			И (КодыЗагрузкиОрганизации.ДатаОкончанияДействия = ДАТАВРЕМЯ(1, 1, 1)
	|				ИЛИ КодыЗагрузкиОрганизации.ДатаОкончанияДействия > &ДатаСреза)
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.РаскрытиеСпискаВладельцев КАК РаскрытиеСпискаВладельцев
	|		ПО (РаскрытиеСпискаВладельцев.Ссылка = ЗапросСубброкеруНаРаскрытие.РСВ)
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.КорпоративноеДействие_Новый КАК КорпоративноеДействие_Новый
	|		ПО (КорпоративноеДействие_Новый.Ссылка = ЗапросСубброкеруНаРаскрытие.КД)
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ЦенныеБумаги КАК ЦеннаяБумагаЗапроса
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.КодыЗагрузки КАК КодыЗагрузки
	|			ПО (КодыЗагрузки.Владелец = ЦеннаяБумагаЗапроса.Ссылка)
	|				И ((ВЫРАЗИТЬ(КодыЗагрузки.Биржа КАК Справочник.КлассификаторыЗагрузки)) = &НДЦ)
	|		ПО (ЦеннаяБумагаЗапроса.ISIN = ЗапросСубброкеруНаРаскрытие.ISIN)
	|			И (ЦеннаяБумагаЗапроса.НомерРегистрации = ЗапросСубброкеруНаРаскрытие.ГосРегНомерВыпуска)
	|			И (ЦеннаяБумагаЗапроса.Ссылка В (ЕСТЬNULL(КорпоративноеДействие_Новый.ЦеннаяБумага1, РаскрытиеСпискаВладельцев.ЦеннаяБумага1), ЕСТЬNULL(КорпоративноеДействие_Новый.ЦеннаяБумага2, РаскрытиеСпискаВладельцев.ЦеннаяБумага2)))
	|			И (ЗапросСубброкеруНаРаскрытиеДанныеСубброкера.КодНРД = КодыЗагрузки.Код)
	|ГДЕ
	|	ЗапросСубброкеруНаРаскрытие.Ссылка = &ЗапросНаРСВ";
	Запрос.УстановитьПараметр("ЗапросНаРСВ", ЗапросНаРСВ);
	Запрос.УстановитьПараметр("Доход", Перечисления.ТипыКорпоративныхДействий.Доход);
	Запрос.УстановитьПараметр("НДЦ", Константы.КлассификаторЗагрузкиНДЦ.Получить());
	Запрос.УстановитьПараметр("ДатаСреза", ТекущаяДатаСеанса());
	Запрос.УстановитьПараметр("WTRC", "WTRC");

	Запрос.Выполнить();
	
КонецПроцедуры

Функция ЗапросыСубброкеруКОтправке(РаскрытиеСпискаВладельцевСсылка)
	
	Запрос = Новый Запрос( 
	"ВЫБРАТЬ
	|	ЗапросСубброкеруНаРаскрытие.Клиент,
	|	ЗапросСубброкеруНаРаскрытие.Ссылка,
	|	ЗапросСубброкеруНаРаскрытие.Дата
	|ПОМЕСТИТЬ ЗапросыСубброкеруНаРаскрытие
	|ИЗ
	|	Документ.ЗапросСубброкеруНаРаскрытие КАК ЗапросСубброкеруНаРаскрытие
	|ГДЕ
	|	ЗапросСубброкеруНаРаскрытие.Статус = &СтатусСформирован
	|	И ЗапросСубброкеруНаРаскрытие.РСВ = &РСВ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЗапросыСубброкеруНаРаскрытие.Клиент,
	|	МАКСИМУМ(ЗапросыСубброкеруНаРаскрытие.Ссылка) КАК Ссылка,
	|	ЗапросыСубброкеруНаРаскрытие.Дата
	|ПОМЕСТИТЬ СрезПоследних
	|ИЗ
	|	ЗапросыСубброкеруНаРаскрытие КАК ЗапросыСубброкеруНаРаскрытие
	|
	|СГРУППИРОВАТЬ ПО
	|	ЗапросыСубброкеруНаРаскрытие.Клиент,
	|	ЗапросыСубброкеруНаРаскрытие.Дата
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЗапросыСубброкеруНаРаскрытие.Клиент КАК Клиент,
	|	ЗапросыСубброкеруНаРаскрытие.Ссылка КАК Ссылка
	|ИЗ
	|	СрезПоследних КАК СрезПоследних
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ЗапросыСубброкеруНаРаскрытие КАК ЗапросыСубброкеруНаРаскрытие
	|		ПО СрезПоследних.Клиент = ЗапросыСубброкеруНаРаскрытие.Клиент
	|			И СрезПоследних.Дата = ЗапросыСубброкеруНаРаскрытие.Дата");
	
	Запрос.УстановитьПараметр("РСВ",РаскрытиеСпискаВладельцевСсылка);
	Запрос.УстановитьПараметр("СтатусСформирован",Перечисления.СтатусыДокументаЗапросСубброкеруНаРаскрытие.Сформирован);
	Возврат Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка");
	
КонецФункции

Функция ДанныеЗаполненияУведомленийИЗапросовКОтправке(ДокументыКОтправке)
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	ЗапросСубброкеруНаРаскрытие.Ссылка КАК ЗапросСубброкеруСсылка,
	|	ЗапросСубброкеруНаРаскрытие.Клиент КАК Клиент,
	|	ЗапросСубброкеруНаРаскрытие.РазделСчетаДЕПО КАК РазделСчетаДЕПО,
	|	ЗапросСубброкеруНаРаскрытие.СчетДЕПО КАК СчетДЕПО,
	|	ЕСТЬNULL(ЦенныеБумаги.Ссылка, ЗНАЧЕНИЕ(Справочник.ЦенныеБумаги.ПустаяСсылка)) КАК ЦеннаяБумага,
	|	ЗапросСубброкеруНаРаскрытие.КД КАК КД,
	|	ЗапросСубброкеруНаРаскрытие.ЗаголовокСообщения КАК Тема,
	|	ЗапросСубброкеруНаРаскрытие.ТелоСообщения КАК Тело,
	|	ЗапросСубброкеруНаРаскрытие.РСВ КАК РСВ,
	|	ЕСТЬNULL(ЗапросСубброкеруНаРаскрытие.КД.ДатаФиксации, ЗапросСубброкеруНаРаскрытие.РСВ.ДатаФиксации) КАК ДатаФиксации,
	|	ЗапросСубброкеруНаРаскрытие.ВидКД.Код КАК ВидКДКод
	|ПОМЕСТИТЬ ЗапросыСубброкеруНаРаскрытие
	|ИЗ
	|	Документ.ЗапросСубброкеруНаРаскрытие КАК ЗапросСубброкеруНаРаскрытие
	|	ЛЕВОЕ СОЕДИНЕНИЕ Документ.РаскрытиеСпискаВладельцев КАК РаскрытиеСпискаВладельцев
	|	ПО
	|		РаскрытиеСпискаВладельцев.Ссылка = ЗапросСубброкеруНаРаскрытие.РСВ 
	|
	|	ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ЦенныеБумаги КАК ЦенныеБумаги
	|	ПО
	|		ЦенныеБумаги.ISIN = ЗапросСубброкеруНаРаскрытие.ISIN 
	|		И ЦенныеБумаги.НомерРегистрации = ЗапросСубброкеруНаРаскрытие.ГосРегНомерВыпуска 
	|		И ЦенныеБумаги.Ссылка В (РаскрытиеСпискаВладельцев.ЦеннаяБумага1, РаскрытиеСпискаВладельцев.ЦеннаяБумага2)
	|		И ЦенныеБумаги.Дробная = ЛОЖЬ
	|ГДЕ
	|	ЗапросСубброкеруНаРаскрытие.Ссылка В(&ДокументыКОтправке)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ОтправленныеЗапросСубброкеруНаРаскрытие.Клиент КАК Клиент,
	|	ЕСТЬNULL(ЦенныеБумаги.Ссылка, ЗНАЧЕНИЕ(Справочник.ЦенныеБумаги.ПустаяСсылка)) КАК ЦеннаяБумага
	|ПОМЕСТИТЬ ОтправленныеЗапросСубброкеруНаРаскрытие
	|ИЗ
	|	Документ.ЗапросСубброкеруНаРаскрытие КАК ОтправленныеЗапросСубброкеруНаРаскрытие
	|	ЛЕВОЕ СОЕДИНЕНИЕ Документ.РаскрытиеСпискаВладельцев КАК РаскрытиеСпискаВладельцев
	|	ПО
	|		РаскрытиеСпискаВладельцев.Ссылка = ОтправленныеЗапросСубброкеруНаРаскрытие.РСВ 
	|
	|	ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ЦенныеБумаги КАК ЦенныеБумаги
	|	ПО
	|		ЦенныеБумаги.ISIN = ОтправленныеЗапросСубброкеруНаРаскрытие.ISIN 
	|		И ЦенныеБумаги.НомерРегистрации = ОтправленныеЗапросСубброкеруНаРаскрытие.ГосРегНомерВыпуска 
	|		И ЦенныеБумаги.Ссылка В (РаскрытиеСпискаВладельцев.ЦеннаяБумага1, РаскрытиеСпискаВладельцев.ЦеннаяБумага2)
	|		И ЦенныеБумаги.Дробная = ЛОЖЬ
	|ГДЕ
	|	ОтправленныеЗапросСубброкеруНаРаскрытие.Статус В(&СтатусыОтправленных)
	|	И ОтправленныеЗапросСубброкеруНаРаскрытие.РСВ В
	|			(ВЫБРАТЬ
	|				ЗапросыСубброкеруНаРаскрытие.РСВ
	|			ИЗ
	|				ЗапросыСубброкеруНаРаскрытие)
	|	И НЕ ОтправленныеЗапросСубброкеруНаРаскрытие.ПометкаУдаления
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	КодыЗагрузкиКлиента.Код КАК КодЗагрузки,
	|	КодыЗагрузкиКлиента.Код КАК ClientId,
	|	ЗапросыСубброкеруНаРаскрытие.ЗапросСубброкеруСсылка КАК ЗапросСубброкеруСсылка,
	|	ЗапросыСубброкеруНаРаскрытие.Клиент КАК Клиент,
	|	ЗапросыСубброкеруНаРаскрытие.РазделСчетаДЕПО КАК РазделСчетаДЕПО,
	|	ЗапросыСубброкеруНаРаскрытие.СчетДЕПО КАК СчетДЕПО,
	|	ЗапросыСубброкеруНаРаскрытие.ЦеннаяБумага КАК ЦеннаяБумага,
	|	ЗапросыСубброкеруНаРаскрытие.КД КАК КД,
	|	ЗапросыСубброкеруНаРаскрытие.Тема КАК Тема,
	|	ЗапросыСубброкеруНаРаскрытие.Тело КАК Тело,
	|	ЗапросыСубброкеруНаРаскрытие.РСВ КАК РСВ,
	|	ЗапросыСубброкеруНаРаскрытие.ДатаФиксации КАК ДатаФиксации,
	|	ВЫБОР
	|		КОГДА ЕСТЬNULL(ОтправленныеЗапросСубброкеруНаРаскрытие.Клиент, ИСТИНА) = ИСТИНА
	|			ТОГДА ЛОЖЬ
	|		ИНАЧЕ ИСТИНА
	|	КОНЕЦ КАК ПовторныйЗапрос,
	|	ЗапросыСубброкеруНаРаскрытие.ВидКДКод КАК ВидКДКод
	|ИЗ
	|	ЗапросыСубброкеруНаРаскрытие КАК ЗапросыСубброкеруНаРаскрытие
	|		ЛЕВОЕ СОЕДИНЕНИЕ ОтправленныеЗапросСубброкеруНаРаскрытие КАК ОтправленныеЗапросСубброкеруНаРаскрытие
	|		ПО ЗапросыСубброкеруНаРаскрытие.Клиент = ОтправленныеЗапросСубброкеруНаРаскрытие.Клиент
	|			И ЗапросыСубброкеруНаРаскрытие.ЦеннаяБумага = ОтправленныеЗапросСубброкеруНаРаскрытие.ЦеннаяБумага
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.КодыЗагрузки КАК КодыЗагрузкиКлиента
	|		ПО ЗапросыСубброкеруНаРаскрытие.Клиент = КодыЗагрузкиКлиента.Владелец
	|			И (НЕ КодыЗагрузкиКлиента.ПометкаУдаления)
	|			И (КодыЗагрузкиКлиента.Биржа = &КлассификаторыЗагрузкиКлиенты)");
	
	СтатусыОтправленных = Новый Массив();
	СтатусыОтправленных.Добавить(Перечисления.СтатусыДокументаЗапросСубброкеруНаРаскрытие.Отправлен);
	СтатусыОтправленных.Добавить(Перечисления.СтатусыДокументаЗапросСубброкеруНаРаскрытие.ОтправленПовторно);
	СтатусыОтправленных.Добавить(Перечисления.СтатусыДокументаЗапросСубброкеруНаРаскрытие.ПолученОтвет);
	
	Запрос.УстановитьПараметр("ДокументыКОтправке", ДокументыКОтправке);
	Запрос.УстановитьПараметр("КлассификаторыЗагрузкиКлиенты", Справочники.КлассификаторыЗагрузки.Клиенты);
	Запрос.УстановитьПараметр("СтатусыОтправленных", СтатусыОтправленных);
	Возврат Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
КонецФункции

Процедура ДобавитьДокументЗапросСубброкераКОтправке(ДокументыКОтправке,ДокументСсылка)
	
	Если ТипЗнч(ДокументСсылка) = Тип("ДокументСсылка.РаскрытиеСпискаВладельцев") Тогда 
		ЗапросыСубброкера = ЗапросыСубброкеруКОтправке(ДокументСсылка);
		Для Каждого ЗапросСубброкера Из ЗапросыСубброкера Цикл 
			ДокументыКОтправке.Добавить(ЗапросСубброкера);
		КонецЦикла;
	ИначеЕсли ТипЗнч(ДокументСсылка) = Тип("ДокументСсылка.ЗапросСубброкеруНаРаскрытие") Тогда
		ДокументыКОтправке.Добавить(ДокументСсылка);
	КонецЕсли;
	
КонецПроцедуры

