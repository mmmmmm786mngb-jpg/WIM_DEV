
//#Область ОписаниеПеременных

&НаСервере
Перем мТекущийОбъектНаСервере;

//#КонецОбласти 

//#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриЧтенииНаСервере(ТекущийОбъект)
	Оболочки.ПриЧтенииНаСервереДокумента(ЭтотОбъект, ТекущийОбъект);
КонецПроцедуры

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)

	//проверка на возможность создания документа на основании поручения
	Если Объект.Проверка Тогда	    
	    Отказ = Истина;		
		Возврат;
	КонецЕсли; 
		
	Если ЭтоНовый(ЭтаФорма) Тогда 		
		// Заполнить реквизиты значениями по умолчанию.
		ОбщегоНазначения.ЗаполнитьШапкуДокумента(Объект, ПараметрыСеанса.ТекущийПользователь);
		
		// Установка номера счета в зависимости от владельца счета.
		УстановкаНомераСчетаДепо();	
	Иначе
		
		УправлениеВидимостьюРеквизитовДоговораСчетаДепо();		
	КонецЕсли;
	
	УстановитьОграничениеТипаСчетаДЕПО();
	УстановитьВидимостьСчетаДепоМХ();
	
КонецПроцедуры

&НаСервере
Процедура ПослеЗаписиНаСервере(ТекущийОбъект, ПараметрыЗаписи)
	ОбработатьСобытиеОткрытиеСчетаДепо(ТекущийОбъект);
КонецПроцедуры

//#КонецОбласти

//#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ВладелецСчетаПриИзменении(Элемент)
	ВладелецСчетаПриИзмененииНаСервере();
	
КонецПроцедуры

//#КонецОбласти

//#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ПечатьУведомленияОбОткрытии(Команда)
	ТабДок = ПечатьУведомленияОбОткрытииНаСервере(Объект.Ссылка);
	ТабДок.ОтображатьСетку 		= Ложь;
	ТабДок.Защита 				= Ложь;
	ТабДок.ТолькоПросмотр 		= Истина;
	ТабДок.ОтображатьЗаголовки 	= Ложь;
	ТабДок.АвтоМасштаб			= Истина;	
	ТабДок.Показать();
КонецПроцедуры

//#КонецОбласти

//#Область СлужебныеПроцедурыИФункции

//#Область Сервис

&НаКлиентеНаСервереБезКонтекста
Функция ЭтоНовый(Форма)
	Возврат НЕ ЗначениеЗаполнено(Форма.Объект.Ссылка);	
КонецФункции 

//#КонецОбласти 

//#Область ВызовСервера

&НаСервере
Процедура ВладелецСчетаПриИзмененииНаСервере()
	УстановитьОграничениеТипаСчетаДЕПО();
	УстановкаНомераСчетаДепо();
	УправлениеВидимостьюРеквизитовДоговораСчетаДепо();
	УстановитьВидимостьСчетаДепоМХ();
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ПечатьУведомленияОбОткрытииНаСервере(Ссылка)
