	//ТабДок = Документы.ОткрытиеСчетаДепо.ПечатьУведомленияОбОткрытии(Ссылка);
	//ТабДок = Новый ТабличныйДокумент;
	//Возврат ТабДок;		
КонецФункции

&НаСервере
Процедура УстановитьВидимостьСчетаДепоМХ()
	Элементы.СчетДепоМХ.Видимость = ТипЗнч(Объект.ВладелецСчета) = Тип("СправочникСсылка.Контрагенты");
КонецПроцедуры

//#КонецОбласти 

//#Область Диалог

//#Область НастройкаФормы

&НаСервере
Процедура УстановитьОграничениеТипаСчетаДЕПО()
	
	ТипыОграничений = Новый Массив;
	
	ТипВладельца = ТипЗнч(Объект.ВладелецСчета);
	Если ТипВладельца = Тип("СправочникСсылка.Контрагенты") Тогда
		ТипыОграничений.Добавить(Тип("СправочникСсылка.СчетаДепо"));
		
	ИначеЕсли ТипВладельца = Тип("СправочникСсылка.МестаХранения") Тогда
		ТипыОграничений.Добавить(Тип("СправочникСсылка.СчетаДепоМХ"));		
		
	Иначе
		ТипыОграничений.Добавить(Тип("СправочникСсылка.СчетаДепо"));
		ТипыОграничений.Добавить(Тип("СправочникСсылка.СчетаДепоМХ"));
		
	КонецЕсли; 
	
	Элементы.СчетДепо.ОграничениеТипа = Новый ОписаниеТипов(ТипыОграничений);
	Объект.СчетДепо = Элементы.СчетДепо.ОграничениеТипа.ПривестиЗначение(Объект.СчетДепо);
	
КонецПроцедуры 

//Управление видимостью реквизитов договора счета депо.
//
//Параметры
//		БезПараметров
//
&НаСервере
Процедура УправлениеВидимостьюРеквизитовДоговораСчетаДепо()

	Если ТипЗнч(Объект.ВладелецСчета) = Тип("СправочникСсылка.МестаХранения") Тогда
		Элементы.НомерДепозитарногоДоговора.Видимость        = Истина;
		Элементы.ДатаДепозитарногоДоговора.Видимость         = Истина;
				
	ИначеЕсли ТипЗнч(Объект.ВладелецСчета) = Тип("СправочникСсылка.Контрагенты") Тогда		
		Элементы.НомерДепозитарногоДоговора.Видимость        = Ложь;
		Элементы.ДатаДепозитарногоДоговора.Видимость         = Ложь;
		
		
	КонецЕсли; 
	
КонецПроцедуры // УправлениеВидимостьюРеквизитовДоговораСчетаДепо()
  
//#КонецОбласти 

//#КонецОбласти 

//#Область НомерСчетаДЕПО

//Процедура установки нмера счета депо, в зависимости от владельца счета.
//
&НаСервере
Процедура УстановкаНомераСчетаДепо()
	
	//проверка на указание владельца счета.
	Если ТипЗнч(Объект.ВладелецСчета) = Неопределено Тогда
		
		Сообщить("Не указан владелец счета");
		Возврат;
		
	Иначе
		 
		СозданиеНомераСчетаДепоДепонента();
		 
	КонецЕсли; 
	
КонецПроцедуры	

// Процедура установки номера счета депо депонента
// Параметры
//   Без параметров
//  
&НаСервере
Процедура СозданиеНомераСчетаДепоДепонента()
	
	Если ТипЗнч(Объект.ВладелецСчета) = Тип("СправочникСсылка.Контрагенты") Тогда
	
		Префикс	= Объект.ВладелецСчета.Префикс;
		
		Если Объект.ВладелецСчета.ЮрФизЛицо = Перечисления.ЮрФизЛицо.ЮрЛицо Тогда
			
			Префикс	= Префикс+"1-";	
			 
		КонецЕсли; 
	
		НовыйОбъект = Справочники.СчетаДепо.СоздатьЭлемент();
		НовыйОбъект.Код = Объект.НомерСчета;
		
	ИначеЕсли ТипЗнч(Объект.ВладелецСчета) = Тип("СправочникСсылка.МестаХранения") Тогда
		
		НовыйОбъект = Справочники.СчетаДепоМХ.СоздатьЭлемент();
		НовыйОбъект.Код = Объект.НомерСчета;
	
	КонецЕсли; 

КонецПроцедуры // СозданиеНомераСчетаДепоДепонента()

// Обработка события "Открытие счета Депо" в части Формирования печатной формы 
// уведомления о заключении договора на обслуживание.
// Обработчик располагается в форме документа, поскольку использует метод Напечатать()
// табличного документа. Прежняя логика обработки события не изменилась.
//
&НаСервере
Процедура ОбработатьСобытиеОткрытиеСчетаДепо(ТекущийОбъект)

	Запрос = Новый Запрос();
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	СтатусыПорученийСрезПоследних.СтатусПоручения КАК СтатусПоручения
	|ИЗ
	|	РегистрСведений.СтатусыПоручений.СрезПоследних(
	|			,
	|			Поручение = &Поручение
	|				И СтатусПоручения = ЗНАЧЕНИЕ(Перечисление.СтатусыПоручений.Исполнено)) КАК СтатусыПорученийСрезПоследних
	|";
	Запрос.УстановитьПараметр("Поручение", ТекущийОбъект.ДокументОснование);
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		
		Запрос = Новый Запрос();
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	СчетаДепо.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.СчетаДепо КАК СчетаДепо
		|ГДЕ
		|	СчетаДепо.ОперацияОткрытияСчета = &ОперацияОткрытияСчета";
		Запрос.УстановитьПараметр("ОперацияОткрытияСчета", ТекущийОбъект.Ссылка);
		Выборка1 = Запрос.Выполнить().Выбрать();
		Если Не Выборка1.Следующий() Тогда
			Сообщить("Невозможно зарегистрировать счет Депо в Бэк офисе по причине:"+
			Символы.ПС+Символы.Таб+"Не обнаружен счет депо при проведении операции открытия счета.");
			Отказ = Истина;
		КонецЕсли;
		
	КонецЕсли;

КонецПроцедуры

