				<DynamicDataRead>true</DynamicDataRead>
				<QueryText>ВЫБРАТЬ
	Уведомление.Ссылка КАК Ссылка,
	Уведомление.ВерсияДанных КАК ВерсияДанных,
	Уведомление.ПометкаУдаления КАК ПометкаУдаления,
	Уведомление.Номер КАК Номер,
	Уведомление.Дата КАК Дата,
	Уведомление.Проведен КАК Проведен,
	Уведомление.ВидКД КАК ВидКД,
	Уведомление.ДатаСообщения КАК ДатаСообщения,
	Уведомление.ДатаФиксации КАК ДатаФиксации,
	Уведомление.ДокументОснование КАК ДокументОснование,
	Уведомление.КДРеференс КАК КДРеференс,
	Уведомление.Статус КАК Статус,
	Уведомление.ЦеннаяБумага1 КАК ЦеннаяБумага1,
	Уведомление.ЦеннаяБумага2 КАК ЦеннаяБумага2,
	Уведомление.Эмитент КАК Эмитент,
	Уведомление.Этап КАК Этап,
	Уведомление.МоментВремени КАК МоментВремени,
	ВЫБОР
		КОГДА Уведомление.ФормаСообщенияКК = &amp;ФормаОПоступленииМатериаловКОбщемуСобраниюВладельцев
			ТОГДА Уведомление.ДатаКДПлан
		КОГДА Уведомление.ФормаСообщенияКК = &amp;ФормаОПоступленииИнформацииИзБюллетеня
			ТОГДА Уведомление.ДатаКДПлан
		КОГДА Уведомление.ФормаСообщенияКК = &amp;ФормаКонвертацияОбменЦБ
			ТОГДА Уведомление.ДатаКДРеестр
		КОГДА Уведомление.ФормаСообщенияКК = &amp;ФормаОбъединениеВыпусковЦБ
			ТОГДА Уведомление.ДатаКДРеестр
		КОГДА Уведомление.ФормаСообщенияКК = &amp;ФормаРеорганизацииОбщества
			ТОГДА Уведомление.ДатаКДРеестр
		КОГДА Уведомление.ФормаСообщенияКК = &amp;ФормаCписаниеЦБ
			ТОГДА Уведомление.ДатаКДРеестр
		КОГДА Уведомление.ФормаСообщенияКК = &amp;ФормаCвязанногоСВыплатой
			ТОГДА Уведомление.ДатаКДПлан
		КОГДА Уведомление.ФормаСообщенияКК = &amp;ФормаОтменыКД
			ТОГДА Уведомление.ДатаКДПлан
		ИНАЧЕ ДАТАВРЕМЯ(1, 1, 1)
	КОНЕЦ КАК ДатаКД,
	Уведомление.ПризнакОбязательностиКД КАК ПризнакОбязательностиКД,
	Уведомление.ДополнительнаяИнформация КАК ДополнительнаяИнформация
ИЗ
	Документ.УведомлениеКлиентам КАК Уведомление</QueryText>
				<MainTable>Document.УведомлениеКлиентам</MainTable>
				<ListSettings>
