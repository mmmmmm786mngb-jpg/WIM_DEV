// РАБОТА С WEB-СЕРВИСАМИ CreateCorporateActionWtrc И AddClientToCorporateActionWtrc

Функция РезультатСозданияКДИлиДобавленияКлиентаВ_КД_WTRC(ОтправительУведомленийКК, ПараметрыWebСервиса) Экспорт
	Если ВКабинетеКлиентаСозданоКД(ОтправительУведомленийКК) Тогда
		Возврат ДобавитьКлиентаВСуществующееКорпоративноеДействиеWTRC(ПараметрыWebСервиса, ОтправительУведомленийКК);
	Иначе
		Возврат СохранитьКорпоративноеДействиеWTRC(ПараметрыWebСервиса, ОтправительУведомленийКК);
	КонецЕсли;
КонецФункции

Функция ДанныеДляWebСервисовWTRC(КД, МассивДепонентов, Дата, ИмяТабЧастиИсточника = "Депоненты") Экспорт
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	СУММА(ДепонентыБП.Количество) КАК Unit,
	|	ДепонентыБП.ЦеннаяБумага.ISIN КАК Isin,
	|	ДепонентыБП.ЦеннаяБумага.Наименование КАК SecName,
	|	ВЫБОР
	|		КОГДА ДепонентыБП.ЦеннаяБумага.ВидЦБ = &ВидыАкцийОбыкновенная
	|			ТОГДА ""Ordinary""
	|		ИНАЧЕ ""Preference""
	|	КОНЕЦ КАК SecType,
	|	КодыЗагрузкиЦБ.Код КАК SecCode,
	|	КодыЗагрузкиКлиента.Код КАК ClientId,
	|	ДепонентыБП.ЦеннаяБумага.НомерРегистрации КАК GosRegNumber,
	|	ЕСТЬNULL(НоминалЦБСрезПоследних.Сумма, 0) КАК NominalValue,
	|	ВЫБОР
	|		КОГДА ДепонентыБП.ЦеннаяБумага.ВалютаНоминала = &ПустаяВалюта
	|			ТОГДА &НаименованиеВалютыПоУмолчанию
	|		ИНАЧЕ ДепонентыБП.ЦеннаяБумага.ВалютаНоминала.Наименование
	|	КОНЕЦ КАК NominalCurrency,
	|	0 КАК StakeToParticipate,
	|	ДепонентыБП.РазделСчета.Владелец.Код КАК DepoAccountFrom,
	|	МАКСИМУМ(ДепонентыБП.РазделСчета.Код) КАК DepoSectionFrom,
	|	МАКСИМУМ(ДепонентыБП.РазделСчетаПолучатель.Владелец.Код) КАК DepoAccountTo,
	|	МАКСИМУМ(ДепонентыБП.РазделСчетаПолучатель.Код) КАК DepoSectionTo,
	|	ДепонентыБП.Депонент КАК Клиент,
	|	Договоры.Ссылка КАК Договор,
	|	ДепонентыБП.РазделСчета.Владелец КАК СчетДепо,
	|	МАКСИМУМ(ДепонентыБП.РазделСчета) КАК РазделСчетаДепо,
	|	ДепонентыБП.ЦеннаяБумага КАК ЦеннаяБумага,
	|	СУММА(ДепонентыБП.Количество) КАК Количество
	|ИЗ
	|	БизнесПроцесс.ОбработкаWTRCСообщения.Депоненты КАК ДепонентыБП
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.КодыЗагрузки КАК КодыЗагрузкиЦБ
	|		ПО ДепонентыБП.ЦеннаяБумага = КодыЗагрузкиЦБ.Владелец
	|			И (КодыЗагрузкиЦБ.Биржа = &НДЦ)
	|			И (НЕ КодыЗагрузкиЦБ.ПометкаУдаления)
	|			И (КодыЗагрузкиЦБ.ДатаОкончанияДействия = ДАТАВРЕМЯ(1, 1, 1)
	|				ИЛИ КодыЗагрузкиЦБ.ДатаОкончанияДействия > &ДатаСреза)
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.КодыЗагрузки КАК КодыЗагрузкиКлиента
	|		ПО ДепонентыБП.Депонент = КодыЗагрузкиКлиента.Владелец
	|			И (КодыЗагрузкиКлиента.Биржа = &КлассификаторыЗагрузкиКлиенты)
	|			И (НЕ КодыЗагрузкиКлиента.ПометкаУдаления)
	|			И (КодыЗагрузкиКлиента.ДатаОкончанияДействия = ДАТАВРЕМЯ(1, 1, 1)
	|				ИЛИ КодыЗагрузкиКлиента.ДатаОкончанияДействия > &ДатаСреза)
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.НоминалЦБ.СрезПоследних(&ДатаСреза, ) КАК НоминалЦБСрезПоследних
	|		ПО ДепонентыБП.ЦеннаяБумага = НоминалЦБСрезПоследних.ЦеннаяБумага
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ДоговорыКонтрагентов КАК Договоры
	|		ПО ДепонентыБП.Депонент = Договоры.Владелец
	|			И (НЕ Договоры.ПометкаУдаления)
	|ГДЕ
	|	ДепонентыБП.Ссылка.КД = &КД
	|	И НЕ ДепонентыБП.Ссылка.ПометкаУдаления
	|	И ДепонентыБП.РазделСчетаПолучатель <> &ПустойРазделСчетаДепо
	|	И НЕ ДепонентыБП.РазделСчета.ТипРазделаСчетаДЕПО = &НалоговыйРаздел
	|	И ДепонентыБП.Депонент В(&МассивДепонентов)
	|
	|СГРУППИРОВАТЬ ПО
	|	ДепонентыБП.ЦеннаяБумага.ISIN,
	|	ДепонентыБП.ЦеннаяБумага.Наименование,
	|	ВЫБОР
	|		КОГДА ДепонентыБП.ЦеннаяБумага.ВидЦБ = &ВидыАкцийОбыкновенная
	|			ТОГДА ""Ordinary""
	|		ИНАЧЕ ""Preference""
	|	КОНЕЦ,
	|	КодыЗагрузкиЦБ.Код,
	|	КодыЗагрузкиКлиента.Код,
	|	ДепонентыБП.ЦеннаяБумага.НомерРегистрации,
	|	ЕСТЬNULL(НоминалЦБСрезПоследних.Сумма, 0),
	|	ВЫБОР
	|		КОГДА ДепонентыБП.ЦеннаяБумага.ВалютаНоминала = &ПустаяВалюта
	|			ТОГДА &НаименованиеВалютыПоУмолчанию
	|		ИНАЧЕ ДепонентыБП.ЦеннаяБумага.ВалютаНоминала.Наименование
	|	КОНЕЦ,
	|	ДепонентыБП.Депонент,
	|	ДепонентыБП.РазделСчета.Владелец,
	|	ДепонентыБП.РазделСчета.Владелец.Код,
	|	ДепонентыБП.ЦеннаяБумага,
	|	Договоры.Ссылка";
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "БизнесПроцесс.ОбработкаWTRCСообщения.Депоненты",
		"БизнесПроцесс.ОбработкаWTRCСообщения." + ИмяТабЧастиИсточника);
	Запрос.УстановитьПараметр("МассивДепонентов",		МассивДепонентов);
	Запрос.УстановитьПараметр("ВидыАкцийОбыкновенная",	Перечисления.ВидыАкций.Обыкновенная);
	Запрос.УстановитьПараметр("НДЦ",					Константы.КлассификаторЗагрузкиНДЦ.Получить());
	Запрос.УстановитьПараметр("КлассификаторыЗагрузкиКлиенты", Справочники.КлассификаторыЗагрузки.Клиенты);
	Запрос.УстановитьПараметр("ДатаСреза",				Дата);
	Запрос.УстановитьПараметр("КД",						КД);
	Запрос.УстановитьПараметр("ПустойРазделСчетаДепо",	Справочники.РазделыСчетаДепо.ПустаяСсылка());	
	Запрос.УстановитьПараметр("КД",						КД);
	Запрос.УстановитьПараметр("ПустаяВалюта", 			Справочники.Валюты.ПустаяСсылка());
	Запрос.УстановитьПараметр("НаименованиеВалютыПоУмолчанию", Справочники.Валюты.ДолларСША().Наименование);
	Запрос.УстановитьПараметр("НалоговыйРаздел",		Перечисления.ТипыРазделовСчетовДЕПО.Налоговый);
	
	Возврат Запрос.Выполнить().Выгрузить();
КонецФункции

// Возвращает последний по хронологии документ уведомления для КД со статусом "Отправлено",
// т.е. тот, который пользователь проверил и подтвердил текст сообщения для рассылки клиентам.
Функция ПодтвержденноеУведомлениеПоКД(КД) Экспорт
	Запрос = Новый Запрос(
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	Уведомление.Ссылка КАК ПодтвержденноеУведомление
	|ИЗ
	|	Документ.УведомлениеКлиентам КАК Уведомление
	|ГДЕ
	|	Уведомление.ДокументОснование = &КД
	|	И НЕ Уведомление.ПометкаУдаления
	|	И Уведомление.Статус = &Отправлено
	|
	|УПОРЯДОЧИТЬ ПО
	|	Уведомление.Дата УБЫВ");
	Запрос.УстановитьПараметр("КД",			КД);
	Запрос.УстановитьПараметр("Отправлено",	Перечисления.СтатусыУведомленийКлиентам.Отправлено);
	Выборка = Запрос.Выполнить().Выбрать();
	Уведомление = Документы.УведомлениеКлиентам.ПустаяСсылка();
	Если Выборка.Следующий() Тогда
		Уведомление = Выборка.ПодтвержденноеУведомление;
	КонецЕсли;
	Возврат Уведомление;
КонецФункции

