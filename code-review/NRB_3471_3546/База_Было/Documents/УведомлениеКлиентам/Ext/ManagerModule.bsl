// ИНТЕРФЕЙС

// Возвращает док. УведомлениеКлиентам среди подчиненных документу-основанию,
// у которого форма сообщения КК и соответствующие ей реквизиты совпадают с такими же реквизитами
// тестируемого уведомления.
// Если такое уведомление не найдено, возвращает Неопределено.
Функция ИдентичноеУведомление(ДокументОснование, ТестируемоеУведомление) Экспорт
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	УведомлениеКлиентам.Ссылка КАК ПодчиненноеУведомление
	|ИЗ
	|	Документ.УведомлениеКлиентам КАК УведомлениеКлиентам
	|ГДЕ
	|	УведомлениеКлиентам.ДокументОснование = &ДокументОснование
	|	И НЕ УведомлениеКлиентам.ПометкаУдаления
	|	И УведомлениеКлиентам.ФормаСообщенияКК = &ФормаСообщенияКК
	|	И УведомлениеКлиентам.АктивнаяСсылка = &АктивнаяСсылка
	|
	|ДЛЯ ИЗМЕНЕНИЯ
	|	Документ.УведомлениеКлиентам
	|
	|УПОРЯДОЧИТЬ ПО
	|	УведомлениеКлиентам.Дата");
	Запрос.УстановитьПараметр("ДокументОснование",	ДокументОснование);
	Запрос.УстановитьПараметр("ФормаСообщенияКК",	ТестируемоеУведомление.ФормаСообщенияКК);
	Запрос.УстановитьПараметр("АктивнаяСсылка",	ТестируемоеУведомление.АктивнаяСсылка);
	Выборка = Запрос.Выполнить().Выбрать();
	АктуальныеРеквизиты = АктуальныеРеквизиты(ТестируемоеУведомление.ФормаСообщенияКК);
	Пока Выборка.Следующий() Цикл
		Если РеквизитыРавны(ТестируемоеУведомление, Выборка.ПодчиненноеУведомление, АктуальныеРеквизиты.ОбщиеКопируемые)
			И РеквизитыРавны(ТестируемоеУведомление, Выборка.ПодчиненноеУведомление, АктуальныеРеквизиты.СпецифичныеКопируемые)
			И РеквизитыРавны(ТестируемоеУведомление, Выборка.ПодчиненноеУведомление, АктуальныеРеквизиты.Произвольные) Тогда
			Возврат Выборка.ПодчиненноеУведомление;
		КонецЕсли;
	КонецЦикла;
	Возврат Неопределено;
КонецФункции

Функция УведомлениеПоТексту(ДокументОснование, ФормаСообщенияКК, ТелоСообщения) Экспорт 
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	УведомлениеКлиентам.Ссылка КАК УведомлениеСсылка,
	|	УведомлениеКлиентам.ТелоСообщения КАК ТелоСообщения
	|ИЗ
	|	Документ.УведомлениеКлиентам КАК УведомлениеКлиентам
	|ГДЕ
	|	УведомлениеКлиентам.ДокументОснование = &ДокументОснование
	|	И НЕ УведомлениеКлиентам.ПометкаУдаления
	|	И УведомлениеКлиентам.ФормаСообщенияКК = &ФормаСообщенияКК
	|
	|ДЛЯ ИЗМЕНЕНИЯ
	|	Документ.УведомлениеКлиентам
	|
	|УПОРЯДОЧИТЬ ПО
	|	УведомлениеКлиентам.Дата");
	Запрос.УстановитьПараметр("ДокументОснование",	ДокументОснование);
	Запрос.УстановитьПараметр("ФормаСообщенияКК",	ФормаСообщенияКК);
	Результат = Запрос.Выполнить();
	Если Результат.Пустой() Тогда 
		Возврат Неопределено;
	КонецЕсли;
	
	Выборка = Результат.Выбрать();
	Пока Выборка.Следующий() Цикл 
		Если Выборка.ТелоСообщения = ТелоСообщения Тогда 
			Возврат Выборка.УведомлениеСсылка;	
		КонецЕсли;
	КонецЦикла;
	
	Возврат Неопределено;
	
КонецФункции

// Возвращает Истина, если код вида ВидКД содержится в строке СписокКодовКД, иначе Ложь.
//
// Параметры:
//	ВидКД - СправочникСсылка.ВидыКорпоративныхДействий, код которого анализируется.
//	СписокКодовКД - строка с кодами видов КД, разделенных запятыми.
//
// Возвращаемое значение:
//	булево
//
Функция ВидКДВСписке(ВидКД, СписокКодовКД) Экспорт
	Возврат МассивПодстрок(СписокКодовКД).Найти(ВидКД.Код) <> Неопределено;
КонецФункции

Процедура ОтправитьУведомление(ДокументСсылка, ОбработкаВебСервисы = Неопределено) Экспорт
	Если ЗначениеЗаполнено(ДокументСсылка)
		И ТипЗнч(ДокументСсылка) = Тип("ДокументСсылка.УведомлениеКлиентам") Тогда
		ДокументОбъект = ДокументСсылка.ПолучитьОбъект();
		ДокументОбъект.ОтправитьУведомление(ОбработкаВебСервисы);
	КонецЕсли;
КонецПроцедуры

Функция СтатусРазрешенДляОтправки(СтатусДокумента) Экспорт
	Статусы = Новый Массив;
	Статусы.Добавить(Перечисления.СтатусыУведомленийКлиентам.ОжидаетОтправки);
	Статусы.Добавить(Перечисления.СтатусыУведомленийКлиентам.СформированоСОшибками);
	Статусы.Добавить(Перечисления.СтатусыУведомленийКлиентам.СбойОтправки);
	
	Возврат Статусы.Найти(СтатусДокумента) <> Неопределено;
КонецФункции

// Возвращает списки актуальных реквизитов документа для данной формы сообщения:
// ОбщиеКопируемые - общие реквизиты, которые копируются из док. КД_новый один к одному для всех форм, кроме свободной
// СпецифичныеКопируемые - специфичные для данной формы реквизиты, которые копируются из док. КД_новый один к одному
// Произвольные - специфичные для данной формы реквизиты, которые устанавливаются произвольно в обработке заполнения документа
//
// Параметры:
//	ФормаСообщенияКК - перечисление - форма, для которой возвращаются списки реквизитов
// Возвращаемое значение:
//	структура из строк ("ОбщиеКопируемые", "СпецифичныеКопируемые", "Произвольные")
Функция АктуальныеРеквизиты(ФормаСообщенияКК) Экспорт
	Реквизиты = Новый Структура("ОбщиеКопируемые, СпецифичныеКопируемые, Произвольные", "", "", "");
	
	Если ФормаСообщенияКК <> Перечисления.ФормыСообщенийКК.СвободнаяФорма Тогда
		Реквизиты.Вставить("ОбщиеКопируемые", "ВидКД, Этап, ТипУведомления, Эмитент, ЦеннаяБумага1, ЦеннаяБумага2,
			|КДРеференс, ДатаФиксации, АдресВСетиИнтернет");
	КонецЕсли;
		
	Если ФормаСообщенияКК = Перечисления.ФормыСообщенийКК.ОПоступленииМатериаловКОбщемуСобраниюВладельцев Тогда
		Реквизиты.Вставить("Произвольные", "ДатаОкончанияГолосования, ДатаКДПлан, ПризнакОбязательностиКД,
			|ДатаОкончанияПриемаИнструкцийНРДИностранногоЭмитента");
		
	ИначеЕсли ФормаСообщенияКК = Перечисления.ФормыСообщенийКК.ОПоступленииИнформацииИзБюллетеня Тогда
		Реквизиты.Вставить("СпецифичныеКопируемые", "ДатаКДПлан");
		Реквизиты.Вставить("Произвольные", "ДатаОкончанияГолосования, ПризнакОбязательностиКД");
		
	ИначеЕсли Перечисления.ФормыСообщенийКК.ЭтоФормаСвязаннаяСВыкупомИлиПриобретениемЦБ(ФормаСообщенияКК) Тогда
		Реквизиты.Вставить("СпецифичныеКопируемые", "НомерСтатьи, ИнициаторВыкупа, ДатаКДРеестр, ЦенаРазмещения,
			|ВалютаЦеныРазмещения, ПризнакОбязательностиКД, ПоследнийСрокРынка, ВыплатаНа1ЦБ");
		Реквизиты.Вставить("Произвольные", "ДатаНачалаПериода, ДатаОкончанияПериода, ВалютаПлатежа, ДатаКДПлан,
			|ДатаОкончанияГолосования, КДРеференсСвязанныйСобрание");
			
	ИначеЕсли ФормаСообщенияКК = Перечисления.ФормыСообщенийКК.ОПроведенииКД_КонвертацияОбменЦБ Тогда
		Реквизиты.Вставить("СпецифичныеКопируемые", "ДатаКДРеестр, ПризнакОбязательностиКД, НовыйНоминалАкций,
			|КоэффициентКонвертации, ПравилоОкругления");
		Реквизиты.Вставить("Произвольные", "ДатаОкончанияГолосования, КДРеференсСвязанныйСобрание");
			
	ИначеЕсли ФормаСообщенияКК = Перечисления.ФормыСообщенийКК.ОПроведенииКД_ОбъединениеВыпусковЦБ Тогда
		Реквизиты.Вставить("СпецифичныеКопируемые", "ДатаКДРеестр, ДатаКДНРД");
		Реквизиты.Вставить("Произвольные", "ТабличнаяЧастьЦенныеБумаги"); // Псевдореквизит ТабличнаяЧастьЦенныеБумаги используется в функции РеквизитыРавны() для сравнения таб. частей ЦенныеБумаги
			
	ИначеЕсли ФормаСообщенияКК = Перечисления.ФормыСообщенийКК.ОПроведенииКД_РеорганизацииОбщества Тогда
		Реквизиты.Вставить("СпецифичныеКопируемые", "ПризнакОбязательностиКД, ДатаФиксацииНеизвестна, ДатаЕГРЮЛ, ДатаКДРеестр,
			|ДатаКДРеестрНеизвестна, ДатаКДНРД, ДатаКДНРДНеизвестна, КоэффициентКонвертации,
			|ДатаПодачиДокументовНаГосРегистрацию, ПравилоОкругления");
		Реквизиты.Вставить("Произвольные", "ДатаНачалаПериода, ДатаОкончанияПериода, КДРеференсСвязанныйСобрание,
			|ТабличнаяЧастьЦенныеБумаги"); // Псевдореквизит ТабличнаяЧастьЦенныеБумаги используется в функции РеквизитыРавны() для сравнения таб. частей ЦенныеБумаги
		
	ИначеЕсли ФормаСообщенияКК = Перечисления.ФормыСообщенийКК.ОбОтменеКД Тогда
		Реквизиты.Вставить("СпецифичныеКопируемые", "ПричинаОтмены, ДатаКДПлан");
		
	ИначеЕсли ФормаСообщенияКК = Перечисления.ФормыСообщенийКК.ОПроведенииКД_CписаниеЦБ Тогда
		Реквизиты.Вставить("СпецифичныеКопируемые", "ДатаКДРеестр, ДатаКДНРД, ПризнакОбязательностиКД");
		
	ИначеЕсли Перечисления.ФормыСообщенийКК.ЭтоФормаСвязаннаяСВыплатой(ФормаСообщенияКК) Тогда
		Реквизиты.Вставить("СпецифичныеКопируемые", "ДатаКДПлан, ПризнакОбязательностиКД, ХДивДата, СтавкаНалога,
			|ЧистаяСтавкаДивидендов, ВалютаЧистойСтавкиДивидендов, ВыплатаНа1ЦБ, ВалютаПлатежа, Период,
			|ПогашаемаяЧасть, РазмерПогашаемойЧасти, СтавкаКупонногоДоходаГодовых, КоличествоДнейВКупонномПериоде");
		Реквизиты.Вставить("Произвольные", "ДатаНачалаПериода, ДатаОкончанияПериода");
			
	ИначеЕсли ФормаСообщенияКК = Перечисления.ФормыСообщенийКК.ОПроведенииКД_ПодтверждениеОсвобожденияОтНалога Тогда
		Реквизиты.Вставить("СпецифичныеКопируемые", "ДатаКДПлан");
		Реквизиты.Вставить("Произвольные", "ДатаОкончанияПриемаФормыW8, ДатаОкончанияПриемаПоручений1_5,
			|ДатаОкончанияПриемаПоручений1_10");
			
	ИначеЕсли Перечисления.ФормыСообщенийКК.ЭтоФормаСвязаннаяСвозвратомЧастиНалога(ФормаСообщенияКК) Тогда
		Реквизиты.Вставить("СпецифичныеКопируемые",	"ДатаОкончанияПриемаИнструкцийНРД,
			|ДатаОкончанияПриемаИнструкцийВТБКБ, ДатаКДПлан");
			
	ИначеЕсли ФормаСообщенияКК = Перечисления.ФормыСообщенийКК.ОПроведенииКД_РаскрытиеИнформации Тогда
		Реквизиты.Вставить("СпецифичныеКопируемые", "ВалютаПлатежа, ДатаОкончанияПриемаИнструкцийВТБКБ");
		Реквизиты.Вставить("Произвольные", "ДатаНачалаПериода, ДатаОкончанияПериода");
			
	ИначеЕсли ФормаСообщенияКК = Перечисления.ФормыСообщенийКК.ОПроведенииКД_ПодтверждениеОсвобожденияОтНалогаПоЦБНеПодпадающимПодНалоговоеРегулированиеСША Тогда
		Реквизиты.Вставить("СпецифичныеКопируемые",	"ДатаОкончанияПриемаИнструкцийНРД, ДатаОкончанияПриемаИнструкцийВТБКБ");
		
	ИначеЕсли Перечисления.ФормыСообщенийКК.ЭтоФормаСвязаннаяСПодтверждениемОсвобожденияОтНалога(ФормаСообщенияКК) Тогда
		Реквизиты.Вставить("СпецифичныеКопируемые", "ДатаКДПлан, ДатаОкончанияПриемаИнструкцийНРД, ДатаОкончанияПриемаИнструкцийВТБКБ");
		Реквизиты.Вставить("Произвольные", "ДатаОкончанияПриемаФормыW8, ДатаОкончанияПриемаПоручений1_5, ДатаОкончанияПриемаПоручений1_10");
	КонецЕсли;
		
	Возврат Реквизиты;
КонецФункции

Функция ХарактеристикиЦБ(ЦеннаяБумага1, ЦеннаяБумага2) Экспорт
	Если ЗначениеЗаполнено(ЦеннаяБумага1)
		И ЗначениеЗаполнено(ЦеннаяБумага1.ТипЦБ)
		И ЗначениеЗаполнено(ЦеннаяБумага1.ISIN) Тогда
		Возврат СокрЛП(ЦеннаяБумага1.ТипЦБ) + " " + СокрЛП(ЦеннаяБумага1.ISIN)
				+ ?(ЗначениеЗаполнено(ЦеннаяБумага2), " / " + СокрЛП(ЦеннаяБумага2.ТипЦБ) + " "
					+ СокрЛП(ЦеннаяБумага2.ISIN), "");
	Иначе
		Возврат "Данные отсутствуют";
	КонецЕсли;
КонецФункции

Функция ПодписьСообщения(ДатаКонтактнойИнформации) Экспорт
	Организация = Константы.ОрганизацияПоУмолчанию.Получить();
	Отбор = Новый Структура;
	Отбор.Вставить("Объект",	Организация);
	Отбор.Вставить("Тип",		Перечисления.ТипыКонтактнойИнформации.АдресЭлектроннойПочты);
	Отбор.Вставить("Вид",		Справочники.ВидыКонтактнойИнформации.EmailКлиентскихМенеджеровОрганизации);	
	Адреса = РегистрыСведений.КонтактнаяИнформация.СрезПоследних(ДатаКонтактнойИнформации, Отбор);
	Если Адреса.Количество() > 0 Тогда
		ЭлектроннаяПочта = СокрЛП(Адреса[0].Представление);
	КонецЕсли;
	
	Отбор.Вставить("Тип",	Перечисления.ТипыКонтактнойИнформации.Телефон);
	Отбор.Вставить("Вид",	Справочники.ВидыКонтактнойИнформации.ТелефонКлиентскихМенеджеровОрганизации);	
	Телефоны = РегистрыСведений.КонтактнаяИнформация.СрезПоследних(ДатаКонтактнойИнформации, Отбор);
	Если Телефоны.Количество() > 0 Тогда
		Телефон = СокрЛП(Телефоны[0].Представление);
	Иначе
		Телефон = "НЕ УКАЗАН";
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "Внимание! Не указан телефон клиентских менеджеров " + Организация
			+ " на " + ДатаКонтактнойИнформации;
		Сообщение.Сообщить();
	КонецЕсли;
	
	Шаблон = "По всем вопросам, связанным с настоящим сообщением, Вы можете обращаться к Вашему клиентскому "
		+ "менеджеру по телефону: %2";
		
	Если ЗначениеЗаполнено(ЭлектроннаяПочта) Тогда			
		Шаблон = Шаблон + "; e-mail: %1.";
		Шаблон = СтрЗаменить(Шаблон, "%1", ЭлектроннаяПочта);
	Иначе
		Шаблон = Шаблон + ".";
	КонецЕсли;	

	Шаблон = СтрЗаменить(Шаблон, "%2", Телефон);
	
	Возврат Шаблон;
КонецФункции

Функция УбратьЛишниеСимволы(Текст) Экспорт
	Строки = СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(Текст, Символы.ПС);	
	Результат = "";
	Для Каждого Строка Из Строки Цикл
		Если ЗначениеЗаполнено(Строка) Тогда
			Результат = Результат + ?(ЗначениеЗаполнено(Результат), Символы.ПС, "") + СокрЛП(Строка);
		КонецЕсли;
	КонецЦикла;
	Возврат Результат;
КонецФункции

