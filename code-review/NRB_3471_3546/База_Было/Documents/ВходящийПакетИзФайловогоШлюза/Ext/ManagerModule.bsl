Функция НайтиДокумент(Параметры) Экспорт
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
	|	ВходящийПакетИзФайловогоШлюза.Ссылка
	|ИЗ
	|	Документ.ВходящийПакетИзФайловогоШлюза КАК ВходящийПакетИзФайловогоШлюза
	|ГДЕ Истина";
	
	НомерПараметра = 0;
	Для каждого Параметр Из Параметры Цикл
		Если ТипЗнч(Параметр.Значение) = Тип("Строка") Тогда
			Запрос.Текст = Запрос.Текст + " И ВЫРАЗИТЬ(" + Параметр.Ключ + " КАК Строка(1000)) = &Параметр" + НомерПараметра;
		Иначе
			Запрос.Текст = Запрос.Текст + " И " + Параметр.Ключ + " = &Параметр" + НомерПараметра;
		КонецЕсли; 
		
		Запрос.УстановитьПараметр("Параметр" + НомерПараметра, Параметр.Значение);
		
		НомерПараметра = НомерПараметра + 1;
	КонецЦикла; 
	
	Результат = Запрос.Выполнить();
	Выборка = Результат.Выбрать();
	
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Ссылка;
	Иначе
		Возврат Документы.ВходящийПакетИзФайловогоШлюза.ПустаяСсылка();
	КонецЕсли;
	 
КонецФункции // ()

# Область CSDR_ВходящийПакетИзФайловогоШлюза

// Функция - Дополнить строку пробелом - Дополняет переданную в качестве первого параметра строку символами слева\справа до заданной длины и возвращает ее
//                                       Разрешено в качестве символа дополнения использование любого символа
// Параметры:
//  Строка		 - 	 - - исходная строка, которую необходимо дополнить символами до заданной длины
//  ДлинаСтроки	 - 	 - - требуемая конечная длина строки
//  Символ		 - 	 - - (необязательный) значение символа, которым необходимо дополнить строку
//  Режим		 - 	 - - (необязательный) [Слева|Справа] режим добавления символов к исходной строке: слева или справа
// 
// Возвращаемое значение: Строка - строка, дополненная символами слева или справа
//   - 
//
Функция ДополнитьСтрокуПроизвольнымСимволом(Знач Строка, Знач ДлинаСтроки, Знач Символ = " ", Знач Режим = "Справа") Экспорт
	
	// длина символа не должна превышать единицы
	
	Символ = Лев(Символ, 1);
	
	// удаляем крайние пробелы слева и справа строки
	
	Строка = СокрЛП(Строка);
	
	КоличествоСимволовНадоДобавить = ДлинаСтроки - СтрДлина(Строка);
	
	Если КоличествоСимволовНадоДобавить > 0 Тогда
		
		СтрокаДляДобавления = СтрСоединить(новый массив(КоличествоСимволовНадоДобавить + 1), Символ);
		
		Если ВРег(Режим) = "СЛЕВА" Тогда
			
			Строка = СтрокаДляДобавления + Строка;
			
		ИначеЕсли ВРег(Режим) = "СПРАВА" Тогда
			
			Строка = Строка + СтрокаДляДобавления;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Строка;
	
КонецФункции

// Функция - Получить значение по имени
//
// Параметры:
//  СодержимоеФайла	 - 	 - Таблица документа ВходящийПакетИзФайловогоШлюза
//  ИмяЗначения		 - 	 - Имя значения (соотвествует имени в поле MESS_ABOUT)
// 
// Возвращаемое значение: Значение из строки следующей за найденной
//   - 
//
Функция ПолучитьЗначениеПоИмени(СодержимоеФайла,ИмяЗначения)
	СтруктураПоиска = Новый Структура("Значение",ИмяЗначения);
	МассивНайденныхВФайлеСтрок = СодержимоеФайла.НайтиСтроки(СтруктураПоиска);
	Если МассивНайденныхВФайлеСтрок.Количество() = 0 Тогда
		Возврат "";
	Иначе
		Возврат СокрЛП(СодержимоеФайла[МассивНайденныхВФайлеСтрок[0].НомерСтроки].Значение);
	КонецЕсли;
КонецФункции

// Функция - Это штрафы премии CSDR
//
// Параметры:
//  Ссылка		 - 	 - 
//  ВидОтвета	 - 	 - 
// 
// Возвращаемое значение: Является ли этот входящий пакет пакетом "штафов\ премий НРД"  (Истина\Ложь) но для вида ответа "Номер" (Номер\пусто)
//   - 
//
Функция ЭтоШтрафыПремииCSDR(Ссылка , ВидОтвета = "Номер") Экспорт
	
	СтруктураПоиска = Новый Структура("Значение",ДополнитьСтрокуПроизвольнымСимволом("штрафе/премии, выставленном ICSD по поручению",254," ","Справа"));
	МассивНайденныхВФайлеСтрокШтрафовПремий = Ссылка.СодержимоеФайла.НайтиСтроки(СтруктураПоиска);
	
	Если МассивНайденныхВФайлеСтрокШтрафовПремий.Количество()>0 Тогда
		Если ВидОтвета = "Номер" Тогда
			Результат = Ссылка.Номер;
		Иначе
			Результат = Истина;
		КонецЕсли;
	Иначе
		Если ВидОтвета = "Номер" Тогда
			Результат = "";
		Иначе
			Результат = Ложь;
		КонецЕсли;
	КонецЕсли;
	
	Возврат Результат;
КонецФункции

// Функция - Создать пустую структуру штрафы премии CSDR для ИЦ
// 
// Возвращаемое значение: Структура для использования в функции ШтрафыПремииCSDRВходящегоПакета
//   - 
//
Функция НовоеОписаниеШтрафаПремииCSDRДляИЦ()
	СтруктураРезультата = Новый Структура();
	СтруктураРезультата.Вставить("НомерВБазеДЕПО","");
	СтруктураРезультата.Вставить("ВходящийНомер","");
	СтруктураРезультата.Вставить("ВходящаяДатаОтчетаНРД",Дата(1,1,1));
	СтруктураРезультата.Вставить("ДокументОснование",Новый Структура("РегистрационныйНомерНРД,НомерПорученияВВыгрузкеВНРД","",""));   
	// РегистрационныйНомерНРД - это поле из файла DBF MESS_ABOUT, НомерПорученияВВыгрузкеВНРД - это поле из ДокументОснование.Номер
	тзШтрафыПремии = Новый ТаблицаЗначений;
	тзШтрафыПремии.Колонки.Добавить("Референс", Новый ОписаниеТипов("Строка"));
	тзШтрафыПремии.Колонки.Добавить("Признак", Новый ОписаниеТипов("Строка"));
	тзШтрафыПремии.Колонки.Добавить("ДатаНачисления", Новый ОписаниеТипов("Дата"));
	тзШтрафыПремии.Колонки.Добавить("ДатаФормирования", Новый ОписаниеТипов("Дата"));
	тзШтрафыПремии.Колонки.Добавить("ПредыдущийРеференс", Новый ОписаниеТипов("Строка"));
	тзШтрафыПремии.Колонки.Добавить("Тип", Новый ОписаниеТипов("Строка"));
	тзШтрафыПремии.Колонки.Добавить("Статус", Новый ОписаниеТипов("Строка"));
	тзШтрафыПремии.Колонки.Добавить("Причина", Новый ОписаниеТипов("Строка"));
	
	тзШтрафыПремии.Колонки.Добавить("Сумма", Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(15,2)));
	тзШтрафыПремии.Колонки.Добавить("Валюта", Новый ОписаниеТипов("Строка"));
	тзШтрафыПремии.Колонки.Добавить("КоличествоДней", Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(3,0)));
	тзШтрафыПремии.Колонки.Добавить("Ставка", Новый ОписаниеТипов("Строка"));
	
	СтруктураРезультата.Вставить("ШтрафыПремии",тзШтрафыПремии);
	
	Возврат СтруктураРезультата;
КонецФункции

// Процедура - Заполнить данные таблицы CSDR
//
// Параметры:
//  СодержимоеФайла		 - 	 - Исходная таблица документа ВходящийПакетИзФайловогоШлюза
//  КвоДок				 - 	 - Количество искомых строк
//  ИмяЗначения			 - 	 - Имя исходного реквизита
//  ТаблицаРезультата	 - 	 - Результирующая таблица
//  ИмяКолонки			 - 	 - Имя выходного реквизита
//  ТипКолонки			 - 	 - Тип выходного реквизита
//
Процедура ЗаполнитьДанныеТаблицыCSDR(СодержимоеФайла, КвоСтрок, ИмяЗначения, ТаблицаРезультата, ИмяКолонки, ТипКолонки="Строка")
	Если КвоСтрок = 0 Тогда
		Возврат;
	КонецЕсли;
	СтруктураПоиска = Новый Структура("Значение",ИмяЗначения);
	МассивНайденныхВФайлеСтрок = СодержимоеФайла.НайтиСтроки(СтруктураПоиска);
	КвоНайденныхСтрок = МассивНайденныхВФайлеСтрок.Количество();
	Коэф = КвоНайденныхСтрок / КвоСтрок; // 1 - норма.. если например 3 - то по 3 одинаковых строки, и брать только 1-ую из них
	Инд=0;
	ТекНомерСтроки=0;
	Для каждого СтрокаФайла из МассивНайденныхВФайлеСтрок Цикл
		ТекНомерСтроки = ТекНомерСтроки + 1;
		ТекНомерСтрокиСУчетомКоэф = (ТекНомерСтроки-1)/Коэф;
		Если ТекНомерСтрокиСУчетомКоэф <> Цел(ТекНомерСтрокиСУчетомКоэф) Тогда
			Продолжить;
		КонецЕсли;
		
		СтрокаРезультата = ТаблицаРезультата[Инд];
		НайденноеЗначение = СокрЛП(СодержимоеФайла[СтрокаФайла.НомерСтроки].Значение);
		Если      ТипКолонки="Строка" Тогда
			Если НЕ ЗначениеЗаполнено(СтрокаРезультата[ИмяКолонки]) Тогда
				СтрокаРезультата[ИмяКолонки] = НайденноеЗначение;
			КонецЕсли;
		ИначеЕсли ТипКолонки="Дата" Тогда
			Если СтрДлина(НайденноеЗначение) <= 10 Тогда
				Если СтрДлина(НайденноеЗначение) = 0 Тогда
					СтрокаРезультата[ИмяКолонки] = Дата(1,1,1);
				Иначе
					СтрокаРезультата[ИмяКолонки] = Дата(НайденноеЗначение + " 00:00:00");
				КонецЕсли;
			Иначе
				СтрокаРезультата[ИмяКолонки] = Дата(НайденноеЗначение);
			КонецЕсли;
		ИначеЕсли ТипКолонки="Число" Тогда
			Если СтрДлина(НайденноеЗначение) = 0 Тогда
				СтрокаРезультата[ИмяКолонки] = 0 ;
			Иначе
				СтрокаРезультата[ИмяКолонки] = СтроковыеФункцииКлиентСервер.СтрокаВЧисло(НайденноеЗначение);
			КонецЕсли;
		ИначеЕсли ТипКолонки="CSDR_Статус" Тогда // Исключение
			Если СтрДлина(НайденноеЗначение) = 0 Тогда
				СтрокаРезультата["Причина"]="";
				СтрокаРезультата["Статус"]="";
			Иначе
				ПозицияРазделителя = СтрНайти(НайденноеЗначение," ");
				Если ПозицияРазделителя = 0 Тогда
					СтрокаРезультата["Причина"] =НайденноеЗначение;
					СтрокаРезультата["Статус"]="";
				иначе
					СтрокаРезультата["Причина"] = Лев(НайденноеЗначение,ПозицияРазделителя-1);
					ПозицияАктивности = СтрНайти(НайденноеЗначение,"активный ");
					Если ПозицияАктивности>0 Тогда
						СтрокаРезультата["Статус"]="Активный";
					Иначе
						СтрокаРезультата["Статус"]="Исключенный";
					КонецЕсли;
				КонецЕсли;
			КонецЕсли;
		ИначеЕсли ТипКолонки="CSDR_Причина" Тогда // Исключение
			Если СтрДлина(НайденноеЗначение) <> 0 Тогда
				ПозицияРазделителя = СтрНайти(НайденноеЗначение," ");
				Если ПозицияРазделителя = 0 Тогда
					СтрокаРезультата["Причина"] =НайденноеЗначение;
				иначе
					СтрокаРезультата["Причина"] = Лев(НайденноеЗначение,ПозицияРазделителя-1);
				КонецЕсли;
			КонецЕсли;
		ИначеЕсли ТипКолонки="CSDR_Сумма" Тогда // Исключение
			Если СтрДлина(НайденноеЗначение) = 0 Тогда
				СтрокаРезультата["Сумма"]=0;
				СтрокаРезультата["Валюта"]="SUR";
			Иначе
				ПозицияРазделителя = СтрНайти(НайденноеЗначение," ");
				Если ПозицияРазделителя = 0 Тогда
					Попытка
						СтрокаРезультата["Сумма"] = СтроковыеФункцииКлиентСервер.СтрокаВЧисло(НайденноеЗначение);
						СтрокаРезультата["Валюта"]= "SUR";
					исключение
						СтрокаРезультата["Сумма"] = 0;
						СтрокаРезультата["Валюта"]= НайденноеЗначение;
					КонецПопытки;
				иначе
					СтрокаРезультата["Сумма"] = СтроковыеФункцииКлиентСервер.СтрокаВЧисло(Лев(НайденноеЗначение,ПозицияРазделителя-1));
					СтрокаРезультата["Валюта"]= СокрЛП(Сред(НайденноеЗначение,ПозицияРазделителя+1));
				КонецЕсли;
			КонецЕсли;
		Иначе
			СтрокаРезультата[ИмяКолонки] = НайденноеЗначение;
		КонецЕсли;
		Инд=Инд+1;
	КонецЦикла;
КонецПроцедуры

// Функция - Получить структуру штрафы премии CSDR для ИЦ
//
// Параметры:
//  ВходящийПакет	 - 	 - ВходящийПакетИзФайловогоШлюза
// 
// Возвращаемое значение: Структура, содержащие данные выбранные из всего документа ВходящийПакетИзФайловогоШлюза для передачи в базу ИЦ в докумет Штрафы\премии CSDR
//   - 
//
Функция ШтрафыПремииCSDRВходящегоПакета(ВходящийПакет) Экспорт
	СодержимоеФайла = ВходящийПакет.СодержимоеФайла;
	ШтрафПремияCSDR = НовоеОписаниеШтрафаПремииCSDRДляИЦ();
	
	СтруктураПоиска = Новый Структура("Значение", ДополнитьСтрокуПроизвольнымСимволом("Рег. № поручения", 70, " ", "Справа"));
	КоличествоШтрафовПремийВДокументе = СодержимоеФайла.НайтиСтроки(СтруктураПоиска).Количество();
	Если КоличествоШтрафовПремийВДокументе = 0 Тогда
		Возврат ШтрафПремияCSDR;
	КонецЕсли;
	Для НомерСтрокиШтрафаПремии = 1 по КоличествоШтрафовПремийВДокументе Цикл
		ШтрафПремияCSDR.ШтрафыПремии.Добавить();
	КонецЦикла;
	
	ШтрафПремияCSDR.НомерВБазеДЕПО         = ВходящийПакет.Номер;
	ШтрафПремияCSDR.ВходящийНомер          = ВходящийПакет.НомерВходящегоДокумента;
	ШтрафПремияCSDR.ВходящаяДатаОтчетаНРД  = ВходящийПакет.ДатаВходящегоДокумента;
	ШтрафПремияCSDR.ДокументОснование.РегистрационныйНомерНРД = 
		ПолучитьЗначениеПоИмени(СодержимоеФайла, ДополнитьСтрокуПроизвольнымСимволом("Рег. № поручения", 70, " ", "Справа"));
	ШтрафПремияCSDR.ДокументОснование.НомерПорученияВВыгрузкеВНРД = ВходящийПакет.ДокументОснование.Номер;
	
	ЗаполнитьДанныеТаблицыCSDR(СодержимоеФайла, КоличествоШтрафовПремийВДокументе,
		ДополнитьСтрокуПроизвольнымСимволом("Референс штрафа/премии", 70, " ", "Справа"), ШтрафПремияCSDR.ШтрафыПремии, "Референс", "Строка");
	ЗаполнитьДанныеТаблицыCSDR(СодержимоеФайла, КоличествоШтрафовПремийВДокументе,
		ДополнитьСтрокуПроизвольнымСимволом("Признак штраф/премия", 70, " ", "Справа"), ШтрафПремияCSDR.ШтрафыПремии, "Признак", "Строка");
	ЗаполнитьДанныеТаблицыCSDR(СодержимоеФайла, КоличествоШтрафовПремийВДокументе,
		ДополнитьСтрокуПроизвольнымСимволом("Дата штрафа/премии", 70, " ", "Справа"), ШтрафПремияCSDR.ШтрафыПремии, "ДатаНачисления", "Дата");
	ЗаполнитьДанныеТаблицыCSDR(СодержимоеФайла, КоличествоШтрафовПремийВДокументе,
		ДополнитьСтрокуПроизвольнымСимволом("Дата формирования", 70, " ", "Справа"), ШтрафПремияCSDR.ШтрафыПремии, "ДатаФормирования", "Дата");
	ЗаполнитьДанныеТаблицыCSDR(СодержимоеФайла, КоличествоШтрафовПремийВДокументе,
		ДополнитьСтрокуПроизвольнымСимволом("Предыдущий референс штрафа/премии", 70, " ", "Справа"), ШтрафПремияCSDR.ШтрафыПремии, "ПредыдущийРеференс", "Строка");
	ЗаполнитьДанныеТаблицыCSDR(СодержимоеФайла, КоличествоШтрафовПремийВДокументе,
		ДополнитьСтрокуПроизвольнымСимволом("Тип штрафа/премии", 70, " ", "Справа"), ШтрафПремияCSDR.ШтрафыПремии, "Тип", "Строка");
	
	ЗаполнитьДанныеТаблицыCSDR(СодержимоеФайла, КоличествоШтрафовПремийВДокументе,
