
Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)

	ДополнительныеСвойства.Вставить("ЭтоНовый", НЕ ЗначениеЗаполнено(Ссылка));
	Если ДополнительныеСвойства.ЭтоНовый Тогда
		ЗаполнитьКодОперации();
	КонецЕсли;
	
КонецПроцедуры

Процедура ПриЗаписи(Отказ)
	
	Если ДополнительныеСвойства.ЭтоНовый Тогда
		Запрос = Новый Запрос(ТекстЗапросаОбработанныйВходящийПакетИзФайловогоШлюза());
		Запрос.УстановитьПараметр("ПолныйПуть", ПолныйПуть);
		Запрос.УстановитьПараметр("Ссылка", Ссылка);
		Запрос.УстановитьПараметр("НачалоТекущегоГода",НачалоГода(ТекущаяДата()));
		Запрос.УстановитьПараметр("ДокументОснование",ДокументОснование);
		Выборка = Запрос.Выполнить().Выбрать();
		Если Выборка.Следующий() Тогда
			ЗаписьЖурналаРегистрации("Запись нового входящего пакета ФШ", УровеньЖурналаРегистрации.Предупреждение,
				Метаданные.Документы.ВходящийПакетИзФайловогоШлюза, Выборка.ВходящийПакет,
				"Входящий пакет не записан, т.к. обнаружен обработанный документ с таким же полным путем и документом-основанием: " + ПолныйПуть);
			Отказ = Истина;
		КонецЕсли;
		
		Если НЕ Отказ и (СокрЛП(КодОперации) = "40" или СокрЛП(КодОперации) = "41") Тогда
			ЗарегистрироватьВПланеОбмена();
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

Функция ТекстЗапросаОбработанныйВходящийПакетИзФайловогоШлюза()
	
	Возврат
	"ВЫБРАТЬ
	|	ВходящийПакетФШ.Ссылка КАК ВходящийПакет
	|ИЗ
	|	Документ.ВходящийПакетИзФайловогоШлюза КАК ВходящийПакетФШ
	|ГДЕ
	|	(ВЫРАЗИТЬ(ВходящийПакетФШ.ПолныйПуть КАК СТРОКА(1024))) = &ПолныйПуть
	|	И ВходящийПакетФШ.Обработан
	|	И ВходящийПакетФШ.Ссылка <> &Ссылка
	|	И ВходящийПакетФШ.Дата >= &НачалоТекущегоГода
	|	И ВходящийПакетФШ.ДокументОснование = &ДокументОснование
	|
	|ДЛЯ ИЗМЕНЕНИЯ
	|	Документ.ВходящийПакетИзФайловогоШлюза";
	
КонецФункции

Процедура ЗаполнитьКодОперации()
	
	СтрокаДанных = СодержимоеФайла.Найти("ORD_TYPE_I", "Элемент");
	Если Не СтрокаДанных = Неопределено Тогда
		КодОперации = СтрокаДанных.Значение;
	КонецЕсли;
	
КонецПроцедуры

Процедура ЗарегистрироватьВПланеОбмена()
	
	ПланыОбмена.ЗарегистрироватьИзменения(ПланыОбмена.ВыпискиПоЦеннымБумагам.НайтиПоКоду("000"), Ссылка);
	
КонецПроцедуры

Процедура ОбработкаПроведения(Отказ, Режим)
	
	Если СокрЛП(КодОперации) = "40" Тогда
		
		Записи = ПолучитьТаблицуДВижений();
		Движения.ОстаткиПоЦеннымБумагамНРД.Загрузить(Записи);
		
	КонецЕсли;
	
КонецПроцедуры

Функция ПолучитьТаблицуДВижений()
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	SECTION_CO.НомерСтрокиФайла КАК НомерСтрокиФайла,
		|	DEPO_ACC_C.Значение КАК DEPO_ACC_C,
		|	SECTION_CO.Значение КАК SECTION_CO,
		|	DEPO_ACC_C.Ссылка КАК Ссылка,
		|	END_DATE.Значение КАК Дата
		|ПОМЕСТИТЬ вт
		|ИЗ
		|	Документ.ВходящийПакетИзФайловогоШлюза.СодержимоеФайла КАК SECTION_CO,
		|	Документ.ВходящийПакетИзФайловогоШлюза.СодержимоеФайла КАК DEPO_ACC_C,
		|	Документ.ВходящийПакетИзФайловогоШлюза.СодержимоеФайла КАК END_DATE
		|ГДЕ
		|	SECTION_CO.Ссылка = &Ссылка
		|	И SECTION_CO.Элемент = ""SECTION_CO""
		|	И DEPO_ACC_C.Элемент = ""DEPO_ACC_C""
		|	И DEPO_ACC_C.Ссылка = &Ссылка
		|	И DEPO_ACC_C.НомерСтрокиФайла = 1
		|	И END_DATE.Ссылка = &Ссылка
		|	И END_DATE.Элемент = ""END_DATE""
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	вт.Дата КАК Дата,
		|	вт.DEPO_ACC_C КАК DEPO_ACC_C,
		|	вт.SECTION_CO КАК SECTION_CO,
		|	SECURITY_C.Значение КАК SECURITY_C,
		|	SEQ_AMO.Значение КАК SEQ_AMO
		|ПОМЕСТИТЬ ВходящиеДанные
		|ИЗ
		|	вт КАК вт
		|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ВходящийПакетИзФайловогоШлюза.СодержимоеФайла КАК SEQ_AMO
		|		ПО вт.Ссылка = SEQ_AMO.Ссылка
		|			И вт.НомерСтрокиФайла = SEQ_AMO.НомерСтрокиФайла
		|			И (SEQ_AMO.Элемент = ""SEQ_AMO"")
		|			И (SEQ_AMO.ИмяФайла = ""sttds.dbf"")
		|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ВходящийПакетИзФайловогоШлюза.СодержимоеФайла КАК SECURITY_C
		|		ПО вт.НомерСтрокиФайла = SECURITY_C.НомерСтрокиФайла
		|			И вт.Ссылка = SECURITY_C.Ссылка
		|			И (SECURITY_C.Элемент = ""SECURITY_C"")
		|			И (SECURITY_C.ИмяФайла = ""sttds.dbf"")
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВходящиеДанные.Дата КАК Дата,
		|	СчетаДепоМХ.Ссылка КАК СчетДепоМХ,
		|	РазделыСчетаДепоМХ.Ссылка КАК РазделСчетаДепоМХ,
		|	КодыЗагрузки.Владелец КАК ЦеннаяБумага,
		|	ВходящиеДанные.SEQ_AMO КАК SEQ_AMO
		|ИЗ
		|	ВходящиеДанные КАК ВходящиеДанные
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.СчетаДепоМХ КАК СчетаДепоМХ
		|		ПО ВходящиеДанные.DEPO_ACC_C = СчетаДепоМХ.Код
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.РазделыСчетаДепоМХ КАК РазделыСчетаДепоМХ
		|		ПО ВходящиеДанные.DEPO_ACC_C = РазделыСчетаДепоМХ.Владелец.Код
		|			И ВходящиеДанные.SECTION_CO = РазделыСчетаДепоМХ.Код
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.КодыЗагрузки КАК КодыЗагрузки
		|		ПО ВходящиеДанные.SECURITY_C = КодыЗагрузки.Код
		|ГДЕ
		|	(КодыЗагрузки.ДатаОкончанияДействия > &Дата
		|			ИЛИ КодыЗагрузки.ДатаОкончанияДействия = ДАТАВРЕМЯ(1, 1, 1))
		|	И НЕ КодыЗагрузки.ПометкаУдаления
		|	И КодыЗагрузки.Биржа = &Биржа
		|
		|СГРУППИРОВАТЬ ПО
		|	СчетаДепоМХ.Ссылка,
		|	ВходящиеДанные.Дата,
		|	РазделыСчетаДепоМХ.Ссылка,
		|	ВходящиеДанные.SEQ_AMO,
		|	КодыЗагрузки.Владелец";
	
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	Запрос.УстановитьПараметр("Дата", ДатаВходящегоДокумента);
	Запрос.УстановитьПараметр("Биржа", Справочники.КлассификаторыЗагрузки.НДЦ());
	
	РезультатЗапроса = Запрос.Выполнить().Выгрузить();
	РезультатЗапроса.Колонки.Добавить("Количество");
	
	Для каждого стр из РезультатЗапроса Цикл
		
		Стр.Количество = Число(СтрЗаменить(Стр.SEQ_AMO," ","")); 
		
	КонецЦикла;
	
	РезультатЗапроса.Свернуть("Дата,СчетДепоМХ,РазделСчетаДепоМХ,ЦеннаяБумага","Количество");
	
	Возврат РезультатЗапроса;
	
КонецФункции