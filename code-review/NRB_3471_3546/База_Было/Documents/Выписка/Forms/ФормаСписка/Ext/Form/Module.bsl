#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ЖурналОтправлений(Команда)
	
	Если Элементы.Список.ТекущаяСтрока <> Неопределено Тогда
		
		ОтправленоВЭДО = ОбщегоНазначенияПовтИсп.ЗначениеГлобальногоПараметра("83.СводныеОтчетыВЭДОилиВKafka", 0) = 0;
		Если ОтправленоВЭДО Тогда
			ОтборПоДокументу = Новый Структура("Документ", Элементы.Список.ТекущиеДанные.Ссылка);
			ПараметрыФормы = Новый Структура("Отбор", ОтборПоДокументу);
			ИмяРегистра = "РегистрацияДокументовВЭДО";
			ОткрытьФорму("РегистрСведений." + ИмяРегистра + ".ФормаСписка", ПараметрыФормы, ЭтаФорма, УникальныйИдентификатор);
		Иначе
			Элементы.Список.Обновить();
			ОтборПоИдентификатору = Новый Структура("Идентификатор", Элементы.Список.ТекущиеДанные.ИсходящийНомер);
			ПараметрыФормы = Новый Структура("Отбор", ОтборПоИдентификатору);
			ИмяРегистра = "ЖурналИсходящихСообщенийKafka";
			ОткрытьФорму("РегистрСведений." + ИмяРегистра + ".ФормаСписка", ПараметрыФормы, ЭтаФорма, УникальныйИдентификатор);
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти


