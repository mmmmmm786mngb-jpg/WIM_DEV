Процедура ПередУдалением(Отказ)
	Если ВыпискаУжеВыгруженаВСЭД() Тогда
		Отказ = Истина;
		Сообщение = Новый СообщениеПользователю();
		Сообщение.Текст = "Удаление выгруженной в ЭДО выписки невозможно. Документ: "+Ссылка;
		Сообщение.Сообщить();
	КонецЕсли;
КонецПроцедуры

Функция ВыпискаУжеВыгруженаВСЭД()
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	КОЛИЧЕСТВО(РегистрацияДокументовВЭДО.Документ) КАК КоличествоВыгруженныхДокументов
	|ИЗ
	|	РегистрСведений.РегистрацияДокументовВЭДО КАК РегистрацияДокументовВЭДО
	|ГДЕ
	|	ВЫРАЗИТЬ(РегистрацияДокументовВЭДО.Документ КАК Документ.Выписка) = &Ссылка
	|");
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.КоличествоВыгруженныхДокументов > 0;
	Иначе
		Возврат Ложь;
	КонецЕсли;
КонецФункции

Функция ФормироватьОперацииПоПоручениямНаОтчет(ДатаПоручения)
	Возврат ЗначениеЗаполнено(Константы.ДатаНачалаФормированияОперацийПоПоручениямНаОтчет.Получить())
		И НачалоДня(ДатаПоручения) >= НачалоДня(Константы.ДатаНачалаФормированияОперацийПоПоручениямНаОтчет.Получить());
КонецФункции

Функция ЗаполнитьВыпискуНаОснованииПорученияНаОтчет(Основание)
	Дата							= Основание.ДатаИсполненияПоручения;
	ДокументОснование 				= Основание.Ссылка;
	ВладелецСчета 					= Основание.СчетДепо.Владелец;
	СчетДепо						= Основание.СчетДепо;
	ДатаНачПериода					= Основание.ДатаНачПериода;
	Если Основание.ВидОперацииД = Перечисления.ВидыОтчетов.ВыпискаОСостоянииСчетаДЕПО Тогда
		ДатаКонПериода = Основание.ДатаНачПериода;
	Иначе
		ДатаКонПериода = Основание.ДатаКонПериода;
	КонецЕсли;
	МХУведомление					= Основание.МХДепонента;
	МХВыписка						= Основание.МХКонтрагент;
	ЭмитентУведомление				= Основание.ЭмитентУведомление;
	ЭмитентВыписка					= Основание.ЭмитентВыписка;
	ВидОтчета						= Основание.ВидОперацииД;
	ПозицияВыпискиОперационныйДень	= Основание.ПозицияВыпискиОперационныйДень;
	СпособОтправкиОтчета			= Основание.СпособОтправкиОтчета;
	ЦБУведомление					= Основание.ЦБУведомление;
	ЦБВыписка						= Основание.ЦБВыписка;
КонецФункции

Процедура ОбновитьДопИнформацию()
	
	Если НеОбновлятьДопИнформацию Тогда
		Возврат;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(ДокументОснование) Или Не ТипЗнч(ДокументОснование) = Тип("ДокументСсылка.Поручение") Тогда
		
		ДопИнформация = "";
		
		Возврат;
		
	КонецЕсли;
	
	ДопИнформация = Документы.Поручение.ОписаниеПараметровDVP3(ДокументОснование);
	
КонецПроцедуры