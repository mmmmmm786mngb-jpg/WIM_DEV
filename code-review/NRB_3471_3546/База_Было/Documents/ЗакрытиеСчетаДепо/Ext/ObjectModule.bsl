Процедура ОбработкаЗаполнения(Основание)
	Если Основание = Неопределено Тогда 
		Возврат;
	КонецЕсли;
		
	Если Не Основание.ВидОперацииД = Справочники.ВидыОпераций.ЗакрытиеСчетаДепо Тогда
		Проверка = Истина;
		Сообщить("На основании данного поручения нельзя вводить документ, т.к. вид операции не соответствует закрытию!!!");
		Возврат;
	КонецЕсли;
	
	Если НЕ Документы.ЗакрытиеСчетаДепо.НайтиПоРеквизиту("ДокументОснование",Основание).Пустая() Тогда
		Проверка = Истина;
		Сообщить("На основании данного поручения уже есть введенный документ!!!");
		Возврат;
	КонецЕсли;
	
	Если ТипЗнч(Основание) = Тип("ДокументСсылка.Поручение") Тогда
		Если Не ЗначениеЗаполнено(Основание.ДатаИсполненияПоручения) Тогда
			Проверка = Истина;
			Сообщить("В поручении не заполнена дата исполнения!!!");
			Возврат;
		КонецЕсли;
		Если Основание.ВидОперацииД = Справочники.ВидыОпераций.ЗакрытиеСчетаДепо Тогда 
			Дата				= Основание.ДатаИсполненияПоручения;
			ДокументОснование 	= Основание.Ссылка;
			ВладелецСчета 		= ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Основание.СчетДепо,"Владелец");
			СчетДепо			= Основание.СчетДепо;
			Автор				= ПараметрыСеанса.ТекущийПользователь;
			Комментарий 		= Основание.Комментарий;
		Иначе
			Проверка = Истина;
			Сообщить("На основании данного вида поручения нельзя создать документ Закрытие счета депо !!!");
			Возврат;	
		КонецЕсли;
	Иначе
		Проверка = Истина;
		Сообщить("Основанием не является поручение!!!");
		Возврат;	
	КонецЕсли;
КонецПроцедуры

Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
	Если ОбменДанными.Загрузка = Истина Тогда
		Возврат;
	КонецЕсли;
	УстановитьНовыйНомер();
КонецПроцедуры

Процедура ПриУстановкеНовогоНомера(СтандартнаяОбработка, Префикс)
	
	СтандартнаяОбработка = Ложь;
	
	Префикс = НумераторыОбъектов.ПолучитьПрефиксНомера(ЭтотОбъект);
	
	Номер = НумераторыОбъектов.ПолучитьНомерДокумента(ЭтотОбъект, Префикс);
	
КонецПроцедуры

Процедура ПриКопировании(ОбъектКопирования)
	ДокументОснование	= Документы.Поручение.ПустаяСсылка();
КонецПроцедуры

Функция ЕстьОткрытыеСчетаДепо()
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	СчетаДепо.Ссылка
	|ИЗ
	|	Справочник.СчетаДепо КАК СчетаДепо
	|ГДЕ
	|	НЕ СчетаДепо.ПометкаУдаления
	|	И СчетаДепо.Владелец = &Владелец
	|	И СчетаДепо.Ссылка <> &Ссылка
	|	И НЕ СчетаДепо.СтатусСчетаДепо = ЗНАЧЕНИЕ(Перечисление.СтатусыСчетовДепо.Закрыт)";

	Запрос.УстановитьПараметр("Владелец"		, СчетДепо.Владелец);
	Запрос.УстановитьПараметр("Ссылка"			, СчетДепо);
	
	Результат = Запрос.Выполнить();
	
	Если Результат.Пустой() Тогда
		Возврат Ложь;
	Иначе
		Возврат Истина;
	КонецЕсли;
КонецФункции

Функция ПолучитьОстаткиПоСчету()
	ГраницаПроверки	= Новый Граница(ЭтотОбъект.МоментВремени(), ВидГраницы.Исключая);
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	ОстаткиЦБОстатки.СчетДепо,
	|	ОстаткиЦБОстатки.РазделСчетаДепо,
	|	ОстаткиЦБОстатки.ЦБ,
	|	ОстаткиЦБОстатки.СчетДепоМХ,
	|	ОстаткиЦБОстатки.РазделСчетаДепоМХ,
	|	ОстаткиЦБОстатки.КоличествоОстаток
	|ИЗ
	|	РегистрНакопления.ОстаткиЦБ.Остатки(&Период, СчетДепо = &СчетДепо) КАК ОстаткиЦБОстатки");

	Запрос.УстановитьПараметр("Период"	, ГраницаПроверки);
	Запрос.УстановитьПараметр("СчетДепо", СчетДепо);
	
	Возврат Запрос.Выполнить().Выгрузить();
КонецФункции

Процедура ОбработкаПроведения(Отказ, Режим)
	Если СчетДепо.СтатусСчетаДепо	= Перечисления.СтатусыСчетовДепо.Закрыт Тогда
		ОбщегоНазначения.СообщитьОбОшибке("Данный Счет ДЕПО уже закрыт!!!", Отказ);
		Возврат;
	КонецЕсли;
	Договор = Справочники.ДоговорыКонтрагентов.НайтиПоКоду(Лев(СокрЛП(СчетДЕПО.Код),7));
	// Посчитаем параметры по услугам депозитария и сделаем движения	
	РасчетныеПараметры = РасчетТарифов.РасчетСтоимостиУслуги(
							Дата,
							Договор,
							Новый Структура("Операция, МестоХранения1, МестоХранения2",Справочники.ВидыОпераций.ЗакрытиеСчетаДепо,Неопределено,Неопределено));
							
	Если РасчетныеПараметры <> Неопределено Тогда
		Движение				= Движения.УслугиДепозитария.ДобавитьПриход();
		Движение.Период			= Дата;
		Движение.Инициатор		= Договор;
		Движение.Услуга			= РасчетныеПараметры.Услуга;
		Движение.СтавкаНДС		= Перечисления.СтавкиНДС.НДС18_118;
		Движение.Валюта			= РасчетныеПараметры.Валюта;
		Движение.Сумма			= РасчетныеПараметры.Сумма;
		Движение.СуммаВВалюте	= Конвертации.КонвертацияВалюты(Дата, Движение.Сумма, РасчетныеПараметры.Валюта);
		Движение.СуммаНДС		= РасчетТарифов.РТ_РасчетНДС(Движение.СтавкаНДС, Движение.Сумма);
		Движение.СуммаВсего		= РасчетТарифов.РТ_ОбщаяСумма(Движение.СтавкаНДС,Движение.Сумма,Движение.СуммаНДС);
		Движение.Сумма			= Движение.СуммаВсего - Движение.СуммаНДС;
		Движение.ТипТарифа		= РасчетныеПараметры.ТипТарифа;
		Движение.Тариф			= РасчетныеПараметры.Тариф;
	КонецЕсли;
	// Проверить возможность закрытия счета
	ОстаткиПоСчету	= ПолучитьОстаткиПоСчету();
	Если ОстаткиПоСчету.Количество()>0 Тогда
		Для Каждого Строка ИЗ ОстаткиПоСчету Цикл
			Сообщить(	"По закрываемому счету есть не нулевые остатки:
						| - Счет ДЕПО МХ: "+Строка.СчетДепоМХ+";
						| - Раздел счета ДЕПО МХ: "+Строка.РазделСчетаДепоМХ+";
						| - Счет ДЕПО: "+Строка.СчетДепо+";
						| - Раздел счета ДЕПО: "+Строка.РазделСчетаДепо+";
						| - Ценная бумага: "+Строка.ЦБ+";
						| - Остаток: "+Строка.КоличествоОстаток+".");
		КонецЦикла;
		Отказ	= Истина;
		Возврат;
	КонецЕсли;	
	// Закрываем счет
	СчетДепоОбъект 					 			= СчетДепо.ПолучитьОбъект();
	СчетДепоОбъект.СтатусСчетаДепо   			= Перечисления.СтатусыСчетовДепо.Закрыт;
	СчетДепоОбъект.ДатаЗакрытияСчета 			= Дата;
	СчетДепоОбъект.ОперацияЗакрытияСчетаДепо    = Ссылка;
	СчетДепоОбъект.Записать();
	//разделы счета депо
	Если  ТипЗнч(СчетДепо) = Тип("СправочникСсылка.СчетаДепо") Тогда
		ВыборкаРазделыСчетаДепо	=	Справочники.РазделыСчетаДепо.Выбрать(,СчетДепо);
		Пока	ВыборкаРазделыСчетаДепо.Следующий() Цикл
			Если ВыборкаРазделыСчетаДепо.СтатусСчетаДепо = Перечисления.СтатусыСчетовДепо.Закрыт Тогда
				Продолжить;
			КонецЕсли;
			РазделыСчетаДепоОбъект 					 = ВыборкаРазделыСчетаДепо.ПолучитьОбъект();
			РазделыСчетаДепоОбъект.СтатусСчетаДепо   = Перечисления.СтатусыСчетовДепо.Закрыт;
			РазделыСчетаДепоОбъект.ДатаЗакрытияСчета = Дата;
			РазделыСчетаДепоОбъект.Записать();
		КонецЦикла;	
	Иначе 
		ВыборкаРазделыСчетаДепо	=	Справочники.РазделыСчетаДепоМХ.Выбрать(,СчетДепо);
		Пока	ВыборкаРазделыСчетаДепо.Следующий() Цикл
			Если ВыборкаРазделыСчетаДепо.СтатусСчетаДепо = Перечисления.СтатусыСчетовДепо.Закрыт Тогда
				Продолжить;
			КонецЕсли;
			РазделыСчетаДепоОбъект 					 = ВыборкаРазделыСчетаДепо.ПолучитьОбъект();
			РазделыСчетаДепоОбъект.СтатусСчетаДепо   = Перечисления.СтатусыСчетовДепо.Закрыт;
			РазделыСчетаДепоОбъект.ДатаЗакрытияСчета = Дата;
			РазделыСчетаДепоОбъект.Записать();
		КонецЦикла;
	КонецЕсли;
	// Проверим все ли счета ДЕПО закрыты, если да, то закроем договор(а) контрагента
	Если ТипЗнч(СчетДепо) = Тип("СправочникСсылка.СчетаДепо") Тогда
		Если Не ЕстьОткрытыеСчетаДепо() Тогда
			ВыборкаДоговоров	= 	Справочники.ДоговорыКонтрагентов.Выбрать( ,СчетДепо.Владелец);
			Пока ВыборкаДоговоров.Следующий() Цикл
				ДоговороОбъект	= ВыборкаДоговоров.ПолучитьОбъект();
				ДоговороОбъект.ДатаОкончанияДействия	= Дата;
				ДоговороОбъект.Записать();
				РегистрыСведений.РегистрНазначенныхКомиссий.ЗакрытьКомиссииПоДоговору(ДоговороОбъект.Ссылка);
			КонецЦикла;	
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

Процедура ОтменаЗакрытияСчета()
	Если СчетДепо.СтатусСчетаДепо = Перечисления.СтатусыСчетовДепо.Закрыт И СчетДепо.ОперацияЗакрытияСчетаДепо = Ссылка Тогда
		//счет депо
		СчетДепоОбъект 					 			= СчетДепо.ПолучитьОбъект();
		СчетДепоОбъект.СтатусСчетаДепо   			= Перечисления.СтатусыСчетовДепо.Открыт;
		СчетДепоОбъект.ДатаЗакрытияСчета 			= Дата(1,1,1);
		СчетДепоОбъект.ОперацияЗакрытияСчетаДепо    = Документы.ЗакрытиеСчетаДепо.ПустаяСсылка();
		СчетДепоОбъект.Записать();
		//разделы счета депо
		Если  ТипЗнч(СчетДепо) = Тип("СправочникСсылка.СчетаДепо") Тогда
			ВыборкаРазделыСчетаДепо	=	Справочники.РазделыСчетаДепо.Выбрать(,СчетДепо);
			Пока ВыборкаРазделыСчетаДепо.Следующий() Цикл
				РазделыСчетаДепоОбъект 					 = ВыборкаРазделыСчетаДепо.ПолучитьОбъект();
				РазделыСчетаДепоОбъект.СтатусСчетаДепо   = Перечисления.СтатусыСчетовДепо.Открыт;
				РазделыСчетаДепоОбъект.ДатаЗакрытияСчета = Дата(1,1,1);
				РазделыСчетаДепоОбъект.Записать();
			КонецЦикла;	
		Иначе 
			ВыборкаРазделыСчетаДепо	=	Справочники.РазделыСчетаДепоМХ.Выбрать(,СчетДепо);
			Пока ВыборкаРазделыСчетаДепо.Следующий() Цикл
				РазделыСчетаДепоОбъект 					 = ВыборкаРазделыСчетаДепо.ПолучитьОбъект();
				РазделыСчетаДепоОбъект.СтатусСчетаДепо   = Перечисления.СтатусыСчетовДепо.Открыт;
				РазделыСчетаДепоОбъект.ДатаЗакрытияСчета = Дата(1,1,1);
				РазделыСчетаДепоОбъект.Записать();
			КонецЦикла;
		КонецЕсли;
		// откатываем закрытие договоров
		Если ТипЗнч(СчетДепо) = Тип("СправочникСсылка.СчетаДепо") Тогда
			ВыборкаДоговоров	= 	Справочники.ДоговорыКонтрагентов.Выбрать( ,СчетДепо.Владелец);
			Пока ВыборкаДоговоров.Следующий() Цикл
				ДоговороОбъект	= ВыборкаДоговоров.ПолучитьОбъект();
				ДоговороОбъект.ДатаОкончанияДействия	= Дата(1,1,1);
				ДоговороОбъект.Записать();
			КонецЦикла;	
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

Процедура ОбработкаУдаленияПроведения(Отказ)
	ОтменаЗакрытияСчета();
КонецПроцедуры

Процедура ПередУдалением(Отказ)
	ОтменаЗакрытияСчета();
КонецПроцедуры

