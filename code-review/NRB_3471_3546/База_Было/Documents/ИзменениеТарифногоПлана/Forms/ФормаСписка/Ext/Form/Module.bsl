
#Область СобытияФормы

// Процедура - При создании на сервере
//
// Параметры:
//  Отказ				 - Булево - Признак отказа от создания формы
//  СтандартнаяОбработка - Булево - Признак выполнения стандартной (системной) обработки события
//
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ОбщегоНазначения.ПриСозданииНаСервере(ЭтаФорма);
	
КонецПроцедуры

// Процедура - Обработка оповещения
//
// Параметры:
//  ИмяСобытия	 - Строка - Имя события
//  Параметр	 - Произвольный - Параметр, переданный в сообщении
//  Источник	 - Произвольный - Источник события, переданный в сообщении
//
&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	Если ИмяСобытия = "ИзменениеТарифногоПлана_ИзменилсяПризнакПроведения" Тогда
		
		Элементы.Список.Обновить();
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти


