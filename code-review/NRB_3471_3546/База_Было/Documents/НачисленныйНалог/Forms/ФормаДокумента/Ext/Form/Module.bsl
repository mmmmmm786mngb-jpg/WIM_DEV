
#Область ОбработчикиСобытийФормы

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	Если ОбщегоНазначенияПовтИсп.ЗначениеКонстанты("РасчетНалогаПоДивидендамВСистеме")
		Или ОбщегоНазначенияПовтИсп.ЗначениеКонстанты("РасчетНалогаПоКупонамВСистеме") Тогда
		
			Элементы.Документ1СИЦ.Видимость = Ложь;
		
	Иначе
		
			Элементы.ГруппаРасчеты.Видимость = Ложь;
		
			Элементы.Подтвержден.Видимость = Ложь;
		
			Элементы.ФормаРассчитатьНалог.Видимость = Ложь;
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Страна = СтранаЭмитента(Объект.Эмитент);
	УстановитьВидимостьИДоступностьЭлементов();
	
КонецПроцедуры

&НаСервере
Процедура ПриЧтенииНаСервере(ТекущийОбъект)
	Оболочки.ПриЧтенииНаСервереДокумента(ЭтотОбъект, ТекущийОбъект);
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ДатаПриИзменении(Элемент)
	
	ДатаПриИзмененииНаСервере();
	
КонецПроцедуры

&НаКлиенте
Процедура СтавкиНалогаУстановленыВРучномРежимеПриИзменении(Элемент)
	
	ДатаПриИзмененииНаСервере();
	
КонецПроцедуры

&НаКлиенте
Процедура СтавкаПриИзменении(Элемент)
	
	ДатаПриИзмененииНаСервере();
	
КонецПроцедуры

&НаКлиенте
Процедура СтавкаНалогаПовышеннаяПриИзменении(Элемент)
	
	ДатаПриИзмененииНаСервере();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура РассчитатьНалог(Команда)
	
	РассчитатьНалогНаСервере();
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Функция СтранаЭмитента(Эмитент)
	
	Возврат Справочники.КлассификаторСтранМира.СтранаЭмитента(Эмитент);
	
КонецФункции

&НаСервере
Процедура УстановитьВидимостьИДоступностьЭлементов()
	
	Если Объект.Проведен И Не Объект.Подтвержден Тогда
		РасхожденияПоПричинеНеподтвержденныхНалогов = Документы.НачисленныйНалог.ИнформацияОРанееНеподтвержденныхНалогах(Объект.Ссылка);
		ЕстьНеподтвержденныеНалоги = ЗначениеЗаполнено(РасхожденияПоПричинеНеподтвержденныхНалогов);
		РасхожденияПоПричинеПодтвержденныхНалогов = Документы.НачисленныйНалог.ИнформацияОПодтвержденныхНалогахПозжеТекущего(Объект.Ссылка);
		ЕстьПодтвержденныеНалоги = ЗначениеЗаполнено(РасхожденияПоПричинеПодтвержденныхНалогов);
		Если ЕстьНеподтвержденныеНалоги Тогда
			РасхожденияРасчетаНалога = РасхожденияПоПричинеНеподтвержденныхНалогов;
		ИначеЕсли ЕстьПодтвержденныеНалоги Тогда
			РасхожденияРасчетаНалога = РасхожденияПоПричинеПодтвержденныхНалогов;
		Иначе
			РасхожденияРасчетаНалога = Документы.НачисленныйНалог.ИнформацияОКорректностиРасчетаНалога(Объект.Ссылка, Объект);
		КонецЕсли;
		УстановитьВидимостьИДоступностьГруппыПересчетаНалога(РасхожденияРасчетаНалога, ЕстьНеподтвержденныеНалоги, ЕстьПодтвержденныеНалоги);
		Элементы.СтавкиНалогаУстановленыВРучномРежиме.Доступность = Истина;
	Иначе
		Элементы.ГруппаПересчета.Видимость = Ложь;
		Элементы.ПересчитатьНалог.Видимость = Ложь;
		Элементы.Подтвержден.Доступность = Истина;
		Элементы.ФормаРассчитатьНалог.Видимость = Истина;
		Элементы.СтавкиНалогаУстановленыВРучномРежиме.Доступность = Ложь;
	КонецЕсли;
	ДоходВРублях = (Объект.Валюта = ОбщегоНазначенияПовтИсп.ЗначениеКонстанты("ВалютаРегламентированногоУчета")
		Или Не ЗначениеЗаполнено(Объект.Валюта));
	Элементы.ГруппаНалогиСредняя.Видимость = Не ДоходВРублях;
	Элементы.СуммаЗачетНалогаВИностраннойЮрисдикции.Видимость = Не ДоходВРублях;
	Элементы.ДекорацияГруппаНалогиСредняя.Видимость = ДоходВРублях;
	Элементы.СуммаОкругленияВыплат.Видимость = Не ДоходВРублях И Объект.СуммаОкругленияВыплат <> 0;
	
	Элементы.Ставка.Доступность = Объект.СтавкиНалогаУстановленыВРучномРежиме;
	Элементы.СтавкаНалогаПовышенная.Доступность = Объект.СтавкиНалогаУстановленыВРучномРежиме;
	Если Объект.СтавкиНалогаУстановленыВРучномРежиме Тогда
		Элементы.Ставка.ЦветФона = WebЦвета.СветлоЗолотистый;
		Элементы.СтавкаНалогаПовышенная.ЦветФона = WebЦвета.СветлоЗолотистый;
	Иначе
		Элементы.Ставка.ЦветФона = WebЦвета.Белый;
		Элементы.СтавкаНалогаПовышенная.ЦветФона = WebЦвета.Белый;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура УстановитьВидимостьИДоступностьГруппыПересчетаНалога(РасхожденияРасчетаНалога,
	ЕстьНеподтвержденныеНалоги, ЕстьПодтвержденныеНалоги)
	
	Если ЗначениеЗаполнено(РасхожденияРасчетаНалога) Тогда
		Элементы.ГруппаПересчета.Показать();
		Элементы.ГруппаПересчета.ЦветТекстаЗаголовка = ЦветаСтиля.ЦветОсобогоТекста;
		Если ЕстьНеподтвержденныеНалоги Тогда
			Элементы.ГруппаПересчета.Заголовок = "По данному клиенту есть не подтвержденные выплаты в рамках налоговой базы";
			Элементы.ПересчитатьНалог.Видимость = Ложь;
			Элементы.ФормаРассчитатьНалог.Видимость = Ложь;
		ИначеЕсли ЕстьПодтвержденныеНалоги Тогда
			Элементы.ГруппаПересчета.Заголовок = "По данному клиенту есть подтвержденные выплаты (в будущем) в рамках налоговой базы";
			Элементы.ПересчитатьНалог.Видимость = Ложь;
			Элементы.ФормаРассчитатьНалог.Видимость = Ложь;
		Иначе
			Элементы.ГруппаПересчета.Заголовок = "Требуется пересчет налога";
			Элементы.ПересчитатьНалог.Видимость = Истина;
			Элементы.ФормаРассчитатьНалог.Видимость = Истина;
		КонецЕсли;
		Элементы.Подтвержден.Доступность = Ложь;
	Иначе
		Элементы.ГруппаПересчета.Скрыть();
		Элементы.ГруппаПересчета.ЦветТекстаЗаголовка = ЦветаСтиля.ЦветТекстаКнопки;
		Элементы.ГруппаПересчета.Заголовок = "Нет расхождений";
		Элементы.ПересчитатьНалог.Видимость = Ложь;
		Элементы.Подтвержден.Доступность = Истина;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура РассчитатьНалогНаСервере()
	
	ДокументОбъект = РеквизитФормыВЗначение("Объект");
	
	ДокументОбъект.Заполнить(Неопределено);
	
	ЗначениеВРеквизитФормы(ДокументОбъект, "Объект");
	
	УстановитьВидимостьИДоступностьЭлементов();
	
КонецПроцедуры

&НаСервере
Процедура ДатаПриИзмененииНаСервере()
	
	Если Не Объект.Подтвержден Тогда
		Если Объект.Проведен Тогда
			ДокОбъект = РеквизитФормыВЗначение("Объект");
			ДокОбъект.Записать(РежимЗаписиДокумента.Проведение);
			ЗначениеВРеквизитФормы(ДокОбъект, "Объект");
		Иначе
			Записать();
		КонецЕсли;
		Модифицированность = Ложь;
	КонецЕсли;
	УстановитьВидимостьИДоступностьЭлементов();
	
КонецПроцедуры

#КонецОбласти
