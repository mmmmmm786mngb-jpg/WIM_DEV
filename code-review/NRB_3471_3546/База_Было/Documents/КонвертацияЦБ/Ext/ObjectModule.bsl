//// ОБРАБОТЧИКИ СОБЫТИЙ

Процедура ОбработкаПроведения(Отказ, Режим)
	флУслуги = Ложь;
	
	//Определяем делать ли движения по регистру УслугиДепозитария
	Если ЗначениеЗаполнено(ТарифныйПлан) Тогда
		Услуги 				= Справочники.УслугиТарифногоПлана;
		УслугаОперации = Справочники.УслугиТарифногоПлана.УслугаТарифногоПланаПоРеквизиту("Операция",
			Справочники.ВидыОпераций.Конвертация, ,Неопределено);
		//Проверка существования услуги.
		Если НЕ УслугаОперации.Пустая() Тогда
			Тариф		= 	РегистрыСведений.Тарифы.ПолучитьПоследнее(Дата, Новый Структура("Услуга",УслугаОперации));
			Если Тариф <> Неопределено Тогда
				флУслуги = Истина;
	        Иначе
				Сообщить("Не определен тариф услуги депозитария - " + УслугаОперации);
				Отказ = Истина;
			КонецЕсли; 		
			флУслуги = Ложь;
		Иначе
			Сообщить("Данная услуга - не определена в справочнике /Услуги тарифного плана/.");
			Отказ = Истина;
		КонецЕсли; 	
	КонецЕсли;
	Если НЕ Отказ Тогда
		Если Дата < Дата(2014, 12, 20) Тогда
			////////////////////////////////////////////////////////////
			// Раньше мы списывали по остаткам, не обращая внимание на таблицы "списание" и "зачисление"
			табОстаткиЦБ = СформироватьЗапросПоРегиструОстаткиЦБ();
			табЦБВПути   = СформироватьЗапросПоРегиструЦБВПути();
			Если табОстаткиЦБ.Количество() = 0 И табЦБВПути.Количество() Тогда
				Сообщить("Указанных ценных бумаг нет ни на одном из счетов депо.");
				Отказ = Истина;
			КонецЕсли;
			ДвиженияПоРегистрамНакопления(Движения.ОстаткиЦБ, табОстаткиЦБ, флУслуги);
			ДвиженияПоРегистрамНакопления(Движения.ЦБВПути, табЦБВПути, флУслуги);
		Иначе
			////////////////////////////////////////////////////////////
			// Новое списание
			СтараяЦБ = ЦенныеБумагиИсходные[0].ЦБ;
			НоваяЦБ = ЦенныеБумаги[0].ЦБ;
			////////////////////////////////////////////////////////////
			// Движение ЦБ
			Для Каждого СтрокаСписания Из Списание Цикл
				Запрос = Новый Запрос;
				Запрос.Текст =
				"ВЫБРАТЬ
				|	ОстаткиЦБОстатки.СчетДепо,
				|	ОстаткиЦБОстатки.РазделСчетаДепо,
				|	ОстаткиЦБОстатки.СчетДепоМХ,
				|	ОстаткиЦБОстатки.РазделСчетаДепоМХ,
				|	ОстаткиЦБОстатки.СтатусЦБ,
				|	ОстаткиЦБОстатки.КоличествоОстаток
				|ИЗ
				|	РегистрНакопления.ОстаткиЦБ.Остатки(
				|			&Период,
				|			ЦБ = &ЦеннаяБумага
				|			И СчетДепо = &СчетДепо
				|			И РазделСчетаДепо = &РазделСчетаДепо
				|			И СчетДепоМХ = &СчетДепоМХ
				|			И РазделСчетаДепоМХ = &РазделСчетаДепоМХ
				|			И СтатусЦБ = &СтатусЦБ
				|			) КАК ОстаткиЦБОстатки
				|ГДЕ
				|	ОстаткиЦБОстатки.КоличествоОстаток > 0
				|
				|УПОРЯДОЧИТЬ ПО
				|	ОстаткиЦБОстатки.СчетДепо,
				|	ОстаткиЦБОстатки.РазделСчетаДепо,
				|	ОстаткиЦБОстатки.СчетДепоМХ,
				|	ОстаткиЦБОстатки.РазделСчетаДепоМХ,
				|	ОстаткиЦБОстатки.СтатусЦБ";
				Запрос.УстановитьПараметр("ЦеннаяБумага", СтараяЦБ);
				Запрос.УстановитьПараметр("СчетДепо", СтрокаСписания.СчетДепо);
				Запрос.УстановитьПараметр("РазделСчетаДепо", СтрокаСписания.РазделСчетаДепо);
				Запрос.УстановитьПараметр("СчетДепоМХ", СтрокаСписания.СчетДепоМХ);
				Запрос.УстановитьПараметр("РазделСчетаДепоМХ", СтрокаСписания.РазделСчетаДепоМХ);
				Запрос.УстановитьПараметр("СтатусЦБ", СтрокаСписания.СтатусЦБ);
				Запрос.УстановитьПараметр("Период", МоментВремени());
				Выборка = Запрос.Выполнить().Выбрать();
				// Вычисляем коэффициент конвертации для отдельно взятой бумаги
				Отбор = Новый Структура;
				Отбор.Вставить("СчетДепо", СтрокаСписания.СчетДепо);
				Отбор.Вставить("РазделСчетаДепо", СтрокаСписания.РазделСчетаДепо);
				Отбор.Вставить("СчетДепоМХ", СтрокаСписания.СчетДепоМХ);
				Отбор.Вставить("РазделСчетаДепоМХ", СтрокаСписания.РазделСчетаДепоМХ);
				Отбор.Вставить("СтатусЦБ", СтрокаСписания.СтатусЦБ);
				НайденныеСтрокиЗачисления = Зачисление.НайтиСтроки(Отбор);
				Если НайденныеСтрокиЗачисления.Количество() = 1 Тогда
					КоэффициентКонвертации = НайденныеСтрокиЗачисления[0].Количество / СтрокаСписания.Количество;
				Иначе
					Отказ = Истина;
				КонецЕсли;
				
				Если Выборка.Следующий() Тогда
					Если Выборка.КоличествоОстаток >= СтрокаСписания.Количество Тогда
						КоличествоКСписанию = Мин(Выборка.КоличествоОстаток, СтрокаСписания.Количество);
					КонецЕсли;
					// Списание ЦБ
					Движение = Движения.ОстаткиЦБ.Добавить(); 
					Движение.ВидДвижения = ВидДвиженияНакопления.Расход;
					Движение.Период = Дата;
					Движение.СчетДепо = СтрокаСписания.СчетДепо;
					Движение.РазделСчетаДепо = СтрокаСписания.РазделСчетаДепо;
					Движение.ЦБ = СтараяЦБ;
					Движение.СчетДепоМХ = СтрокаСписания.СчетДепоМХ;
					Движение.РазделСчетаДепоМХ = СтрокаСписания.РазделСчетаДепоМХ;
					Движение.СтатусЦБ = СтрокаСписания.СтатусЦБ;
					Движение.Количество = КоличествоКСписанию;
					// Зачисление ЦБ
					Движение = Движения.ОстаткиЦБ.Добавить(); 
					Движение.ВидДвижения = ВидДвиженияНакопления.Приход;
					Движение.Период = Дата;
					Движение.СчетДепо = СтрокаСписания.СчетДепо;
					Движение.РазделСчетаДепо = СтрокаСписания.РазделСчетаДепо;
					Движение.ЦБ = НоваяЦБ;
					Движение.СчетДепоМХ = СтрокаСписания.СчетДепоМХ;
					Движение.РазделСчетаДепоМХ = СтрокаСписания.РазделСчетаДепоМХ;
					Движение.СтатусЦБ = СтрокаСписания.СтатусЦБ;
					Движение.Количество = КоличествоКСписанию * КоэффициентКонвертации;
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
	КонецЕсли;
	// Сформируем необходимые выписки
	ПометкаНаУдалениеВыписокПриЗаписи(Ссылка);
	//---
	МассивСчетовДЕПО	= Новый Массив;
	Для Каждого СтрокаСписания ИЗ Списание Цикл
		Если ЗначениеЗаполнено(СтрокаСписания.СчетДепо) И МассивСчетовДЕПО.Найти(СтрокаСписания.СчетДепо) = Неопределено Тогда
			МассивСчетовДЕПО.Добавить(СтрокаСписания.СчетДепо);
		КонецЕсли;
	КонецЦикла;
	Для Каждого СтрокаЗачисления ИЗ Зачисление Цикл
		Если ЗначениеЗаполнено(СтрокаЗачисления.СчетДепо) И МассивСчетовДЕПО.Найти(СтрокаЗачисления.СчетДепо) = Неопределено Тогда
			МассивСчетовДЕПО.Добавить(СтрокаЗачисления.СчетДепо);
		КонецЕсли;
	КонецЦикла;
	//---
	ЗапросВыписки	= ПодготовитьЗапросВыписки();
	//---
	Для Каждого СчетДЕПО ИЗ МассивСчетовДЕПО Цикл
		СформироватьВыписку(СчетДЕПО, ЗапросВыписки);
	КонецЦикла;
	
КонецПроцедуры

Процедура ПометкаНаУдалениеВыписокПриЗаписи(Источник) Экспорт
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	Выписка.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.Выписка КАК Выписка
	|ГДЕ
	|	Выписка.ОперацияЦБ = &Ссылка");
	
	Запрос.УстановитьПараметр("Ссылка", Источник.Ссылка);
	
	Результат = Запрос.Выполнить();
	
	Если Результат.Пустой() Тогда
		Возврат;
	КонецЕсли; 
	
	Выборка = Результат.Выбрать();
	Пока Выборка.Следующий() Цикл
		ДокументОбъект = Выборка.Ссылка.ПолучитьОбъект();
		ДокументОбъект.УстановитьПометкуУдаления(Истина);
		ДокументОбъект.Записать();
	КонецЦикла;
КонецПроцедуры

Функция ПодготовитьЗапросВыписки()
	Запрос = Новый Запрос(
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	Ссылка		КАК Документ
	|ИЗ
	|	Документ.Выписка
	|ГДЕ
	|	НЕ ПометкаУдаления
	|	И ВидОтчета = ЗНАЧЕНИЕ(Перечисление.ВидыОтчетов.Отчет)
	|	И ДокументОснование.ВидОперацииД = ЗНАЧЕНИЕ(Справочник.ВидыОпераций.Конвертация)
	|	И СчетДепо = &СчетДепо
	|	И ОперацияЦБ = &ОперацияЦБ");

	Запрос.УстановитьПараметр("ОперацияЦБ", Ссылка);
	
	Возврат Запрос;
КонецФункции
            
Процедура СформироватьВыписку(СчетДЕПО, ЗапросВыписки)
	ЗапросВыписки.УстановитьПараметр("СчетДепо", СчетДЕПО);
	Результат	= ЗапросВыписки.Выполнить().Выгрузить();
	//---
	Если Результат.Количество()>0 Тогда 
		ВыпискаОбъект	= Результат[0].Документ.ПолучитьОбъект();
	Иначе
		ВыпискаОбъект	= Документы.Выписка.СоздатьДокумент();
	КонецЕсли;
	//---
	Если ВыпискаОбъект.ПометкаУдаления Тогда
		ВыпискаОбъект.УстановитьПометкуУдаления(Ложь);
	КонецЕсли;
	//---
	ВыпискаОбъект.Дата					= Дата;
	ВыпискаОбъект.ДокументОснование		= ДокументОснование;
	ВыпискаОбъект.ОперацияЦБ			= Ссылка;
	ВыпискаОбъект.ВидОтчета				= Перечисления.ВидыОтчетов.Отчет;
	ВыпискаОбъект.ТарифныйПлан			= ТарифныйПлан;
	ВыпискаОбъект.СпособОтправкиОтчета	= Справочники.СпособыПередачиИнформации.ЭДО;
	ВыпискаОбъект.Автор					= ?(ЗначениеЗаполнено(ВыпискаОбъект.Автор), ВыпискаОбъект.Автор, ПараметрыСеанса.ТекущийПользователь);
	ВыпискаОбъект.Изменил				= ПараметрыСеанса.ТекущийПользователь;
	ВыпискаОбъект.СчетДепо				= СчетДЕПО;
	ВыпискаОбъект.ВладелецСчета			= СчетДЕПО.Владелец;
	//---
	Попытка
		ВыпискаОбъект.Записать(РежимЗаписиДокумента.Проведение);
	Исключение
		ВызватьИсключение "Не удалось сформировать документ выписка (счет Депо: "+СчетДЕПО+") на основании данной конвертации!";
	КонецПопытки;
КонецПроцедуры

Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
    
	Если ОбменДанными.Загрузка = Истина Тогда
		Возврат;
	КонецЕсли;
	
	Если ЦенныеБумаги.Количество() = 0 Тогда
		
		Сообщить("Не выбрано ни одной получаемой ценной бумаги");  
		Отказ = Истина;			
		
	КонецЕсли;	
	
	Если ЦенныеБумагиИсходные.Количество() = 0 Тогда
		
		Сообщить("Не выбрано ни одной исходной ценной бумаги");  
		Отказ = Истина;			
		
	КонецЕсли;	
	
	Если ОбщегоНазначения.ЗначениеНеЗаполнено(Инициатор) Тогда
		
		Сообщить("Не выбран иницаитор");  
		Отказ = Истина;			
		
	КонецЕсли;	
	УстановитьНовыйНомер();
КонецПроцедуры // ПередЗаписью()

// Обработчик события создания документа "Открытие счета на основании" на основании.
//
Процедура ОбработкаЗаполнения(Основание) Экспорт
	Если ЗначениеЗаполнено(Основание) И Основание.ВидОперацииД = Справочники.ВидыОпераций.Конвертация Тогда 
		
		Дата				= ОбщегоНазначения.ДатаДокумента(Основание);
		Инициатор			= Основание.Инициатор;
		ДокументОснование 	= Основание.Ссылка;			
		Комментарий			= "Поручение № " + Основание.Номер + " от " + Основание.Дата;
		ТипОперации			= Основание.ТипКонвертации;
		ТарифныйПлан		= Справочники.ТарифныеПланы.НайтиПоНаименованию("Основной");
		НомерОтчета 		= Основание.НомерОтчета;
		
		ЦенныеБумагиИсходные.Очистить();
		ЦенныеБумаги.Очистить();
		Списание.Очистить();
		Зачисление.Очистить();
		
		Для Каждого СтрокаСписания ИЗ Основание.ЦенныеБумагиСписываемые Цикл
			НоваяСтрока						= ЦенныеБумагиИсходные.Добавить();
			НоваяСтрока.ЦБ					= СтрокаСписания.ЦеннаяБумага;
			НоваяСтрока.КоличествоИсходных	= СтрокаСписания.Количество;
		КонецЦикла;
			
		Для Каждого СтрокаЗачисления ИЗ Основание.ЦенныеБумагиЗачисляемые Цикл
			НоваяСтрока						= ЦенныеБумаги.Добавить();
			НоваяСтрока.ЦБ					= СтрокаЗачисления.ЦеннаяБумага;
			НоваяСтрока.КоличествоИтоговых	= СтрокаЗачисления.Количество;
		КонецЦикла;
		
		Для Каждого СтрокаСписания ИЗ Основание.Списание Цикл
			НоваяСтрока = Списание.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаСписания);
		КонецЦикла;
		
		Для Каждого СтрокаЗачисления ИЗ Основание.Зачисление Цикл
			НоваяСтрока = Зачисление.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаЗачисления);
		КонецЦикла;
		
	Иначе
		Проверка = Истина;
		ДокументОснование 	= Документы.Поручение.ПустаяСсылка();			
		Сообщить("На основании данного вида поручения нельзя создать документ ""Конвертация ценных бумаг"". 
				  |Вид операции должен быть ""Конвертация""!");
		Возврат;	
	КонецЕсли;
	
КонецПроцедуры

