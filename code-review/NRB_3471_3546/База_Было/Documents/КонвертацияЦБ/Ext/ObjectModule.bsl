Процедура РассчитатьДляЦелыхЗачислений()  Экспорт 
	
	Списание.Очистить();
	Зачисление.Очистить();
	
	КоэффициентКонвертации = ЦенныеБумаги[0].КоличествоИтоговых / ЦенныеБумагиИсходные[0].КоличествоИсходных;
					
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	СчетДепо,
	|	РазделСчетаДепо,
	|	СчетДепоМХ,
	|	РазделСчетаДепоМХ,
	|	СтатусЦБ,
	|	КоличествоОстаток КАК Количество
	|ИЗ
	|	РегистрНакопления.ОстаткиЦБ.Остатки(&Период, ЦБ = &ЦеннаяБумага)
	|ГДЕ
	|	КоличествоОстаток > 0
	|УПОРЯДОЧИТЬ ПО
	|	СчетДепо,
	|	РазделСчетаДепо,
	|	СчетДепоМХ,
	|	РазделСчетаДепоМХ,
	|	СтатусЦБ";
	Запрос.УстановитьПараметр("ЦеннаяБумага", ЦенныеБумагиИсходные[0].ЦБ);
	Запрос.УстановитьПараметр("Период", МоментВремени());
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		
		Если Выборка.Количество <= 0 Тогда
			Продолжить;
		КонецЕсли; 
		
		КоличествоЗачисления = Цел(Выборка.Количество * КоэффициентКонвертации);
		КоличествоСписания = КоличествоЗачисления / КоэффициентКонвертации;
		
		СтрокаСписание = Списание.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаСписание, Выборка);
		СтрокаСписание.Количество = КоличествоСписания;
		
		Для Каждого Элемент Из ЦенныеБумаги Цикл
			
			СтрокаЗачисление = Зачисление.Добавить();
			ЗаполнитьЗначенияСвойств(СтрокаЗачисление, Выборка);
			СтрокаЗачисление.Количество = КоличествоЗачисления;
			
		КонецЦикла;
		
	КонецЦикла;
	
КонецПроцедуры

