Перем УслугаОперации, Тариф;

////////////////////////////////////////////////////////////////////////////////
// ПРОЦЕДУРЫ И ФУНКЦИИ ДЛЯ ОБЕСПЕЧЕНИЯ ПРОВЕДЕНИЯ ДОКУМЕНТА

// Поиск ЦБ на всех счетах депо
//
Функция СформироватьЗапросПоРегиструОстаткиЦБ()
	
	Запрос = Новый Запрос;
	
	СписокЦБ = ЦенныеБумагиИсходные.ВыгрузитьКолонку("ЦБ");
	
	Запрос.Текст = "ВЫБРАТЬ
	               |	ОстаткиЦБОстатки.СчетДепо,
	               |	ОстаткиЦБОстатки.РазделСчетаДепо,
	               |	ОстаткиЦБОстатки.СчетДепоМХ,
	               |	ОстаткиЦБОстатки.РазделСчетаДепоМХ,
	               |	ОстаткиЦБОстатки.ЦБ,
	               |	ОстаткиЦБОстатки.СтатусЦБ,
	               |	ОстаткиЦБОстатки.КоличествоОстаток
	               |ИЗ
	               |	РегистрНакопления.ОстаткиЦБ.Остатки(&выбДата, ЦБ В (&СписокЦБ)) КАК ОстаткиЦБОстатки";

	Запрос.УстановитьПараметр("выбДата", Дата);
	Запрос.УстановитьПараметр("СписокЦБ", СписокЦБ);

	Результат = Запрос.Выполнить();
	
	Возврат Результат.Выгрузить();
	
КонецФункции // СформироватьЗапросПоРегиструОстаткиЦБ()

// Поиск ЦБ на всех счетах депо
//
Функция СформироватьЗапросПоРегиструЦБВПути()
	
	Запрос = Новый Запрос;
	
	СписокЦБ = ЦенныеБумагиИсходные.ВыгрузитьКолонку("ЦБ");
	
	Запрос.Текст = "ВЫБРАТЬ
	               |	ЦБВПутиОстатки.СчетДепо КАК СчетДепо,
	               |	ЦБВПутиОстатки.РазделСчетаДепо КАК РазделСчетаДепо,
	               |	ЦБВПутиОстатки.СчетДепоМХ КАК СчетДепоМХ,
	               |	ЦБВПутиОстатки.РазделСчетаДепоМХ КАК РазделСчетаДепоМХ,
	               |	ЦБВПутиОстатки.ЦБ КАК ЦБ,
	               |	ЦБВПутиОстатки.КоличествоОстаток КАК КоличествоОстаток
	               |ИЗ
	               |	РегистрНакопления.ЦБВПути.Остатки(&ВыбДата, ЦБ В (&СписокЦБ)) КАК ЦБВПутиОстатки";

	Запрос.УстановитьПараметр("выбДата", Дата);
	Запрос.УстановитьПараметр("СписокЦБ", СписокЦБ);

	Результат = Запрос.Выполнить();
	
	Возврат Результат.Выгрузить();
	
КонецФункции // СформироватьЗапросПоРегиструЦБВПути()

// Формируем движения по регистрам
//
// Параметры: 
//  ВыборкаПоШапкеДокумента                  - выборка из результата запроса по шапке документа.
//	ВыборкаПоРаботники					     - выборка из результата запроса ТЧ "Работники".									
//  СтруктураПроведенияПоРегистрамНакопления - структура, содержащая имена регистров 
//                                             накопления по которым надо проводить документ
//  СтруктураПараметров                      - структура параметров проведения.
//
// Возвращаемое значение:
//  Нет.
//
Процедура ДвиженияПоРегистрамНакопления(текДвижения, табЦБ, флДелатьДвиженияПоРегиструУслуг)
	
	стИсх = Новый Соответствие;
	
	Для Каждого СтрокаТЧ Из ЦенныеБумагиИсходные Цикл
		стИсх[СтрокаТЧ.ЦБ] = СтрокаТЧ.КоличествоИсходных;
	КонецЦикла;
	
	// Переменные для механизма правильного округления выходных количеств
	ЦБнаВыходеНужно = 0;
	Для Каждого СтрокаЦБ Из ЦенныеБумаги Цикл
		ЦБнаВыходеНужно = ЦБнаВыходеНужно + СтрокаЦБ.КоличествоИтоговых;
	КонецЦикла;
	ЦБнаВыходеФакт = 0;
	
	Для Каждого СтрокаИсхЦБ Из табЦБ Цикл
				
		Движение = текДвижения.Добавить();
		Движение.ВидДвижения = ВидДвиженияНакопления.Расход;
		Движение.Период = Дата;
		Движение.СчетДепо = СтрокаИсхЦБ.СчетДепо;
		Движение.РазделСчетаДепо = СтрокаИсхЦБ.РазделСчетаДепо;
		Движение.ЦБ = СтрокаИсхЦБ.ЦБ;
		Движение.СчетДепоМХ = СтрокаИсхЦБ.СчетДепоМХ;
		Движение.РазделСчетаДепоМХ = СтрокаИсхЦБ.РазделСчетаДепоМХ;
		
		Если текДвижения = Движения.ОстаткиЦБ Тогда
			
			Движение.СтатусЦБ = СтрокаИсхЦБ.СтатусЦБ;
			
		КонецЕсли;
		
		Движение.Количество = СтрокаИсхЦБ.КоличествоОстаток;
		
		Для Каждого СтрокаЦБ Из ЦенныеБумаги Цикл
			
			КолИсх = стИсх[СтрокаИсхЦБ.ЦБ];
			
			Движение = текДвижения.Добавить();
			Движение.ВидДвижения = ВидДвиженияНакопления.Приход;
			Движение.Период = Дата;
			Движение.СчетДепо = СтрокаИсхЦБ.СчетДепо;
			Движение.РазделСчетаДепо = СтрокаИсхЦБ.РазделСчетаДепо;
			Движение.ЦБ = СтрокаЦБ.ЦБ;
			Движение.СчетДепоМХ = СтрокаИсхЦБ.СчетДепоМХ;
			Движение.РазделСчетаДепоМХ = СтрокаИсхЦБ.РазделСчетаДепоМХ;
			
			Если текДвижения = Движения.ОстаткиЦБ Тогда
				
				Движение.СтатусЦБ = СтрокаИсхЦБ.СтатусЦБ;
				
			КонецЕсли;
			
			//Движение.Количество = СтрокаИсхЦБ.КоличествоОстаток * СтрокаЦБ.Коэффициент;
			Движение.Количество = СтрокаИсхЦБ.КоличествоОстаток * СтрокаЦБ.КоличествоИтоговых / КолИсх;
			
			// Rarus Karg 21.06.2007  
			Если ОкруглятьДробноеКоличествоЦБ Тогда
				Движение.Количество = Окр(Движение.Количество);
			КонецЕсли; 
				
			// Считаем фактический приход бумаг
			// для механизма правильного округления выходных количеств
			ЦБнаВыходеФакт = ЦБнаВыходеФакт + Движение.Количество;
			
		КонецЦикла;
		
		Если флДелатьДвиженияПоРегиструУслуг Тогда
			
			ДепозитарийКлиент.СоздатьДвиженияДокумента(Дата,Движения,СтрокаИсхЦБ.СчетДепо.Владелец,УслугаОперации,Тариф);
			
		КонецЕсли;
				
	КонецЦикла;
	
	// Корректируем последнее движение по регистру ОстаткиЦБ
	// для механизма правильного округления выходных количеств
	Если текДвижения = Движения.ОстаткиЦБ Тогда
		ПоследнееДвижениеПоОстаткамЦБ = Движения.ОстаткиЦБ.Получить(Движения.ОстаткиЦБ.Количество() - 1);
		ПоследнееДвижениеПоОстаткамЦБ.Количество = ПоследнееДвижениеПоОстаткамЦБ.Количество + (ЦБнаВыходеНужно - ЦБнаВыходеФакт);
	КонецЕсли;
	
	текДвижения.Записать();
	
КонецПроцедуры // ДвиженияПоРегистрамНакопления()

