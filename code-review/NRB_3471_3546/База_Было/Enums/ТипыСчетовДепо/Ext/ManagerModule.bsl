
Функция НоминальныхДержателей() Экспорт
	НоминальныхДержателей = Новый Массив;
	НоминальныхДержателей.Добавить(НоминальногоДержателя);
	НоминальныхДержателей.Добавить(НоминальногоДержателяТорговый);
	НоминальныхДержателей.Добавить(ИностранногоНоминальногоДержателя);
	НоминальныхДержателей.Добавить(ИностранногоНоминальногоДержателяТорговый);
	Возврат НоминальныхДержателей;
КонецФункции

Функция Торговые() Экспорт
	Торговые = Новый Массив;
	Торговые.Добавить(ВладельцаТорговый);
	Торговые.Добавить(НоминальногоДержателяТорговый);
	Торговые.Добавить(ДоверительногоУправляющегоТорговый);
	Торговые.Добавить(ИностранногоНоминальногоДержателяТорговый);
	Торговые.Добавить(ИностранногоУполномоченногоДержателяТорговый);
	Возврат Торговые;
КонецФункции

Функция ТипСчетаМХДляKafka(ТипСчетаМХ) Экспорт
	
	СоответствиеТипов = Новый Соответствие;
	СоответствиеТипов.Вставить(Перечисления.ТипыСчетовДепо.Владельца									, "Basic");
	СоответствиеТипов.Вставить(Перечисления.ТипыСчетовДепо.ВладельцаТорговый							, "Trade");
	СоответствиеТипов.Вставить(Перечисления.ТипыСчетовДепо.ДоверительногоУправляющего					, "Trustee");
	СоответствиеТипов.Вставить(Перечисления.ТипыСчетовДепо.ДоверительногоУправляющегоТорговый			, "TrustTrade");
	СоответствиеТипов.Вставить(Перечисления.ТипыСчетовДепо.Залогодержателя								, "Mortgagee");
	СоответствиеТипов.Вставить(Перечисления.ТипыСчетовДепо.ИностранногоНоминальногоДержателя			, "ForeignNominal");
	СоответствиеТипов.Вставить(Перечисления.ТипыСчетовДепо.ИностранногоНоминальногоДержателяТорговый	, "ForeignNominalTrade");
	СоответствиеТипов.Вставить(Перечисления.ТипыСчетовДепо.ИностранногоУполномоченногоДержателя			, "ForeignAuthorized");
	СоответствиеТипов.Вставить(Перечисления.ТипыСчетовДепо.ИностранногоУполномоченногоДержателяТорговый	, "ForeignAuthorizedTrading");
	СоответствиеТипов.Вставить(Перечисления.ТипыСчетовДепо.ИныеФедеральныеСчета							, "Other");
	СоответствиеТипов.Вставить(Перечисления.ТипыСчетовДепо.КазначейскийСчетЭмитента						, "IssuerTreasury");
	СоответствиеТипов.Вставить(Перечисления.ТипыСчетовДепо.КлиринговыйСчетДЕПО							, "DepoClearing");
	СоответствиеТипов.Вставить(Перечисления.ТипыСчетовДепо.НеустановленныхЛиц							, "Unidentified");
	СоответствиеТипов.Вставить(Перечисления.ТипыСчетовДепо.НоминальногоДержателя						, "Nominee");
	СоответствиеТипов.Вставить(Перечисления.ТипыСчетовДепо.НоминальногоДержателяТорговый				, "NomineeTrading");
	СоответствиеТипов.Вставить(Перечисления.ТипыСчетовДепо.УчетПравНаЦБПереданныеВДепозитНотариусаСуда	, "DepositNotary");
	СоответствиеТипов.Вставить(Перечисления.ТипыСчетовДепо.ЭмиссионныйСчет								, "Issuing");
	
	Возврат СоответствиеТипов[ТипСчетаМХ];
	
КонецФункции

