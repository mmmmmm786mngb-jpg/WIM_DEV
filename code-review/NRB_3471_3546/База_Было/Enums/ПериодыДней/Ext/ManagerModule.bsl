#Область СлужебныйПрограммныйИнтерфейс

// Получить дату по типу периода
//
// Параметры:
//  ТипПериодаЗагрузкиКотировок	 - ПеречислениеСсылка.ПериодыДней	 - Тип периода
//  ТекущаяДата					 - Дата								 - Текущая дата
// 
// Возвращаемое значение:
//   - Дата - Результирующая дата
//
Функция ДатаПоТипуПериода(ТипПериодаЗагрузкиКотировок, ТекущаяДата) Экспорт
	
	Если ТипПериодаЗагрузкиКотировок = Перечисления.ПериодыДней.ПредыдущийРабочийДень Тогда
		ДатаНачала = ОбщегоНазначения.ПредыдущийРабочийДень(ТекущаяДата);
	ИначеЕсли ТипПериодаЗагрузкиКотировок = Перечисления.ПериодыДней.ТекущийДень Тогда
		ДатаНачала = НачалоДня(ТекущаяДата);
	ИначеЕсли ТипПериодаЗагрузкиКотировок = Перечисления.ПериодыДней.ПредыдущийДень Тогда
		ДатаНачала = НачалоДня(НачалоДня(ТекущаяДата) - 1);
	Иначе
		ДатаНачала = Дата("00010101");
	КонецЕсли;
	
	Возврат ДатаНачала;
	
КонецФункции

#КонецОбласти