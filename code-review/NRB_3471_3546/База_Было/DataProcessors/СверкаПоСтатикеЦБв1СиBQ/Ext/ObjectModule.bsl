Процедура СверитьОсновныеПоляЭмитента(ДанныеЭмитентаBQ, ДанныеЭмитентаДЕПО, ОсновныеДанныеЦБ_ДЕПО,
										ЗаголовокПоЦБВыведен, ТабДок, Макет, ЕстьРасхождения)
	НесовпадающиеПоля = НовыйТаблицаПолейСНесовпадающимиЗначениями();
	
	СоответствиеИменРеквизитов = СоответствиеИменОсновныхРеквизитовЭмитента();
	Для Каждого Элемент Из СоответствиеИменРеквизитов Цикл
		СравнитьОдинРеквизитЭмитента(ДанныеЭмитентаBQ, ДанныеЭмитентаДЕПО, Элемент.Значение, Элемент.Ключ, НесовпадающиеПоля);
	КонецЦикла;
	
	ЕстьРасхожденияВЭмитенте = (НесовпадающиеПоля.Количество() <> 0);
	Если ЕстьРасхожденияВЭмитенте Тогда
		ВывестиЗаголовокПоЦБ(ЗаголовокПоЦБВыведен, ОсновныеДанныеЦБ_ДЕПО, ТабДок, Макет);
		ТипРасхождений = "Расхождения в основной информации об эмитенте:";
		ВывестиИнформациюОНесовпадающихРеквизитах(ТипРасхождений, НесовпадающиеПоля, ТабДок, Макет, "ОсновныеПоляЭмитента");
		ЕстьРасхождения = ЕстьРасхожденияВЭмитенте;
	КонецЕсли;
КонецПроцедуры

Процедура СравнитьОдинРеквизитЭмитента(ДанныеИзBQ, ДанныеИзДЕПО, ИмяРеквизитаBQ, ИмяРеквизитаДЕПО, НесовпадающиеПоля)
	Если ДанныеИзBQ = Неопределено Тогда
		ЗначениеРеквизитаДЕПО = ДанныеИзДЕПО[ИмяРеквизитаДЕПО];
		ДобавитьВНесовпадающиеПоля(НесовпадающиеПоля, ИмяРеквизитаBQ, ИмяРеквизитаДЕПО, "Н/Д", ЗначениеРеквизитаДЕПО);
	Иначе
		Если ИмяРеквизитаДЕПО = "НеРезидент" Тогда
			СравнитьРезидентство(ДанныеИзBQ, ДанныеИзДЕПО, ИмяРеквизитаBQ, ИмяРеквизитаДЕПО, НесовпадающиеПоля);
		Иначе
			СравнитьРеквизиты(ДанныеИзBQ, ДанныеИзДЕПО, ИмяРеквизитаBQ, ИмяРеквизитаДЕПО, НесовпадающиеПоля);
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

Процедура СравнитьРезидентство(ДанныеИзBQ, ДанныеИзДЕПО,  ИмяПоляBQ, ИмяПоляДЕПО, НесовпадающиеПоля)
	ЗначениеПоляBQ = ДанныеИзBQ[ИмяПоляBQ];
	ЗначениеПоляДЕПО = ДанныеИзДЕПО[ИмяПоляДЕПО];
	
	ЗначениеДляСравненияДЕПО = ЗначениеПоляДЕПО;
	Если ЗначениеПоляBQ = "y" Тогда
		ЗначениеДляСравненияBQ = Ложь;
	ИначеЕсли ЗначениеПоляBQ = "n" Тогда
		ЗначениеДляСравненияBQ = Истина;
	Иначе
		ЗначениеДляСравненияBQ = ЗначениеПоляBQ;
	КонецЕсли;
	
	Если ЗначениеДляСравненияBQ <> ЗначениеДляСравненияДЕПО Тогда
		ДобавитьВНесовпадающиеПоля(НесовпадающиеПоля, ИмяПоляBQ, ИмяПоляДЕПО, ЗначениеПоляBQ, ЗначениеПоляДЕПО);
	КонецЕсли;
КонецПроцедуры

Функция ЧислоИзДепоСовпадаетСоСтрокойИзBQ(ЗначениеИзДЕПО, ЗначениеИзBQ)
	ЗначениеДляСравненияДЕПО = ЧислоВСтроку(ЗначениеИзДЕПО);
	ЗначениеДляСравненияBQ = СтрокаВЧисло(ЗначениеИзBQ);
	
	Возврат (ЗначениеДляСравненияДЕПО = ЗначениеДляСравненияBQ);
КонецФункции

Функция СтрокаВЧисло(ЗначениеСтрока)
	Возврат СтрЗаменить(СтрЗаменить(СокрЛП(ЗначениеСтрока), Символы.НПП, ""), " ", "");
КонецФункции

Функция ЧислоВСтроку(ЗначениеЧисло)
	Возврат СтрЗаменить(СтрЗаменить(Строка(ЗначениеЧисло), Символы.НПП, ""), " ", "");
КонецФункции

