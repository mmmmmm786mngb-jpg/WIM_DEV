#Область ПрограммныйИнтерфейс

// Процедура заполняет ТЧ СверкаСтатикиЦБ, помещая в нее все ЦБ, которые приняты на обслуживание 
// и не сняты с него, или по которым есть остатки на текущую дату.
Процедура ЗаполнитьСписокЦБ() Экспорт
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ЦенныеБумаги.Ссылка КАК ЦеннаяБумага
	|ПОМЕСТИТЬ ВТ_ЦенныеБумаги
	|ИЗ
	|	Справочник.ЦенныеБумаги КАК ЦенныеБумаги
	|ГДЕ
	|	ЦенныеБумаги.ДатаПриемаНаОбслуживание <= &ТекущаяДата
	|	И ЦенныеБумаги.ДатаПриемаНаОбслуживание <> ДАТАВРЕМЯ(1, 1, 1)
	|	И ВЫБОР
	|			КОГДА ЦенныеБумаги.ДатаСнятияСОбслуживания = ДАТАВРЕМЯ(1, 1, 1)
	|				ТОГДА ИСТИНА
	|			КОГДА ЦенныеБумаги.ДатаСнятияСОбслуживания > &ТекущаяДата
	|				ТОГДА ИСТИНА
	|			ИНАЧЕ ЛОЖЬ
	|		КОНЕЦ
	|	И НЕ ЦенныеБумаги.ПометкаУдаления
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ОстаткиЦБОстатки.ЦБ
	|ИЗ
	|	РегистрНакопления.ОстаткиЦБ.Остатки(&ТекущаяДата, 1 = 1) КАК ОстаткиЦБОстатки
	|ГДЕ
	|	ОстаткиЦБОстатки.КоличествоОстаток <> 0
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_ЦенныеБумаги.ЦеннаяБумага КАК ЦеннаяБумага,
	|	ЦенныеБумаги.Наименование КАК Наименование
	|ИЗ
	|	ВТ_ЦенныеБумаги КАК ВТ_ЦенныеБумаги
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ЦенныеБумаги КАК ЦенныеБумаги
	|		ПО (ЦенныеБумаги.Ссылка = ВТ_ЦенныеБумаги.ЦеннаяБумага)
	|
	|СГРУППИРОВАТЬ ПО
	|	ВТ_ЦенныеБумаги.ЦеннаяБумага,
	|	ЦенныеБумаги.Наименование
	|
	|УПОРЯДОЧИТЬ ПО
	|	ЦенныеБумаги.Наименование";
	Запрос.УстановитьПараметр("ТекущаяДата", НачалоДня(ТекущаяДатаСеанса()) );
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		НовСтрока = СписокЦБДляСверки.Добавить();
		НовСтрока.ЦеннаяБумага = Выборка.ЦеннаяБумага;
		ДанныеОКоде = РаботаСДаннымиBQВызовСервера.ТипКодаИКодДляСверки(НовСтрока.ЦеннаяБумага);
		НовСтрока.ТипКодаДляСверки = ДанныеОКоде.ТипКода;
		НовСтрока.КодДляСверки = СокрЛП(ДанныеОКоде.Код);
	КонецЦикла;
КонецПроцедуры

// Выполняет сверку данных 1С ДЕПО с backQORT и возвращает описание найденых расхождений
// Параметры:
//	ИмяРеквизита - строка
// Возвращаемое значение:
//	- ТабличныйДокумент - также может быть строка с ошибкой.
Функция РезультатСверкиДанных(ИмяРеквизита = Неопределено) Экспорт
	Перем АДО;
	
	Если Не ПодключениеАДОУстановлено(АДО) Тогда
		Возврат "Не удалось подключиться к базе BQ";
	КонецЕсли;
	
	ТабДок = Новый ТабличныйДокумент;
	ТабДок.НачатьАвтогруппировкуСтрок();
	
	Если ЗначениеЗаполнено(ИмяРеквизита) Тогда
		ДлинаИмениРеквизита = СтрДлина(ИмяРеквизита);
		ПрефиксЦБ = "ЦБ: ";
		ПрефиксЭмитент = "Эмитент: ";
		Если Лев(ИмяРеквизита, СтрДлина(ПрефиксЦБ)) = ПрефиксЦБ Тогда
			ТипСущности = "ЦБ";
			ИмяРеквизитаДЕПО = Прав(ИмяРеквизита, ДлинаИмениРеквизита - СтрДлина(ПрефиксЦБ) );
			СоответствиеИменРеквизитов = СоответствиеИменОсновныхРеквизитовЦБ();
		Иначе
			ТипСущности = "Эмитент";
			ИмяРеквизитаДЕПО = Прав(ИмяРеквизита, ДлинаИмениРеквизита - СтрДлина(ПрефиксЭмитент) );
			СоответствиеИменРеквизитов = СоответствиеИменОсновныхРеквизитовЭмитента();
		КонецЕсли;
		СверяемыйРеквизит = Новый Структура();
		СверяемыйРеквизит.Вставить("ИмяРеквизитаДЕПО", ИмяРеквизитаДЕПО);
		СверяемыйРеквизит.Вставить("ИмяРеквизитаBQ", СоответствиеИменРеквизитов[ИмяРеквизитаДЕПО]);
		СверяемыйРеквизит.Вставить("ЧислоРасхождений", 0);
		СверяемыйРеквизит.Вставить("ТипСущности", ТипСущности);
		Макет = Обработки.СверкаПоСтатикеЦБв1СиBQ.ПолучитьМакет("МакетОтчетаОРасхожденияхПоОдномуРеквизиту");
		ОбластьШапкаОтчета = Макет.ПолучитьОбласть("ОбластьШапкаОтчета");
		ОбластьШапкаОтчета.Параметры.ИмяРеквизита = ИмяРеквизита;
		ЗаголовокСущности = ?(ТипСущности = "ЦБ", "Наименование ЦБ", "Наименование ЦБ / Эмитента");
		ОбластьШапкаОтчета.Параметры.ЗаголовокСущности = ЗаголовокСущности;
		ТабДок.Вывести(ОбластьШапкаОтчета);
	Иначе
		Макет = Обработки.СверкаПоСтатикеЦБв1СиBQ.ПолучитьМакет("МакетОтчетаОРасхождениях");
		СверяемыйРеквизит = Неопределено;
	КонецЕсли;
	Для Каждого СтрокаТЧ Из СписокЦБДляСверки Цикл
		ПолучитьИСверитьДанныеПоОднойЦБ(АДО, СтрокаТЧ, СверяемыйРеквизит, ТабДок, Макет);
	КонецЦикла;
	
	ТабДок.ЗакончитьАвтогруппировкуСтрок();
	Если СписокЦБДляСверки.Количество() > 1 Тогда
		ТабДок.ПоказатьУровеньГруппировокСтрок(0);
	Иначе
		ТабДок.ПоказатьУровеньГруппировокСтрок(1);
	КонецЕсли;
	
	Возврат ТабДок;
КонецФункции 

// Проверяет найдены ли расхождения при сверке
// Возвращаемое значение:
//	- Булево
Функция НайденыРасхождения() Экспорт
	НайденыРасхождения = Ложь;
	Для Каждого СтрокаТЧ Из СписокЦБДляСверки Цикл
		Если СтрокаТЧ.ЕстьРасхождения Тогда
			НайденыРасхождения = Истина;
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	Возврат НайденыРасхождения;
КонецФункции

