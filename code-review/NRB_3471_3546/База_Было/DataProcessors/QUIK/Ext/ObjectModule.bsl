// ВСПОМОГАТЕЛЬНЫЕ ПРОЦЕДУРЫ

Функция ТекстЗапросаSQLНеторговыеПоручения(НачалоПериода, КонецПериода)
	НачалоПериодаДата	= Формат(НачалоПериода			, "ДФ=yyyyMMdd"); 
	НачалоПериодаВремя	= Формат(НачалоПериода			, "ДФ=HHmmss");
	КонецПериодаДата	= Формат(КонецПериода			, "ДФ=yyyyMMdd"); 
	КонецПериодаВремя	= Формат(КонецДня(КонецПериода)	, "ДФ=HHmmss");
	
	ТекстЗапроса = "
	|SELECT
	|	CAST(t1.Number AS VARCHAR(20))	AS НомерПоручения,
	|	t1.FirmID		AS ИДФирмы,
	|	t1.ClientId		AS ИДКлиента,
	|	t1.ClientBuyId	AS ИДКлиентаПолучателя,
	|	CASE 
	|		WHEN CHARINDEX('_',t1.ClientId)>0 THEN SUBSTRING(t1.ClientId, 1, CHARINDEX('_',t1.ClientId)-1)
	|		ELSE t1.ClientId
	|	END AS ИДКлиентаСубброкер,
	|	CASE 
	|		WHEN CHARINDEX('_',t1.ClientBuyId)>0 THEN SUBSTRING(t1.ClientBuyId, 1, CHARINDEX('_',t1.ClientBuyId)-1)
	|		ELSE t1.ClientBuyId
	|	END AS ИДКлиентаПолучателяСубброкер,
	|	CAST(CASE
	|		WHEN t2.Type IN (0, 1, 10, 12, 14) THEN 'Депонирование'
	|		WHEN t2.Type IN (2, 5, 6, 7, 11, 13, 15) THEN 'СнятиеСДепонирования'
	|		WHEN t2.Type IN (3, 4) THEN 'Перевод'
	|		ELSE 'Неизвестно'
	|	END AS VARCHAR(50) ) AS ТипОперации,
	|	t1.Status	AS Состояние,
	|	CASE WHEN AcceptTime > 0 THEN DATEADD(SECOND, (AcceptTime/10000) * 3600 + (AcceptTime/100 - (AcceptTime/10000)*100) * 60  + (AcceptTime - (AcceptTime/100)*100), convert(datetime, CONVERT(DATETIME, CONVERT(CHAR(8), AcceptDate)))) ELSE 0 END	AS ДатаИсполнения,
	|	DATEADD(SECOND, (RegisterTime/10000) * 3600 + (RegisterTime/100 - (RegisterTime/10000)*100) * 60  + (RegisterTime - (RegisterTime/100)*100), convert(datetime, CONVERT(DATETIME, CONVERT(CHAR(8), RegisterDate))))	AS ДатаРегистрации,
	|	CASE
	|		WHEN t1.DepoAccount = NULL OR CHARINDEX(CHAR(3), ISNULL(t1.DepoAccount, ''), 1)<=0 
	|		THEN ISNULL(t1.DepoAccount, '')
	|		ELSE SUBSTRING(ISNULL(t1.DepoAccount, ''), 1, CHARINDEX(CHAR(3), ISNULL(t1.DepoAccount, ''), 1)-1)
	|		END AS СчетСписанияД,
	|	CASE
	|		WHEN t1.DepoAccountCP = NULL OR CHARINDEX(CHAR(3), ISNULL(t1.DepoAccountCP, ''), 1)<=0 
	|		THEN ISNULL(t1.DepoAccountCP, '')
	|		ELSE SUBSTRING(ISNULL(t1.DepoAccountCP, ''), 1, CHARINDEX(CHAR(3), ISNULL(t1.DepoAccountCP, ''), 1)-1)
	|	END AS СчетЗачисленияД,
	|	t1.Account	AS Счет,
	|	t1.AccountIn AS СчетПриемник,
	|	t1.UserId							AS UID, 
	|	t1.SecCode,
	|	t1.TradeSystem						AS Биржа, 
	|	t1.CommentDeny						AS CommentDeny,
	|	t1.DocComment						AS DocComment,
	|	CAST(CASE
	|		WHEN Right(SecCode,4) = 'EQTV'
	|			OR (FirmCode = 'SPBFUT' AND ClientID <> 'J400000')
	|			OR (ClientId <> '')
	|			THEN'Б'
	|		WHEN Right(SecCode,4) = 'EQTS' 
	|			OR (FirmCode = 'SPBFUT' AND ClientID = 'J400000')
	|			THEN 'Д'
	|		ELSE 'O'
	|	END AS VARCHAR(2) ) AS ТипДеятельности,
	|	CAST(Volume/100 AS NUMERIC(19,4)) AS Объем,
	|	CASE 
	|		WHEN LEFT(SecCode,3) = 'RUR'
	|			THEN 'SUR'
	|		WHEN LEFT(SecCode,3) = 'EUR'
	|			THEN 'EUR'
	|		WHEN LEFT(SecCode,3) = 'USD'
	|			THEN 'USD'
	|		ELSE 'SUR'
	|	END								AS CurrencyCode,
	|	ISNULL(PayNumber,'')			AS НомерПлатежа,
	|	ID,
	|	CP,
	|	DepoCP,
	|	ISNULL(t1.ExtID,'')				AS ExtID,
	|	SubDepoCP,
	|	CASE WHEN PayDate > 0 THEN convert(datetime, CONVERT(DATETIME, CONVERT(CHAR(8), PayDate))) ELSE 0 END AS PayDate,
	|	CASE WHEN DealDate > 0 THEN convert(datetime, CONVERT(DATETIME, CONVERT(CHAR(8), DealDate))) ELSE 0 END AS DealDate,
	|	t1.Place AS НаименованиеМестаРасчетов,
	|	t1.Comment AS Комментарий
	|FROM
	|	Instructions t1
	|INNER JOIN InstrTypes t2 
	|	ON t1.TypeId=t2.TypeId
	|WHERE
	|	t2.Type IN (4, 8, 9, 10, 11, 12, 13, 14, 15)
	|	AND (((t1.RegisterDate = "+НачалоПериодаДата+" AND t1.RegisterTime >= "+НачалоПериодаВремя+") OR (t1.RegisterDate > "+НачалоПериодаДата+")
	|			AND ((t1.RegisterDate = "+КонецПериодаДата+" AND t1.RegisterTime <= "+КонецПериодаВремя+") OR (t1.RegisterDate < "+КонецПериодаДата+")))
	|		OR (t1.AcceptDate > 0 AND 
	|		((t1.AcceptDate = "+НачалоПериодаДата+" AND t1.AcceptTime >= "+НачалоПериодаВремя+") OR (t1.AcceptDate > "+НачалоПериодаДата+"))
	|		AND ((t1.AcceptDate = "+КонецПериодаДата+" AND t1.AcceptTime <= "+КонецПериодаВремя+") OR (t1.AcceptDate < "+КонецПериодаДата+"))))";
	
	Возврат ТекстЗапроса;
	
КонецФункции

Функция sp_SignInstrSec(ПараметрыХранимойПроцедуры)
	
	ВходныеПараметры = Новый Структура;
	ВходныеПараметры.Вставить("QueryNo",	Число(ПараметрыХранимойПроцедуры.Number));
	ВходныеПараметры.Вставить("ClientID",	ПараметрыХранимойПроцедуры.ClientID);
	ВходныеПараметры.Вставить("Volume",		Число(ПараметрыХранимойПроцедуры.Volume)/100);
	ВходныеПараметры.Вставить("ValFee",		0);
	ВходныеПараметры.Вставить("ValDepoPay",	0);
	ВходныеПараметры.Вставить("ValCashPay",	0);
	ВходныеПараметры.Вставить("IntSecCode",	"EQTV");
	ВходныеПараметры.Вставить("BlockS",		0);
	ВходныеПараметры.Вставить("PutReason",	ПараметрыХранимойПроцедуры.PutReason);
	ВходныеПараметры.Вставить("FirmID",		ПараметрыХранимойПроцедуры.FirmCode);
	ВходныеПараметры.Вставить("SignFlag",	ПараметрыХранимойПроцедуры.SignFlag);
	ВходныеПараметры.Вставить("DealDate",	ПараметрыХранимойПроцедуры.DealDate);
	ВходныеПараметры.Вставить("PayDate",	ПараметрыХранимойПроцедуры.PayDate);
	ВыходныеПараметры = Новый Структура;
	ВыходныеПараметры.Вставить("ActionID",	0);
	
	АДО.ВыполнитьХранимуюПроцедуру("dbo.sp_SignInstrSec", ВходныеПараметры, ВыходныеПараметры);
	
	Возврат ВыходныеПараметры.ActionID;
	
КонецФункции

Процедура ИзвлечьИнформациюИзКомментария(НеторговоеПоручение)
	ОжидаемоеЧислоПодстрок = 4;
	Подстроки = СтрРазделить(НеторговоеПоручение.Комментарий, "/");
	Если Подстроки.Количество() = ОжидаемоеЧислоПодстрок Тогда
		НеторговоеПоручение.СчетДепоКлиентаКонтрагента = Подстроки[0];
		НеторговоеПоручение.НаименованиеКлиента = Подстроки[1];
		НеторговоеПоручение.Референс = Подстроки[2];
		НеторговоеПоручение.ДатаСоздания = СтроковыеФункцииКлиентСервер.СтрокаВДатуСоВременем(Подстроки[3]);
	Иначе
		Текст = "Формат комментария к поручению " + НеторговоеПоручение.НомерПоручения + " отличается от ожидаемого. "
				+ "Невозможно определить референс, наименования клиента, дату создания и счет депо клиента контрагента.";
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(Текст);
	КонецЕсли;
КонецПроцедуры

