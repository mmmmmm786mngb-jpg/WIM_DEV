////////////////////////////////////////////////////////////////////////////////
// ИНТЕРФЕЙС

Перем АДО Экспорт;

Процедура ИнициироватьСоединение(Параметры = Неопределено) Экспорт
	ВнешниеДанные.ДобавитьПараметрСоединения(Параметры, "ВнешнийИсточник", ПланыВидовХарактеристик.ВнешниеИсточники.QuikInstruction);
	ВнешниеДанные.ИнициироватьСоединение(АДО, "АДО", Параметры); 
КонецПроцедуры

Функция СтатусИсполненияПоручения(ActionId) Экспорт
	Результат = Новый Структура("Статус,Описание");
	ТекстЗапроса =
	"SELECT
	|	a.QueryStatus,
	|	a.ReplyText
	|FROM
	|	Actions a
	|WHERE
	|	a.ActionID = ?";
	ВходныеПараметры = Новый Структура;
	ВходныеПараметры.Вставить("Id", ActionID);	
	Actions = АДО.ВыполнитьЗапрос(ТекстЗапроса, ВходныеПараметры);
	
	Если Actions.Количество() = 1 Тогда
		Результат.Статус	= Actions[0].QueryStatus;
		Результат.Описание	= Actions[0].ReplyText;
	Иначе
		Результат.Статус	= 0;
		Результат.Описание	= "В БД QuikInstruction в таблице Actions " + ?(Actions.Количество() = 0, "не найдено ни", "найдено больше")+" одной записи с ActionID " + ActionID;
	КонецЕсли;
	Возврат Результат;
КонецФункции

Функция РезультатПодписанияПоручения(ИдентификаторЗагрузки, ВидОперации) Экспорт
	
	Результат = Новый Структура("Ошибка,ActionID", "", 0);
	ТекстЗапроса =
	"select
	|	i.Number,
	|	i.ClientID,
	|	i.PutReason,
	|	i.FirmCode,
	|	i.DealDate,
	|	i.PayDate,
	|	i.Volume
	|from
	|	Instructions i
	|where
	|	i.Number = ?
	|";
	ВходныеПараметры = Новый Структура;
	ВходныеПараметры.Вставить("Id", ИдентификаторЗагрузки);	
	Instructions = АДО.ВыполнитьЗапрос(ТекстЗапроса, ВходныеПараметры);
	Если Instructions.Количество() <> 1 Тогда
		Результат.Ошибка = "В БД QuikInstruction в таблице Instructions не найдено ни одной/"
			+ " больше одной записи с идентификатором загрузки " + ИдентификаторЗагрузки;
			
		Возврат Результат;
		
	КонецЕсли;
	
	Instructions.Колонки.Добавить("SignFlag", Новый ОписаниеТипов("Число",,,Новый КвалификаторыЧисла(2)));
	ПараметрыПодписи = Instructions[0];
	Если ВидОперации = Справочники.ВидыОпераций.СнятиеСДепонирования Тогда
		ПараметрыПодписи.SignFlag = 27;
	ИначеЕсли ВидОперации = Справочники.ВидыОпераций.Депонирование Тогда
		ПараметрыПодписи.SignFlag = 25;
	Иначе
		ПараметрыПодписи.SignFlag = 8;
	КонецЕсли;
	Результат.ActionId = sp_SignInstrSec(ПараметрыПодписи);
	Если Результат.ActionId = Null Тогда
		Результат.Ошибка = "ошибка при вызове хранимой процедуры";
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция НеторговыеПорученияЗаПериод(НачалоПериода, КонецПериода) Экспорт
	НеторговыеПоручения = АДО.ВыполнитьЗапрос(ТекстЗапросаSQLНеторговыеПоручения(НачалоПериода, КонецПериода));
	
	Колонки = НеторговыеПоручения.Колонки;
	НазваниеТипаСтрока = "Строка";
	Колонки.Добавить("НаименованиеКлиента", 		Новый ОписаниеТипов(НазваниеТипаСтрока, , Новый КвалификаторыСтроки(200)));
	Колонки.Добавить("СчетДепоКлиентаКонтрагента",	Новый ОписаниеТипов(НазваниеТипаСтрока, , Новый КвалификаторыСтроки(100)));
	Колонки.Добавить("Референс",					Новый ОписаниеТипов(НазваниеТипаСтрока, , Новый КвалификаторыСтроки(200)));
	Колонки.Добавить("ДатаСоздания", 				Новый ОписаниеТипов("Дата", , , Новый КвалификаторыДаты(ЧастиДаты.ДатаВремя)));
	
	Для Каждого НеторговоеПоручение Из НеторговыеПоручения Цикл
		// Извлечение информации в 4 дополнительные колонки из комментария
		Если Не ПустаяСтрока(НеторговоеПоручение.Комментарий) Тогда
			ИзвлечьИнформациюИзКомментария(НеторговоеПоручение);
		КонецЕсли;
		
		// Удаление нечитаемых символов в колонке CP
		ДопустимаяСтрока = СокрЛП(ОбщегоНазначенияКлиентСервер.УдалитьНедопустимыеСимволыXML(НеторговоеПоручение.CP));
		НеторговоеПоручение.CP = ДопустимаяСтрока;
	КонецЦикла;
	
	Возврат НеторговыеПоручения;
КонецФункции

Функция ОтменитьПоручение(ИдентификаторПоручения, ПричинаОтмены) Экспорт
	Результат = Ложь;
	// BSLLS:QueryParseError-off
	ТекстЗапроса =
	"DECLARE @ActionID INTEGER
	|
	|EXEC sp_DenyInstr
	|@ActionID OUT,
	|@QueryNo=?,
	|@CancelText=?";
	// BSLLS:QueryParseError-on
	ВходящиеПараметры = Новый Структура("QueryNo, CancelText", Число(ИдентификаторПоручения), ПричинаОтмены);
	
	ПараметрыВнешнегоИсточника = ВнешниеДанные.ПолучитьПараметрыВнешнегоИсточника(ПланыВидовХарактеристик.ВнешниеИсточники.QuikInstruction);
	ОписаниеВызова = РегистрыСведений.ЖурналРегистрацииВызовов.НовоеОписаниеВызова(
		"Сервер = " + ПараметрыВнешнегоИсточника.Сервер + "; База = " + ПараметрыВнешнегоИсточника.База,
		"QUIK.ОтменитьПоручение()");
	РегистрыСведений.ЖурналРегистрацииВызовов.ЗафиксироватьНачало(ОписаниеВызова);
	
	Попытка
		АДО.ВыполнитьЗапрос(ТекстЗапроса, ВходящиеПараметры);
		Результат = Истина;
	Исключение
		ТекстОшибки = "Не удалось отменить поручение № " + Строка(ИдентификаторПоручения) + " в QUIK!";
		ЗаписьЖурналаРегистрации("Обработка неторговых поручений", УровеньЖурналаРегистрации.Ошибка, , , ТекстОшибки);
		РегистрыСведений.ЖурналРегистрацииВызовов.ЗафиксироватьОшибку(ОписаниеВызова, ТекстОшибки);
	КонецПопытки;
	
	РегистрыСведений.ЖурналРегистрацииВызовов.ЗафиксироватьОкончание(ОписаниеВызова);
	Возврат Результат;
КонецФункции

Функция СтатусОтменыПоручения(ИдентификаторПоручения) Экспорт
	Результат = Новый Структура("Статус,Описание");
	// BSLLS:QueryParseError-off
	ТекстЗапроса =
	"SELECT TOP 1
	|	QueryStatus,
	|	ReplyText
	|FROM
	|	Actions a
	|WHERE
	|	ActionType = 4 AND
	|	QueryNo = ?
	|ORDER BY RegisterTime DESC";
	// BSLLS:QueryParseError-on
	ВходныеПараметры = Новый Структура;
	ВходныеПараметры.Вставить("QueryNo", ИдентификаторПоручения);
	Actions = АДО.ВыполнитьЗапрос(ТекстЗапроса, ВходныеПараметры);
	
	Если Actions.Количество() = 0 Тогда
		Результат.Статус = Неопределено;
		Результат.Описание = "В базе QuikInstruction не найдено команды на отмену поручения с идентификатором "
								+ Строка(ИдентификаторПоручения) + "!";
	Иначе 
		Результат.Статус = Actions[0].QueryStatus;
		Результат.Описание = Actions[0].ReplyText;
	КонецЕсли;
		
	Возврат Результат;
КонецФункции

