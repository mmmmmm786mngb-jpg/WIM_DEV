// Прочие процедуры и функции.

// Параметры:
//  ОбъектМетаданных - ОбъектМетаданныхКонстанта
//
Процедура ОбработатьКонстанты(ОбъектМетаданных)
	
	ЗначениеКонстанты = Константы[ОбъектМетаданных.Имя].Получить();
	МенеджерКонстанты = Константы[ОбъектМетаданных.Имя].СоздатьМенеджерЗначения();
	Обработано = Истина;
	ОбработатьСвойство(ЗначениеКонстанты, ОбъектМетаданных, Обработано);
	
	Если Обработано Тогда
		МенеджерКонстанты.Значение = ЗначениеКонстанты;
		УстановитьПривилегированныйРежим(Истина);
		ЗаписатьДанные(МенеджерКонстанты);
		УстановитьПривилегированныйРежим(Ложь);
	КонецЕсли;
	
КонецПроцедуры

Процедура ОбработатьСвойство(Свойство, ПараметрыСвойства, Обработано, ИзменяемыйОбъект = Неопределено)
	
	Обработано = Истина;
	ТипСвойства = ТипЗнч(Свойство);
	Если ТипСвойства = Тип("Строка") Тогда
		ОбработатьСтроку(Свойство, ПараметрыСвойства, Обработано, ИзменяемыйОбъект);
	ИначеЕсли ТипСвойства = Тип("Число") Тогда
		ОбработатьЧисло(Свойство, ПараметрыСвойства, Обработано);
	ИначеЕсли ТипСвойства = Тип("Булево") Тогда
		ОбработатьБулево(Свойство, ПараметрыСвойства, Обработано);
	ИначеЕсли ТипСвойства = Тип("Дата") Тогда
		ОбработатьДату(Свойство, ПараметрыСвойства, Обработано);
	ИначеЕсли ТипСвойства = Тип("ХранилищеЗначения") Тогда
		ОбработатьХранилищеЗначений(Свойство, ПараметрыСвойства, Обработано);
	Иначе
		Обработано = Ложь;
	КонецЕсли;
	
КонецПроцедуры

Процедура ОбработатьСтроку(Свойство, ПараметрыСвойства, Обработано, ИзменяемыйОбъект)
	
	Индекс = XMLСтрока(ГенераторСлучайныхЧисел.СлучайноеЧисло(100000, 999999));
	
	ПравилоОбработки = ПравилоОбработкиОбработатьСтроку(ПараметрыСвойства);
	
	ИмяПравилаСлучайноеЧислоСтрокой = "СлучайноеЧислоСтрокой";
	
	Если ПравилоОбработки = "Очистить" Тогда
		Свойство = "";
	ИначеЕсли ПравилоОбработки = "СлучайноеЗначение" Тогда
		СлучайнаяСтрока = Новый УникальныйИдентификатор;
		Свойство = СтрЗаменить(СлучайнаяСтрока, "-", "");
	ИначеЕсли ПравилоОбработки = "ИмяПоляИндекс" Тогда
		Свойство = ПараметрыСвойства.Имя + Индекс;
	ИначеЕсли ПравилоОбработки = "ИмяОбъектаИндекс" Тогда
		ИмяОбъекта = СтрРазделить(ПараметрыСвойства.ПолноеИмя, ".")[1];
		Свойство = ИмяОбъекта + Индекс;
	ИначеЕсли ПравилоОбработки = "ЛицензияСтрокой" Тогда
		Свойство = ЦифрыСДефисами(Свойство, 16, "4,10");
	ИначеЕсли ПравилоОбработки = "БукваБукваЦифраЦифра" Тогда
		Свойство = БукваБукваЦифраЦифра(Свойство, КодыСимволовСтроки);
	ИначеЕсли СтрНайти(ПравилоОбработки, ИмяПравилаСлучайноеЧислоСтрокой) > 0 Тогда
		Свойство = СлучайноеЧислоСтрокой(Свойство, ПараметрыСвойства, ПравилоОбработки, ИмяПравилаСлучайноеЧислоСтрокой);
	ИначеЕсли ПравилоОбработки = "СлучайноеФИО" Тогда
		Свойство = СлучайноеНаименованиеФизлица(Свойство, ИзменяемыйОбъект);
	ИначеЕсли ПравилоОбработки = "НаименованиеЮрЛиц" Тогда
		Свойство = СлучайноеНаименованиеЮридическогоЛица(Свойство, ИзменяемыйОбъект);
	ИначеЕсли ПравилоОбработки = "КодСчетаРазделаДепо" Тогда
		Свойство = КодСчетаИРазделаДепо(Свойство, ИзменяемыйОбъект);
	Иначе
		Обработано = Ложь;
	КонецЕсли;
	
КонецПроцедуры

Функция ПравилоОбработкиОбработатьСтроку(ПараметрыСвойства)
	
	ПравилоОбработки = ПравилоСтрока;
	Если ПараметрыСвойства.ПравилоОбработки.Количество() > 0 Тогда
		ПараметрыОбработкиСтроки = ПараметрыСвойства.ПравилоОбработки.НайтиПоЗначению("Строка");
		Если ПараметрыОбработкиСтроки <> Неопределено Тогда
			ПравилоОбработки = ПараметрыОбработкиСтроки.Представление;
		КонецЕсли;
	КонецЕсли;
	
	Возврат ПравилоОбработки;
	
КонецФункции

Процедура ОбработатьЧисло(Свойство, ПараметрыСвойства, Обработано)
	
	ПравилоОбработки = ПравилоЧисло;
	Если ПараметрыСвойства.ПравилоОбработки.Количество() > 0 Тогда
		ПараметрыОбработкиЧисел = ПараметрыСвойства.ПравилоОбработки.НайтиПоЗначению("Число");
		Если ПараметрыОбработкиЧисел <> Неопределено Тогда
			ПравилоОбработки = ПараметрыОбработкиЧисел.Представление;
		КонецЕсли;
	КонецЕсли;
	
	Если ПравилоОбработки = "Очистить" Тогда
		Свойство = 0;
	ИначеЕсли СтрНайти(ПравилоОбработки, "Умножить") > 0 Тогда
		ПравилоМассив = СтрРазделить(ПравилоОбработки, ";");
		Свойство = Свойство * Число(ПравилоМассив[1]);
	ИначеЕсли СтрНайти(ПравилоОбработки, "Разделить") > 0 Тогда
		ПравилоМассив = СтрРазделить(ПравилоОбработки, ";");
		Свойство = Свойство / Число(ПравилоМассив[1]);
	ИначеЕсли СтрНайти(ПравилоОбработки, "Прибавить") > 0 Тогда
		ПравилоМассив = СтрРазделить(ПравилоОбработки, ";");
		Свойство = Свойство + Число(ПравилоМассив[1]);
	ИначеЕсли СтрНайти(ПравилоОбработки, "Вычесть") > 0 Тогда
		ПравилоМассив = СтрРазделить(ПравилоОбработки, ";");
		Свойство = Свойство - Число(ПравилоМассив[1]);
	ИначеЕсли СтрНайти(ПравилоОбработки, "СлучайноеЗначение") > 0 Тогда
		ЧислоНулей = 6; // 1000000 - 1
		Попытка
			ВсегоЦифр = 1 * ПараметрыСвойства.ТипЗначения.КвалификаторыЧисла.Разрядность;
			ВсегоЦифрПослеЗапятой = 1 * ПараметрыСвойства.ТипЗначения.КвалификаторыЧисла.РазрядностьДробнойЧасти;
			ЧислоНулей =  Мин(ЧислоНулей, ВсегоЦифр - ВсегоЦифрПослеЗапятой);
		Исключение
			ЧислоНулей = 6;
		КонецПопытки;
		ПределЧисла = Pow(10, ЧислоНулей) - 1;
		
		Свойство = ГенераторСлучайныхЧисел.СлучайноеЧисло(1, ПределЧисла);
	Иначе
		Обработано = Ложь;
	КонецЕсли;
	
КонецПроцедуры

Процедура ОбработатьБулево(Свойство, ПараметрыСвойства, Обработано)
	
	ПравилоОбработки = ПравилоБулево;
	Если ПараметрыСвойства.ПравилоОбработки.Количество() > 0 Тогда
		ПараметрыОбработкиБулево = ПараметрыСвойства.ПравилоОбработки.НайтиПоЗначению("Булево");
		Если ПараметрыОбработкиБулево <> Неопределено Тогда
			ПравилоОбработки = ПараметрыОбработкиБулево.Представление;
		КонецЕсли;
	КонецЕсли;
	
	Если ПравилоОбработки = "Инвертировать" Тогда
		Свойство = Не Свойство;
	Иначе
		Обработано = Ложь;
	КонецЕсли;
	
КонецПроцедуры

Процедура ОбработатьДату(Свойство, ПараметрыСвойства, Обработано)
	
	ПравилоОбработки = ПравилоДата;
	Если ПараметрыСвойства.ПравилоОбработки.Количество() > 0 Тогда
		ПараметрыОбработкиДат = ПараметрыСвойства.ПравилоОбработки.НайтиПоЗначению("Дата");
		Если ПараметрыОбработкиДат <> Неопределено Тогда
			ПравилоОбработки = ПараметрыОбработкиДат.Представление;
		КонецЕсли;
	КонецЕсли;
	
	СуткиВСекундах = ОбщегоНазначенияПовтИсп.СекундВСутках();
	Если СтрНайти(ПравилоОбработки, "Прибавить") > 0 Тогда
		ПравилоМассив = СтрРазделить(ПравилоОбработки, ";");
		Свойство = Свойство + СуткиВСекундах * Число(ПравилоМассив[1]);
	ИначеЕсли СтрНайти(ПравилоОбработки, "Вычесть") > 0 Тогда
		ПравилоМассив = СтрРазделить(ПравилоОбработки, ";");
		Свойство = Свойство - СуткиВСекундах * Число(ПравилоМассив[1]);
	ИначеЕсли СтрНайти(ПравилоОбработки, "СлучайноеЗначение") > 0 Тогда
		Разница = ГенераторСлучайныхЧисел.СлучайноеЧисло(1, 730);
		Свойство = Свойство - СуткиВСекундах * Разница;
	Иначе
		Обработано = Ложь;
	КонецЕсли;
	
КонецПроцедуры

Процедура ОбработатьХранилищеЗначений(Свойство, ПараметрыСвойства, Обработано)
	
	ПравилоОбработки = ПравилоХранилищеЗначений;
	Если ПараметрыСвойства.ПравилоОбработки.Количество() > 0 Тогда
		ПараметрыОбработкиХранилищаЗначений = ПараметрыСвойства.ПравилоОбработки.НайтиПоЗначению("ХранилищеЗначений");
		Если ПараметрыОбработкиХранилищаЗначений <> Неопределено Тогда
			ПравилоОбработки = ПараметрыОбработкиХранилищаЗначений.Представление;
		КонецЕсли;
	КонецЕсли;
	
	Если ПравилоОбработки = "Очистить" Тогда
		Свойство = Неопределено;
	Иначе
		Обработано = Ложь;
	КонецЕсли;
	
КонецПроцедуры

Процедура ЗаписатьДанные(Знач Данные, Знач РегистрироватьНаУзлахПлановОбмена = Ложь, 
	Знач ВключитьБизнесЛогику = Ложь) Экспорт
	
	Данные.ОбменДанными.Загрузка = Не ВключитьБизнесЛогику;
	Данные.ДополнительныеСвойства.Вставить("СкрытиеКонфиденциальнойИнформации");
	
	Если Не РегистрироватьНаУзлахПлановОбмена Тогда
		Данные.ДополнительныеСвойства.Вставить("ОтключитьМеханизмРегистрацииОбъектов");
		Данные.ОбменДанными.Получатели.АвтоЗаполнение = Ложь;
	КонецЕсли;
	
	Данные.Записать();
	
КонецПроцедуры

Функция ПравилаОбработкиПоУмолчанию() Экспорт
	
	Правила = Новый Структура;
	Правила.Вставить("Строка", "СлучайноеЗначение");
	Правила.Вставить("Дата", "НеИзменять");
	Правила.Вставить("Булево", "НеИзменять");
	Правила.Вставить("ХранилищаЗначений", "Очистить");
	Правила.Вставить("Числа", "СлучайноеЗначение");
	Правила.Вставить("УдалятьФайлы", Истина);
	Правила.Вставить("ОчищатьПерсональныеНастройкиПользователей", Истина);
	
	Возврат Правила;
	
КонецФункции

Функция ОбщийМодуль(Имя)
	
	Если Метаданные.ОбщиеМодули.Найти(Имя) <> Неопределено Тогда
		// АПК:488-выкл ВычислитьВБезопасномРежиме не используется, чтобы избежать вызова ОбщийМодуль рекурсивно.
		УстановитьБезопасныйРежим(Истина);
		Модуль = Вычислить(Имя);
		// АПК:488-вкл
	Иначе
		Модуль = Неопределено;
	КонецЕсли;
	
	Возврат Модуль;
	
КонецФункции

#Область ПодготовкаДанных

Функция БазаДанныхФизлицаФИО()
	
	Результат = Новый Структура;
	Фамилии		 = Новый Массив;
	Имена		 = Новый Массив;
	Отчества	 = Новый Массив;
	ФамилииВсе	 = Новый Массив;
	ИменаВсе	 = Новый Массив;
	ОтчестваВсе	 = Новый Массив;
	ФамилииЖ	 = Новый Массив;
	ИменаЖ		 = Новый Массив;
	ОтчестваЖ	 = Новый Массив;
	ФамилииВсеЖ	 = Новый Массив;
	ИменаВсеЖ	 = Новый Массив;
	ОтчестваВсеЖ = Новый Массив;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ФизическиеЛица.Наименование КАК Наименование,
	|	ФизическиеЛица.Пол КАК Пол
	|ИЗ
	|	Справочник.ФизическиеЛица КАК ФизическиеЛица
	|ГДЕ
	|	ФизическиеЛица.Пол <> ЗНАЧЕНИЕ(Перечисление.ПолФизическихЛиц.ПустаяСсылка)
	|	И ФизическиеЛица.Наименование <> """"";
	РезультатЗапроса = Запрос.Выполнить();
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	ИндексДляФамилий = 0;
	ИндексДляИмен = 1;
	ИндексДляОтчеств = 2;
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		ФИО = СтрРазделить(ВыборкаДетальныеЗаписи.Наименование, " ", Ложь);
		Для Индекс = 0 По ФИО.ВГраница() Цикл
			Если Индекс = ИндексДляФамилий Тогда
				Фамилия = ФИО[Индекс];
				БуквыВНачале = БукваБукваЦифраЦифра(Сред(Фамилия, 1, 2), КодыСимволовСтроки);
				Фамилия = БуквыВНачале + Сред(Фамилия, 3);
				ФИО[Индекс] = Фамилия;
				
				ДобавитьФИО(Индекс, ФИО, ФамилииВсеЖ, ФамилииВсе, ВыборкаДетальныеЗаписи);
				
			КонецЕсли;
			Если Индекс = ИндексДляИмен Тогда
				
				ДобавитьФИО(Индекс, ФИО, ИменаВсеЖ, ИменаВсе, ВыборкаДетальныеЗаписи);
				
			КонецЕсли;
			Если Индекс = ИндексДляОтчеств Тогда
				
				ДобавитьФИО(Индекс, ФИО, ОтчестваВсеЖ, ОтчестваВсе, ВыборкаДетальныеЗаписи);
				
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;
	
	ОбщегоНазначенияКлиентСервер.ДополнитьМассив(Фамилии	, ФамилииВсе	, Истина);
	ОбщегоНазначенияКлиентСервер.ДополнитьМассив(Имена		, ИменаВсе		, Истина);
	ОбщегоНазначенияКлиентСервер.ДополнитьМассив(Отчества	, ОтчестваВсе	, Истина);
	ОбщегоНазначенияКлиентСервер.ДополнитьМассив(ФамилииЖ	, ФамилииВсеЖ	, Истина);
	ОбщегоНазначенияКлиентСервер.ДополнитьМассив(ИменаЖ		, ИменаВсеЖ		, Истина);
	ОбщегоНазначенияКлиентСервер.ДополнитьМассив(ОтчестваЖ	, ОтчестваВсеЖ	, Истина);
	
	Результат.Вставить("Фамилия"	, Фамилии);
	Результат.Вставить("Имя"		, Имена);
	Результат.Вставить("Отчество"	, Отчества);
	Результат.Вставить("ФамилияЖ"	, ФамилииЖ);
	Результат.Вставить("ИмяЖ"		, ИменаЖ);
	Результат.Вставить("ОтчествоЖ"	, ОтчестваЖ);
	
	Возврат Результат;
	
КонецФункции

Процедура ДобавитьФИО(Индекс, ФИО, ЧастьФИОЖ, ЧастьФИОВсе, ВыборкаДетальныеЗаписи)
	
	МинимальнаяДлинаИмени = 2;
	ЧастьФИО = ФИО[Индекс];
	Если ВРег(ЧастьФИО) = ЧастьФИО Тогда
		Возврат;
	КонецЕсли;
	Если СтрДлина(ЧастьФИО) > МинимальнаяДлинаИмени Тогда
		Если ВыборкаДетальныеЗаписи.Пол = Перечисления.ПолФизическихЛиц.Женский Тогда
			ЧастьФИОЖ.Добавить(ЧастьФИО);
		Иначе
			ЧастьФИОВсе.Добавить(ЧастьФИО);
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

Функция ЮридическиеЛицаКИзменению()
	
	Запрос = Новый Запрос;
	НаименованияИсключения = Новый СписокЗначений;
	НаименованияИсключения.Добавить("НКО НКЦ (АО)");
	НаименованияИсключения.Добавить("НКО АО НРД");
	НаименованияИсключения.Добавить("ЗАО АКБ ""Национальный Клиринговый Центр""");
	
	Запрос.УстановитьПараметр("НаименованияИсключения", НаименованияИсключения);
	Запрос.УстановитьПараметр("Эмитенты", Справочники.Контрагенты.Эмитенты);
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ЮридическиеЛица.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.ЮридическиеЛица КАК ЮридическиеЛица
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Контрагенты КАК Контрагенты
	|		ПО ЮридическиеЛица.Ссылка = Контрагенты.ЮридическиеФизическиеЛица
	|ГДЕ
	|	ВЫБОР
	|			КОГДА Контрагенты.Ссылка ЕСТЬ NULL
	|				ТОГДА ИСТИНА
	|			ИНАЧЕ НЕ Контрагенты.Ссылка В ИЕРАРХИИ (&Эмитенты)
	|		КОНЕЦ
	|	И НЕ ЮридическиеЛица.Наименование В (&НаименованияИсключения)
	|
	|СГРУППИРОВАТЬ ПО
	|	ЮридическиеЛица.Ссылка";
	
	РезультатЗапроса = Запрос.Выполнить().Выгрузить();
	
	Возврат РезультатЗапроса.ВыгрузитьКолонку("Ссылка");
	
КонецФункции

// Возвращает тип слова, в зависимости от символов в нем
//
// Параметры:
//  ПроверяемоеСлово - Строка - Про
// 
// Возвращаемое значение:
//   - Число - Тип слова: 1 - Кириллица, 2 - Латиница, 0 - Прочее (цифры и т.п.)
//
Функция ТипСловаПоСимволам(ПроверяемоеСлово)
	
	БуквВсего		 = СтрДлина(ПроверяемоеСлово);
	БуквКириллицей	 = КоличествоБуквПоТипуСимволов(ПроверяемоеСлово, "Кириллица");
	БуквЛатиницей	 = КоличествоБуквПоТипуСимволов(ПроверяемоеСлово, "Латиница");
	БуквПрочее		 = БуквВсего - БуквКириллицей - БуквЛатиницей;
	БуквМаксимум	 = Макс(БуквПрочее, БуквКириллицей, БуквЛатиницей);
	
	Если БуквМаксимум		 = БуквКириллицей Тогда
		Возврат 1;
	ИначеЕсли 	БуквМаксимум = БуквЛатиницей Тогда
		Возврат 2;
	Иначе
		Возврат 0;
	КонецЕсли;
	
КонецФункции

Функция КоличествоБуквПоТипуСимволов(ПроверяемоеСлово, ТипСимволов)
	
	Если ТипСимволов = "Кириллица" Тогда
		RegExp.Pattern		 = "[А-Яа-я]";	// ищем вхождения всех русских букв верхнего и нижнего регистров
		Matches				 = RegExp.Execute(ПроверяемоеСлово);
		БуквВСловеПоТипу = Matches.Count;
	ИначеЕсли ТипСимволов = "Латиница" Тогда
		RegExp.Pattern		 = "[A-Za-z]";	// ищем вхождения всех латинских букв верхнего и нижнего регистров
		Matches				 = RegExp.Execute(ПроверяемоеСлово);
		БуквВСловеПоТипу = Matches.Count;
	Иначе
		БуквВСловеПоТипу = 0;
	КонецЕсли;
	
	Возврат БуквВСловеПоТипу;
	
КонецФункции

Функция БазаДанныхСлов(ИмяСправочника, ИмяКолонки, Фильтр = Неопределено)
	
	РеквизитТипСлова		 = "ТипСлова";
	РеквизитКоличествоБукв	 = "КоличествоБукв";
	ОписаниеТипаЧисло		 = Новый ОписаниеТипов("Число");
	
	Словарь = Новый ТаблицаЗначений;
	Словарь.Колонки.Добавить(РеквизитТипСлова		, ОписаниеТипаЧисло);
	Словарь.Колонки.Добавить(РеквизитКоличествоБукв	, ОписаниеТипаЧисло);
	Словарь.Колонки.Добавить("Слово"				, Новый ОписаниеТипов("Строка"));
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ПоВсем", Фильтр = Неопределено);
	Запрос.УстановитьПараметр("Фильтр", Фильтр);
	МинимальнаяБазаНаименований = 1000;
	Если ЗначениеЗаполнено(Фильтр) И Фильтр.Количество() < МинимальнаяБазаНаименований Тогда
		Запрос.УстановитьПараметр("НужныДопНаименования", Истина);
	Иначе
		Запрос.УстановитьПараметр("НужныДопНаименования", Ложь);
	КонецЕсли;
	Запрос.Текст =
	// BSLLS:SelectTopWithoutOrderBy-off
	"ВЫБРАТЬ
	|	ЮридическиеЛица.Наименование КАК Источник
	|ИЗ
	|	Справочник.ЮридическиеЛица КАК ЮридическиеЛица
	|ГДЕ
	|	ВЫБОР
	|			КОГДА &ПоВсем
	|				ТОГДА ИСТИНА
	|			ИНАЧЕ ЮридическиеЛица.Ссылка В (&Фильтр)
	|		КОНЕЦ
	|
	|СГРУППИРОВАТЬ ПО
	|	ЮридическиеЛица.Наименование
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ ПЕРВЫЕ 50000
	|	ЮридическиеЛица.Наименование
	|ИЗ
	|	Справочник.ЮридическиеЛица КАК ЮридическиеЛица
	|ГДЕ
	|	&НужныДопНаименования
	|	И НЕ ЮридическиеЛица.Ссылка В (&Фильтр)
	|
	|СГРУППИРОВАТЬ ПО
	|	ЮридическиеЛица.Наименование
	|";
	// BSLLS:SelectTopWithoutOrderBy-on
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "ЮридическиеЛица", ИмяСправочника);
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "Наименование", ИмяКолонки);
	РезультатЗапроса = Запрос.Выполнить();
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		МассивСлов = РазложитьСтрокуВМассивСлов(ВыборкаДетальныеЗаписи.Источник, РазделителиСлов);
		Для Каждого СловоБезОбработки Из МассивСлов Цикл
			Слово = СокрЛП(СловоБезОбработки);
			НовоеСлово = Словарь.Добавить();
			НовоеСлово.ТипСлова	 = ТипСловаПоСимволам(Слово);
			НовоеСлово.КоличествоБукв		 = СтрДлина(Слово);
			НовоеСлово.Слово		 = Слово;
		КонецЦикла;
	КонецЦикла;
	Словарь.Свернуть("ТипСлова, КоличествоБукв, Слово");
	
	Результат = Новый ТаблицаЗначений;
	Результат.Колонки.Добавить(РеквизитТипСлова			, ОписаниеТипаЧисло);
	Результат.Колонки.Добавить(РеквизитКоличествоБукв	, ОписаниеТипаЧисло);
	Результат.Колонки.Добавить("Слова"					, Новый ОписаниеТипов("Массив"));
	
	Для Каждого СловарноеСлово Из Словарь Цикл
		СтруктураПоиска = Новый Структура("ТипСлова, КоличествоБукв", СловарноеСлово.ТипСлова, СловарноеСлово.КоличествоБукв);
		НайденПараграф = Результат.НайтиСтроки(СтруктураПоиска);
		Если НайденПараграф.Количество() = 0 Тогда
			Параграф = Результат.Добавить();
			Параграф.ТипСлова	 = СловарноеСлово.ТипСлова;
			Параграф.КоличествоБукв		 = СловарноеСлово.КоличествоБукв;
			Параграф.Слова			 = Новый Массив;
		Иначе
			Параграф = НайденПараграф[0];
		КонецЕсли;
		Параграф.Слова.Добавить(СловарноеСлово.Слово);
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция РазложитьСтрокуВМассивСлов(Знач Значение, Диапазоны, РазделителиСлов = Неопределено)
	Слова = Новый Массив;
	РазмерТекста = СтрДлина(Значение);
	НачалоСлова = 1;
	Для Позиция = 1 По РазмерТекста Цикл
		КодСимвола = КодСимвола(Значение, Позиция);
		Если ЭтоРазделительСлов(КодСимвола, Диапазоны, РазделителиСлов) Тогда
			Если Позиция <> НачалоСлова Тогда
				Слова.Добавить(Сред(Значение, НачалоСлова, Позиция - НачалоСлова));
			КонецЕсли;
			НачалоСлова = Позиция + 1;
		КонецЕсли;
	КонецЦикла;
	Если Позиция <> НачалоСлова Тогда
		Слова.Добавить(Сред(Значение, НачалоСлова, Позиция - НачалоСлова));
	КонецЕсли;
	Возврат Слова;
КонецФункции

Функция ЭтоРазделительСлов(КодСимвола, Диапазоны, РазделителиСлов = Неопределено)
	Если РазделителиСлов <> Неопределено Тогда
		Возврат СтрНайти(РазделителиСлов, Символ(КодСимвола)) > 0;
	КонецЕсли;
	Для Каждого Диапазон Из Диапазоны Цикл
		Если КодСимвола >= Диапазон.Мин И КодСимвола <= Диапазон.Макс Тогда
			Возврат Ложь;
		КонецЕсли;
	КонецЦикла;
	Возврат Истина;
КонецФункции

Функция ДиапазоныСлов()
	
	МинМакс = "Мин,Макс";
	Диапазоны = Новый Массив;
	Диапазоны.Добавить(Новый Структура(МинМакс, 48, 57));     // цифры
	Диапазоны.Добавить(Новый Структура(МинМакс, 65, 90));     // латиница большие
	Диапазоны.Добавить(Новый Структура(МинМакс, 97, 122));    // латиница маленькие
	Диапазоны.Добавить(Новый Структура(МинМакс, 1040, 1103)); // кириллица
	Диапазоны.Добавить(Новый Структура(МинМакс, 1025, 1025)); // символ "Ё"
	Диапазоны.Добавить(Новый Структура(МинМакс, 1105, 1105)); // символ "ё"
	Диапазоны.Добавить(Новый Структура(МинМакс, 95, 95));     // символ "_"
	Возврат Диапазоны;
	
КонецФункции

Функция КодыСимволов()
	
	Результат = Новый Структура;
	Результат.Вставить("Код0", КодСимвола("0"));
	Результат.Вставить("Код9", КодСимвола("9"));
	Результат.Вставить("КодA", КодСимвола("A"));
	Результат.Вставить("КодZ", КодСимвола("Z"));
	Результат.Вставить("Код_a", КодСимвола("a"));
	Результат.Вставить("Код_z", КодСимвола("z"));
	Результат.Вставить("КодА", КодСимвола("А"));
	Результат.Вставить("КодЯ", КодСимвола("Я"));
	Результат.Вставить("КодШ", КодСимвола("Ш"));
	Результат.Вставить("Код_а", КодСимвола("а"));
	Результат.Вставить("Код_я", КодСимвола("я"));
	
	Возврат Результат;
	
КонецФункции

Функция СлучайнаяДлинаСлова(ТипСлова, Знач ДлинаСлова)
	
	МинимальнаяДлина = 3;
	Если ДлинаСлова < МинимальнаяДлина Тогда
		Возврат ДлинаСлова;
	КонецЕсли;
	
	ПараметрыПоиска = Новый Структура("ТипСлова, КоличествоБукв", ТипСлова, ДлинаСлова);
	Параграфы = СловарьЮЛ.НайтиСтроки(ПараметрыПоиска);
	Если Параграфы.Количество() > 0 Тогда
		КоличествоСловСТакимКоличествомБукв = 1 + Параграфы[0].Слова.ВГраница();
	Иначе
		КоличествоСловСТакимКоличествомБукв = 0;
	КонецЕсли;
	Если КоличествоСловСТакимКоличествомБукв >= МинимальнаяДлина Тогда
		Возврат ДлинаСлова;
	КонецЕсли;
	
	ПараметрыПоиска = Новый Структура("ТипСлова", ТипСлова);
	Параграфы = СловарьЮЛ.НайтиСтроки(ПараметрыПоиска);
	ДлиныСлов = Новый Массив;
	Для Каждого Параграф Из Параграфы Цикл
		ДлиныСлов.Добавить(Параграф.КоличествоБукв);
	КонецЦикла;
	
	Если ДлиныСлов.Количество() = 0 Тогда
		Возврат ДлинаСлова;
	Иначе
		СлучайныйИндексДлины = ГенераторСлучайныхЧисел.СлучайноеЧисло(0, ДлиныСлов.ВГраница());
		Возврат ДлиныСлов[СлучайныйИндексДлины];
	КонецЕсли;
	
КонецФункции

Функция СимволКодировкиНормированный(Кодировка)
	
	СимволКодировки =  Символ(Кодировка);
	Если СимволКодировки = "Й" Тогда
		СимволКодировки = "И";
	КонецЕсли;
	Если СимволКодировки = "й" Тогда
		СимволКодировки = "и";
	КонецЕсли;
	Возврат СимволКодировки;
	
КонецФункции

Функция УдостоверениеЛичности(Паспорт)
	
	ДокументУдостоверяющийЛичность = "" + Паспорт.ДокументВид + ", серия: " + Паспорт.ДокументСерия + ", № " + Паспорт.ДокументНомер
		+ ", выдан: " + Формат(Паспорт.ДокументДатаВыдачи, "ДФ='дд ММММ гггг'; ДП='Не указано'") + " года, "
		+ Паспорт.ДокументКемВыдан + ", № подр. " + Паспорт.ДокументКодПодразделения; // BSLLS:Typo-off
	Если ДокументУдостоверяющийЛичность = ", серия: , № , выдан: Не указано года, , № подр. " Тогда // BSLLS:Typo-off
		ДокументУдостоверяющийЛичность = "";
	Иначе
		ДокументУдостоверяющийЛичность = СтрЗаменить(ДокументУдостоверяющийЛичность, "Не указано", "...");
	КонецЕсли;
	
	Возврат ДокументУдостоверяющийЛичность;
	
КонецФункции

#КонецОбласти

#Область ДополнительныеМетодыОбезличивания

// BSLLS:CognitiveComplexity-off
// BSLLS:CyclomaticComplexity-off

// Процедура - Заменить в связанных объектах
//
// Параметры:
//  ИзменяемыйОбъект		 - ПроизвольныйОбъект	 - Обезличиваемый объект
//  ИмяОбъекта				 - Строка				 - Условное наименование
//  ДополнительныеПараметры	 - Структура			 - Произвольные дополнительные параметры
//
Процедура ЗаменитьВСвязанныхОбъектах(ИзменяемыйОбъект, ИмяОбъекта, ДополнительныеПараметры)
	
	СвойствоНезависимости = "ЭтоНезависимыйОбъект";
	
	Если ИмяОбъекта = "ПаспортныеДанныеФизЛиц" Тогда
		
		ДокументУдостоверяющийЛичность = УдостоверениеЛичности(ИзменяемыйОбъект);
		
		// Контрагенты
		ОтборЮридическиеФизическиеЛица = Новый Структура("ЮридическиеФизическиеЛица", ИзменяемыйОбъект.ФизЛицо);
		КонтрагентыВыборка = Справочники.Контрагенты.Выбрать( , , ОтборЮридическиеФизическиеЛица);
		Пока КонтрагентыВыборка.Следующий() Цикл
			КонтрагентыОбъект = КонтрагентыВыборка.ПолучитьОбъект();
			КонтрагентыОбъект.ДокументУдостоверяющийЛичность = ДокументУдостоверяющийЛичность;
			КонтрагентыОбъект.ОбменДанными.Загрузка = Истина;
			КонтрагентыОбъект.Записать();
		КонецЦикла;
		
	КонецЕсли;
	
	Если ИмяОбъекта = "КодСчетаИРазделаДепо" Тогда
		
		ЭтоНезависимыйОбъект = Ложь;
		Если ДополнительныеПараметры.Свойство(СвойствоНезависимости , ЭтоНезависимыйОбъект) И ЭтоНезависимыйОбъект Тогда
			ИзменяемыйОбъект.Код = ДополнительныеПараметры.Код;
			ИзменяемыйОбъект.ОбменДанными.Загрузка = Истина;
			ИзменяемыйОбъект.Записать();
		КонецЕсли;
		
		// РазделыСчетаДепо
		РазделыСчетаДепоВыборка = Справочники.РазделыСчетаДепо.Выбрать( , ИзменяемыйОбъект.Ссылка);
		Пока РазделыСчетаДепоВыборка.Следующий() Цикл
			КодРазделаСчетаДепо = СокрЛП(РазделыСчетаДепоВыборка.Код);
			Если СтрНайти(КодРазделаСчетаДепо, ДополнительныеПараметры.КодБыл) > 0 Тогда
				
				РазделыСчетаДепоОбъект = РазделыСчетаДепоВыборка.ПолучитьОбъект();
				РазделыСчетаДепоОбъект.Код = СтрЗаменить(КодРазделаСчетаДепо, ДополнительныеПараметры.КодБыл, ДополнительныеПараметры.Код);
				РазделыСчетаДепоОбъект.ОбменДанными.Загрузка = Истина;
				РазделыСчетаДепоОбъект.Записать();
				
			КонецЕсли;
		КонецЦикла;
		
	КонецЕсли;
	
	Если ИмяОбъекта = "СлучайноеФИОКонтактныеЛица" Тогда
		
		ИзменяемыйОбъект.Фамилия	= ДополнительныеПараметры.Фамилия;
		ИзменяемыйОбъект.Имя 		= ДополнительныеПараметры.Имя;
		ИзменяемыйОбъект.Отчество	= ДополнительныеПараметры.Отчество;
		ЭтоНезависимыйОбъект = Ложь;
		Если ДополнительныеПараметры.Свойство(СвойствоНезависимости , ЭтоНезависимыйОбъект) И ЭтоНезависимыйОбъект Тогда
			ИзменяемыйОбъект.Наименование = ДополнительныеПараметры.Наименование;
			ИзменяемыйОбъект.ОбменДанными.Загрузка = Истина;
			ИзменяемыйОбъект.Записать();
		КонецЕсли;
		
	КонецЕсли;
	
	Если ИмяОбъекта = "СлучайноеФИОФизическиеЛица" Тогда
		
		ОтборФизЛицо = Новый Структура("ФизЛицо", ИзменяемыйОбъект.Ссылка);
		
		// ФИО
		Набор = РегистрыСведений.ФИОФизЛиц.СоздатьНаборЗаписей();
		Набор.Отбор.ФизЛицо.Установить(ИзменяемыйОбъект.Ссылка);
		Набор.Прочитать();
		Для Каждого Запись Из Набор Цикл
			Запись.Фамилия	= ДополнительныеПараметры.Фамилия;
			Запись.Имя 		= ДополнительныеПараметры.Имя;
			Запись.Отчество	= ДополнительныеПараметры.Отчество;
		КонецЦикла;
		Если Набор.Модифицированность() Тогда
			Набор.Записать();
		КонецЕсли;
		
		// Пользователи
		ПользователиВыборка = Справочники.Пользователи.Выбрать( , , ОтборФизЛицо);
		Пока ПользователиВыборка.Следующий() Цикл
			Если Не ЗначениеЗаполнено(ПользователиВыборка.ИдентификаторПользователяИБ) Тогда
				ПользователиОбъект = ПользователиВыборка.ПолучитьОбъект();
				ПользователиОбъект.Код = Строка(ПользователиОбъект.Ссылка.УникальныйИдентификатор());
				ПользователиОбъект.Наименование = ДополнительныеПараметры.Наименование;
				ПользователиОбъект.ОбменДанными.Загрузка = Истина;
				ПользователиОбъект.Записать();
			КонецЕсли;
		КонецЦикла;
		
		// Сотрудники
		СотрудникиВыборка = Справочники.Сотрудники.Выбрать( , , ОтборФизЛицо);
		Пока СотрудникиВыборка.Следующий() Цикл
			СотрудникиОбъект = СотрудникиВыборка.ПолучитьОбъект();
			СотрудникиОбъект.Наименование = ДополнительныеПараметры.Наименование;
			СотрудникиОбъект.ОбменДанными.Загрузка = Истина;
			СотрудникиОбъект.Записать();
		КонецЦикла;
		
	КонецЕсли;
	
	Если ИмяОбъекта = "СлучайноеНаименованиеЮридическогоЛица" Тогда
		
		// Собственные поля справочника юридические лица
		ИзменяемыйОбъект.ПолноеНаименование					 = ДополнительныеПараметры.Наименование;
		ИзменяемыйОбъект.ПолноеНаименованиеНаАнглийскомЯзыке = ОбщегоНазначенияКлиентСервер.Транслит(ДополнительныеПараметры.Наименование);
		ЭтоНезависимыйОбъект = Ложь;
		Если ДополнительныеПараметры.Свойство(СвойствоНезависимости , ЭтоНезависимыйОбъект) И ЭтоНезависимыйОбъект Тогда
			ИзменяемыйОбъект.Наименование = ДополнительныеПараметры.Наименование;
			ИзменяемыйОбъект.ОбменДанными.Загрузка = Истина;
			ИзменяемыйОбъект.Записать();
		КонецЕсли;
		
	КонецЕсли;
	
	Если ИмяОбъекта = "СлучайноеФИОФизическиеЛица" Или ИмяОбъекта = "СлучайноеНаименованиеЮридическогоЛица" Тогда
		
		// ФормыW8
		ОтборЛицо = Новый Структура("Лицо", ИзменяемыйОбъект.Ссылка);
		ФормыВэ8Выборка = Справочники.ФормыW8.Выбрать( , , ОтборЛицо);
		Пока ФормыВэ8Выборка.Следующий() Цикл
			ФормыВэ8Объект = ФормыВэ8Выборка.ПолучитьОбъект();
			ФормыВэ8Объект.Наименование = ДополнительныеПараметры.Наименование + " (" + ФормыВэ8Выборка.ТипФормы + ")";
			ФормыВэ8Объект.НаименованиеЛицаАнгл = ОбщегоНазначенияКлиентСервер.Транслит(ФормыВэ8Объект.Наименование);
			ФормыВэ8Объект.ОбменДанными.Загрузка = Истина;
			ФормыВэ8Объект.Записать();
		КонецЦикла;
		
		// Контрагенты
		ОтборЮридическиеФизическиеЛица = Новый Структура("ЮридическиеФизическиеЛица", ИзменяемыйОбъект.Ссылка);
		КонтрагентыВыборка = Справочники.Контрагенты.Выбрать( , , ОтборЮридическиеФизическиеЛица);
		СчетчикКонтрагентов = 0;
		Пока КонтрагентыВыборка.Следующий() Цикл
			Если Не КонтрагентыВыборка.Родитель = Справочники.Контрагенты.Эмитенты Тогда
				СчетчикКонтрагентов = СчетчикКонтрагентов + 1;
				КонтрагентыОбъект = КонтрагентыВыборка.ПолучитьОбъект();
				КонтрагентыОбъект.Наименование = ДополнительныеПараметры.Наименование;
				Если СчетчикКонтрагентов > 1 Тогда
					КонтрагентыОбъект.Наименование = КонтрагентыОбъект.Наименование + " " + СокрЛП(КонтрагентыОбъект.Код);
				КонецЕсли;
				КонтрагентыОбъект.НаименованиеПолное = КонтрагентыОбъект.Наименование;
				КонтрагентыОбъект.АнглийскоеНаименование = ОбщегоНазначенияКлиентСервер.Транслит(КонтрагентыОбъект.Наименование);
				КонтрагентыОбъект.TIN = БукваБукваЦифраЦифра(КонтрагентыОбъект.TIN, КодыСимволовСтроки);
				КонтрагентыОбъект.ИНН = БукваБукваЦифраЦифра(КонтрагентыОбъект.ИНН, КодыСимволовСтроки);
				КонтрагентыОбъект.КПП = БукваБукваЦифраЦифра(КонтрагентыОбъект.КПП, КодыСимволовСтроки);
				КонтрагентыОбъект.КодПоОКПО = БукваБукваЦифраЦифра(КонтрагентыОбъект.КодПоОКПО, КодыСимволовСтроки);
				КонтрагентыОбъект.ОбменДанными.Загрузка = Истина;
				КонтрагентыОбъект.Записать();
			КонецЕсли;
		КонецЦикла;
		
	КонецЕсли;
	
КонецПроцедуры
// BSLLS:CognitiveComplexity-on
// BSLLS:CyclomaticComplexity-on

Функция КодСчетаИРазделаДепо(Знач Свойство, ИзменяемыйОбъект)
	
	Свойство			 = СокрЛП(Свойство);
	КодБыл				 = Свойство;
	МинимальнаяДлинаКода = 4;
	ДлинаКода			 = СтрДлина(Свойство);
	Если ДлинаКода < МинимальнаяДлинаКода Тогда
		Возврат Свойство;
	КонецЕсли;
	
	Свойство = БукваБукваЦифраЦифра(Свойство, КодыСимволовСтроки);
	
	ДополнительныеПараметры = Новый Структура;
	ДополнительныеПараметры.Вставить("КодБыл" 	, КодБыл);
	ДополнительныеПараметры.Вставить("Код"		, Свойство);
	Если ТипЗнч(ИзменяемыйОбъект) = Тип("СправочникОбъект.СчетаДепо") Тогда
		ЗаменитьВСвязанныхОбъектах(ИзменяемыйОбъект, "КодСчетаИРазделаДепо", ДополнительныеПараметры);
	КонецЕсли;
	
	Возврат Свойство;
	
КонецФункции

Функция СлучайноеНаименованиеЮридическогоЛица(Знач Свойство, ИзменяемыйОбъект)
	
	Если ТипЗнч(ИзменяемыйОбъект) = Тип("СправочникОбъект.ЮридическиеЛица") Тогда
		РазрешенноеКИзменениюЮЛ = ОбезличиваемыеЮЛ.Найти(ИзменяемыйОбъект.Ссылка);
		Если РазрешенноеКИзменениюЮЛ = Неопределено Тогда
			Возврат Свойство; // Не менять для эмитентов
		КонецЕсли;
	КонецЕсли;
	
	МассивСлов = РазложитьСтрокуВМассивСлов(Свойство, РазделителиСлов);
	МассивСловНовый = Новый Массив;
	Для Каждого СловоБезОбработки Из МассивСлов Цикл
		Слово = СокрЛП(СловоБезОбработки);
		ТипСлова		 = ТипСловаПоСимволам(Слово);
		КоличествоБуквИсточника = СтрДлина(Слово);
		КоличествоБукв			 = СлучайнаяДлинаСлова(ТипСлова, КоличествоБуквИсточника);
		
		ПараметрыПоиска = Новый Структура("ТипСлова, КоличествоБукв", ТипСлова, КоличествоБукв);
		Параграфы = СловарьЮЛ.НайтиСтроки(ПараметрыПоиска);
		Если КоличествоБуквИсточника = 1 Или Параграфы.Количество() = 0 Тогда
			СлучайноеСлово = Слово;
		Иначе
			Слова = Параграфы[0].Слова;
			СлучайныйИндексСлова = ГенераторСлучайныхЧисел.СлучайноеЧисло(0, Слова.ВГраница());
			СлучайноеСлово = Слова[СлучайныйИндексСлова];
		КонецЕсли;
		МассивСловНовый.Добавить(СлучайноеСлово);
		
	КонецЦикла;
	Свойство = СтрСоединить(МассивСловНовый, " ");
	
	ДополнительныеПараметры = Новый Структура;
	ДополнительныеПараметры.Вставить("Наименование", Свойство);
	Если ТипЗнч(ИзменяемыйОбъект) = Тип("СправочникОбъект.ЮридическиеЛица") Тогда
		ЗаменитьВСвязанныхОбъектах(ИзменяемыйОбъект, "СлучайноеНаименованиеЮридическогоЛица", ДополнительныеПараметры);
	КонецЕсли;
	
	Возврат Свойство;
	
КонецФункции

Функция СлучайноеНаименованиеФизлица(Знач Свойство, ИзменяемыйОбъект)
	
	Попытка
		ИзменяемыйОбъектПол = ИзменяемыйОбъект.Пол;
	Исключение
		СлучайныйПол = ГенераторСлучайныхЧисел.СлучайноеЧисло(0, 1);
		ИзменяемыйОбъектПол = ?(СлучайныйПол = 0, Перечисления.ПолФизическихЛиц.Женский, Перечисления.ПолФизическихЛиц.Мужской);
	КонецПопытки;
	
	Свойство = "";
	ИндексФамилии	 = ГенераторСлучайныхЧисел.СлучайноеЧисло(0, ФизлицаФИО.Фамилия.ВГраница());
	ИндексИмени		 = ГенераторСлучайныхЧисел.СлучайноеЧисло(0, ФизлицаФИО.Имя.ВГраница());
	ИндексОтчества	 = ГенераторСлучайныхЧисел.СлучайноеЧисло(0, ФизлицаФИО.Отчество.ВГраница());
	ИндексФамилииЖ	 = ГенераторСлучайныхЧисел.СлучайноеЧисло(0, ФизлицаФИО.ФамилияЖ.ВГраница());
	ИндексИмениЖ	 = ГенераторСлучайныхЧисел.СлучайноеЧисло(0, ФизлицаФИО.ИмяЖ.ВГраница());
	ИндексОтчестваЖ	 = ГенераторСлучайныхЧисел.СлучайноеЧисло(0, ФизлицаФИО.ОтчествоЖ.ВГраница());
	
	ДополнительныеПараметры = Новый Структура;
	Если ИзменяемыйОбъектПол = Перечисления.ПолФизическихЛиц.Женский Тогда
		ДополнительныеПараметры.Вставить("Фамилия"	, ФизлицаФИО.ФамилияЖ[ИндексФамилииЖ]);
		ДополнительныеПараметры.Вставить("Имя"		, ФизлицаФИО.ИмяЖ[ИндексИмениЖ]);
		ДополнительныеПараметры.Вставить("Отчество"	, ФизлицаФИО.ОтчествоЖ[ИндексОтчестваЖ]);
	Иначе
		ДополнительныеПараметры.Вставить("Фамилия"	, ФизлицаФИО.Фамилия[ИндексФамилии]);
		ДополнительныеПараметры.Вставить("Имя"		, ФизлицаФИО.Имя[ИндексИмени]);
		ДополнительныеПараметры.Вставить("Отчество"	, ФизлицаФИО.Отчество[ИндексОтчества]);
	КонецЕсли;
	Свойство = ДополнительныеПараметры.Фамилия + " " + ДополнительныеПараметры.Имя + " " + ДополнительныеПараметры.Отчество;
	ДополнительныеПараметры.Вставить("Наименование", Свойство);
	
	ТипЗначенияИзменяемогоОбъекта = ТипЗнч(ИзменяемыйОбъект);
	Если ТипЗначенияИзменяемогоОбъекта = Тип("СправочникОбъект.ФизическиеЛица") Тогда
		ЗаменитьВСвязанныхОбъектах(ИзменяемыйОбъект, "СлучайноеФИОФизическиеЛица", ДополнительныеПараметры);
	КонецЕсли;
	Если ТипЗначенияИзменяемогоОбъекта = Тип("СправочникОбъект.КонтактныеЛица") Тогда
		ЗаменитьВСвязанныхОбъектах(ИзменяемыйОбъект, "СлучайноеФИОКонтактныеЛица", ДополнительныеПараметры);
	КонецЕсли;
	
	Возврат Свойство;
	
КонецФункции

Функция ЦифрыСДефисами(Знач Свойство, ВсегоСимволов, НомераДефисов)
	
	Свойство = "";
	
	Для Индекс = 1 По ВсегоСимволов Цикл
		Дефисы = СтрРазделить(НомераДефисов, ",", Ложь);
		Если Дефисы.Найти(Строка(Индекс)) <> Неопределено Тогда
			СимволШаблона = "-";
		Иначе
			СлучайнаяЦифра = ГенераторСлучайныхЧисел.СлучайноеЧисло(0, 9);
			СимволШаблона = Формат(СлучайнаяЦифра, "ЧЦ=1; ЧН=0");
		КонецЕсли;
		Свойство = Свойство + СимволШаблона;
	КонецЦикла;
	
	Возврат Свойство;
	
КонецФункции

Функция БукваБукваЦифраЦифра(Знач Свойство, КодыСимволовСтроки)
	
	Результат		 = "";
	Свойство		 = СокрЛП(Свойство);
	
	ДлинаСтроки		 = СтрДлина(Свойство);
	Если ДлинаСтроки = 0 Тогда
		Возврат Результат;
	КонецЕсли;
	
	Для Индекс = 1 По ДлинаСтроки Цикл
		СимволСтроки = Сред(Свойство, Индекс, 1);
		Кодировка	 = КодСимвола(СимволСтроки);
		Если		 Кодировка >= КодыСимволовСтроки.Код0 И Кодировка <= КодыСимволовСтроки.Код9 Тогда // 0-9
			Кодировка = ГенераторСлучайныхЧисел.СлучайноеЧисло(КодыСимволовСтроки.Код0, КодыСимволовСтроки.Код9);
		ИначеЕсли	 Кодировка >= КодыСимволовСтроки.КодA И Кодировка <= КодыСимволовСтроки.КодZ Тогда // A-Z
			Кодировка = ГенераторСлучайныхЧисел.СлучайноеЧисло(КодыСимволовСтроки.КодA, КодыСимволовСтроки.КодZ);
		ИначеЕсли	 Кодировка >= КодыСимволовСтроки.Код_a И Кодировка <= КодыСимволовСтроки.Код_z Тогда // a-z
			Кодировка = ГенераторСлучайныхЧисел.СлучайноеЧисло(КодыСимволовСтроки.Код_a, КодыСимволовСтроки.Код_z);
		ИначеЕсли	 Кодировка >= КодыСимволовСтроки.КодА И Кодировка <= КодыСимволовСтроки.КодЯ Тогда // А-Я
			Кодировка = ГенераторСлучайныхЧисел.СлучайноеЧисло(КодыСимволовСтроки.КодА, КодыСимволовСтроки.КодШ); // Большые Ъ Ь искл.
		ИначеЕсли	 Кодировка >= КодыСимволовСтроки.Код_а И Кодировка <= КодыСимволовСтроки.Код_я Тогда // а-я
			Кодировка = ГенераторСлучайныхЧисел.СлучайноеЧисло(КодыСимволовСтроки.Код_а, КодыСимволовСтроки.Код_я);
		Иначе
			Кодировка = КодСимвола(СимволСтроки);
		КонецЕсли;
		
		СимволКодировки = СимволКодировкиНормированный(Кодировка);
		Результат = Результат + СимволКодировки;
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция СлучайноеЧислоСтрокой(Знач Свойство, ПараметрыСвойства, ПравилоОбработки, ИмяПравилаСлучайноеЧислоСтрокой)
	
	Попытка
		МаксимальноеЧислоСимволов  = 28;
		ДлинаСтроки = Сред(ПравилоОбработки, СтрДлина(ИмяПравилаСлучайноеЧислоСтрокой) + 1);
		Если ЗначениеЗаполнено(ДлинаСтроки) Тогда
			ВсегоСимволов = 1 * ДлинаСтроки;
		Иначе
			ВсегоСимволов = 1 * ПараметрыСвойства.ТипЗначения.КвалификаторыСтроки.Длина;
		КонецЕсли;
		Если ВсегоСимволов = 0 Тогда
			ВсегоСимволов = МаксимальноеЧислоСимволов;
		КонецЕсли;
		Свойство = "";
		Для Индекс = 1 По ВсегоСимволов Цикл
			СлучайнаяЦифра = ГенераторСлучайныхЧисел.СлучайноеЧисло(0, 9);
			Свойство = Свойство + Формат(СлучайнаяЦифра, "ЧЦ=1; ЧН=0");
		КонецЦикла;
	Исключение
		СлучайнаяСтрока = Новый УникальныйИдентификатор;
		Свойство = СтрЗаменить(СлучайнаяСтрока, "-", "");
	КонецПопытки;
	
	Возврат Свойство;
	
КонецФункции

Процедура ИзменитьДвиженияЦенныхБумаг()
	
	ИзменитьДвиженияЦенныхБумагВводНачальныхОстатков();
	
	ИзменитьДвиженияЦенныхБумагЗачислениеЦенныхБумаг();
	
	ИзменитьДвиженияЦенныхБумагПогашениеВНоль();
	
КонецПроцедуры

Процедура ИзменитьДвиженияЦенныхБумагВводНачальныхОстатков()
	
	ВремяНачалаФормирования = ОценкаПроизводительности.НачатьЗамерВремени();
	ВесЗамера = 0;
	
	СтоПроцентов = 100;
	Десять = 10;
	Выборка = Документы.ВводОстатковЦБ.Выбрать( , , , "Дата");
	Пока Выборка.Следующий() Цикл
		Если Не Выборка.Проведен Тогда
			Продолжить;
		КонецЕсли;
		ВводОстатковЦБ = Выборка.ПолучитьОбъект();
		Для Каждого Остаток Из ВводОстатковЦБ.Остатки Цикл
			ВесЗамера = ВесЗамера + 1;
			СлучайныйПроцент = ГенераторСлучайныхЧисел.СлучайноеЧисло(1, СтоПроцентов);
			КоличествоСтарое = Остаток.Количество;
			КоличествоНовое = Окр(КоличествоСтарое * (1 + СлучайныйПроцент / СтоПроцентов));
			Если КоличествоНовое = КоличествоСтарое Тогда
				УвеличитьНа = ГенераторСлучайныхЧисел.СлучайноеЧисло(1, Десять);
				КоличествоНовое = КоличествоНовое + УвеличитьНа;
			КонецЕсли;
			Остаток.Количество = Окр(КоличествоНовое);
		КонецЦикла;
		ВводОстатковЦБ.Записать(РежимЗаписиДокумента.Проведение, РежимПроведенияДокумента.Неоперативный);
	КонецЦикла;
	ОценкаПроизводительности.ЗакончитьЗамерВремени(
		"СкрытиеКонфиденциальнойИнформации.ИзменитьВводНачальныхОстатков", ВремяНачалаФормирования, ВесЗамера);
	
КонецПроцедуры

Процедура ИзменитьДвиженияЦенныхБумагЗачислениеЦенныхБумаг()
	
	ВремяНачалаФормирования = ОценкаПроизводительности.НачатьЗамерВремени();
	ВесЗамера = 0;
	
	РегистрыНакопления.ОстаткиЦБ.УстановитьИспользованиеИтогов(Ложь);
	РегистрыНакопления.ОстаткиЦБДепозитарийМХ.УстановитьИспользованиеИтогов(Ложь);
	РегистрыНакопления.ОстаткиЦБМестоРасчетов.УстановитьИспользованиеИтогов(Ложь);
	
	СтоПроцентов = 100;
	Десять = 10;
	Выборка = Документы.иц_СводноеПоручение.Выбрать( , , , "Дата");
	Пока Выборка.Следующий() Цикл
		Если Не Выборка.Проведен Тогда
			Продолжить;
		КонецЕсли;
		иц_СводноеПоручение = Выборка.ПолучитьОбъект();
		Для Каждого Оборот Из иц_СводноеПоручение.СоставПоручения Цикл
			Если Оборот.ВидОперацииД = Справочники.ВидыОпераций.Депонирование Тогда
				ВесЗамера = ВесЗамера + 1;
				СлучайныйПроцент = ГенераторСлучайныхЧисел.СлучайноеЧисло(1, СтоПроцентов);
				КоличествоСтарое = Оборот.Количество;
				КоличествоНовое = Окр(КоличествоСтарое * (1 + СлучайныйПроцент / СтоПроцентов));
				Если КоличествоНовое = КоличествоСтарое Тогда
					УвеличитьНа = ГенераторСлучайныхЧисел.СлучайноеЧисло(1, Десять);
					КоличествоНовое = КоличествоНовое + УвеличитьНа;
				КонецЕсли;
				
				ИзменитьОперациюПоСводномуПоручению(иц_СводноеПоручение.Ссылка, Оборот, КоличествоНовое);
				ИзменитьСводныйОтчетПоСводномуПоручению(иц_СводноеПоручение.Ссылка, Оборот, КоличествоНовое);
				
				Оборот.Количество = КоличествоНовое;
			КонецЕсли;
		КонецЦикла;
		иц_СводноеПоручение.ОбменДанными.Загрузка = Истина;
		иц_СводноеПоручение.Записать();
		
	КонецЦикла;
	
	ОценкаПроизводительности.ЗакончитьЗамерВремени(
		"СкрытиеКонфиденциальнойИнформации.ИзменитьЗачислениеЦенныхБумаг", ВремяНачалаФормирования, ВесЗамера);
	
	ВремяНачалаФормирования = ОценкаПроизводительности.НачатьЗамерВремени();
	ВесЗамера = 3;
	
	РегистрыНакопления.ОстаткиЦБ.УстановитьИспользованиеИтогов(Истина);
	РегистрыНакопления.ОстаткиЦБДепозитарийМХ.УстановитьИспользованиеИтогов(Истина);
	РегистрыНакопления.ОстаткиЦБМестоРасчетов.УстановитьИспользованиеИтогов(Истина);
	
	ОценкаПроизводительности.ЗакончитьЗамерВремени(
		"СкрытиеКонфиденциальнойИнформации.УстановитьИспользованиеИтогов", ВремяНачалаФормирования, ВесЗамера);
	
КонецПроцедуры

Процедура ИзменитьОперациюПоСводномуПоручению(СводноеПоручениеСсылка, СтрокаСводногоПоручения, КоличествоНовое)
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ОперацииЦБ.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.ОперацииЦБ КАК ОперацииЦБ
	|ГДЕ
	|	ОперацииЦБ.Проведен
	|	И ОперацииЦБ.ВидОперацииД = &ВидОперацииД
	|	И ОперацииЦБ.Количество = &Количество
	|	И ОперацииЦБ.ЦБ = &ЦБ
	|	И ОперацииЦБ.ДокументОснование = &ДокументОснование
	|	И ОперацииЦБ.СчетДепо = &СчетДепо
	|	И ОперацииЦБ.РазделСчетаДепо = &РазделСчетаДепо";
	
	Запрос.УстановитьПараметр("ВидОперацииД",		 СтрокаСводногоПоручения.ВидОперацииД);
	Запрос.УстановитьПараметр("Количество",			 СтрокаСводногоПоручения.Количество);
	Запрос.УстановитьПараметр("РазделСчетаДепо",	 СтрокаСводногоПоручения.РазделСчетаДепо);
	Запрос.УстановитьПараметр("ДокументОснование",	 СводноеПоручениеСсылка);
	Запрос.УстановитьПараметр("СчетДепо",			 СтрокаСводногоПоручения.СчетДепо);
	Запрос.УстановитьПараметр("ЦБ",					 СтрокаСводногоПоручения.ЦеннаяБумага);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		ОперацияЦБ = ВыборкаДетальныеЗаписи.Ссылка.ПолучитьОбъект();
		ОперацияЦБ.Количество = КоличествоНовое;
		ОперацияЦБ .ОбменДанными.Загрузка = Истина;
		ОперацияЦБ.Записать();
		// Регистры операции
		ИзменитьДвиженияЦенныхБумагПоОперации(РегистрыНакопления.ОстаткиЦБ,				 ОперацияЦБ.Ссылка, КоличествоНовое);
		ИзменитьДвиженияЦенныхБумагПоОперации(РегистрыНакопления.ОстаткиЦБДепозитарийМХ, ОперацияЦБ.Ссылка, КоличествоНовое);
		ИзменитьДвиженияЦенныхБумагПоОперации(РегистрыНакопления.ОстаткиЦБМестоРасчетов, ОперацияЦБ.Ссылка, КоличествоНовое);
	КонецЦикла;
	
КонецПроцедуры

Процедура ИзменитьДвиженияЦенныхБумагПоОперации(Регистр, ДокументРегистратор, НовыйОстаток)
	
	Набор = Регистр.СоздатьНаборЗаписей();
	Набор.Отбор.Регистратор.Установить(ДокументРегистратор);
	Набор.Прочитать();
	Если Набор.Количество() > 0 Тогда
		Для Каждого Движение Из Набор Цикл
			Совпадение =
				Движение.СчетДепо			 = ДокументРегистратор.СчетДепо
				И Движение.РазделСчетаДепо	 = ДокументРегистратор.РазделСчетаДепо
				И Движение.ЦБ				 = ДокументРегистратор.ЦБ
				И Движение.СчетДепоМХ		 = ДокументРегистратор.СчетДепоМХ
				И Движение.РазделСчетаДепоМХ = ДокументРегистратор.РазделСчетаДепоМХ;
			Если Совпадение Тогда
				Движение.Количество = НовыйОстаток;
			КонецЕсли;
		КонецЦикла;
		Набор.Записать(Истина);
	КонецЕсли;
	
КонецПроцедуры

Процедура ИзменитьСводныйОтчетПоСводномуПоручению(СводноеПоручениеСсылка, СтрокаСводногоПоручения, КоличествоНовое)
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	СводныйОтчетОСовершенныхОперациях.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.СводныйОтчетОСовершенныхОперациях.Операции КАК СводныйОтчетОСовершенныхОперацияхОперации
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.СводныйОтчетОСовершенныхОперациях КАК СводныйОтчетОСовершенныхОперациях
	|		ПО СводныйОтчетОСовершенныхОперацияхОперации.Ссылка = СводныйОтчетОСовершенныхОперациях.Ссылка
	|ГДЕ
	|	СводныйОтчетОСовершенныхОперациях.Проведен
	|	И СводныйОтчетОСовершенныхОперацияхОперации.ТипОперации = &ВидОперацииД
	|	И СводныйОтчетОСовершенныхОперацияхОперации.ОборотЗачислено = &Количество
	|	И СводныйОтчетОСовершенныхОперацияхОперации.ЦБ = &ЦБ
	|	И СводныйОтчетОСовершенныхОперацияхОперации.ОснованиеОперации = &ДокументОснование
	|	И СводныйОтчетОСовершенныхОперациях.СчетДепо = &СчетДепо
	|	И СводныйОтчетОСовершенныхОперацияхОперации.РазделСчетаДепо = &РазделСчетаДепо";
	
	Запрос.УстановитьПараметр("ВидОперацииД",		 СтрокаСводногоПоручения.ВидОперацииД);
	Запрос.УстановитьПараметр("Количество",			 СтрокаСводногоПоручения.Количество);
	Запрос.УстановитьПараметр("РазделСчетаДепо",	 СтрокаСводногоПоручения.РазделСчетаДепо);
	Запрос.УстановитьПараметр("ДокументОснование",	 СводноеПоручениеСсылка);
	Запрос.УстановитьПараметр("СчетДепо",			 СтрокаСводногоПоручения.СчетДепо);
	Запрос.УстановитьПараметр("ЦБ",					 СтрокаСводногоПоручения.ЦеннаяБумага);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		СводныйОтчетОСовершенныхОперациях = ВыборкаДетальныеЗаписи.Ссылка.ПолучитьОбъект();
		ПараметрыОтбораОпераций = Новый Структура;
		ПараметрыОтбораОпераций.Вставить("ТипОперации",			 СтрокаСводногоПоручения.ВидОперацииД);
		ПараметрыОтбораОпераций.Вставить("ОборотЗачислено",		 СтрокаСводногоПоручения.Количество);
		ПараметрыОтбораОпераций.Вставить("РазделСчетаДепо",		 СтрокаСводногоПоручения.РазделСчетаДепо);
		ПараметрыОтбораОпераций.Вставить("ОснованиеОперации",	 СводноеПоручениеСсылка);
		ПараметрыОтбораОпераций.Вставить("ЦБ",					 СтрокаСводногоПоручения.ЦеннаяБумага);
		
		ОперацииСводногоОтчета = СводныйОтчетОСовершенныхОперациях.Операции.НайтиСтроки(ПараметрыОтбораОпераций);
		Для Каждого ОперацияСводногоОтчета Из ОперацииСводногоОтчета Цикл
			ОперацияСводногоОтчета.ОборотЗачислено = КоличествоНовое;
		КонецЦикла;
		
		СводныйОтчетОСовершенныхОперациях.ОбменДанными.Загрузка = Истина;
		СводныйОтчетОСовершенныхОперациях.Записать();
	КонецЦикла;
	
КонецПроцедуры

Процедура ИзменитьДвиженияЦенныхБумагПогашениеВНоль()
	
	ВремяНачалаФормирования = ОценкаПроизводительности.НачатьЗамерВремени();
	ВесЗамера = 0;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ОстаткиЦБОбороты.СчетДепо КАК СчетДепо,
	|	ОстаткиЦБОбороты.РазделСчетаДепо КАК РазделСчетаДепо,
	|	ОстаткиЦБОбороты.ЦБ КАК ЦБ,
	|	ОстаткиЦБОбороты.Регистратор КАК ГлобальнаяОперация,
	|	ВЫРАЗИТЬ(ОстаткиЦБОбороты.Регистратор КАК Документ.ГлобальнаяОперация).ДокументОснование КАК Поручение,
	|	ОстаткиЦБОбороты.Период КАК Период,
	|	ОстаткиЦБОбороты.СчетДепоМХ КАК СчетДепоМХ,
	|	ОстаткиЦБОбороты.РазделСчетаДепоМХ КАК РазделСчетаДепоМХ,
	|	ОстаткиЦБОбороты.СтатусЦБ КАК СтатусЦБ
	|ИЗ
	|	РегистрНакопления.ОстаткиЦБ.Обороты(, , Регистратор, ) КАК ОстаткиЦБОбороты
	|ГДЕ
	|	ОстаткиЦБОбороты.Регистратор ССЫЛКА Документ.ГлобальнаяОперация
	|
	|УПОРЯДОЧИТЬ ПО
	|	Период";
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		ВесЗамера = ВесЗамера + 1;
		
		НовыйОстаток = ПолучитьОстатокЦенныхБумаг(ВыборкаДетальныеЗаписи);
		
		ИзменитьДвиженияЦенныхБумагПогашениеВНольПоручение(ВыборкаДетальныеЗаписи, НовыйОстаток);
		ИзменитьДвиженияЦенныхБумагПогашениеВНольГлобальнаяОперация(ВыборкаДетальныеЗаписи, НовыйОстаток);
		
	КонецЦикла;
	ОценкаПроизводительности.ЗакончитьЗамерВремени(
		"СкрытиеКонфиденциальнойИнформации.ИзменитьПогашениеВНоль", ВремяНачалаФормирования, ВесЗамера);
	
КонецПроцедуры

Функция ПолучитьОстатокЦенныхБумаг(ПараметрыОтбора)
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	ОстаткиЦБОстатки.КоличествоОстаток КАК КоличествоОстаток
	|ИЗ
	|	РегистрНакопления.ОстаткиЦБ.Остатки(
	|			&Период,
	|			РазделСчетаДепо = &РазделСчетаДепо
	|				И РазделСчетаДепоМХ = &РазделСчетаДепоМХ
	|				И СчетДепо = &СчетДепо
	|				И СчетДепоМХ = &СчетДепоМХ
	|				И ЦБ = &ЦБ
	|				И СтатусЦБ = &СтатусЦБ) КАК ОстаткиЦБОстатки";
	
	Запрос.УстановитьПараметр("Период",				 ПараметрыОтбора.ГлобальнаяОперация.МоментВремени());
	Запрос.УстановитьПараметр("РазделСчетаДепо",	 ПараметрыОтбора.РазделСчетаДепо);
	Запрос.УстановитьПараметр("РазделСчетаДепоМХ",	 ПараметрыОтбора.РазделСчетаДепоМХ);
	Запрос.УстановитьПараметр("СчетДепо",			 ПараметрыОтбора.СчетДепо);
	Запрос.УстановитьПараметр("СчетДепоМХ",			 ПараметрыОтбора.СчетДепоМХ);
	Запрос.УстановитьПараметр("ЦБ",					 ПараметрыОтбора.ЦБ);
	Запрос.УстановитьПараметр("СтатусЦБ",			 ПараметрыОтбора.СтатусЦБ);
	
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() Тогда
		Возврат 0;
	Иначе
		ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
		ВыборкаДетальныеЗаписи.Следующий();
		Возврат ВыборкаДетальныеЗаписи.КоличествоОстаток;
	КонецЕсли;
	
КонецФункции

Процедура ИзменитьДвиженияЦенныхБумагПогашениеВНольПоручение(ПараметрыОтбора, НовыйОстаток)
	
	Поручение = ПараметрыОтбора.Поручение.ПолучитьОбъект();
	
	ПараметрыОтбораОпераций = Новый Структура;
	ПараметрыОтбораОпераций.Вставить("СчетДепо",			 ПараметрыОтбора.СчетДепо);
	ПараметрыОтбораОпераций.Вставить("РазделСчетаДепо",		 ПараметрыОтбора.РазделСчетаДепо);
	ПараметрыОтбораОпераций.Вставить("СчетДепоМХ",			 ПараметрыОтбора.СчетДепоМХ);
	ПараметрыОтбораОпераций.Вставить("РазделСчетаДепоМХ",	 ПараметрыОтбора.РазделСчетаДепоМХ);
	ПараметрыОтбораОпераций.Вставить("ЦеннаяБумага",		 ПараметрыОтбора.ЦБ);
	
	ОперацииПоручения = Поручение.ЦенныеБумагиСписываемые.НайтиСтроки(ПараметрыОтбораОпераций);
	Для Каждого ОперацияПоручения Из ОперацииПоручения Цикл
		ОперацияПоручения.Количество = НовыйОстаток;
	КонецЦикла;
	
	Поручение.ОбменДанными.Загрузка = Истина;
	Поручение.Записать();
	
КонецПроцедуры

Процедура ИзменитьДвиженияЦенныхБумагПогашениеВНольГлобальнаяОперация(ПараметрыОтбора, НовыйОстаток)
	
	ГлобальнаяОперация = ПараметрыОтбора.ГлобальнаяОперация.ПолучитьОбъект();
	
	ПараметрыОтбораОпераций = Новый Структура;
	ПараметрыОтбораОпераций.Вставить("РазделСчетаДепо",		 ПараметрыОтбора.РазделСчетаДепо);
	ПараметрыОтбораОпераций.Вставить("СчетДепоМХ",			 ПараметрыОтбора.СчетДепоМХ);
	ПараметрыОтбораОпераций.Вставить("РазделСчетаДепоМХ",	 ПараметрыОтбора.РазделСчетаДепоМХ);
	ПараметрыОтбораОпераций.Вставить("ЦеннаяБумага",		 ПараметрыОтбора.ЦБ);
	
	ОперацииГлобальнойОперации = ГлобальнаяОперация.ЦенныеБумаги.НайтиСтроки(ПараметрыОтбораОпераций);
	Для Каждого ОперацияГлобальнойОперации Из ОперацииГлобальнойОперации Цикл
		ОперацияГлобальнойОперации.Количество = НовыйОстаток;
	КонецЦикла;
	
	ГлобальнаяОперация.ОбменДанными.Загрузка = Истина;
	ГлобальнаяОперация.Записать();
	
	// Регистры глобальной операции
	ИзменитьДвиженияЦенныхБумагПогашениеВНольРегистры(РегистрыНакопления.ОстаткиЦБ,				 ПараметрыОтбора, НовыйОстаток);
	ИзменитьДвиженияЦенныхБумагПогашениеВНольРегистры(РегистрыНакопления.ОстаткиЦБДепозитарийМХ, ПараметрыОтбора, НовыйОстаток);
	ИзменитьДвиженияЦенныхБумагПогашениеВНольРегистры(РегистрыНакопления.ОстаткиЦБМестоРасчетов, ПараметрыОтбора, НовыйОстаток);
	
КонецПроцедуры

Процедура ИзменитьДвиженияЦенныхБумагПогашениеВНольРегистры(Регистр, ПараметрыОтбора, НовыйОстаток)
	
	Набор = Регистр.СоздатьНаборЗаписей();
	Набор.Отбор.Регистратор.Установить(ПараметрыОтбора.ГлобальнаяОперация);
	Набор.Прочитать();
	Если Набор.Количество() > 0 Тогда
		Для Каждого Движение Из Набор Цикл
			Совпадение =
				Движение.СчетДепо			 = ПараметрыОтбора.СчетДепо
				И Движение.РазделСчетаДепо	 = ПараметрыОтбора.РазделСчетаДепо
				И Движение.ЦБ				 = ПараметрыОтбора.ЦБ
				И Движение.СчетДепоМХ		 = ПараметрыОтбора.СчетДепоМХ
				И Движение.РазделСчетаДепоМХ = ПараметрыОтбора.РазделСчетаДепоМХ
				И Движение.СтатусЦБ			 = ПараметрыОтбора.СтатусЦБ;
			Если Совпадение Тогда
				Движение.Количество = НовыйОстаток;
			КонецЕсли;
		КонецЦикла;
		Набор.Записать(Истина);
	КонецЕсли;
	
КонецПроцедуры

