#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	Если Параметры.Свойство("ПолучитьСсылкиИзISIN") Тогда
		ПолучитьСсылкиИзISIN = Параметры.ПолучитьСсылкиИзISIN;
	КонецЕсли;
	
	Макет = Обработки.ЗагрузкаСпискаЦБИзExcel.ПолучитьМакет("Макет");
	ОбластьЗаголовок = Макет.ПолучитьОбласть("ОбластьЗаголовок");
	ТабДок.Вывести(ОбластьЗаголовок);
	ТабДок.ФиксацияСверху = 1;
	
	ТабДок.Защита = Истина;
	Колонка1 = ТабДок.Область(, 1, , 1);
	Колонка1.Защита = Ложь;
	Шапка = ТабДок.Область(1, 1, 1, 1);
	Шапка.Защита = Истина;
КонецПроцедуры

#КонецОбласти


#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура Загрузить(Команда)
	МассивЦБ = ПолучитьМассивЦБ();
	
	Закрыть(МассивЦБ);
КонецПроцедуры

#КонецОбласти


#Область СлужебныеПроцедурыИФункции

&НаСервере
Функция ПолучитьМассивЦБ()
	МассивУникальныхНепустыхISIN = Новый Массив;
	
	ОбластиТаб = ТабДок.Область(1, 1, ТабДок.ВысотаТаблицы, 1);
	Построитель = Новый ПостроительЗапроса;
	Построитель.ИсточникДанных = Новый ОписаниеИсточникаДанных(ОбластиТаб);
	Построитель.Выполнить();
	ТабДанные = Построитель.Результат.Выгрузить();
	Для Каждого СтрокаТЗ Из ТабДанные Цикл
		ISIN = СтрокаТЗ.ISIN;
		Если Не ПустаяСтрока(ISIN) И МассивУникальныхНепустыхISIN.Найти(ISIN) = Неопределено Тогда
			МассивУникальныхНепустыхISIN.Добавить(ISIN);
		КонецЕсли;
	КонецЦикла;
	
	МассивЦБ = МассивЦБ(МассивУникальныхНепустыхISIN, ПолучитьСсылкиИзISIN);
	
	Возврат МассивЦБ;
КонецФункции

&НаСервереБезКонтекста
Функция МассивЦБ(МассивISIN, ПолучитьСсылкиИзISIN)
		
	Если ПолучитьСсылкиИзISIN Тогда
		МассивЦБ = Новый Массив;
		Для Каждого ISIN Из МассивISIN Цикл
			СсылкаНаЦБ = Справочники.ЦенныеБумаги.ЦеннаяБумагаПоРегНомеруИISIN(ISIN, Неопределено, Ложь);
			Если СсылкаНаЦБ <> Неопределено Тогда
				МассивЦБ.Добавить(СсылкаНаЦБ);
			Иначе
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не удалось найти ЦБ по ISIN " + ISIN + " ...");
			КонецЕсли;
		КонецЦикла;
	Иначе
		МассивЦБ = МассивISIN;
	КонецЕсли;
		
	Возврат МассивЦБ;
КонецФункции

#КонецОбласти