&НаСервере
Процедура ПодключениеНаСервере(НомерБД)
	
	ОбработкаОбъект = РеквизитФормыВЗначение("Объект");
	ЭтотОбъект["СтрокаСоединения"+НомерБД] = ОбработкаОбъект.СформироватьСтрокуСоединения(НомерБД);
	
	Если Не ОбработкаОбъект.СоединениеУстановлено(ЭтотОбъект["СтрокаСоединения"+НомерБД], НомерБД) Тогда 
		Элементы["Объект"+НомерБД].СписокВыбора.Очистить();
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Соединение с базой не установлено");
		Возврат;
	КонецЕсли;
	
	БД = ОбработкаОбъект["Подключение" + НомерБД];
	Для Каждого Справочник Из БД.Метаданные.Справочники Цикл
		
		Элементы["Объект"+НомерБД].СписокВыбора.Добавить(Справочник.Имя);
		
	КонецЦикла; 
	БД = Неопределено;
	
КонецПроцедуры

&НаКлиенте
Процедура ИмяБД1НачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	Диалог = Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.ВыборКаталога);
	Диалог.Заголовок = "Выберите каталог БД";
	Диалог.ПолноеИмяФайла = "";
	Диалог.ПредварительныйПросмотр = Ложь;
	
	Если Диалог.Выбрать() Тогда
		Объект.ИмяБД1 = Диалог.Каталог;
	КонецЕсли;
	
КонецПроцедуры

