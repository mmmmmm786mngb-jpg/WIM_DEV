&НаСервере
Процедура ДобавитьКолонку(ИмяТабличногоПоля, ИмяКолонки)
	
	ЭлементФормы = Элементы.Добавить(ИмяТабличногоПоля + ИмяКолонки, Тип("ПолеФормы"), Элементы[ИмяТабличногоПоля]);
	ЭлементФормы.Вид = ВидПоляФормы.ПолеВвода;
	ЭлементФормы.ПутьКДанным = ИмяТабличногоПоля + "." + ИмяКолонки;
	
КонецПроцедуры

&НаКлиенте
Процедура Объект1ПриИзменении(Элемент)

	Если Объект.Объект1 = ТекущийОбъект1
		И ЗначениеЗаполнено(ТекущийОбъект1) Тогда
		
		Объект.Объект1 = ТекущийОбъект1;
		Возврат;
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ТекущийОбъект1)
		И ТабличноеПоле1.Количество() Тогда
	
		Ответ = Вопрос("Изменить объект 1?", РежимДиалогаВопрос.ДаНет);
		Если Ответ = КодВозвратаДиалога.Нет Тогда
			Возврат;
		КонецЕсли; 
		
	КонецЕсли;
	
	ПодготовитьТаблицу(1, Объект.ПереключательБД1 = "Текущая", Истина);
	
	ТекущийОбъект1 = Объект.Объект1;
	
КонецПроцедуры

&НаКлиенте
Процедура Объект2ПриИзменении(Элемент)

	Если Объект.Объект2 = ТекущийОбъект2
		И ЗначениеЗаполнено(ТекущийОбъект2) Тогда
		
		Объект.Объект2 = ТекущийОбъект2;
		Возврат;
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ТекущийОбъект2)
		И ТабличноеПоле2.Количество() Тогда
	
		Ответ = Вопрос("Изменить объект 2?", РежимДиалогаВопрос.ДаНет);
		Если Ответ = КодВозвратаДиалога.Нет Тогда
			Возврат;
		КонецЕсли; 
		
	КонецЕсли;
	
	ПодготовитьТаблицу(2, Объект.ПереключательБД2 = "Текущая", Истина);
	
	ТекущийОбъект2 = Объект.Объект2;
	
КонецПроцедуры

&НаКлиенте
Процедура ПравилоЗаполненияНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	ВыбранныйЭлемент = ВыбратьИзСписка(СписокВыбораПравилоЗаполнения, Элемент);
	Если ВыбранныйЭлемент <> Неопределено Тогда 
