
////////////////////////////////////////////////////////////////////////////////
// ПЕРЕМЕННЫЕ МОДУЛЯ
&НаКлиенте
Перем ТекущийОбъект1, ТекущийОбъект2; 
&НаКлиенте
Перем СписокВыбораПравилоЗаполнения, СписокВыбораПравилоСинхронизации;
&НаКлиенте
Перем ЭлементНачалаПеретаскивания;

////////////////////////////////////////////////////////////////////////////////
// ПРОЦЕДУРЫ И ФУНКЦИИ ОБЩЕГО НАЗНАЧЕНИЯ

// Готовит массив объектов которые можно синхронизировать
//
// Параметры
//  НомерБД      - Число - Номер бд
//
// Возвращаемое значение:
//   ОбъектыМетаданных – Массив объектов МД, которые могут синхронизироваться
//
&НаСервере
Функция ОбъектыМетаданных(НомерБД)
	
	ОбъектыМетаданных = Новый Массив;
	
	Для Каждого Справочник Из Метаданные.Справочники Цикл
		
		ОбъектыМетаданных.Добавить(Справочник.Имя);
		
	КонецЦикла; 
	
	Возврат ОбъектыМетаданных;
	
КонецФункции // ОбъектыМетаданных()

&НаКлиенте
Процедура ПриИзмененииПереключателя1()
	
	БД1Текущая = Объект.ПереключательБД1 = "Текущая";
	
	Если БД1Текущая Тогда
		
		Элементы.Объект1.СписокВыбора.ЗагрузитьЗначения(ОбъектыМетаданных(1));
		
	Иначе
		
		Элементы.Объект1.СписокВыбора.Очистить();
		Объект.Объект1 = Неопределено;
		
	КонецЕсли; 
	
	СтрокаСоединения1 = "";
	
КонецПроцедуры // ПриИзмененииПереключателя1()

&НаКлиенте
Процедура ПриИзмененииПереключателя2()
	
	БД2Текущая = Объект.ПереключательБД2 = "Текущая";
	
	Если БД2Текущая Тогда
		
		Элементы.Объект2.СписокВыбора.ЗагрузитьЗначения(ОбъектыМетаданных(1));
		
	Иначе
		
		Элементы.Объект2.СписокВыбора.Очистить();
		Объект.Объект2 = Неопределено;
		
	КонецЕсли; 
	
	СтрокаСоединения2 = "";
	
КонецПроцедуры // ПриИзмененииПереключателя2()

// Готовит пустую или заполненную таблицу данных
//
// Параметры
//  НомерБД         - Число - Номер бд
//  БДТекущая       - Булево - признак того, что обрабатываетя текущая БД
//  ТолькоСтруктура – Булево – Истина - создается только структура таблицы
//
&НаСервере
Процедура ПодготовитьТаблицу(НомерБД, БДТекущая, ТолькоСтруктура)
	
	ОбработкаОбъект = РеквизитФормыВЗначение("Объект");
	Если БДТекущая Тогда 
		Данные = ОбработкаОбъект.ПолучитьДанныеТекущейБД(Объект["Объект" + НомерБД], НомерБД, ТолькоСтруктура);
	Иначе 
		Данные = ОбработкаОбъект.ПолучитьДанныеУдаленнойБД(Объект["Объект" + НомерБД], НомерБД, ЭтотОбъект["СтрокаСоединения" + НомерБД], ТолькоСтруктура);
	КонецЕсли;

	Если Данные = Неопределено Тогда 
		Возврат;
	КонецЕсли;
	
	ИмяТабличногоПоля = "ТабличноеПоле" + НомерБД;
	ЭтаФорма[ИмяТабличногоПоля].Очистить();
	
	УдаляемыеРеквизиты = Новый Массив;
	РеквизитыДляУдаления = ПолучитьРеквизиты(ИмяТабличногоПоля);
	Для Каждого УдаляемыйРеквизит Из РеквизитыДляУдаления Цикл 
		УдаляемыеРеквизиты.Добавить(ИмяТабличногоПоля + "." + УдаляемыйРеквизит.Имя);
		Элементы.Удалить(Элементы[ИмяТабличногоПоля + УдаляемыйРеквизит.Имя]);
	КонецЦикла;
	
	ОписаниеТипаNull = Новый ОписаниеТипов("Null");
	ОписаниеТипаСтрока = Новый ОписаниеТипов("Строка");
	ДобавляемыеРеквизиты = Новый Массив;
	Для Каждого Колонка Из Данные.Колонки Цикл 
		ДобавляемыеРеквизиты.Добавить(Новый РеквизитФормы(Колонка.Имя, ?(Колонка.ТипЗначения = ОписаниеТипаNull, ОписаниеТипаСтрока, Колонка.ТипЗначения), ИмяТабличногоПоля, Колонка.Заголовок));
	КонецЦикла;

	ИзменитьРеквизиты(ДобавляемыеРеквизиты, УдаляемыеРеквизиты);
	
	Если Не ТолькоСтруктура Тогда 
		ЗначениеВРеквизитФормы(Данные, ИмяТабличногоПоля);
	КонецЕсли;
	
	ДобавляемыеРеквизиты.Очистить();
	ДобавляемыеРеквизиты.Добавить(Новый РеквизитФормы("Синхронизирован", Новый ОписаниеТипов("Булево"), ИмяТабличногоПоля));
	ДобавляемыеРеквизиты.Добавить(Новый РеквизитФормы("Нпп", ОбщегоНазначения.ПолучитьОписаниеТиповЧисла(8), ИмяТабличногоПоля));
	ДобавляемыеРеквизиты.Добавить(Новый РеквизитФормы("Соответствие", ОбщегоНазначения.ПолучитьОписаниеТиповЧисла(8), ИмяТабличногоПоля));
	
	ИзменитьРеквизиты(ДобавляемыеРеквизиты);
	
	ДобавитьКолонку(ИмяТабличногоПоля, "Синхронизирован");
	ДобавитьКолонку(ИмяТабличногоПоля, "Нпп");
	ДобавитьКолонку(ИмяТабличногоПоля, "Соответствие");
	Для Каждого Колонка Из Данные.Колонки Цикл 
		ДобавитьКолонку(ИмяТабличногоПоля, Колонка.Имя);
	КонецЦикла;
	
	Элементы[ИмяТабличногоПоля+"Синхронизирован"].Видимость = Ложь;
	Элементы[ИмяТабличногоПоля+"Нпп"].Видимость = Ложь;
	Элементы[ИмяТабличногоПоля+"Соответствие"].Видимость = Ложь;
	
	Если НомерБД = 2 Тогда 
		
		Элементы.Колонка_2.СписокВыбора.Очистить();
		
		КолонкиТаблицы = ПолучитьРеквизиты("ТабличноеПоле2");
		Для Каждого Колонка Из КолонкиТаблицы Цикл
			
			Если Найти("Ссылка, Синхронизирован, Соответствие", Колонка.Имя) Тогда
				Продолжить;
			КонецЕсли; 
			
			Элементы.Колонка_2.СписокВыбора.Добавить(Колонка.Имя);
			
		КонецЦикла;
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция КоличествоСтрокВТаблице(ИмяТабличногоПоля)
	
	ТЗ = РеквизитФормыВЗначение(ИмяТабличногоПоля);
	Возврат ТЗ.Количество();
	
КонецФункции

// Очищает таблицу после получения подтверждения от пользователя
//
// Параметры
//  ИмяТабличногоПоля – Строка – Имя таблицы, которую нужно очистить
//
&НаСервере
Процедура ОчиститьТаблицуНаСервере(ИмяТабличногоПоля)
	
	ТЗ = РеквизитФормыВЗначение(ИмяТабличногоПоля);
	ТЗ.Очистить();
	ЗначениеВРеквизитФормы(ТЗ, ИмяТабличногоПоля);
	
КонецПроцедуры // ОчиститьТаблицуНаСервере()

// Перед началом добавления строки
//
// Параметры
//  НомерБД             - Число - Номер бд
//  ОбъектСинхронизации – Строка – ИмяОбъекта
//  Текущая             – Булево – Признак того что обрабатывается объект текущей БД
//  ИмяТабличногоПоля   – Строка – Имя табличного поля, в которое добавляется строка
//
&НаКлиенте
Процедура ПередНачаломДобавленияСтроки(НомерБД, Знач ОбъектСинхронизации, Текущая, ИмяТабличногоПоля)

	Если Не ЗначениеЗаполнено(ОбъектСинхронизации) Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не выбран объект " + НомерБД + "!"); 
		Возврат;
	КонецЕсли;
	
	ОповещениеОВыборе = Новый ОписаниеОповещения("ПриЗакрытииФормыВыбора", ЭтаФорма, ИмяТабличногоПоля);
	СтруктураПараметров = Новый Структура("ЗакрыватьПриВыборе, ТекущийОбъект, НомерБД, Текущая, СтрокаСоединения", Истина, Объект["Объект"+НомерБД], НомерБД, Текущая, ЭтотОбъект["СтрокаСоединения"+НомерБД]);
	ОткрытьФорму("Обработка.НастройкаСинхронизацииОбъектов.Форма.ФормаВыбораСтроки", СтруктураПараметров, ЭтаФорма,,,, ОповещениеОВыборе, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
КонецПроцедуры // ПередНачаломДобавленияСтроки()

&НаКлиенте
Процедура ПриЗакрытииФормыВыбора(Значение, ДополнительныеПараметры) Экспорт 
	
	Если Значение = Неопределено Тогда 
		Возврат;
	КонецЕсли;
	
	ДобавитьСтрокуВТаблицу(Значение, ДополнительныеПараметры);
	
КонецПроцедуры // ПриЗакрытииФормыВыбора()

&НаСервере
Процедура ДобавитьСтрокуВТаблицу(ДанныеЗаполнения, ИмяТабличногоПоля)
	
	ТЗ = РеквизитФормыВЗначение(ИмяТабличногоПоля);
	НоваяСтрока = ТЗ.Добавить();
	ЗаполнитьЗначенияСвойств(НоваяСтрока, ДанныеЗаполнения);
	ЗначениеВРеквизитФормы(ТЗ, ИмяТабличногоПоля);
	Элементы[ИмяТабличногоПоля].ТекущаяСтрока = 0;

КонецПроцедуры // ДобавитьСтрокуВТаблицу()

// Очищает синхронизацию таблиц
//
// Параметры
//  Нет
//
&НаСервере
Процедура СброситьСинхронизацию()

	ТЗ = РеквизитФормыВЗначение("ТабличноеПоле1");
	Если ТЗ.Колонки.Найти("Синхронизирован") <> Неопределено Тогда
		ТЗ.ЗаполнитьЗначения(Ложь, "Синхронизирован");
		ЗначениеВРеквизитФормы(ТЗ, "ТабличноеПоле1");
	КонецЕсли; 
	
	ТЗ = РеквизитФормыВЗначение("ТабличноеПоле2");
	Если ТЗ.Колонки.Найти("Синхронизирован") <> Неопределено Тогда
		ТЗ.ЗаполнитьЗначения(Ложь, "Синхронизирован");
		ЗначениеВРеквизитФормы(ТЗ, "ТабличноеПоле2");
	КонецЕсли;

КонецПроцедуры // СброситьСинхронизацию()

// Корректирует (удаляет) синхронизацию между конкретными строками 
//
// Параметры
//  ИмяТабличногоПоля – Строка – Имя табличного поля, которое корректируется
//  Нпп               – Число – порядковый номер строки в которой необходимо очистить синхронизацию
//
&НаСервере
Процедура КорректировкаСинхронизации(ИмяТабличногоПоля, Нпп)

	ТЗ = РеквизитФормыВЗначение(ИмяТабличногоПоля);
	
	НайденнаяСтрока = ТЗ.Найти(Нпп, "Нпп");
	Если НайденнаяСтрока <> Неопределено Тогда
	
		НайденнаяСтрока.Синхронизирован = Ложь;
		НайденнаяСтрока.Соответствие = -1;
	
	КонецЕсли; 

	ЗначениеВРеквизитФормы(ТЗ, ИмяТабличногоПоля);
	
КонецПроцедуры // КорректировкаСинхронизации()



////////////////////////////////////////////////////////////////////////////////
// ПРОЦЕДУРЫ И ФУНКЦИИ ДЛЯ УПРАВЛЕНИЯ ВНЕШНИМ ВИДОМ ФОРМЫ

// Обрабатывает интерактивное изменение элементов формы обработки
//
// Параметры
//  Нет
//
&НаКлиенте
Процедура УстановитьВидимость()
	
	ДоступностьБД1 = Объект.ПереключательБД1 = "Удаленная";
	
	Элементы.ТипСоединения1.ТолькоПросмотр	= Не ДоступностьБД1;
	Элементы.ИмяБД1.ТолькоПросмотр			= Не ДоступностьБД1;
	Элементы.ИмяСервера1.ТолькоПросмотр 	= Не ДоступностьБД1;
	Элементы.Пользователь1.ТолькоПросмотр 	= Не ДоступностьБД1;
	Элементы.Пароль1.ТолькоПросмотр 		= Не ДоступностьБД1;
	
	Элементы.Подключение1.Доступность		= ДоступностьБД1;
	
	Если ДоступностьБД1 Тогда
		
		Если Объект.ТипСоединения1 Тогда
			
			Элементы.ИмяБД1.Заголовок = "Путь к базе данных";
			
		Иначе
			
			Элементы.ИмяБД1.Заголовок = "Имя базы данных";
			
		КонецЕсли; 
		
		Элементы.ИмяСервера1.ТолькоПросмотр = Объект.ТипСоединения1;
		
	КонецЕсли; 
	
	Элементы.ИмяБД1.КнопкаВыбора = Объект.ТипСоединения1;
	
	
	
	ДоступностьБД2 = Объект.ПереключательБД2 = "Удаленная";
	
	Элементы.ТипСоединения2.ТолькоПросмотр	= Не ДоступностьБД2;
	Элементы.ИмяБД2.ТолькоПросмотр			= Не ДоступностьБД2;
	Элементы.ИмяСервера2.ТолькоПросмотр 	= Не ДоступностьБД2;
	Элементы.Пользователь2.ТолькоПросмотр 	= Не ДоступностьБД2;
	Элементы.Пароль2.ТолькоПросмотр 		= Не ДоступностьБД2;
	
	Элементы.Подключение2.Доступность		= ДоступностьБД2;
	
	Если ДоступностьБД2 Тогда
		
		Если Объект.ТипСоединения2 Тогда
			
			Элементы.ИмяБД2.Заголовок = "Путь к базе данных";
			
		Иначе
			
			Элементы.ИмяБД2.Заголовок = "Имя базы данных";
			
		КонецЕсли; 
		
		Элементы.ИмяСервера2.ТолькоПросмотр = Объект.ТипСоединения2;
		
	КонецЕсли; 
	
	Элементы.ИмяБД2.КнопкаВыбора = Объект.ТипСоединения2;
	
КонецПроцедуры // УстановитьВидимость()



////////////////////////////////////////////////////////////////////////////////
// ПРОЦЕДУРЫ - ОБРАБОТЧИКИ СОБЫТИЙ ФОРМЫ

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Для Номер = 1 По 2 Цикл 
		ИмяТабличногоПоля = "ТабличноеПоле"+Номер;
		ДобавляемыеРеквизиты = Новый Массив;
		ДобавляемыеРеквизиты.Добавить(Новый РеквизитФормы("Синхронизирован", Новый ОписаниеТипов("Булево"), ИмяТабличногоПоля));
		ДобавляемыеРеквизиты.Добавить(Новый РеквизитФормы("Нпп", ОбщегоНазначения.ПолучитьОписаниеТиповЧисла(8), ИмяТабличногоПоля));
		ДобавляемыеРеквизиты.Добавить(Новый РеквизитФормы("Соответствие", ОбщегоНазначения.ПолучитьОписаниеТиповЧисла(8), ИмяТабличногоПоля));
		
		ИзменитьРеквизиты(ДобавляемыеРеквизиты);
		
		ЭлементФормы = Элементы.Добавить(ИмяТабличногоПоля + "Синхронизирован", Тип("ПолеФормы"), Элементы[ИмяТабличногоПоля]);
		ЭлементФормы.Вид = ВидПоляФормы.ПолеВвода;
		ЭлементФормы.ПутьКДанным = ИмяТабличногоПоля + ".Синхронизирован";
		ЭлементФормы = Элементы.Добавить(ИмяТабличногоПоля + "Нпп", Тип("ПолеФормы"), Элементы[ИмяТабличногоПоля]);
		ЭлементФормы.Вид = ВидПоляФормы.ПолеВвода;
		ЭлементФормы.ПутьКДанным = ИмяТабличногоПоля + ".Нпп";
		ЭлементФормы = Элементы.Добавить(ИмяТабличногоПоля + "Соответствие", Тип("ПолеФормы"), Элементы[ИмяТабличногоПоля]);
		ЭлементФормы.Вид = ВидПоляФормы.ПолеВвода;
		ЭлементФормы.ПутьКДанным = ИмяТабличногоПоля + ".Соответствие";
	КонецЦикла;
	
	НастроитьУсловноеОформление();
	
КонецПроцедуры

&НаСервере
Процедура НастроитьУсловноеОформление()
	
	Для Номер = 1 По 2 Цикл 
		
		ЭлементОформления = УсловноеОформление.Элементы.Добавить();
		ЭлементОтбора = ЭлементОформления.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
		ЭлементОтбора.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("ТабличноеПоле"+Номер+".Синхронизирован");
		ЭлементОтбора.ВидСравнения = ВидСравненияКомпоновкиДанных.Равно;
		ЭлементОтбора.ПравоеЗначение = Истина;
		ЭлементОформления.Оформление.УстановитьЗначениеПараметра("ЦветФона", WebЦвета.Хаки);
		ПолеОформления = ЭлементОформления.Поля.Элементы.Добавить();
		ПолеОформления.Поле = Новый ПолеКомпоновкиДанных("ТабличноеПоле"+Номер);
		
		ЭлементОформления = УсловноеОформление.Элементы.Добавить();
		ЭлементОтбора = ЭлементОформления.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
		ЭлементОтбора.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("ТабличноеПоле"+Номер+".ЭтоГруппа");
		ЭлементОтбора.ВидСравнения = ВидСравненияКомпоновкиДанных.Равно;
		ЭлементОтбора.ПравоеЗначение = Истина;
		ЭлементОформления.Оформление.УстановитьЗначениеПараметра("Шрифт", Новый Шрифт(WindowsШрифты.ШрифтДиалоговИМеню,,8,Истина));
		ПолеОформления = ЭлементОформления.Поля.Элементы.Добавить();
		ПолеОформления.Поле = Новый ПолеКомпоновкиДанных("ТабличноеПоле"+Номер);
		
	КонецЦикла;

КонецПроцедуры

