// ПРОЦЕДУРЫ - ДЕЙСТВИЯ КОМАНДНЫХ ПАНЕЛЕЙ ФОРМЫ

&НаКлиенте
Процедура ОбновитьСправочник(Команда)
	
	Если Не ЗначениеЗаполнено(Колонка_2) Тогда 
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не выбрана колонка, в которой корректируются значения.");
		Возврат;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(Объект.ПравилоЗаполнения) Тогда 
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не указаны правила заполнения значений.");
		Возврат;
	КонецЕсли;
	
	Если СтрНайти(Объект.ПравилоУсловия, "Строка_1") > 0 Тогда 
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("В условиях нельзя использовать значение ""Строка_1""");
		Возврат;
	КонецЕсли;
	
	Оповещение = Новый ОписаниеОповещения("ВопросПередОбновлениемЗавершение", ЭтотОбъект);
	ТекстВопроса = "Вы действительно хотите заполнить поле " + Колонка_2 
				   + " в справочнике " + Объект.Объект2 + " БД2 значением """ 
				   + СокрЛП(Объект.ПравилоЗаполнения) + """?";
	ПоказатьВопрос(Оповещение, ТекстВопроса, РежимДиалогаВопрос.ДаНет);
	
КонецПроцедуры

&НаКлиенте
Процедура ВопросПередОбновлениемЗавершение(Результат, ДополнительныеПараметры) Экспорт 
	
	Если Результат = КодВозвратаДиалога.Нет Тогда 
		Возврат;
	КонецЕсли;
	
	ОбновитьСправочникНаСервере();
	
	Если СписокВыбораПравилоЗаполнения.НайтиПоЗначению(СокрЛП(Объект.ПравилоЗаполнения)) = Неопределено Тогда
		СписокВыбораПравилоЗаполнения.Добавить(СокрЛП(Объект.ПравилоЗаполнения));
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьСправочникНаСервере()
	
	БД2Текущая = Объект.ПереключательБД2 = "Текущая";
	
	ТЗ1 = РеквизитФормыВЗначение("ТабличноеПоле1");
	ТЗ2 = РеквизитФормыВЗначение("ТабличноеПоле2");
	
	ОбработкаОбъект = РеквизитФормыВЗначение("Объект");
	ОбработкаОбъект.ОбновитьСправочник(СтрокаСоединения2, БД2Текущая, ТЗ1, ТЗ2, Колонка_2);
	
	ТЗ2.Очистить();
	
	ЗначениеВРеквизитФормы(ТЗ1, "ТабличноеПоле1");
	ЗначениеВРеквизитФормы(ТЗ2, "ТабличноеПоле2");
	
КонецПроцедуры

&НаКлиенте
Процедура Синхронизировать(Команда)
	
	Если Не ЗначениеЗаполнено(Объект.ПравилоСинхронизации) Тогда 
		Возврат;
	КонецЕсли;
	
	СброситьСинхронизацию();
	СинхронизироватьНаСервере(СписокВыбораПравилоСинхронизации);
	
	Если СписокВыбораПравилоСинхронизации.НайтиПоЗначению(СокрЛП(Объект.ПравилоСинхронизации)) = Неопределено Тогда
		СписокВыбораПравилоСинхронизации.Добавить(СокрЛП(Объект.ПравилоСинхронизации));
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура СинхронизироватьНаСервере(СписокПравил)
	
	ТЗ1 = РеквизитФормыВЗначение("ТабличноеПоле1");
	ТЗ2 = РеквизитФормыВЗначение("ТабличноеПоле2");
	
	Для Каждого Строка_1 Из ТЗ1 Цикл
	
		Для Каждого Строка_2 Из ТЗ2 Цикл
			
			Попытка
			
				Если Вычислить(Объект.ПравилоСинхронизации) Тогда
				
					Строка_1.Синхронизирован = Истина;
					Строка_2.Синхронизирован = Истина;
					
					Строка_1.Соответствие = ТЗ2.Индекс(Строка_2);
					Строка_2.Соответствие = ТЗ1.Индекс(Строка_1);
					
					Строка_1.Нпп = ТЗ1.Индекс(Строка_1);
				
				КонецЕсли; 
			
			Исключение
				
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ОписаниеОшибки()); 
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Ошибка выполнения правил синхронизации."); 
				Возврат;
			
			КонецПопытки;
		
		КонецЦикла; 
	
	КонецЦикла;
	
	ЗначениеВРеквизитФормы(ТЗ1, "ТабличноеПоле1");
	ЗначениеВРеквизитФормы(ТЗ2, "ТабличноеПоле2");
	
КонецПроцедуры

&НаКлиенте
Процедура Заполнить1(Команда)
	
	Если Не ЗначениеЗаполнено(Объект.Объект1) Тогда 
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не выбран объект 1!");
		Возврат;
	КонецЕсли;
	
	Оповещение = Новый ОписаниеОповещения("Заполнить1Завершение", ЭтотОбъект);
	ОчиститьТаблицу("ТабличноеПоле1", Оповещение);
	
