Функция ПолучитьДатуИзСтроки(ДатаСтрокой)
	Возврат Дата(Прав(ДатаСтрокой,4)+Сред(ДатаСтрокой,4,2)+Лев(ДатаСтрокой,2));
КонецФункции

Процедура ДобавитьСтрокуВДанныеПерсонПоОбъектуXDTO(ОбъектXDTO)
	НоваяСтрока	= ДанныеПерсон.Добавить();
	
	НоваяСтрока.Персона_Ид					= ОбъектXDTO.Ид;
	
	НоваяСтрока.Персона_Фамилия				= СокрЛП(ОбъектXDTO.ПерсИнфо.ФИОД.Фамилия);
	НоваяСтрока.Персона_Имя					= СокрЛП(ОбъектXDTO.ПерсИнфо.ФИОД.Имя);
	НоваяСтрока.Персона_Отчество			= СокрЛП(ОбъектXDTO.ПерсИнфо.ФИОД.Отчество);
	НоваяСтрока.Персона_ДатаРождения		= ПолучитьДатуИзСтроки(СокрЛП(ОбъектXDTO.ПерсИнфо.ФИОД.ДатаРожд));
	
	КодДокументаДляПоиска					= СокрЛП(ОбъектXDTO.ПерсИнфо.Документ.КодВидДок);
	Если СтрДлина(КодДокументаДляПоиска)=1 Тогда
		КодДокументаДляПоиска	= "0"+КодДокументаДляПоиска;
	КонецЕсли;
	
	НоваяСтрока.Документ_ВидУдостоверения	= Справочники.ДокументыУдостоверяющиеЛичность.НайтиПоРеквизиту("КодИМНС", КодДокументаДляПоиска);
	НоваяСтрока.Документ_Серия				= СокрЛП(ОбъектXDTO.ПерсИнфо.Документ.Серия);
	НоваяСтрока.Документ_Номер				= СокрЛП(ОбъектXDTO.ПерсИнфо.Документ.Номер);
	
	НоваяСтрока.Адрес_КодСубъекта			= СокрЛП(ОбъектXDTO.ПерсИнфо.Адрес.КодСубъекта);
	НоваяСтрока.Адрес_НеконфАдрес			= СокрЛП(ОбъектXDTO.ПерсИнфо.Адрес.НеконфАдрес);
	НоваяСтрока.Адрес_КонфАдрес				= СокрЛП(ОбъектXDTO.ПерсИнфо.Адрес.КонфАдрес);
	НоваяСтрока.Адрес_МестоРождения			= СокрЛП(ОбъектXDTO.ПерсИнфо.Адрес.МестоРождения);
	
	НоваяСтрока.СлужИнфо_ВРНКанд			= ОбъектXDTO.СлужИнфо.ВРНКанд;
	
	НоваяСтрока.СлужИнфо_КодСубъекта		= СокрЛП(ОбъектXDTO.СлужИнфо.ИДИнфо.КодСубъекта);
	НоваяСтрока.СлужИнфо_Кампания			= СокрЛП(ОбъектXDTO.СлужИнфо.ИДИнфо.Кампания);
	НоваяСтрока.СлужИнфо_Система			= СокрЛП(ОбъектXDTO.СлужИнфо.ИДИнфо.Система);
	
	НоваяСтрока.СлужИнфо_Выборы				= СокрЛП(ОбъектXDTO.СлужИнфо.Наименование.Выборы);
	НоваяСтрока.СлужИнфо_Субъект			= СокрЛП(ОбъектXDTO.СлужИнфо.Наименование.Субъект);
	НоваяСтрока.СлужИнфо_ДатаСвед			= ПолучитьДатуИзСтроки(СокрЛП(ОбъектXDTO.СлужИнфо.Наименование.ДатаСвед));
	
	НоваяСтрока.МаскаДокумента				= "%"+СтрЗаменить(НоваяСтрока.Документ_Серия, " ", "%")+"%"+СтрЗаменить(НоваяСтрока.Документ_Номер, " ", "%");
КонецПроцедуры

Процедура ЧтениеДанныхИзФайла() Экспорт
	#Если Клиент Тогда
		Состояние("Чтение данных из файла ЦИК");
	#КонецЕсли
	
	ПроверкаПройдена	= Ложь;
	
	ДанныеПерсон.Очистить();
	
	Файл	= Новый Файл(ПутьКФайлу);
	Если Не Файл.Существует() Тогда
		ОбщегоНазначения.СообщитьОбОшибке("При попытке чтения данных 'ЦИК' указанный файл не обнаружен!");
		Возврат;
	КонецЕсли;	
	
	ТекстXML	= Новый ТекстовыйДокумент;
	ТекстXML.Прочитать(ПутьКФайлу, "UTF-8");
	XMLДанные	= ТекстXML.ПолучитьТекст();
	// Обработаем спец символы из-за которых не происходит загрузка
	XMLДанные	= СтрЗаменить(XMLДанные, "&quot;", "-|$|-");
	//---
	ЧтениеXML 	= Новый ЧтениеXML;
	ЧтениеXML.УстановитьСтроку(XMLДанные);
	//---
	Объект		= ФабрикаXDTO.ПрочитатьXML(ЧтениеXML);
	//---
	ВерсияФормы			= СокрЛП(Объект.ВерсФорм);
	ТипИнформации		= СокрЛП(Объект.ТипИнф);
	ВерсияПрограммы		= СокрЛП(Объект.ВерсПрог);
	ИдентификаторФайла	= СокрЛП(Объект.ИдФайл);
	ЗапросИдентификатор	= СокрЛП(Объект.Запрос.Ид);
	ЗапросДата			= ПолучитьДатуИзСтроки(СокрЛП(Объект.Запрос.Дата));
	// Обработаем список Персон и их данные
	Если ТипЗнч(Объект.Персона) = Тип("СписокXDTO") Тогда
		Для Каждого Персона Из Объект.Персона Цикл
			ДобавитьСтрокуВДанныеПерсонПоОбъектуXDTO(Персона);
		КонецЦикла;
	Иначе
		ДобавитьСтрокуВДанныеПерсонПоОбъектуXDTO(Объект.Персона);
	КонецЕсли;
	
	ФормироватьОтветЦИКВНовомФормате = ФормироватьОтветЦИКВНовомФормате();
	Если ФормироватьОтветЦИКВНовомФормате Тогда
		СформироватьВходящийДокумент();
	КонецЕсли;
КонецПроцедуры

Процедура ПроверитьСуществованиеКлиентов() Экспорт
	#Если Клиент Тогда
		Состояние("Проверка данных из файла ЦИК после чтения");
	#КонецЕсли
	
	СтрокиДанныхКУдалению	= Новый Массив;
	ТаблицаОбработанная		= ДанныеПерсон.Выгрузить();	
	
	Запрос	= Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ТЗ.Обработать КАК Обработать,
	|	ТЗ.Персона_Ид КАК Персона_Ид,
	|	ТЗ.Персона_Фамилия КАК Персона_Фамилия,
	|	ТЗ.Персона_Имя КАК Персона_Имя,
	|	ТЗ.Персона_Отчество КАК Персона_Отчество,
	|	ТЗ.Персона_ДатаРождения КАК Персона_ДатаРождения,
	|	ТЗ.Документ_ВидУдостоверения КАК Документ_ВидУдостоверения,
	|	ТЗ.Документ_Серия КАК Документ_Серия,
	|	ТЗ.Документ_Номер КАК Документ_Номер,
	|	ТЗ.Адрес_КодСубъекта КАК Адрес_КодСубъекта,
	|	ТЗ.Адрес_НеконфАдрес КАК Адрес_НеконфАдрес,
	|	ТЗ.Адрес_КонфАдрес КАК Адрес_КонфАдрес,
	|	ТЗ.Адрес_МестоРождения КАК Адрес_МестоРождения,
	|	ТЗ.СлужИнфо_ВРНКанд КАК СлужИнфо_ВРНКанд,
	|	ТЗ.СлужИнфо_КодСубъекта КАК СлужИнфо_КодСубъекта,
	|	ТЗ.СлужИнфо_Кампания КАК СлужИнфо_Кампания,
	|	ТЗ.СлужИнфо_Система КАК СлужИнфо_Система,
	|	ТЗ.СлужИнфо_Выборы КАК СлужИнфо_Выборы,
	|	ТЗ.СлужИнфо_Субъект КАК СлужИнфо_Субъект,
	|	ТЗ.СлужИнфо_ДатаСвед КАК СлужИнфо_ДатаСвед,
	|	ТЗ.МаскаДокумента КАК МаскаДокумента
	|ПОМЕСТИТЬ ДанныеЧтения
	|ИЗ
	|	&ТЗ КАК ТЗ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ФИОФизЛиц.ФизЛицо КАК ФизЛицо,
	|	ФИОФизЛиц.Фамилия КАК Фамилия,
	|	ФИОФизЛиц.Имя КАК Имя,
	|	ФИОФизЛиц.Отчество КАК Отчество,
	|	ФИОФизЛиц.Период КАК НачалоДействия,
	|	МИНИМУМ(ЕСТЬNULL(ФИОФизЛицСледующиеЗаписи.Период, &ПустаяДата)) КАК КонецДействия,
	|	ФизическиеЛица.ДатаРождения КАК ДатаРождения
	|ПОМЕСТИТЬ ПериодыАктуальностиФИО
	|ИЗ
	|	РегистрСведений.ФИОФизЛиц КАК ФИОФизЛиц
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ФИОФизЛиц КАК ФИОФизЛицСледующиеЗаписи
	|		ПО ФИОФизЛиц.ФизЛицо = ФИОФизЛицСледующиеЗаписи.ФизЛицо
	|			И ФИОФизЛиц.Период < ФИОФизЛицСледующиеЗаписи.Период
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ФизическиеЛица КАК ФизическиеЛица
	|		ПО ФИОФизЛиц.ФизЛицо = ФизическиеЛица.Ссылка
	|
	|СГРУППИРОВАТЬ ПО
	|	ФИОФизЛиц.ФизЛицо,
	|	ФИОФизЛиц.Фамилия,
	|	ФИОФизЛиц.Имя,
	|	ФИОФизЛиц.Отчество,
	|	ФИОФизЛиц.Период,
	|	ФизическиеЛица.ДатаРождения
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ДанныеЧтения.Персона_Фамилия КАК Персона_Фамилия,
	|	ДанныеЧтения.Персона_Имя КАК Персона_Имя,
	|	ДанныеЧтения.Персона_Отчество КАК Персона_Отчество,
	|	ДанныеЧтения.Персона_ДатаРождения КАК Персона_ДатаРождения,
	|	ДанныеЧтения.Документ_ВидУдостоверения КАК Документ_ВидУдостоверения,
	|	ДанныеЧтения.Документ_Серия КАК Документ_Серия,
	|	ДанныеЧтения.Документ_Номер КАК Документ_Номер,
	|	ДанныеЧтения.МаскаДокумента КАК МаскаДокумента,
	|	ДанныеЧтения.СлужИнфо_ДатаСвед КАК СлужИнфо_ДатаСвед,
	|	ДанныеЧтения.Обработать КАК Обработать,
	|	ДанныеЧтения.Персона_Ид КАК Персона_Ид,
	|	ДанныеЧтения.Адрес_КодСубъекта КАК Адрес_КодСубъекта,
	|	ДанныеЧтения.Адрес_НеконфАдрес КАК Адрес_НеконфАдрес,
	|	ДанныеЧтения.Адрес_КонфАдрес КАК Адрес_КонфАдрес,
	|	ДанныеЧтения.Адрес_МестоРождения КАК Адрес_МестоРождения,
	|	ДанныеЧтения.СлужИнфо_ВРНКанд КАК СлужИнфо_ВРНКанд,
	|	ДанныеЧтения.СлужИнфо_КодСубъекта КАК СлужИнфо_КодСубъекта,
	|	ДанныеЧтения.СлужИнфо_Кампания КАК СлужИнфо_Кампания,
	|	ДанныеЧтения.СлужИнфо_Система КАК СлужИнфо_Система,
	|	ДанныеЧтения.СлужИнфо_Выборы КАК СлужИнфо_Выборы,
	|	ДанныеЧтения.СлужИнфо_Субъект КАК СлужИнфо_Субъект,
	|	ЕСТЬNULL(ПериодыАктуальностиФИО.ФизЛицо, &ПустоеФизлицо) КАК Физлицо
	|ПОМЕСТИТЬ ДанныеЧтенияСФизлицами
	|ИЗ
	|	ДанныеЧтения КАК ДанныеЧтения
	|		ЛЕВОЕ СОЕДИНЕНИЕ ПериодыАктуальностиФИО КАК ПериодыАктуальностиФИО
	|		ПО ДанныеЧтения.Персона_Фамилия = ПериодыАктуальностиФИО.Фамилия
	|			И ДанныеЧтения.Персона_Имя = ПериодыАктуальностиФИО.Имя
	|			И (ДанныеЧтения.Персона_Отчество = ПериодыАктуальностиФИО.Отчество
	|				ИЛИ ДанныеЧтения.Персона_Отчество = &ПустаяСтрока)
	|			И ДанныеЧтения.СлужИнфо_ДатаСвед >= ПериодыАктуальностиФИО.НачалоДействия
	|			И (ДанныеЧтения.СлужИнфо_ДатаСвед < ПериодыАктуальностиФИО.КонецДействия
	|				ИЛИ ПериодыАктуальностиФИО.КонецДействия = &ПустаяДата)
	|			И ДанныеЧтения.Персона_ДатаРождения = ПериодыАктуальностиФИО.ДатаРождения
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ДанныеЧтенияСФизлицами.Физлицо КАК Физлицо,
	|	МАКСИМУМ(ЕСТЬNULL(ПаспортныеДанныеФизЛиц.Период, &ПустаяДата)) КАК Период
	|ПОМЕСТИТЬ ПериодыУстановкиПаспортныхДанныхПоФЛ
	|ИЗ
	|	ДанныеЧтенияСФизлицами КАК ДанныеЧтенияСФизлицами
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ПаспортныеДанныеФизЛиц КАК ПаспортныеДанныеФизЛиц
	|		ПО ДанныеЧтенияСФизлицами.Физлицо = ПаспортныеДанныеФизЛиц.ФизЛицо
	|			И ДанныеЧтенияСФизлицами.СлужИнфо_ДатаСвед >= ПаспортныеДанныеФизЛиц.Период
	|ГДЕ
	|	ДанныеЧтенияСФизлицами.Физлицо <> &ПустоеФизлицо
	|
	|СГРУППИРОВАТЬ ПО
	|	ДанныеЧтенияСФизлицами.Физлицо
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ДанныеЧтенияСФизлицами.Физлицо КАК Физлицо,
	|	МАКСИМУМ(ЕСТЬNULL(ПаспортныеДанныеФизЛиц.Период, &ПустаяДата)) КАК Период
	|ПОМЕСТИТЬ ПериодыУстановкиПаспортныхДанныхПоУдостоверению
	|ИЗ
	|	ДанныеЧтенияСФизлицами КАК ДанныеЧтенияСФизлицами
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ПаспортныеДанныеФизЛиц КАК ПаспортныеДанныеФизЛиц
	|		ПО ДанныеЧтенияСФизлицами.Документ_ВидУдостоверения = ПаспортныеДанныеФизЛиц.ДокументВид
	|			И (ПаспортныеДанныеФизЛиц.ДокументСерия + ПаспортныеДанныеФизЛиц.ДокументНомер ПОДОБНО ДанныеЧтенияСФизлицами.МаскаДокумента)
	|ГДЕ
	|	ДанныеЧтенияСФизлицами.Физлицо <> &ПустоеФизлицо
	|
	|СГРУППИРОВАТЬ ПО
	|	ДанныеЧтенияСФизлицами.Физлицо
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ДанныеЧтенияСФизлицами.Обработать КАК Обработать,
	|	ДанныеЧтенияСФизлицами.Персона_Ид КАК Персона_Ид,
	|	ДанныеЧтенияСФизлицами.Персона_Фамилия КАК Персона_Фамилия,
	|	ДанныеЧтенияСФизлицами.Персона_Имя КАК Персона_Имя,
	|	ДанныеЧтенияСФизлицами.Персона_Отчество КАК Персона_Отчество,
	|	ДанныеЧтенияСФизлицами.Персона_ДатаРождения КАК Персона_ДатаРождения,
	|	ДанныеЧтенияСФизлицами.Документ_ВидУдостоверения КАК Документ_ВидУдостоверения,
	|	ДанныеЧтенияСФизлицами.Документ_Серия КАК Документ_Серия,
	|	ДанныеЧтенияСФизлицами.Документ_Номер КАК Документ_Номер,
	|	ДанныеЧтенияСФизлицами.Адрес_КодСубъекта КАК Адрес_КодСубъекта,
	|	ДанныеЧтенияСФизлицами.Адрес_НеконфАдрес КАК Адрес_НеконфАдрес,
	|	ДанныеЧтенияСФизлицами.Адрес_КонфАдрес КАК Адрес_КонфАдрес,
	|	ДанныеЧтенияСФизлицами.Адрес_МестоРождения КАК Адрес_МестоРождения,
	|	ДанныеЧтенияСФизлицами.СлужИнфо_ВРНКанд КАК СлужИнфо_ВРНКанд,
	|	ДанныеЧтенияСФизлицами.СлужИнфо_КодСубъекта КАК СлужИнфо_КодСубъекта,
	|	ДанныеЧтенияСФизлицами.СлужИнфо_Кампания КАК СлужИнфо_Кампания,
	|	ДанныеЧтенияСФизлицами.СлужИнфо_Система КАК СлужИнфо_Система,
	|	ДанныеЧтенияСФизлицами.СлужИнфо_Выборы КАК СлужИнфо_Выборы,
	|	ДанныеЧтенияСФизлицами.СлужИнфо_Субъект КАК СлужИнфо_Субъект,
	|	ДанныеЧтенияСФизлицами.СлужИнфо_ДатаСвед КАК СлужИнфо_ДатаСвед,
	|	ДанныеЧтенияСФизлицами.МаскаДокумента КАК МаскаДокумента,
	|	ЕСТЬNULL(Контрагенты.Ссылка, &ПустойКонтрагент) КАК Контрагент1СПоФИО,
	|	ЕСТЬNULL(ВЫРАЗИТЬ(Контрагенты.ЮридическиеФизическиеЛица КАК Справочник.ФизическиеЛица).ДатаРождения, &ПустаяДата) КАК Контрагент1С_ДатаРождения,
	|	ЕСТЬNULL(КонтрагентыПоПаспортнымДаннымФизлиц.Ссылка, &ПустойКонтрагент) КАК Контрагент1СПоДокументу,
	|	ЕСТЬNULL(ПДФЛ_ФИО.ДокументВид, &ПустойВидДокумента) КАК ВидУдостоверенияПоФИО,
	|	ЕСТЬNULL(ПДФЛ_ФИО.ДокументСерия, &ПустаяСтрока) КАК СерияПоФИО,
	|	ЕСТЬNULL(ПДФЛ_ФИО.ДокументНомер, &ПустаяСтрока) КАК НомерПоФИО,
	|	ДанныеЧтенияСФизлицами.Физлицо КАК Физлицо
	|ПОМЕСТИТЬ ПодготовленныеДанные
	|ИЗ
	|	ДанныеЧтенияСФизлицами КАК ДанныеЧтенияСФизлицами
	|		ЛЕВОЕ СОЕДИНЕНИЕ ПериодыУстановкиПаспортныхДанныхПоФЛ КАК ПериодыУстановкиПаспортныхДанныхПоФЛ
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ПаспортныеДанныеФизЛиц КАК ПДФЛ_ФИО
	|			ПО ПериодыУстановкиПаспортныхДанныхПоФЛ.Физлицо = ПДФЛ_ФИО.ФизЛицо
	|				И ПериодыУстановкиПаспортныхДанныхПоФЛ.Период = ПДФЛ_ФИО.Период
	|		ПО ДанныеЧтенияСФизлицами.Физлицо = ПериодыУстановкиПаспортныхДанныхПоФЛ.Физлицо
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Контрагенты КАК Контрагенты
	|		ПО ДанныеЧтенияСФизлицами.Физлицо = Контрагенты.ЮридическиеФизическиеЛица
	|		ЛЕВОЕ СОЕДИНЕНИЕ ПериодыУстановкиПаспортныхДанныхПоУдостоверению КАК ПериодыУстановкиПаспортныхДанныхПоУдостоверению
	|		ПО ДанныеЧтенияСФизлицами.Физлицо = ПериодыУстановкиПаспортныхДанныхПоУдостоверению.Физлицо
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Контрагенты КАК КонтрагентыПоПаспортнымДаннымФизлиц
	|		ПО (ПериодыУстановкиПаспортныхДанныхПоУдостоверению.Физлицо = КонтрагентыПоПаспортнымДаннымФизлиц.ЮридическиеФизическиеЛица)
	|ГДЕ
	|	(НЕ Контрагенты.Ссылка ЕСТЬ NULL
	|			ИЛИ НЕ КонтрагентыПоПаспортнымДаннымФизлиц.Ссылка ЕСТЬ NULL)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ПодготовленныеДанные.Контрагент1СПоФИО КАК Контрагент,
	|	ПодготовленныеДанные.СлужИнфо_ДатаСвед КАК ДатаСведений
	|ПОМЕСТИТЬ КонтрагентыИДатыДляПолученияОстатков
	|ИЗ
	|	ПодготовленныеДанные КАК ПодготовленныеДанные
	|ГДЕ
	|	ПодготовленныеДанные.Контрагент1СПоФИО <> &ПустойКонтрагент
	|
	|ОБЪЕДИНИТЬ
	|
	|ВЫБРАТЬ
	|	ПодготовленныеДанные.Контрагент1СПоДокументу,
	|	ПодготовленныеДанные.СлужИнфо_ДатаСвед
	|ИЗ
	|	ПодготовленныеДанные КАК ПодготовленныеДанные
	|ГДЕ
	|	ПодготовленныеДанные.Контрагент1СПоДокументу <> &ПустойКонтрагент
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	КонтрагентыСОстаткамиЦБ.ДатаСведений КАК ДатаСведений,
	|	КонтрагентыСОстаткамиЦБ.Контрагент КАК Контрагент,
	|	СУММА(КонтрагентыСОстаткамиЦБ.КоличествоОстаток) КАК КоличествоОстаток
	|ПОМЕСТИТЬ КонтрагентыСОстаткамиЦБ
	|ИЗ
	|	ТекстЗапросаПолученияОстатковЦБ КАК КонтрагентыСОстаткамиЦБ
	|
	|СГРУППИРОВАТЬ ПО
	|	КонтрагентыСОстаткамиЦБ.Контрагент,
	|	КонтрагентыСОстаткамиЦБ.ДатаСведений
	|
	|ИМЕЮЩИЕ
	|	СУММА(КонтрагентыСОстаткамиЦБ.КоличествоОстаток) > 0
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ПодготовленныеДанные.Обработать КАК Обработать,
	|	ПодготовленныеДанные.Персона_Ид КАК Персона_Ид,
	|	ПодготовленныеДанные.Персона_Фамилия КАК Персона_Фамилия,
	|	ПодготовленныеДанные.Персона_Имя КАК Персона_Имя,
	|	ПодготовленныеДанные.Персона_Отчество КАК Персона_Отчество,
	|	ПодготовленныеДанные.Персона_ДатаРождения КАК Персона_ДатаРождения,
	|	ПодготовленныеДанные.Документ_ВидУдостоверения КАК Документ_ВидУдостоверения,
	|	ПодготовленныеДанные.Документ_Серия КАК Документ_Серия,
	|	ПодготовленныеДанные.Документ_Номер КАК Документ_Номер,
	|	ПодготовленныеДанные.Адрес_КодСубъекта КАК Адрес_КодСубъекта,
	|	ПодготовленныеДанные.Адрес_НеконфАдрес КАК Адрес_НеконфАдрес,
	|	ПодготовленныеДанные.Адрес_КонфАдрес КАК Адрес_КонфАдрес,
	|	ПодготовленныеДанные.Адрес_МестоРождения КАК Адрес_МестоРождения,
	|	ПодготовленныеДанные.СлужИнфо_ВРНКанд КАК СлужИнфо_ВРНКанд,
	|	ПодготовленныеДанные.СлужИнфо_КодСубъекта КАК СлужИнфо_КодСубъекта,
	|	ПодготовленныеДанные.СлужИнфо_Кампания КАК СлужИнфо_Кампания,
	|	ПодготовленныеДанные.СлужИнфо_Система КАК СлужИнфо_Система,
	|	ПодготовленныеДанные.СлужИнфо_Выборы КАК СлужИнфо_Выборы,
	|	ПодготовленныеДанные.СлужИнфо_Субъект КАК СлужИнфо_Субъект,
	|	ПодготовленныеДанные.СлужИнфо_ДатаСвед КАК СлужИнфо_ДатаСвед,
	|	ПодготовленныеДанные.МаскаДокумента КАК МаскаДокумента,
	|	ПодготовленныеДанные.Контрагент1СПоФИО КАК Контрагент1СПоФИО,
	|	ПодготовленныеДанные.Контрагент1С_ДатаРождения КАК Контрагент1С_ДатаРождения,
	|	ПодготовленныеДанные.Контрагент1СПоДокументу КАК Контрагент1СПоДокументу,
	|	ПодготовленныеДанные.ВидУдостоверенияПоФИО КАК ВидУдостоверенияПоФИО,
	|	ПодготовленныеДанные.СерияПоФИО КАК СерияПоФИО,
	|	ПодготовленныеДанные.НомерПоФИО КАК НомерПоФИО
	|ИЗ
	|	ПодготовленныеДанные КАК ПодготовленныеДанные
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ КонтрагентыСОстаткамиЦБ КАК КонтрагентыСОстаткамиЦБ
	|		ПО (ПодготовленныеДанные.Контрагент1СПоФИО = КонтрагентыСОстаткамиЦБ.Контрагент
	|				ИЛИ ПодготовленныеДанные.Контрагент1СПоДокументу = КонтрагентыСОстаткамиЦБ.Контрагент)
	|			И ПодготовленныеДанные.СлужИнфо_ДатаСвед = КонтрагентыСОстаткамиЦБ.ДатаСведений
	|
	|УПОРЯДОЧИТЬ ПО
	|	Персона_Фамилия,
	|	Персона_Имя,
	|	Персона_Отчество,
	|	Документ_Серия,
	|	Документ_Номер";
	
	ДополнениеКЗапросу = ДополнениеКЗапросуДляПолученияОстатковЦБ();
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "ТекстЗапросаПолученияОстатковЦБ", ДополнениеКЗапросу.ТекстЗапроса);
	
	Для Каждого Параметр Из ДополнениеКЗапросу.Параметры Цикл
		Запрос.УстановитьПараметр(Параметр.Ключ, Параметр.Значение);
	КонецЦикла;
	Запрос.УстановитьПараметр("ТЗ"			, ТаблицаОбработанная);
	Запрос.УстановитьПараметр("ДатаПроверки", ДатаОтвета);
	Запрос.УстановитьПараметр("ПустаяДата", Дата(1, 1, 1));
	Запрос.УстановитьПараметр("ПустаяСтрока", "");
	Запрос.УстановитьПараметр("ПустоеФизлицо", Справочники.ФизическиеЛица.ПустаяСсылка());
	Запрос.УстановитьПараметр("ПустойКонтрагент", Справочники.Контрагенты.ПустаяСсылка());
	Запрос.УстановитьПараметр("ПустойВидДокумента", Справочники.ДокументыУдостоверяющиеЛичность.ПустаяСсылка());
	
	Результат = Запрос.Выполнить().Выгрузить();
	
	Для Каждого Строка Из Результат Цикл
		Если Строка.Контрагент1СПоФИО = Строка.Контрагент1СПоДокументу Тогда
			Строка.Обработать = Истина;			
		КонецЕсли;		
		Если Не ЗначениеЗаполнено(Строка.Контрагент1СПоФИО)
			Или Не ЗначениеЗаполнено(Строка.Контрагент1СПоДокументу) Тогда
			ТекстСообщения = "Не удалось найти клиента: " + Строка.Персона_Фамилия + " " + Строка.Персона_Имя
			+ " " + Строка.Персона_Отчество + " Паспорт " + Строка.Документ_Серия + " " + Строка.Документ_Номер;
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
		КонецЕсли;
	КонецЦикла;	
	
	ДанныеПерсон.Очистить();	
	ДанныеПерсон.Загрузить(Результат);
	
	ПроверкаПройдена = Истина;
КонецПроцедуры

Функция ПолучитьОстаткиЦБПоКлиенту(Строка)
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ОстаткиЦБОстатки.ЦБ КАК ЦБ,
	|	ОстаткиЦБОстатки.КоличествоОстаток КАК КоличествоОстаток
	|ИЗ
	|	РегистрНакопления.ОстаткиЦБ.Остатки(&ДатаРасчета, СчетДепо.Владелец = &Клиент) КАК ОстаткиЦБОстатки
	|
	|УПОРЯДОЧИТЬ ПО
	|	ОстаткиЦБОстатки.ЦБ.ISIN,
	|	ОстаткиЦБОстатки.ЦБ.Код";
	
	ДатаРасчета = ?(ЗначениеЗаполнено(Строка.СлужИнфо_ДатаСвед), Строка.СлужИнфо_ДатаСвед, ДатаОтвета);
	Запрос.УстановитьПараметр("ДатаРасчета"	, ДатаРасчета);
	Запрос.УстановитьПараметр("Клиент"		, ?(ЗначениеЗаполнено(Строка.Контрагент1СПоДокументу), Строка.Контрагент1СПоДокументу, Строка.Контрагент1СПоФИО));
	
	Возврат Запрос.Выполнить().Выгрузить();
КонецФункции

Процедура СозданиеФайлаПроверки() Экспорт
	Файл	= Новый Файл(ПутьКФайлу);
	Если Не Файл.Существует() Тогда
		ОбщегоНазначения.СообщитьОбОшибке("При попытке проверки данных 'ЦИК' перед формированием не обнаружен каталог!");
		Возврат;
	Иначе
		КаталогЗаписи	= Файл.Путь;
		ОГРН			= Константы.ОрганизацияПоУмолчанию.Получить().ОГРН;
		КодЗапроса		= Сред(Файл.ИмяБезРасширения, 23, 1);
		НомерЗапроса	= Сред(Файл.ИмяБезРасширения, 25, 4);
		ИмяФайла		= "D" + ОГРН + "_" + Формат(ДатаОтвета, "ДФ=ddMMyy_HHmmss") + "_" + КодЗапроса + "_" + НомерЗапроса;
	КонецЕсли;
	
	ФормироватьОтветЦИКВНовомФормате = ФормироватьОтветЦИКВНовомФормате();
	
	БазоваяВалюта = Константы.ВалютаРегламентированногоУчета.Получить();
	// Флаг что выгружены данные хотя бы по 1 клиенту
	ДанныеПерсонВыгружались	= Ложь;
	// Создадим файл и заполним базовые параметры
	ПространствоИмен	= "VO_CIK_CB_7.xsd";
	// Объявим объект для записи XML
	ЗаписьXML	= Новый ЗаписьXML;
	ЗаписьXML.УстановитьСтроку("UTF-8");
	ЗаписьXML.ЗаписатьОбъявлениеXML();
	// {{ Файл
	Файл_Тип		= ФабрикаXDTO.Пакеты.Получить(ПространствоИмен).КорневыеСвойства.Получить("Файл").Тип;
	Файл			= ФабрикаXDTO.Создать(Файл_Тип);
		// {{ Заполним параметры
		Файл.ВерсПрог	= СокрЛП(СтрЗаменить(ВерсияПрограммы	, "-|$|-", "&quot;"));
		Файл.ВерсФорм	= СокрЛП(СтрЗаменить(ВерсияФормы		, "-|$|-", "&quot;"));
		Файл.ТипИнф		= СокрЛП(СтрЗаменить(ТипИнформации		, "-|$|-", "&quot;"));
		Файл.ИдФайл		= ИмяФайла;
		// {{ Запрос
			Запрос_Тип		= СвойствоКоллекцииXDTO(Файл.Свойства(),"Запрос").Тип;
			Запрос			= ФабрикаXDTO.Создать(Запрос_Тип);
			// {{ Заполним параметры
	        Запрос.Ид		= СокрЛП(ЗапросИдентификатор);
			Запрос.Дата		= Формат(ЗапросДата, "ДФ=dd.MM.yyyy");
			// }}
	    Файл.Запрос		= Запрос;
		// {{ ИнфОрг
			ИнфОрг_Тип		= СвойствоКоллекцииXDTO(Файл.Свойства(), "ИнфОрг").Тип;
			ИнфОрг			= ФабрикаXDTO.Создать(ИнфОрг_Тип);
			// {{ Заполним параметры
			ИнфОрг.Адрес	= СокрЛП(РегистрыСведений.КонтактнаяИнформация.ПолучитьПоследнее(, Новый Структура("Объект, Тип, Вид", Константы.ОрганизацияПоУмолчанию.Получить(), Перечисления.ТипыКонтактнойИнформации.Адрес, Справочники.ВидыКонтактнойИнформации.ЮрАдресОрганизации))["Представление"]);
			ИнфОрг.ИНН		= Константы.ОрганизацияПоУмолчанию.Получить().ИНН;
			ИнфОрг.Название	= СокрЛП(Константы.ОрганизацияПоУмолчанию.Получить().Наименование);
			ИнфОрг.ОГРН		= Константы.ОрганизацияПоУмолчанию.Получить().ОГРН;
			ИнфОрг.ФИО		= СокрЛП(ПараметрыСеанса.ТекущийПользователь.Наименование);
			ИнфОрг.Телефон	= СокрЛП(РегистрыСведений.КонтактнаяИнформация.ПолучитьПоследнее(, Новый Структура("Объект, Тип, Вид", ПараметрыСеанса.ТекущийПользователь, Перечисления.ТипыКонтактнойИнформации.Телефон, Справочники.ВидыКонтактнойИнформации.ТелефонПользователя))["Представление"]);
			ИнфОрг.ЭлПочта	= СокрЛП(РегистрыСведений.КонтактнаяИнформация.ПолучитьПоследнее(, Новый Структура("Объект, Тип, Вид", ПараметрыСеанса.ТекущийПользователь, Перечисления.ТипыКонтактнойИнформации.АдресЭлектроннойПочты, Справочники.ВидыКонтактнойИнформации.EmailПользователя))["Представление"]);
			// }}
		Файл.ИнфОрг		= ИнфОрг;
	
	Для Каждого Строка Из ДанныеПерсон Цикл
		Если Не Строка.Обработать Тогда
			Продолжить;
		КонецЕсли;
		// {{ Персона
			Персона_Тип		= СвойствоКоллекцииXDTO(Файл.Свойства(), "Персона").Тип;
			Персона			= ФабрикаXDTO.Создать(Персона_Тип);
			Персона.Ид		= Строка.Персона_Ид;
			// {{ ПерсИнфо
				ПерсИнфо_Тип	= СвойствоКоллекцииXDTO(Персона.Свойства(), "ПерсИнфо").Тип;
				ПерсИнфо		= ФабрикаXDTO.Создать(ПерсИнфо_Тип);
				// {{ ФИОД
					ФИОД_Тип		= СвойствоКоллекцииXDTO(ПерсИнфо.Свойства(), "ФИОД").Тип;
					ФИОД			= ФабрикаXDTO.Создать(ФИОД_Тип);
				    //---
					ФИОД.Фамилия	= СокрЛП(СтрЗаменить(Строка.Персона_Фамилия	, "-|$|-", "&quot;"));
					ФИОД.Имя		= СокрЛП(СтрЗаменить(Строка.Персона_Имя		, "-|$|-", "&quot;"));
					ФИОД.Отчество	= СокрЛП(СтрЗаменить(Строка.Персона_Отчество, "-|$|-", "&quot;"));
					ФИОД.ДатаРожд	= Формат(Строка.Персона_ДатаРождения, "ДФ=dd.MM.yyyy");
					// }}
				ПерсИнфо.ФИОД		= ФИОД;
				// {{ Адрес
					Адрес_Тип		= СвойствоКоллекцииXDTO(ПерсИнфо.Свойства(), "Адрес").Тип;
					Адрес			= ФабрикаXDTO.Создать(Адрес_Тип);
					Адрес.КодСубъекта	= СокрЛП(СтрЗаменить(Строка.Адрес_КодСубъекта	, "-|$|-", "&quot;"));
					Адрес.НеконфАдрес	= СокрЛП(СтрЗаменить(Строка.Адрес_НеконфАдрес	, "-|$|-", "&quot;"));
					Адрес.КонфАдрес		= СокрЛП(СтрЗаменить(Строка.Адрес_КонфАдрес		, "-|$|-", "&quot;"));
					Адрес.МестоРождения	= СокрЛП(СтрЗаменить(Строка.Адрес_МестоРождения	, "-|$|-", "&quot;"));
					// }}
				ПерсИнфо.Адрес		= Адрес;
				// {{ Документ
					Документ_Тип	= СвойствоКоллекцииXDTO(ПерсИнфо.Свойства(), "Документ").Тип;
					Документ		= ФабрикаXDTO.Создать(Документ_Тип);
					Документ.КодВидДок	= СокрЛП(Строка.Документ_ВидУдостоверения.КодИМНС);
					Документ.Серия		= СокрЛП(Строка.Документ_Серия);
					Документ.Номер		= СокрЛП(Строка.Документ_Номер);
					// }}
				ПерсИнфо.Документ	= Документ;
			// }}
			Персона.ПерсИнфо	= ПерсИнфо;
			// {{ СлужИнфо
				СлужИнфо_Тип	= СвойствоКоллекцииXDTO(Персона.Свойства(), "СлужИнфо").Тип;
				СлужИнфо		= ФабрикаXDTO.Создать(СлужИнфо_Тип);
				// {{ Заполним параметры
				СлужИнфо.ВРНКанд		= Строка.СлужИнфо_ВРНКанд;
				    // {{ ИДИнфо
					ИДИнфо_Тип	= СвойствоКоллекцииXDTO(СлужИнфо.Свойства(), "ИДИнфо").Тип;
					ИДИнфо		= ФабрикаXDTO.Создать(ИДИнфо_Тип);
					ИДИнфо.КодСубъекта	= СокрЛП(Строка.СлужИнфо_КодСубъекта);
					ИДИнфо.Кампания		= СокрЛП(СтрЗаменить(Строка.СлужИнфо_Кампания	, "-|$|-", "&quot;"));
					ИДИнфо.Система		= СокрЛП(СтрЗаменить(Строка.СлужИнфо_Система	, "-|$|-", "&quot;"));
					// }}
				СлужИнфо.ИДИнфо		= ИДИнфо;
				    // {{ ИДИнфо
					Наименование_Тип	= СвойствоКоллекцииXDTO(СлужИнфо.Свойства(),"Наименование").Тип;
					Наименование		= ФабрикаXDTO.Создать(Наименование_Тип);
					Наименование.Выборы		= СокрЛП(СтрЗаменить(Строка.СлужИнфо_Выборы	, "-|$|-", "&quot;"));
					Наименование.Субъект	= СокрЛП(СтрЗаменить(Строка.СлужИнфо_Субъект, "-|$|-", "&quot;"));
					Наименование.ДатаСвед	= Формат(Строка.СлужИнфо_ДатаСвед, "ДФ=dd.MM.yyyy");
					// }}
				СлужИнфо.Наименование	= Наименование;
			// }}
			Персона.СлужИнфо	= СлужИнфо;
				// Список ЦБ и Остатков по Клиенту
				СписокОстатковЦБ	= ПолучитьОстаткиЦБПоКлиенту(Строка);
				Для Каждого СтрокаОстатков ИЗ СписокОстатковЦБ Цикл
					// {{ ЦенныеБумаги
						ЦенныеБумаги_Тип 		= СвойствоКоллекцииXDTO(Персона.Свойства(), "ЦенныеБумаги").Тип;
						ЦенныеБумаги			= ФабрикаXDTO.Создать(ЦенныеБумаги_Тип);
						ЦеннаяБумага1С			= СтрокаОстатков["ЦБ"];
						ЦенныеБумаги.ИдБумаги	= Строка(ЦеннаяБумага1С.УникальныйИдентификатор());
						// {{ Организация
							Организация_Тип		= СвойствоКоллекцииXDTO(ЦенныеБумаги.Свойства(), "Организация").Тип;
							Организация			= ФабрикаXDTO.Создать(Организация_Тип);
							//---
							ИменаРеквизитовЦБ = Новый Структура;
							ИменаРеквизитовЦБ.Вставить("ISIN", "ISIN");
							ИменаРеквизитовЦБ.Вставить("CFI", "CFI");
							ИменаРеквизитовЦБ.Вставить("ТипЦБ", "ТипЦБ");
							ИменаРеквизитовЦБ.Вставить("ВидЦБ", "ВидЦБ");
							ИменаРеквизитовЦБ.Вставить("ВалютаНоминала", "ВалютаНоминала");
							ИменаРеквизитовЦБ.Вставить("КодВидаЦББанкаРоссии", "ВидЦББанкаРоссии.Код");
							ИменаРеквизитовЦБ.Вставить("ЭмитентНаименование", "Эмитент.Наименование");
							ИменаРеквизитовЦБ.Вставить("ЭмитентНаименованиеПолное", "Эмитент.НаименованиеПолное");
							ИменаРеквизитовЦБ.Вставить("ЭмитентИНН", "Эмитент.ИНН");
							ИменаРеквизитовЦБ.Вставить("МеждународнаяОрганизация", "Эмитент.ЮридическиеФизическиеЛица.МеждународнаяОрганизация");
							ИменаРеквизитовЦБ.Вставить("КодСтраны", "Эмитент.ЮридическиеФизическиеЛица.Страна.Код");
							ИменаРеквизитовЦБ.Вставить("НаименованиеСтраны", "Эмитент.ЮридическиеФизическиеЛица.Страна.НаименованиеПолное");
							ИменаРеквизитовЦБ.Вставить("ЮридическиеФизическиеЛица", "Эмитент.ЮридическиеФизическиеЛица");
							РеквизитыЦБ = ОбщегоНазначения.ПолучитьЗначенияРеквизитов(ЦеннаяБумага1С, ИменаРеквизитовЦБ);
							
							Организация.ДоляЗнаменатель	= "";
							Организация.ДоляПроцент		= "";
							Организация.ДоляЧислитель	= "";
							Организация.КодСубОрг		= "";
							Организация.КонфАдрОрг		= "";
							Организация.НеконфАдрОрг	= "";
							Организация.Статус			= "";
							Организация.ПИФ				= ?(РеквизитыЦБ.ТипЦБ = Перечисления.ТипыЦБ.Пай, СокрЛП(ЦеннаяБумага1С), "");
							Организация.Название		= ?(ЗначениеЗаполнено(РеквизитыЦБ.ЭмитентНаименованиеПолное), СокрЛП(РеквизитыЦБ.ЭмитентНаименованиеПолное), СокрЛП(РеквизитыЦБ.ЭмитентНаименование));
							Организация.ИННОрг			= ?(ЗначениеЗаполнено(РеквизитыЦБ.ЭмитентИНН), РеквизитыЦБ.ЭмитентИНН, "0000000000");
							Если ФормироватьОтветЦИКВНовомФормате Тогда
								Организация.ОКСМ = КодСтраныЭмитента(РеквизитыЦБ);
								Если Организация.ОКСМ = "996" Или Организация.ОКСМ = "998" Или Организация.ОКСМ = "999" Тогда
									Организация.Страна = "";
								Иначе
									Организация.Страна = РеквизитыЦБ.НаименованиеСтраны;
								КонецЕсли;
							КонецЕсли;
						// }}
						ЦенныеБумаги.Организация = Организация;
						// {{ Бумага
							Бумага_Тип			= СвойствоКоллекцииXDTO(ЦенныеБумаги.Свойства(), "Бумага").Тип;
							Бумага				= ФабрикаXDTO.Создать(Бумага_Тип);
							//---
							Если РеквизитыЦБ.ТипЦБ = Перечисления.ТипыЦБ.Акция Тогда
								Бумага.КодВидБум		= 91;
							ИначеЕсли РеквизитыЦБ.ТипЦБ = Перечисления.ТипыЦБ.Облигация Тогда
								Бумага.КодВидБум		= 1;
							ИначеЕсли РеквизитыЦБ.ТипЦБ = Перечисления.ТипыЦБ.Пай Тогда
								Бумага.КодВидБум		= 93;
							ИначеЕсли Перечисления.ТипыЦБ.ЭтоДепозитарнаяРасписка(РеквизитыЦБ.ТипЦБ) Тогда
								Бумага.КодВидБум		= 96;
							КонецЕсли;
							Бумага.КодКатег		= ?(РеквизитыЦБ.ТипЦБ = Перечисления.ТипыЦБ.Акция, ?(РеквизитыЦБ.ВидЦБ = Перечисления.ВидыАкций.Обыкновенная, "1", "2"), "");
							Бумага.Колво		= СтрокаОстатков["КоличествоОстаток"];
							Бумага.КолвоЗнам	= 0;
							Бумага.КолвоЧисл	= 0;
							
							Если РеквизитыЦБ.ТипЦБ = Перечисления.ТипыЦБ.Пай
								Или РеквизитыЦБ.ТипЦБ = Перечисления.ТипыЦБ.ДепозитарнаяРасписка Тогда
								Бумага.Стоимость = 0;
							ИначеЕсли Не ЗначениеЗаполнено(РеквизитыЦБ.ВалютаНоминала) Тогда
								Бумага.Стоимость = 0;
								ТекстСообщения = СтрШаблон("Не заполнена валюта номинала у ценной бумаги '%1' (ISIN %2)", ЦеннаяБумага1С, РеквизитыЦБ.ISIN);
								ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
							Иначе
								НоминалыЦБ					= РегистрыСведений.НоминалЦБ.СрезПоследних(ДатаОтвета, Новый Структура("ЦеннаяБумага", ЦеннаяБумага1С));
								Если НоминалыЦБ.Количество() = 0 Тогда
									Бумага.Стоимость		= 0;
								Иначе
									Если РеквизитыЦБ.ТипЦБ = Перечисления.ТипыЦБ.Акция Тогда
										СтоимостьНоминала	= НоминалыЦБ[0]["Сумма"];
									Иначе
										СтоимостьНоминала	= СтрокаОстатков["КоличествоОстаток"] * НоминалыЦБ[0]["Сумма"];
									КонецЕсли;
									Если РеквизитыЦБ.ВалютаНоминала = БазоваяВалюта Тогда
										Бумага.Стоимость	= СтоимостьНоминала;
									Иначе
										КурсыНоминала		= РегистрыСведений.КурсыВалют.ПолучитьПоследнее(ДатаОтвета, Новый Структура("Валюта", РеквизитыЦБ.ВалютаНоминала));
										Бумага.Стоимость    = ОбщегоНазначения.ПересчитатьИзВалютыВВалюту(СтоимостьНоминала, РеквизитыЦБ.ВалютаНоминала, БазоваяВалюта, КурсыНоминала["Курс"], 1, КурсыНоминала["Кратность"], 1);
									КонецЕсли;
								КонецЕсли;								
							КонецЕсли;
							
							Если ФормироватьОтветЦИКВНовомФормате Тогда
								Бумага.КодТипБум = СокрЛП(РеквизитыЦБ.КодВидаЦББанкаРоссии);
								Бумага.КодИдент = СокрЛП(РеквизитыЦБ.ISIN);
								Бумага.КодКласс = СокрЛП(РеквизитыЦБ.CFI);
								Бумага.ДатаСведОтв = Формат(Строка.СлужИнфо_ДатаСвед, "ДФ=dd.MM.yyyy");
							КонецЕсли;
						// }}
					ЦенныеБумаги.Бумага	= Бумага;
					// }}
					Персона.ЦенныеБумаги.Добавить(ЦенныеБумаги);
				КонецЦикла;
			Файл.Персона.Добавить(Персона);
	КонецЦикла;
	
	ФабрикаXDTO.ЗаписатьXML(ЗаписьXML, Файл, "Файл");
	СтрокаXML	= ЗаписьXML.Закрыть();
	
	СтрокаXML	= СтрЗаменить(СтрокаXML, "xmlns:xs=""http://www.w3.org/2001/XMLSchema""", "");
	СтрокаXML	= СтрЗаменить(СтрокаXML, "xmlns=""VO_CIK_CB_7.xsd""", "xsi:noNamespaceSchemaLocation=""VO_CIK_CB_7.xsd""");
	
	ТекстXML	= Новый ТекстовыйДокумент;
	ТекстXML.ДобавитьСтроку(СтрокаXML);
	
	Попытка
		ТекстXML.Записать(КаталогЗаписи + ИмяФайла + ".xml", КодировкаТекста.UTF8);
		Если ФормироватьОтветЦИКВНовомФормате Тогда
			СформироватьИсходящийДокумент(ИмяФайла);
		КонецЕсли;
	Исключение
		ОбщегоНазначения.СообщитьОбОшибке("Не удалось записать сформированный файл для ЦИК!");
	КонецПопытки;
КонецПроцедуры

Процедура СозданиеФайлаКвитанции() Экспорт
	
	// Проверка каталога
	Файл	= Новый Файл(ПутьКФайлу);
	Если Не Файл.Существует() Тогда
		ОбщегоНазначения.СообщитьОбОшибке("При попытке проверки данных 'ЦИК' перед формированием не обнаружен каталог!");
		Возврат;
	Иначе
		КаталогЗаписи	= Файл.Путь;
		КодЦИК			= Лев(Файл.ИмяБезРасширения, 14);
		НашКод			= "D" + Константы.ОрганизацияПоУмолчанию.Получить().ОГРН;
		КодЗапроса		= Сред(Файл.ИмяБезРасширения, 23, 1);
		НомерЗапроса	= Сред(Файл.ИмяБезРасширения, 25, 4);
		ИмяФайла		= НашКод + "_" + Формат(ДатаОтвета, "ДФ=ddMMyy_HHmmss") + "_K_" + НомерЗапроса + "_1000_" + КодЦИК;
	КонецЕсли;

	// Объявим объект для записи XML
	ЗаписьXML	= Новый ЗаписьXML;
	ЗаписьXML.УстановитьСтроку("UTF-8");
	ЗаписьXML.ЗаписатьОбъявлениеXML();
	
	ЗаписьXML.ЗаписатьНачалоЭлемента("File");
	ЗаписьXML.ЗаписатьАтрибут("xmlns:xsi", "http://www.w3.org/2001/XMLSchema-instance");
	ЗаписьXML.ЗаписатьАтрибут("xsi:noNamespaceSchemaLocation", "VO_CIK_CB_K_6.xsd");
	
		ЗаписьXML.ЗаписатьНачалоЭлемента("AcknowledgementType");
		ЗаписьXML.ЗаписатьТекст("10");
		ЗаписьXML.ЗаписатьКонецЭлемента();
	
		ЗаписьXML.ЗаписатьНачалоЭлемента("ResultCode");
		ЗаписьXML.ЗаписатьТекст("1000");
		ЗаписьXML.ЗаписатьКонецЭлемента();
	
		ЗаписьXML.ЗаписатьНачалоЭлемента("ResultText");
		ЗаписьXML.ЗаписатьТекст("Информация по проверяемым лицам отсутствует");
		ЗаписьXML.ЗаписатьКонецЭлемента();
	
		ЗаписьXML.ЗаписатьНачалоЭлемента("To");
		ЗаписьXML.ЗаписатьТекст(КодЦИК);
		ЗаписьXML.ЗаписатьКонецЭлемента();
		
		ЗаписьXML.ЗаписатьНачалоЭлемента("From");
		ЗаписьXML.ЗаписатьТекст(НашКод);
		ЗаписьXML.ЗаписатьКонецЭлемента();
		
		ЗаписьXML.ЗаписатьНачалоЭлемента("MessageID");
		ЗаписьXML.ЗаписатьТекст(ИмяФайла);
		ЗаписьXML.ЗаписатьКонецЭлемента();
		
		ЗаписьXML.ЗаписатьНачалоЭлемента("CorrelationMessageID");
		ЗаписьXML.ЗаписатьТекст(Файл.ИмяБезРасширения);
		ЗаписьXML.ЗаписатьКонецЭлемента();
		
		ЗаписьXML.ЗаписатьНачалоЭлемента("MessageType");
		ЗаписьXML.ЗаписатьТекст("2");
		ЗаписьXML.ЗаписатьКонецЭлемента();
		
		ЗаписьXML.ЗаписатьНачалоЭлемента("Priority");
		ЗаписьXML.ЗаписатьТекст("5");
		ЗаписьXML.ЗаписатьКонецЭлемента();
		
		ЗаписьXML.ЗаписатьНачалоЭлемента("CreateTime");
		ЗаписьXML.ЗаписатьТекст(Формат(ТекущаяДатаСеанса(), "ДФ=dd.MM.yyyy"));
		ЗаписьXML.ЗаписатьКонецЭлемента();
		
	ЗаписьXML.ЗаписатьКонецЭлемента();
	
	СтрокаXML	= ЗаписьXML.Закрыть();
	ТекстXML	= Новый ТекстовыйДокумент;
	ТекстXML.ДобавитьСтроку(СтрокаXML);
	
	Попытка
		ТекстXML.Записать(КаталогЗаписи + ИмяФайла + ".xml", КодировкаТекста.UTF8);
		ФормироватьОтветЦИКВНовомФормате = ФормироватьОтветЦИКВНовомФормате();
		Если ФормироватьОтветЦИКВНовомФормате Тогда
			СформироватьИсходящийДокумент(ИмяФайла);
		КонецЕсли;
	Исключение
		ОбщегоНазначения.СообщитьОбОшибке("Не удалось записать сформированную квитанцию для ЦИК!");
	КонецПопытки;
	
КонецПроцедуры

Функция СвойствоКоллекцииXDTO(КоллекцияXDTO, ИмяСвойства)
	
	Возврат КоллекцияXDTO.Получить(ИмяСвойства);
	
КонецФункции

Процедура СформироватьВходящийДокумент()
	НаименованиеДокумента = "Запрос ЦИК";
	НомерОтчета = ИдентификаторФайла;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Входящий.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.Входящий КАК Входящий
	|ГДЕ
	|	НЕ Входящий.ПометкаУдаления
	|	И Входящий.Дата МЕЖДУ &НачалоПериода И &КонецПериода
	|	И Входящий.ИсходящийНомер = &НомерОтчета
	|	И Входящий.НаименованиеДокументаИлиКомплекта = &НаименованиеДокумента
	|
	|УПОРЯДОЧИТЬ ПО
	|	Входящий.Проведен УБЫВ";
	Запрос.УстановитьПараметр("НачалоПериода", НачалоДня(ДатаОтвета));
	Запрос.УстановитьПараметр("КонецПериода", КонецДня(ДатаОтвета));
	Запрос.УстановитьПараметр("НомерОтчета", НомерОтчета);
	Запрос.УстановитьПараметр("НаименованиеДокумента", НаименованиеДокумента);
	
	РезультатЗапрос = Запрос.Выполнить();
	Если РезультатЗапрос.Пустой() Тогда
		ДокументОбъект = Документы.Входящий.СоздатьДокумент();
		ТекстСообщения = "Создан";
	Иначе
		Выборка = РезультатЗапрос.Выбрать();
		Выборка.Следующий();
	 	ДокументОбъект = Выборка.Ссылка.ПолучитьОбъект();
		ТекстСообщения = "Обновлен";
	КонецЕсли;
	
	ДокументОбъект.Дата = ДатаОтвета;
	ДокументОбъект.ДатаОтправления = ДатаОтвета;
	ДокументОбъект.Депонент = ОбщегоНазначения.ЗначениеКонстанты("ОрганизацияПоУмолчанию");
	ДокументОбъект.Исполнитель = ПараметрыСеанса.ТекущийПользователь;
	ДокументОбъект.ИсходящийНомер = НомерОтчета;
	ДокументОбъект.Комментарий = ИдентификаторФайла;
	ДокументОбъект.ЛицоНаправившееДокумент = "ЦИК, Банк России";
	ДокументОбъект.НаименованиеДокументаИлиКомплекта = НаименованиеДокумента;
	ДокументОбъект.РучнойВвод = Ложь;
	ДокументОбъект.ЦеннаяБумага = Справочники.ЦенныеБумаги.ПустаяСсылка();
	ДокументОбъект.Записать(РежимЗаписиДокумента.Проведение);
	
	ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения + " документ " + ДокументОбъект.Ссылка);
КонецПроцедуры

Процедура СформироватьИсходящийДокумент(НомерОтчета)
	НаименованиеДокумента = "Ответ ЦИК";
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Исходящий.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.Исходящий КАК Исходящий
	|ГДЕ
	|	НЕ Исходящий.ПометкаУдаления
	|	И Исходящий.Дата МЕЖДУ &НачалоПериода И &КонецПериода
	|	И Исходящий.ИсходящийНомер = &НомерОтчета
	|	И Исходящий.НаименованиеДокументаИлиКомплекта = &НаименованиеДокумента
	|
	|УПОРЯДОЧИТЬ ПО
	|	Исходящий.Проведен УБЫВ";
	Запрос.УстановитьПараметр("НачалоПериода", НачалоДня(ДатаОтвета));
	Запрос.УстановитьПараметр("КонецПериода", КонецДня(ДатаОтвета));
	Запрос.УстановитьПараметр("НомерОтчета", НомерОтчета);
	Запрос.УстановитьПараметр("НаименованиеДокумента", НаименованиеДокумента);
	
	РезультатЗапрос = Запрос.Выполнить();
	Если РезультатЗапрос.Пустой() Тогда
		ДокументОбъект = Документы.Исходящий.СоздатьДокумент();
		ТекстСообщения = "Создан";
	Иначе
		Выборка = РезультатЗапрос.Выбрать();
		Выборка.Следующий();
	 	ДокументОбъект = Выборка.Ссылка.ПолучитьОбъект();
		ТекстСообщения = "Обновлен";
	КонецЕсли;
	
	ДокументОбъект.Дата = ДатаОтвета;
	ДокументОбъект.Депонент = ОбщегоНазначения.ЗначениеКонстанты("ОрганизацияПоУмолчанию");
	ДокументОбъект.Адресат = "ЦИК, Банк России";
	ДокументОбъект.НаименованиеДокументаИлиКомплекта = НаименованиеДокумента;
	ДокументОбъект.Исполнитель = ПараметрыСеанса.ТекущийПользователь;
	ДокументОбъект.ИсходящийНомер = НомерОтчета;
	ДокументОбъект.Комментарий = "В электронном виде";
	ДокументОбъект.РучнойВвод = Ложь;
	ДокументОбъект.ЦеннаяБумага = Справочники.ЦенныеБумаги.ПустаяСсылка();
	ДокументОбъект.Записать(РежимЗаписиДокумента.Проведение);
	
	ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения + " документ " + ДокументОбъект.Ссылка);
КонецПроцедуры

Функция КодСтраныЭмитента(Данные)
	ЭтоМК = РегистрыСведений.ЮридическиеЛицаМеждународныеКомпании.ЭтоМК(ДатаОтвета, Данные.ЮридическиеФизическиеЛица);
	
	Если ЭтоМК Тогда
		Возврат "996";
	ИначеЕсли Данные.МеждународнаяОрганизация = Истина Тогда
		Возврат "998";
	ИначеЕсли ЗначениеЗаполнено(Данные.КодСтраны) Тогда
		Возврат СокрЛП(Данные.КодСтраны);
	Иначе
		Возврат "999";
	КонецЕсли;
КонецФункции

Функция ФормироватьОтветЦИКВНовомФормате()
	ДатаНачалаФормированияОтветовЦИКвНовомФормате =
		РегистрыСведений.ПараметрыГлобальные.ЗначениеПараметра("9846.ДатаНачалаФормированияОтветовЦИКвНовомФормате");
	ФормироватьОтветЦИКВНовомФормате = ЗначениеЗаполнено(ДатаНачалаФормированияОтветовЦИКвНовомФормате)
		И ДатаОтвета >= ДатаНачалаФормированияОтветовЦИКвНовомФормате;
		
	Возврат ФормироватьОтветЦИКВНовомФормате;
КонецФункции

Функция ДополнениеКЗапросуДляПолученияОстатковЦБ()
	ШаблонТекстаЗапроса =
	"ВЫБРАТЬ
	|	&ИмяПараметра КАК ДатаСведений,
	|	ОстаткиЦБ.СчетДепо.Владелец КАК Контрагент,
	|	ОстаткиЦБ.КоличествоОстаток КАК КоличествоОстаток
	|ИЗ
	|	РегистрНакопления.ОстаткиЦБ.Остатки(
	|			&ИмяПараметра,
	|			СчетДепо.Владелец В
	|				(ВЫБРАТЬ
	|					ПодготовленныеДанные.Контрагент1СПоФИО
	|				ИЗ
	|					ПодготовленныеДанные
	|			
	|				ОБЪЕДИНИТЬ ВСЕ
	|			
	|				ВЫБРАТЬ
	|					ПодготовленныеДанные.Контрагент1СПоДокументу
	|				ИЗ
	|					ПодготовленныеДанные)) КАК ОстаткиЦБ";
	
	ШаблонТекстаРазделителя =
	"
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|";
	
	ДатыСведений = Новый Массив;
	Если ДанныеПерсон.Количество() = 0 Тогда
		ДанныеПерсон.Добавить(ДатаОтвета);
	Иначе
		ОбщегоНазначения.ЗаполнитьМассивУникальнымиЗначениями(ДатыСведений, ДанныеПерсон.ВыгрузитьКолонку("СлужИнфо_ДатаСвед"));
	КонецЕсли;
	
	ТекстЗапросаПоОстаткамЦБ = "";
	
	ТекстыЗапросов = Новый Массив;
	Параметры = Новый Структура;
	
	Для Индекс = 0 По ДатыСведений.ВГраница() Цикл
		ИмяПараметра = "ДатаСведений" + Формат(Индекс, "ЧН=0; ЧГ=0");
		ТекстЗапросаПоОстаткамЦБ = СтрЗаменить(ШаблонТекстаЗапроса, "ИмяПараметра", ИмяПараметра);
		
		ТекстыЗапросов.Добавить(ТекстЗапросаПоОстаткамЦБ);
		Параметры.Вставить(ИмяПараметра, ДатыСведений[Индекс]);
	КонецЦикла;
	
	Результат = Новый Структура;
	Результат.Вставить("ТекстЗапроса", "(" + СтрСоединить(ТекстыЗапросов, ШаблонТекстаРазделителя) + ")");
	Результат.Вставить("Параметры", Параметры);
	Возврат Результат;
КонецФункции

ОбщегоНазначения.ЛогироватьИспользованиеОбъекта(ЭтотОбъект);
