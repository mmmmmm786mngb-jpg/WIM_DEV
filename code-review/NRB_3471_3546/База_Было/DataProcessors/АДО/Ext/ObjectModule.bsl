Перем СоединениеАДО;
Перем КомандаАДО;
Перем НаборЗаписейАДО;

Перем НаправлениеПараметра;
Перем ТипыЗапросов;

Перем  ИспользоватьДляПараметровХППризнакOUT;	// При формировании вызова хранимых процедур с возвращаемыми праметрами в зависимости
												// от используемой строки подключения ошибку может вызывать как отсутствие у такого
												// параметра признака OUT, так и его присутствие. Поэтому добавлением OUT нужно управлять.

Процедура ИнициироватьСоединение(Параметры = Неопределено) Экспорт
	
	Если ВнешнийИсточник.Пустая() Тогда
		Если ТипЗнч(Параметры) = Тип("Структура") И Параметры.Свойство("ВнешнийИсточник") Тогда
			Параметры.Свойство("ВнешнийИсточник", ВнешнийИсточник);
		ИначеЕсли ТипЗнч(Параметры) = Тип("ПланВидовХарактеристикСсылка.ВнешниеИсточники") Тогда
			ВнешнийИсточник = Параметры;
		КонецЕсли;
		Если ВнешнийИсточник.Пустая() Тогда
			ВызватьИсключение("Не задан источник данных для ADO!");
		КонецЕсли;
	КонецЕсли; 
	ВнешниеДанные.ADOConnect(СоединениеАДО, КомандаАДО, НаборЗаписейАДО, ВнешнийИсточник, , , ИспользоватьДляПараметровХППризнакOUT);
	
КонецПроцедуры

Функция ВыполнитьХранимуюПроцедуру(Наименование, СтруктураВходныхПараметров = Неопределено,
	СтруктураВыходныхПараметров = Неопределено) Экспорт
	
	ТаблицаПараметров = ВнешниеДанные.СоздатьТаблицуПараметров();
	
	Если СтруктураВходныхПараметров = Неопределено Тогда
		СтруктураВходныхПараметров = Новый Структура;
	КонецЕсли;
	
	Если СтруктураВыходныхПараметров = Неопределено Тогда
		СтруктураВыходныхПараметров = Новый Структура;
	КонецЕсли;
	
	Для каждого ВходнойПараметр Из СтруктураВходныхПараметров Цикл
		ВнешниеДанные.ДобавитьПараметрВТаблицу(ТаблицаПараметров, ВходнойПараметр.Ключ, ВходнойПараметр.Значение,
			НаправлениеПараметра.Входящий);
	КонецЦикла;
	
	Для каждого ВыходнойПараметр Из СтруктураВыходныхПараметров Цикл
		ВнешниеДанные.ДобавитьПараметрВТаблицу(ТаблицаПараметров, ВыходнойПараметр.Ключ, ВыходнойПараметр.Значение,
			НаправлениеПараметра.Исходящий);
	КонецЦикла;
	
	ВнешниеДанные.СформироватьПараметрыADO(КомандаАДО, ТаблицаПараметров);
	ВнешниеДанные.SQLЗапрос(КомандаАДО, НаборЗаписейАДО, Наименование, ТипыЗапросов.ХранимаяПроцедура, ИспользоватьДляПараметровХППризнакOUT);
	
	Для каждого ВыходнойПараметр Из СтруктураВыходныхПараметров Цикл
		СтруктураВыходныхПараметров[ВыходнойПараметр.Ключ] = КомандаАДО.Parameters.Item(ВыходнойПараметр.Ключ).Value;
	КонецЦикла; 
	
	Таблица = Новый ТаблицаЗначений;
	КолонкиТаблицы = Таблица.Колонки;
	Для каждого Field Из НаборЗаписейАДО.Fields Цикл
		ТипКолонки = ТипПоПолюАДО(Field);
		Колонка = КолонкиТаблицы.Добавить(Field.Name, ТипКолонки, Field.Name);
	КонецЦикла;
	
	Если НаборЗаписейАДО.State <> 0 Тогда
		Пока Не НаборЗаписейАДО.EOF() Цикл
			НоваяСтрока = Таблица.Добавить();
			Для каждого Поле Из НаборЗаписейАДО.Fields Цикл
				НоваяСтрока[Поле.Name] = Поле.Value;
			КонецЦикла;
			НаборЗаписейАДО.MoveNext();
		КонецЦикла;
	КонецЕсли;
	
	Возврат Таблица;
	
КонецФункции

Функция ВыполнитьЗапрос(ТекстЗапроса, СтруктураВходныхПараметров = Неопределено,
		СтруктураВыходныхПараметров = Неопределено) Экспорт
	
	КомандаАДО = Новый COMОбъект("ADODB.Command"); 
	КомандаАДО.ActiveConnection = СоединениеАДО;
	
	Если СтруктураВходныхПараметров = Неопределено Тогда
		СтруктураВходныхПараметров = Новый Структура;
	КонецЕсли;
	
	Если СтруктураВыходныхПараметров = Неопределено Тогда
		СтруктураВыходныхПараметров = Новый Структура;
	КонецЕсли;
	
	ТаблицаПараметров = ВнешниеДанные.СоздатьТаблицуПараметров();
	
	Для каждого ВходнойПараметр Из СтруктураВходныхПараметров Цикл
		ВнешниеДанные.ДобавитьПараметрВТаблицу(ТаблицаПараметров, ВходнойПараметр.Ключ, ВходнойПараметр.Значение,
			НаправлениеПараметра.Входящий);
	КонецЦикла;
	
	Для каждого ВыходнойПараметр Из СтруктураВыходныхПараметров Цикл
		ВнешниеДанные.ДобавитьПараметрВТаблицу(ТаблицаПараметров, ВыходнойПараметр.Ключ, ВыходнойПараметр.Значение,
			НаправлениеПараметра.Исходящий);
	КонецЦикла;
	
	ВнешниеДанные.СформироватьПараметрыADO(КомандаАДО, ТаблицаПараметров);
	ВнешниеДанные.SQLЗапрос(КомандаАДО, НаборЗаписейАДО, ТекстЗапроса, ТипыЗапросов.ОператорSQL);
	
	Таблица = Новый ТаблицаЗначений;
	КолонкиТаблицы = Таблица.Колонки;
	Для каждого Field Из НаборЗаписейАДО.Fields Цикл
		ТипКолонки = ТипПоПолюАДО(Field);
		Колонка = КолонкиТаблицы.Добавить(Field.Name, ТипКолонки, Field.Name);
	КонецЦикла; 
	
	Если НаборЗаписейАДО.State <> 0 Тогда
		Пока Не НаборЗаписейАДО.EOF() Цикл
			НоваяСтрока = Таблица.Добавить();
			Для каждого Поле Из НаборЗаписейАДО.Fields Цикл
				НоваяСтрока[Поле.Name] = Поле.Value;
			КонецЦикла;
			НаборЗаписейАДО.MoveNext();
		КонецЦикла;
	КонецЕсли;
	
	Возврат Таблица;
	
КонецФункции

Процедура УстановитьСоединениеСВнешнимИсточником(ВнешнийИсточник) Экспорт
	
	ВнешниеДанные.ADOConnect(СоединениеАДО, КомандаАДО, НаборЗаписейАДО, ВнешнийИсточник, , , ИспользоватьДляПараметровХППризнакOUT);
	
КонецПроцедуры

Функция ТипПоПолюАДО(Field)

	Если Field.Type = 3 Или Field.Type = 2 Или Field.Type = 131 Тогда
		Возврат Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(0, 0, ДопустимыйЗнак.Любой));
	ИначеЕсли Field.Type = 200 Тогда
		Возврат Новый ОписаниеТипов("Строка", , Новый КвалификаторыСтроки(Field.DefinedSize,
			ДопустимаяДлина.Переменная));
	ИначеЕсли Field.Type = 135 Тогда
		Возврат Новый ОписаниеТипов("Дата", , , Новый КвалификаторыДаты(ЧастиДаты.ДатаВремя));
	ИначеЕсли Field.Type = 11 Или Field.Type = 2 Тогда
		Возврат Новый ОписаниеТипов("Булево");
	КонецЕсли;
	
	Возврат Новый ОписаниеТипов("Строка", , Новый КвалификаторыСтроки(0, ДопустимаяДлина.Переменная));
	
КонецФункции

НаправлениеПараметра = ВнешниеДанные.ИнициализацияТиповНаправленияПараметровADO();
ТипыЗапросов = ВнешниеДанные.ИнициализацияТиповADO();
ОбщегоНазначения.ЛогироватьИспользованиеОбъекта(ЭтотОбъект);
