Функция Новый_id_V02_t(Идентификатор,ВладелецИдентификатораИлиСхема=Неопределено,ЗарегистрированSWIFT=Ложь)
	Результат = НовыйОбъектСхемыFCDR("id_V02_t");
	Результат.id = string35(СокрЛП(Идентификатор));
	Если ЗначениеЗаполнено(ВладелецИдентификатораИлиСхема) Тогда
		Если ЗарегистрированSWIFT Тогда
			//Наименование схемы кодировки – для организаций, зарегистрированных SWIFT
			Результат.scheme_name = scheme_name_et(ВладелецИдентификатораИлиСхема);
		Иначе
			//Указывается код Организации, ведущей справочник идентификационных кодов, не зарегистрированная SWIFTом (NSDR – НКО НРД), 
			//если иное правило заполнения поля не задано выше лежащими блоками XSD-схемы. 
			Результат.issuer = string35(ВладелецИдентификатораИлиСхема);
		КонецЕсли;
	КонецЕсли;
	
	Возврат Результат;
КонецФункции

Функция Новый_party_id_name_V2_t(ИдентификаторыV02, Наименование=Неопределено)
	Результат = НовыйОбъектСхемыFCDR("party_id_name_V2_t");
	Если ТипЗнч(ИдентификаторыV02)=Тип("Массив") Тогда
		Для Каждого Эл Из ИдентификаторыV02 Цикл
			Результат.id.Добавить(Новый_id_V02_t(Эл.Идентификатор, Эл.ВладелецИдентификатораИлиСхема, Эл.ЗарегистрированSWIFT));
		КонецЦикла;
	Иначе
		Результат.id.Добавить(Новый_id_V02_t(ИдентификаторыV02.Идентификатор, ИдентификаторыV02.ВладелецИдентификатораИлиСхема, ИдентификаторыV02.ЗарегистрированSWIFT));
	КонецЕсли;
	Если ЗначениеЗаполнено(Наименование) Тогда 
		Результат.name = string512(Наименование);
	КонецЕСли;
	Возврат Результат;
КонецФункции

