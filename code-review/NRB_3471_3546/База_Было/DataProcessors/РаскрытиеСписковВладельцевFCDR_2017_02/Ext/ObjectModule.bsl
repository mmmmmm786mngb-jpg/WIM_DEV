	Возврат НовыйОбъектСхемыFCDR("any_t");
КонецФункции

Функция Новый_bank_prop_curr_ndc_t(КодКлиента, БанковскиеРеквизиты)
	Результат = НовыйОбъектСхемыFCDR("bank_prop_curr_ndc_t");
	Результат.shareholder_id = СокрЛП(КодКлиента);
	Результат.ccy_code = БанковскиеРеквизиты.Валюта;
	Результат.ow_acc = БанковскиеРеквизиты.НомерСчета;
	НаименованиеПолучателя = БанковскиеРеквизиты.АнглНаименованиеПолучателя;
	Результат.ow_acc_n1 = Лев(НаименованиеПолучателя, 35);
	Если СтрДлина(НаименованиеПолучателя) > 35 Тогда
		Результат.ow_acc_n2 = Сред(НаименованиеПолучателя, 36, 35);
	КонецЕсли; 
	АдресПолучателя = БанковскиеРеквизиты.АнглАдресПолучателя;
	Результат.ow_addr1 = Лев(АдресПолучателя, 35);
	Если СтрДлина(АдресПолучателя) > 35 Тогда
		Результат.ow_addr2 = Сред(АдресПолучателя, 36, 35);
	КонецЕсли; 
	Результат.ow_b_swift = БанковскиеРеквизиты.SWIFT;
	
	Возврат Результат;
КонецФункции

Функция Новый_XtnsnDt(ВыборкаКлиенты,БанковскиеРеквизиты)
	Результат = НовыйОбъектСхемыFCDR("XtnsnDt");
	
	Пока ВыборкаКлиенты.Следующий() Цикл
		Результат.bank_prop_curr.Добавить(Новый_bank_prop_curr_ndc_t(ВыборкаКлиенты.КодКлиента, БанковскиеРеквизиты));
	КонецЦикла;
	
	Возврат Результат;
КонецФункции

//Бенефициары
Функция Новый_beneficiary_dtls_t(ВыборкаБенефициары=Неопределено, ВыборкаВложения=Неопределено, ОписаниеОшибки="",УКБезВыгодоприобретателей=Неопределено)
	Результат = НовыйОбъектСхемыFCDR("beneficiary_dtls_t");
	Если ВыборкаБенефициары<>Неопределено Тогда
		Пока ВыборкаБенефициары.Следующий() Цикл
			ТекОшибка = "";
			Если НЕ ЗначениеЗаполнено(ВыборкаБенефициары.Бенефициар) Тогда
				Если УКБезВыгодоприобретателей=Неопределено Тогда
					УКБезВыгодоприобретателей = "";
				КонецЕсли;
				УКБезВыгодоприобретателей = УКБезВыгодоприобретателей + Символы.ПС + СокрЛП(ВыборкаБенефициары.КодКлиента) + ": " + ВыборкаБенефициары.КлиентНаименование;
			Иначе
				Попытка
					Результат.beneficiaries.Добавить(Новый_beneficiaries_t(ВыборкаБенефициары, ТекОшибка));
					Результат.Проверить();
				Исключение
					ТекОшибка = ОписаниеОшибки();
				КонецПопытки;
			КонецЕсли;
			Если ЗначениеЗаполнено(ТекОшибка) Тогда
				ОписаниеОшибки = ОписаниеОшибки+Символы.ПС+"выгодоприобретатель "+ВыборкаБенефициары.Бенефициар+": "+ТекОшибка;
			КонецЕсли;
		КонецЦикла;
	Иначе
		Пока ВыборкаВложения.Следующий() Цикл
			Результат.attch.Добавить(Новый_attachment_t(ВыборкаВложения));
		КонецЦикла;
	КонецЕсли;
	
	Возврат Результат;
КонецФункции

Функция Новый_beneficiaries_t(Данные,ОписаниеОшибки="")
	Результат = НовыйОбъектСхемыFCDR("beneficiaries_t");
	
	Результат.party_account_type = Новый_party_account_type_t(Данные.ТипСчетаБенефициара, Данные.ТектовоеОписаниеТипаOTHERБенефициара);

	//Результат.beneficiary_account_dtls = Новый_account_dtls_beneficiary_t(Данные);

	Если Данные.ТипСчетаКлиента = "JNRH" Тогда
		//joint_owners.Добавить(Новый_joint_owner_t(Данные));
	Иначе
		АдресКлиента = НовыйСтруктураАдреса(Данные.КлиентУКАдресПоле1,Данные.КлиентУКАдресПоле2,Данные.КлиентУКАдресПоле3,Данные.КлиентУКАдресПоле4,Данные.КлиентУКАдресПоле5,Данные.КлиентУКАдресПоле6,Данные.КлиентУКАдресПоле7,Данные.КлиентУКАдресПоле8,Данные.КлиентУКАдресПоле9,
						Данные.КлиентУКАдрес,Данные.КлиентУКСтранаИностранногоАдреса,Данные.Россия);
		
		Если Данные.БенефициарЮрФизЛицо=Перечисления.ЮрФизЛицо.ЮрЛицо Тогда
			ДанныеОбЮрФизЛице = НовыйДанныеОбОрганизации(Данные.БенефициарЮрФизЛицо, Данные.БенефициарТипКодаДокумента,Данные.БенефициарНомерДокумента,Данные.БенефициарДатаДокумента,Данные.БенефициарРегистрирующийОрган, Данные.БенефициарСтрана, Неопределено); //Данные.БенефициарДатаРегистрации);
			Если НЕ ЗначениеЗаполнено(Данные.БенефициарНомерДокумента) И НЕ ЗначениеЗаполнено(АдресКлиента.Адрес) Тогда
				ОписаниеОшибки = "Нет идентификационной информации";
			КонецЕсли;
		Иначе
			ДанныеОбЮрФизЛице = НовыйДанныеОФизЛице(Данные.БенефициарФЛДокументТип,Данные.БенефициарФЛДокументСерия,Данные.БенефициарФЛДокументНомер,Данные.БенефициарФЛДокументДатаВыдачи,Данные.БенефициарФЛДокументКемВыдан, Данные.БенефициарФЛДатаРождения,Данные.БенефициарФЛМестоРождения,Данные.БенефициарФЛГражданство,Данные.БенефициарИНН);
			Если НЕ ЗначениеЗаполнено(Данные.БенефициарФЛДокументНомер) И НЕ ЗначениеЗаполнено(АдресКлиента.Адрес) Тогда
				ОписаниеОшибки = "Нет идентификационной информации";
			КонецЕсли;
		КонецЕсли;
		
		Результат.beneficiary_info = Новый_party_dtls_V02_t(Данные.БенефициарНаименование,Данные.БенефициарЮрФизЛицо,ДанныеОбЮрФизЛице,АдресКлиента);
	КонецЕсли;

	//Если ЗначениеЗаполнено(Данные.Контакты) Тогда
	//	Результат.beneficiary_contacts = Новый_party_contacts_V02_t(Данные.Контакты);
	//КонецЕсли;
	
	Выборка = Данные.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Пока Выборка.Следующий() Цикл
		Результат.beneficiary_security_balance.Добавить(Новый_security_balance_bnfr_t(Выборка));
	КонецЦикла;

	//Результат.beneficiary_add_info.Добавить(string255(Данные.БенефициарыДопИнфо));

	Возврат Результат;
КонецФункции

