	Идентификаторы = НовыйИдентификаторыДля_id_V02_t(КодНРД, ДанныеЗапроса.ВладелецИдентификатораПолучателя);
	Результат.request_issuer = Новый_party_id_name_V2_t(Идентификаторы);

