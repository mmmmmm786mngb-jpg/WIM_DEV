Функция Новый_shareholder_dtls_t(Данные, ВключатьБенефициаров, БанковскиеРеквизиты, ЗначениеPaymentFromNominee, ОписаниеОшибки, УКБезВыгодоприобретателей)
	Результат = НовыйОбъектСхемыFCDR("shareholder_dtls_t");
	
	Результат.shareholder_id = string35(СокрЛП(Данные.КодКлиента));
	
	Результат.party_account_type = Новый_party_account_type_t(Данные.ТипСчетаКлиента, Данные.ТектовоеОписаниеТипаOTHER);
	Результат.account_dtls = Новый_account_dtls_v03_t(Данные);

	Если Данные.ЭтоСубброкер Тогда  
		АдресКлиента = Новый Структура("Страна,Индекс,Адрес", Данные.ДанныеСубброкераАдресСтрана,Данные.ДанныеСубброкераАдресИндекс,Данные.ДанныеСубброкераАдрес);
		ПочтовыйАдресКлиента = Новый Структура("Страна,Индекс,Адрес",Данные.ДанныеСубброкераПочтовыйАдресСтрана,Данные.ДанныеСубброкераПочтовыйАдресИндекс,Данные.ДанныеСубброкераПочтовыйАдрес) ;
	Иначе
		АдресКлиента = НовыйСтруктураАдреса(Данные.КлиентАдресПоле1,Данные.КлиентАдресПоле2,Данные.КлиентАдресПоле3,Данные.КлиентАдресПоле4,Данные.КлиентАдресПоле5,Данные.КлиентАдресПоле6,Данные.КлиентАдресПоле7,Данные.КлиентАдресПоле8,Данные.КлиентАдресПоле9,
				Данные.КлиентАдрес,Данные.КлиентСтранаИностранногоАдреса,Данные.Россия);
		ПочтовыйАдресКлиента = НовыйСтруктураАдреса(Данные.КлиентПочтовыйАдресПоле1,Данные.КлиентПочтовыйАдресПоле2,Данные.КлиентПочтовыйАдресПоле3,Данные.КлиентПочтовыйАдресПоле4,Данные.КлиентПочтовыйАдресПоле5,Данные.КлиентПочтовыйАдресПоле6,Данные.КлиентПочтовыйАдресПоле7,Данные.КлиентПочтовыйАдресПоле8,Данные.КлиентПочтовыйАдресПоле9,
				Данные.КлиентПочтовыйАдрес,Данные.КлиентСтранаИностранногоПочтовогоАдреса,Данные.Россия);
	КонецЕсли;
		
	Если НЕ ЗначениеЗаполнено(ПочтовыйАдресКлиента.Адрес) Тогда
		ПочтовыйАдресКлиента = АдресКлиента;
	КонецЕсли;			
				
	Если Данные.ТипСчетаКлиента = "JNRH" Тогда
		//joint_owners.Добавить(Новый_joint_owner_t(Данные));
	Иначе
		Если Данные.КлиентЮрФизЛицо=Перечисления.ЮрФизЛицо.ЮрЛицо Тогда
			ДанныеОбЮрФизЛице = НовыйДанныеОбОрганизации(Данные.КлиентЮрФизЛицо, Данные.КлиентТипКодаДокумента,Данные.КлиентНомерДокумента,Данные.КлиентДатаДокумента,Данные.КлиентРегистрирующийОрган, Данные.КлиентСтрана, Данные.КлиентДатаРегистрации, Данные.КлиентФЛДатаРождения);
		Иначе
			ДанныеОбЮрФизЛице = НовыйДанныеОФизЛице(Данные.КлиентФЛДокументТип,Данные.КлиентФЛДокументСерия,Данные.КлиентФЛДокументНомер,Данные.КлиентФЛДокументДатаВыдачи,Данные.КлиентФЛДокументКемВыдан, Данные.КлиентФЛДатаРождения,Данные.КлиентФЛМестоРождения,Данные.КлиентФЛГражданство,Данные.КлиентИНН);
		КонецЕсли;
		
		Результат.party_dtls = Новый_party_dtls_V02_t(Данные.КлиентНаименование,Данные.КлиентЮрФизЛицо,ДанныеОбЮрФизЛице,АдресКлиента);
	КонецЕсли;
	
	Результат.postal_name = НовыйОбъектСхемыFCDRИзСвойств("shareholder_dtls_t","postal_name");
	Результат.postal_name.name = string512(Данные.КлиентПочтовоеНаименование);
	
	Если ЗначениеЗаполнено(ПочтовыйАдресКлиента.Адрес) И ЗначениеЗаполнено(ПочтовыйАдресКлиента.Страна) Тогда
		Результат.postal_name.address = Новый_address_V03_t(ПочтовыйАдресКлиента);
	ИначеЕсли ЗначениеЗаполнено(ПочтовыйАдресКлиента.Адрес) Тогда
		Результат.postal_name.address = Новый_address_V03_t(,ПочтовыйАдресКлиента.Адрес);
	КонецЕсли;
	
	//Результат.shareholder_contacts = Новый_party_contacts_V02_t(Данные);
	
	Если ЗначениеЗаполнено(Данные.КлиентСтрана) Тогда
		Результат.country_location = string2(Данные.КлиентСтрана);
	КонецЕсли;
	
	Результат.tax_category = Новый_tax_category_V02_t(Данные.КлиентНеРезидент,,Данные.НаличиеЛьготы);
	
	Если ЗначениеЗаполнено(БанковскиеРеквизиты) Тогда
		Результат.bank_prop_rub = Новый_bank_prop_rub_V02_t(БанковскиеРеквизиты);
	КонецЕсли;
	
	//Результат.authorization_info = string512(Данные);
	Если ВключатьБенефициаров Тогда
		ВыборкаЦБ = Данные.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам,"ЦеннаяБумага");
	Иначе
		ВыборкаЦБ = Данные.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	КонецЕсли;
	Пока ВыборкаЦБ.Следующий() Цикл
		Результат.security_balance.Добавить(Новый_security_balance_t_v03(ВыборкаЦБ));
	КонецЦикла;
		
	Если ВключатьБенефициаров И Данные.ЭтоУК Тогда
		ВыборкаБенефициаров = Данные.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		ТекОшибка = "";
		Результат.beneficiary = Новый_beneficiary_dtls_t(ВыборкаБенефициаров,,ТекОшибка,УКБезВыгодоприобретателей);
		Если ЗначениеЗаполнено(ТекОшибка) Тогда
			ОписаниеОшибки = ОписаниеОшибки+Символы.ПС + "Ошибки заполнения выгодоприобретателей"+ТекОшибка;
		КонецЕсли;
	КонецЕсли;

	Если ЗначениеЗаполнено(ЗначениеPaymentFromNominee) Тогда
		Результат.shareholder_add_info.Добавить(payment_from_nominee(ЗначениеPaymentFromNominee));
	КонецЕсли;

	Если ЗначениеЗаполнено(Данные.ДополнительнаяИнформация) Тогда
		Результат.shareholder_add_info.Добавить(Данные.ДополнительнаяИнформация);
	КонецЕсли;

	//Результат.attch.Добавить(Новый_attachment_t(Данные));
	
	Возврат Результат;
КонецФункции

Функция Новый_register_list_dtls_t(ДанныеГруппировкаКлиент, ВключатьБенефициаров, ЭтоДораскрытие, БанковскиеРеквизиты, ЗначениеPaymentFromNominee, ОписаниеОшибки,УКБезВыгодоприобретателей)
	
	Результат = НовыйОбъектСхемыFCDR("register_list_dtls_t");
	
	//Выборка по клиентам
	Пока ДанныеГруппировкаКлиент.Следующий() Цикл
		//Выборка по кодам клиента. Необходимо для разделения субклиентов представленных строкой ФИО
		// т.к. бывают случаи полного совпадения ФИО, различен только НомерСчетаДепо
		Данные = ДанныеГруппировкаКлиент.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		Пока Данные.Следующий() Цикл
			ТекОшибка = "";
			Если Данные.ЭтоСубброкер Тогда
				Если НЕ ЗначениеЗаполнено(Данные.ОтветНаРСВ) Тогда
					ТекОшибка = ОшибкаДокументНеГотов("Нет ответа субброкера.");
				ИначеЕсли НЕ Данные.ЕстьОтветСубброкера Тогда
					ТекОшибка = ОшибкаДокументНеГотов("В ответе "+Данные.ОтветНаРСВ+" не найдена строка данных по клиенту.");
				КонецЕсли;
			КонецЕсли;
			Если НЕ ЗначениеЗаполнено(ТекОшибка) Тогда
				Попытка
					КлиентXDTO = Новый_shareholder_dtls_t(Данные,ВключатьБенефициаров, БанковскиеРеквизиты, ЗначениеPaymentFromNominee, ТекОшибка,УКБезВыгодоприобретателей);
					КлиентXDTO.Проверить();
					Результат.shareholder.Добавить(КлиентXDTO);
				Исключение
					ТекОшибка = ОписаниеОшибки();
				КонецПопытки;
			КонецЕсли;
			Если ЗначениеЗаполнено(ТекОшибка) Тогда
				ОписаниеОшибки = ОписаниеОшибки + Символы.ПС
					+ ?(Данные.ЭтоСубброкер, "Субклиент ", "Клиент ")
					+ Данные.Клиент + ?(ЗначениеЗаполнено(Данные.КодКлиента), " (код: " + СокрЛП(Данные.КодКлиента) + "): ", ": ")
					+ ТекОшибка;
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;
	
	
	Возврат Результат;
КонецФункции

