Функция ОпределитьШаблонРаскрытия(ОписаниеОшибки) Экспорт
	Шаблон = ДокументРСВ.ШаблонFCDR_2017_02;
	Результат = Истина;
	Если Шаблон = "0001" Тогда
		ВключатьБенефициаров = Ложь;
		ВключатьБанковскиеРеквизиты = Ложь;
		НеобходимостьПредоставленияБанковскихРеквизитов = Ложь;
		ВыплатаЧерезНоминальногоВладельца = Ложь;
	ИначеЕсли Шаблон = "0002" Тогда
		ВключатьБенефициаров = Ложь;
		ВключатьБанковскиеРеквизиты = Ложь;
		НеобходимостьПредоставленияБанковскихРеквизитов = Истина;
		ВыплатаЧерезНоминальногоВладельца = Истина;
	ИначеЕсли Шаблон = "0003" Тогда
		ВключатьБенефициаров = Истина;
		ВключатьБанковскиеРеквизиты = Ложь;
		НеобходимостьПредоставленияБанковскихРеквизитов = Ложь;
		ВыплатаЧерезНоминальногоВладельца = Ложь;
	ИначеЕсли Шаблон = "0010" Тогда
		ВключатьБенефициаров = Ложь;
		ВключатьБанковскиеРеквизиты = Истина;
		НеобходимостьПредоставленияБанковскихРеквизитов = Истина;
		ВыплатаЧерезНоминальногоВладельца = Ложь;
	ИначеЕсли Шаблон = "0012" Тогда
		ВключатьБенефициаров = Ложь;
		ВключатьБанковскиеРеквизиты = Истина;
		НеобходимостьПредоставленияБанковскихРеквизитов = Истина;
		ВыплатаЧерезНоминальногоВладельца = Ложь;
	ИначеЕсли Шаблон = "0013" Тогда
		ВключатьБенефициаров = Истина;
		ВключатьБанковскиеРеквизиты = Истина;
		НеобходимостьПредоставленияБанковскихРеквизитов = Истина;
		ВыплатаЧерезНоминальногоВладельца = Ложь;
	ИначеЕсли Шаблон = "0014" Тогда
		ВключатьБенефициаров = Истина;
		ВключатьБанковскиеРеквизиты = Истина;
		НеобходимостьПредоставленияБанковскихРеквизитов = Истина;
		ВыплатаЧерезНоминальногоВладельца = Ложь;
	Иначе
		ОписаниеОшибки = "Не определен шаблон раскрытия";
		Результат = Ложь;
	КонецЕсли;
	Возврат Результат;
КонецФункции
Функция ОшибкаДокументНеГотов(ТекущаяОшибка)
	Возврат ТекущаяОшибка+" Файл раскрытия не может быть сформирован";
КонецФункции

Функция ВыгрузитьРаскрытиеСписка_FCDR_17_02(ОписаниеОшибки,УКБезВыгодоприобретателей=Неопределено) Экспорт
	ПространствоИмен = "FCDR_2017_02(2019v3)";
	
	Запрос = Новый Запрос;
	ТекстЗапроса = ТекстЗапросаСписокРаскрытия();
	ВставитьПоляБенефициара(ТекстЗапроса, ВключатьБенефициаров);
	ВставитьПоляБанковскихРеквизитов(ТекстЗапроса, ВключатьБанковскиеРеквизиты);
	 
	Запрос = Новый Запрос;
	Запрос.Текст = ТекстЗапроса;
	
	Запрос.УстановитьПараметр("ДокументРСВ", ДокументРСВ);
	Запрос.УстановитьПараметр("Дата", ДокументРСВ.Дата);
	Запрос.УстановитьПараметр("ДатаФиксации", ДокументРСВ.ДатаФиксации);
	Запрос.УстановитьПараметр("Прочее", "OTHR");
	Запрос.УстановитьПараметр("NSDR", ЗначениеКодНРД());
	Запрос.УстановитьПараметр("ИдентификаторРезидента", "OGRN");
	Запрос.УстановитьПараметр("ИдентификаторНерезидента", "INCR");
	Запрос.УстановитьПараметр("ВидОбременения", "COLO");
	Запрос.УстановитьПараметр("ПочтовыйАдресЮрлица", Константы.ВидАдресаПочтовыйДляРаскрытияСпискаFCDR_2017_02.Получить());
	Запрос.УстановитьПараметр("тзнТипыСчетовЛуч", ТаблицаКодовТиповСчетов());
	Запрос.УстановитьПараметр("ПустойТипСчетаБенефициара", "");
	
	Если ВключатьБенефициаров Тогда
		Запрос.УстановитьПараметр("ТипСчетаTRSR", "TRSR");
	КонецЕсли;
	 
	
	РезультатыЗапросов = Запрос.ВыполнитьПакет();
	Выборка = РезультатыЗапросов[4].Выбрать();
	Выборка.Следующий();
	
	Если НЕ Выборка.Проведен Тогда
		ОписаниеОшибки = ОшибкаДокументНеГотов("Документ " + ДокументРСВ + " не проведен.");
	КонецЕсли;
	
	НомерРаскрытия = СтрЗаменить(ОбщегоНазначенияКлиентСервер.Транслит(СокрЛП(Выборка.НомерРаскрытия)), "-", "");
	Результат = Новый Структура("Номер,Дата,ТекстДокумента,Шаблон", НомерРаскрытия, Выборка.ДатаРаскрытия, "", Выборка.Шаблон);
	
	ТипРаскрытие = ФабрикаXDTO.Пакеты.Получить(ПространствоИмен).КорневыеСвойства.Получить("REGISTER_OF_SHAREHOLDERS_V02").Тип;
	РаскрытиеXDTO = ФабрикаXDTO.Создать(ТипРаскрытие);
	
	
	ЭтоДораскрытие = Ложь;
	
	РаскрытиеXDTO.version = ВерсияФорматаFCDR();
	РаскрытиеXDTO.header = Новый_header_t(НомерРаскрытия, Выборка);
	
	//Если ТипЗнч(ДанныеИдентификацииЗапроса) = ТипМассив Тогда
	//	Для Каждого Эл Из ДанныеИдентификацииЗапроса Цикл
	//		РаскрытиеXDTO.request_identification.Добавить(Новый_request_identification_t(Эл));
	//	КонецЦикла;
	//Иначе
		РаскрытиеXDTO.request_identification.Добавить(Новый_request_identification_t(Выборка));
	//КонецЕсли;
	//РаскрытиеXDTO.doc_link.Добавить();
	
	ДокументЭмитента = НовыйДанныеДокументаДля_organization_document_t(Выборка.ЭмитентТипНомера, Неопределено, Неопределено, Выборка.ЭмитентНомер);
	АдресЭмитента = Неопределено;
	РаскрытиеXDTO.issuer.Добавить(Новый_legal_entity_details_t(Выборка.ЭмитентНаименование, ДокументЭмитента, АдресЭмитента));
	Если ЗначениеЗаполнено(Выборка.Эмитент2Номер) ИЛИ ЗначениеЗаполнено(Выборка.Эмитент2Наименование) Тогда
		ДокументЭмитента = НовыйДанныеДокументаДля_organization_document_t(Выборка.Эмитент2ТипНомера, Неопределено, Неопределено, Выборка.Эмитент2Номер);
		РаскрытиеXDTO.issuer.Добавить(Новый_legal_entity_details_t(Выборка.Эмитент2Наименование, ДокументЭмитента, АдресЭмитента));
	КонецЕсли;
	
	РаскрытиеXDTO.corporate_action_reference = Новый_corporate_action_reference_t_v03(Выборка);
	//РаскрытиеXDTO.events_linkage.Добавить();
	РаскрытиеXDTO.record_date = date_t(Выборка.ДатаФиксации);
	РаскрытиеXDTO.message_function = list_message_function_et(ЭтоДораскрытие);
	РаскрытиеXDTO.account_dtls = Новый_account_dtls_v04_t(Выборка.СчетДЕПО, Выборка.ТипСчетаДЕПО);
	
	ИдентификаторыV02 = НовыйИдентификаторыДля_id_V02_t(Выборка.ОтправительИдентификатор, Выборка.ВладелецИдентификатораОтправителя);
	РаскрытиеXDTO.account_holder = Новый_party_id_name_V03_t(Выборка.ОтправительНаименование, ИдентификаторыV02);
	РаскрытиеXDTO.information_indicator = Новый_information_type_V02_t(Выборка.ТипСписка, НеобходимостьПредоставленияБанковскихРеквизитов, Выборка.Шаблон);
	//РаскрытиеXDTO.total_security_balance.Добавить();
	
	Если ВключатьБанковскиеРеквизиты Тогда
		
		БанковскиеРеквизиты = НовыйБанковскиеРеквизиты(Выборка.БанкРеквНаименованиеПолучателя, Выборка.БанкРеквАнглНаименованиеПолучателя, Выборка.БанкРеквИННПолучателя, Выборка.БанкРеквАнглАдресПолучателя, Выборка.БанкРеквНомерСчета,
								Выборка.БанкРеквБанкНаименование, Выборка.БанкРеквБанкГород,
								Выборка.БанкРеквБИК, Выборка.БанкРеквSWIFT, Выборка.БанкРеквКорСчет, Выборка.БанкРеквВалюта);
							
		Если Выборка.БанкРеквРублевый = Истина Тогда
			БанковскиеРеквизитыРуб = БанковскиеРеквизиты;
		ИначеЕсли Выборка.БанкРеквРублевый = Ложь Тогда
			БанковскиеРеквизитыВал = БанковскиеРеквизиты;
		КонецЕсли;
		
	Иначе
		БанковскиеРеквизитыРуб = Неопределено;
		БанковскиеРеквизитыВал = Неопределено;
	КонецЕсли;
	
	РезультатЗарпосаПоТаблице = РезультатыЗапросов[5];
	Если РезультатЗарпосаПоТаблице.Пустой() Тогда
		ОписаниеОшибки = ОшибкаДокументНеГотов("Документ " + ДокументРСВ + " не заполнен.");
		Возврат Неопределено;
	КонецЕсли;
	Выборка = РезультатЗарпосаПоТаблице.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	ТекОшибка = "";
	Если ВыплатаЧерезНоминальногоВладельца Тогда
		ЗначениеPaymentFromNominee = Истина;
	Иначе
		ЗначениеPaymentFromNominee = Неопределено;
	КонецЕсли;
	РаскрытиеXDTO.register_list.Добавить(Новый_register_list_dtls_t(Выборка, ВключатьБенефициаров, ЭтоДораскрытие, БанковскиеРеквизитыРуб, ЗначениеPaymentFromNominee, ТекОшибка, УКБезВыгодоприобретателей));
	Если ЗначениеЗаполнено(ТекОшибка) Тогда
		ОписаниеОшибки = ОписаниеОшибки + Символы.ПС + "Ошибки заполнения списка клиентов:" + ТекОшибка;
		ЗаписьЖурналаРегистрации("Выгрузка 'Раскрытия списка владельцев FCDR_2017_02'", УровеньЖурналаРегистрации.Ошибка, , ДокументРСВ, ОписаниеОшибки);
		Возврат Неопределено;
	КонецЕсли;
	
	//РаскрытиеXDTO.list_add_info = ;
	//РаскрытиеXDTO.pagination = ;
	//РаскрытиеXDTO.attch.Добавить();
	//РаскрытиеXDTO.signature = ;
	Если БанковскиеРеквизитыВал<>Неопределено Тогда
		ДопИнфо = Новый_any_t();
		Выборка.Сбросить();
		ДопИнфо.Добавить(ФормаXML.Элемент, ПространствоИмен, "XtnsnDt", Новый_XtnsnDt(Выборка, БанковскиеРеквизитыВал));
		РаскрытиеXDTO.add_info = ДопИнфо;
	КонецЕсли;
	//РаскрытиеXDTO.add_info = ;
	
	ЗаписьXML = Новый ЗаписьXML;
	ЗаписьXML.УстановитьСтроку("Windows-1251");
	ЗаписьXML.ЗаписатьОбъявлениеXML();
	
	ФабрикаXDTO.ЗаписатьXML(ЗаписьXML, РаскрытиеXDTO, "REGISTER_OF_SHAREHOLDERS_V02");
	
	ТекстДокумента = ЗаписьXML.Закрыть();
	ТекстДокумента = СтрЗаменить(ТекстДокумента, "<REGISTER_OF_SHAREHOLDERS_V02 xmlns=""FCDR_2017_02(2019v3)"" xmlns:xs=""http://www.w3.org/2001/XMLSchema"" xmlns:xsi=""http://www.w3.org/2001/XMLSchema-instance"">", "<REGISTER_OF_SHAREHOLDERS_V02>");
	ТекстДокумента = СтрЗаменить(ТекстДокумента, "xmlns="""" xmlns:d2p1=""FCDR_2017_02(2019v3)""", "");
	ТекстДокумента = СтрЗаменить(ТекстДокумента, "d2p1:", "");
	ТекстДокумента = СтрЗаменить(ТекстДокумента, "xsi:type=""xs:string""", "");
	Результат.ТекстДокумента = СтрЗаменить(ТекстДокумента, "xmlns=""""", "");
	
	Возврат Результат;
	
КонецФункции

Функция РезультатФормированияПакета_ФШ(СообщениеВФШНРД,УКБезВыгодоприобретателей) Экспорт
	
	Если СообщениеВФШНРД.Шаблон="0013" Тогда
		Ошибка = Новый Структура("СообщениеПользователю, СообщениеВЖурнал, Данные");
		Ошибка.СообщениеПользователю = "Сообщение в файловый шлюз не может быть сформировано для раскрытий по шаблону 0013. Воспользуйтесь выгрузкой в файл и отредактируйте его в «WEB-кабинете КД»";
		Возврат Ошибка;
	КонецЕсли;
	Если ВключатьБенефициаров Тогда
		Если ЗначениеЗаполнено(УКБезВыгодоприобретателей) Тогда
			Ошибка = Новый Структура("СообщениеПользователю, СообщениеВЖурнал, Данные");
			Ошибка.СообщениеПользователю = "Сообщение в файловый шлюз не может быть сформировано. Найдены Управляющие компании без Выгодоприобретателей:"+УКБезВыгодоприобретателей;
			Возврат Ошибка;
		КонецЕсли;
	КонецЕсли;
	
	
	ИсходящийНомер = Обработки.ЭкспортПорученийВЛуч.ФорматИсходящегоНомера(СообщениеВФШНРД.Номер);
	                                                                                                                        
	Ошибка = Обработки.ЭкспортПорученийВЛуч.СформироватьИсходящийПакетВФайловыйШлюз(ИсходящийНомер, СообщениеВФШНРД.Дата, ТипТехническойОперации(), КодТехническойОперации(), ДокументРСВ, СообщениеВФШНРД.ТекстДокумента);
	
	Если Ошибка = Неопределено Тогда
		УстановитьСтатусДокументаРСВ(Перечисления.СтатусыРаскрытияСписковВладельцев.Выгружено);
	КонецЕсли;
	
	Возврат Ошибка;
	
КонецФункции
Функция УстановитьСтатусДокументаРСВ(Статус) Экспорт
	Если ДокументРСВ.Статус <> Статус Тогда
		ДокументОбъект = ДокументРСВ.ПолучитьОбъект();
		ДокументОбъект.Статус = Статус;
		ДокументОбъект.Записать();
	КонецЕсли;
КонецФункции
Функция ВыгрузитьВФайлПоУмолчанию(СообщениеВФШНРД) Экспорт
	
	ИсходящийНомер = Обработки.ЭкспортПорученийВЛуч.ФорматИсходящегоНомера(СообщениеВФШНРД.Номер);
	
	ВнешнийИсточникФайл = ПланыВидовХарактеристик.ВнешниеИсточники.КаталогФайловРаскрытияСпискаВладельцевFCDR;	
	ПутьДляВыгрузки = ВнешниеДанные.ПолучитьПараметрыВнешнегоИсточника(ВнешнийИсточникФайл).Папка;
	
	Ошибка = Новый Структура("СообщениеПользователю, СообщениеВЖурнал, Данные");
	Если НЕ ЗначениеЗаполнено(ПутьДляВыгрузки) Тогда
		Ошибка.СообщениеВЖурнал = "Не указан внешний источник";
		Ошибка.Данные = ВнешнийИсточникФайл;
		Ошибка.СообщениеПользователю = Ошибка.СообщениеВЖурнал + " " + ВнешнийИсточникФайл;
		Возврат Ошибка;
	КонецЕсли;
	
	Папка = Новый Файл(ПутьДляВыгрузки);
	Если НЕ Папка.Существует() ИЛИ НЕ Папка.ЭтоКаталог() Тогда
		Ошибка.СообщениеВЖурнал = "Каталог " + ПутьДляВыгрузки + " не существует";
		Ошибка.Данные = ВнешнийИсточникФайл;
		Ошибка.СообщениеПользователю = Ошибка.СообщениеВЖурнал + " " + ВнешнийИсточникФайл;
		Возврат Ошибка;
	КонецЕсли;	
	
	ЗаписьXML = Новый ЗаписьXML;
	ЗаписьXML.ОткрытьФайл(ПутьДляВыгрузки+"\"+ИсходящийНомер+".xml", "windows-1251");
	ЗаписьXML.ЗаписатьБезОбработки(СообщениеВФШНРД.ТекстДокумента);
	ЗаписьXML.Закрыть();
	
	УстановитьСтатусДокументаРСВ(Перечисления.СтатусыРаскрытияСписковВладельцев.Выгружено);
	
	Возврат Неопределено;
КонецФункции

Функция ВизуализацияHTML(СообщениеВФШНРД) Экспорт
	Макет = ПолучитьМакет("ПреобразованиеXSL").ПолучитьТекст();
	Преобразование = Новый ПреобразованиеXSL;
	Преобразование.ЗагрузитьИзСтроки(Макет);
	Возврат Преобразование.ПреобразоватьИзСтроки(СообщениеВФШНРД.ТекстДокумента);
КонецФункции

// ЗАГРУЗКА. Идентификация типа документа
// Параметры:
//   ТекстДокумента - Строка - данные файла xml.
//   СообщениеОбОшибке - Строка - данные об ошибках обработки файла.
//   Регламент - Булево - показатель запуска загрузки РСВ регламентом.
//   ДокументСоздан - Булево - показатель успешности создания документа РСВ в 1С для помещения входящего файла в архив
//   ИмяКаталога - Строка
Процедура ЗагрузитьВходящийДокументИзТекста(ТекстДокумента, СообщениеОбОшибке, Регламент = Ложь, ДокументСоздан = Ложь,
											ИмяКаталога = Неопределено) Экспорт
	ЧтениеXML = Новый ЧтениеXML;
	ЧтениеXML.УстановитьСтроку(ТекстДокумента);
	ЗагрузитьВходящийДокументXML(ЧтениеXML, СообщениеОбОшибке, Регламент, ДокументСоздан, ИмяКаталога);
КонецПроцедуры

Процедура ЗагрузитьВходящийДокументXML(ЧтениеXML, СообщениеОбОшибке, Регламент = Ложь, ДокументСоздан = Ложь,
										ИмяКаталога = Неопределено) Экспорт
	Если ЧтениеXML.Прочитать() Тогда
		ИмяОбъекта = ВРЕГ(ЧтениеXML.Имя);
		Если ИмяОбъекта = "DISCLOSURE_REQUEST" Тогда
			СформироватьДокументЗапросНаРаскрытие(ЧтениеXML, СообщениеОбОшибке, Регламент, ДокументСоздан);
		ИначеЕсли ИмяОбъекта = "REGISTER_OF_SHAREHOLDERS_STATUS_ADVICE" Тогда
			СформироватьДокументОтчетОСтатусеРСВ(ЧтениеXML, СообщениеОбОшибке);
		ИначеЕсли ИмяОбъекта = "STATEMENT_OF_HOLDINGS" Тогда
			СформироватьВыпискуИзРеестра(ЧтениеXML, ИмяКаталога, СообщениеОбОшибке, Регламент, ДокументСоздан);
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

//ЗАГРУЗКА ЗАПРОСА
Функция ПолучитьБулево(YesNo)
	Возврат ВРег(YesNo)="YES";
КонецФункции
Функция ПолучитьДату(СтрокаДата)
	Возврат XMLЗначение(Тип("Дата"),СтрокаДата);
КонецФункции
Процедура ПолучитьРеквизитыЗаголовкаСообщения(header, Номер, Дата, КодПолучателя, СообщениеОбОшибке)
	Номер = header.doc_num;
	Дата = ПолучитьДату(header.doc_date.date);
	
	КодПолучателя = Неопределено;
	Ид = header.to.id_2;
	Если ЭтоСписокXDTO(Ид) Тогда
		Для Каждого Эл Из ИД Цикл
			Если ЭтоКодНРД(Эл) Тогда
				КодПолучателя = Эл.id;
				Прервать;
			КонецЕсли;
		КонецЦикла
	Иначе
		Если ЭтоКодНРД(Ид) Тогда
			КодПолучателя = Ид.id;
		КонецЕсли;
	КонецЕсли;
	Если НЕ ЗначениеЗаполнено(КодПолучателя) Тогда
		СообщениеОбОшибке = СообщениеОбОшибке+Символы.ПС+"Не заполнен код получателя";
	КонецЕсли;
КонецПроцедуры
Функция ЗначениеКодНРД()
	Возврат "NSDR";
КонецФункции
Функция ЭтоКодНРД(Элемент)
	Возврат  ЭтоПрочее(Элемент.id_type) И Элемент.narrative=ЗначениеКодНРД();
КонецФункции
Функция ЭтоОГРН(Документ)
	Возврат Документ.organization_code_type = "OGRN" Или Документ.organization_code_type = "REGN";
КонецФункции
Функция ЭтоИД_ПИФ_ИСУ(Документ)
	Возврат Документ.organization_code_type="TMRL" ИЛИ Документ.organization_code_type="MMRL";
КонецФункции

Процедура ПолучитьЦеннуюБумагу(ЦеннаяБумага, ДанныеЦБ)
	СвойстваЦБ = ЦеннаяБумага.security.Свойства();
	КодНРД = Неопределено;
	ISIN = Неопределено;
	НомерРегистрации = Неопределено;
	ДатаГосРег = Неопределено;
	Количество = 0;
	Если СвойстваЦБ.Получить("proprietary_security_code")<>Неопределено Тогда
		Если ЦеннаяБумага.security.proprietary_security_code.issuer = ЗначениеКодНРД() Тогда
			КодНРД = ЦеннаяБумага.security.proprietary_security_code.id;
		КонецЕсли;
	КонецЕсли;
	Если СвойстваЦБ.Получить("ISIN_identifier")<>Неопределено Тогда
		ISIN = ЦеннаяБумага.security.ISIN_identifier;
	КонецЕсли;
	
	Если СвойстваЦБ.Получить("state_reg_num") <> Неопределено Тогда
		НомерРегистрации = ЦеннаяБумага.security.state_reg_num;
	КонецЕсли;
	Если СвойстваЦБ.Получить("state_reg_date") <> Неопределено Тогда
		ДатаГосРег = ПолучитьДату(ЦеннаяБумага.security.state_reg_date);
	КонецЕсли;
	
	Количество = ЦеннаяБумага.total.qty_units.units;
	
	Если ЗначениеЗаполнено(ДанныеЦБ.КодНРД1) ИЛИ ЗначениеЗаполнено(ДанныеЦБ.ISIN1) Тогда
		ДанныеЦБ.ISIN2 = ISIN;
		ДанныеЦБ.КодНРД2 = КодНРД;
		ДанныеЦБ.НомерРегистрации2 = НомерРегистрации;
		ДанныеЦБ.ДатаГосРег2 = ДатаГосРег;
		ДанныеЦБ.Остаток2 = Количество;
	Иначе
		ДанныеЦБ.ISIN1 = ISIN;
		ДанныеЦБ.КодНРД1 = КодНРД;
		ДанныеЦБ.НомерРегистрации1 = НомерРегистрации;
		ДанныеЦБ.ДатаГосРег1 = ДатаГосРег;
		ДанныеЦБ.Остаток1 = Количество;
	КонецЕсли;
	
КонецПроцедуры

Процедура ПолучитьСписокЦенныхБумаг(СписокЦБ, ДанныеЦБ, Отказ, СообщениеОбОшибке)
	
	Если ЭтоСписокXDTO(СписокЦБ) Тогда
		Для Каждого ЦБ Из СписокЦБ Цикл
			ПолучитьЦеннуюБумагу(ЦБ, ДанныеЦБ);
		КонецЦикла;
	Иначе
		ПолучитьЦеннуюБумагу(СписокЦБ, ДанныеЦБ);
	КонецЕсли;
		
	ЕстьДанныеДляОпределенияЦБ = ЗначениеЗаполнено(ДанныеЦБ.ISIN1) Или ЗначениеЗаполнено(ДанныеЦБ.КодНРД1)
	Или (ЗначениеЗаполнено(ДанныеЦБ.НомерРегистрации1) И ЗначениеЗаполнено(ДанныеЦБ.ДатаГосРег1));
	
	Если Не ЕстьДанныеДляОпределенияЦБ Тогда
		СообщениеОбОшибке = СообщениеОбОшибке + Символы.ПС
		+ "Не заполнены ISIN, код НРД, номер регистрации и дата гос регистрации ценной бумаги для запроса по счету "
		+ ДанныеЦБ.СчетДепо;
		Отказ = Истина;
	КонецЕсли;
	
КонецПроцедуры
Функция ПолучитьДанныеЭмитента(Эмитент,ДокументЭмитента,ОГРНЭмитента,Эмитент2Наименование,Эмитент2Номер,Эмитент2ТипНомера)
	Если ЭтоОГРН(ДокументЭмитента) Тогда
		Если НЕ ДокументЭмитента.Свойства().Получить("org_doc_num") = Неопределено Тогда
			ОГРНЭмитента = ДокументЭмитента.org_doc_num.doc_num;
		КонецЕсли;
		Результат = Истина;
	ИначеЕсли ЭтоИД_ПИФ_ИСУ(ДокументЭмитента) Тогда
		Эмитент2Наименование = Эмитент.legal_entity_name;
		Эмитент2Номер = ДокументЭмитента.org_doc_num.doc_num;
		Эмитент2ТипНомера = ДокументЭмитента.organization_code_type;
		Результат = Истина;
	Иначе
		Результат = Ложь;
	КонецЕсли;
	Возврат Результат;
КонецФункции
Функция ПолучитьЭмитента(Эмитент,ОГРНЭмитента,Эмитент2Наименование,Эмитент2Номер,Эмитент2ТипНомера)
	Результат = Ложь;
	ИдентификаторыЭмитента = Эмитент.legal_entity_id;
	Если ЭтоСписокXDTO(ИдентификаторыЭмитента.organization_id) Тогда
		Для Каждого Документ ИЗ ИдентификаторыЭмитента.organization_id Цикл
			Если ПолучитьДанныеЭмитента(Эмитент, Документ, ОГРНЭмитента, Эмитент2Наименование, Эмитент2Номер, Эмитент2ТипНомера) Тогда
				Результат = Истина;
				Прервать;
			КонецЕсли;
		КонецЦикла;
	Иначе
		Результат = ПолучитьДанныеЭмитента(Эмитент, ИдентификаторыЭмитента.organization_id, ОГРНЭмитента, Эмитент2Наименование, Эмитент2Номер, Эмитент2ТипНомера);
	КонецЕсли;
	Возврат Результат;
КонецФункции
Процедура ПолучитьЭмитентовСообщения(issuer, ОГРНЭмитента,Эмитент2Наименование,Эмитент2Номер,Эмитент2ТипНомера,СообщениеОбОшибке)
	Если ЭтоСписокXDTO(issuer) Тогда
		Для Каждого Эмитент Из issuer Цикл
			ПолучитьЭмитента(Эмитент,ОГРНЭмитента,Эмитент2Наименование,Эмитент2Номер,Эмитент2ТипНомера);
		КонецЦикла;
	Иначе
		ПолучитьЭмитента(issuer,ОГРНЭмитента,Эмитент2Наименование,Эмитент2Номер,Эмитент2ТипНомера);
	КонецЕсли;
КонецПроцедуры
Функция ИнициаторПоКодуЗагрузки(КодЗагрузки)
	МхПоУмолчанию = ОбщегоНазначенияПовтИсп.ЗначениеКонстанты("МестоХраненияПоУмолчанию");
	Если ЗначениеЗаполнено(КодЗагрузки) Тогда
		Запрос = Новый Запрос(
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	КодыЗагрузки.Владелец КАК Владелец
		|ИЗ
		|	Справочник.КодыЗагрузки КАК КодыЗагрузки
		|ГДЕ
		|	КодыЗагрузки.Код = &Код
		|	И КодыЗагрузки.Биржа = &Биржа
		|	И КодыЗагрузки.Владелец ССЫЛКА Справочник.МестаХранения
		|	И НЕ КодыЗагрузки.ПометкаУдаления
		|	И (КодыЗагрузки.ДатаОкончанияДействия = ДАТАВРЕМЯ(1, 1, 1)
		|			ИЛИ КодыЗагрузки.ДатаОкончанияДействия < &ТекущаяДата)");
		Запрос.УстановитьПараметр("Код", КодЗагрузки);
		Запрос.УстановитьПараметр("Биржа", Справочники.КлассификаторыЗагрузки.НДЦ());
		Запрос.УстановитьПараметр("ТекущаяДата", ТекущаяДатаСеанса());
		Результат = Запрос.Выполнить();
		Если Результат.Пустой() Тогда
			Возврат МхПоУмолчанию;
		Иначе
			Выборка = Результат.Выбрать();
			Выборка.Следующий();
			Возврат Выборка.Владелец;
		КонецЕсли;
	Иначе
		Возврат МхПоУмолчанию;
	КонецЕсли;
КонецФункции

Функция НовыйТипСписка(Код)
	ТипСпискаОбъект	= Справочники.РСВ_ТипСписка.СоздатьЭлемент();
	ТипСпискаОбъект.Код = Код;
	ТипСпискаОбъект.Записать();
	Возврат ТипСпискаОбъект.Ссылка;
КонецФункции

Процедура ТектовоеПредставлениеЭлемента(Элемент, Результат, НачалоЗначения="")
	ТипОбъектXDTO = Тип("ОбъектXDTO");
	ТипСписокXDTO = Тип("СписокXDTO");
	СвойстваЭлемента = Элемент.Свойства();
	Для Каждого Свойство Из СвойстваЭлемента Цикл
		
		Если Свойство.ВерхняяГраница=1 Тогда
			ВложенныйЭлемент = Элемент.Получить(Свойство);
		Иначе
			ВложенныйЭлемент = Элемент.ПолучитьСписок(Свойство);
		КонецЕсли;
		ТипЗнчЭлемент = ТипЗнч(ВложенныйЭлемент);
		
		ТекСтрока = НачалоЗначения+Свойство.Имя;
		
		Если ТипЗнчЭлемент=ТипОбъектXDTO Тогда
			ТекСтрока = ТекСтрока+"/";
			ТектовоеПредставлениеЭлемента(ВложенныйЭлемент, Результат, ТекСтрока);
			
		ИначеЕсли ТипЗнчЭлемент=ТипСписокXDTO Тогда
			Инд=0;
			Для Каждого Эл Из ВложенныйЭлемент Цикл
				Инд = Инд+1;
				ТекСтрокаСписка = ТекСтрока+"["+Формат(Инд,"ЧГ=")+"]";
				Если ТипЗнч(Эл)= ТипОбъектXDTO Тогда
					ТектовоеПредставлениеЭлемента(Эл, Результат, ТекСтрокаСписка);
				Иначе
					Если Результат<>"" Тогда
						Результат = Результат+Символы.ПС;
					КонецЕсли;
					Результат = Результат + ТекСтрокаСписка+": "+Эл;
				КонецЕсли;
			КонецЦикла;
			
		Иначе
			Если Результат<>"" Тогда
				Результат = Результат+Символы.ПС;
			КонецЕсли;
			Результат = Результат + ТекСтрока+": "+ВложенныйЭлемент;
		КонецЕсли;
			
	КонецЦикла;
КонецПроцедуры

Функция ЗагрузитьЗапросНаРаскрытиеИзФайла(ИмяФайлаЗапроса, СообщениеОбОшибке) Экспорт
	СообщениеОбОшибке = "";
	
	ЧтениеXML = Новый ЧтениеXML;
	ЧтениеXML.ОткрытьФайл(ИмяФайлаЗапроса);

	Возврат СформироватьДокументЗапросНаРаскрытие(ЧтениеXML, СообщениеОбОшибке)
КонецФункции
Функция ЗагрузитьЗапросНаРаскрытиеИзТекста(ТекстЗапроса, СообщениеОбОшибке) Экспорт
	СообщениеОбОшибке = "";
	
	ЧтениеXML = Новый ЧтениеXML;
	ЧтениеXML.УстановитьСтроку(ТекстЗапроса);

	Возврат СформироватьДокументЗапросНаРаскрытие(ЧтениеXML, СообщениеОбОшибке)
КонецФункции
Функция СформироватьДокументЗапросНаРаскрытие(XMLЗапросНРД, СообщениеОбОшибке, Регламент = Ложь, ДокументСоздан = Ложь) Экспорт
	Отказ = Ложь;
	ПространствоИмен = "FCDR_2017_02(2019v3)";
	
	ТипXDTO = ФабрикаXDTO.Тип(ПространствоИмен, "DISCLOSURE_REQUEST");
	ЗапросНРД = ФабрикаXDTO.ПрочитатьXML(XMLЗапросНРД, ТипXDTO);
	
	ДатаДокумента = ТекущаяДатаСеанса();
	Попытка
		КодЗагрузкиИнициатора = ЗапросНРД.header.from.id_2.id;
	Исключение
		ЗаписьЖурналаРегистрации(
			"Загрузка Раскрытия списков владельцев в формате FCDR 2017 02",
			УровеньЖурналаРегистрации.Ошибка, , ,
			ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		КодЗагрузкиИнициатора = Неопределено;
	КонецПопытки;
	Инициатор = ИнициаторПоКодуЗагрузки(КодЗагрузкиИнициатора);
	
	ВходящийДокументНомер = "";
	ВходящийДокументДата = "";
	КодПолучателя = "";
	ПолучитьРеквизитыЗаголовкаСообщения(ЗапросНРД.header, ВходящийДокументНомер, ВходящийДокументДата, КодПолучателя, СообщениеОбОшибке);
	
	КДРеференс = ЗапросНРД.corporate_action_reference.corp_actn_evt_id;
	ВидКД = ЗапросНРД.corporate_action_reference.corporate_action_code;
	ДатаФиксации = ПолучитьДату(ЗапросНРД.record_date);
	ДатаОкончанияПриема = ПолучитьДату(ЗапросНРД.response_deadline);
	
	ПредоставитьБанковскиеРеквизиты = ПолучитьБулево(ЗапросНРД.information_indicator.request_bank_details);
	Шаблон = ЗапросНРД.information_indicator.disclosure_template;
	ТипСпискаКод = ЗапросНРД.information_indicator.information_type_code;
	
	REPORT_ID = ЗапросНРД.header.doc_num;
	ОснованиеЗапросаСтрокой = ЗапросНРД.basis_of_request.laws_in_place_code;
	ИнициаторЗапросаСтрокой = ЗапросНРД.initiator_request.initiator_request_type_code;
	ИнициаторЗапроса = Справочники.ТипыИнициатораЗапросаFCDR_2017_02.НайтиПоКоду(ИнициаторЗапросаСтрокой);
	ОснованиеЗапроса = Справочники.КодыСоответствияЗаконодательномуАктуFCDR_2017_02.НайтиПоКоду(ОснованиеЗапросаСтрокой);
	ОснованиеЗапросаОписание = ОснованиеЗапроса.Описание;
	ВыгрузкаPARTADВCоответствииCоCтатьей8_6_1 = (ОснованиеЗапросаСтрокой = "OWNS");
	СвойстваBasis = ЗапросНРД.basis_of_request.Свойства();
	Если СвойстваBasis.Получить("subordinate_legislation") <> Неопределено Тогда
		ПодзаконныйАкт = ЗапросНРД.basis_of_request.subordinate_legislation;
	КонецЕсли;

	ДополнительноеОписаниеОснованияЗапроса = "";
	Если ОснованиеЗапросаСтрокой = "OTHR" ИЛИ СвойстваBasis.Получить("narrative") <> Неопределено Тогда
		ДополнительноеОписаниеОснованияЗапроса = ЗапросНРД.basis_of_request.narrative;
	КонецЕсли;
	ДатаПоступленияЗапроса = ТекущаяДатаСеанса();
	
	СвойстваЗапроса = ЗапросНРД.Свойства();
	Комментарий = "";
	Если СвойстваЗапроса.Получить("add_info") <> Неопределено Тогда
		ТектовоеПредставлениеЭлемента(ЗапросНРД.add_info, Комментарий);
	КонецЕсли;
	
	ОГРНЭмитента = Неопределено;
	Эмитент2Наименование = Неопределено;
	Эмитент2Номер = Неопределено;
	Эмитент2ТипНомера = Неопределено;
	ПолучитьЭмитентовСообщения(ЗапросНРД.issuer, ОГРНЭмитента, Эмитент2Наименование, Эмитент2Номер, Эмитент2ТипНомера, СообщениеОбОшибке);
	
	ТипНомерСчета = Новый ОписаниеТипов("Строка", , , , Новый КвалификаторыСтроки(20));
	ТипКодISIN = Новый ОписаниеТипов("Строка", , , , Новый КвалификаторыСтроки(30));
	ТипНомерРегистрации = Новый ОписаниеТипов("Строка", , , , Новый КвалификаторыСтроки(50));
	ТипДатаГосРег = Новый ОписаниеТипов("Дата", , , , Новый КвалификаторыДаты(ЧастиДаты.Дата));
	ТипОстатокЦБ = Метаданные.ОпределяемыеТипы.КоличествоЦБ.Тип;
	СчетаДепоИЦБ = Новый ТаблицаЗначений;
	СчетаДепоИЦБ.Колонки.Добавить("СчетДепо", Новый ОписаниеТипов("Строка", , , , Новый КвалификаторыСтроки(17)));
	СчетаДепоИЦБ.Колонки.Добавить("ISIN1", ТипКодISIN);
	СчетаДепоИЦБ.Колонки.Добавить("ISIN2", ТипКодISIN);
	СчетаДепоИЦБ.Колонки.Добавить("КодНРД1", ТипКодISIN);
	СчетаДепоИЦБ.Колонки.Добавить("КодНРД2", ТипКодISIN);
	СчетаДепоИЦБ.Колонки.Добавить("Остаток1", ТипОстатокЦБ);
	СчетаДепоИЦБ.Колонки.Добавить("Остаток2", ТипОстатокЦБ);
	СчетаДепоИЦБ.Колонки.Добавить("НомерРегистрации1", ТипНомерРегистрации);
	СчетаДепоИЦБ.Колонки.Добавить("ДатаГосРег1", ТипДатаГосРег);
	СчетаДепоИЦБ.Колонки.Добавить("НомерРегистрации2", ТипНомерРегистрации);
	СчетаДепоИЦБ.Колонки.Добавить("ДатаГосРег2", ТипДатаГосРег);
	СчетаДепоИЦБ.Колонки.Добавить("НомерСчета", ТипНомерСчета);
	
	Если ЭтоСписокXDTO(ЗапросНРД.registered_shareholders) Тогда
		Для Каждого Эл Из ЗапросНРД.registered_shareholders Цикл
			НовСтр = СчетаДепоИЦБ.Добавить();
			НовСтр.СчетДепо = Эл.account_dtls.account_id.id;
			ПолучитьСписокЦенныхБумаг(Эл.security_balance, НовСтр, Отказ, СообщениеОбОшибке);
			ПолучитьНомерБанковскогоСчета(Эл, НовСтр, ПредоставитьБанковскиеРеквизиты);
		КонецЦикла;
	Иначе
		НовСтр = СчетаДепоИЦБ.Добавить();
		НовСтр.СчетДепо = ЗапросНРД.registered_shareholders.account_dtls.account_id.id;
		ПолучитьСписокЦенныхБумаг(ЗапросНРД.registered_shareholders.security_balance, НовСтр, Отказ, СообщениеОбОшибке);
		ПолучитьНомерБанковскогоСчета(ЗапросНРД.registered_shareholders, НовСтр, ПредоставитьБанковскиеРеквизиты);
	КонецЕсли;

	Если Отказ И НЕ Регламент Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = ТекстЗапросаДанныхДляРСВ();
	Запрос.Параметры.Вставить("КодПолучателя", КодПолучателя);
	Запрос.Параметры.Вставить("КДРеференс", КДРеференс);
	Запрос.Параметры.Вставить("ОГРНЭмитента", ОГРНЭмитента);
	Запрос.Параметры.Вставить("ТипСписка", ТипСпискаКод);
	Запрос.Параметры.Вставить("ВидКД", ВидКД);
	Запрос.Параметры.Вставить("тзн", СчетаДепоИЦБ);
	Запрос.Параметры.Вставить("Дата", ВходящийДокументДата);
	Запрос.Параметры.Вставить("ДатаФиксации", ДатаФиксации);
	
	Выборка = Запрос.Выполнить().Выбрать();
	ТипСписка = Неопределено;
	Если Выборка.Следующий() Тогда
		
		Если НЕ ЗначениеЗаполнено(Выборка.Организация) И ЗначениеЗаполнено(КодПолучателя) Тогда
			СообщениеОбОшибке = СообщениеОбОшибке + Символы.ПС + "Неизвестный получатель запроса «" + КодПолучателя + "»";
			Отказ = Истина;
		Иначе
		
			Если НЕ ЗначениеЗаполнено(Выборка.ВидКорпоративногоДействия) Тогда
				СообщениеОбОшибке = СообщениеОбОшибке + Символы.ПС + "Неизвестный вид КД";
				Отказ = Истина;
			Иначе
				
				ТипСписка = Выборка.ТипСписка;
				Если НЕ ЗначениеЗаполнено(ТипСписка) И ЗначениеЗаполнено(ТипСпискаКод) Тогда
					ТипСписка = НовыйТипСписка(ТипСпискаКод);
				КонецЕсли;
		
				Если НЕ ЗначениеЗаполнено(Выборка.Эмитент) И ЗначениеЗаполнено(ОГРНЭмитента) Тогда
					СообщениеОбОшибке = СообщениеОбОшибке + Символы.ПС + "Не найден эмитент с ОГРН «" + ОГРНЭмитента + "»";
					Отказ = Истина;
				КонецЕсли;
				
			КонецЕсли;
			
			Если Не ЗначениеЗаполнено(Выборка.ЦеннаяБумага1) Тогда
				СообщениеОбОшибке = СообщениеОбОшибке + Символы.ПС + "Не удалось обнаружить ценную бумагу «" + Выборка.ISIN1 + "»";
				Отказ = Истина;
			КонецЕсли;
			
		КонецЕсли;
	КонецЕсли;
	
	Если Не Отказ ИЛИ Регламент Тогда
		Выборка.Сбросить();
		Пока Выборка.Следующий() Цикл
			
			Док = Документы.РаскрытиеСпискаВладельцев.СоздатьДокумент();
			
			Док.ШаблонFCDR_2017_02 = Шаблон;
			Док.ТипЗагрузкиСписковРаскрытия = Перечисления.ТипЗагрузкиСписковРаскрытия.FCDR_2017_02;
			Док.Дата = ДатаДокумента;
			Док.ВходящийДокументНомер = ВходящийДокументНомер;
			Док.ВходящийДокументДата = ВходящийДокументДата;
			Док.Инициатор = Инициатор;
			Док.КДРеференс = КДРеференс;
			Док.ДатаФиксации = ДатаФиксации;
			Док.ДатаОкончанияПриема = ДатаОкончанияПриема;
			Док.Эмитент2Наименование = Эмитент2Наименование;
			Док.Эмитент2Номер = Эмитент2Номер;
			Док.Эмитент2ТипНомера = Эмитент2ТипНомера;
			Док.Комментарий = Комментарий;
			Остаток1 = 0;
			Остаток2 = 0;
			
			Док.REPORT_ID = REPORT_ID;
			Док.ОснованиеЗапроса = ОснованиеЗапросаОписание;
			Док.ИнициаторЗапроса = ИнициаторЗапроса;
			Док.КодОснованияЗапроса = ОснованиеЗапроса;
			Док.ВыгрузкаPARTADВCоответствииCоCтатьей8_6_1 = ВыгрузкаPARTADВCоответствииCоCтатьей8_6_1;
			Док.ДатаПоступленияЗапроса = ДатаПоступленияЗапроса;
			Док.ПодзаконныйАкт = ПодзаконныйАкт;
			Док.ДополнительноеОписаниеОснованияЗапроса = ДополнительноеОписаниеОснованияЗапроса;
			Док.ПредоставитьБанковскиеРеквизиты = ПредоставитьБанковскиеРеквизиты;

			
			ЗаполнитьЗначенияСвойств(Док, Выборка);
			Док.Эмитент = Док.ЦеннаяБумага1.Эмитент;
			
			ОГРНЦБЭмитента = СокрЛП(Док.ЦеннаяБумага1.Эмитент.ЮридическиеФизическиеЛица.ОГРН);
			Если ОГРНРазличается(ОГРНЭмитента, ОГРНЦБЭмитента) Тогда
				СообщениеОбОшибке = СообщениеОбОшибке + Символы.ПС + "ОГРН указанного эмитента в раскрытии «" + ОГРНЭмитента + "» 
					|не совпадает с ОГРН по эмитенту в ЦБ «" + ОГРНЦБЭмитента + "»";
				Отказ = Истина;
				Прервать;
			КонецЕсли;
			Док.ТипСписка = ТипСписка;
			
			Если ПредоставитьБанковскиеРеквизиты Тогда
				Док.БанковскийСчет = Выборка.БанковскийСчетИзФайла;
			КонецЕсли;
			
			Док.Записать();
		КонецЦикла;
		ДокументСоздан = Не Отказ;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(СообщениеОбОшибке) Тогда 
		СообщениеОбОшибке = "Ошибки загрузки DISCLOSURE REQUEST " + ВходящийДокументНомер + ": " + СообщениеОбОшибке;
	КонецЕсли;
	
	Возврат Не Отказ;
	
КонецФункции

Функция ТекстЗапросаДанныхДляРСВ()
	Возврат
	"ВЫБРАТЬ
	|	тзнЗапросНРД.СчетДепо КАК СчетДепо,
	|	тзнЗапросНРД.КодНРД1 КАК КодНРД1,
	|	тзнЗапросНРД.КодНРД2 КАК КодНРД2,
	|	тзнЗапросНРД.ISIN1 КАК ISIN1,
	|	тзнЗапросНРД.ISIN2 КАК ISIN2,
	|	тзнЗапросНРД.Остаток1 КАК Остаток1,
	|	тзнЗапросНРД.Остаток2 КАК Остаток2,
	|	тзнЗапросНРД.НомерРегистрации1 КАК НомерРегистрации1,
	|	тзнЗапросНРД.ДатаГосРег1 КАК ДатаГосРег1,
	|	тзнЗапросНРД.НомерРегистрации2 КАК НомерРегистрации2,
	|	тзнЗапросНРД.ДатаГосРег2 КАК ДатаГосРег2,
	|	тзнЗапросНРД.НомерСчета КАК НомерСчета
	|ПОМЕСТИТЬ ВТ_ЗапросНРД
	|ИЗ
	|	&тзн КАК тзнЗапросНРД
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_ЗапросНРД.НомерРегистрации1 КАК НомерРегистрации,
	|	ВТ_ЗапросНРД.ДатаГосРег1 КАК ДатаГосРег,
	|	МАКСИМУМ(ЕСТЬNULL(ЦБпоНомеруИДатеРегистрации.Ссылка, ЗНАЧЕНИЕ(Справочник.ЦенныеБумаги.ПустаяСсылка))) КАК ЦеннаяБумага
	|ПОМЕСТИТЬ ЦБпоНомеруИДатеРегистрации1
	|ИЗ
	|	ВТ_ЗапросНРД КАК ВТ_ЗапросНРД
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ЦенныеБумаги КАК ЦБпоНомеруИДатеРегистрации
	|		ПО (ВТ_ЗапросНРД.НомерРегистрации1 <> """")
	|			И ВТ_ЗапросНРД.НомерРегистрации1 = ЦБпоНомеруИДатеРегистрации.НомерРегистрации
	|			И ВТ_ЗапросНРД.ДатаГосРег1 = ЦБпоНомеруИДатеРегистрации.ДатаГосРег
	|			И (НЕ ЦБпоНомеруИДатеРегистрации.ПометкаУдаления)
	|
	|СГРУППИРОВАТЬ ПО
	|	ВТ_ЗапросНРД.НомерРегистрации1,
	|	ВТ_ЗапросНРД.ДатаГосРег1
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_ЗапросНРД.НомерРегистрации2 КАК НомерРегистрации,
	|	ВТ_ЗапросНРД.ДатаГосРег2 КАК ДатаГосРег,
	|	МАКСИМУМ(ЕСТЬNULL(ЦБпоНомеруИДатеРегистрации.Ссылка, ЗНАЧЕНИЕ(Справочник.ЦенныеБумаги.ПустаяСсылка))) КАК ЦеннаяБумага
	|ПОМЕСТИТЬ ЦБпоНомеруИДатеРегистрации2
	|ИЗ
	|	ВТ_ЗапросНРД КАК ВТ_ЗапросНРД
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ЦенныеБумаги КАК ЦБпоНомеруИДатеРегистрации
	|		ПО (ВТ_ЗапросНРД.НомерРегистрации2 <> """")
	|			И ВТ_ЗапросНРД.НомерРегистрации2 = ЦБпоНомеруИДатеРегистрации.НомерРегистрации
	|			И ВТ_ЗапросНРД.ДатаГосРег2 = ЦБпоНомеруИДатеРегистрации.ДатаГосРег
	|			И (НЕ ЦБпоНомеруИДатеРегистрации.ПометкаУдаления)
	|
	|СГРУППИРОВАТЬ ПО
	|	ВТ_ЗапросНРД.НомерРегистрации2,
	|	ВТ_ЗапросНРД.ДатаГосРег2
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	МАКСИМУМ(Таб.Организация) КАК Организация,
	|	МАКСИМУМ(Таб.КарточкаКД) КАК КарточкаКД,
	|	МАКСИМУМ(Таб.Эмитент) КАК Эмитент,
	|	МАКСИМУМ(Таб.ТипСписка) КАК ТипСписка,
	|	ЕСТЬNULL(ЕСТЬNULL(КодыЦБ1.Владелец, СпрЦБ1.Ссылка), ЦБпоНомеруИДатеРегистрации1.ЦеннаяБумага) КАК ЦеннаяБумага1,
	|	ЕСТЬNULL(ЕСТЬNULL(КодыЦБ2.Владелец, СпрЦБ2.Ссылка), ЦБпоНомеруИДатеРегистрации2.ЦеннаяБумага) КАК ЦеннаяБумага2,
	|	ЗапросНРД.ISIN1 КАК ISIN1,
	|	ЗапросНРД.ISIN2 КАК ISIN2,
	|	ЗапросНРД.КодНРД1 КАК КодНРД1,
	|	ЗапросНРД.КодНРД2 КАК КодНРД2,
	|	ЗапросНРД.Остаток1 КАК ЦеннаяБумага1Остаток,
	|	ЗапросНРД.Остаток2 КАК ЦеннаяБумага2Остаток,
	|	МАКСИМУМ(Таб.ВидКорпоративногоДействия) КАК ВидКорпоративногоДействия,
	|	СчетаМХ.Ссылка КАК СчетДепо,
	|	МАКСИМУМ(БанковскиеСчета.Ссылка) КАК БанковскийСчет,
	|	МАКСИМУМ(ЕСТЬNULL(БанковскиеСчетаИзФайла.Ссылка, ЗНАЧЕНИЕ(Справочник.БанковскиеСчета.ПустаяСсылка))) КАК БанковскийСчетИзФайла
	|ИЗ
	|	ВТ_ЗапросНРД КАК ЗапросНРД
	|		ЛЕВОЕ СОЕДИНЕНИЕ Константа.КлассификаторЗагрузкиНДЦ КАК КлассификаторЗагрузкиНДЦ
	|		ПО (ИСТИНА)
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.СчетаДепоМХ КАК СчетаМХ
	|		ПО (СчетаМХ.Код = ЗапросНРД.СчетДепо)
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.КодыЗагрузки КАК КодыЦБ1
	|		ПО (КодыЦБ1.Код = ЗапросНРД.КодНРД1)
	|			И (КодыЦБ1.Биржа = КлассификаторЗагрузкиНДЦ.Значение)
	|			И (КодыЦБ1.Владелец ССЫЛКА Справочник.ЦенныеБумаги)
	|			И (НЕ КодыЦБ1.ПометкаУдаления)
	|			И (КодыЦБ1.ДатаОкончанияДействия = ДАТАВРЕМЯ(1, 1, 1)
	|				ИЛИ КодыЦБ1.ДатаОкончанияДействия > &ДатаФиксации)
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ЦенныеБумаги КАК СпрЦБ1
	|		ПО (СпрЦБ1.ISIN = ЗапросНРД.ISIN1)
	|			И (ЗапросНРД.КодНРД1 = """")
	|			И (ЗапросНРД.ISIN1 <> """")
	|			И (НЕ СпрЦБ1.ПометкаУдаления)
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.КодыЗагрузки КАК КодыЦБ2
	|		ПО (КодыЦБ2.Код = ЗапросНРД.КодНРД2)
	|			И (КодыЦБ2.Биржа = КлассификаторЗагрузкиНДЦ.Значение)
	|			И (КодыЦБ1.Владелец ССЫЛКА Справочник.ЦенныеБумаги)
	|			И (НЕ КодыЦБ2.ПометкаУдаления)
	|			И (КодыЦБ2.ДатаОкончанияДействия = ДАТАВРЕМЯ(1, 1, 1)
	|				ИЛИ КодыЦБ2.ДатаОкончанияДействия > &ДатаФиксации)
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ЦенныеБумаги КАК СпрЦБ2
	|		ПО (СпрЦБ2.ISIN = ЗапросНРД.ISIN2)
	|			И (ЗапросНРД.КодНРД2 = """")
	|			И (ЗапросНРД.ISIN2 <> """")
	|			И (НЕ СпрЦБ2.ПометкаУдаления)
	|		ЛЕВОЕ СОЕДИНЕНИЕ ЦБпоНомеруИДатеРегистрации1 КАК ЦБпоНомеруИДатеРегистрации1
	|		ПО (ЗапросНРД.НомерРегистрации1 <> """")
	|			И ЗапросНРД.НомерРегистрации1 = ЦБпоНомеруИДатеРегистрации1.НомерРегистрации
	|			И ЗапросНРД.ДатаГосРег1 = ЦБпоНомеруИДатеРегистрации1.ДатаГосРег
	|		ЛЕВОЕ СОЕДИНЕНИЕ ЦБпоНомеруИДатеРегистрации2 КАК ЦБпоНомеруИДатеРегистрации2
	|		ПО (ЗапросНРД.НомерРегистрации2 <> """")
	|			И ЗапросНРД.НомерРегистрации2 = ЦБпоНомеруИДатеРегистрации2.НомерРегистрации
	|			И ЗапросНРД.ДатаГосРег2 = ЦБпоНомеруИДатеРегистрации2.ДатаГосРег
	|		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	|			Таб.Организация КАК Организация,
	|			Таб.КарточкаКД КАК КарточкаКД,
	|			Таб.Эмитент КАК Эмитент,
	|			Таб.ТипСписка КАК ТипСписка,
	|			Таб.ВидКорпоративногоДействия КАК ВидКорпоративногоДействия
	|		ИЗ
	|			(ВЫБРАТЬ
	|				Таб.Ссылка КАК Организация,
	|				NULL КАК КарточкаКД,
	|				NULL КАК Эмитент,
	|				NULL КАК ТипСписка,
	|				NULL КАК ВидКорпоративногоДействия
	|			ИЗ
	|				Справочник.КодыЗагрузки КАК СпрКоды
	|					ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Организации КАК Таб
	|					ПО (Таб.ЮридическоеЛицо = СпрКоды.Владелец)
	|			ГДЕ
	|				СпрКоды.Код = &КодПолучателя
	|				И НЕ СпрКоды.ПометкаУдаления
	|				И СпрКоды.Владелец ССЫЛКА Справочник.ЮридическиеЛица
	|				И (СпрКоды.ДатаОкончанияДействия = ДАТАВРЕМЯ(1, 1, 1)
	|						ИЛИ СпрКоды.ДатаОкончанияДействия > &Дата)
	|			
	|			ОБЪЕДИНИТЬ ВСЕ
	|			
	|			ВЫБРАТЬ
	|				NULL,
	|				Таб.Ссылка,
	|				NULL,
	|				NULL,
	|				NULL
	|			ИЗ
	|				Документ.КорпоративноеДействие_Новый КАК Таб
	|			ГДЕ
	|				Таб.КДРеференс = &КДРеференс
	|				И НЕ Таб.ПометкаУдаления
	|			
	|			ОБЪЕДИНИТЬ ВСЕ
	|			
	|			ВЫБРАТЬ
	|				NULL,
	|				NULL,
	|				Таб.Ссылка,
	|				NULL,
	|				NULL
	|			ИЗ
	|				Справочник.Контрагенты КАК Таб
	|			ГДЕ
	|				Таб.ЮридическиеФизическиеЛица.ОГРН = &ОГРНЭмитента
	|				И НЕ Таб.ПометкаУдаления
	|				И Таб.Родитель = ЗНАЧЕНИЕ(Справочник.Контрагенты.Эмитенты)
	|			
	|			ОБЪЕДИНИТЬ ВСЕ
	|			
	|			ВЫБРАТЬ
	|				NULL,
	|				NULL,
	|				NULL,
	|				Таб.Ссылка,
	|				NULL
	|			ИЗ
	|				Справочник.РСВ_ТипСписка КАК Таб
	|			ГДЕ
	|				Таб.Код = &ТипСписка
	|				И НЕ Таб.ПометкаУдаления
	|			
	|			ОБЪЕДИНИТЬ ВСЕ
	|			
	|			ВЫБРАТЬ
	|				NULL,
	|				NULL,
	|				NULL,
	|				NULL,
	|				Таб.Ссылка
	|			ИЗ
	|				Справочник.ВидыКорпоративныхДействий КАК Таб
	|			ГДЕ
	|				Таб.Код = &ВидКД) КАК Таб) КАК Таб
	|		ПО (ИСТИНА)
	|		ЛЕВОЕ СОЕДИНЕНИЕ Константа.ВалютаРегламентированногоУчета КАК ВалютаРегл
	|		ПО (ИСТИНА)
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.БанковскиеСчета КАК БанковскиеСчета
	|		ПО (БанковскиеСчета.Владелец = Таб.Организация)
	|			И (НЕ БанковскиеСчета.ПометкаУдаления)
	|			И (БанковскиеСчета.ВалютаДенежныхСредств = КодыЦБ1.Владелец.ВалютаНоминала)
	|			И (БанковскиеСчета.ТипНазначения = ЗНАЧЕНИЕ(Перечисление.ТипыНазначенияБанковскихСчетов.Депозитарный))
	|			И (СчетаМХ.Владелец.НомерГосударственнойРегистрации = БанковскиеСчета.Банк.ОГРН)
	|			И (БанковскиеСчета.ДатаОткрытия <= &Дата)
	|			И (БанковскиеСчета.ДатаЗакрытия > &Дата
	|				ИЛИ БанковскиеСчета.ДатаЗакрытия = ДАТАВРЕМЯ(1, 1, 1))
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.БанковскиеСчета КАК БанковскиеСчетаИзФайла
	|		ПО ЗапросНРД.НомерСчета = БанковскиеСчетаИзФайла.НомерСчета
	|			И (СОКРЛП(ЗапросНРД.НомерСчета) <> """")
	|			И (НЕ БанковскиеСчетаИзФайла.ПометкаУдаления)
	|
	|СГРУППИРОВАТЬ ПО
	|	ЗапросНРД.КодНРД1,
	|	ЗапросНРД.КодНРД2,
	|	ЗапросНРД.ISIN1,
	|	ЗапросНРД.ISIN2,
	|	ЗапросНРД.НомерРегистрации1,
	|	ЗапросНРД.НомерРегистрации2,
	|	ЗапросНРД.Остаток1,
	|	ЗапросНРД.Остаток2,
	|	СчетаМХ.Ссылка,
	|	ЕСТЬNULL(ЕСТЬNULL(КодыЦБ1.Владелец, СпрЦБ1.Ссылка), ЦБпоНомеруИДатеРегистрации1.ЦеннаяБумага),
	|	ЕСТЬNULL(ЕСТЬNULL(КодыЦБ2.Владелец, СпрЦБ2.Ссылка), ЦБпоНомеруИДатеРегистрации2.ЦеннаяБумага)";

КонецФункции

Функция ОГРНРазличается(ОГРНЭмитента, ОГРНЦБЭмитента)
	Возврат ОГРНЭмитента <> ОГРНЦБЭмитента И НЕ (ПустаяСтрока(ОГРНЭмитента) И ПустаяСтрока(ОГРНЦБЭмитента));
КонецФункции

Процедура ПолучитьНомерБанковскогоСчета(registered_shareholders, НовСтр, ПредоставитьБанковскиеРеквизиты)
	Если ПредоставитьБанковскиеРеквизиты Тогда
		ДоступныеСвойства = registered_shareholders.Свойства();
		Если ДоступныеСвойства.Получить("bank_prop_rub") <> Неопределено Тогда
			НовСтр.НомерСчета = registered_shareholders.bank_prop_rub.cash_rub_dtls.account.id;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

