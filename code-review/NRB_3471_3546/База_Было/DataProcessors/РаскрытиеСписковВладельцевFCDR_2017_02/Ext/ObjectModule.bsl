Функция Новый_header_t(НомерРаскрытия, ДанныеЗаголовок)
	Результат = НовыйОбъектСхемыFCDR("header_t");
	
	Результат.doc_num = string35(НомерРаскрытия);
	Результат.doc_date = Новый_date_or_datetime_t(ДанныеЗаголовок.ДатаРаскрытия);
	
	РегистрационныеДанные = НовыйРегистрационныеДанныеДля_party_identification2_V02_t(ДанныеЗаголовок.ОтправительИдентификатор, ДанныеЗаголовок.ОтправительТипИдентификатора, ДанныеЗаголовок.ВладелецИдентификатораОтправителя);
	Результат.from = Новый_party_identification2_V02_t(РегистрационныеДанные);
	
	РегистрационныеДанные = НовыйРегистрационныеДанныеДля_party_identification2_V02_t(ДанныеЗаголовок.ПолучательИдентификатор, ДанныеЗаголовок.ПолучательТипИдентификатора, ДанныеЗаголовок.ВладелецИдентификатораПолучателя);
	Результат.to = Новый_party_identification2_V02_t(РегистрационныеДанные);
	Возврат Результат;
