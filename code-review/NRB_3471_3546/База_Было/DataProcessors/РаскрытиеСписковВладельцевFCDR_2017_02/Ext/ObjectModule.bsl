Функция Новый_party_id_name_V03_t(Наименование, ИдентификаторыV02)
	Результат = НовыйОбъектСхемыFCDR("party_id_name_V03_t");
	Если ТипЗнч(ИдентификаторыV02)=Тип("Массив") Тогда
		Для Каждого Эл Из ИдентификаторыV02 Цикл
			Результат.id.Добавить(Новый_id_V02_t(Эл.Идентификатор, Эл.ВладелецИдентификатораИлиСхема, Эл.ЗарегистрированSWIFT));
		КонецЦикла;
	Иначе
		Результат.id.Добавить(Новый_id_V02_t(ИдентификаторыV02.Идентификатор, ИдентификаторыV02.ВладелецИдентификатораИлиСхема, ИдентификаторыV02.ЗарегистрированSWIFT));
	КонецЕсли;
	Результат.name = string512(Наименование);

	Возврат Результат;
КонецФункции

Функция Новый_information_type_V02_t(ТипСписка, ПредоставитьБанковскиеРеквизиты, Шаблон, ОписаниеТипаСписка=Неопределено)
	Результат = НовыйОбъектСхемыFCDR("information_type_V02_t");
	
	Результат.information_type_code = ТипСписка;

	Результат.request_bank_details = yes_no_t(ПредоставитьБанковскиеРеквизиты);

	Результат.disclosure_template = Шаблон;

	Если ЭтоПрочее(ТипСписка) И ЗначениеЗаполнено(ОписаниеТипаСписка) Тогда
		Результат.narrative = string254(ОписаниеТипаСписка);
	КонецЕсли;
	
	Возврат Результат;
КонецФункции

