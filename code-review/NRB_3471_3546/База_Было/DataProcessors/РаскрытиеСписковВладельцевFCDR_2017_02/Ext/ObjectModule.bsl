Функция Новый_document_details_choice_t(СтруктураСерияНомер)
	Результат = НовыйОбъектСхемыFCDR("document_details_choice_t");
	
	Серия = Неопределено;
	Номер = Неопределено;
	СерияИНомер = Неопределено;
	СтруктураСерияНомер.Свойство("Серия",Серия);
	СтруктураСерияНомер.Свойство("Номер",Номер);
	СтруктураСерияНомер.Свойство("СерияИНомер",СерияИНомер);
	
	Если ЗначениеЗаполнено(Серия) И ЗначениеЗаполнено(Номер) Тогда
		Результат.dtls_apart = Новый_document_ser_num_t(Серия,Номер);
	ИначеЕсли ЗначениеЗаполнено(СерияИНомер) Тогда
		Результат.dtls_together = string20(СерияИНомер);
	Иначе
		Результат.doc_num = string35(?(ЗначениеЗаполнено(Номер), Номер, "UKWN"));
	КонецЕсли;
	
	Возврат Результат;
