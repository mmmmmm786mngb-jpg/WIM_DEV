Функция ТаблицаКодовТиповСчетов()
	Результат = Новый ТаблицаЗначений;
	Результат.Колонки.Добавить("КодЛуч",Новый ОписаниеТипов("Строка",,,,Новый КвалификаторыСтроки(2)));
	Результат.Колонки.Добавить("КодFCDR",Новый ОписаниеТипов("Строка",,,,Новый КвалификаторыСтроки(4)));
	НовыйСтрокаТаблицыКодовТиповСчетов(Результат,"01","OWNE");
	НовыйСтрокаТаблицыКодовТиповСчетов(Результат,"20","OWNE");
	НовыйСтрокаТаблицыКодовТиповСчетов(Результат,"03","TRUS");
	НовыйСтрокаТаблицыКодовТиповСчетов(Результат,"21","FTRS");
	Возврат Результат;
КонецФункции
Функция ТекстЗапросаСписокРаскрытия()
	Возврат
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	РСВ.Клиент.ЮридическиеФизическиеЛица КАК ЮридическиеФизическиеЛица,
	|	РСВ.Клиент.ЮрФизЛицо КАК ЮрФизЛицо
	|ПОМЕСТИТЬ ВТ_ЮрФизЛицаДокумента
	|ИЗ
	|	Документ.РаскрытиеСпискаВладельцев.СписокВладельцев КАК РСВ
	|ГДЕ
	|	РСВ.Ссылка = &ДокументРСВ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	РСВ.РазделСчетаДепо.Залогодержатель.ЮридическиеФизическиеЛица КАК ЮридическиеФизическиеЛица,
	|	РСВ.РазделСчетаДепо.Залогодержатель.ЮрФизЛицо КАК ЮрФизЛицо
	|ПОМЕСТИТЬ ВТ_ЗалогодержателиДокумента
	|ИЗ
	|	Документ.РаскрытиеСпискаВладельцев.СписокВладельцев КАК РСВ
	|ГДЕ
	|	РСВ.Ссылка = &ДокументРСВ
	|	И РСВ.РазделСчетаДепо.Залогодержатель <> ЗНАЧЕНИЕ(Справочник.Контрагенты.ПустаяСсылка)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Субклиенты.Клиент КАК ЮридическиеФизическиеЛица,
	|	ВЫБОР
	|		КОГДА Субклиенты.Клиент ССЫЛКА Справочник.ЮридическиеЛица
	|			ТОГДА ЗНАЧЕНИЕ(Перечисление.ЮрФизЛицо.ЮрЛицо)
	|		ИНАЧЕ ЗНАЧЕНИЕ(Перечисление.ЮрФизЛицо.ФизЛицо)
	|	КОНЕЦ КАК ЮрФизЛицо
	|ПОМЕСТИТЬ ВТ_ЮрФизЛицаДокументаУК
	|ИЗ
	|	Документ.РаскрытиеСпискаВладельцев.СписокВладельцев КАК РСВ
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.Субклиенты КАК Субклиенты
	|		ПО (Субклиенты.Объект = РСВ.Клиент)
	|ГДЕ
	|	РСВ.Ссылка = &ДокументРСВ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	тзн.КодЛуч КАК КодЛуч,
	|	тзн.КодFCDR КАК КодFCDR
	|ПОМЕСТИТЬ ВТ_ТипыСчетовЛуч
	|ИЗ
	|	&тзнТипыСчетовЛуч КАК тзн
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	&ПоляБанковскихРеквизитов КАК ПоляБанковскихРеквизитов,
	|	РСВ.Проведен КАК Проведен,
	|	РСВ.Номер КАК НомерРаскрытия,
	|	РСВ.Дата КАК ДатаРаскрытия,
	|	РСВ.Организация.ЮридическоеЛицо.Наименование КАК ОтправительНаименование,
	|	КодыОтправителя.Код КАК ОтправительИдентификатор,
	|	&Прочее КАК ОтправительТипИдентификатора,
	|	&NSDR КАК ВладелецИдентификатораОтправителя,
	|	КодыПолучателя.Код КАК ПолучательИдентификатор,
	|	&Прочее КАК ПолучательТипИдентификатора,
	|	&NSDR КАК ВладелецИдентификатораПолучателя,
	|	РСВ.ВходящийДокументНомер КАК НомерЗапроса,
	|	РСВ.ВходящийДокументДата КАК ДатаЗапроса,
	|	РСВ.Эмитент.ЮридическиеФизическиеЛица.ПолноеНаименование КАК ЭмитентНаименование,
	|	РСВ.Эмитент.ЮридическиеФизическиеЛица.ОГРН КАК ЭмитентНомер,
	|	""OGRN"" КАК ЭмитентТипНомера,
	|	РСВ.Эмитент2Наименование КАК Эмитент2Наименование,
	|	РСВ.Эмитент2Номер КАК Эмитент2Номер,
	|	РСВ.Эмитент2ТипНомера КАК Эмитент2ТипНомера,
	|	РСВ.КДРеференс КАК КДРеференс,
	|	РСВ.ВидКорпоративногоДействия.Код КАК КодТипаКД,
	|	РСВ.ДатаФиксации КАК ДатаФиксации,
	|	РСВ.СчетДЕПО.Код КАК СчетДЕПО,
	|	РСВ.СчетДЕПО.ТипСчета КАК ТипСчетаДЕПО,
	|	РСВ.ТипСписка.Код КАК ТипСписка,
	|	ЛОЖЬ КАК ПредоставитьБанковскиеРеквизиты,
	|	РСВ.ШаблонFCDR_2017_02 КАК Шаблон
	|ИЗ
	|	Документ.РаскрытиеСпискаВладельцев КАК РСВ
	|		ЛЕВОЕ СОЕДИНЕНИЕ Константа.КлассификаторЗагрузкиНДЦ КАК КлассификаторЗагрузкиНДЦ
	|		ПО (ИСТИНА)
	|		ЛЕВОЕ СОЕДИНЕНИЕ Константа.ВалютаРегламентированногоУчета КАК ВалютаРегламентированногоУчета
	|		ПО (ИСТИНА)
	|		ЛЕВОЕ СОЕДИНЕНИЕ Константа.ДепозитарийПоУмолчанию КАК ДепозитарийПоУмолчанию
	|		ПО (ИСТИНА)
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.КодыЗагрузки КАК КодыОтправителя
	|		ПО (КодыОтправителя.Владелец = РСВ.Организация.ЮридическоеЛицо)
	|			И (КодыОтправителя.Биржа = КлассификаторЗагрузкиНДЦ.Значение)
	|			И (КодыОтправителя.ДатаОкончанияДействия = ДАТАВРЕМЯ(1, 1, 1)
	|				ИЛИ КодыОтправителя.ДатаОкончанияДействия > &Дата)
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.КодыЗагрузки КАК КодыПолучателя
	|		ПО (КодыПолучателя.Владелец = РСВ.Инициатор)
	|			И (КодыПолучателя.Биржа = КлассификаторЗагрузкиНДЦ.Значение)
	|			И (КодыПолучателя.ДатаОкончанияДействия = ДАТАВРЕМЯ(1, 1, 1)
	|				ИЛИ КодыПолучателя.ДатаОкончанияДействия > &Дата),
	|	&ИсточникиБанковскихРеквизитов КАК ИсточникиБанковскихРеквизитов
	|ГДЕ
	|	РСВ.Ссылка = &ДокументРСВ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	&ПоляБенефициаров КАК ПоляБенефициаров,
	|	РСВ.ЦеннаяБумага КАК ЦеннаяБумага,
	|	РСВ.ЦеннаяБумага.ТипЦБ КАК ТипЦБ,
	|	ВЫБОР
	|		КОГДА РСВ.ЦеннаяБумага.ТипЦБ = ЗНАЧЕНИЕ(Перечисление.ТипыЦБ.Акция)
	|			ТОГДА РСВ.ЦеннаяБумага.ВидЦБ
	|		ИНАЧЕ НЕОПРЕДЕЛЕНО
	|	КОНЕЦ КАК ВидЦБ,
	|	РСВ.Количество КАК Количество,
	|	РСВ.КоличествоВЗалоге КАК КоличествоВЗалоге,
	|	КодыЦБ.Код КАК КодЦБ,
	|	&NSDR КАК ВладелецКодаЦБ,
