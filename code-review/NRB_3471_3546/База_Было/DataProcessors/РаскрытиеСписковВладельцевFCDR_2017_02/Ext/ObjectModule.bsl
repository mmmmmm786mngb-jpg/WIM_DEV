Функция Новый_block_type_V03_t(Данные)
	Результат = НовыйОбъектСхемыFCDR("block_type_V03_t");
	Результат.block_type_code = Данные.ВидОбременения;
	Если ЭтоПрочее(Результат.block_type_code) Тогда
		Результат.narrative = string254(Данные.ОписаниеВидаОбременения);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Данные.СведенияОбОбременении) Тогда
		Результат.restrictions = string512(Данные.СведенияОбОбременении);
	КонецЕсли;
	
	Если Результат.block_type_code = "COLO" Тогда
		СведенияОЗалоге = НовыйОбъектСхемыFCDRИзСвойств("block_type_V03_t","pledgee_info");
		//ТипСведенийОЗалоге = ФабрикаXDTO.Тип("block_type_V03_t").Свойства.Получить("pledgee_info").Тип;
		
		СведенияОЗалоге.account_dtls_v02 = Новый_account_dtls_v05_t(Данные);
		
		АдресЗалогодержателя = НовыйСтруктураАдреса(Данные.ЗалогодержательАдресПоле1,Данные.ЗалогодержательАдресПоле2,Данные.ЗалогодержательАдресПоле3,Данные.ЗалогодержательАдресПоле4,Данные.ЗалогодержательАдресПоле5,Данные.ЗалогодержательАдресПоле6,Данные.ЗалогодержательАдресПоле7,Данные.ЗалогодержательАдресПоле8,Данные.ЗалогодержательАдресПоле9,
				Данные.ЗалогодержательАдрес,Данные.ЗалогодержательСтранаИностранногоАдреса,Данные.Россия);
				
		Если Данные.ЗалогодержательЮрФизЛицо=Перечисления.ЮрФизЛицо.ЮрЛицо Тогда
			ДанныеОбЮрФизЛице = НовыйДанныеОбОрганизации(Данные.ЗалогодержательЮрФизЛицо, Данные.ЗалогодержательТипКодаДокумента,Данные.ЗалогодержательНомерДокумента,Данные.ЗалогодержательДатаДокумента,Данные.ЗалогодержательРегистрирующийОрган, Данные.ЗалогодержательСтрана, Данные.ЗалогодержательДатаРегистрации);
		Иначе
			ДанныеОбЮрФизЛице = НовыйДанныеОФизЛице(Данные.ЗалогодержательФЛДокументТип,Данные.ЗалогодержательФЛДокументСерия,Данные.ЗалогодержательФЛДокументНомер,Данные.ЗалогодержательФЛДокументДатаВыдачи,Данные.ЗалогодержательФЛДокументКемВыдан, Данные.ЗалогодержательФЛДатаРождения,Данные.ЗалогодержательФЛМестоРождения,Данные.ЗалогодержательФЛГражданство);
		КонецЕсли;
		СведенияОЗалоге.pledgee = Новый_party_dtls_V02_t(Данные.ЗалогодержательНаименование, Данные.ЗалогодержательЮрФизЛицо, ДанныеОбЮрФизЛице, АдресЗалогодержателя);
		
		Если ЗначениеЗаполнено(Данные.ОписаниеУсловийЗалога) Тогда
			СведенияОЗалоге.pledgee_narrative = string4000(Данные.ОписаниеУсловийЗалога);
		КонецЕсли;
		
