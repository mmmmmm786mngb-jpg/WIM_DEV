Функция Новый_security_classification_et(ТипЦБ)
	Если ТипЦБ=Перечисления.ТипыЦБ.Акция Тогда
		Результат = "SHAR";
	ИначеЕсли ТипЦБ=Перечисления.ТипыЦБ.Облигация Тогда
		Результат = "BOND";
	ИначеЕсли ТипЦБ=Перечисления.ТипыЦБ.Пай Тогда
		Результат = "MFUN";
	ИначеЕсли ТипЦБ=Перечисления.ТипыЦБ.ДепозитарнаяРасписка Тогда
		Результат = "RDRP";
	Иначе
		ВызватьИсключение "Ошибка преобразования типа акции "+ТипЦБ;
	КонецЕсли;    
	Возврат Результат;
КонецФункции
Функция Новый_security_category_et(ВидЦБ)
	Если ВидЦБ=Перечисления.ВидыАкций.Обыкновенная Тогда
		Результат = "ORDN";
	ИначеЕсли ВидЦБ=Перечисления.ВидыАкций.Привилегированная Тогда
		Результат = "PREF";
	Иначе
		ВызватьИсключение "Ошибка преобразования вида акции "+ВидЦБ;
	КонецЕсли;    
	Возврат Результат;
КонецФункции

