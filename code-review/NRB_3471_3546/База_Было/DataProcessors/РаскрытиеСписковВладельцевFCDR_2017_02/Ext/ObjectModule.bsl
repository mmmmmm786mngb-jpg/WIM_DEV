Процедура ДобавитьЦБВЗалоге(ВыборкаЦБВЗалоге, РаскрытиеXDTO, ТипОбъектаБлокировки)
	Если ВыборкаЦБВЗалоге.КоличествоВЗалоге>0 Тогда
		Блокировка = ФабрикаXDTO.Создать(ТипОбъектаБлокировки);
		Блокировка.quantity = Новый_quantity_choice_t(ВыборкаЦБВЗалоге.КоличествоВЗалоге);
		Блокировка.block_type.Добавить(Новый_block_type_V03_t(ВыборкаЦБВЗалоге));
		РаскрытиеXDTO.blocked.Добавить(Блокировка);
	КонецЕсли;
КонецПроцедуры

Функция Новый_security_balance_t_v03(Данные)
	ДанныеЕстьБлокировкаЦБ = Ложь;
	ДанныеБлокировкиЦБ = "";
	
	Результат = НовыйОбъектСхемыFCDR("security_balance_t_v03");
	
	Результат.security = Новый_security_info_V3_t(Данные);

	Результат.total = Новый_quantity_choice_t(Данные.Количество);
	
	Если Данные.КоличествоВЗалоге>0 Тогда
		ТипОбъектаБлокировки = ФабрикаXDTO.Тип(ПространствоИмен,"security_balance_t_v03").Свойства.Получить("blocked").Тип;
		Если ВключатьБенефициаров Тогда
			ВыборкаЦБ = Данные.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
			Пока ВыборкаЦБ.Следующий() Цикл
				ВыборкаЦБВЗалоге = ВыборкаЦБ.Выбрать();
				Пока ВыборкаЦБВЗалоге.Следующий() Цикл
					ДобавитьЦБВЗалоге(ВыборкаЦБВЗалоге, Результат, ТипОбъектаБлокировки);
				КонецЦикла;
			КонецЦикла;
		Иначе
			ВыборкаЦБВЗалоге = Данные.Выбрать();
			Пока ВыборкаЦБВЗалоге.Следующий() Цикл
				ДобавитьЦБВЗалоге(ВыборкаЦБВЗалоге, Результат, ТипОбъектаБлокировки);
			КонецЦикла;
		КонецЕсли;
	КонецЕсли;


	Возврат Результат;
КонецФункции

Функция НовыйСтруктураАдреса(АдресПоле1,АдресПоле2,АдресПоле3,АдресПоле4,АдресПоле5,АдресПоле6,АдресПоле7,АдресПоле8,АдресПоле9,ПредставлениеАдреса,СтранаИностранногоАдреса,СтранаРоссия)
	ЗаписьАдреса = Новый Структура("Поле1,Поле2,Поле3,Поле4,Поле5,Поле6,Поле7,Поле8,Поле9",
		АдресПоле1,АдресПоле2,АдресПоле3,АдресПоле4,АдресПоле5,АдресПоле6,АдресПоле7,АдресПоле8,АдресПоле9);
		
	АдресСтрана = Неопределено;
	ПроизвольныйАдрес = (КонтактнаяИнформация.ПолучитьПредставлениеАдреса(ЗаписьАдреса) <> ПредставлениеАдреса);		
	Если ПроизвольныйАдрес Тогда
		АдресСтрана = СтранаИностранногоАдреса;
		АдресИндекс = "";
	Иначе
		АдресСтрана = СтранаРоссия;
		АдресИндекс = АдресПоле1;
	КонецЕсли; 	
	Возврат Новый Структура("Страна,Индекс,Адрес", АдресСтрана,АдресИндекс,ПредставлениеАдреса);
КонецФункции

