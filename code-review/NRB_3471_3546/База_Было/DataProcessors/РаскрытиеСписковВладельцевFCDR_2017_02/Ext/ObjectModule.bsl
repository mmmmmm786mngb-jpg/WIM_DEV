		|	МАКСИМУМ(БенефициарФЛМестоРождения),
		|	МАКСИМУМ(БенефициарФЛДокументТип),
		|	МАКСИМУМ(БенефициарФЛДокументСерия),
		|	МАКСИМУМ(БенефициарФЛДокументНомер),
		|	МАКСИМУМ(БенефициарФЛДокументДатаВыдачи),
		|	МАКСИМУМ(БенефициарФЛДокументКемВыдан),
		|	МАКСИМУМ(БенефициарФЛГражданство),
		
		|	МАКСИМУМ(КлиентУКАдрес),
		|	МАКСИМУМ(КлиентУКАдресПоле1),
		|	МАКСИМУМ(КлиентУКАдресПоле2),
		|	МАКСИМУМ(КлиентУКАдресПоле3),
		|	МАКСИМУМ(КлиентУКАдресПоле4),
		|	МАКСИМУМ(КлиентУКАдресПоле5),
		|	МАКСИМУМ(КлиентУКАдресПоле6),
		|	МАКСИМУМ(КлиентУКАдресПоле7),
		|	МАКСИМУМ(КлиентУКАдресПоле8),
		|	МАКСИМУМ(КлиентУКАдресПоле9),
		|	МАКСИМУМ(КлиентУКСтранаИностранногоАдреса),
		
		|	МАКСИМУМ(ТипСчетаБенефициара),
		|	МАКСИМУМ(ТектовоеОписаниеТипаOTHERБенефициара),
		|	МАКСИМУМ(БенефициарНаименование),";
		
		ГруппировкиИтоговБенефициаров = 
		"	Бенефициар,";

	КонецЕсли;
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса,"&ПоляБенефициаров КАК ПоляБенефициаров,",ПоляБенефициаров);
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса,"ИсточникиБенефициаров КАК ИсточникиБенефициаров",ИсточникиБенефициаров);
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса,"&ИтогиБенефициаров КАК ПоляБенефициаров,",ИтогиБенефициаров);
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса,"&ГруппировкиИтоговБенефициаров,",ГруппировкиИтоговБенефициаров);
КонецПроцедуры
Процедура ВставитьПоляБанковскихРеквизитов(ТекстЗапроса,ВключатьБанковскиеРеквизиты)
	ПоляБанковскихРеквизитов = "";
	ИсточникиБанковскихРеквизитов = "";
	Если ВключатьБанковскиеРеквизиты Тогда
		ПоляБанковскихРеквизитов = 
		"	РСВ.БанковскийСчет.Владелец.Наименование КАК БанкРеквНаименованиеПолучателя,
		|	РСВ.БанковскийСчет.Владелец.АнглийскоеНаименование КАК БанкРеквАнглНаименованиеПолучателя,
		|	АдресОрганизации.Представление КАК БанкРеквАнглАдресПолучателя,
		|	РСВ.БанковскийСчет.Владелец.ИНН КАК БанкРеквИННПолучателя,
		|	РСВ.БанковскийСчет.НомерСчета КАК БанкРеквНомерСчета,
		|	РСВ.БанковскийСчет.Банк.Наименование КАК БанкРеквБанкНаименование,
		|	РСВ.БанковскийСчет.Банк.Город КАК БанкРеквБанкГород,
		|	РСВ.БанковскийСчет.Банк.Код КАК БанкРеквБИК,
		|	РСВ.БанковскийСчет.Банк.SWIFT КАК БанкРеквSWIFT,
		|	РСВ.БанковскийСчет.Банк.КоррСчет КАК БанкРеквКорСчет,
		|	РСВ.БанковскийСчет.ВалютаДенежныхСредств.Наименование КАК БанкРеквВалюта,
		|	ВЫБОР КОГДА ВалютаРегламентированногоУчета.Значение=РСВ.БанковскийСчет.ВалютаДенежныхСредств ТОГДА ИСТИНА ИНАЧЕ ЛОЖЬ КОНЕЦ КАК БанкРеквРублевый,
		|";
		
		ИсточникиБанковскихРеквизитов =
		"
		|ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.КонтактнаяИнформация.СрезПоследних(&Дата, 
		|			(Объект, Тип, Вид) В 
		|				(ВЫБРАТЬ Организация, ЗНАЧЕНИЕ(Перечисление.ТипыКонтактнойИнформации.Адрес), ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ФактАдресОрганизацииEng)
		|				ИЗ Документ.РаскрытиеСпискаВладельцев ГДЕ Ссылка = &ДокументРСВ)
		|		) КАК АдресОрганизации
		|		ПО АдресОрганизации.Объект = РСВ.Организация";

	КонецЕсли;
