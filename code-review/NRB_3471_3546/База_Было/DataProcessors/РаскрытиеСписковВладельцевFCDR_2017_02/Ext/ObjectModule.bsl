Функция Новый_address_V2_t(Адрес_partad=Неопределено, Адрес_plain=Неопределено, АдресСтруктура=Неопределено)
	Результат = НовыйОбъектСхемыFCDR("address_V2_t");
	Если ЗначениеЗаполнено(Адрес_partad) Тогда
		Результат.partad = Новый_address_partad_V02_t(Адрес_partad.Страна, Адрес_partad.Индекс, Адрес_partad.Адрес);
	ИначеЕсли ЗначениеЗаполнено(Адрес_plain) Тогда 
