	Результат = НовыйОбъектСхемыFCDR("organization_id_t");
	
	Если Тип(Документ)=Тип("Массив") Тогда
		Для Каждого Стр Из Документ Цикл
			Результат.organization_id.Добавить(Новый_organization_document_t(Стр));
		КонецЦИкла;
	Иначе
		Результат.organization_id.Добавить(Новый_organization_document_t(Документ));
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ЮрФизЛицо) Тогда
		Результат.legal_entity_indicator = yes_no_t(ЮрФизЛицо=Перечисления.ЮрФизЛицо.ЮрЛицо);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Страна) Тогда
		Результат.country_of_incorporation = string2(Страна);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ДатаРегистрации) Тогда
		Результат.date_of_incorporation = date_t(ДатаРегистрации);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Наименование) Тогда
		Результат.short_name = string350(Наименование);
	КонецЕсли;
	
	Возврат Результат;
