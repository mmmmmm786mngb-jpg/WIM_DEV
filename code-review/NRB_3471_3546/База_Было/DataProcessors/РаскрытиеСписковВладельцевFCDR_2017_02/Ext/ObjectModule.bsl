Функция ВосстановитьНомерРСВ(НомерРСВ, ДатаРСВ)
	ЭкземплярДокументаРаскрытия = Документы.РаскрытиеСпискаВладельцев.СоздатьДокумент();
	ЭкземплярДокументаРаскрытия.Дата = ?(ДатаРСВ = Неопределено, ТекущаяДатаСеанса(), ДатаРСВ);
	Префикс = НумераторыОбъектов.ПолучитьПрефиксНомера(ЭкземплярДокументаРаскрытия);
	ПрефиксТранслит = ОбщегоНазначенияКлиентСервер.Транслит(Префикс);
	
	Если СтрНайти(НомерРСВ,ПрефиксТранслит)>0 Тогда
		Результат = СтрЗаменить(НомерРСВ, ПрефиксТранслит, Префикс);
	Иначе
		Результат = НомерРСВ;
	КонецЕсли;
	
	Если СтрДлина(Результат)<12 Тогда
		Результат = Лев(Результат,8)+"-"+Сред(Результат,9);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Процедура ДобавитьЭлементВоВходящийПакет(ДокСодержимоеФайла,ИмяЭлемента,Элемент,НомерСтроки)
	ТипЗнчЭлемент = ТипЗнч(Элемент);
	Если ТипЗнчЭлемент=Тип("ОбъектXDTO") Тогда
		СвойстваЭлемента = Элемент.Свойства();
		Для Каждого Свойство Из СвойстваЭлемента Цикл
			Если Свойство.ВерхняяГраница=1 Тогда
				ВложенныйЭлемент = Элемент.Получить(Свойство);
			Иначе
				ВложенныйЭлемент = Элемент.ПолучитьСписок(Свойство);
			КонецЕсли;
			ИмяВложенногоЭлемента = ИмяЭлемента;
			Если ИмяВложенногоЭлемента<>"" Тогда
				ИмяВложенногоЭлемента = ИмяВложенногоЭлемента+".";
			КонецЕсли;
			ИмяВложенногоЭлемента = ВРег(ИмяВложенногоЭлемента+Свойство.Имя);
			ДобавитьЭлементВоВходящийПакет(ДокСодержимоеФайла,ИмяВложенногоЭлемента,ВложенныйЭлемент,НомерСтроки);
		КонецЦикла;
	ИначеЕсли ТипЗнчЭлемент=Тип("СписокXDTO") Тогда
		НомерТекущейСтроки = 1;
		Для Каждого Эл Из Элемент Цикл
			СвойстваЭлемента = Эл.Свойства();
			Для Каждого Свойство Из СвойстваЭлемента Цикл
				ИмяВложенногоЭлемента = ИмяЭлемента;
				Если ИмяВложенногоЭлемента<>"" Тогда
					ИмяВложенногоЭлемента = ИмяВложенногоЭлемента+".";
				КонецЕсли;
				ИмяВложенногоЭлемента = ВРег(ИмяВложенногоЭлемента+Свойство.Имя);
				ДобавитьЭлементВоВходящийПакет(ДокСодержимоеФайла,ИмяВложенногоЭлемента,Эл.Получить(Свойство),НомерТекущейСтроки);
			КонецЦикла;
			НомерТекущейСтроки = НомерТекущейСтроки+1;
		КонецЦикла;
	Иначе
		НовСтр = ДокСодержимоеФайла.Добавить();
		НовСтр.Элемент = ИмяЭлемента;
		НовСтр.Значение = Элемент;
		НовСтр.НомерСтрокиФайла = НомерСтроки;
	КонецЕсли;
КонецПроцедуры
Функция СформироватьДокументОтчетОСтатусеРСВ(XMLОтчетНРД, СообщениеОбОшибке) Экспорт
	
	Отказ = Ложь;
	ПространствоИмен = "FCDR_2017_02(2019v3)";
	
	ТипXDTO = ФабрикаXDTO.Тип(ПространствоИмен,"REGISTER_OF_SHAREHOLDERS_STATUS_ADVICE");
	ОтчетНРД = ФабрикаXDTO.ПрочитатьXML(XMLОтчетНРД,ТипXDTO);
	
	НовыйВходящийПакет = Документы.ВходящийПакетИзФайловогоШлюза.СоздатьДокумент();
	ДобавитьЭлементВоВходящийПакет(НовыйВходящийПакет.СодержимоеФайла,"",ОтчетНРД,0);
	СтрНомерРСВ = НовыйВходящийПакет.СодержимоеФайла.Найти("DOC_LINK.DOC_NUM","Элемент");
	НачатьТранзакцию();
	Если СтрНомерРСВ<>Неопределено Тогда
		НомерРСВ = СокрЛП(СтрНомерРСВ.Значение);
		СтрДатаРСВ = НовыйВходящийПакет.СодержимоеФайла.Найти("DOC_LINK.DOC_DATE.DATE","Элемент");
		Если СтрДатаРСВ<>Неопределено Тогда
			ДатаРСВ = ПолучитьДату(СтрДатаРСВ.Значение);
		Иначе
			ДатаРСВ = Неопределено;
		КонецЕсли;
		
		Запрос = Новый Запрос;
		Запрос.Текст =
		"ВЫБРАТЬ
		|	Док.Ссылка КАК Ссылка,
		|	Док.Дата КАК Дата
		|ИЗ
		|	Документ.РаскрытиеСпискаВладельцев КАК Док
		|ГДЕ
		|	Док.Номер = &НомерРСВ
		|	И НЕ Док.ПометкаУдаления
		|	И &УсловиеДатаРСВ";
		Запрос.УстановитьПараметр("НомерРСВ",ВосстановитьНомерРСВ(НомерРСВ, ДатаРСВ));
		Если ЗначениеЗаполнено(ДатаРСВ) Тогда
			УсловиеДатаРСВ = "НАЧАЛОПЕРИОДА(Док.Дата,ДЕНЬ) = &ДатаРСВ";
			Запрос.УстановитьПараметр("ДатаРСВ", НачалоДня(ДатаРСВ));
		Иначе
			УсловиеДатаРСВ = "ИСТИНА";
		КонецЕсли;
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеДатаРСВ", УсловиеДатаРСВ);
		Выборка = Запрос.Выполнить().Выбрать();
		Если Выборка.Следующий() Тогда
			ДокументОснование = Выборка.Ссылка;
			ДатаДокументаОснования = Выборка.Дата;
		Иначе
			ДокументОснование = Неопределено;
			ДатаДокументаОснования = Неопределено;
		КонецЕсли;
		
		Если ЗначениеЗаполнено(ДокументОснование) Тогда
			ТехОперация = Документы.ТехническаяОперация.НайтиДокумент(Новый Структура("ДокументОснование",ДокументОснование));
		Иначе
			ТехОперация = Неопределено;
		КонецЕсли;
		Если НЕ ЗначениеЗаполнено(ТехОперация) Тогда
			ДокументОбъект = Документы.ТехническаяОперация.СоздатьДокумент();
			ДокументОбъект.НомерДокументаОснования = НомерРСВ;
			
			ТекущаяДата = ТекущаяДатаСеанса();
			НовыйПорядковыйНомер = Документы.ТехническаяОперация.НовыйПорядковыйНомерВТечениеДня(ТекущаяДата);
			
			ДокументОбъект = Документы.ТехническаяОперация.СоздатьДокумент();
			ДокументОбъект.Дата = ТекущаяДатаСеанса();
			ДокументОбъект.НомерДокументаОснования = НомерРСВ;
			ДокументОбъект.ДатаДокументаОснования = ДатаДокументаОснования;
			ДокументОбъект.ТипОперации = ТипТехническойОперации();
			ДокументОбъект.КодОперации = КодТехническойОперации();
			ДокументОбъект.ДокументОснование = ДокументОснование;
			ДокументОбъект.ПорядковыйНомерВнутриДня = НовыйПорядковыйНомер;
			ДокументОбъект.Комментарий = "Загрузка входящего пакета REGISTER_OF_SHAREHOLDERS_STATUS_ADVICE";
			ДокументОбъект.УстановитьНовыйНомер();
			ДокументОбъект.Записать(РежимЗаписиДокумента.Проведение);
			
			ТехОперация = ДокументОбъект.Ссылка;
		КонецЕсли;
	КонецЕсли;
	НовыйВходящийПакет.ДокументОснование = ?(ЗначениеЗаполнено(ТехОперация), ТехОперация, Неопределено);
	НовыйВходящийПакет.Дата = ТекущаяДата();
	НовыйВходящийПакет.Записать();
	
	СтрГлобальныйСтатусПроцессинг = НовыйВходящийПакет.СодержимоеФайла.Найти("REGISTER_LIST_STATUS.GLOBAL_STATUS.PROCESSING_STATUS.STATUS.STATUS_CODE","Элемент");
	СтрГлобальныйСтатусОтказКод 			= НовыйВходящийПакет.СодержимоеФайла.Найти("REGISTER_LIST_STATUS.GLOBAL_STATUS.REJECTION_STATUS.REASON.STATUS_CODE","Элемент");
	СтрГлобальныйСтатусОтказСобственныйКод  = НовыйВходящийПакет.СодержимоеФайла.Найти("REGISTER_LIST_STATUS.GLOBAL_STATUS.REJECTION_STATUS.REASON.PROPRIETARY.ID","Элемент");
	Если СтрГлобальныйСтатусПроцессинг<>Неопределено ИЛИ СтрГлобальныйСтатусОтказКод<>Неопределено ИЛИ СтрГлобальныйСтатусОтказСобственныйКод<>Неопределено Тогда
		Обработки.РаскрытиеСписковВладельцевFCDR_2017_02.ОбновитьГлобальныйСтатусДокумента(ДокументОснование);
	Иначе
		Обработки.РаскрытиеСписковВладельцевFCDR_2017_02.ОбновитьДетальныйСтатусДокумента(ДокументОснование);
	КонецЕсли;
	
	ЗафиксироватьТранзакцию();
	
КонецФункции
Функция НовыйДанныеДокументаИННДля_person_document_t(ИНН)
	Возврат Новый Структура("Тип,ОписаниеТипа,Номер,ДатаВыдачи,КемВыдан,МестоВыдачи", "00","TXID",СокрЛП(ИНН),Дата("19000101"),"UKWN","");
КонецФункции

Процедура СформироватьВыпискуИзРеестра(XMLОтчетНРД, ИмяКаталога, СообщениеОбОшибке, Регламент = Ложь, ДокументСоздан = Ложь)
	
	ТекущаяДата = ТекущаяДатаСеанса();
	ИмяРеквизитаЭлемент = "Элемент";
	
	Если Регламент Тогда
		ВнешнийИсточник = ПланыВидовХарактеристик.ВнешниеИсточники.ШлюзНРД;
		ПараметрыИсточника = ВнешниеДанные.ПолучитьПараметрыВнешнегоИсточника(ВнешнийИсточник);
		ПутьАрхива = ПараметрыИсточника.Папка + "\Archive";
		СоздаватьКаталоги = Ложь;
		ПолныйПутьАрхива = Обработки.ЗагрузкаКДИзДепозитария.ОбщийКаталогПеремещаемогоФайлаВАрхив(ПутьАрхива, "W", , СоздаватьКаталоги);
	Иначе
		ПолныйПутьАрхива = Неопределено;
	КонецЕсли;
		
	ТипXDTO = ФабрикаXDTO.Тип(ПространствоИмен, "STATEMENT_OF_HOLDINGS");
	ОтчетНРД = ФабрикаXDTO.ПрочитатьXML(XMLОтчетНРД, ТипXDTO);
	
	НовыйВходящийПакет = Документы.ВходящийПакетИзФайловогоШлюза.СоздатьДокумент();
	ДобавитьЭлементВоВходящийПакет(НовыйВходящийПакет.СодержимоеФайла, "", ОтчетНРД, 0);
	
	ИтогиПоКоличеству = Новый Структура(ИмяРеквизитаЭлемент, "SECURITY_BALANCE.TOTAL.UNITS");
	СтрокиСИтогом = НовыйВходящийПакет.СодержимоеФайла.НайтиСтроки(ИтогиПоКоличеству);
	Для Каждого СтрокаСИтогом Из СтрокиСИтогом Цикл
		СтрокаСИтогом.Значение = СтроковыеФункцииКлиентСервер.ЧислоИзСтроки(СтрокаСИтогом.Значение);
		СтрокаСИтогом.Тип = "N";
	КонецЦикла;
	
	ДатаОстаткаИзВыписки = '00010101';
	ДатыКПреобразованию = Новый Структура(ИмяРеквизитаЭлемент, "STATEMENT_DATE");
	СтрокиСДатами = НовыйВходящийПакет.СодержимоеФайла.НайтиСтроки(ДатыКПреобразованию);
	Для Каждого СтрокаСДатами Из СтрокиСДатами Цикл
		СтрокаСДатами.Значение = XMLЗначение(Тип("Дата"), СтрокаСДатами.Значение);
		СтрокаСДатами.Тип = "D";
		ДатаОстаткаИзВыписки = СтрокаСДатами.Значение;
	КонецЦикла;
	
	СтрокаРегистраторОГРН = НовыйВходящийПакет.СодержимоеФайла.Найти("REGISTRAR.PARTY_DTLS.OGRN", ИмяРеквизитаЭлемент);
	ОГРНРегистратора = ОбщегоНазначенияКлиентСервер.ЗаменитьНедопустимыеСимволыВИмениФайла(СтрокаРегистраторОГРН.Значение, "_");
	НомерГосударственнойРегистрации = СокрЛП(ОГРНРегистратора);
	Если ЗначениеЗаполнено(НомерГосударственнойРегистрации) Тогда
		МХ = Справочники.МестаХранения.НайтиПоРеквизиту("НомерГосударственнойРегистрации", НомерГосударственнойРегистрации);
	КонецЕсли;
	Если ЗначениеЗаполнено(МХ) Тогда
		ИмяРегистратора = СокрЛП(МХ.Наименование);
	Иначе
		СтрокаРегистратор = НовыйВходящийПакет.СодержимоеФайла.Найти("REGISTRAR.PARTY_DTLS.NAME", ИмяРеквизитаЭлемент);
		ИмяРегистратора = СтрокаРегистратор.Значение;
	КонецЕсли;
	
	СтрокаНомерВходящегоДокумента = НовыйВходящийПакет.СодержимоеФайла.Найти("HEADER.DOC_NUM", ИмяРеквизитаЭлемент);
	НомерВходящегоДокумента = СтрокаНомерВходящегоДокумента.Значение;
	НовыйВходящийПакет.НомерВходящегоДокумента = НомерВходящегоДокумента;
	СтрокаДатаВходящегоДокумента = НовыйВходящийПакет.СодержимоеФайла.Найти("HEADER.DOC_DATE.DATE", ИмяРеквизитаЭлемент);
	ДатаВходящегоДокумента = ПолучитьДату(СтрокаДатаВходящегоДокумента.Значение);
	НовыйВходящийПакет.ДатаВходящегоДокумента = ДатаВходящегоДокумента;
	СтрокаДанныеНаДату = НовыйВходящийПакет.СодержимоеФайла.Найти("STATEMENT_DATE", ИмяРеквизитаЭлемент);
	ДанныеНаДату = СтрокаДанныеНаДату.Значение;
	
	СтруктураОтбора = Новый Структура("НомерВходящегоДокумента, ДатаВходящегоДокумента, КодОперации",
		НовыйВходящийПакет.НомерВходящегоДокумента, НовыйВходящийПакет.ДатаВходящегоДокумента, "5RESTR03");
	ВходящийПакетПоИсходящемуНомеру = Документы.ВходящийПакетИзФайловогоШлюза.НайтиДокумент(СтруктураОтбора);
	Если ЗначениеЗаполнено(ВходящийПакетПоИсходящемуНомеру) Тогда
		ИмяСобытия = "Загрузка отчета STATEMENT_OF_HOLDINGS";
		УровеньОшибки = УровеньЖурналаРегистрации.Предупреждение;
		ШаблонСообщения = "Входящий пакет из файлового шлюза [Код операции = 5RESTR03] вх.№ %1 от %2 уже загружен.";
		ТекстСообщения = СтрШаблон(ШаблонСообщения,
			НовыйВходящийПакет.НомерВходящегоДокумента, Формат(НовыйВходящийПакет.ДатаВходящегоДокумента, "ДЛФ=D"));
		ЗаписьЖурналаРегистрации(ИмяСобытия, УровеньОшибки, Метаданные(), , ТекстСообщения);
	Иначе
		НовыйВходящийПакет.КодОперации = "5RESTR03";
		НовыйВходящийПакет.Дата = ТекущаяДата;
		НовыйВходящийПакет.Комментарий = "Создан автоматически в " + Формат(ТекущаяДата, "ДЛФ=DT");
		НовыйВходящийПакет.ПутьАрхив = ПолныйПутьАрхива;
		НовыйВходящийПакет.ОтносительныйПуть = ИмяКаталога;
		
		НовыйВходящий = Документы.Входящий.СоздатьДокумент();
		НовыйВходящий.ДатаОтправления = ДатаВходящегоДокумента;
		НовыйВходящий.Депонент = ОбщегоНазначенияПовтИсп.ОрганизацияПоУмолчанию();
		НовыйВходящий.Исполнитель = ОбщегоНазначенияПовтИсп.ЗначениеКонстанты("ПользовательРобот");
		НовыйВходящий.ИсходящийНомер = НомерВходящегоДокумента;
		СтрокаНомерСчета = НовыйВходящийПакет.СодержимоеФайла.Найти("ACCOUNT_DTLS.ACCOUNT_ID.ID", ИмяРеквизитаЭлемент);
		НовыйВходящий.Комментарий = "Номер счета МХ: " + СтрокаНомерСчета.Значение;
		НовыйВходящий.ЛицоНаправившееДокумент = ИмяРегистратора;
		НовыйВходящий.НаименованиеДокументаИлиКомплекта = "Выписка на дату " + Формат(ДанныеНаДату, "ДФ=""дд.ММ.гггг""");
		НовыйВходящий.Дата = ТекущаяДата;
		
		НачатьТранзакцию();
		Попытка
			НовыйВходящийПакет.Записать(РежимЗаписиДокумента.Проведение);
			НовыйВходящий.ДокументОснование = НовыйВходящийПакет.Ссылка;
			НовыйВходящий.Записать(РежимЗаписиДокумента.Проведение);
			ДокументСоздан = Истина;
			ЗафиксироватьТранзакцию();
		Исключение
			ОтменитьТранзакцию();
			СообщениеОбОшибке = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
			Возврат;
		КонецПопытки;
		
		ОтправитьУведомлениеОПоступленииВыписокОтРегистраторов(ИмяРегистратора, СтрокаНомерСчета.Значение, ДатаОстаткаИзВыписки);
	КонецЕсли;
	
КонецПроцедуры

Процедура ОтправитьУведомлениеОПоступленииВыписокОтРегистраторов(ИмяРегистратора, НомерСчетаМХ, ДатаОстаткаИзВыписки)
	
	ПВХ = ПланыВидовХарактеристик.ВнешниеИсточники.РассылкаУведомленийОПоступленииВыписокОтРегистраторов;
	НастройкиОбмена = ВнешниеДанные.ПолучитьПараметрыВнешнегоИсточника(ПВХ).Настройка;
	
	ТемаПисьма = "Выписка из реестра / Справка на дату / Справка о наличии [" + Формат(ДатаОстаткаИзВыписки, "ДФ=dd.MM.yyyy") + "]";
	ТекстУведомления = "Выписка от регистратора: [" + ИмяРегистратора + "]
	| по счету МХ: [" + НомерСчетаМХ + "]
	| получена.";
	
	ПС = "<br>";
	ОтчетHTML = "<html><BODY>" + Символы.ПС + ТекстУведомления + ПС + Символы.ПС + ПС + Символы.ПС;
	ОтчетHTML = ОтчетHTML + "</BODY></html>";
	
	ПараметрыУведомления = Новый Соответствие;
	ПараметрыУведомления.Вставить("НастройкиОбмена",	НастройкиОбмена);
	ПараметрыУведомления.Вставить("Кодировка",			"UTF-8");
	ПараметрыУведомления.Вставить("ТемаПисьма",			ТемаПисьма);
	ПараметрыУведомления.Вставить("ТекстПисьма",		ОтчетHTML);
	ПараметрыУведомления.Вставить("ТипТекстаПисьма",	ТипТекстаПочтовогоСообщения.HTML);
	ПараметрыУведомления.Вставить("Важность",			ВажностьИнтернетПочтовогоСообщения.Обычная);
	
	РегистрыСведений.УведомленияКОтправке.ДобавитьУведомлениеКотправке(ПараметрыУведомления);
	
КонецПроцедуры

