	ДанныеПричинаОтсутствияИДентификационнойИнформации = "Не предоставлена";
	
	Результат = НовыйОбъектСхемыFCDR("person_dtls_t");
	
	Если ДанныеЕстьИдентификационнаяИнформация Тогда
		ДокументыФизЛица = Новый Массив;
		ДокументыФизЛица.Добавить(НовыйДанныеДокументаДля_person_document_t(Данные.ДокументТип,, Данные.ДокументСерия,Данные.ДокументНомер,, Данные.ДокументДатаВыдачи,Данные.ДокументКемВыдан));
		Если ЗначениеЗаполнено(Данные.ИНН) Тогда
			ДокументыФизЛица.Добавить(НовыйДанныеДокументаИННДля_person_document_t(Данные.ИНН));
		КонецЕсли;
		Результат.person_info = Новый_person_id_t(ДокументыФизЛица,Данные.ДатаРождения,Данные.МестоРождения,Данные.Гражданство);
	Иначе
		Результат.unknown = Новый_unknown_t(ДанныеПричинаОтсутствияИДентификационнойИнформации);
	КонецЕсли;

	Возврат Результат;
КонецФункции

Функция Новый_person_id_t(Документы,ДатаРождения,МестоРождения,Гражданство)
	
	ДанныеДокументы = Новый Массив;
	ДанныеГражданство = "Гражданство";
	ДанныеДатаРождения = Дата("19771201");
	ДанныеМестоРождения = "г. МестоРождения";
	
	Результат = НовыйОбъектСхемыFCDR("person_id_t");
	
	Если ТипЗнч(Документы)=Тип("Массив") Тогда
		Для Каждого Док Из Документы Цикл
			Результат.person_id.Добавить(Новый_person_document_t(Док));
		КонецЦикла;
	Иначе
		Результат.person_id.Добавить(Новый_person_document_t(Документы));
	КонецЕсли;

	Если ЗначениеЗаполнено(Гражданство) Тогда
		Результат.nationality = string150(Гражданство);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ДатаРождения) Тогда
		Результат.birthday = date_t(ДатаРождения);
	КонецЕсли;
	Если ЗначениеЗаполнено(МестоРождения) Тогда
		Результат.birthplace = string150(МестоРождения);
	КонецЕсли;
	
	Возврат Результат;
КонецФункции

Функция Новый_person_document_t(Документ)
	Результат = НовыйОбъектСхемыFCDR("person_document_t");
	
	Результат.person_document_type_code	= Документ.Тип;

	Если Документ.Тип="00" Тогда
		Результат.narrative	= string254(Документ.ОписаниеТипа);
	КонецЕсли;

	Результат.person_doc_num = Новый_document_details_choice_t(Документ);

	Если ЗначениеЗаполнено(Документ.ДатаВыдачи) Тогда
		Результат.doc_date = date_t(Документ.ДатаВыдачи);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Документ.КемВыдан) Тогда
		Результат.org = string150(Документ.КемВыдан);
	КонецЕсли;

	Если ЗначениеЗаполнено(Документ.МестоВыдачи) Тогда
		Результат.place = string150(Документ.МестоВыдачи)
	КонецЕсли;
	
	Возврат Результат;
КонецФункции

