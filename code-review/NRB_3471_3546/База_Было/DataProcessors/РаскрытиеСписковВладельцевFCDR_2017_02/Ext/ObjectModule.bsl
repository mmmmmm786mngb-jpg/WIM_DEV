	Результат.org_doc_num = Новый_document_details_choice_t(Документ);
	
	Если ЗначениеЗаполнено(Документ.Дата) Тогда
		Результат.doc_date = date_t(Документ.Дата);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Документ.ОрганРегистрации) Тогда
		Результат.reg_org = string254(Документ.ОрганРегистрации);
	КонецЕсли;
	
	Возврат Результат;
