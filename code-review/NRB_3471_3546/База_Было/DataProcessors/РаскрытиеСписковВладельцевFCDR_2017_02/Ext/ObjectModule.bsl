Процедура ВставитьПоляБенефициара(ТекстЗапроса,ВключатьБенефициаров)
	ПоляБенефициаров = "Истина КАК ЗаглушкаПоляБенефициаров,";
	ИсточникиБенефициаров = "(ВЫБРАТЬ Истина) КАК ЗаглушкаИсточникиБенефициаров";
	ИтогиБенефициаров = "";
	ГруппировкиИтоговБенефициаров = "";
	Если ВключатьБенефициаров Тогда
			
		ПоляБенефициаров =
		"	СубклиентыУК.Клиент КАК Бенефициар,
		|	СубклиентыУК.Клиент.ИНН КАК БенефициарИНН,
		|	ВЫБОР
		|		КОГДА СубклиентыУК.Клиент ССЫЛКА Справочник.ЮридическиеЛица ТОГДА ЗНАЧЕНИЕ(Перечисление.ЮрФизЛицо.ЮрЛицо)
		|		ИНАЧЕ ЗНАЧЕНИЕ(Перечисление.ЮрФизЛицо.ФизЛицо)
		|	КОНЕЦ КАК БенефициарЮрФизЛицо,
		|	ВЫБОР
		|		КОГДА СубклиентыУК.Клиент.НеРезидент ТОГДА &ИдентификаторНерезидента
		|		ИНАЧЕ &ИдентификаторРезидента
		|	КОНЕЦ КАК БенефициарТипКодаДокумента,
		
		|	ВЫБОР
		|		КОГДА СубклиентыУК.Клиент ССЫЛКА Справочник.ЮридическиеЛица ТОГДА СубклиентыУК.Клиент.Страна.КодАльфа2
		|		ИНАЧЕ ГражданствоУК.Страна.КодАльфа2
		|	КОНЕЦ КАК БенефициарСтрана,
		|	ВЫБОР
		|		КОГДА СубклиентыУК.Клиент.НеРезидент = ИСТИНА ТОГДА СубклиентыУК.Клиент.ДатаГосРегистрации
		|		КОГДА СубклиентыУК.Клиент.ДатаВнесенияВЕГРЮЛ = ДАТАВРЕМЯ(1,1,1) И СубклиентыУК.Клиент.ДатаГосРегистрации >= ДАТАВРЕМЯ(2002,7,1) ТОГДА СубклиентыУК.Клиент.ДатаГосРегистрации
		|		ИНАЧЕ СубклиентыУК.Клиент.ДатаВнесенияВЕГРЮЛ
		|	КОНЕЦ КАК БенефициарДатаДокумента,
		|	СубклиентыУК.Клиент.ОГРН КАК БенефициарНомерДокумента,
		|	СубклиентыУК.Клиент.РегистрирующийОрган КАК БенефициарРегистрирующийОрган,
		|	СубклиентыУК.Клиент.ДатаРождения КАК БенефициарФЛДатаРождения,
		|	СубклиентыУК.Клиент.МестоРождения КАК БенефициарФЛМестоРождения,
		|	ПаспортУК.ДокументВид.КодИМНС КАК БенефициарФЛДокументТип,
		|	ПаспортУК.ДокументСерия КАК БенефициарФЛДокументСерия,
		|	ПаспортУК.ДокументНомер КАК БенефициарФЛДокументНомер,
		|	ПаспортУК.ДокументДатаВыдачи КАК БенефициарФЛДокументДатаВыдачи,
		|	ПаспортУК.ДокументКемВыдан КАК БенефициарФЛДокументКемВыдан,
		|	ГражданствоУК.Страна.КодАльфа2 КАК БенефициарФЛГражданство,
		|	ЕСТЬNULL(РСВ.СчетДепо.ТипСчетаБенефициараFCDR_2017_02.Код,&ПустойТипСчетаБенефициара) КАК ТипСчетаБенефициара,
		|	"""" КАК ТектовоеОписаниеТипаOTHERБенефициара,
		|	ВЫБОР
		|		КОГДА СубклиентыУК.Клиент ССЫЛКА Справочник.ЮридическиеЛица ТОГДА СубклиентыУК.Клиент.ПолноеНаименование
		|		ИНАЧЕ СубклиентыУК.Клиент.Наименование
		|	КОНЕЦ КАК БенефициарНаименование,
		|	КонтактнаяИнформацияУК.Представление КАК КлиентУКАдрес,
		|	КонтактнаяИнформацияУК.Поле1 КАК КлиентУКАдресПоле1,
		|	КонтактнаяИнформацияУК.Поле2 КАК КлиентУКАдресПоле2,
		|	КонтактнаяИнформацияУК.Поле3 КАК КлиентУКАдресПоле3,
		|	КонтактнаяИнформацияУК.Поле4 КАК КлиентУКАдресПоле4,
		|	КонтактнаяИнформацияУК.Поле5 КАК КлиентУКАдресПоле5,
		|	КонтактнаяИнформацияУК.Поле6 КАК КлиентУКАдресПоле6,
		|	КонтактнаяИнформацияУК.Поле7 КАК КлиентУКАдресПоле7,
		|	КонтактнаяИнформацияУК.Поле8 КАК КлиентУКАдресПоле8,
		|	КонтактнаяИнформацияУК.Поле9 КАК КлиентУКАдресПоле9,
		|	СпрСтраныУК.КодАльфа2 КАК КлиентУКСтранаИностранногоАдреса,
		|";
		
		ИсточникиБенефициаров =
		"	ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.Субклиенты КАК СубклиентыУК
		|	ПО РСВ.Клиент.УправляющаяКомпания И НЕ РСВ.Клиент.Субброкер
		|	И СубклиентыУК.Объект = РСВ.Клиент
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.КонтактнаяИнформация.СрезПоследних(&Дата, 
	|			(Объект,Тип,Вид) В
	|				(ВЫБРАТЬ
	|					ЮридическиеФизическиеЛица,
	|					ЗНАЧЕНИЕ(Перечисление.ТипыКонтактнойИнформации.Адрес),
	|					ВЫБОР
	|						КОГДА ЮрФизЛицо=ЗНАЧЕНИЕ(Перечисление.ЮрФизЛицо.ЮрЛицо) ТОГДА ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ФактАдресЮрЛица)
	|						ИНАЧЕ ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ЮрАдресФизЛица)
	|					КОНЕЦ
	|				ИЗ ВТ_ЮрФизЛицаДокументаУК)) КАК КонтактнаяИнформацияУК
	|		ПО (КонтактнаяИнформацияУК.Объект = СубклиентыУК.Клиент)
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.КлассификаторСтранМира КАК СпрСтраныУК
	|		ПО СпрСтраныУК.Наименование = КонтактнаяИнформацияУК.Поле1
	
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ПаспортныеДанныеФизЛиц.СрезПоследних(&Дата, ФизЛицо В (ВЫБРАТЬ ЮридическиеФизическиеЛица ИЗ ВТ_ЮрФизЛицаДокументаУК)) КАК ПаспортУК
	|		ПО СубклиентыУК.Клиент = ПаспортУК.ФизЛицо
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ГражданствоФизЛиц.СрезПоследних(&Дата, ФизЛицо В (ВЫБРАТЬ ЮридическиеФизическиеЛица ИЗ ВТ_ЮрФизЛицаДокументаУК)) КАК ГражданствоУК
	|		ПО СубклиентыУК.Клиент = ГражданствоУК.ФизЛицо";

		ИтогиБенефициаров =
		"	МАКСИМУМ(БенефициарЮрФизЛицо),
		|	МАКСИМУМ(БенефициарИНН),
		|	МАКСИМУМ(БенефициарТипКодаДокумента),
