Функция ЗагрузитьВходящиеДокументы(ФайлыFCDR_2017_02) Экспорт
	Обр = Обработки.РаскрытиеСписковВладельцевFCDR_2017_02.Создать();
	СообщениеОбОшибке = "";
	Результат = Новый Структура;
	Результат.Вставить("Успех", Истина);
	ВходящиеНомераДокументов = Новый Массив;
	Для Каждого Эл Из ФайлыFCDR_2017_02 Цикл
		Попытка
			ТекСообщениеОбОшибке = "";
			ДокументСоздан = Ложь; 
			Регламент = Истина;
			Обр.ЗагрузитьВходящийДокументИзТекста(Эл.ДанныеФайла, ТекСообщениеОбОшибке, Регламент, ДокументСоздан, Эл.Каталог.Имя);
			Если ЗначениеЗаполнено(ТекСообщениеОбОшибке) И НЕ ДокументСоздан Тогда
				СообщениеОбОшибке = СообщениеОбОшибке+Символы.ПС+ТекСообщениеОбОшибке;
			Иначе
				ВходящиеНомераДокументов.Добавить(НомерВхДокумента(Эл.ДанныеФайла));
			КонецЕсли;
		Исключение
			СообщениеОбОшибке = СообщениеОбОшибке+Символы.ПС + "Ошибка загрузки " + Эл.Обработка + ":" + Символы.ПС + ОписаниеОшибки();
		КонецПопытки;
	КонецЦикла;
	Если ЗначениеЗаполнено(СообщениеОбОшибке) Тогда
		ИмяСобытия	= "Загрузка 'Корпоративных действий'";
		ЗаписьЖурналаРегистрации(ИмяСобытия, УровеньЖурналаРегистрации.Ошибка, , , "Ошибка загрузки корпоративных действий DSCL:"+СообщениеОбОшибке);
	КонецЕсли;
	Результат.Вставить("ВходящиеНомераДокументов", ВходящиеНомераДокументов);

	Возврат Результат;
КонецФункции

Функция ВыгрузитьРаскрытиеСпискаВ_ФШ(Документ, ОписаниеОшибки) Экспорт
	Обр = Обработки.РаскрытиеСписковВладельцевFCDR_2017_02.Создать();
	Обр.ДокументРСВ = Документ;
	УКБезВыгодоприобретателей = "";
	Если Обр.ОпределитьШаблонРаскрытия(ОписаниеОшибки) Тогда
		СообщениеВФШНРД = Обр.ВыгрузитьРаскрытиеСписка_FCDR_17_02(ОписаниеОшибки,УКБезВыгодоприобретателей);
		Если НЕ ЗначениеЗаполнено(ОписаниеОшибки) Тогда
			Ошибка = Обр.РезультатФормированияПакета_ФШ(СообщениеВФШНРД, УКБезВыгодоприобретателей);
			Если Ошибка<>Неопределено Тогда
				ОписаниеОшибки = Ошибка.СообщениеПользователю;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
КонецФункции
			
Функция ПолучитьДетальныеСтатусы(РаскрытиеСпискаВладельцев) Экспорт
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	РаскрытиеСпискаВладельцевСписокВладельцев.Ссылка.СтатусFCDRДетальный КАК ТекущийСтатус,
	|	РаскрытиеСпискаВладельцевСписокВладельцев.Договор КАК Договор,
	|	РаскрытиеСпискаВладельцевСписокВладельцев.Выгодоприобретатель КАК Выгодоприобретатель,
	|	ВходящийПакет.Пакет КАК ОтчетОСтатусе,
	|	ВходящийПакет.ДатаПакета КАК ДатаОтчета,
	|	ВходящийПакет.НомерОтчетаНРД КАК НомерОтчетаНРД,
	|	ВходящийПакет.ДатаОтчетаНРД КАК ДатаОтчетаНРД,
	|	ВходящийПакет.Статус КАК Статус,
	|	ВходящийПакет.СтатусОтказДопИнфо КАК СтатусОтказДопИнфо
	|ИЗ
	|	Документ.РаскрытиеСпискаВладельцев.СписокВладельцев КАК РаскрытиеСпискаВладельцевСписокВладельцев
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ОтветСубброкераНаРаскрытие.ДанныеСубброкера КАК ДанныеСубброкера
	|		ПО РаскрытиеСпискаВладельцевСписокВладельцев.ОтветНаРСВ = ДанныеСубброкера.Ссылка
	|			И РаскрытиеСпискаВладельцевСписокВладельцев.Выгодоприобретатель = ДанныеСубброкера.Выгодоприобретатель
	|			И (НЕ РаскрытиеСпискаВладельцевСписокВладельцев.Клиент.УправляющаяКомпания)
	|			И (РаскрытиеСпискаВладельцевСписокВладельцев.Клиент.Субброкер)
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	|			ВходящийПакет.Ссылка КАК Пакет,
	|			ВходящийПакет.Дата КАК ДатаПакета,
	|			ВЫРАЗИТЬ(НомерОтчетаНРД.Значение КАК СТРОКА(35)) КАК НомерОтчетаНРД,
	|			ВЫРАЗИТЬ(ДатаОтчетаНРД.Значение КАК СТРОКА(10)) КАК ДатаОтчетаНРД,
	|			ВЫРАЗИТЬ(ВходящийПакетКодКлиента.Значение КАК СТРОКА(20)) КАК КодКлиента,
	|			ЕСТЬNULL(ЕСТЬNULL(ВЫРАЗИТЬ(ВходящийПакетСтатус.Значение КАК СТРОКА(4)), ВЫРАЗИТЬ(ВходящийПакетСтатусОтказ.Значение КАК СТРОКА(4))), ВЫРАЗИТЬ(ВходящийПакетСтатусОтказСобственныйКод.Значение КАК СТРОКА(35))) КАК Статус,
	|			ВходящийПакетСтатусОтказДопИнфо.Значение КАК СтатусОтказДопИнфо
	|		ИЗ
	|			Документ.ТехническаяОперация КАК ТехническаяОперация
	|				ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ВходящийПакетИзФайловогоШлюза КАК ВходящийПакет
	|				ПО (ВходящийПакет.ДокументОснование = ТехническаяОперация.Ссылка)
	|				ЛЕВОЕ СОЕДИНЕНИЕ Документ.ВходящийПакетИзФайловогоШлюза.СодержимоеФайла КАК НомерОтчетаНРД
	|				ПО (ВходящийПакет.Ссылка = НомерОтчетаНРД.Ссылка)
	|					И (НомерОтчетаНРД.Элемент = ""HEADER.DOC_NUM"")
	|				ЛЕВОЕ СОЕДИНЕНИЕ Документ.ВходящийПакетИзФайловогоШлюза.СодержимоеФайла КАК ДатаОтчетаНРД
	|				ПО (ВходящийПакет.Ссылка = ДатаОтчетаНРД.Ссылка)
	|					И (ДатаОтчетаНРД.Элемент = ""HEADER.DOC_DATE.DATE"")
	|				ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ВходящийПакетИзФайловогоШлюза.СодержимоеФайла КАК ВходящийПакетКодКлиента
	|				ПО (ВходящийПакет.Ссылка = ВходящийПакетКодКлиента.Ссылка)
	|					И (ВходящийПакетКодКлиента.Элемент = ""REGISTER_LIST_STATUS.DETAILED_RECORD_STATUS.SHAREHOLDER_ID"")
	|				ЛЕВОЕ СОЕДИНЕНИЕ Документ.ВходящийПакетИзФайловогоШлюза.СодержимоеФайла КАК ВходящийПакетСтатус
	|				ПО (ВходящийПакет.Ссылка = ВходящийПакетСтатус.Ссылка)
	|					И (ВходящийПакетСтатус.Элемент = ""REGISTER_LIST_STATUS.DETAILED_RECORD_STATUS.RECORD_STATUS_DTLS.PROCESSING_STATUS.STATUS.STATUS_CODE"")
	|					И (ВходящийПакетСтатус.НомерСтрокиФайла = ВходящийПакетКодКлиента.НомерСтрокиФайла)
	|				ЛЕВОЕ СОЕДИНЕНИЕ Документ.ВходящийПакетИзФайловогоШлюза.СодержимоеФайла КАК ВходящийПакетСтатусОтказ
	|				ПО (ВходящийПакет.Ссылка = ВходящийПакетСтатусОтказ.Ссылка)
	|					И (ВходящийПакетСтатусОтказ.Элемент = ""REGISTER_LIST_STATUS.DETAILED_RECORD_STATUS.RECORD_STATUS_DTLS.REJECTION_STATUS.REASON.STATUS_CODE"")
	|					И (ВходящийПакетСтатусОтказ.НомерСтрокиФайла = ВходящийПакетКодКлиента.НомерСтрокиФайла)
	|				ЛЕВОЕ СОЕДИНЕНИЕ Документ.ВходящийПакетИзФайловогоШлюза.СодержимоеФайла КАК ВходящийПакетСтатусОтказСобственныйКод
	|				ПО (ВходящийПакет.Ссылка = ВходящийПакетСтатусОтказСобственныйКод.Ссылка)
	|					И (ВходящийПакетСтатусОтказСобственныйКод.Элемент = ""REGISTER_LIST_STATUS.DETAILED_RECORD_STATUS.RECORD_STATUS_DTLS.REJECTION_STATUS.REASON.PROPRIETARY.ID"")
	|					И (ВходящийПакетСтатусОтказСобственныйКод.НомерСтрокиФайла = ВходящийПакетКодКлиента.НомерСтрокиФайла)
	|				ЛЕВОЕ СОЕДИНЕНИЕ Документ.ВходящийПакетИзФайловогоШлюза.СодержимоеФайла КАК ВходящийПакетСтатусОтказДопИнфо
	|				ПО (ВходящийПакет.Ссылка = ВходящийПакетСтатусОтказДопИнфо.Ссылка)
	|					И (ВходящийПакетСтатусОтказДопИнфо.Элемент = ""REGISTER_LIST_STATUS.DETAILED_RECORD_STATUS.RECORD_STATUS_DTLS.REJECTION_STATUS.ADD_INF"")
	|					И (ВходящийПакетСтатусОтказДопИнфо.НомерСтрокиФайла = ВходящийПакетКодКлиента.НомерСтрокиФайла)
	|		ГДЕ
	|			ТехническаяОперация.ДокументОснование = &РСВ) КАК ВходящийПакет
	|		ПО (ВходящийПакет.КодКлиента = ЕСТЬNULL(ДанныеСубброкера.НомерСчетаДепоКлиента, РаскрытиеСпискаВладельцевСписокВладельцев.Договор.Код))
	|ГДЕ
	|	РаскрытиеСпискаВладельцевСписокВладельцев.Ссылка = &РСВ
	|
	|УПОРЯДОЧИТЬ ПО
	|	ДатаОтчетаНРД УБЫВ,
	|	ДатаОтчета УБЫВ
	|ИТОГИ
	|	МАКСИМУМ(ТекущийСтатус)
	|ПО
	|	Договор,
	|	Выгодоприобретатель";
	
	Запрос.УстановитьПараметр("РСВ",РаскрытиеСпискаВладельцев);
	Возврат Запрос.Выполнить().Выгрузить(ОбходРезультатаЗапроса.ПоГруппировкам);
	
КонецФункции

Функция ПолучитьГлобальныйСтатус(РаскрытиеСпискаВладельцев) Экспорт
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	РСВ.СтатусFCDRГлобальный КАК ТекущийСтатус,
	|	ВходящийПакет.Ссылка КАК Пакет,
	|	ВходящийПакет.Дата КАК ДатаОтчета,
	|	ВЫРАЗИТЬ(НомерОтчетаНРД.Значение КАК СТРОКА(35)) КАК НомерОтчетаНРД,
	|	ВЫРАЗИТЬ(ДатаОтчетаНРД.Значение КАК СТРОКА(10)) КАК ДатаОтчетаНРД,
	|	ЕСТЬNULL(ЕСТЬNULL(ВЫРАЗИТЬ(ВходящийПакетСтатус.Значение КАК СТРОКА(4)), ВЫРАЗИТЬ(ВходящийПакетСтатусОтказ.Значение КАК СТРОКА(4))), ВЫРАЗИТЬ(ВходящийПакетСтатусОтказСобственныйКод.Значение КАК СТРОКА(35))) КАК Статус,
	|	ВходящийПакетСтатусОтказДопИнфо.Значение КАК СтатусОтказДопИнфо
	|ИЗ
	|	Документ.РаскрытиеСпискаВладельцев КАК РСВ
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ТехническаяОперация КАК ТехническаяОперация
	|		ПО (ТехническаяОперация.ДокументОснование = &РСВ)
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ВходящийПакетИзФайловогоШлюза КАК ВходящийПакет
	|		ПО (ВходящийПакет.ДокументОснование = ТехническаяОперация.Ссылка)
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ВходящийПакетИзФайловогоШлюза.СодержимоеФайла КАК НомерОтчетаНРД
	|		ПО (ВходящийПакет.Ссылка = НомерОтчетаНРД.Ссылка)
	|			И (НомерОтчетаНРД.Элемент = ""HEADER.DOC_NUM"")
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ВходящийПакетИзФайловогоШлюза.СодержимоеФайла КАК ДатаОтчетаНРД
	|		ПО (ВходящийПакет.Ссылка = ДатаОтчетаНРД.Ссылка)
	|			И (ДатаОтчетаНРД.Элемент = ""HEADER.DOC_DATE.DATE"")
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ВходящийПакетИзФайловогоШлюза.СодержимоеФайла КАК ВходящийПакетСтатус
	|		ПО (ВходящийПакет.Ссылка = ВходящийПакетСтатус.Ссылка)
	|			И (ВходящийПакетСтатус.Элемент = ""REGISTER_LIST_STATUS.GLOBAL_STATUS.PROCESSING_STATUS.STATUS.STATUS_CODE"")
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ВходящийПакетИзФайловогоШлюза.СодержимоеФайла КАК ВходящийПакетСтатусОтказ
	|		ПО (ВходящийПакет.Ссылка = ВходящийПакетСтатусОтказ.Ссылка)
	|			И (ВходящийПакетСтатусОтказ.Элемент = ""REGISTER_LIST_STATUS.GLOBAL_STATUS.REJECTION_STATUS.REASON.STATUS_CODE"")
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ВходящийПакетИзФайловогоШлюза.СодержимоеФайла КАК ВходящийПакетСтатусОтказСобственныйКод
	|		ПО (ВходящийПакет.Ссылка = ВходящийПакетСтатусОтказСобственныйКод.Ссылка)
	|			И (ВходящийПакетСтатусОтказСобственныйКод.Элемент = ""REGISTER_LIST_STATUS.GLOBAL_STATUS.REJECTION_STATUS.REASON.PROPRIETARY.ID"")
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ВходящийПакетИзФайловогоШлюза.СодержимоеФайла КАК ВходящийПакетСтатусОтказДопИнфо
	|		ПО (ВходящийПакет.Ссылка = ВходящийПакетСтатусОтказДопИнфо.Ссылка)
	|			И (ВходящийПакетСтатусОтказДопИнфо.Элемент = ""REGISTER_LIST_STATUS.GLOBAL_STATUS.REJECTION_STATUS.ADD_INF"")
	|ГДЕ
	|	РСВ.Ссылка = &РСВ
	|
	|УПОРЯДОЧИТЬ ПО
	|	ДатаОтчетаНРД УБЫВ,
	|	ДатаОтчета УБЫВ";
	Запрос.УстановитьПараметр("РСВ",РаскрытиеСпискаВладельцев);
	Возврат Запрос.Выполнить().Выгрузить();
	
КонецФункции

Функция ОбновитьГлобальныйСтатусДокумента(ДокРаскрытиеСпискаВладельцев) Экспорт
	Статусы = Обработки.РаскрытиеСписковВладельцевFCDR_2017_02.ПолучитьГлобальныйСтатус(ДокРаскрытиеСпискаВладельцев);
	Если Статусы.Количество()>0 Тогда
		Статус = Статусы[0].Статус;
		Если Статус<>Статусы[0].ТекущийСтатус Тогда
			Док = ДокРаскрытиеСпискаВладельцев.ПолучитьОбъект();
			Док.СтатусFCDRГлобальный = Статус;
			Док.Записать();
		КонецЕсли;
	КонецЕсли;	
КонецФункции

Функция ОбновитьДетальныйСтатусДокумента(ДокРаскрытиеСпискаВладельцев) Экспорт
	Статусы = Обработки.РаскрытиеСписковВладельцевFCDR_2017_02.ПолучитьДетальныеСтатусы(ДокРаскрытиеСпискаВладельцев);
	
	Если Статусы.Строки.Количество()>0 Тогда
		ЕстьОтказ = Ложь;
		Статус = Неопределено;
		Для Каждого СтрДоговор Из Статусы.Строки Цикл
			Для Каждого СтрВыгодоприобретатель ИЗ СтрДоговор.Строки Цикл
				Если Статус=Неопределено Тогда
					Статус = СтрВыгодоприобретатель.Строки[0].Статус;
				ИначеЕсли Статус<>СтрВыгодоприобретатель.Строки[0].Статус Тогда
					Статус = "...";
				КонецЕсли;
				ЕстьОтказ = ЕстьОтказ ИЛИ СтрВыгодоприобретатель.Строки[0].Статус="RJCT";
			КонецЦИкла;
		КонецЦикла;
		
		Если ЕстьОтказ Тогда
			Статус = "RJCT";
		КонецЕсли;
	
		Если Статус<>Статусы.Строки[0].ТекущийСтатус Тогда
			Док = ДокРаскрытиеСпискаВладельцев.ПолучитьОбъект();
			Док.СтатусFCDRДетальный = Статус;
			Док.Записать();
		КонецЕсли;
	КонецЕсли;
	
КонецФункции

Функция НомерВхДокумента(ФайлFCDR_2017_02)
	
	Номер = "";
	ЧтениеXML = Новый ЧтениеXML;
	ЧтениеXML.УстановитьСтроку(ФайлFCDR_2017_02);
	Если ЧтениеXML.Прочитать() Тогда
		ПространствоИмен = "FCDR_2017_02(2019v3)";
		ТипXDTO = ФабрикаXDTO.Тип(ПространствоИмен,"DISCLOSURE_REQUEST");
		РезультатЧтения = ФабрикаXDTO.ПрочитатьXML(ЧтениеXML, ТипXDTO);
		Номер = РезультатЧтения.header.doc_num;
	КонецЕсли;
	
	Возврат Номер;
	
КонецФункции