
Процедура ПодготовитьУведомленияОИсполненииОперацииЦБ(ПредыдущийДень = Ложь) Экспорт
	
	Данные.Очистить();
	Если Не ЗначениеЗаполнено(ОсновнаяНастройкаОтправкиУведомлений) Тогда
		ОписаниеОшибки = "Не заполнены параметры внешнего источника '"+ПланыВидовХарактеристик.ВнешниеИсточники.РассылкаУведомленийОИсполненииПорученийНаОперацииСЦБ+"'";
		ЗаписьЖурналаРегистрации("Уведомление о исполнении поручений на операции с ЦБ", УровеньЖурналаРегистрации.Ошибка,,,ОписаниеОшибки);
		Возврат;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(НастройкаОтправкиУведомленийОСписанииЦБПоФл) Тогда
		ОписаниеОшибки = "Не заполнены параметры внешнего источника '"+ПланыВидовХарактеристик.ВнешниеИсточники.РассылкаУведомленийОИсполненииПорученийНаОперацииСЦБ+"'";
		ЗаписьЖурналаРегистрации("Уведомление о исполнении поручений на операции с ЦБ", УровеньЖурналаРегистрации.Ошибка,,,ОписаниеОшибки);
		Возврат;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = ТекстЗапросаДляПодготовкиУведомлений();
	Запрос.УстановитьПараметр("Перевод", Справочники.ВидыОпераций.Перевод);
	Запрос.УстановитьПараметр("ЗаПредыдущийДень", ПредыдущийДень);
	Запрос.УстановитьПараметр("ДатаТекущийДень", НачалоДня(ТекущаяДата()));
	РезультатЗапроса = Запрос.Выполнить();
	Выборка = РезультатЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Пока Выборка.Следующий() Цикл
		
		ВидОперации = Выборка.ВидОперации;
		ТекущиеНастройкиОтправки = ОсновнаяНастройкаОтправкиУведомлений;
		ПереносСтроки = Символы.ПС + "<br>";
		Если ВидОперации = Справочники.ВидыОпераций.СнятиеСДепонирования Тогда
			ТемаПисьма = "Cписаны ЦБ";
			Если Выборка.ЮрФизЛицо = Перечисления.ЮрФизЛицо.ФизЛицо Тогда
				ТекущиеНастройкиОтправки = НастройкаОтправкиУведомленийОСписанииЦБПоФл;
			КонецЕсли;
			ТекстПисьма = ТекстПисьмаДляСписанияЗачисленияЦБ(Выборка, ПереносСтроки);
		ИначеЕсли ВидОперации = Справочники.ВидыОпераций.Депонирование Тогда
			ТемаПисьма = "Зачислены ЦБ";
			ТекстПисьма = ТекстПисьмаДляСписанияЗачисленияЦБ(Выборка, ПереносСтроки);
		ИначеЕсли ВидОперации = Справочники.ВидыОпераций.Перевод Тогда
			ТемаПисьма = "Перевод ЦБ между договорами клиентов (без движения в м/х)";
			ТекстПисьма = ТекстПисьмаДляПереводаЦБ(Выборка, ПереносСтроки);
			Если Выборка.ЮрФизЛицо = Перечисления.ЮрФизЛицо.ФизЛицо Тогда
				ТекущиеНастройкиОтправки = НастройкаОтправкиУведомленийОСписанииЦБПоФл;
			КонецЕсли;
		ИначеЕсли ВидОперации = Справочники.ВидыОпераций.ПереводМеждуРазделамиСчетаДепо Тогда
			ТемаПисьма = "Перевод ЦБ внутри одного счета депо (+ изменение места хранения)";
			ТекстПисьма = ТекстПисьмаДляПереводовВнутриОдногоСчета(Выборка, ПереносСтроки);
		ИначеЕсли ВидОперации = Справочники.ВидыОпераций.Перемещение Тогда
			ТемаПисьма = "Перевод ЦБ между счетами одного клиента (изменение места хранения)";
			ТекстПисьма = ТекстПисьмаДляПеремещений(Выборка, ПереносСтроки);
		КонецЕсли;
		
		НоваяСтрока = Данные.Добавить();
		НоваяСтрока.Поручение = Выборка.Поручение;
		НоваяСтрока.ВстречноеПоручение = Выборка.ВстречноеПоручение;
		НоваяСтрока.Депонент = Выборка.Депонент;
		НоваяСтрока.ТемаПисьма = ТемаПисьма;
		НоваяСтрока.НастройкаОтправки = ТекущиеНастройкиОтправки;
		НоваяСтрока.ТекстПисьма = ТекстПисьма;
		
	КонецЦикла;
	
КонецПроцедуры

Процедура СформироватьПодготовленныеУведомления() Экспорт
	
	ГруппировкиОбхода = Данные.Выгрузить();
	ГруппировкиОбхода.Свернуть("Депонент, ТемаПисьма, НастройкаОтправки");
	Для Каждого ГруппировкаОбхода Из ГруппировкиОбхода Цикл
		
		Отбор = Новый Структура;
		Отбор.Вставить("Депонент", ГруппировкаОбхода.Депонент);
		Отбор.Вставить("ТемаПисьма", ГруппировкаОбхода.ТемаПисьма);
		Отбор.Вставить("НастройкаОтправки", ГруппировкаОбхода.НастройкаОтправки);
		СтрокиПоГруппировке = Данные.НайтиСтроки(Отбор);
		
		ДатаФормирования = ТекущаяДата();
		ТекстПисьма = "";
		НачатьТранзакцию();
		Попытка
			
			Для Каждого Стр Из СтрокиПоГруппировке Цикл
				
				Если Не ПустаяСтрока(ТекстПисьма) Тогда
					ТекстПисьма = ТекстПисьма + Символы.ПС + "<br>" + Символы.ПС + "<br>";
				КонецЕсли;
				
				ТекстПисьма = ТекстПисьма + Стр.ТекстПисьма;
				
				ЗаписатьСостояниеПодготовленДляПоручения(Стр.Поручение, ДатаФормирования);
				Если ЗначениеЗаполнено(Стр.ВстречноеПоручение) Тогда
					ЗаписатьСостояниеПодготовленДляПоручения(Стр.ВстречноеПоручение, ДатаФормирования);
				КонецЕсли;
				
			КонецЦикла;
			
			ПараметрыУведомления = Новый Соответствие;
			ПараметрыУведомления.Вставить("НастройкиОбмена"	, ГруппировкаОбхода.НастройкаОтправки);
			ПараметрыУведомления.Вставить("ТемаПисьма"		, ГруппировкаОбхода.ТемаПисьма);
			ПараметрыУведомления.Вставить("ТекстПисьма"		, ТекстПисьма);
			ПараметрыУведомления.Вставить("ТипТекстаПисьма"	, ТипТекстаПочтовогоСообщения.HTML);
			ПараметрыУведомления.Вставить("Кодировка"		, "UTF-8");
			ПараметрыУведомления.Вставить("Важность"		, ВажностьИнтернетПочтовогоСообщения.Обычная);
			РегистрыСведений.УведомленияКОтправке.ДобавитьУведомлениеКотправке(ПараметрыУведомления);
			
			ЗафиксироватьТранзакцию();
		Исключение
			ОтменитьТранзакцию();
			ВызватьИсключение;
		КонецПопытки;
		
	КонецЦикла;
	Данные.Очистить();
	
КонецПроцедуры

Процедура ПолучитьПараметрыВнешнихИсточников() Экспорт
	
	ОсновнаяНастройкаОтправкиУведомлений = ВнешниеДанные.ПолучитьПараметрыВнешнегоИсточника(ПланыВидовХарактеристик.ВнешниеИсточники.РассылкаУведомленийОИсполненииПорученийНаОперацииСЦБ).Настройка;
	НастройкаОтправкиУведомленийОСписанииЦБПоФл = ВнешниеДанные.ПолучитьПараметрыВнешнегоИсточника(ПланыВидовХарактеристик.ВнешниеИсточники.РассылкаУведомленийОИсполненииПорученийНаСписаниеЦБПоФЛ).Настройка;

КонецПроцедуры

Функция ТекстЗапросаДляПодготовкиУведомлений()
	
	Возврат
	"ВЫБРАТЬ
	|	СостоянияУведомленийОбОперацияхСЦБ.Поручение КАК ДокументПоручение
	|ПОМЕСТИТЬ НеподготовленныеУведомления
	|ИЗ
	|	РегистрСведений.СостоянияУведомленийОбОперацияхСЦБ КАК СостоянияУведомленийОбОперацияхСЦБ
	|ГДЕ
	|	НЕ СостоянияУведомленийОбОперацияхСЦБ.Подготовлено
	|	И ВЫБОР
	|			КОГДА &ЗаПредыдущийДень
	|				ТОГДА СостоянияУведомленийОбОперацияхСЦБ.Поручение.Дата < &ДатаТекущийДень
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Поручение.СчетДепоМХ КАК СчетДепоМХ,
	|	Поручение.СчетДепоМХКонтрагента КАК СчетДепоМХКонтрагента,
	|	Поручение.Депонент.Код КАК КодДепонента,
	|	Поручение.Контрагент.Код КАК КодКонтрагента,
	|	Поручение.РазделСчетаДепоМХ.Код КАК РазделСчетаДепоМХ,
	|	Поручение.РазделСчетаДепоМХКонтрагента.Код КАК РазделСчетаДепоМХКонтрагента,
	|	Поручение.РазделСчетаДепо.Код КАК РазделСчетаДепо,
	|	Поручение.РазделСчетаДепоКонтрагента.Код КАК РазделСчетаДепоКонтрагента,
	|	Поручение.СчетДепо КАК СчетДепо,
	|	Поручение.СчетДепоКонтрагента КАК СчетДепоКонтрагента,
	|	ПоручениеЦенныеБумагиСписываемые.ЦеннаяБумага.ISIN КАК ISIN,
	|	ПоручениеЦенныеБумагиСписываемые.Количество КАК КоличествоЦБ,
	|	ПоручениеЦенныеБумагиСписываемые.ЦеннаяБумага.Представление КАК ЦБПредставление,
	|	Поручение.Ссылка КАК Поручение,
	|	Поручение.Депонент КАК Депонент,
	|	Поручение.Контрагент КАК Контрагент,
	|	Поручение.ВидОперацииД КАК ВидОперации,
	|	Поручение.Депонент.ЮрФизЛицо КАК ЮрФизЛицо,
	|	Поручение.Номер КАК НомерПоручения,
	|	Поручение.Дата КАК ДатаПоручения,
	|	Поручение.ДатаИсполненияПоручения КАК ДатаИсполненияПоручения,
	|	Поручение.ИсточникЗагрузки КАК ИсточникЗагрузки,
	|	ЗНАЧЕНИЕ(Документ.Поручение.ПустаяСсылка) КАК ВстречноеПоручение,
	|	ДАТАВРЕМЯ(1, 1, 1) КАК ДатаВстречногоПоручения,
	|	"""" КАК НомерВстречногоПоручения
	|ИЗ
	|	НеподготовленныеУведомления КАК НеподготовленныеУведомления
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.Поручение КАК Поручение
	|			ЛЕВОЕ СОЕДИНЕНИЕ Документ.Поручение.ЦенныеБумагиСписываемые КАК ПоручениеЦенныеБумагиСписываемые
	|			ПО Поручение.Ссылка = ПоручениеЦенныеБумагиСписываемые.Ссылка
	|		ПО НеподготовленныеУведомления.ДокументПоручение = Поручение.Ссылка
	|ГДЕ
	|	Поручение.Ссылка ЕСТЬ НЕ NULL 
	|	И Поручение.ВидОперацииД <> &Перевод
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	Поручение.СчетДепоМХ,
	|	Поручение.СчетДепоМХКонтрагента,
	|	Поручение.Депонент.Код,
	|	Поручение.Контрагент.Код,
	|	Поручение.РазделСчетаДепоМХ.Код,
	|	Поручение.РазделСчетаДепоМХКонтрагента.Код,
	|	Поручение.РазделСчетаДепо.Код,
	|	Поручение.РазделСчетаДепоКонтрагента.Код,
	|	Поручение.СчетДепо,
	|	Поручение.СчетДепоКонтрагента,
	|	Поручение.ЦБ.ISIN,
	|	Поручение.КоличествоЦБ,
	|	Поручение.ЦБ.Представление,
	|	Поручение.Ссылка,
	|	Поручение.Депонент,
	|	Поручение.Контрагент,
	|	Поручение.ВидОперацииД,
	|	Поручение.Депонент.ЮрФизЛицо,
	|	Поручение.Номер,
	|	Поручение.Дата,
	|	Поручение.ДатаИсполненияПоручения КАК ДатаИсполненияПоручения,
	|	Поручение.ИсточникЗагрузки КАК ИсточникЗагрузки,
	|	ОперацииЦБ.ДокументОснованиеВстречный,
	|	ОперацииЦБ.ДокументОснованиеВстречный.Дата,
	|	ОперацииЦБ.ДокументОснованиеВстречный.Номер
	|ИЗ
	|	НеподготовленныеУведомления КАК НеподготовленныеУведомления
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.Поручение КАК Поручение
	|		ПО НеподготовленныеУведомления.ДокументПоручение = Поручение.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ОперацииЦБ КАК ОперацииЦБ
	|		ПО НеподготовленныеУведомления.ДокументПоручение = ОперацииЦБ.ДокументОснование
	|			И (ОперацииЦБ.ДокументОснование = Поручение.Ссылка)
	|			И (ОперацииЦБ.Проведен)
	|ГДЕ
	|	Поручение.Ссылка ЕСТЬ НЕ NULL 
	|	И Поручение.ВидОперацииД = &Перевод
	|	И ОперацииЦБ.Ссылка ЕСТЬ НЕ NULL 
	|
	|УПОРЯДОЧИТЬ ПО
	|	Депонент,
	|	ВидОперации,
	|	ДатаПоручения
	|ИТОГИ
	|	МАКСИМУМ(СчетДепоМХ),
	|	МАКСИМУМ(СчетДепоМХКонтрагента),
	|	МАКСИМУМ(КодДепонента),
	|	МАКСИМУМ(КодКонтрагента),
	|	МАКСИМУМ(РазделСчетаДепоМХ),
	|	МАКСИМУМ(РазделСчетаДепоМХКонтрагента),
	|	МАКСИМУМ(РазделСчетаДепо),
	|	МАКСИМУМ(РазделСчетаДепоКонтрагента),
	|	МАКСИМУМ(СчетДепо),
	|	МАКСИМУМ(СчетДепоКонтрагента),
	|	МАКСИМУМ(Депонент),
	|	МАКСИМУМ(Контрагент),
	|	МАКСИМУМ(ВидОперации),
	|	МАКСИМУМ(ЮрФизЛицо),
	|	МАКСИМУМ(НомерПоручения),
	|	МАКСИМУМ(ДатаПоручения),
	|	МАКСИМУМ(ДатаИсполненияПоручения),
	|	МАКСИМУМ(ИсточникЗагрузки),
	|	МАКСИМУМ(ВстречноеПоручение),
	|	МАКСИМУМ(ДатаВстречногоПоручения),
	|	МАКСИМУМ(НомерВстречногоПоручения)
	|ПО
	|	Поручение";
	
КонецФункции

Функция ТекстПисьмаДляСписанияЗачисленияЦБ(Выборка, ПереносСтроки)
	
	ТекстПисьма = 
	"На основании поручения %НомерПоручения от %ДатаПоручения клиента %КодКлиента" + ПереносСтроки
	+ "%ТипОперации ценные бумаги" + ПереносСтроки
	+ "Источник загрузки %ИсточникЗагрузки" + ПереносСтроки
	+ "Счет депо места хранения %СчетДепоМХ" + ПереносСтроки
	+ "Раздел счета депо места хранения %РазделСчетаДепоМХ" + ПереносСтроки
	+ "Счет депо клиента %СчетДепо" + ПереносСтроки
	+ "Раздел счета депо клиента %РазделСчетаДепо" + ПереносСтроки
	+ "%ДанныеЦБ";
	ТекстПисьма = СтрЗаменить(ТекстПисьма, "%НомерПоручения", СокрЛП(Выборка.НомерПоручения));
	ТекстПисьма = СтрЗаменить(ТекстПисьма, "%ДатаПоручения", СокрЛП(Выборка.ДатаПоручения));
	ТекстПисьма = СтрЗаменить(ТекстПисьма, "%КодКлиента", СокрЛП(Выборка.КодДепонента));
	ТекстПисьма = СтрЗаменить(ТекстПисьма, "%ТипОперации", ?(Выборка.ВидОперации = Справочники.ВидыОпераций.СнятиеСДепонирования, "Списаны", "Зачислены"));
	Если ЗначениеЗаполнено(Выборка.ИсточникЗагрузки) Тогда
		ТекстПисьма = СтрЗаменить(ТекстПисьма, "%ИсточникЗагрузки", СокрЛП(Выборка.ИсточникЗагрузки));
	Иначе 
		ТекстПисьма = СтрЗаменить(ТекстПисьма, "%ИсточникЗагрузки", "Нет");
	КонецЕсли;
	ТекстПисьма = СтрЗаменить(ТекстПисьма, "%СчетДепоМХ", СокрЛП(Выборка.СчетДепоМХ));
	ТекстПисьма = СтрЗаменить(ТекстПисьма, "%РазделСчетаДепоМХ", СокрЛП(Выборка.РазделСчетаДепоМХ));
	ТекстПисьма = СтрЗаменить(ТекстПисьма, "%СчетДепо", СокрЛП(Выборка.СчетДепо));
	ТекстПисьма = СтрЗаменить(ТекстПисьма, "%РазделСчетаДепо", СокрЛП(Выборка.РазделСчетаДепо));
	ТекстПисьма = СтрЗаменить(ТекстПисьма, "%ДанныеЦБ", ТекстДанныеЦБ(Выборка, ПереносСтроки));
	
	Возврат ТекстПисьма;
	
КонецФункции

Функция ТекстПисьмаДляПереводаЦБ(Выборка, ПереносСтроки)
	
	ТекстПисьма =
	"На основании поручений клиентов %НомерПоручения от %ДатаПоручения и %НомерВстречногоПоручения от %ДатаВстречногоПоручения осуществлён" + ПереносСтроки +
	"перевод ЦБ между договорами клиентов %КодКлиентаИсточник и %КодКлиентаПриемник (без движения в м/х):" + ПереносСтроки +
	"Счет депо места хранения (списание ЦБ) %СчетДепоМХИсточник" + ПереносСтроки +
	"Счет депо места хранения (зачисление ЦБ) %СчетДепоМХПриемник" + ПереносСтроки +
	"Раздел счета депо места хранения (списание ЦБ) %РазделСчетаДепоМХИсточник" + ПереносСтроки +
	"Раздел счета депо места хранения (зачисление ЦБ) %РазделСчетаДепоМХПриемник" + ПереносСтроки +
	"Счет депо клиента (списание ЦБ) %СчетДепоИсточник" + ПереносСтроки +
	"Счет депо клиента (зачисление ЦБ) %СчетДепоПриемник" + ПереносСтроки +
	"%ДанныеЦБ" +
	"%ТекстTAX";
	ТекстПисьма = СтрЗаменить(ТекстПисьма, "%НомерПоручения", СокрЛП(Выборка.НомерПоручения));
	ТекстПисьма = СтрЗаменить(ТекстПисьма, "%ДатаПоручения", СокрЛП(Выборка.ДатаПоручения));
	ТекстПисьма = СтрЗаменить(ТекстПисьма, "%НомерВстречногоПоручения", СокрЛП(Выборка.НомерВстречногоПоручения));
	ТекстПисьма = СтрЗаменить(ТекстПисьма, "%ДатаВстречногоПоручения", СокрЛП(Выборка.ДатаВстречногоПоручения));
	ТекстПисьма = СтрЗаменить(ТекстПисьма, "%КодКлиентаИсточник", СокрЛП(Выборка.КодДепонента));
	ТекстПисьма = СтрЗаменить(ТекстПисьма, "%КодКлиентаПриемник", СокрЛП(Выборка.КодКонтрагента));
	ТекстПисьма = СтрЗаменить(ТекстПисьма, "%СчетДепоМХИсточник", СокрЛП(Выборка.СчетДепоМХ));
	ТекстПисьма = СтрЗаменить(ТекстПисьма, "%СчетДепоМХПриемник", СокрЛП(Выборка.СчетДепоМХКонтрагента));
	ТекстПисьма = СтрЗаменить(ТекстПисьма, "%РазделСчетаДепоМХИсточник", СокрЛП(Выборка.РазделСчетаДепоМХ));
	ТекстПисьма = СтрЗаменить(ТекстПисьма, "%РазделСчетаДепоМХПриемник", СокрЛП(Выборка.РазделСчетаДепоМХКонтрагента));
	ТекстПисьма = СтрЗаменить(ТекстПисьма, "%СчетДепоИсточник", СокрЛП(Выборка.СчетДепо));
	ТекстПисьма = СтрЗаменить(ТекстПисьма, "%СчетДепоПриемник", СокрЛП(Выборка.СчетДепоКонтрагента));
	ТекстПисьма = СтрЗаменить(ТекстПисьма, "%ДанныеЦБ", ТекстДанныеЦБ(Выборка, ПереносСтроки));
	
	Если Выборка.ЮрФизЛицо = Перечисления.ЮрФизЛицо.ФизЛицо Тогда
		ТекстTAX = 
		"ЦБ списаны без подтверждения налога, в 1С ИЦ налог исчислен и ожидает подтверждения от TAX dpt на уплату в бюджет." + ПереносСтроки +
		"Для уплаты налога применяем срок, установленный законодательством – 1 месяц.";
		ТекстПисьма = СтрЗаменить(ТекстПисьма, "%ТекстTAX", ПереносСтроки + ТекстTAX);
	Иначе
		ТекстПисьма = СтрЗаменить(ТекстПисьма, "%ТекстTAX", "");
	КонецЕсли;

	Возврат ТекстПисьма;
	
КонецФункции

