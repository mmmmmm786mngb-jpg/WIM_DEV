Процедура ЗаписатьСостояниеПодготовленДляПоручения(Поручение, ДатаПодготовки);
	
	Запись = РегистрыСведений.СостоянияУведомленийОбОперацияхСЦБ.СоздатьМенеджерЗаписи();
	Запись.Поручение = Поручение;
	Запись.Подготовлено = Истина;
	Запись.ДатаПодготовлено = ДатаПодготовки;
	Запись.Записать();
	
КонецПроцедуры

Функция ТекстДанныеЦБ(Выборка, ПереносСтроки)
	ТекстДанныеЦБ = "";
	ДанныеЦБ = Выборка.Выбрать();
	Пока ДанныеЦБ.Следующий() Цикл
		ТекстДанныеЦБ = ТекстДанныеЦБ + ?(ПустаяСтрока(ТекстДанныеЦБ), "", ПереносСтроки)
		+ СтрШаблон("ISIN %1, %2; Количество ценных бумаг %3",
		СокрЛП(ДанныеЦБ.ISIN), СокрЛП(ДанныеЦБ.ЦБПредставление), СокрЛП(ДанныеЦБ.КоличествоЦБ));
	КонецЦикла;
	Возврат ТекстДанныеЦБ;
КонецФункции

