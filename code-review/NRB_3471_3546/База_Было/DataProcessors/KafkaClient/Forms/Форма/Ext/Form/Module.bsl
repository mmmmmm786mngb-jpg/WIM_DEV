
&НаКлиенте
Процедура ПрочитатьСообщение(Команда)
	ПрочитатьСообщениеНаСервере();
КонецПроцедуры

&НаКлиенте
Процедура ОтправитьСообщение(Команда)
	ОтправитьСообщениеНаСервере();
КонецПроцедуры

&НаСервере
Процедура ПрочитатьСообщениеНаСервере()
	РекОбъект = РеквизитФормыВЗначение("Объект");
	Если ЗначениеЗаполнено(ВнешнийИсточник) Тогда
		ОтветМассив = РекОбъект.РезультатЧтенияСообщенияПоВнешнемуИсточнику(ВнешнийИсточник);
	Иначе
		ДанныеДляОтправки = СтруктураДанныхРучныхНастроек();
		ОтветМассив = РекОбъект.РезультатЧтенияСообщенияПоВнешнемуИсточнику(ДанныеДляОтправки);
	КонецЕсли;
	Ответ = "[" + Дата(ОтветМассив[3]) + "] " + ОтветМассив[1] + ": " + ОтветМассив[2];
	ЗначениеВРеквизитФормы(РекОбъект, "Объект");
КонецПроцедуры

&НаСервере
Процедура ОтправитьСообщениеНаСервере()
	ДанныеОтправкиСообщения = СтруктураДанныхРучныхНастроек();
	ДанныеОтправкиСообщения.Вставить("ВнешнийИсточник", ВнешнийИсточник);
	ДанныеОтправкиСообщения.Вставить("Ключ", Ключ);
	ДанныеОтправкиСообщения.Вставить("Сообщение", Сообщение);
		
	РекОбъект = РеквизитФормыВЗначение("Объект");
	Ответ = РекОбъект.РезультатОтправкиСообщенияПоВнешнемуИсточнику(ДанныеОтправкиСообщения);
	ЗначениеВРеквизитФормы(РекОбъект, "Объект");
КонецПроцедуры

&НаСервере
Функция СтруктураДанныхРучныхНастроек()
	Результат = Новый Структура("KafkaАдрес,KafkaПользователь,KafkaПароль,KafkaСертификат,KafkaТопик,KafkaПодписчик",
		Адрес, Пользователь, Пароль, Сертификат, Топик, Подписчик);
	Возврат Результат;
КонецФункции