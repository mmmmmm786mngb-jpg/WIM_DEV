Процедура ЗаполнитьContract(ДанныеContract, Ошибка)
	
	Попытка
		Запись = Contract.Добавить();
		Запись.CreateDate							= ДатаИзJSON(ДанныеContract.CreateDate, ФорматДатыJSON.ISO);
		Запись.CloseDate							= ДатаИзJSON(ДанныеContract.CloseDate, ФорматДатыJSON.ISO);
		Запись.ContractType							= ДанныеContract.ContractType;
		Запись.ContractSubType						= ДанныеContract.ContractSubType;
		Запись.DepoAccountSectionType				= ДанныеContract.DepoAccountSectionType;
		Запись.StatusCode							= ДанныеContract.StatusCode;
		Запись.CrmClientId							= Формат(ДанныеContract.CrmClientId, "ЧГ=");
		Запись.ClientIdSystem						= ДанныеContract.ClientIdSystem;
		Запись.ContractNumber						= ДанныеContract.ContractNumber;
		Запись.IsSCP								= ДанныеContract.IsSCP;
		Запись.IsClientGrantedRightsUseSecurities	= ДанныеContract.IsClientGrantedRightsUseSecurities;
		Запись.Comment								= ДанныеContract.Comment;
		Запись.ObjectVersion						= ДанныеContract.ObjectVersion;
		Запись.ContractRateCode						= ДанныеContract.ContractRateCode;
		Если ДанныеContract.Свойство("Flags") И ТипЗнч(ДанныеContract.Flags) = Тип("Массив") Тогда
			Для Каждого Элемент Из ДанныеContract.Flags Цикл
				Если Элемент.Type = "Profit" Тогда
					Запись.Profit = ДанныеContract.Flags[0].Value;
					Прервать;
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
		Если ДанныеContract.Свойство("Holder") Тогда
			ДанныеHolder = ДанныеContract.Holder;
			Запись.BrokerCode = ДанныеHolder.BrokerCode;
			Запись.BrokerName = ДанныеHolder.BrokerName;
			Запись.AdditionalAgreementNumber = ДанныеHolder.AdditionalAgreementNumber;
			Запись.AdditionalAgreementDate = ДатаИзJSON(ДанныеHolder.AdditionalAgreementDate, ФорматДатыJSON.ISO);
			Запись.DepoMxDivisionCode = ДанныеHolder.DepoMxDivisionCode;
		КонецЕсли;
	Исключение
		ОбработатьОшибкуИнициализацииДанных(Ошибка, "Contract");
		ВызватьИсключение;
	КонецПопытки;
	
КонецПроцедуры

Процедура ИнициализацияMessageInfo(СтруктураJSON, Ошибка, Ключ) Экспорт
	
	ИмяСобытия = "РегистрацияКлиента";
	СтатусРегистрацииОшибка = "REGERR";
	ОчиститьТабличныеДанные();
	Попытка
		ДанныеMessageInfo = СтруктураJSON.MessageInfo;
		ЗаполнитьMessageInfo(ДанныеMessageInfo, Ошибка, Ключ);
	Исключение
		ОбработатьОшибкуИнициализацииДанных(Ошибка, Ключ);
		ВызватьИсключение;
	КонецПопытки;
		
КонецПроцедуры

