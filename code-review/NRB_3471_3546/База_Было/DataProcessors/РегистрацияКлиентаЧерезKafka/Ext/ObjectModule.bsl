Процедура ЗарегистрироватьИдентификаторКлиента(Клиент, Идентификатор)
	
	КодЗагрузки = Справочники.КодыЗагрузки.СсылкаПоВладельцуКлассификаторуКоду(
		Клиент,
		Справочники.КлассификаторыЗагрузки.Клиенты,
		Идентификатор,
		ТекущаяДатаСеанса());
		
	Если КодЗагрузки = Неопределено Тогда
		
		КодЗагрузки = Справочники.КодыЗагрузки.СоздатьЭлемент();
		КодЗагрузки.ДополнительныеСвойства.Вставить("КомментарийДляИсторииДанных", "РегистрацияКлиентовДепозитарий");
		КодЗагрузки.Владелец = Клиент;
		КодЗагрузки.Биржа = Справочники.КлассификаторыЗагрузки.Клиенты;
		КодЗагрузки.Код = Идентификатор;
		КодЗагрузки.Записать();
		
	КонецЕсли;
		
КонецПроцедуры

