Функция СчетДепоМХПоручения(Депонент, ТипСчетаДепо)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ПравоИспользования.Значение КАК ПравоИспользованияЦБКлиентов
		|ИЗ
		|	РегистрСведений.ПравоИспользованияЦБКлиентов.СрезПоследних(&ТекущаяДата, Клиент = &Клиент) КАК ПравоИспользования";
	
	Запрос.УстановитьПараметр("Клиент", Депонент);
	Запрос.УстановитьПараметр("ТекущаяДата", ТекущаяДатаСеанса());
	
	РезультатЗапроса = Запрос.Выполнить();
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда
		ПравоИспользованияЦБ = ВыборкаДетальныеЗаписи.ПравоИспользованияЦБКлиентов;
	Иначе
		ПравоИспользованияЦБ = Ложь;
	КонецЕсли;
	
	ИмяОбъекта = "Обработка.РегистрацияКлиентаЧерезKafka";
	ПустаяСтруктура = Новый Структура;
	// BSLLS:Typo-off
	ИмяНастройки = ?(ПравоИспользованияЦБ, "МХ_СПИпоУмолчанию", "МХ_БПИпоУмолчанию");
	// BSLLS:Typo-on
	ЗначенияРеквизитов =
		ОбщегоНазначения.ПолучитьЗначенияРеквизитовШапкиОбъектаПоУмолчанию(ИмяОбъекта, ПустаяСтруктура, ИмяНастройки);
		
	ЭтоТорговыйСчет = ТипСчетаДепо = Перечисления.ТипыСчетовДепо.ВладельцаТорговый
		Или ТипСчетаДепо = Перечисления.ТипыСчетовДепо.НоминальногоДержателяТорговый
		Или ТипСчетаДепо = Перечисления.ТипыСчетовДепо.ДоверительногоУправляющегоТорговый
		Или ТипСчетаДепо = Перечисления.ТипыСчетовДепо.ИностранногоНоминальногоДержателяТорговый
		Или ТипСчетаДепо = Перечисления.ТипыСчетовДепо.ИностранногоУполномоченногоДержателяТорговый;
	Если ЭтоТорговыйСчет Тогда
		РазделСчетаДепоМХ = ЗначенияРеквизитов.МХОбеспечения;
	Иначе
		РазделСчетаДепоМХ = ЗначенияРеквизитов.МХОсновной;
	КонецЕсли;
	
	СчетДепоМХ = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(РазделСчетаДепоМХ, "Владелец");
	Возврат СчетДепоМХ;
	
КонецФункции

Процедура ЗаполнитьПоручениеДляДержательскойСхемы(Поручение, ДепозитарийМХ, ПараметрыПоручений) // BSLLS:Typo-off
	
	ДанныеДоговора = ПараметрыПоручений.ДанныеДоговора;
	Поручение.ОткрытьВМХ = Истина;
	Поручение.СчетДепоМХ = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДепозитарийМХ, "Владелец");
	НайденныйРазделСчетаДепоМХ = Справочники.РазделыСчетаДепоМХ.НайтиПоКоду(ДанныеДоговора.DepoMxDivisionCode);
	Если ЗначениеЗаполнено(НайденныйРазделСчетаДепоМХ) Тогда
		ТекстОшибки = СтрШаблон("Номер раздела счета депо МХ %1 уже зарегистрирован", ДанныеДоговора.DepoMxDivisionCode);
		ВызватьИсключение ТекстОшибки;
	Иначе
		Поручение.НомерРазделаСчетаДепоМХ = ДанныеДоговора.DepoMxDivisionCode;
	КонецЕсли;
	КодЗагрузкиБрокера = СокрЛП(ДанныеДоговора.BrokerCode);
	НайденныйБрокер = БрокерПоКодуЗагрузки(КодЗагрузкиБрокера);
	Если ЗначениеЗаполнено(НайденныйБрокер) Тогда
		Поручение.Брокер = НайденныйБрокер;
	Иначе
		ТекстОшибки = СтрШаблон("Не удалось найти брокера по коду загрузки %1", КодЗагрузкиБрокера);
		ВызватьИсключение ТекстОшибки;
	КонецЕсли;
	
	ФорматДаты = "ДФ=dd.MM.yyyy";
	Поручение.Комментарий = СтрШаблон("Депозитарный договор № %1 от %2, Дополнительное соглашение № %3 от %4",
		СокрЛП(ПараметрыПоручений.НомерДоговораДепо), Формат(ПараметрыПоручений.ДатаДоговораДепо, ФорматДаты),
		ДанныеДоговора.AdditionalAgreementNumber, Формат(ДанныеДоговора.AdditionalAgreementDate, ФорматДаты));
	
КонецПроцедуры

Функция БрокерПоКодуЗагрузки(Код)
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	КодыЗагрузки.Владелец КАК КодЗагрузкиВладелец,
	|	Контрагенты.Ссылка КАК ГруппаКонтрагенты
	|ПОМЕСТИТЬ КодЗагрузкиИГруппаКонтрагенты
	|ИЗ
	|	Справочник.КодыЗагрузки КАК КодыЗагрузки
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Контрагенты КАК Контрагенты
	|		ПО (Контрагенты.Код = &ГруппаКонтрагентыКод)
	|			И (Контрагенты.ЭтоГруппа)
	|ГДЕ
	|	КодыЗагрузки.Код = &Код
	|	И НЕ КодыЗагрузки.ПометкаУдаления
	|	И ВЫБОР
	|			КОГДА КодыЗагрузки.ДатаОкончанияДействия = ДАТАВРЕМЯ(1, 1, 1)
	|				ТОГДА ИСТИНА
	|			КОГДА КодыЗагрузки.ДатаОкончанияДействия > &ТекущаяДата
	|				ТОГДА ИСТИНА
	|			ИНАЧЕ ЛОЖЬ
	|		КОНЕЦ
	|	И КодыЗагрузки.Биржа = &Классификатор
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Контрагенты.Ссылка КАК Брокер
	|ИЗ
	|	КодЗагрузкиИГруппаКонтрагенты КАК КодЗагрузкиИГруппаКонтрагенты
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Контрагенты КАК Контрагенты
	|		ПО КодЗагрузкиИГруппаКонтрагенты.КодЗагрузкиВладелец = Контрагенты.Ссылка
	|			И КодЗагрузкиИГруппаКонтрагенты.ГруппаКонтрагенты = Контрагенты.Родитель
	|ГДЕ
	|	НЕ Контрагенты.Ссылка ЕСТЬ NULL
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	КонтрагентыЮрлица.Ссылка
	|ИЗ
	|	КодЗагрузкиИГруппаКонтрагенты КАК КодЗагрузкиИГруппаКонтрагенты
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ЮридическиеЛица КАК ЮридическиеЛица
	|		ПО КодЗагрузкиИГруппаКонтрагенты.КодЗагрузкиВладелец = ЮридическиеЛица.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Контрагенты КАК КонтрагентыЮрлица
	|		ПО (ЮридическиеЛица.Ссылка = КонтрагентыЮрлица.ЮридическиеФизическиеЛица)
	|			И КодЗагрузкиИГруппаКонтрагенты.ГруппаКонтрагенты = КонтрагентыЮрлица.Родитель
	|ГДЕ
	|	НЕ КонтрагентыЮрлица.Ссылка ЕСТЬ NULL";
	Запрос.УстановитьПараметр("Код", Код);
	Запрос.УстановитьПараметр("Классификатор", Справочники.КлассификаторыЗагрузки.NrdCode);
	Запрос.УстановитьПараметр("ТекущаяДата", ТекущаяДатаСеанса());
	Запрос.УстановитьПараметр("ГруппаКонтрагентыКод", "Контрагент");
	
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Брокер;
	Иначе
		Возврат Неопределено;
	КонецЕсли;
	
КонецФункции

