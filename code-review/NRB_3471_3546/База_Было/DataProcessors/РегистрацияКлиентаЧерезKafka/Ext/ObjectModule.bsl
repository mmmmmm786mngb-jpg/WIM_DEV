Процедура ЗаполнитьClientTaxInfo(ДанныеClientTaxInfo, Ошибка)
	
	Запись = ClientTaxInfo.Добавить();
	
	Если НЕ ЗначениеЗаполнено(ДанныеClientTaxInfo) Тогда
		CrmClientId = ?(ClientIds.Количество() > 0, ClientIds[0].CrmClientId, "");
		MessageId = ?(MessageInfo.Количество() > 0, MessageInfo[0].MessageId, "");
		Ошибка = "Отсутствует информация о том, является ли клиент с CrmClientId = " + CrmClientId + "налоговым резидентом РФ"
					+ " - в сообщении с MessageId = " + MessageId + " нет секции ClientTaxInfo";
		ЗаписьЖурналаРегистрации(ИмяСобытия, УровеньЖурналаРегистрации.Ошибка, , , Ошибка);
		Ответ = СтруктураСообщенияОшибки("", Ошибка);
		Ответ.Вставить("Ключ", "Client");
		Кафка.ОтправитьОшибкуОбработки(Ответ);
		Возврат;
	КонецЕсли;
	
	Попытка
		Запись.RuTaxResident	= ДанныеClientTaxInfo.RuTaxResident;
		Запись.Inn				= ДанныеClientTaxInfo.Inn;
	Исключение
		ОбработатьОшибкуИнициализацииДанныхКлиента(Ошибка);
		ВызватьИсключение;
	КонецПопытки;
	
КонецПроцедуры

