Функция КатегорияРолиКлиентаИзJSON(ОбозначениеИзJSON)
	КатегорииРолей = Справочники.КатегорииРолейКлиентовСогласноУказов81и95;
	ЗаглавнымиОбозначениеИзJSON = Врег(ОбозначениеИзJSON);
	
	Если ЗаглавнымиОбозначениеИзJSON = "FRES_UC_FPERS_FROM_US" Тогда
		КатегорияРоли = КатегорииРолей.ИностранныйРезидентПодКонтролемИностранныхЛицИзНедружественныхСтран;
	ИначеЕсли ЗаглавнымиОбозначениеИзJSON = "FRES_UC_FPERS_FROM_FS" Тогда
		КатегорияРоли = КатегорииРолей.ИностранныйРезидентПодКонтролемИностранныхЛицИзДружественныхСтран;
	ИначеЕсли ЗаглавнымиОбозначениеИзJSON = "FRES_S_DECREE95" Тогда
		КатегорияРоли = КатегорииРолей.ИностранныйРезидентУдовлетворяющийТребованиямП12Указа95;
	ИначеЕсли ЗаглавнымиОбозначениеИзJSON = "RRES_UC_FPERS_FROM_US" Тогда
		КатегорияРоли = КатегорииРолей.РоссийскийРезидентПодКонтролемИностранныхЛицИзНедружественныхСтран;
	ИначеЕсли ЗаглавнымиОбозначениеИзJSON = "RRES_UC_FPERS_FROM_FS" Тогда
		КатегорияРоли = КатегорииРолей.РоссийскийРезидентПодКонтролемИностранныхЛицИзДружественныхСтран;
	ИначеЕсли ЗаглавнымиОбозначениеИзJSON = "RRES_UC_RRES" Тогда
		КатегорияРоли = КатегорииРолей.РоссийскийРезидентПодКонтролемРоссийскихРезидентов;
	Иначе
		ВызватьИсключение "Не предусмотренное обозначение категории роли клиента согласно Указов №81 и №95: " + ОбозначениеИзJSON;
	КонецЕсли;
	
	Возврат КатегорияРоли;
КонецФункции

Функция CrmClientIdЗарегистрирован(CrmClientId)
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	КодыЗагрузки.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.КодыЗагрузки КАК КодыЗагрузки
	|ГДЕ
	|	КодыЗагрузки.Код = &Код
	|	И НЕ КодыЗагрузки.ПометкаУдаления
	|	И (КодыЗагрузки.ДатаОкончанияДействия = ДАТАВРЕМЯ(1, 1, 1)
	|			ИЛИ КодыЗагрузки.ДатаОкончанияДействия > &ТекущаяДата)
	|	И КодыЗагрузки.Биржа = ЗНАЧЕНИЕ(справочник.КлассификаторыЗагрузки.Клиенты)");
	Запрос.УстановитьПараметр("Код", СокрЛП(CrmClientId));
	Запрос.УстановитьПараметр("ТекущаяДата", НачалоДня(ТекущаяДатаСеанса()));
	Результат = Запрос.Выполнить();
	Возврат НЕ Результат.Пустой();
КонецФункции

Процедура ЗафиксироватьОшибку(СообщениеОбОшибке, Data, Ошибка)
	ДанныеСообщения = MessageInfo[0];
	Если НРег(ДанныеСообщения.MessageType) = "client" Тогда
		CrmClientId = ClientIds[0].CrmClientId;
		Data.Client.ClientStatuses.DepoClientStatus = СтатусРегистрацииОшибка;
		Data.Client.ClientStatuses.DepoClientStatusDate = ЗаписатьДатуJSON(ТекущаяДатаСеанса(), ФорматДатыJSON.ISO);
		Data.Client.ClientIds.CrmClientId = CrmClientId;
	ИначеЕсли НРег(ДанныеСообщения.MessageType) = "contract" Тогда
		CrmClientId = Data.CrmClientId;
		Data.StatusCode = СтатусРегистрацииОшибка;
	КонецЕсли;
	Ошибка = Ошибка + Символы.ПС + СообщениеОбОшибке;
КонецПроцедуры

