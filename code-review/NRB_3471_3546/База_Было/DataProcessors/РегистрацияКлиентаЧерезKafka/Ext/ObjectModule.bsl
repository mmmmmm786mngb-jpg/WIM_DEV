Процедура ИнициализацияДанныхКлиентаJSON(СтруктураJSON, Ошибка) Экспорт
	
	Попытка
		ДанныеКлиента = СтруктураJSON.Data.Client;
		ИдентификаторыКлиента = ДанныеКлиента.ClientIds;
		УслугиКлиента = ДанныеКлиента.ClientServices;
	Исключение
		ОбработатьОшибкуИнициализацииДанныхКлиента(Ошибка);
		ВызватьИсключение;
	КонецПопытки;
	ЗаполнитьClientIds(ИдентификаторыКлиента, Ошибка);
	ЗаполнитьClientServices(УслугиКлиента, Ошибка);		// В этой секции есть сведения о том, является ли этот клиент клиентом депозитария
	
	Если Не ЭтоДепозитарныйКлиент() Тогда
		Возврат;
	КонецЕсли;
	
	Попытка
		СтатусыКлиента = ДанныеКлиента.ClientStatuses;
	Исключение
		ОбработатьОшибкуИнициализацииДанныхКлиента(Ошибка);
	КонецПопытки;
	ЗаполнитьClientStatuses(СтатусыКлиента, Ошибка);	// В этой секции есть сведения о том, является ли клиент юрлицом или физлицом
	
	ПустойМассив = Новый Массив;
	Попытка
		Если ЭтоЮрлицо() Тогда
			ДанныеЮридическогоЛица = ДанныеКлиента.LegalInfo;
			ДанныеОЛицензияхЮрЛица = ДанныеКлиента.Licenses;
			ДанныеОГосРегистрацииЮрЛица = ДанныеКлиента.RegState;
		Иначе
			ДанныеФизлица = ДанныеКлиента.PersonInfo;
			ДанныеФИО = ДанныеФизлица.ClientFio;
			ДанныеДокументов = ДанныеКлиента.ClientDocuments;
		КонецЕсли;
		НалоговыеДанные = ДанныеКлиента.ClientTaxInfo;
		АдресаКлиента = ДанныеКлиента.ClientAddresses;
		КонтактыКлиента = ДанныеКлиента.ClientContacts;
		КлиентскиеМенеджеры = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ДанныеКлиента, "ManagerInfo", ПустойМассив);
	Исключение
		ОбработатьОшибкуИнициализацииДанныхКлиента(Ошибка);
		ВызватьИсключение;
	КонецПопытки;
	
	Если ЭтоЮрлицо() Тогда
		ЗаполнитьLegalInfo(ДанныеЮридическогоЛица, Ошибка);
		ЗаполнитьVed(ДанныеЮридическогоЛица, Ошибка);
		ЗаполнитьLicenses(ДанныеОЛицензияхЮрЛица, Ошибка);
		ЗаполнитьRegState(ДанныеОГосРегистрацииЮрЛица, Ошибка);
	Иначе
		ЗаполнитьPersonInfo(ДанныеФизлица, Ошибка);
		ЗаполнитьPersonFio(ДанныеФИО, Ошибка);
		ЗаполнитьClientDocuments(ДанныеДокументов, Ошибка);
	КонецЕсли;
	
	ЗаполнитьClientTaxInfo(НалоговыеДанные, Ошибка);
	ЗаполнитьClientAddresses(АдресаКлиента, Ошибка);
	ЗаполнитьClientContacts(КонтактыКлиента, Ошибка);
	ЗаполнитьManagerInfo(КлиентскиеМенеджеры, Ошибка);
КонецПроцедуры

