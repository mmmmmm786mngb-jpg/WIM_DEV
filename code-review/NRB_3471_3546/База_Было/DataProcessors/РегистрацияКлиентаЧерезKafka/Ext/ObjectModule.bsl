#Область ОсновнаяФункциональностьРегистрацииКлиента

Функция РезультатРегистрацииКлиентаВДепозитарии(СтрКлиент, ТипОперации, НовоеЮрФизЛицо, Ошибка) Экспорт
	
	Data = НовыйСтруктураОтветаКлиента();
	
	Если НЕ ЭтоДепозитарныйКлиент() Тогда
		ЗафиксироватьОшибку("Не подключена услуга депозитарного обслуживания", Data, Ошибка);
		Возврат РезультатОбработки(СтрКлиент.MessageInfo, Data);
	КонецЕсли;
	
	ИдентификаторыКлиента = ClientIds[0];
	НеРезидент = НЕ ClientTaxInfo[0].RuTaxResident;
	
	ПропускаемРегистрацию = (ТипОперации = "ins" И CrmClientIdЗарегистрирован(ClientIds[0].CrmClientId));
	Если ПропускаемРегистрацию Тогда
		ЗафиксироватьОшибку("Клиент с таким CrmClientId зарегистрирован", Data, Ошибка);
		Возврат РезультатОбработки(СтрКлиент.MessageInfo, Data);
	КонецЕсли;
	
	ПерезаписываемКонтрагента = Ложь;
	Попытка
		Если ЭтоФизлицо() Тогда
			ЮридическиеФизическиеЛица = РезультатРегистрацииФизлицаВДепозитарии(ТипОперации, НовоеЮрФизЛицо, ПерезаписываемКонтрагента, Ошибка);
		ИначеЕсли ЭтоЮрлицо() Тогда
			ЮридическиеФизическиеЛица = РезультатРегистрацииЮрлицаВДепозитарии(ТипОперации, НовоеЮрФизЛицо, ПерезаписываемКонтрагента, Ошибка);
		Иначе
			ЗафиксироватьОшибку("Тип клиента не определен", Data, Ошибка);
			Возврат РезультатОбработки(СтрКлиент.MessageInfo, Data);
		КонецЕсли;
	Исключение
		ОписаниеОшибки = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		ЗафиксироватьОшибку(ОписаниеОшибки, Data, Ошибка);
		Возврат РезультатОбработки(СтрКлиент.MessageInfo, Data);
	КонецПопытки;
	
	ДанныеСтатусаКлиента = Data.Client.ClientStatuses;
	ДанныеИДКлиента = Data.Client.ClientIds;
	ДанныеСтатусаКлиента.DepoClientStatus = "REG";
	ДанныеСтатусаКлиента.DepoClientStatusDate = ЗаписатьДатуJSON(ТекущаяДатаСеанса(), ФорматДатыJSON.ISO);
	ДанныеИДКлиента.DepoClientId = СокрЛП(ЮридическиеФизическиеЛица.Код);
	ДанныеИДКлиента.CrmClientId = СокрЛП(ИдентификаторыКлиента.CrmClientId);
	ЗарегистрироватьИдентификаторКлиента(ЮридическиеФизическиеЛица.Ссылка, ИдентификаторыКлиента.CrmClientId);
	
	Если ПерезаписываемКонтрагента Тогда
		ОбновитьДанныеКонтрагентаПоЮрФизЛицу(ЮридическиеФизическиеЛица);
	КонецЕсли;
	
	Результат = РезультатОбработки(СтрКлиент.MessageInfo, Data);
	Результат.Вставить("Ссылка", ЮридическиеФизическиеЛица.Ссылка);
	Возврат Результат;
	
КонецФункции

Функция РезультатРегистрацииФизлицаВДепозитарии(ТипОперации, НовоеФизЛицо, ПерезаписываемКонтрагента, Ошибка)
	CrmClientId = ClientIds[0].CrmClientId;
	ФизЛицоСсылка = Обработки.РегистрацияКлиентаЧерезKafka.КлиентПоCrmClientId(CrmClientId);
	
	ПаспортныеДанные = Неопределено;
	Для Каждого ДокументКлиента Из ClientDocuments Цикл
		Если ЭтоПаспорт(ДокументКлиента.DocumentType) Тогда
			Если Не ЗначениеЗаполнено(ФизЛицоСсылка) Тогда
				ФизЛицоСсылка = ФизлицоПоПаспорту(ДокументКлиента.Series, ДокументКлиента.Number, ДокументКлиента.DocumentType);
				Если ФизЛицоСсылка = Справочники.ФизическиеЛица.ПустаяСсылка() Тогда
					ФизЛицоСсылка = ФизЛицоПоИНН(ClientTaxInfo[0].Inn);
				КонецЕсли;
			КонецЕсли;
			ПаспортныеДанные = ДокументКлиента;
			Если ДокументКлиента.Active = 1 Тогда
				Прервать;
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
	ПерсональнаяИнформация = PersonInfo[0];
	НалоговыеДанныеКлиента = ClientTaxInfo[0];
	ФИОКлиента = PersonFio[0];

	Если ЗначениеЗаполнено(ФизЛицоСсылка) Тогда
		ФизЛицо = ФизЛицоСсылка.ПолучитьОбъект();
	Иначе
		ФизЛицо = Справочники.ФизическиеЛица.СоздатьЭлемент();
		НовоеФизЛицо = Истина;
	КонецЕсли;
	
	ПерезаписываемКонтрагента = (ФизЛицо.Наименование <> ФИОКлиента.Name) Или (ФизЛицо.ИНН <> НалоговыеДанныеКлиента.Inn);
	
	ФизЛицо.Наименование = ФИОКлиента.Name;
	ФизЛицо.ДатаРождения = ПерсональнаяИнформация.BirthDate;
	ФизЛицо.МестоРождения = ПерсональнаяИнформация.BirthPlace;
	ФизЛицо.ИНН = НалоговыеДанныеКлиента.Inn;
	ФизЛицо.Пол = ПолФизЛица(ПерсональнаяИнформация.Sex);
	ФизЛицо.СтраховойНомерПФР = ПерсональнаяИнформация.Snils;
	ФизЛицо.ПБОЮЛ = ПерсональнаяИнформация.Pboul;
	ФизЛицо.Код = CrmClientId;
	
	Попытка
		ФизЛицо.Записать();
		ЗарегистрироватьКатегорииРолейФизлицаСогласноУказов81и95(ФизЛицо.Ссылка, НовоеФизЛицо, НалоговыеДанныеКлиента);
	Исключение
		Ошибка = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		ЗаписьЖурналаРегистрации(ИмяСобытия, УровеньЖурналаРегистрации.Ошибка, , , Ошибка);
	КонецПопытки;
	
	ВыполнитьРегистрацииДанныхФизЛица(ФизЛицо, ФИОКлиента, ПаспортныеДанные, ПерезаписываемКонтрагента, Ошибка);

	Возврат ФизЛицо.Ссылка;
КонецФункции

Функция РезультатРегистрацииЮрЛицаВДепозитарии(ТипОперации, НовоеЮрЛицо, ПерезаписываемКонтрагента, Ошибка)
	CrmClientId = ClientIds[0].CrmClientId;
	ЮрЛицоСсылка = Обработки.РегистрацияКлиентаЧерезKafka.КлиентПоCrmClientId(CrmClientId);
	
	НалоговыеДанныеКлиента = ClientTaxInfo[0];
	ИнформацияОЮрЛице = LegalInfo[0];
	ИнформацияОГосРегистрацииЮрЛица = RegState[0];
	
	Если ЗначениеЗаполнено(ЮрЛицоСсылка) Тогда
		ЮрЛицо = ЮрЛицоСсылка.ПолучитьОбъект();
	Иначе
		ЮрЛицо = Справочники.ЮридическиеЛица.СоздатьЭлемент();
		НовоеЮрЛицо = Истина;
	КонецЕсли;
	
	ПерезаписываемКонтрагента = (ЮрЛицо.Наименование <> ИнформацияОЮрлице.FullName) Или (ЮрЛицо.ИНН <> НалоговыеДанныеКлиента.Inn);
	ЮрЛицо.Наименование = ИнформацияОЮрЛице.ShortName;
	ЮрЛицо.ПолноеНаименование = ИнформацияОЮрЛице.FullName;
	ЮрЛицо.ПолноеНаименованиеНаАнглийскомЯзыке = ИнформацияОЮрЛице.FullFrgnName;
	ЮрЛицо.УнифицированноеНаименованиеЦБРФ = ИнформацияОЮрлице.UniCBName;
	ЮрЛицо.ОПФ = ИнформацияОЮрЛице.Ownership;
	ЮрЛицо.МеждународнаяОрганизация = ИнформацияОЮрЛице.InternationalOrganization;
	ЮрЛицо.МеждународнаяКомпания = ИнформацияОЮрЛице.InternationalCompany;
	ЮрЛицо.Страна = Справочники.КлассификаторСтранМира.СтранаПоКодуАльфа2(ИнформацияОЮрЛице.RegCountry);
	ЮрЛицо.НеРезидент = Не ИнформацияОЮрЛице.IsResident;
	ЮрЛицо.ИНН = НалоговыеДанныеКлиента.Inn;
	ЮрЛицо.КПП = ИнформацияОЮрЛице.Kpp;
	ЮрЛицо.КодПоОКПО = ИнформацияОЮрЛице.Okpo;
	ЮрЛицо.КодПоОКВЭД = ИнформацияОЮрЛице.OkVed;
	ЮрЛицо.TIN = ИнформацияОЮрЛице.TIN;
	ЮрЛицо.ОКОПФ = ИнформацияОЮрЛице.OKOPF;
	ЮрЛицо.ОКФС = ИнформацияОЮрЛице.OKFS;
	ЮрЛицо.ОКОГУ = ИнформацияОЮрЛице.OKOGU;
	ЮрЛицо.КодПоОКОНХ = ИнформацияОЮрЛице.OKONH;
	ЮрЛицо.ВидПая = ВидПаяИзJSON(ИнформацияОЮрЛице.TypeSare);
	ЮрЛицо.ТипДепонента = ТипДепонентаИзJSON(ИнформацияОЮрЛице.CodeClientReg);
	ЮрЛицо.ОГРН = ИнформацияОГосРегистрацииЮрЛица.OGRN;
	ЮрЛицо.РегистрирующийОрган = ИнформацияОГосРегистрацииЮрЛица.RegAuthority;
	ЮрЛицо.ДатаГосРегистрации = ИнформацияОГосРегистрацииЮрЛица.RegDate;
	ЮрЛицо.МестоГосРегистрации = ИнформацияОГосРегистрацииЮрЛица.RegPlace;
	ЮрЛицо.РегНомер = ИнформацияОГосРегистрацииЮрЛица.OGRNNumber;
	ЮрЛицо.ДатаВнесенияВЕГРЮЛ = ИнформацияОГосРегистрацииЮрЛица.RecordDate;
	ЮрЛицо.Код = CrmClientId;
		
	Попытка
		ЮрЛицо.Записать();
	Исключение
		Ошибка = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		ЗаписьЖурналаРегистрации(ИмяСобытия, УровеньЖурналаРегистрации.Ошибка, , , Ошибка);
	КонецПопытки;
	
	ВыполнитьРегистрацииДанныхЮрЛица(ЮрЛицо, ИнформацияОЮрлице, Ошибка);
	
	Возврат ЮрЛицо.Ссылка;
КонецФункции

Функция РезультатРегистрацииДоговораКлиента(стрДоговор, Ошибка) Экспорт
	
	ДанныеДоговора = Contract[0];
	НомерДоговора = ДанныеДоговора.ContractNumber;
	ЮрФизЛицо = Обработки.РегистрацияКлиентаЧерезKafka.КлиентПоCrmClientId(ДанныеДоговора.CrmClientId);
	Если НЕ ЗначениеЗаполнено(ЮрФизЛицо) Тогда
		ЗафиксироватьОшибку("Не найден зарегистрированный клиент с кодом " + ДанныеДоговора.CrmClientId,
			ДанныеДоговора, Ошибка);
		Возврат РезультатОбработки(стрДоговор.MessageInfo,
			Новый Структура("StatusCode,CrmClientId", ДанныеДоговора.StatusCode, ДанныеДоговора.CrmClientId));
	КонецЕсли;
	Попытка 
		Контрагент = РезультатРегистрацииДепонента(ЮрФизЛицо, Ошибка);
	Исключение
		ОписаниеОшибки = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		ЗафиксироватьОшибку(ОписаниеОшибки, ДанныеДоговора, Ошибка);
		Возврат РезультатОбработки(стрДоговор.MessageInfo,
			Новый Структура("StatusCode,CrmClientId", ДанныеДоговора.StatusCode, ДанныеДоговора.CrmClientId));
	КонецПопытки;
	Если Контрагент = Неопределено Тогда
		ЗафиксироватьОшибку("Договор клиента с номером " + НомерДоговора + " уже зарегистрирован в системе",
			ДанныеДоговора, Ошибка);
		Возврат РезультатОбработки(стрДоговор.MessageInfo,
			Новый Структура("StatusCode,CrmClientId", ДанныеДоговора.StatusCode, ДанныеДоговора.CrmClientId));
	КонецЕсли;
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	ДоговорыКонтрагентов.Ссылка КАК ДоговорСсылка
	|ИЗ
	|	Справочник.ДоговорыКонтрагентов КАК ДоговорыКонтрагентов
	|ГДЕ
	|	ДоговорыКонтрагентов.Владелец = &Владелец
	|	И ДоговорыКонтрагентов.Код = &Код
	|	И ДоговорыКонтрагентов.ТипДоговора = &ТипДоговора");
	Запрос.УстановитьПараметр("Владелец", ЮрФизЛицо);
	Запрос.УстановитьПараметр("Код", НомерДоговора);
	Запрос.УстановитьПараметр("ТипДоговора", Перечисления.ТипыДоговоров.Депозитарный);
	Результат = Запрос.Выполнить();
	Если Результат.Пустой() Тогда
		Договор = Справочники.ДоговорыКонтрагентов.СоздатьЭлемент();
	Иначе
		ЗафиксироватьОшибку("Договор клиента с номером " + НомерДоговора + " уже зарегистрирован в системе",
			ДанныеДоговора, Ошибка);
		Возврат РезультатОбработки(стрДоговор.MessageInfo,
			Новый Структура("StatusCode,CrmClientId", ДанныеДоговора.StatusCode, ДанныеДоговора.CrmClientId));
	КонецЕсли;
	
	Договор.Владелец = Контрагент;
	Договор.ДатаНачалоДействия = ДанныеДоговора.CreateDate;
	Договор.Код = НомерДоговора;
	Если НРег(ДанныеДоговора.ContractSubType) = "dep" Тогда
		Договор.ТипДоговора = Перечисления.ТипыДоговоров.Депозитарный;
	Иначе
		Договор.ТипДоговора = Перечисления.ТипыДоговоров.МежДепозитарный;
	КонецЕсли;
	Договор.Наименование = НомерДоговора;
	Договор.Организация = ОбщегоНазначенияПовтИсп.ОрганизацияПоУмолчанию();
	Договор.Комментарий = ДанныеДоговора.Comment;
	Договор.ОбменДанными.Загрузка = Истина;
	Попытка
		Договор.Записать();
	Исключение
		ЗафиксироватьОшибку(ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()), ДанныеДоговора, Ошибка);
		Возврат РезультатОбработки(стрДоговор.MessageInfo,
			Новый Структура("StatusCode,CrmClientId", ДанныеДоговора.StatusCode, ДанныеДоговора.CrmClientId));
	КонецПопытки;
	ДанныеДоговора.StatusCode = "REG";
	ДанныеДоговора.Договор = Договор.Ссылка;
	Если ЭтоКорректныйКодТарифногоПлана(ДанныеДоговора.ContractRateCode) Тогда
		УстановитьУслугиПоДоговору(Договор.Ссылка, ДанныеДоговора.ContractRateCode);
	Иначе
		ЗафиксироватьОшибку(СтрШаблон("Указан недопустимый код тарифа CRM %1", ДанныеДоговора.ContractRateCode), ДанныеДоговора, Ошибка);
		Возврат РезультатОбработки(стрДоговор.MessageInfo,
			Новый Структура("StatusCode, CrmClientId", ДанныеДоговора.StatusCode, ДанныеДоговора.CrmClientId));
	КонецЕсли;
	ЗарегистрироватьПравоИспользованияЦБ(Контрагент, ДанныеДоговора);
	Data = НовыйСтруктураОтветаДоговора();
	Data.ContractId = стрДоговор.Data.ContractId;
	Data.SrcSystem = стрДоговор.Data.SrcSystem;
	Если НЕ Data.ObjectVersion = 0 Тогда
		Data.ObjectVersion = стрДоговор.Data.ObjectVersion + 1;
	КонецЕсли;
	Результат = РезультатОбработки(стрДоговор.MessageInfo, Data);
	Результат.Вставить("Ссылка", Договор.Ссылка);
	Возврат Результат;

КонецФункции

Функция РезультатРегистрацииДепонента(ЮрФизЛицо, Ошибка)
	
	ДанныеДоговора = Contract[0];
	КонтрагентСсылка = Справочники.Контрагенты.КлиентПоCrmContractNumber(ДанныеДоговора.ContractNumber);
	Если ЗначениеЗаполнено(КонтрагентСсылка) Тогда
		Возврат Неопределено;
	Иначе
		Контрагент = Справочники.Контрагенты.СоздатьЭлемент();
	КонецЕсли;
	Контрагент.Код						 = ДанныеДоговора.ContractNumber;
	Контрагент.Родитель 				 = Справочники.Контрагенты.Депоненты;
	Контрагент.ДоходныйСчет				 = ДанныеДоговора.Profit;
	Контрагент.ЮридическиеФизическиеЛица = ЮрФизЛицо;
	Контрагент.СпособОтправкиОтчетов	 = Перечисления.СпособыОтправкиОтчетов.МП;
	Если ТипЗнч(ЮрФизЛицо) = Тип("СправочникСсылка.ФизическиеЛица") Тогда
		ЗаполнитьДанныеКонтрагентаПоФизЛицу(Контрагент, ЮрФизЛицо, ДанныеДоговора.CreateDate);
	Иначе
		ЗаполнитьДанныеКонтрагентаПоЮрЛицу(Контрагент, ЮрФизЛицо);
	КонецЕсли;
		
	Если ЗначениеЗаполнено(ДанныеДоговора.BrokerCode) Тогда
		Контрагент.КлиентОтсутствуетВBQ = Истина;
	КонецЕсли;
	Контрагент.Записать();
	ЗарегистрироватьИдентификаторДоговора(Контрагент.Ссылка, ДанныеДоговора.ContractNumber);
	ЗаполнитьПредоставленныеДокументыДепонентаДляДержательскойСхемы(Контрагент, ДанныеДоговора);
	
	Возврат Контрагент.Ссылка;
КонецФункции

Процедура ОбновитьДанныеКонтрагентаПоЮрФизЛицу(ЮридическиеФизическиеЛица)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Контрагенты.Ссылка КАК КонтрагентСсылка
	|ИЗ
	|	Справочник.Контрагенты КАК Контрагенты
	|ГДЕ
	|	НЕ Контрагенты.ПометкаУдаления
	|	И Контрагенты.ЮридическиеФизическиеЛица = &ЮридическиеФизическиеЛица";
	
	Запрос.УстановитьПараметр("ЮридическиеФизическиеЛица", ЮридическиеФизическиеЛица.Ссылка);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		Контрагент = ВыборкаДетальныеЗаписи.КонтрагентСсылка.ПолучитьОбъект();
		Если ТипЗнч(ЮридическиеФизическиеЛица) = Тип("СправочникСсылка.ФизическиеЛица") Тогда
			ЗаполнитьДанныеКонтрагентаПоФизЛицу(Контрагент, ЮридическиеФизическиеЛица, ТекущаяДатаСеанса(), ClientTaxInfo[0].RuTaxResident);
		Иначе
			ЗаполнитьДанныеКонтрагентаПоЮрлицу(Контрагент, ЮридическиеФизическиеЛица);
		КонецЕсли;
		Контрагент.Записать();
	КонецЦикла;

КонецПроцедуры

Процедура ЗаполнитьДанныеКонтрагентаПоЮрЛицу(Контрагент, Юрлицо)
	Контрагент.ЮрФизЛицо			 = Перечисления.ЮрФизЛицо.ЮрЛицо;
	Контрагент.Наименование			 = ЮрЛицо.Наименование;
	Контрагент.НаименованиеПолное	 = ЮрЛицо.ПолноеНаименование;
	Контрагент.ИНН					 = ЮрЛицо.ИНН;
	Контрагент.КПП					 = ЮрЛицо.КПП;
	Контрагент.ОКОНХ				 = ЮрЛицо.КодПоОКОНХ;
	Контрагент.ОКВЭД 				 = ЮрЛицо.КодПоОКВЭД;
	Контрагент.КодПоОКПО			 = ЮрЛицо.КодПоОКПО;
	Контрагент.TIN					 = ЮрЛицо.TIN;
	Контрагент.ОПФ					 = ЮрЛицо.ОПФ;
	Контрагент.ОГРН					 = ЮрЛицо.ОГРН;
	
	Контрагент.Резидент				 = Не РезидентПоСтране(ЮрЛицо.Страна);		// В реквизите Резидент  - хранятся данные о резидентстве по
																				// паспорту/учередительным документам, причем Истина означает, что это
																				// нерезидент - вот такая удачная шутка предыдущих разработчиков.
	
	Контрагент.НеРезидент			 = ЮрЛицо.НеРезидент;						// Не является налоговым резидентом РФ
КонецПроцедуры

Процедура ЗаполнитьДанныеКонтрагентаПоФизЛицу(Контрагент, ФизЛицо, Дата, РезидентПоНалогам = Неопределено)
	Контрагент.ЮрФизЛицо			 = Перечисления.ЮрФизЛицо.ФизЛицо;
	Контрагент.Наименование			 = ФизЛицо.Наименование;
	Контрагент.НаименованиеПолное	 = ФизЛицо.Наименование;
	Контрагент.ИНН					 = ФизЛицо.ИНН;
	Контрагент.Резидент				 = НеРезидентПоГражданству(ФизЛицо, Дата);	// В реквизите Резидент  - хранятся данные о резидентстве по
																				// паспорту/учередительным документам, причем Истина означает, что это
																				// нерезидент - вот такая удачная шутка предыдущих разработчиков.
	Если РезидентПоНалогам <> Неопределено Тогда
		Контрагент.НеРезидент		 = Не РезидентПоНалогам;					// Не является налоговым резидентом РФ
	КонецЕсли;
КонецПроцедуры

Процедура ЗарегистрироватьПризнакКвалИнвестор(Ошибка) Экспорт	// BSLLS:Typo-off
	
	СтатусКвалификации = НРег(QualInfo[0].QualInvestStatus);
	Если СтатусКвалификации = "storeg" Тогда
		ДатаКвалификации = QualInfo[0].QualInvestDate;
		ЮрФизЛицо = Обработки.РегистрацияКлиентаЧерезKafka.КлиентПоCrmClientId(ClientIds[0].CrmClientId);
		Если ЮрФизЛицо = Неопределено Тогда
			ВызватьИсключение "Не найден клиент с CrmClientId: " + ClientIds[0].CrmClientId;
		КонецЕсли;
		
		ВидОперации = Перечисления.ВидыОперацийРеестраКвалифицированныхИнвесторов.Признание;
		РегистрируемИзменениеРеестра = НеобходимаРегистрацияИзмененияРеестраКвалИнвесторов(ЮрФизЛицо, ВидОперации, ДатаКвалификации);
		
		Если РегистрируемИзменениеРеестра Тогда
			СоздатьДокументРегистрацияИзмененийРеестра(ЮрФизЛицо, ВидОперации, ДатаКвалификации, Ошибка);
		КонецЕсли;
	Иначе
		ВызватьИсключение "Неизвестный статус квалификации: " + СтатусКвалификации;
	КонецЕсли;
	
КонецПроцедуры

Процедура ВыполнитьРегистрацииДанныхФизЛица(ФизЛицо, ФИОКлиента, ПаспортныеДанные, ПерезаписываемКонтрагента, Ошибка)
	
	Попытка
		ЗарегистрироватьФИО(ФИОКлиента, ФизЛицо.Ссылка);
	Исключение
		Ошибка = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		ЗаписьЖурналаРегистрации(ИмяСобытия, УровеньЖурналаРегистрации.Ошибка, , , Ошибка);
	КонецПопытки;
	
	Если ЗначениеЗаполнено(ПаспортныеДанные) Тогда
		Попытка
			ЗарегистрироватьПаспортныеДанные(ПаспортныеДанные, ФизЛицо.Ссылка);
		Исключение
			Ошибка = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
			ЗаписьЖурналаРегистрации(ИмяСобытия, УровеньЖурналаРегистрации.Ошибка, , , Ошибка);
		КонецПопытки;
	КонецЕсли;
	
	Попытка
		ЗарегистрироватьГражданствоФизЛица(ФизЛицо.Ссылка, ПерезаписываемКонтрагента);
	Исключение
		Ошибка = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		ЗаписьЖурналаРегистрации(ИмяСобытия, УровеньЖурналаРегистрации.Ошибка, , , Ошибка);
	КонецПопытки;
	
	Попытка
		ЗарегистрироватьКИЮрФизЛица(ФизЛицо);
	Исключение
		Ошибка = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		ЗаписьЖурналаРегистрации(ИмяСобытия, УровеньЖурналаРегистрации.Ошибка, , , Ошибка);
	КонецПопытки;
	
	Попытка
		ЗарегистрироватьКлиентскиеМенеджерыЮрФизЛица(ФизЛицо.Ссылка);
	Исключение
		Ошибка = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		ЗаписьЖурналаРегистрации(ИмяСобытия, УровеньЖурналаРегистрации.Ошибка, , , Ошибка);
	КонецПопытки;

КонецПроцедуры

Процедура ВыполнитьРегистрацииДанныхЮрЛица(ЮрЛицо, ИнформацияОЮрлице, Ошибка)
	
	Попытка
		ЗарегистрироватьКИЮрФизЛица(ЮрЛицо);
		ЗарегистрироватьЛицензииЮрЛица(ЮрЛицо.Ссылка);
		ЗарегистрироватьКатегорииРолейКлиентовСогласноУказов81и95(ЮрЛицо.Ссылка, ИнформацияОЮрЛице.CategoryRole);
		ЗарегистрироватьКлиентскиеМенеджерыЮрФизЛица(ЮрЛицо.Ссылка);
	Исключение
		Ошибка = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		ЗаписьЖурналаРегистрации(ИмяСобытия, УровеньЖурналаРегистрации.Ошибка, , , Ошибка);
	КонецПопытки;
	
КонецПроцедуры

Процедура ЗарегистрироватьКИЮрФизЛица(ЮрФизЛицо)
	ВидыКИЮрФизЛица = Новый Структура("ФактическийАдрес, ЮридическийАдрес, ПочтовыйАдрес, Телефон, Email");
	
	Если ТипЗнч(ЮрФизЛицо) = Тип("СправочникОбъект.ФизическиеЛица") Тогда
		ВидыКИЮрФизЛица.ФактическийАдрес = Справочники.ВидыКонтактнойИнформации.ФактАдресФизЛица;
		ВидыКИЮрФизЛица.ЮридическийАдрес = Справочники.ВидыКонтактнойИнформации.ЮрАдресФизЛица;
		ВидыКИЮрФизЛица.ПочтовыйАдрес	 = Справочники.ВидыКонтактнойИнформации.ИнформАдресФизЛица;
		ВидыКИЮрФизЛица.Телефон			 = Справочники.ВидыКонтактнойИнформации.ТелефонФизЛица;
		ВидыКИЮрФизЛица.Email			 = Справочники.ВидыКонтактнойИнформации.EmailФизЛица;
	Иначе
		ВидыКИЮрФизЛица.ФактическийАдрес = Справочники.ВидыКонтактнойИнформации.ФактАдресЮрЛица;
		ВидыКИЮрФизЛица.ЮридическийАдрес = Справочники.ВидыКонтактнойИнформации.ЮрАдресЮрЛица;
		ВидыКИЮрФизЛица.ПочтовыйАдрес	 = Справочники.ВидыКонтактнойИнформации.АдресЮрлицаПочтовый;
		ВидыКИЮрФизЛица.Телефон			 = Справочники.ВидыКонтактнойИнформации.ТелефонЮрЛица;
		ВидыКИЮрФизЛица.Email			 = Справочники.ВидыКонтактнойИнформации.EmailЮрЛица;
	КонецЕсли;
	
	ВидыКИ = Новый Массив;
	ВидыКИ.Добавить(ВидыКИЮрФизЛица.ФактическийАдрес);
	ВидыКИ.Добавить(ВидыКИЮрФизЛица.ЮридическийАдрес);
	ВидыКИ.Добавить(ВидыКИЮрФизЛица.Телефон);
	ВидыКИ.Добавить(ВидыКИЮрФизЛица.Email);
	
	ДанныеКИЮрФизЛица = ПолучитьДанныеКИ(ЮрФизЛицо.Ссылка, ВидыКИ);
	
	ЗарегистрироватьАдресаЮрФизЛица(ЮрФизЛицо.Ссылка, ДанныеКИЮрФизЛица, ВидыКИЮрФизЛица);
	ЗарегистрироватьКонтактыЮрФизЛица(ЮрФизЛицо.Ссылка, ДанныеКИЮрФизЛица, ВидыКИЮрФизЛица);

КонецПроцедуры

Процедура СоздатьДокументРегистрацияИзмененийРеестра(Физлицо, ВидОперации, ДатаКвалификации, Ошибка)
	РегистрацияИзмененийРеестра = Документы.РегистрацияИзмененийРеестраКвалифицированныхИнвесторовРОФР;
	КатегорииЦенныхБумагДляРеестра = КатегорияФизЛицаПоДаннымKafka();
	Организация = ОбщегоНазначенияПовтИсп.ЗначениеКонстанты("ОрганизацияПоУмолчанию");
	ДатаПереходаНа24млн = 
		ОбщегоНазначенияПовтИсп.ЗначениеГлобальногоПараметра("2413.ДатаПереходаНаРазмерИмуществаФизЛицаКвала_24млн", '00010101');
	
	ДокументОбъект = РегистрацияИзмененийРеестра.СоздатьДокумент();
	ДокументОбъект.Дата = ДатаКвалификации;
	ДокументОбъект.Организация = Организация;
	ДокументОбъект.ЮрФизЛицо = Физлицо;
	ДокументОбъект.ВидОперации = ВидОперации;
	Если ДатаКвалификации >= ДатаПереходаНа24млн Тогда
		ДокументОбъект.ФизЛицоРазмерИмущества_24 = Истина;
	Иначе
		ДокументОбъект.ФизЛицоРазмерИмущества_12 = Истина;
	КонецЕсли;
	
	Для Каждого Категория Из QualInfo Цикл
		ЗначениеКатегории = КатегорииЦенныхБумагДляРеестра[Категория.QualSecCateg];
		Если ТипЗнч(ЗначениеКатегории) = Тип("Массив") Тогда
			Для Каждого ИмяРеквизита Из ЗначениеКатегории Цикл
				ВключитьФлагИнструмента(ДокументОбъект, ИмяРеквизита);
			КонецЦикла;
		Иначе
			ВключитьФлагИнструмента(ДокументОбъект, ЗначениеКатегории);
		КонецЕсли;
	КонецЦикла;
		
	Попытка
		ДокументОбъект.ДополнительныеСвойства.Вставить("НеВыполнятьПроверкуДатыЗапретаРедактирования", Истина);
		ДокументОбъект.Записать(РежимЗаписиДокумента.Проведение);
	Исключение
		Ошибка = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		ЗаписьЖурналаРегистрации(ИмяСобытия, УровеньЖурналаРегистрации.Ошибка, , , Ошибка);
	КонецПопытки;
КонецПроцедуры

Функция НеобходимаРегистрацияИзмененияРеестраКвалИнвесторов(Физлицо, ВидОперации, ДатаКвалификации)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	РегистрацияИзмененийРеестраКвалифицированныхИнвесторовРОФР.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.РегистрацияИзмененийРеестраКвалифицированныхИнвесторовРОФР КАК РегистрацияИзмененийРеестраКвалифицированныхИнвесторовРОФР
	|ГДЕ
	|	РегистрацияИзмененийРеестраКвалифицированныхИнвесторовРОФР.Проведен
	|	И РегистрацияИзмененийРеестраКвалифицированныхИнвесторовРОФР.ЮрФизЛицо = &ЮрФизЛицо
	|	И РегистрацияИзмененийРеестраКвалифицированныхИнвесторовРОФР.ВидОперации = &ВидОперации
	|	И НАЧАЛОПЕРИОДА(РегистрацияИзмененийРеестраКвалифицированныхИнвесторовРОФР.Дата, ДЕНЬ) = &ДатаКвалификации";
	
	Запрос.УстановитьПараметр("ВидОперации", ВидОперации);
	Запрос.УстановитьПараметр("ЮрФизЛицо", Физлицо);
	Запрос.УстановитьПараметр("ДатаКвалификации", НачалоДня(ДатаКвалификации));
	
	РезультатЗапроса = Запрос.Выполнить();
	Возврат РезультатЗапроса.Пустой();

КонецФункции

Процедура ВключитьФлагИнструмента(ДокументОбъект, ИмяРеквизита)
	Если ОбщегоНазначения.ЕстьРеквизитДокумента(ИмяРеквизита, ДокументОбъект.Метаданные()) Тогда
		ДокументОбъект[ИмяРеквизита] = Истина;
	КонецЕсли;
КонецПроцедуры

Процедура ЗаполнитьПредоставленныеДокументыДепонентаДляДержательскойСхемы(Депонент, ДанныеДоговора) // BSLLS:Typo-off
	
	Если Не ЗначениеЗаполнено(ДанныеДоговора.BrokerCode) Тогда
		Возврат;
	КонецЕсли;
	
	ВидДокументаНаименование = "Дополнительное соглашение(Держатель)";
	ВидДокумента = Справочники.ВидыДокументовУдостоверяющихПолномочия.НайтиПоНаименованию(ВидДокументаНаименование, Истина);
	Если Не ЗначениеЗаполнено(ВидДокумента) Тогда
		ТекстОшибки = СтрШаблон("Не найден вид документа ""%1""", ВидДокументаНаименование);
		ВызватьИсключение ТекстОшибки;
	КонецЕсли;
	ДатаДополнительногоСоглашения = ДанныеДоговора.AdditionalAgreementDate;
	
	Запись = РегистрыСведений.ПредоставленныеДокументы.СоздатьМенеджерЗаписи();
	Запись.Период = ДатаДополнительногоСоглашения;
	Запись.Лицо = Депонент.ЮридическиеФизическиеЛица;
	Запись.Депонент = Депонент.Ссылка;
	Запись.ВидДокумента = ВидДокумента;
	Запись.ДатаПредоставления = ДатаДополнительногоСоглашения;
	Запись.Примечание = СтрШаблон("Дополнительное соглашение № %1 от %2",
		ДанныеДоговора.AdditionalAgreementNumber, Формат(ДатаДополнительногоСоглашения, "ДФ=dd.MM.yyyy"));
	Запись.Записать();
	
КонецПроцедуры

#КонецОбласти

