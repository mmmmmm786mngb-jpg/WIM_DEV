Функция ВидЛицензииИзJSON(ОбозначениеИзJSON)
	
	ВидыЛицензий = Справочники.ВидыЛицензий;
	ЗаглавнымиОбозначениеИзJSON = Врег(ОбозначениеИзJSON);
	
	Если ЗаглавнымиОбозначениеИзJSON = "BANK" Тогда
		ВидЛицензии = ВидыЛицензий.БанковскаяДеятельность;
	ИначеЕсли ЗаглавнымиОбозначениеИзJSON = "BROK" Тогда
		ВидЛицензии = ВидыЛицензий.БрокерскаяДеятельность;
	ИначеЕсли ЗаглавнымиОбозначениеИзJSON = "DEAL" Тогда
		ВидЛицензии = ВидыЛицензий.ДилерскаяДеятельность;
	ИначеЕсли ЗаглавнымиОбозначениеИзJSON = "DEPO" Тогда
		ВидЛицензии = ВидыЛицензий.ДепозитарнаяДеятельность;
	ИначеЕсли ЗаглавнымиОбозначениеИзJSON = "SECUR" Тогда
		ВидЛицензии = ВидыЛицензий.ДеятельностьДоверительногоУправления;
	ИначеЕсли ЗаглавнымиОбозначениеИзJSON = "ENSUR" Тогда
		ВидЛицензии = ВидыЛицензий.СтраховаяДеятельность;
	ИначеЕсли ЗаглавнымиОбозначениеИзJSON = "FOUND" Тогда
		ВидЛицензии = ВидыЛицензий.ДеятельностьПоУправлениюИФ_ПИФ_НПФ;
	ИначеЕсли ЗаглавнымиОбозначениеИзJSON = "CLEAR" Тогда
		ВидЛицензии = ВидыЛицензий.КлиринговаяДеятельность;
	ИначеЕсли ЗаглавнымиОбозначениеИзJSON = "STOCK" Тогда
		ВидЛицензии = ВидыЛицензий.ОрганизацияБиржевойТорговли;
	ИначеЕсли ЗаглавнымиОбозначениеИзJSON = "REG" Тогда
		ВидЛицензии = ВидыЛицензий.РегистраторскаяДеятельность;
	ИначеЕсли ЗаглавнымиОбозначениеИзJSON = "PENS" Тогда
		ВидЛицензии = ВидыЛицензий.ПенсионноеОбеспечениеИПенсионноеСтрахование;
	ИначеЕсли ЗаглавнымиОбозначениеИзJSON = "OTHER" Тогда
		ВидЛицензии = ВидыЛицензий.Иная;
	Иначе
		ВызватьИсключение "Не предусмотренное обозначение вида лицензии: " + ОбозначениеИзJSON;
	КонецЕсли;
	
	Возврат ВидЛицензии;
КонецФункции

Функция ТипДепонентаИзJSON(КодИзJSON)
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	ТипыДепонентов.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.ТипыДепонентов КАК ТипыДепонентов
	|ГДЕ
	|	ТипыДепонентов.Код = &КодИзJSON
	|	И НЕ ТипыДепонентов.ПометкаУдаления";
	Запрос.УстановитьПараметр("КодИзJSON", КодИзJSON);
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() Тогда
		ВызватьИсключение "Не найден в справочнике типов депонентов код: " + КодИзJSON;
	Иначе
		Выборка = РезультатЗапроса.Выбрать();
		Выборка.Следующий();
		ТипДепонента = Выборка.Ссылка;
	КонецЕсли;
	
	Возврат ТипДепонента;
КонецФункции

