КонецПроцедуры

Процедура ЗарегистрироватьФИО(СтрФизлицо, ФизЛицо)
	
	ОбновитьДанныеФИО = Ложь;
	
	ОтборФизЛицо=Новый Структура("ФизЛицо", ФизЛицо);
	
	ФИОФизЛиц=РегистрыСведений.ФИОФизЛиц.СрезПоследних( , Новый Структура("ФизЛицо", ФизЛицо));
	
	Если ФИОФизЛиц.Количество() = 1 Тогда
		ОбновитьДанныеФИО = (ФИОФизЛиц[0].Фамилия <> СтрФизлицо.LastName) Или (ФИОФизЛиц[0].Имя <> СтрФизлицо.FirstName) Или (ФИОФизЛиц[0].Отчество <> СтрФизлицо.MiddleName);
	Иначе
		ОбновитьДанныеФИО = Истина;
	КонецЕсли;
	
	Если ОбновитьДанныеФИО Тогда
		НоваяЗаписьФИО = РегистрыСведений.ФИОФизЛиц.СоздатьМенеджерЗаписи();
		НоваяЗаписьФИО.ФизЛицо = ФизЛицо;
		НоваяЗаписьФИО.Период = ТекущаяДатаСеанса();
		НоваяЗаписьФИО.Фамилия = СтрФизлицо.LastName;
		НоваяЗаписьФИО.Имя = СтрФизлицо.FirstName;
		НоваяЗаписьФИО.Отчество = СтрФизлицо.MiddleName;
		НоваяЗаписьФИО.Записать();
	КонецЕсли;
	
КонецПроцедуры

Процедура ЗарегистрироватьПаспортныеДанные(ПаспортныеДанные, ФизЛицо)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ВЫБОР
		|		КОГДА ПаспортныеДанныеФизЛицСрезПоследних.ДокументСерия = &ДокументСерия
		|				И ПаспортныеДанныеФизЛицСрезПоследних.ДокументНомер = &ДокументНомер
		|				И ПаспортныеДанныеФизЛицСрезПоследних.ДокументВид = &ВидДокумента
		|			ТОГДА ПаспортныеДанныеФизЛицСрезПоследних.Период
		|		ИНАЧЕ &ТекущаяДата
		|	КОНЕЦ КАК Период
		|ИЗ
		|	РегистрСведений.ПаспортныеДанныеФизЛиц.СрезПоследних(, ФизЛицо = &ФизЛицо) КАК ПаспортныеДанныеФизЛицСрезПоследних";
	
	Запрос.УстановитьПараметр("ФизЛицо", ФизЛицо);
	ТекущаяДата = ТекущаяДатаСеанса();
	ДокументНомер = НомерДокумента(ПаспортныеДанные.Number);
	ДокументСерия = СерияДокумента(ПаспортныеДанные.Series);
	Запрос.УстановитьПараметр("ДокументСерия", ДокументСерия);
	Запрос.УстановитьПараметр("ДокументНомер", ДокументНомер);
	Запрос.УстановитьПараметр("ТекущаяДата", ТекущаяДата);
	ВидДокумента = ВидДокументаПоИдентификаторуВида(ПаспортныеДанные.DocumentType);
	Запрос.УстановитьПараметр("ВидДокумента", ВидДокумента);
	
	РезультатЗапроса = Запрос.Выполнить();
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Запись = РегистрыСведений.ПаспортныеДанныеФизЛиц.СоздатьМенеджерЗаписи();
	Запись.ФизЛицо = ФизЛицо;
	Запись.Период = ?(ВыборкаДетальныеЗаписи.Следующий(), ВыборкаДетальныеЗаписи.Период, ТекущаяДата);
	Запись.ДокументВид = ВидДокумента;
	Запись.ДокументНомер = ДокументНомер;
	Запись.ДокументСерия = ДокументСерия;
	Запись.ДокументКемВыдан = ПаспортныеДанные.Issuer;
	Запись.ДокументДатаВыдачи = ПаспортныеДанные.IssueDate;
	Запись.ДокументКодПодразделения = ПаспортныеДанные.IssuerCode;
	Запись.Записать();
	
КонецПроцедуры

Процедура ЗарегистрироватьГражданствоФизЛица(ФизЛицо, ПерезаписываемКонтрагента)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ВЫБОР
		|		КОГДА ГражданствоФизЛицСрезПоследних.Период ЕСТЬ NULL
		|			ТОГДА ФизическиеЛица.ДатаРождения
		|		ИНАЧЕ &ТекущаяДата
		|	КОНЕЦ КАК Период
		|ИЗ
		|	Справочник.ФизическиеЛица КАК ФизическиеЛица
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ГражданствоФизЛиц.СрезПоследних(, ФизЛицо = &ФизЛицо) КАК ГражданствоФизЛицСрезПоследних
		|		ПО (ГражданствоФизЛицСрезПоследних.ФизЛицо = ФизическиеЛица.Ссылка)
		|ГДЕ
		|	ФизическиеЛица.Ссылка = &ФизЛицо
		|	И ВЫБОР
		|			КОГДА ГражданствоФизЛицСрезПоследних.Страна = &Страна
		|					И ГражданствоФизЛицСрезПоследних.НеЯвляетсяНалоговымРезидентомРФ = &НеЯвляетсяНалоговымРезидентомРФ
		|				ТОГДА ЛОЖЬ
		|			ИНАЧЕ ИСТИНА
		|		КОНЕЦ";
	
	Страна = СтранаПоКодуАльфа2(PersonInfo[0].Citizenship);
	НеЯвляетсяНалоговымРезидентомРФ = Не ClientTaxInfo[0].RuTaxResident;
	ТекущаяДата = ТекущаяДатаСеанса();
	
	Запрос.УстановитьПараметр("ФизЛицо", ФизЛицо);
	Запрос.УстановитьПараметр("Страна", Страна);
	Запрос.УстановитьПараметр("НеЯвляетсяНалоговымРезидентомРФ", НеЯвляетсяНалоговымРезидентомРФ);
	Запрос.УстановитьПараметр("ТекущаяДата", ТекущаяДата);
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда
		ПерезаписываемКонтрагента = Истина;
		Запись = РегистрыСведений.ГражданствоФизЛиц.СоздатьМенеджерЗаписи();
		Запись.ФизЛицо = ФизЛицо;
		Запись.Период = ВыборкаДетальныеЗаписи.Период;
		Запись.Страна = Страна;
		Запись.НеЯвляетсяНалоговымРезидентомРФ = НеЯвляетсяНалоговымРезидентомРФ;
		Запись.Записать();
	КонецЕсли;
	
КонецПроцедуры
	
Процедура ЗарегистрироватьАдресаЮрФизЛица(ЮрФизЛицо, ДанныеКИФизЛица, ВидыКИЮрФизЛица)
	
	Для Каждого СтрокаАдреса Из ClientAddresses Цикл
		
		Вид = ВидАдресаИзJSON(ВРег(СтрокаАдреса.AddrType), ВидыКИЮрФизЛица);
		Если Не ЗначениеЗаполнено(Вид) Или ПустаяСтрока(СтрокаАдреса.AddrValue) Тогда
			Продолжить;
		КонецЕсли;
		
		ПараметрыОтбора = Новый Структура("Вид", Вид);
		Записи = ДанныеКИФизЛица.НайтиСтроки(ПараметрыОтбора);
		Если Записи.Количество() Тогда
			НайденнаяСтрока = Записи[0];
			Период = НайденнаяСтрока.Период;
		ИначеЕсли Не ЗначениеЗаполнено(СтрокаАдреса.AddrDate) Тогда
			Период = Дата(2000, 1, 1);
		Иначе
			Период = СтрокаАдреса.AddrDate;
		КонецЕсли;
		
		МенеджерЗаписи 			= РегистрыСведений.КонтактнаяИнформация.СоздатьМенеджерЗаписи();
		МенеджерЗаписи.Период 	= Период;
		МенеджерЗаписи.Объект 	= ЮрФизЛицо;
		МенеджерЗаписи.Тип 		= Перечисления.ТипыКонтактнойИнформации.Адрес;
		МенеджерЗаписи.Вид		= Вид;
		Если ВРег(СтрокаАдреса.Country) <> "РОССИЯ" Тогда
			МенеджерЗаписи.Поле1 = СтрокаАдреса.Страна;
			МенеджерЗаписи.ЭтоРоссийскийАдрес = Ложь;
		Иначе
			МенеджерЗаписи.Поле1 = СтрокаАдреса.Index;
			МенеджерЗаписи.ЭтоРоссийскийАдрес = Истина;
		КонецЕсли;
		МенеджерЗаписи.Представление = СтрокаАдреса.AddrValue;
		МенеджерЗаписи.Поле2 = СтрокаАдреса.Region;
		МенеджерЗаписи.Поле3 = СтрокаАдреса.Area;
		МенеджерЗаписи.Поле4 = СтрокаАдреса.Town;
		МенеджерЗаписи.Поле5 = СтрокаАдреса.Locality;
		МенеджерЗаписи.Поле6 = СтрокаАдреса.Street;
		МенеджерЗаписи.Поле7 = СтрокаАдреса.House;
		МенеджерЗаписи.Поле8 = СтрокаАдреса.Housing;
		МенеджерЗаписи.Поле9 = СтрокаАдреса.Office;
		МенеджерЗаписи.Записать();
	КонецЦикла;
	
КонецПроцедуры

Процедура ЗарегистрироватьКонтактыЮрФизЛица(ЮрФизЛицо, ДанныеКИФизЛица, ВидыКИЮрФизЛица)
	
	Для Каждого Контакт Из ClientContacts Цикл
		Если НРег(Контакт.ContactType) = "phone" Тогда
			Тип = Перечисления.ТипыКонтактнойИнформации.Телефон;
			Вид = ВидыКИЮрФизЛица.Телефон;
		ИначеЕсли НРег(Контакт.ContactType) = "mail" Тогда
			Тип = Перечисления.ТипыКонтактнойИнформации.АдресЭлектроннойПочты;
			Вид = ВидыКИЮрФизЛица.Email;
		Иначе
			Продолжить;
		КонецЕсли;
		Если ПустаяСтрока(Контакт.ContactValue) Тогда
			Продолжить;
		КонецЕсли;
		
		ПараметрыОтбора = Новый Структура("Вид", Вид);
		Записи = ДанныеКИФизЛица.НайтиСтроки(ПараметрыОтбора);
		Если Записи.Количество() Тогда
			НайденнаяСтрока = Записи[0];
			Период = НайденнаяСтрока.Период;
		Иначе
			Период = ТекущаяДатаСеанса();
		КонецЕсли;
		
		МенеджерЗаписи 					= РегистрыСведений.КонтактнаяИнформация.СоздатьМенеджерЗаписи();
		МенеджерЗаписи.Период 			= Период;
		МенеджерЗаписи.Объект 			= ЮрФизЛицо;
		МенеджерЗаписи.Тип				= Тип;
		МенеджерЗаписи.Вид				= Вид;
		МенеджерЗаписи.Представление 	= Контакт.ContactValue;
		МенеджерЗаписи.Записать();
	КонецЦикла;
	
КонецПроцедуры
	
