Процедура УстановитьУслугиПоДоговору(Договор, КодТарифаCRM)
	
	Набор = РегистрыСведений.РегистрНазначенныхКомиссий.СоздатьНаборЗаписей();
	Набор.Отбор.ДоговорКонтрагента.Установить(Договор);
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	УслугиТП.Услуга КАК Услуга
	|ИЗ
	|	Справочник.ТарифныеПланы КАК ТарифныеПланы
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ТарифныеПланы.УслугиТарифногоПлана КАК УслугиТП
	|		ПО (ТарифныеПланы.Ссылка = УслугиТП.Ссылка
	|				И ТарифныеПланы.КодТарифаCRM = &КодТарифаCRM
	|				И НЕ УслугиТП.Услуга.НеИспользуется)";
	Запрос.УстановитьПараметр("КодТарифаCRM", КодТарифаCRM);
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		Запись = Набор.Добавить();
		Запись.Период = Договор.ДатаНачалоДействия;
		Запись.ДоговорКонтрагента = Договор;
		Запись.Услуга = Выборка.Услуга;
		Запись.ФлагАктивности = Истина;
	КонецЦикла;
	Набор.Записать();
	
КонецПроцедуры

Функция ПолучитьДанныеКИ(ФизЛицо, ВидыКИ)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	КонтактнаяИнформацияСрезПоследних.Период КАК Период,
	|	КонтактнаяИнформацияСрезПоследних.Объект КАК Объект,
	|	КонтактнаяИнформацияСрезПоследних.Тип КАК Тип,
	|	КонтактнаяИнформацияСрезПоследних.Вид КАК Вид
	|ИЗ
	|	РегистрСведений.КонтактнаяИнформация.СрезПоследних(
	|			,
	|			Объект = &ФизЛицо
	|				И Вид В (&ВидыКИ)) КАК КонтактнаяИнформацияСрезПоследних";
	
	Запрос.УстановитьПараметр("ВидыКИ", ВидыКИ);
	Запрос.УстановитьПараметр("ФизЛицо", ФизЛицо);
	
	ДанныеКИФизЛица = Запрос.Выполнить().Выгрузить();
	Возврат ДанныеКИФизЛица;

КонецФункции

Процедура ЗарегистрироватьКлиентскиеМенеджерыЮрФизЛица(ЮрФизЛицо)
	МенеджерыЮрФизЛица = МенеджерыЮрФизЛица(ЮрФизЛицо);
	Для Каждого Менеджер Из ManagerInfo Цикл
		НеобходимаЗапись = Ложь;
		МенеджерЗаписи = РегистрыСведений.КлиентскиеМенеджеры.СоздатьМенеджерЗаписи();
		МенеджерЗаписи.ЮрФизЛицо = ЮрФизЛицо;
		НайденныйМенеджер = МенеджерыЮрФизЛица.Найти(Менеджер.ManagerID, "Идентификатор");
		Если НайденныйМенеджер = Неопределено Тогда
			МенеджерЗаписи.Период = ТекущаяДатаСеанса();
			МенеджерЗаписи.Идентификатор = Менеджер.ManagerID;
			МенеджерЗаписи.КлиентскийМенеджер = Менеджер.FIO;
			НеобходимаЗапись = Истина;
		КонецЕсли;
		Если НайденныйМенеджер <> Неопределено И НайденныйМенеджер.КлиентскийМенеджер <> Менеджер.FIO Тогда
			ЗаполнитьЗначенияСвойств(МенеджерЗаписи, НайденныйМенеджер, , "КлиентскийМенеджер");
			МенеджерЗаписи.КлиентскийМенеджер = Менеджер.FIO;
			НеобходимаЗапись = Истина;
		КонецЕсли;
		Если НеобходимаЗапись Тогда
			МенеджерЗаписи.Записать();
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

Функция МенеджерыЮрФизЛица(ЮрФизЛицо)
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	КлиентскиеМенеджеры.Период КАК Период,
	|	КлиентскиеМенеджеры.Идентификатор КАК Идентификатор,
	|	КлиентскиеМенеджеры.КлиентскийМенеджер КАК КлиентскийМенеджер
	|ИЗ
	|	РегистрСведений.КлиентскиеМенеджеры КАК КлиентскиеМенеджеры
	|ГДЕ
	|	КлиентскиеМенеджеры.ЮрФизЛицо = &ЮрФизЛицо";
	
	Запрос.УстановитьПараметр("ЮрФизЛицо", ЮрФизЛицо);
	Возврат Запрос.Выполнить().Выгрузить();
КонецФункции

Процедура ЗарегистрироватьКатегорииРолейФизлицаСогласноУказов81и95(ФизЛицо, НовоеФизЛицо, НалоговыеДанныеКлиента)
	ДанныеСообщения = MessageInfo[0];
	ЗарегистрироватьКатегорииРолей = НовоеФизЛицо И НРег(ДанныеСообщения.MessageType) = "client"
		И НалоговыеДанныеКлиента.RuTaxResident;
	Если ЗарегистрироватьКатегорииРолей Тогда
		МенеджерЗаписи = РегистрыСведений.КатегорииРолейКлиентовСогласноУказов81и95.СоздатьМенеджерЗаписи();
		МенеджерЗаписи.Период = ТекущаяДатаСеанса();
		МенеджерЗаписи.ЮрФизЛицо = ФизЛицо;
		МенеджерЗаписи.КатегорияРоли =
			Справочники.КатегорииРолейКлиентовСогласноУказов81и95.РоссийскийРезидентПодКонтролемРоссийскихРезидентов;
		МенеджерЗаписи.Записать();
	КонецЕсли;
КонецПроцедуры

#КонецОбласти

#Область ФормированиеПорученийНаОткрытиеСчетовДепо

Процедура СформироватьПорученияИОперации() Экспорт
	
	ДанныеДоговора = Contract[0];
	ДоговорОбъект = ДанныеДоговора.Договор.ПолучитьОбъект();
	ТипыСчетовДепо = ТипыСчетовДепо(ДанныеДоговора);
	Если ТипыСчетовДепо = Неопределено Тогда
		ВызватьИсключение "Не определен тип счета депо " + ДанныеДоговора.DepoAccountSectionType;
	КонецЕсли;
	СтруктураРазделовМХ = ОбщегоНазначения.ПолучитьЗначенияРеквизитовШапкиОбъектаПоУмолчанию(
		"Обработка.РегистрацияКлиентаЧерезKafka", Новый Структура,
		?(ДанныеДоговора.IsClientGrantedRightsUseSecurities, "МХ_СПИпоУмолчанию", "МХ_БПИпоУмолчанию"));
		
	МХОсновной = СтруктураРазделовМХ.МХОсновной;
	МХОбеспечения = СтруктураРазделовМХ.МХОбеспечения;
		
	ДатаПоручения = ТекущаяДатаСеанса();
	
	ПараметрыПоручений = Новый Структура();
	ПараметрыПоручений.Вставить("ДатаПоручения", ДатаПоручения);
	ПараметрыПоручений.Вставить("Контрагент", ДоговорОбъект.Владелец);
	ПараметрыПоручений.Вставить("СпособПриемаПоручений", Справочники.СпособыПриемаПоручений.ЭлектронныйВид());
	
	НовыйВходящийНаОткрытиеСчетовДепо(ПараметрыПоручений);
	
	Поручение = НовоеПоручениеНаОткрытиеСчетаДепо(ТипыСчетовДепо.Основной, ПараметрыПоручений);	
	СчетДепо = СчетДепоПоПоручению(Поручение);
	
	ДоговорОбъект.СчетДепо = СчетДепо;
	ДоговорОбъект.Записать();
	
	//МестоХранения
	НовоеПоручениеНаОткрытиеРазделаСчетаДепо(Перечисления.ТипыРазделовСчетовДЕПО.Основной, СчетДепо, МХОсновной, ПараметрыПоручений);
		
	Поручение = НовоеПоручениеНаОткрытиеСчетаДепо(ТипыСчетовДепо.Торговый, ПараметрыПоручений);
	СчетДепоТорговый = СчетДепоПоПоручению(Поручение);
	
	//МестоХраненияОбеспечения
	ТипыРазделовСчетовДЕПО = Перечисления.ТипыРазделовСчетовДЕПО;
	Если ЗначениеЗаполнено(ДанныеДоговора.BrokerCode) Тогда
		ТипРазделаСчетаДепо = ТипыРазделовСчетовДЕПО.ОбеспеченияДержатель;
		ПараметрыПоручений.Вставить("ДанныеДоговора", ДанныеДоговора);
		ПараметрыПоручений.Вставить("НомерДоговораДепо", ДоговорОбъект.Код);
		ПараметрыПоручений.Вставить("ДатаДоговораДепо", ДоговорОбъект.ДатаНачалоДействия);
	Иначе
		ТипРазделаСчетаДепо = ТипыРазделовСчетовДЕПО.Обеспечения;
	КонецЕсли;
	НовоеПоручениеНаОткрытиеРазделаСчетаДепо(ТипРазделаСчетаДепо, СчетДепоТорговый, МХОбеспечения, ПараметрыПоручений);
	
КонецПроцедуры

Функция ТипыСчетовДепо(ДанныеДоговора)
	
	ТипДепозитарногоСчета = СокрЛП(ДанныеДоговора.DepoAccountSectionType);
	ТипыСчетов = Новый Структура;
	
	Если НРег(ТипДепозитарногоСчета) = "owner" Тогда
		ТипыСчетов.Вставить("Основной", Перечисления.ТипыСчетовДепо.Владельца);
		ТипыСчетов.Вставить("Торговый", Перечисления.ТипыСчетовДепо.ВладельцаТорговый);
	Иначе
		ТипыСчетов = Неопределено;
	КонецЕсли;
	
	Возврат ТипыСчетов;
КонецФункции

Функция НовыйВходящийНаОткрытиеСчетовДепо(ПараметрыПоручений)
	
	Входящий 					= Документы.Входящий.СоздатьДокумент();
	Входящий.Дата 				= ПараметрыПоручений.ДатаПоручения;
	Входящий.ДатаОтправления 	= ПараметрыПоручений.ДатаПоручения;
	Входящий.Депонент 			= ПараметрыПоручений.Контрагент.Ссылка;
	Входящий.ИсходящийНомер 	= "б/н";
	Входящий.Комментарий 		= "Оригинал";
	Входящий.РучнойВвод 		= Ложь;
	Входящий.ЦеннаяБумага 		= Справочники.ЦенныеБумаги.ПустаяСсылка();
	Входящий.Исполнитель 		= Константы.ПользовательРобот.Получить();
	Входящий.ЛицоНаправившееДокумент 			= ПараметрыПоручений.Контрагент.Наименование;
	Входящий.НаименованиеДокументаИлиКомплекта 	= "Комплект документов (в соответствии с Прилож.02 к РДО)";
	Входящий.Записать(РежимЗаписиДокумента.Проведение);
	
	Возврат Входящий;	

КонецФункции 

Функция НовоеПоручениеНаОткрытиеСчетаДепо(ТипСчетаДепо, ПараметрыПоручений)
	
	Поручение = Документы.Поручение.СоздатьДокумент();
	Поручение.Дата = ПараметрыПоручений.ДатаПоручения;
	Поручение.ДатаПриема = ПараметрыПоручений.ДатаПоручения;
	Поручение.Инициатор = ПараметрыПоручений.Контрагент.Ссылка;
	Поручение.Депонент = ПараметрыПоручений.Контрагент.Ссылка;
	Поручение.ВидОперацииД = Справочники.ВидыОпераций.ОткрытиеСчетаДепо;
	Поручение.ТипСчетаДепо = ТипСчетаДепо;
	Поручение.ВидСчетаДепо = Перечисления.ВидыСчетовДепо.СчетДЕПО;
	Поручение.ДатаИсполненияПоручения = ПараметрыПоручений.ДатаПоручения + 1;
	Поручение.СпособПриемаПоручений = ПараметрыПоручений.СпособПриемаПоручений;
	Поручение.СчетДепоМХ = СчетДепоМХПоручения(Поручение.Депонент, ТипСчетаДепо);
	Поручение.УстановитьНовыйНомер();
	Поручение.Записать(РежимЗаписиДокумента.Проведение);
	
	Возврат Поручение;
	
КонецФункции

Функция НовоеПоручениеНаОткрытиеРазделаСчетаДепо(ТипРазделаСчетаДепо, СчетДепо, ДепозитарийМХ, ПараметрыПоручений)
	
	Поручение = Документы.Поручение.СоздатьДокумент();
	Поручение.Дата = ПараметрыПоручений.ДатаПоручения;
	Поручение.ДатаПриема = ПараметрыПоручений.ДатаПоручения;
	Поручение.Инициатор = ПараметрыПоручений.Контрагент.Ссылка;
	Поручение.Депонент = ПараметрыПоручений.Контрагент.Ссылка;
	Поручение.ВидОперацииД = Справочники.ВидыОпераций.ОткрытиеРазделаСчетаДепо;
	Поручение.ТипСчетаДепо = СчетДепо.ТипСчетаДепо;
	Поручение.СчетДепо = СчетДепо;
	Поручение.ТипРазделаСчетаДЕПО = ТипРазделаСчетаДепо;
	Если ТипРазделаСчетаДепо = Перечисления.ТипыРазделовСчетовДЕПО.Налоговый Тогда
		Поручение.РазделСчетаДепоМХ = "";
		Поручение.СчетДепоМХ = ДепозитарийМХ.Владелец;
		Если Не ЗначениеЗаполнено(Поручение.СчетДепоМХ) Тогда
			Сообщение = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
				"Не найден СчетДепоМХ для открытия налогового раздела! (НомерРаздела=%1, НомерСчета=%2)",
				ДепозитарийМХ.НомерРаздела,
				ДепозитарийМХ.НомерСчета);
			ЗаписьЖурналаРегистрации(ИмяСобытия, УровеньЖурналаРегистрации.Ошибка, , , Сообщение);
			ВызватьИсключение Сообщение;
		КонецЕсли;
		НомерНалоговогоРазделаНРД = Константы.НомерНалоговогоРазделаНРД.Получить();
		Поручение.НомерРазделаСчетаДепоМХ = Лев(НомерНалоговогоРазделаНРД, 7) + СокрЛП(Поручение.Депонент.Код) + Поручение.Субклиент.Код;
		Поручение.ОткрытьВМХ = Истина;
	ИначеЕсли ТипРазделаСчетаДепо = Перечисления.ТипыРазделовСчетовДЕПО.ОбеспеченияДержатель Тогда
		ЗаполнитьПоручениеДляДержательскойСхемы(Поручение, ДепозитарийМХ, ПараметрыПоручений);
	Иначе	
		Поручение.РазделСчетаДепоМХ = ДепозитарийМХ;
		Поручение.ДатаИсполненияПоручения = ПараметрыПоручений.ДатаПоручения + 1;
	КонецЕсли;
	Поручение.СпособПриемаПоручений = ПараметрыПоручений.СпособПриемаПоручений;
	Поручение.УстановитьНовыйНомер();
	Поручение.Записать(РежимЗаписиДокумента.Проведение);
	
	Возврат Поручение.Ссылка;
	
КонецФункции

Функция СчетДепоПоПоручению(Поручение)

	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	ОткрытиеСчетаДепо.СчетДепо КАК СчетДепо
	|ИЗ
	|	Документ.ОткрытиеСчетаДепо КАК ОткрытиеСчетаДепо
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.Поручение КАК Поручение
	|		ПО ОткрытиеСчетаДепо.ДокументОснование = Поручение.Ссылка
	|ГДЕ
	|	Поручение.Ссылка = &Поручение");
	Запрос.УстановитьПараметр("Поручение", Поручение.Ссылка);
	Результат = Запрос.Выполнить();
	Если Результат.Пустой() Тогда
		
		ЗаписьЖурналаРегистрации(ИмяСобытия, УровеньЖурналаРегистрации.Ошибка, , , "Не создан счет Депо после проведения поручения на открытие счета Депо!");
		ВызватьИсключение "Не создан счет Депо после проведения поручения на открытие счета Депо!";
		
	КонецЕсли;
	
	Выборка = Результат.Выбрать();
	Выборка.Следующий();
	Возврат Выборка.СчетДепо;
	
КонецФункции

#КонецОбласти

#Область ВспомогательныеПроцедуры

Функция ПолФизЛица(Sex)
	НРегSex = НРег(Sex);
	Если НРегSex = "m" Тогда
		Пол = Перечисления.ПолФизическихЛиц.Мужской;
	ИначеЕсли НРегSex = "f" Тогда
		Пол = Перечисления.ПолФизическихЛиц.Женский;
	Иначе
		ВызватьИсключение "Не удалось определить пол";
	КонецЕсли;

	Возврат Пол;
КонецФункции

Функция ВидДокументаПоИдентификаторуВида(DocumentType)
	ВРегDocumentType = ВРег(DocumentType);
	Если ВРегDocumentType = "FOREIGN_PASS" Тогда
		// Заграничный паспорт для постоянно проживающих за границей граждан, которые временно находятся на территории Российской Федерации
		ВидДокумента = Справочники.ДокументыУдостоверяющиеЛичность.ИМНС10;
	Иначе 	// В том числе ВРегDocumentType = "PASS" - паспорт гражданина РФ, действующий на территории РФ с 1 октября 1997 года
			// и любые другие докуметы пока тоже обрабатываем тоже как паспорт гражданина РФ
		ВидДокумента = Справочники.ДокументыУдостоверяющиеЛичность.ИМНС21;
	КонецЕсли;
	
	Возврат ВидДокумента;
КонецФункции

Функция ЭтоПаспорт(DocumentType)
	ВРегDocumentType = ВРег(DocumentType);
	ЭтоПаспорт = (ВРегDocumentType = "PASS" Или ВРегDocumentType = "FOREIGN_PASS");
	
	Возврат ЭтоПаспорт;
КонецФункции

Функция ФизлицоПоПаспорту(Серия, Номер, DocumentType)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ПаспортныеДанныеФизЛицСрезПоследних.ФизЛицо КАК ФизЛицо
	|ИЗ
	|	РегистрСведений.ПаспортныеДанныеФизЛиц.СрезПоследних(
	|			,
	|			ДокументВид = &ВидДокумента
	|				И ДокументСерия = &ДокументСерия
	|				И ДокументНомер = &ДокументНомер) КАК ПаспортныеДанныеФизЛицСрезПоследних";
	Запрос.УстановитьПараметр("ДокументСерия", СерияДокумента(Серия));
	Запрос.УстановитьПараметр("ДокументНомер", НомерДокумента(Номер));
	ВидДокумента = ВидДокументаПоИдентификаторуВида(DocumentType);
	Запрос.УстановитьПараметр("ВидДокумента", ВидДокумента);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.ФизЛицо;
	Иначе
		Возврат Справочники.ФизическиеЛица.ПустаяСсылка();
	КонецЕсли;
	
КонецФункции

Функция ФизЛицоПоИНН(ИНН)
	ФизЛицо = Справочники.ФизическиеЛица.ПустаяСсылка();
	
	Если Не ПустаяСтрока(ИНН) Тогда
		Запрос = Новый Запрос(
		"ВЫБРАТЬ
		|	ФизическиеЛица.Ссылка КАК ФизЛицо
		|ИЗ
		|	Справочник.ФизическиеЛица КАК ФизическиеЛица
		|ГДЕ
		|	ФизическиеЛица.ИНН = &ИНН
		|	И НЕ ФизическиеЛица.ПометкаУдаления");
		Запрос.УстановитьПараметр("ИНН", СокрЛП(ИНН));
		Выборка = Запрос.Выполнить().Выбрать();
		Если Выборка.Следующий() Тогда
			ФизЛицо = Выборка.ФизЛицо;
		КонецЕсли;
	КонецЕсли;
	
	Возврат ФизЛицо;
КонецФункции

Функция СерияДокумента(Знач ДокументНомер)
	
	Серия = Лев(СтрЗаменить(ДокументНомер, " ", ""), 4);
	Возврат Лев(Серия, 2) + " " + Прав(Серия, 2);
	
КонецФункции

Функция НомерДокумента(Знач ДокументНомер)
	
	НомерДокумента = СтрЗаменить(СокрЛП(ДокументНомер), " ", "");
	Возврат НомерДокумента;
	
КонецФункции

Функция СтранаПоКодуАльфа2(Код)
	
	Страна = Справочники.КлассификаторСтранМира.СтранаПоКодуАльфа2(Код);
	Если Страна = Справочники.КлассификаторСтранМира.ПустаяСсылка() Или Страна = Неопределено Тогда
		Страна = СтранаИзКлассификатора(Код);
	КонецЕсли; 
	
	Возврат Страна;
	
КонецФункции

Функция РезидентПоСтране(Страна)
	Возврат Страна = Справочники.КлассификаторСтранМира.РОССИЯ;
КонецФункции

Функция СтранаИзКлассификатора(Код)
	
	Если Код = "" Тогда
		Возврат Справочники.КлассификаторСтранМира.ПустаяСсылка();
	КонецЕсли;
	
	Макет = Справочники.КлассификаторСтранМира.ПолучитьМакет("КлассификаторСтранМира");
	ТекущаяОбласть = Макет.НайтиТекст(Код, , , , Истина);
	
	Если ТекущаяОбласть = Неопределено Тогда
		Возврат Справочники.КлассификаторСтранМира.ПустаяСсылка();
	КонецЕсли; 
	
	ОбластьКодЧисловой			= Макет.Области.КодЧисловой;
	ОбластьНаименованиеКраткое	= Макет.Области.НаименованиеКраткое;
	ОбластьНаименованиеПолное	= Макет.Области.НаименованиеПолное;
	ОбластьКодАльфа2 			= Макет.Области.КодАльфа2;
	
	КодЧисловой         = Макет.Область(ТекущаяОбласть.Верх, ОбластьКодЧисловой.Лево, ТекущаяОбласть.Низ, ОбластьКодЧисловой.Право).Текст;
	НаименованиеКраткое = Макет.Область(ТекущаяОбласть.Верх, ОбластьНаименованиеКраткое.Лево, ТекущаяОбласть.Низ, ОбластьНаименованиеКраткое.Право).Текст;
	НаименованиеПолное  = Макет.Область(ТекущаяОбласть.Верх, ОбластьНаименованиеПолное.Лево, ТекущаяОбласть.Низ, ОбластьНаименованиеПолное.Право).Текст;
	КодАльфа2			= Макет.Область(ТекущаяОбласть.Верх, ОбластьКодАльфа2.Лево, ТекущаяОбласть.Низ, ОбластьКодАльфа2.Право).Текст;
	
	// Создание новой страны
	Элемент = Справочники.КлассификаторСтранМира.СоздатьЭлемент();
	Элемент.Код					= КодЧисловой;
	Элемент.Наименование		= НаименованиеКраткое;
	Элемент.НаименованиеПолное	= НаименованиеПолное;
	Элемент.КодАльфа2			= КодАльфа2;
	Элемент.Записать();
	Возврат Элемент.Ссылка;
	
КонецФункции

Функция СтруктураСообщенияОшибки(CrmClientId, ErrorDescription)
	
	ТекущаяДата = ТекущаяДатаСеанса();
	СтруктураMessageInfo = Новый Структура;
	СтруктураMessageInfo.Вставить("MessageId", Строка(Новый УникальныйИдентификатор()));
	СтруктураMessageInfo.Вставить("MasterMessageId", ?(НРег(MessageInfo[0].MasterMessageId) = "null",
									СтруктураMessageInfo.MessageId, MessageInfo[0].MasterMessageId));
	СтруктураMessageInfo.Вставить("ParentMessageId", MessageInfo[0].MessageId);
	СтруктураMessageInfo.Вставить("DateTimeCreate", ТекущаяДата);
	СтруктураMessageInfo.Вставить("SystemSource", "Depo");
	
	Data = ОбменДаннымиКафка.СообщениеОбОшибкеБлокData();
	Data.ErrorDescription = ErrorDescription;
	Data.Вставить("CrmClientId", CrmClientId);
	
	Результат = Новый Структура("MessageInfo,Data", СтруктураMessageInfo, Data);
	Возврат Результат;
	
КонецФункции

