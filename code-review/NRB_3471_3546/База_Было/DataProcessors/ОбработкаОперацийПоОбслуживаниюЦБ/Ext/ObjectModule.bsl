Перем КэшДат;

Процедура СформироватьПорученияПриемаИСнятия() Экспорт
	
	Если ПериодКонец >= ПериодНачало 
		И ЗначениеЗаполнено(ПериодНачало)
	Тогда
		НачатьТранзакцию();
		ОтобратьЦенныеБумаги();
		СоздатьПоручения();
		Если ТранзакцияАктивна() Тогда
			ЗафиксироватьТранзакцию();
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

Процедура ОтобратьЦенныеБумаги(Прием = Истина, Снятие = Истина) Экспорт
	
	ЦенныеБумаги.Очистить();
	
	Если Прием Тогда
		ЗаполнитьЦенныеБумаги(ТекстЗапросаДляПриемаНаОбслуживание());
	КонецЕсли;
	
	Если Снятие Тогда
		ЗаполнитьЦенныеБумаги(ТекстЗапросаДляСнятияСОбслуживания());
	КонецЕсли;
	
КонецПроцедуры

Процедура СоздатьПоручения(Прием = Истина, Снятие = Истина) Экспорт

	ОрганизацияПоУмолчанию = Константы.ОрганизацияПоУмолчанию.Получить();
	КэшДат = Новый Соответствие;
	ВТранзакции = ТранзакцияАктивна();
	Если Не ВТранзакции Тогда
		ПомеченныеСтроки = ЦенныеБумаги.НайтиСтроки(Новый Структура("Пометка", Истина));
		МассивЦБ = ЦенныеБумаги.Выгрузить(ПомеченныеСтроки, "ЦБ").ВыгрузитьКолонку("ЦБ");	
		Запрос = Новый Запрос;
		Запрос.Текст =
		"ВЫБРАТЬ
		|	Поручение.ЦБ
		|ИЗ
		|	Документ.Поручение КАК Поручение
		|ГДЕ
		|	Поручение.ЦБ В(&ЦБ)
		|	И Поручение.ВидОперацииД = &ВидОперации
		|	И НЕ Поручение.ПометкаУдаления
		|	И Поручение.Проведен";
		Запрос.УстановитьПараметр("ЦБ", МассивЦБ);
		Если Прием Тогда
			Запрос.УстановитьПараметр("ВидОперации", Справочники.ВидыОпераций.ПриемЦБНаОбслуживание);
			УжеПринятые = Запрос.Выполнить().Выгрузить();
		КонецЕсли;
		Если Снятие Тогда
			Запрос.УстановитьПараметр("ВидОперации", Справочники.ВидыОпераций.СнятиеЦБсОбслуживания);
			УжеСнятые = Запрос.Выполнить().Выгрузить();
		КонецЕсли;
	КонецЕсли;
	
	Если Снятие Тогда
		ЦБСНенулевымОстатком = Новый Массив;
	КонецЕсли;
		
	Для Каждого Строка Из ЦенныеБумаги Цикл
		Если Строка.Пометка = Ложь 
			Или (Строка.Снятие И Не Снятие)
			Или (Не Строка.Снятие И Не Прием)
		Тогда
			Продолжить;
		ИначеЕсли Строка.Снятие И Строка.КоличествоОстаток > 0 Тогда
			ЦБСНенулевымОстатком.Добавить(Строка);
			Продолжить;
		КонецЕсли;
		Если Не ВТранзакции Тогда
			Если Прием И УжеПринятые.Найти(Строка.ЦБ) <> Неопределено Тогда
				Сообщить("ЦБ <"+Строка.ЦБ+"> уже была принята на обслуживание!");
				Продолжить;
			КонецЕсли;
			Если Снятие И УжеСнятые.Найти(Строка.ЦБ) <> Неопределено Тогда
				Сообщить("ЦБ <"+Строка.ЦБ+"> уже была снята с обслуживания!");
				Продолжить;
			КонецЕсли;
		КонецЕсли;
		Если Не ЗначениеЗаполнено(Строка.Период) Или Строка.Снятие Тогда
			ДатаВКэше = КэшДат.Получить(Строка.Период); // Виталий Донченко: все можно сформировать одним временем
			Если ДатаВКэше = Неопределено Тогда
				ДатаПоследнегоПоручения = ДатаПоследнегоПоручения(Строка.Период);
				Если Час(ДатаПоследнегоПоручения) < 20 Тогда
					ДатаВремя = Строка.Период + 20*60*60;
				Иначе
					ДатаВремя = ДатаПоследнегоПоручения + 5;
				КонецЕсли;
				КэшДат.Вставить(Строка.Период, ДатаВремя);
				Строка.Период = ДатаВремя;
			Иначе 
				Строка.Период = ДатаВКэше;
			КонецЕсли;
		Иначе
			СекундВМинуте = 60;
			КоличествоМинут = 5;
			ПятьМинут = СекундВМинуте * КоличествоМинут;
			Строка.Период = Строка.Период - ПятьМинут;
		КонецЕсли;
		Поручение = Документы.Поручение.СоздатьДокумент();
		Поручение.Дата						= Строка.Период;
		Поручение.ДатаИсполненияПоручения	= Строка.Период+1;
		Если Строка.Снятие Тогда
			ВидОперации = "'Снятие ЦБ с обслуживания'";
			Поручение.ВидОперацииД				= Справочники.ВидыОпераций.СнятиеЦБсОбслуживания;
		Иначе
			ВидОперации = "'Прием ЦБ на обслуживание'";
			Поручение.ВидОперацииД				= Справочники.ВидыОпераций.ПриемЦБНаОбслуживание;
		КонецЕсли;
		Поручение.Инициатор					= ОрганизацияПоУмолчанию;
		Поручение.ЦБ						= Строка.ЦБ;
		Попытка
			Поручение.Записать(РежимЗаписиДокумента.Проведение);
			Сообщить("Проведена операция "+ВидОперации+" ("+Поручение.Ссылка+") для ЦБ: "+Строка.ЦБ);
			ЗаписьЖурналаРегистрации("Обработка Ценных бумаг к приему на обслуживание", УровеньЖурналаРегистрации.Информация, Поручение.Метаданные(), Поручение.Ссылка, 
				"Проведена операция "+ВидОперации+" ("+Поручение.Ссылка+") для ЦБ: "+Строка.ЦБ);
		Исключение
			Сообщить("Не удалось провести операцию "+ВидОперации+" для ЦБ: "+Строка.ЦБ+" !!!", СтатусСообщения.Внимание);
			ЗаписьЖурналаРегистрации("Обработка Ценных бумаг к приему на обслуживание", УровеньЖурналаРегистрации.Информация, Поручение.Метаданные(), Поручение.Ссылка, 
				"Не удалось провести операцию "+ВидОперации+" для ЦБ: "+Строка.ЦБ);
		КонецПопытки;
	КонецЦикла;
	
	Если Снятие И ЦБСНенулевымОстатком.Количество() > 0 Тогда
		ИмяСобытия = "Обработка Снятие ЦБ с обслуживания";
		
		ТекстСообщения = "При создании поручений на снятие с обслуживания обнаружены остатки по следующим ЦБ:";
		Для Каждого Строка Из ЦБСНенулевымОстатком Цикл
			ТекстСообщения = ТекстСообщения + Символы.ПС + Строка.ЦБ + " (" + Строка.ЦБ.ISIN + "), код загрузки: " + Строка.КодЗагрузки;
		КонецЦикла;
		ТекстСообщения = ТекстСообщения + Символы.ПС + "Снятие с обслуживания данных ЦБ отменено";
		
		ЗаписьЖурналаРегистрации(ИмяСобытия, УровеньЖурналаРегистрации.Ошибка, Метаданные(),,  ТекстСообщения);
		
		НастройкаОтправки = ВнешниеДанные.ПолучитьПараметрыВнешнегоИсточника(ПланыВидовХарактеристик.ВнешниеИсточники.РассылкаУведомленийОСнятииЦБСОбслуживания).Настройка;
		Если Не ЗначениеЗаполнено(НастройкаОтправки) Тогда
			ЗаписьЖурналаРегистрации(ИмяСобытия, УровеньЖурналаРегистрации.Предупреждение,,, "Не заполнена настройка обмена данными <<Депозитарий и IT>> ");
		Иначе
			ПараметрыУведомления = Новый Соответствие;
			ПараметрыУведомления.Вставить("НастройкиОбмена"		, НастройкаОтправки);
			ПараметрыУведомления.Вставить("ТемаПисьма"			, ИмяСобытия);
			ПараметрыУведомления.Вставить("ТекстПисьма"			, ТекстСообщения);
			ПараметрыУведомления.Вставить("ТипТекстаПисьма"		, ТипТекстаПочтовогоСообщения.ПростойТекст);
			ПараметрыУведомления.Вставить("Кодировка"			, "UTF-8");
			РегистрыСведений.УведомленияКОтправке.ДобавитьУведомлениеКотправке(ПараметрыУведомления);
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

Функция ДатаПоследнегоПоручения(ПериодДень)
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	ЕСТЬNULL(МАКСИМУМ(ДокументОбъект.Дата), &Дата) КАК ПоследняяДата
	|ИЗ
	|	Документ.Поручение КАК ДокументОбъект
	|ГДЕ
	|	ДокументОбъект.Дата МЕЖДУ &НачалоПериода И &КонецПериода
	|	И ДокументОбъект.ПометкаУдаления = ЛОЖЬ
	|");
	Запрос.УстановитьПараметр("Дата", ПериодДень);
	Запрос.УстановитьПараметр("НачалоПериода",	НачалоДня(ПериодДень));
	Запрос.УстановитьПараметр("КонецПериода",	КонецДня(ПериодДень));
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.ПоследняяДата;
	Иначе
		Возврат ПериодДень;
	КонецЕсли;
	
КонецФункции

