
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	УстановитьАдресБиблиотекиНаСервере();
	
	Если Параметры.Свойство("СтрокаJSON") Тогда
		РедактируемаяСтрока = Параметры.СтрокаJSON;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	ПодключитьРасширениеРаботыСФайлами();
	
	ПриОткрытииЗавершение(Неопределено, Неопределено);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ПолеРедактораДокументСформирован(Элемент)
	Если ЗначениеЗаполнено(РедактируемаяСтрока) Тогда
		ПодключитьОбработчикОжидания("ОбработчикОжиданияУстановитьРедактируемуюСтрокуВРедакторДерево", 0.5, Истина);
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ПолеРедактораСтрокаДокументСформирован(Элемент)
	Если ЗначениеЗаполнено(РедактируемаяСтрока) Тогда
		ПодключитьОбработчикОжидания("ОбработчикОжиданияУстановитьРедактируемуюСтрокуВРедакторСтроки", 0.1, Истина);
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура СкопироватьИзСтрокиВДерево(Команда)
	СтрокаJSON = JSONСтрокаИзПоляРедактора(Элементы.ПолеРедактораСтрока);
	СтрокаДерева = JSONСтрокаИзПоляРедактора(Элементы.ПолеРедактораДерево);

	УстановитьJSONBHTML(Элементы.ПолеРедактораДерево, СтрокаJSON);
	Если Не ЗначениеЗаполнено(СтрокаДерева) Тогда
		РазвернутьСтрокиДереваJSON(Элементы.ПолеРедактораДерево);
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура СкопироватьИзДереваВСтроку(Команда)
	СтрокаJSON = JSONСтрокаИзПоляРедактора(Элементы.ПолеРедактораДерево);
	УстановитьJSONBHTML(Элементы.ПолеРедактораСтрока, СтрокаJSON);
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура УстановитьАдресБиблиотекиНаСервере()
	ОбработкаОбъект = РеквизитФормыВЗначение("Объект");
	ДвоичныеДанныеБиблиотеки = ОбработкаОбъект.ПолучитьМакет("jsoneditor");
	
	КаталогНаСервере = ПолучитьИмяВременногоФайла();
	СоздатьКаталог(КаталогНаСервере);
	
	Поток = ДвоичныеДанныеБиблиотеки.ОткрытьПотокДляЧтения();
	
	ЧтениеZIP = Новый ЧтениеZipФайла(Поток);
	ЧтениеZIP.ИзвлечьВсе(КаталогНаСервере, РежимВосстановленияПутейФайловZIP.Восстанавливать);
	
	СтруктураБиблиотеки = Новый Соответствие;
	
	ФайлыАрхива = НайтиФайлы(КаталогНаСервере, "*", Истина);
	Для Каждого ФайлБиблиотеки Из ФайлыАрхива Цикл
		КлючФайла = СтрЗаменить(ФайлБиблиотеки.ПолноеИмя, КаталогНаСервере + ПолучитьРазделительПути(), "");
		Если ФайлБиблиотеки.ЭтоКаталог() Тогда
			Продолжить;
		КонецЕсли;
		
		СтруктураБиблиотеки.Вставить(КлючФайла, Новый ДвоичныеДанные(ФайлБиблиотеки.ПолноеИмя));
	КонецЦикла;
	
	АдресБиблиотеки = ПоместитьВоВременноеХранилище(СтруктураБиблиотеки, УникальныйИдентификатор);
	
	Попытка
		УдалитьФайлы(КаталогНаСервере);
	Исключение
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Ошибка удаления временных файлов");
	КонецПопытки;
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытииЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	КаталогВспомогательныхБиблиотекИнструментов = КаталогВременныхФайлов(); // BSLLS:TempFilesDir-off
	КаталогСохраненияБиблиотеки = КаталогВспомогательныхБиблиотекИнструментов
		+ ПолучитьРазделительПути() + "jsoneditor";
	
	ФайлРедактора = Новый Файл(КаталогСохраненияБиблиотеки);
	ФайлРедактора.НачатьПроверкуСуществования(
		Новый ОписаниеОповещения("ПриОткрытииЗавершениеПроверкиСуществованияБиблиотеки", ЭтотОбъект));
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытииЗавершениеПроверкиСуществованияБиблиотеки(Существует, ДополнительныеПараметры1) Экспорт
	
	Если Существует Тогда
		ОповещениеОбУдалениеФайлов =
			Новый ОписаниеОповещения("ПриОткрытииЗавершениеПроверкиСуществованияБиблиотекиЗавершениеУдаленияФайлов",
				ЭтотОбъект, , "ПриОткрытииЗавершениеПроверкиСуществованияБиблиотекиЗавершениеОшибкаУдаленияФайлов", ЭтотОбъект);
				
		НачатьУдалениеФайлов(ОповещениеОбУдалениеФайлов, КаталогСохраненияБиблиотеки);
	Иначе
		ПриОткрытииЗавершениеПроверкиСуществованияБиблиотекиФрагмент();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытииЗавершениеПроверкиСуществованияБиблиотекиЗавершениеУдаленияФайлов(ДополнительныеПараметры) Экспорт
	ПриОткрытииЗавершениеПроверкиСуществованияБиблиотекиФрагмент();
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытииЗавершениеПроверкиСуществованияБиблиотекиЗавершениеОшибкаУдаленияФайлов(ДополнительныеПараметры) Экспорт
	
	КаталогСохраненияБиблиотеки = КаталогСохраненияБиблиотеки + "1";
	
	ОповещениеОбУдалениеФайлов =
		Новый ОписаниеОповещения("ПриОткрытииЗавершениеПроверкиСуществованияБиблиотекиЗавершениеУдаленияФайлов",
			ЭтотОбъект, , "ПриОткрытииЗавершениеПроверкиСуществованияБиблиотекиЗавершениеОшибкаУдаленияФайлов", ЭтотОбъект);
	
	НачатьУдалениеФайлов(ОповещениеОбУдалениеФайлов, КаталогСохраненияБиблиотеки);
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытииЗавершениеПроверкиСуществованияБиблиотекиФрагмент()
	
	НачатьСозданиеКаталога(Новый ОписаниеОповещения("ПриОткрытииЗавершениеСозданияКаталогаБиблиотеки", ЭтотОбъект),
		КаталогСохраненияБиблиотеки);
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытииЗавершениеСозданияКаталогаБиблиотеки(ИмяКаталога, ДополнительныеПараметры) Экспорт
	
	СохранитьБиблиотекуРедактораНаДиск();
	УстановитьТекстХТМЛПоляРедактора();
	
КонецПроцедуры

&НаКлиенте
Процедура СохранитьБиблиотекуРедактораНаДиск()
	
	СоответствиеФайловБиблиотеки = ПолучитьИзВременногоХранилища(АдресБиблиотеки);
	Для Каждого КлючЗначение Из СоответствиеФайловБиблиотеки Цикл
		ИмяФайла = КаталогСохраненияБиблиотеки + ПолучитьРазделительПути() + КлючЗначение.Ключ;

		КлючЗначение.Значение.Записать(ИмяФайла);
		
		Если КлючЗначение.Ключ = "jsoneditor.js" Тогда
			УбратьРекламуНаКлиенте(ИмяФайла);
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

&НаКлиенте
Процедура УбратьРекламуНаКлиенте(ПолноеИмяФайла)
	
	ТекстРекламы = "powered by ace";
	СайтРекламы = "ace.c9.io";
	
	Текст = Новый ЧтениеТекста(ПолноеИмяФайла);
	ВесьФайлОднойСтрокой = Текст.Прочитать();
	Текст.Закрыть();
	
	ВесьФайлОднойСтрокойБезРекламы = СтрЗаменить(ВесьФайлОднойСтрокой, ТекстРекламы, "");
	ВесьФайлОднойСтрокойБезРекламы = СтрЗаменить(ВесьФайлОднойСтрокойБезРекламы, СайтРекламы, "nrb.ru");
	
	ТекстНовый = Новый ЗаписьТекста(ПолноеИмяФайла);
	ТекстНовый.Записать(ВесьФайлОднойСтрокойБезРекламы);
	ТекстНовый.Закрыть();
	
КонецПроцедуры

&НаКлиенте
Процедура УстановитьТекстХТМЛПоляРедактора()
	ТекстCSS = КаталогСохраненияБиблиотеки + ПолучитьРазделительПути() + "jsoneditor.css";
	ТекстJS = КаталогСохраненияБиблиотеки + ПолучитьРазделительПути() + "jsoneditor.js";

	Шаблон = "<!DOCTYPE HTML>
			|<html>
			|<head>
			|  <title>JSONEditor | Synchronize two editors</title>
			|
			|	<link href=""" + ТекстCSS + """ rel=""stylesheet"" type=""text/css"">
											 |  <script src=""" + ТекстJS + """></script>
																			|
																			|  <style type=""text/css"">
																			|    body {
																			|      font-family: sans-serif;
																			|    }
																			|
																			|   .jsoneditor {
																			|      width: 100%;
																			|      height: 100%;
																			|    }
																			|  </style>
																			|</head>
																			|<body>
																			|	<div class=""jsoneditor"" id=""jsoneditor""></div>
																			|
																			|<script>
																			|
																			|  var container = document.getElementById('jsoneditor')
																			|  var options = {
																			|    // switch between pt-BR or en for testing forcing a language
																			|    // leave blank to get language
																			|   'language': 'ru-RU',
																			|   mode: '###РежимРедактора###'
																			|  }
																			|  var editor = new JSONEditor(container, options)
																			|
																			|	function getJSON(){
																			|		return JSON.stringify(editor.get(), null, 2);
																			|	}
																			|
																			|
																			|</script>
																			|	<div id=""footer""></div>
																			|
																			|</body>
																			|</html>";

	СохранитьФайлХТМЛПоляРедактора(СтрЗаменить(Шаблон, "###РежимРедактора###", "tree"),
		КаталогСохраненияБиблиотеки + ПолучитьРазделительПути() + "tree.html" , "ПолеРедактораДерево");
	СохранитьФайлХТМЛПоляРедактора(СтрЗаменить(Шаблон, "###РежимРедактора###", "code"),
		КаталогСохраненияБиблиотеки + ПолучитьРазделительПути() + "code.html", "ПолеРедактораСтрока");
	
КонецПроцедуры

&НаКлиенте
Процедура СохранитьФайлХТМЛПоляРедактора(ТекстHTML, ИмяФайла, ИмяПоляРедактора)
	
	Текст = Новый ТекстовыйДокумент;
	Текст.УстановитьТекст(ТекстHTML);
	
	ДопПараметры = Новый Структура;
	ДопПараметры.Вставить("ИмяПоляРедактора", ИмяПоляРедактора);
	ДопПараметры.Вставить("ИмяФайла", ИмяФайла);
	
	Текст.НачатьЗапись(Новый ОписаниеОповещения("СохранитьФайлХТМЛПоляРедактораЗавершение", ЭтотОбъект, ДопПараметры), ИмяФайла);
КонецПроцедуры

&НаКлиенте
Процедура СохранитьФайлХТМЛПоляРедактораЗавершение(Результат, ДополнительныеПараметры) Экспорт
	ЭтотОбъект[ДополнительныеПараметры.ИмяПоляРедактора] = ДополнительныеПараметры.ИмяФайла;
КонецПроцедуры

#Область ОбработчикРедактора

&НаКлиенте
Процедура ОбработчикОжиданияУстановитьРедактируемуюСтрокуВРедакторДерево()
	Попытка
		УстановитьJSONBHTML(Элементы.ПолеРедактораДерево, РедактируемаяСтрока);
		РазвернутьСтрокиДереваJSON(Элементы.ПолеРедактораДерево);
	Исключение
		ПодключитьОбработчикОжидания("ОбработчикОжиданияУстановитьРедактируемуюСтрокуВРедакторДерево", 0.5, Истина);
	КонецПопытки;
КонецПроцедуры

&НаКлиенте
Процедура ОбработчикОжиданияУстановитьРедактируемуюСтрокуВРедакторСтроки()
	Попытка
		УстановитьJSONBHTML(Элементы.ПолеРедактораСтрока, РедактируемаяСтрока);
		// Форматируем строку JSON по формату редактора
		УстановитьJSONBHTML(Элементы.ПолеРедактораСтрока, JSONСтрокаИзПоляРедактора(Элементы.ПолеРедактораСтрока));
		
	Исключение
		ПодключитьОбработчикОжидания("ОбработчикОжиданияУстановитьРедактируемуюСтрокуВРедакторСтроки", 0.5, Истина);
	КонецПопытки;
КонецПроцедуры

&НаКлиенте
Процедура УстановитьJSONBHTML(ЭлементПоляРедактора, СтрокаJSON)
	ДокументHTML = ЭлементПоляРедактора.Документ;
	Если ДокументHTML.parentWindow = Неопределено Тогда
		СтруктураДокументаДОМ = ДокументHTML.defaultView;
	Иначе
		СтруктураДокументаДОМ = ДокументHTML.parentWindow;
	КонецЕсли;
	СтруктураДокументаДОМ.editor.setText(СтрокаJSON);
	
КонецПроцедуры

&НаКлиенте
Процедура РазвернутьСтрокиДереваJSON(ЭлементПоляРедактора)
	ДокументHTML = ЭлементПоляРедактора.Документ;
	Если ДокументHTML.parentWindow = Неопределено Тогда
		СтруктураДокументаДОМ = ДокументHTML.defaultView;
	Иначе
		СтруктураДокументаДОМ = ДокументHTML.parentWindow;
	КонецЕсли;
	СтруктураДокументаДОМ.editor.expandAll();
	
КонецПроцедуры

&НаКлиенте
Функция JSONСтрокаИзПоляРедактора(ЭлементПоляРедактора)
	ДокументHTML = ЭлементПоляРедактора.Документ;
	Если ДокументHTML.parentWindow = Неопределено Тогда
		СтруктураДокументаДОМ = ДокументHTML.defaultView;
	Иначе
		СтруктураДокументаДОМ = ДокументHTML.parentWindow;
	КонецЕсли;
	Возврат СтруктураДокументаДОМ.getJSON();
КонецФункции

#КонецОбласти
#КонецОбласти
