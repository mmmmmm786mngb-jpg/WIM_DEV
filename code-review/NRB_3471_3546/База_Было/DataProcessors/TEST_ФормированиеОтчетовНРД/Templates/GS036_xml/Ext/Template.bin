<?xml version="1.0" encoding="windows-1251"?>
<ReportNSD xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns="urn:nsd:std:iso:20022:tech:xsd:rprt.envl.001.01" >
	<!--Заголовок сообщения. Одинаковый для всех отчетов.-->
	<AppHdr xmlns="urn:iso:std:iso:20022:tech:xsd:head.001.001.01">
		<!--Отправитель сообщения-->
		<Fr>
			<OrgId>
				<!-- Соответствует Maker_full_name (Наименование отправителя отчета) в файле DBF repotrh. В этом поле указывается краткое наименование отправителя отчета.-->
				<Nm>Краткое наименование отправителя отчета</Nm>
				<Id>
					<OrgId>
						<Othr>
							<!-- Депозитарный код отправителя. Соответствует полю Maker_code (Код отправителя отчета) в файле DBF repotrh.-->
							<Id>NDC000000000</Id>
							<Issr>NSDR</Issr>
						</Othr>
					</OrgId>
				</Id>
			</OrgId>
		</Fr>
		<!--Получатель сообщения-->
		<To>
			<OrgId>
				<!--Соответствует полю Reciv_full_name (Наименование получателя отчета) в файле DBF repotrh. В этом поле указывается краткое наименование получателя отчета.-->
				<Nm>Краткое наименование получателя отчета</Nm>
				<Id>
					<OrgId>
						<Othr>
							<!-- Депозитарный код получателя. Соответствует полю Reciv_code (Код получателя отчета) в файле DBF repotrh.-->
							<Id>MC0000000000</Id>
							<Issr>NSDR</Issr>
						</Othr>
					</OrgId>
				</Id>
			</OrgId>
		</To>
		<!-- Уникальный идентификатор отчета. Соответствует полю Reg_no (Номер отчета) в файле DBF repotrh.-->
		<BizMsgIdr>99187531A</BizMsgIdr>
		<!-- Идентификатор кода отчета. В поле указывается значение "Тип сообщения ISO 20022 " или идентификатор отчета, присвоенный НРД-->
		<MsgDefIdr>rprt.gs036.001.01</MsgDefIdr>
		<!-- Код печатной формы отчета. В поле указывается Код формы бумажного документа в соответствии со Спецификацией функциональных электронных документов СЭД НРД (отчеты). Соответствует полю Out_form (Форма) в файле DBF repotrh-->
		<BizSvc>GS036</BizSvc>
		<!-- Дата и время создания отчета, указывается время по UTC (без учета часового пояса).
Соответствует полям:
- Reg_date (Дата составления отчета) в файле DBF repotrh
- Treg_date (Время составления отчета) в файле DBF repotrh-->
		<CreDt>2020-10-12T10:57:00Z</CreDt>
	</AppHdr>
	<!--Содержание отчета-->
	<Document xmlns="urn:nsd:std:iso:20022:tech:xsd:rprt.gs036.001.01">
		<GS036>
			<Ntfctns>
				<!--NtfctnHdr - Заголовок уведомления / Notification header, может отсутствовать-->
				<!--Текст уведомления / Notification text-->
				<NtfctnTxt>Статусе из места хранения: Обработка не завершена: Текстовое описание причины</NtfctnTxt>
			</Ntfctns>
			<Ntfctns>
				<!--NtfctnHdr - Заголовок уведомления / Notification header, может отсутствовать-->
				<NtfctnHdr>Статус сообщения (формат SWIFT):</NtfctnHdr>
				<!--Текст уведомления / Notification text-->
				<NtfctnTxt>:25::IPRC//PPRC</NtfctnTxt>
			</Ntfctns>
			<Ntfctns>
				<!--NtfctnHdr - Заголовок уведомления / Notification header, может отсутствовать-->
				<NtfctnHdr>Причина (формат SWIFT):</NtfctnHdr>
				<!--Текст уведомления / Notification text-->
				<NtfctnTxt>:24::PPRC//NARR</NtfctnTxt>
			</Ntfctns>
			<Ntfctns>
				<!--NtfctnHdr - Заголовок уведомления / Notification header, может отсутствовать-->
				<NtfctnHdr>Текстовое описание (формат SWIFT):</NtfctnHdr>
				<!--Текст уведомления / Notification text-->
				<NtfctnTxt>:70::Your Instruction is Awaiting Validation.</NtfctnTxt>
			</Ntfctns>
			<SplmtryData>
				<!--Блок расширения для отчета GS036-->
				<Envlp xmlns="urn:nsd:std:iso:20022:tech:xsd:xtns.gs036.001.01">
					<XtnsnDt>
						<SvcInf>
							<!--Язык / Language. Соответствует полю Language (Язык отчета) в файле DBF repotrh-->
							<Lang>RUS</Lang>
							<!--Версия печатной формы -->
							<PrntFrmVrsn>1</PrntFrmVrsn>
							<!--Отправитель отчета / Report Sender-->
							<RptSndr>
								<Nm>Полное наименование отправителя отчета</Nm>
							</RptSndr>
							<!--Получатель отчета / Report Receiver
Соответствует полю Reciv_full_name (Полное  наименование получателя отчета) в файле DBF repotrh, данные вносялтся в */Nm
Соответствует полю Name_add () в файле DBF repotrh, данные вносялтся в */AddNm-->
							<RptRcvr>
								<Nm>Полное наименование</Nm>
								<AddNm>Доп. наименование к наименованию получателя отчета</AddNm>
							</RptRcvr>
						</SvcInf>
						<!--Детали поручения и операции / TransactionProcessorDetails-->
						<TxPrcrDtls>
							<TxId>
							<!--Идентификатор инструкции присвоеный владельцем счета / AccountOwnerTransactionIdentification
Соответствует полю Repl_to_no (Поручение №) в файле DBF repotrh-->
							<AcctOwnrTxId>Поручение №</AcctOwnrTxId>
								<!--Идентификатор инструкции присвоеный обслуживающей организацией / AccountServicerTransactionIdentification
Соответствует полю In_reg_no (Рег. № поручения) в файле DBF repotrh-->
								<AcctSvcrTxId>a</AcctSvcrTxId>
							</TxId>
							<TxDt>
								<!--Дата и время регистрации / Registration Date Time.
Соответствует полям In_reg_dat (Дата регистрации поручения) и tin_reg_da (Дата регистрации поручения (время)) в файле DBF repotrh. Данные заносятся в */Dt-->
								<RegnDtTm>
									<Dt>2020-10-12T09:30:47Z</Dt>
								</RegnDtTm>
								<!--Дата и время принятия на исполнение / Acceptance Execution Date Time.
Соответствует полям Accept_dat (Дата принятия на исполнение) и taccept_da (Дата принятия на исполнение (время)) в файле DBF repotrh. Данные заоносятся в */Dt-->
								<AccptdExctnDtTm>
									<Dt>2020-10-12T09:30:47Z</Dt>
								</AccptdExctnDtTm>
							</TxDt>
							<!--Инициатор поручения / Originator-->
							<Orgtr>
								<!--Наименование (ФИО) / Name. Соответствует полю Person_nam (Наименование инициатора поручения) в файле DBF repotrh-->
								<Nm>Наименование инициатора поручения</Nm>
								<Id>
									<!--Идентификация инициатора поручения-->
									<OrgId>
										<!---->
										<Othr>
											<!--Для ReportNSD/.....:Document/...../SplmtryData/Envlp/XtnsnDt/TxPrcrDtls/Orgtr/Id/OrgId/Othr/Id Соответствует полю Person_cod (Код инициатора поручения) в файле DBF repotrh-->
											<Id>Person_cod</Id>
											<Issr>NSDR</Issr>
										</Othr>
									</OrgId>
								</Id>
							</Orgtr>
							<!--Детали операции / Processor Transaction Details-->
							<PrcrTxDtls>
								<!--Код операции / ProcessorCode. Соответствует полю Ord_type_i (Код операции) в файле DBF repotrh.-->
								<PrcrTxCd>12345678</PrcrTxCd>
								<!--Наименование операции / Name. Соответствует полю Ord_type_n (Наименование операции) в файле DBF repotrh.-->
								<PrcrTxNm>Наименование операции</PrcrTxNm>
								<!--Дата и время исполнения / Execution Date Time.
Соответствует полям Operday (Дата операции (отказа)) и toperday (Время операции (отказа)) в файле DBF repotrh. Данные вносятся в */Dt-->
								<ExctnDtTm>
									<Dt>2020-10-12T09:30:47Z</Dt>
								</ExctnDtTm>
								<!--Дата операционного дня исполнения / Operational Execution Day. Соответствует полю Opday_exe (Дата операционного дня исполнения операции) в файле DBF repotrh. Данные вносятся в */Dt-->
								<OprExctnDt>
									<Dt>2020-10-12</Dt>
								</OprExctnDt>
							</PrcrTxDtls>
						</TxPrcrDtls>
					</XtnsnDt>
				</Envlp>
			</SplmtryData>
		</GS036>
	</Document>
</ReportNSD>
