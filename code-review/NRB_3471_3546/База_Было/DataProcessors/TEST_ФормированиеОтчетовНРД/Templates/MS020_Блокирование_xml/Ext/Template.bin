<?xml version="1.0" encoding="windows-1251"?>
<ReportNSD xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns="urn:nsd:std:iso:20022:tech:xsd:rprt.envl.001.01">
	<AppHdr xmlns="urn:iso:std:iso:20022:tech:xsd:head.001.001.01">
		<Fr>
			<OrgId>
				<!-- Соответствует Maker_name(Краткое наименование отправителя отчета) в файле DBF repotrh-->
				<Nm>НКО АО НРД</Nm>
				<Id>
					<OrgId>
						<Othr>
							<!-- Депозитарный код отправителя. Соответствует полю Maker_code (Код отправителя отчета) в файле DBF repotrh-->
							<Id>NDC000000000</Id>
							<Issr>NSDR</Issr>
						</Othr>
					</OrgId>
				</Id>
			</OrgId>
		</Fr>
		<To>
			<OrgId>
				<!--Соответствует полю Reciv_name (Краткое наименование получателя отчета) в файле DBF repotrh-->
				<Nm>АО БАНК "НАЦИОНАЛЬНЫЙ КЛАССИК"</Nm>
				<Id>
					<OrgId>
						<Othr>
							<!-- Депозитарный код получателя. Соответствует полю Reciv_code (Код получателя отчета) в файле DBF repotrh-->
							<Id>MC0000000000</Id>
							<Issr>NSDR</Issr>
						</Othr>
					</OrgId>
				</Id>
			</OrgId>
		</To>
		<!-- Уникальный идентификатор отчета. Соответствует полю Reg_no (Номер отчета) в файле DBF repotrh-->
		<BizMsgIdr>10840537</BizMsgIdr>
		<!-- Идентификатор кода отчета. В поле указывается значение "Тип сообщения ISO 20022 " или идентификатор отчета, присвоенный НРД-->
		<MsgDefIdr>sese.025.001.10</MsgDefIdr>
		<!-- Код печатной формы отчета. Соответствует полю Out_form (Форма) в файле DBF repotrh-->
		<BizSvc>MS020</BizSvc>
		<!-- Дата и время создания отчета, указывается время по UTC (без учета часового пояса).
Соответствует полям: - Reg_date (Дата составления отчета) и Treg_date (Время составления отчета) в файле DBF repotrh -->
		<CreDt>2022-05-01T10:57:00Z</CreDt>
	</AppHdr>
	<Document xmlns="urn:iso:std:iso:20022:tech:xsd:rprt.sese.025.001.10">
		<!--Подтверждение расчетной операции с ценными бумагами-->
		<SctiesSttlmTxConf>
			<!--Детали идентификации транзакции -->
			<TxIdDtls>
				<!--Соответствует полю Repl_to_no (Исх. № поручения) в файле DBF repotrh. -->
				<AcctOwnrTxId>korn41</AcctOwnrTxId>
				<!-- Соответствует полю In_reg_no (Рег. № поручения ) в файле DBF repotrh.-->
				<AcctSvcrTxId>10840537</AcctSvcrTxId>
				<!--Направление движения ЦБ.Константа. -->
				<SctiesMvmntTp>DELI</SctiesMvmntTp>
				<!--Признак оплаты.Константа.-->
				<Pmt>FREE</Pmt>
				<!--Референс КД. Нет соответствий с DBF-->
				<CorpActnEvtId>757575X5955</CorpActnEvtId>
			</TxIdDtls>
			<!--Детали сделки -->
			<TradDtls>
				<!--Cоответствует полям Reg_date, Treg_date (Дата фактического проведения расчетов) в файле DBF repotrh -->
				<FctvSttlmDt>
					<Dt>
						<Dt>2022-04-29</Dt>
					</Dt>
				</FctvSttlmDt>
			</TradDtls>
			<!--Определение финансового инструмента-->
			<FinInstrmId>
				<OthrId>
					<!-- Cоответствует полю Security_c (Депозитарный код ценной бумаги в кодировке НРД) в файле DBF transs -->
					<Id>US912800AA71</Id>
					<!--Тип идентификатора-->
					<Tp>
						<!--Собственный код. Нет соответствий в DBF.-->
						<Prtry>NSDR</Prtry>
					</Tp>
				</OthrId>
				<OthrId>
					<!--Cоответствует полю Security_r (Регистрационный код код ценной бумаги) в файле DBF transs-->
					<Id>KORN-E-1864-T5</Id>
					<!--Тип идентификатора-->
					<Tp>
						<!--Собственный код. Нет соответствий в DBF.-->
						<Prtry>OTHR</Prtry>
					</Tp>
				</OthrId>
				<!--Cоответствует полю Security_s (Краткое наименование ценной бумаги) в файле DBF transs-->
				<Desc>KORN-E-1864-T5</Desc>
			</FinInstrmId>
			<!--Информация о счете и количестве-->
			<QtyAndAcctDtls>
				<!--Количество финансового инструмента, по которому проведены расчеты-->
				<SttldQty>
					<Qty>
						<!--Cоответствует полю Seq_amo (Количество ценных бумаг) в файле DBF transs.dbf. В случае, если значение количества цб превышает 17 символов, указывается константа : "-00.00"  и  заполняется поле в расширении *Envlp/XtnsnDt/XtnsnMS020/FinInstrmId/RprtdSttlmQty-->
						<Unit>012345678901234567</Unit>
					</Qty>
				</SttldQty>
				<!--Счет депо-->
				<SfkpgAcct>
					<!-- Cоответствует полям Facc_code и Fsec_code, которые указываются через разделитель /KRZD/.(Номер счета депо, номер раздела (списание) счета депо) в файле DBF htrans -->
					<Id>TS1307260057/KRZD/00000000000000000</Id>
				</SfkpgAcct>
			</QtyAndAcctDtls>
			<!--Параметры расчетов-->
			<SttlmParams>
				<SctiesTxTp>
					<!--Тип операции с ценными бумагами.Константа.-->
					<Cd>OWNI</Cd>
				</SctiesTxTp>
			</SttlmParams>
			<!--Получатель-->
			<RcvgSttlmPties>
				<Pty1>
					<Id>
						<NmAndAdr>
							<!-- Указывается полное наименование владельца счета депо. -->
							<Nm>Акционерное общество БАНК "НАЦИОНАЛЬНЫЙ КЛАССИК"</Nm>
						</NmAndAdr>
					</Id>
					<!--Счет депо-->
					<SfkpgAcct>
						<!--Cоответствует полям Facc_code и Tsec_code, которые указываются через разделитель /KRZD/.(Номер счета депо и Номер раздела (зачисление) счета депо.) в файле DBF htrans -->
						<Id>TS1307260057/KRZD/27000000000000000</Id>
					</SfkpgAcct>
				</Pty1>
			</RcvgSttlmPties>
			<SplmtryData>
				<!--Расширение для sese.025.001.10: Подтверждение расчетной операции с ценными бумагами-->
				<Envlp xmlns="urn:nsd:std:iso:20022:tech:xsd:xtns.sese.025.001.10">
					<!--НРД: Корневой элемент для расширения-->
					<XtnsnDt>
						<!--Служебная информация -->
						<SvcInf>
							<!--Язык отчета-->
							<Lang>RUS</Lang>
							<!--Версия печатной формы-->
							<PrntFrmVrsn>1</PrntFrmVrsn>
							<!--Отправитель отчета-->
							<RptSndr>
								<!--Указывается полное наименование отправителя отчета-->
								<Nm>Небанковская кредитная организация акционерное общество «Национальный расчетный депозитарий»</Nm>
							</RptSndr>
							<!--Получатель отчета-->
							<RptRcvr>
								<!--Указываем полное наименование получателя отчета -->
								<Nm>Акционерное Общество БАНК "НАЦИОНАЛЬНЫЙ КЛАССИК"</Nm>
								<!--Cоответствует полю Name_add (Доп. наименование к наименованию получателя отчета.) в файле DBF repotrh-->
								<AddNm>Доп. наименование к наименованию получателя отчета.</AddNm>
							</RptRcvr>
						</SvcInf>
						<TxPrcrDtls>
							<TxId>
								<!--Cоответствует полю Repl_to_no (Исх. № поручения.) в файле DBF repotrh-->
								<AcctOwnrTxId>korn41</AcctOwnrTxId>
								<!-- Соответствует полю In_reg_no (Рег. № поручения ) в файле DBF repotrh-->
								<AcctSvcrTxId>10840537</AcctSvcrTxId>
							</TxId>
							<!--Даты-->
							<TxDt>
								<!--Cоответствует полю Repl_to_da (Дата составления поручения) в файле DBF repotrh-->
								<InstrCreDt>
									<Dt>2022-04-27</Dt>
								</InstrCreDt>
								<!--Cоответствует полю In_reg_dat (Дата регистрации поручения) в файле DBF repotrh-->
								<RegnDtTm>
									<Dt>2022-04-27T09:30:47Z</Dt>
								</RegnDtTm>
							</TxDt>
							<!--Инициатор поручения -->
							<Orgtr>
								<!--Cоответствует полю Person_nam (Полное наименование инициатора поручения) в файле DBF repotrh-->
								<Nm>АО БАНК "НАЦИОНАЛЬНЫЙ КЛАССИК"</Nm>
								<Id>
									<OrgId>
										<Othr>
											<!--Cоответствует полю Person_cod (Код инициатора поручения) в файле DBF repotrh-->
											<Id>MC0186400000</Id>
											<!--Организация, присвоившая код.-->
											<Issr>NSDR</Issr>
										</Othr>
									</OrgId>
								</Id>
							</Orgtr>
							<PrcrTxDtls>
								<!--Cоответствует полю Ord_type_i (Код операции, по которой формируется отчет) в файле DBF repotrh-->
								<PrcrTxCd>36</PrcrTxCd>
								<!--Cоответствует полю Ord_type_n (Наименование операции, по которой формируется отчет) в файле DBF repotrh-->
								<PrcrTxNm>Снятие ценных бумаг с хранения и/или учета</PrcrTxNm>
								<!--Cоответствует полям Reg_date и Treg_date  (Дата и время исполнения операции) в файле DBF repotrh-->
								<ExctnDtTm>
									<Dt>2022-05-02T09:30:47Z</Dt>
								</ExctnDtTm>
								<!--Cоответствует полю Opday_exe (Дата операционного дня исполнения операции) в файле DBF repotrh-->
								<OprExctnDt>
									<Dt>2022-05-02</Dt>
								</OprExctnDt>
							</PrcrTxDtls>
						</TxPrcrDtls>
						<CorpActnGnlInf>
							<EvtTp>
								<!--Код типа КД. -->
								<Cd>TEND</Cd>
							</EvtTp>
						</CorpActnGnlInf>
						<!--Расширение для отчета MS020-->
						<XtnsnMS020>
							<!--Cоответствует полю Name_add_d (Дополнение к наименованию анкеты счета) в файле DBF htrans-->
							<AddNm>Дополнение к наименованию анкеты счета</AddNm>
							<!--Определение финансового инструмента-->
							<FinInstrmId>
								<OthrId>
									<!-- Cоответствует полю Security_c (Депозитарный код ценной бумаги в кодировке НРД) в файле DBF transs -->
									<Id>US912800AA71</Id>
									<!--Тип идентификатора-->
									<Tp>
										<!--Собственный код. Нет соответствий в DBF.-->
										<Prtry>NSDR</Prtry>
									</Tp>
								</OthrId>
								<!--Cоответствует полю Security_s (Краткое наименование ценной бумаги) в файле DBF transs-->
								<Desc>KORN-E-1864-T5</Desc>
								<!--Количество ценных бумаг-->
								<RprtdSttlmQty>1234567890123456789</RprtdSttlmQty>
							</FinInstrmId>
							<!--Определение финансового инструмента-->
							<FinInstrmId>
								<OthrId>
									<!-- Cоответствует полю Security_c (Депозитарный код ценной бумаги в кодировке НРД) в файле DBF transs -->
									<Id>US912800AA99</Id>
									<!--Тип идентификатора-->
									<Tp>
										<!--Собственный код.Константа-->
										<Prtry>NSDR</Prtry>
									</Tp>
								</OthrId>
								<OthrId>
									<!--Cоответствует полю Security_r (Регистрационный код код ценной бумаги) в файле DBF transs-->
									<Id>KORN-E-1864-T9</Id>
									<!--Тип идентификатора-->
									<Tp>
										<!--Собственный код.Константа-->
										<Prtry>OTHR</Prtry>
									</Tp>
								</OthrId>
								<!--Cоответствует полю Security_s (Краткое наименование ценной бумаги) в файле DBF transs-->
								<Desc>KORN-E-1864-T9</Desc>
								<!--Cоответствует полю Seq_amo (Количество ценных бумаг) в файле DBF transs -->
								<RprtdSttlmQty>1111</RprtdSttlmQty>
							</FinInstrmId>
							<!--Основание-->
							<BsDc>
								<!--Cоответствует полю Based_on (Наименование документа основания) в файле DBF transs -->
								<BsDcNm>Наименование документа основания</BsDcNm>
								<!-- Cоответствует полю Based_num (Номер документа основания) в файле DBF transs-->
								<BsDcNum>1234</BsDcNum>
								<!-- Cоответствует полю based_date (Дата документа основания) в файле DBF transs-->
								<BsDcDt>2022-04-13</BsDcDt>
							</BsDc>
							<!--Сторона списания цб-->
							<DlvrgSttlmPties>
								<!--Cоответствует полю Fsec_id (Идентификатор раздела (списание) в файле DBF  htrans-->
								<SctnId>11081183</SctnId>
								<!--Cоответствует полю Fsec_name (Наименование раздела счета депо (списание) в файле DBF  htrans-->
								<SctnTpNm>Основной</SctnTpNm>
							</DlvrgSttlmPties>
							<!--Сторона зачисление цб-->
							<RcvgSttlmPties>
								<!--Cоответствует полю Tsec_id (Идентификатор раздела счета депо (зачисление) в файле DBF  htrans-->
								<SctnId>11232145</SctnId>
								<!--Cоответствует полю Tsec_name (Наименование раздела счета депо (зачисление) в файле DBF  htrans-->
								<SctnTpNm>Блокировано по расчетам</SctnTpNm>
							</RcvgSttlmPties>
						</XtnsnMS020>
					</XtnsnDt>
				</Envlp>
			</SplmtryData>
		</SctiesSttlmTxConf>
	</Document>
</ReportNSD>
