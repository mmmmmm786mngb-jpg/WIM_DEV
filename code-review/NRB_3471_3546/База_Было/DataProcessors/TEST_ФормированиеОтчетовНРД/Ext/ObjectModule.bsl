
Функция ИмяСформированногоФайлаKПакета(ПараметрыПакета) Экспорт
	
	ПараметрыТехОперации = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ТехОперация, "Номер, Дата");
	
	ПараметрыЗаписи = Новый Структура;
	ПараметрыЗаписи.Вставить("reg_no", СокрЛП(ПараметрыПакета.reg_no));
	ПараметрыЗаписи.Вставить("reg_date", Формат(ПараметрыПакета.reg_date, "ДФ='yyyy-MM-dd H:mm:ss'"));
	ПараметрыЗаписи.Вставить("person_code", "MCO292900000");
	ПараметрыЗаписи.Вставить("contragent_doc_id", СокрЛП(ПараметрыТехОперации.Номер));
	ПараметрыЗаписи.Вставить("create_date", Формат(ПараметрыТехОперации.Дата, "ДФ=yyyy-MM-dd"));
	ПараметрыЗаписи.Вставить("depository_code", "NDC000000000");
	ПараметрыЗаписи.Вставить("abort_code", "");
	ПараметрыЗаписи.Вставить("abort_cause", "");
	ПараметрыЗаписи.Вставить("output_num", "");	
	
	ИмяВременногоФайлаXML = ВременныйXMLФайлВыгрузкиКПакета(ПараметрыЗаписи);	
	ИмяСформированногоФайлаXML = ВыгруженныйВШлюзФайлКПакета(ИмяВременногоФайлаXML, ПараметрыПакета);	
	УдалитьФайлы(ИмяВременногоФайлаXML);	
	Возврат ИмяСформированногоФайлаXML;
	
КонецФункции

Функция ИмяСформированногоАрхиваZПакета(ПараметрыПакета) Экспорт 
	
	ВнешнийИсточник = ПланыВидовХарактеристик.ВнешниеИсточники.ФайловыйШлюзКаталогВходящие;	
	НастройкиОбмена = ВнешниеДанные.ПолучитьПараметрыВнешнегоИсточника(ВнешнийИсточник);
	КорневаяПапка = НастройкиОбмена.Папка;
		
	ИмяРабочегоКаталога = КорневаяПапка + "\" + ПараметрыПакета.ИмяКаталога;
	СоздатьКаталог(ИмяРабочегоКаталога);
	ИмяРабочегоАрхива = ИмяРабочегоКаталога + "\" + Сред(ПараметрыПакета.ИмяКаталога, 2) + ".zip";
	УдалитьФайлы(ИмяРабочегоАрхива);
	
	ОбрабатыватьДепозитарнуюОтчетностьXML =
		РегистрыСведений.ПараметрыГлобальные.ЗначениеПараметра("1123.ОбрабатыватьДепозитарнуюОтчетностьВxml", Ложь);
	
	Если ОбрабатыватьДепозитарнуюОтчетностьXML Тогда
		СформироватьФайлыXML(ПараметрыПакета, ИмяРабочегоКаталога);
	Иначе
		СформироватьФайлыDBF(ПараметрыПакета, ИмяРабочегоКаталога);
	КонецЕсли;
	
	Файлы = НайтиФайлы(ИмяРабочегоКаталога + "\", "*.*");
	
	ЗаписьZIP = Новый ЗаписьZipФайла(ИмяРабочегоАрхива);
	ЗаписьZIP.Добавить(ИмяРабочегоКаталога + "\" + "*.*");
	ЗаписьZIP.Записать();
	
	Для Каждого ТекФайл Из Файлы Цикл
		УдалитьФайлы(ТекФайл.ПолноеИмя);
	КонецЦикла;
	
	Возврат ИмяРабочегоАрхива;

КонецФункции

Процедура СформироватьФайлыDBF(ПараметрыПакета, ИмяРабочегоКаталога)
	
	ИмяАрхиваШаблонов = ИмярабочегоКаталога + "\" + "tmp.zip";
	ЭтоБлокировка = ПараметрыПакета.ВидБлокировки = "Блокировка";
	ЭтоРазблокировка = ПараметрыПакета.ВидБлокировки = "Разблокировка";
	isGS036 = ПараметрыПакета.Свойство("GS036") И ПараметрыПакета.GS036;
	
	Если ЭтоБлокировка Тогда
		ИмяМакетаФайлов = "АрхивZФайловБлокировка";
	ИначеЕсли ЭтоРазблокировка Тогда
		ИмяМакетаФайлов = "АрхивZФайловРазблокировка";
	ИначеЕсли isGS036 Тогда
		ИмяМакетаФайлов = "АрхивZФайловMessages";
	Иначе
		ИмяМакетаФайлов = "АрхивZФайлов";
	КонецЕсли;
	ПолучитьМакет(ИмяМакетаФайлов).Записать(ИмяАрхиваШаблонов);
	
	ЧтениеZIP = Новый ЧтениеZipФайла(ИмяАрхиваШаблонов);
	ЧтениеZIP.ИзвлечьВсе(ИмяРабочегоКаталога);
	ЧтениеZIP.Закрыть();
	
	УдалитьФайлы(ИмяАрхиваШаблонов);
	
	СформироватьReportH(ИмяРабочегоКаталога + "\" + "reporth.dbf", ПараметрыПакета);
	Если isGS036 И ЗначениеЗаполнено(ПараметрыПакета.TextMessageGS036) Тогда
		СформироватьMessages(ИмяРабочегоКаталога + "\" + "messages.dbf", ПараметрыПакета);
	ИначеЕсли ЭтоБлокировка Тогда
		СформироватьTranss(ИмяРабочегоКаталога + "\" + "transs.dbf", ПараметрыПакета);
	Иначе
		Если ЗначениеЗаполнено(ПараметрыПакета.ПричинаОтмены) Или ИстекСрокИсполненияПоручения Тогда
			СформироватьReportAbort(ИмяРабочегоКаталога + "\" + "abort.dbf", ПараметрыПакета);
		КонецЕсли;
		СформироватьTranblsc(ИмяРабочегоКаталога + "\" + "tranblsc.dbf", ПараметрыПакета);
		СформироватьHbltrans(ИмяРабочегоКаталога + "\" + "hbltrans.dbf", ПараметрыПакета);
	КонецЕсли;
	
КонецПроцедуры

Функция ИмяСформированногоФайлаВыписки(ПараметрыОперации) Экспорт
	
	ПараметрыТехОперации = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ТехОперация, "РегистрационныйНомер, Дата");
	
	ПараметрыОперации.Вставить("РегистрационныйНомер",  Формат(ПараметрыТехОперации.РегистрационныйНомер, "ЧГ") + ?(ПараметрыОперации.Покупка, "D", "W"));
	
	Если ПараметрыОперации.Покупка Тогда
		Макет = ПолучитьМакет("DВыписка");
	Иначе
		Макет = ПолучитьМакет("WВыписка");
	КонецЕсли;
	
	ИмяВременногоФайла = ПолучитьИмяВременногоФайла("xml");
	Макет.Записать(ИмяВременногоФайла);
			
	ПутьКФайлу = ПараметрыОперации.КаталогФайловОтветаНРД_API + "\" + ПараметрыОперации.ИмяФайла;
	СоздатьКаталог(ПутьКФайлу);
	ПолноеИмяФайла = ПутьКФайлу + "\" + ПараметрыОперации.ИмяФайла + ".xml";
	
	СформироватьФайлВыписки(ПараметрыОперации, ИмяВременногоФайла, ПолноеИмяФайла);
	
	УдалитьФайлы(ИмяВременногоФайла);
	
	Возврат ПолноеИмяФайла;
	
КонецФункции

Процедура СформироватьФайлВыписки(ПараметрыОперации, ИмяФайлаШаблона, ИмяСформированногоФайла)
	
	ЧтениеXML = Новый ЧтениеXML;
	ЧтениеXML.ОткрытьФайл(ИмяФайлаШаблона);
	
	Построитель = Новый ПостроительDOM;
	ДокументDOM = Построитель.Прочитать(ЧтениеXML);
		
	УстановитьЗначенияТегов(ДокументDOM, "CreDt", XMLСтрока(УниверсальноеВремя(ПараметрыОперации.Дата)));
	УстановитьЗначенияТегов(ДокументDOM, "CreDtTm", XMLСтрока(ПараметрыОперации.Дата));
	УстановитьЗначенияТегов(ДокументDOM, "Dt", Формат(ПараметрыОперации.Дата, "ДФ=yyyy-MM-dd; ДЛФ="));
	УстановитьЗначенияТегов(ДокументDOM, "RltdDt", Формат(ПараметрыОперации.Дата, "ДФ=yyyy-MM-dd; ДЛФ="));
		
	BizMsgIdr = ДокументDOM.ПолучитьЭлементыПоИмени("BizMsgIdr")[0];
	BizMsgIdr.ТекстовоеСодержимое = ПараметрыОперации.ИДПлатежа;
	
	EndToEndId = ДокументDOM.ПолучитьЭлементыПоИмени("EndToEndId")[0]; 
	EndToEndId.ТекстовоеСодержимое = ПараметрыОперации.РегистрационныйНомер;
	
	ТегиAmt = ДокументDOM.ПолучитьЭлементыПоИмени("Amt"); 
	Для Каждого Amt из ТегиAmt Цикл
		Amt.ТекстовоеСодержимое = Формат(ПараметрыОперации.Сумма, "ЧГ=");
		Amt.УстановитьАтрибут("Ccy", Справочники.Валюты.ПредставлениеВалюты(ПараметрыОперации.Валюта));
	КонецЦикла;
	
	ЗаписьXML = Новый ЗаписьXML;
	ЗаписьXML.ОткрытьФайл(ИмяСформированногоФайла, "windows-1251");
	
	ЗаписьDOM = Новый ЗаписьDOM;
	ЗаписьDOM.Записать(ДокументDOM, ЗаписьXML);
	
	ЗаписьXML.Закрыть()
	
КонецПроцедуры

Процедура СформироватьReportH(ИмяФайла, ПараметрыПакета)
	
	ПараметрыТехОперации = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ТехОперация, "РегистрационныйНомер, КодОперации");
	
	dbf = Новый XBase(ИмяФайла);
	dbf.Первая();
	dbf.IN_REG_NO = ПараметрыТехОперации.РегистрационныйНомер;
	dbf.ORD_TYPE_I = ПараметрыТехОперации.КодОперации;
	dbf.REG_NO = ПараметрыПакета.НомерОтчетаНРД;
	dbf.REG_DATE = НачалоДня(ПараметрыПакета.ДатаОтчетаНРД);
	dbf.TREG_DATE = Формат(ПараметрыПакета.ДатаОтчетаНРД, "ДЛФ=T");
	dbf.OPERDAY = НачалоДня(ПараметрыПакета.ДатаИсполненияВДепозитарииМХ);
	Если ЗначениеЗаполнено(ПараметрыПакета.ПричинаОтмены) Тогда
		dbf.OUT_FORM = "GS001";
	КонецЕсли;
	Если ПараметрыПакета.Свойство("GS036") И ПараметрыПакета.GS036 Тогда
		dbf.OUT_FORM = "GS036";
	КонецЕсли;
	dbf.Записать();
	
КонецПроцедуры

Процедура СформироватьReportAbort(ИмяФайла, ПараметрыПакета)
	Если ИстекСрокИсполненияПоручения Тогда
		ПолучитьМакет("ZAbortПоСроку").Записать(ИмяФайла);
	Иначе
		dbf = Новый XBase(ИмяФайла);
		dbf.Кодировка = КодировкаXBase.OEM;
		dbf.Первая();
		dbf.REPORT_ID = "";
		dbf.ABORT_CAUS = ПараметрыПакета.ПричинаОтмены;
		dbf.MESS_TYPE = "";
		dbf.Записать();
	КонецЕсли;

КонецПроцедуры

Процедура СформироватьMessages(ИмяФайла, ПараметрыПакета)
	
	dbf = Новый XBase(ИмяФайла);
	dbf.Первая();
	dbf.MESSAGE = Обработки.TEST_ФормированиеОтчетовНРД.ПерекодированиеСтроки(ПараметрыПакета.TextMessageGS036);
	dbf.Записать();
	
КонецПроцедуры

Процедура СформироватьTranblsc(ИмяФайла, ПараметрыПакета)
	
	dbf = Новый XBase(ИмяФайла);
	dbf.Первая();
	dbf.SEQ_AMO = Формат(ПараметрыПакета.Количество, "ЧРГ=' '");	// В оригинальных файлах используются стандартные разделители триад - пробелы
	dbf.Записать();
	
КонецПроцедуры

Процедура СформироватьHbltrans(ИмяФайла, ПараметрыПакета)
	
	dbf = Новый XBase(ИмяФайла);
	dbf.Первая();
	dbf.OPER_DATE = НачалоДня(ПараметрыПакета.ДатаИсполненияВМестеРасчетов);	
	dbf.Записать();
	
КонецПроцедуры

Процедура СформироватьTranss(ИмяФайла, ПараметрыПакета)
	
	dbf = Новый XBase(ИмяФайла);
	dbf.Первая();
	dbf.SEQ_AMO = Формат(ПараметрыПакета.Количество, "ЧРГ=' '");
	dbf.Записать();
	
КонецПроцедуры

Функция ВременныйXMLФайлВыгрузкиКПакета(ПараметрыЗаписи)
		
	ЗаписьXML = Новый ЗаписьXML;
	ВременныйФайл = ПолучитьИмяВременногоФайла("xls");
	ЗаписьXML.ОткрытьФайл(ВременныйФайл,"windows-1251");
	ЗаписьXML.ЗаписатьОбъявлениеXML();
	
	ЗаписьXML.ЗаписатьНачалоЭлемента("Batch");
	ЗаписьXML.ЗаписатьНачалоЭлемента("Document");
	
	ЗаписьXML.ЗаписатьНачалоЭлемента("reg_no");
	ЗаписьXML.ЗаписатьТекст(ПараметрыЗаписи.reg_no);
	ЗаписьXML.ЗаписатьКонецЭлемента();
	
	ЗаписьXML.ЗаписатьНачалоЭлемента("reg_date");
	ЗаписьXML.ЗаписатьТекст(ПараметрыЗаписи.reg_date);
	ЗаписьXML.ЗаписатьКонецЭлемента();
	
	ЗаписьXML.ЗаписатьНачалоЭлемента("person_code");
	ЗаписьXML.ЗаписатьТекст(ПараметрыЗаписи.person_code);
	ЗаписьXML.ЗаписатьКонецЭлемента();
	
	ЗаписьXML.ЗаписатьНачалоЭлемента("contragent_doc_id");
	ЗаписьXML.ЗаписатьТекст(ПараметрыЗаписи.contragent_doc_id);
	ЗаписьXML.ЗаписатьКонецЭлемента();
	
	ЗаписьXML.ЗаписатьНачалоЭлемента("create_date");
	ЗаписьXML.ЗаписатьТекст(ПараметрыЗаписи.create_date);
	ЗаписьXML.ЗаписатьКонецЭлемента();
	
	ЗаписьXML.ЗаписатьНачалоЭлемента("depository_code");
	ЗаписьXML.ЗаписатьТекст(ПараметрыЗаписи.depository_code);
	ЗаписьXML.ЗаписатьКонецЭлемента();
	
	ЗаписьXML.ЗаписатьНачалоЭлемента("abort_code");
	ЗаписьXML.ЗаписатьТекст(ПараметрыЗаписи.abort_code);
	ЗаписьXML.ЗаписатьКонецЭлемента();
	
	ЗаписьXML.ЗаписатьНачалоЭлемента("abort_cause");
	ЗаписьXML.ЗаписатьТекст(ПараметрыЗаписи.abort_cause);
	ЗаписьXML.ЗаписатьКонецЭлемента();
	
	ЗаписьXML.ЗаписатьНачалоЭлемента("output_num");
	ЗаписьXML.ЗаписатьТекст(ПараметрыЗаписи.output_num);
	ЗаписьXML.ЗаписатьКонецЭлемента();
	
	ЗаписьXML.ЗаписатьКонецЭлемента();
	ЗаписьXML.ЗаписатьКонецЭлемента();
	
	ЗаписьXML.Закрыть();
	
	Возврат ВременныйФайл;
	
КонецФункции

Функция ВыгруженныйВШлюзФайлКПакета(ИмяВременногоФайла, ПараметрыПакета)
	
	ВнешнийИсточник = ПланыВидовХарактеристик.ВнешниеИсточники.ФайловыйШлюзКаталогВходящие;	
	НастройкиОбмена = ВнешниеДанные.ПолучитьПараметрыВнешнегоИсточника(ВнешнийИсточник);
	КорневаяПапка = НастройкиОбмена.Папка;
	
	КаталогШлюз = КорневаяПапка + "\" + ПараметрыПакета.ИмяФайла;
	СоздатьКаталог(КаталогШлюз);
	
	ИмяФайла = КаталогШлюз + "\" + ПараметрыПакета.ИмяФайла + ".xml";
	ПереместитьФайл(ИмяВременногоФайла, ИмяФайла);
	
	Возврат ИмяФайла;

КонецФункции

Процедура УстановитьЗначенияТегов(ДокументDOM, ИмяТега, Значение)
	
	СписокУзлов = ДокументDOM.ПолучитьЭлементыПоИмени(ИмяТега);
	Для Каждого Элемент из СписокУзлов Цикл
		Элемент.ТекстовоеСодержимое = Значение;
	КонецЦикла;
	
КонецПроцедуры

Функция СформироватьПодтвержлениеОперацииДС(ПараметрыОперации) Экспорт
	ИмяВременногоФайла = ЗаписатьФайлШаблонВыпискиИзМакета(Ложь);
			
	ПутьКФайлу = ПараметрыОперации.КаталогФайловОтветаНРД_API + "\" + ПараметрыОперации.ИмяФайла;
	СоздатьКаталог(ПутьКФайлу);
	ПолноеИмяФайла = ПутьКФайлу + "\" + ПараметрыОперации.ИмяФайла + ".xml";
	
	СформироватьФайлВыпискиДС(ПараметрыОперации, ИмяВременногоФайла, ПолноеИмяФайла);
	
	УдалитьФайлы(ИмяВременногоФайла);
	Возврат ПолноеИмяФайла;
КонецФункции

Функция ЗаписатьФайлШаблонВыпискиИзМакета(ЭтоПокупка)
	
	Если ЭтоПокупка Тогда
		Макет = ПолучитьМакет("DВыписка");
	Иначе
		Макет = ПолучитьМакет("WВыписка");
	КонецЕсли;
	
	ИмяВременногоФайла = ПолучитьИмяВременногоФайла("xml");
	Макет.Записать(ИмяВременногоФайла);

	Возврат ИмяВременногоФайла;
	
КонецФункции

Процедура СформироватьФайлВыпискиДС(ПараметрыОперации, ИмяФайлаШаблоно, имяСформированногоФайла)
	
	ЧтениеXML = Новый ЧтениеXML;
	ЧтениеXML.ОткрытьФайл(ИмяФайлаШаблоно);
	
	Построитель = Новый ПостроительDOM;
	ДокументDOM = Построитель.Прочитать(ЧтениеXML);
	
	BizMsgIdr = ДокументDOM.ПолучитьЭлементыПоИмени("BizMsgIdr")[0];
	BizMsgIdr.ТекстовоеСодержимое = ПараметрыОперации.ИДПлатежа;
	
	ВыгрузитьDt(ДокументDOM, "CreDt", XMLСтрока(УниверсальноеВремя(ПараметрыОперации.Дата)));
		
	ВыгрузитьAcct(ДокументDOM, "Ntfctn", "Acct", ПараметрыОперации.НомерБанковскогоСчета);
	ВыгрузитьAcct(ДокументDOM, "RltdPties", "CdtrAcct", ПараметрыОперации.НомерБанковскогоСчета);
	
	ВыгрузитьAcct(ДокументDOM, "RltdPties", "DbtrAcct", ПараметрыОперации.НомерТранзитногоСчета);
				
	ВыгрузитьAmt(ДокументDOM, "Amt", Новый Структура("Сумма, Валюта", ПараметрыОперации.Сумма, ПараметрыОперации.Валюта));
	
	ЗаписьXML = новый ЗаписьXML;
	ЗаписьXML.ОткрытьФайл(имяСформированногоФайла, "windows-1251");
	
	ЗаписьDOM = Новый ЗаписьDOM;
	ЗаписьDOM.Записать(ДокументDOM, ЗаписьXML);
	
	ЗаписьXML.Закрыть()
	
КонецПроцедуры

Процедура ВыгрузитьDt(ДокументDOM, ИмяТега, Значение)
	ТегXML = ДокументDOM.ПолучитьЭлементыПоИмени(ИмяТега);
	Для Каждого Dt из ТегXML Цикл
		Dt.ТекстовоеСодержимое = Значение;
	КонецЦикла;
КонецПроцедуры

Процедура ВыгрузитьAcct(ДокументDOM, Имя1, Имя2 , НомерСчета)
	Для Каждого Acc1 из ДокументDOM.ПолучитьЭлементыПоИмени(Имя1) Цикл
		Для Каждого Acc2 из Acc1.ПолучитьЭлементыПоИмени(Имя2) Цикл
			Для Каждого Id из Acc2.ПолучитьЭлементыПоИмени("Id") Цикл
				Для Каждого Othr из Id.ПолучитьЭлементыПоИмени("Othr") Цикл
					Для Каждого AccID из Othr.ПолучитьЭлементыПоИмени("Id") Цикл
						AccID.ТекстовоеСодержимое = НомерСчета;
					КонецЦикла;
				КонецЦикла;
			КонецЦикла;
		КонецЦикла;
	КонецЦикла;
КонецПроцедуры

Процедура ВыгрузитьAmt(ДокументDOM, ИмяТега, valAmt)
	ТегиAmt = ДокументDOM.ПолучитьЭлементыПоИмени(ИмяТега); 
	Для Каждого Amt из ТегиAmt Цикл
		Amt.ТекстовоеСодержимое = Формат(valAmt.Сумма, "ЧГ=");
		Amt.УстановитьАтрибут("Ccy", Справочники.Валюты.ПредставлениеВалюты(valAmt.Валюта));
	КонецЦикла;
КонецПроцедуры

#Область XML

Процедура СформироватьФайлыXML(ПараметрыПакета, ИмяРабочегоКаталога)
	
	ИмяФайла = ИмяРабочегоКаталога + "\repxml.xml";
	ДанныеПоФормеОтчета = ДанныеПоФормеОтчетаXML(ПараметрыПакета);
	ФормаОтчета = ДанныеПоФормеОтчета.ФормаОтчета;
	ПрочитанныйОбъект = ПрочитанныйОбъектПоИмениМакета(ДанныеПоФормеОтчета.ИмяМакета, ИмяФайла);
	ОсновнойУзел = ПрочитанныйОбъект.Document[ДанныеПоФормеОтчета.ИмяОсновногоУзла];
	SplmtryData = ОсновнойУзел.SplmtryData;
	
	Если ФормаОтчета = "GS036" Тогда
		ОсновнойУзел.Ntfctns[0].NtfctnTxt = ПараметрыПакета.TextMessageGS036;
	ИначеЕсли ФормаОтчета = "MS020" Тогда
		КоличествоЦБСтрокой = Формат(ПараметрыПакета.Количество, "ЧРГ=' '");
		ОсновнойУзел.QtyAndAcctDtls.SttldQty.Qty.Unit = КоличествоЦБСтрокой;
	ИначеЕсли ФормаОтчета = "GS001" Тогда
		ТекстПричиныОтмены = ?(ИстекСрокИсполненияПоручения, "Истек срок исполнения поручения.", ПараметрыПакета.ПричинаОтмены);
		Rsn = ОсновнойУзел.PrcgSts.Rjctd.Rsn;
		RjctdRsn = SplmtryData[0].Envlp.XtnsnDt.XtnsnGS001.RjctdRsn;
		МаксимальнаяДлинаСтроки = 210;
		Если СтрДлина(ТекстПричиныОтмены) > МаксимальнаяДлинаСтроки Тогда
			Rsn.AddtlRsnInf = "";
			RjctdRsn.RsnInf = ТекстПричиныОтмены;
		Иначе
			Rsn.AddtlRsnInf = ТекстПричиныОтмены;
			RjctdRsn.RsnInf = "";
		КонецЕсли;
		SplmtryData = SplmtryData[2];
	ИначеЕсли ФормаОтчета = "MS036" Тогда
		ОсновнойУзел.TradDtls.FctvSttlmDt.Dt.Dt = НачалоДня(ПараметрыПакета.ДатаИсполненияВМестеРасчетов);
		КоличествоЦБСтрокой = Формат(ПараметрыПакета.Количество, "ЧРГ=' '");
		ОсновнойУзел.QtyAndAcctDtls.SttldQty.Qty.Unit = КоличествоЦБСтрокой;
	Иначе
		ВызватьИсключение "Не удалось определить форму отчета!";
	КонецЕсли;
	
	ПараметрыТехОперации = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ТехОперация, "РегистрационныйНомер, КодОперации");
	TxPrcrDtls = SplmtryData.Envlp.XtnsnDt.TxPrcrDtls;
	TxPrcrDtls.TxId.AcctSvcrTxId = ПараметрыТехОперации.РегистрационныйНомер;
	TxPrcrDtls.PrcrTxDtls.PrcrTxCd = ПараметрыТехОперации.КодОперации;
	TxPrcrDtls.PrcrTxDtls.OprExctnDt.Dt = Формат(ПараметрыПакета.ДатаИсполненияВДепозитарииМХ, "ДФ=yyyy-MM-dd");
	AppHdr = ПрочитанныйОбъект.AppHdr;
	AppHdr.BizMsgIdr = ПараметрыПакета.НомерОтчетаНРД;
	ДатаОтчетаНРД_UTC = ПараметрыПакета.ДатаОтчетаНРД - СмещениеСтандартногоВремени(ЧасовойПояс());
	AppHdr.CreDt = Формат(ДатаОтчетаНРД_UTC, "ДФ=yyyy-MM-ddTHH:mm:ssZ");
	AppHdr.BizSvc = ФормаОтчета;
	ЗаписатьОбъект(ПрочитанныйОбъект, ИмяФайла);
	
КонецПроцедуры

Функция ДанныеПоФормеОтчетаXML(ПараметрыПакета)
	ДанныеПоФормеОтчета = Новый Структура("ФормаОтчета, ИмяОсновногоУзла, ИмяМакета");
	ЭтоБлокировка = ПараметрыПакета.ВидБлокировки = "Блокировка";
	ЭтоРазблокировка = ПараметрыПакета.ВидБлокировки = "Разблокировка";
	GS036 = "GS036";
	GS001 = "GS001";
	MS036 = "MS036";
	isGS036 = ПараметрыПакета.Свойство(GS036) И ПараметрыПакета.GS036;
	
	SctiesSttlmTxConf = "SctiesSttlmTxConf";
	Если isGS036 И ЗначениеЗаполнено(ПараметрыПакета.TextMessageGS036) Тогда
		ДанныеПоФормеОтчета.ФормаОтчета = GS036;
		ДанныеПоФормеОтчета.ИмяОсновногоУзла = GS036;
		ДанныеПоФормеОтчета.ИмяМакета = GS036;
	ИначеЕсли ЭтоБлокировка Тогда
		ДанныеПоФормеОтчета.ФормаОтчета = "MS020";
		ДанныеПоФормеОтчета.ИмяОсновногоУзла = SctiesSttlmTxConf;
		ДанныеПоФормеОтчета.ИмяМакета = "MS020_Блокирование";
	ИначеЕсли ЭтоРазблокировка Тогда
		ДанныеПоФормеОтчета.ФормаОтчета = MS036;
		ДанныеПоФормеОтчета.ИмяОсновногоУзла = SctiesSttlmTxConf;
		ДанныеПоФормеОтчета.ИмяМакета = "MS036_Разблокирование";
	Иначе
		Если ЗначениеЗаполнено(ПараметрыПакета.ПричинаОтмены) Или ИстекСрокИсполненияПоручения Тогда
			ДанныеПоФормеОтчета.ФормаОтчета = GS001;
			ДанныеПоФормеОтчета.ИмяОсновногоУзла = "SctiesSttlmTxStsAdvc";
			ДанныеПоФормеОтчета.ИмяМакета = GS001;
		Иначе
			ДанныеПоФормеОтчета.ФормаОтчета = MS036;
			ДанныеПоФормеОтчета.ИмяОсновногоУзла = SctiesSttlmTxConf;
			ДанныеПоФормеОтчета.ИмяМакета = MS036;
		КонецЕсли;
	КонецЕсли;
	
	Возврат ДанныеПоФормеОтчета;
КонецФункции

Функция ПрочитанныйОбъектПоИмениМакета(ИмяМакета, ИмяФайла)
	ИмяМакетаФайла = ИмяМакета + "_xml";
	ПолучитьМакет(ИмяМакетаФайла).Записать(ИмяФайла);
	Чтение = Новый ЧтениеXML;
	Чтение.ОткрытьФайл(ИмяФайла);
	ПрочитанныйОбъект = ФабрикаXDTO.ПрочитатьXML(Чтение);
	Чтение.Закрыть();
	Возврат ПрочитанныйОбъект;
КонецФункции

Процедура ЗаписатьОбъект(ПрочитанныйОбъект, ИмяФайла)
	Запись = Новый ЗаписьXML;
	Запись.ОткрытьФайл(ИмяФайла);
	Запись.ЗаписатьОбъявлениеXML();
	ФабрикаXDTO.ЗаписатьXML(Запись, ПрочитанныйОбъект, "ReportNSD", "urn:nsd:std:iso:20022:tech:xsd:rprt.envl.001.01");
	Запись.Закрыть();
КонецПроцедуры

#КонецОбласти

ОбщегоНазначения.ЛогироватьИспользованиеОбъекта(ЭтотОбъект);
