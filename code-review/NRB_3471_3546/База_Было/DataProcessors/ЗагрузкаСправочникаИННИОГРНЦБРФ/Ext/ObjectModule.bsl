
#Область ЭкспортныеПроцедурыИФункции

// Загружает данные из файла ЦБ РФ в регистр сведений
//
// Параметры:
//  ДанныеДляЗагрузки	 - ТаблицаЗначений - данные из файла ЦБ РФ
//  ДатаАктуальности	 - Дата - дата на которую актуальны данные из файла ЦБ РФ
//  ИмяФайла			 - Строка - имя файла, из которого выполняется загрузка данных
//
// Возвращаемое значение:
//  Структура - описание результатов загрузки в элменте структуры "ИтоговоеСообщение"
//
Функция ЗагрузитьДанныеЦБРФ(ДанныеДляЗагрузки, ДатаАктуальности, ИмяФайла) Экспорт
	
	ТекстОшибки = "";
	ВозможнаЗагрузка = РегистрыСведений.ЮридическиеЛицаЦБРФ.ВозможнаЗагрузкаДанныхНаДату(ДатаАктуальности, ТекстОшибки);
	Если Не ВозможнаЗагрузка Тогда
		ВызватьИсключение(ТекстОшибки);
	КонецЕсли;
	
	Ошибки = Новый Массив;
	Предупреждения = Новый Массив;
	Сто = 100;
	ВидыРазличий = Новый Структура;
	ВидыРазличий.Вставить("Отсутствует", 0);
	ВидыРазличий.Вставить("Удалить",	 1);
	ВидыРазличий.Вставить("Добавить",	 2);
	ВидыРазличий.Вставить("Обновить",	 3);
	
	ОписаниеВызова = РегистрыСведений.ЖурналРегистрацииВызовов.НовоеОписаниеВызова(
		"ИмяФайла = " + ИмяФайла, "Обработка.ЗагрузкаСправочникаИННИОГРНЦБРФ.ЗагрузитьДанныеЦБРФ");
	РегистрыСведений.ЖурналРегистрацииВызовов.ЗафиксироватьНачало(ОписаниеВызова);
	
	Выборка = ИзмененияВДанных(ДанныеДляЗагрузки, ДатаАктуальности, ВидыРазличий);
	
	ВсегоСтрокДляОбработки = Выборка.Количество();
	КоличествоСтрокОбновленияПрогресса = Окр(ВсегоСтрокДляОбработки / Сто);
	КоличествоСтрокОбновленияПрогресса = ?(КоличествоСтрокОбновленияПрогресса < Сто, Сто, КоличествоСтрокОбновленияПрогресса);	
	Статистика = Новый Структура;
	Статистика.Вставить("Добавлено",	 0);
	Статистика.Вставить("Обновлено",	 0);
	Статистика.Вставить("Удалено", 		 0);
	Статистика.Вставить("Отсутствует",	 0);
	Статистика.Вставить("Выгружено", 0);
	КоличествоОбработанныхЗаписей = 0;
	СчетчикПрогресса = 0;
	
	Пока Выборка.Следующий() Цикл
		Если Выборка.ВидРазличия = ВидыРазличий.Добавить Или Выборка.ВидРазличия = ВидыРазличий.Обновить Тогда
			ДобавитьОбновитьЗапись(Выборка, ВидыРазличий, Статистика, Ошибки);
		Иначе
			Если Выборка.ВидРазличия = ВидыРазличий.Удалить Тогда
				УдалитьЗапись(Выборка, Статистика, Ошибки);
			КонецЕсли;
			// Запись отсутствует в новой версии справочника
			ТекстСообщения = Выборка.Наименование + " (ИНН:" + Выборка.ИНН + ")";
			Предупреждения.Добавить(ТекстСообщения);
			Статистика.Отсутствует = Статистика.Отсутствует + 1;
		КонецЕсли;
		
		СчетчикПрогресса = СчетчикПрогресса + 1;
		КоличествоОбработанныхЗаписей = КоличествоОбработанныхЗаписей + 1;
		Если СчетчикПрогресса = КоличествоСтрокОбновленияПрогресса Тогда
			Процент = Формат(КоличествоОбработанныхЗаписей / ВсегоСтрокДляОбработки * Сто, "ЧДЦ=2");
			Текст = СтрШаблон("Обработано записей %1 из %2", КоличествоОбработанныхЗаписей, ВсегоСтрокДляОбработки);
			ДлительныеОперации.СообщитьПрогресс(Процент, Текст);
			СчетчикПрогресса = 0;
		КонецЕсли;
	КонецЦикла;
	
	РегистрыСведений.ПараметрыГлобальные.УстановитьЗначениеПараметра("2773.ДатаАктуальностиСправочникаИННИОГРНЦБРФ", ДатаАктуальности);
	Статистика.Вставить("СтрокDBF", ДанныеДляЗагрузки.Количество());
	Статистика.Вставить("Изменений", ВсегоСтрокДляОбработки - Статистика.Отсутствует);
	ИтоговоеСообщение = ИтоговоеСообщениеОРезультатахЗагрузки(ОписаниеВызова, ДатаАктуальности, Статистика, Ошибки, Предупреждения);
	
	Возврат ИтоговоеСообщение;
КонецФункции

#КонецОбласти


#Область СлужебныеПроцедурыИФункции

Функция ИзмененияВДанных(ДанныеДляЗагрузки, ДатаАктуальности, ВидыРазличий)
	Запрос = Новый Запрос;
	Запрос.Текст = 
	// BSLLS:FullOuterJoinQuery-off
	"ВЫБРАТЬ
	|	&ДатаАктуальности КАК Период,
	|	ТЗ_ДанныеДляЗагрузки.INN КАК ИНН,
	|	ТЗ_ДанныеДляЗагрузки.OPF КАК КПП,
	|	ТЗ_ДанныеДляЗагрузки.OGRN КАК ОГРН,
	|	ТЗ_ДанныеДляЗагрузки.NAIM КАК Наименование,
	|	ТЗ_ДанныеДляЗагрузки.PNAIM КАК ПолноеНаименование
	|ПОМЕСТИТЬ ВТ_НовыеДанные
	|ИЗ
	|	&ДанныеДляЗагрузки КАК ТЗ_ДанныеДляЗагрузки
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЮридическиеЛицаЦБРФСрезПоследних.Период КАК Период,
	|	ЮридическиеЛицаЦБРФСрезПоследних.ИНН КАК ИНН,
	|	ЮридическиеЛицаЦБРФСрезПоследних.КПП КАК КПП,
	|	ЮридическиеЛицаЦБРФСрезПоследних.ОГРН КАК ОГРН,
	|	ЮридическиеЛицаЦБРФСрезПоследних.Наименование КАК Наименование,
	|	ВЫРАЗИТЬ(ЮридическиеЛицаЦБРФСрезПоследних.ПолноеНаименование КАК СТРОКА(1000)) КАК ПолноеНаименование1000
	|ПОМЕСТИТЬ ВТ_ТекущиеДанные
	|ИЗ
	|	РегистрСведений.ЮридическиеЛицаЦБРФ.СрезПоследних(&ДатаАктуальности, 1 = 1) КАК ЮридическиеЛицаЦБРФСрезПоследних
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЕСТЬNULL(ВТ_НовыеДанные.ИНН, ВТ_ТекущиеДанные.ИНН) КАК ИНН,
	|	ЕСТЬNULL(ВТ_НовыеДанные.Период, ВТ_ТекущиеДанные.Период) КАК Период,
	|	ВТ_НовыеДанные.КПП КАК КПП,
	|	ВТ_НовыеДанные.ОГРН КАК ОГРН,
	|	ЕСТЬNULL(ВТ_НовыеДанные.Наименование, ВТ_ТекущиеДанные.Наименование) КАК Наименование,
	|	ВТ_НовыеДанные.ПолноеНаименование КАК ПолноеНаименование,
	|	ВЫБОР
	|		КОГДА ВТ_НовыеДанные.ИНН ЕСТЬ NULL И ВТ_ТекущиеДанные.Период <> &ДатаАктуальности
	|			ТОГДА &Отсутствует	// В справочниках за предыдущие даты был, теперь отсутствует
	|		КОГДА ВТ_НовыеДанные.ИНН ЕСТЬ NULL И ВТ_ТекущиеДанные.Период = &ДатаАктуальности
	|			ТОГДА &Удалить		// В прошлой версии справочник за эту же дату был, в текущей его нет
	|		КОГДА ВТ_ТекущиеДанные.ИНН ЕСТЬ NULL
	|			ТОГДА &Добавить
	|		ИНАЧЕ &Обновить
	|	КОНЕЦ КАК ВидРазличия,
	|	ВТ_НовыеДанные.ИНН КАК НовыйИНН
	|ПОМЕСТИТЬ ВТ_Изменения
	|ИЗ
	|	ВТ_НовыеДанные КАК ВТ_НовыеДанные
	|		ПОЛНОЕ СОЕДИНЕНИЕ ВТ_ТекущиеДанные КАК ВТ_ТекущиеДанные
	|		ПО ВТ_НовыеДанные.ИНН = ВТ_ТекущиеДанные.ИНН
	|ГДЕ
	|	(ВТ_НовыеДанные.КПП <> ВТ_ТекущиеДанные.КПП
	|			ИЛИ ВТ_НовыеДанные.ОГРН <> ВТ_ТекущиеДанные.ОГРН
	|			ИЛИ ВТ_НовыеДанные.Наименование <> ВТ_ТекущиеДанные.Наименование
	|			ИЛИ (ВЫРАЗИТЬ(ВТ_НовыеДанные.ПолноеНаименование КАК СТРОКА(1000))) <> ВТ_ТекущиеДанные.ПолноеНаименование1000
	|			ИЛИ ВТ_НовыеДанные.ИНН ЕСТЬ NULL
	|			ИЛИ ВТ_ТекущиеДанные.ИНН ЕСТЬ NULL)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_Изменения.НовыйИНН КАК ИНН
	|ПОМЕСТИТЬ ВТ_ДобавленныеИИзмененныеИНН
	|ИЗ
	|	ВТ_Изменения КАК ВТ_Изменения
	|ГДЕ
	|	ВТ_Изменения.ВидРазличия = &Добавить ИЛИ ВидРазличия = &Обновить
	|
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_Изменения.ИНН КАК ИНН,
	|	МАКСИМУМ(ЮридическиеЛица.Ссылка) КАК ЮрЛицо
	|ПОМЕСТИТЬ ВТ_ИзмененияВЮрлицахЭмитентах
	|ИЗ
	|	ВТ_Изменения КАК ВТ_Изменения
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ЮридическиеЛица КАК ЮридическиеЛица
	|		ПО ВТ_Изменения.НовыйИНН = ЮридическиеЛица.ИНН
	|			И НЕ ЮридическиеЛица.ПометкаУдаления
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Контрагенты КАК Контрагенты
	|		ПО  ЮридическиеЛица.Ссылка = Контрагенты.ЮридическиеФизическиеЛица
	|			И (НЕ Контрагенты.ПометкаУдаления)
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ЦенныеБумаги КАК ЦенныеБумаги
	|		ПО (ЦенныеБумаги.Эмитент = Контрагенты.Ссылка)
	|			И (НЕ ЦенныеБумаги.ПометкаУдаления)
	|СГРУППИРОВАТЬ ПО
	|	ВТ_Изменения.ИНН
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_ИзмененияВЮрлицахЭмитентах.ЮрЛицо КАК Юрлицо,
	|	ВТ_ИзмененияВЮрлицахЭмитентах.ИНН КАК ИНН,
	|	МАКСИМУМ(ЮридическиеЛица.TIN) КАК TIN,
	|	МАКСИМУМ(ЮридическиеЛица.Наименование) КАК НаименованиеЮЛ,
	|	МАКСИМУМ(КодыНРД.Код) КАК NrdCode,
	|	МАКСИМУМ(КодыLei.Код) КАК LeiCode,
	|	МАКСИМУМ(КодыRuData.Код) КАК RuDataCode
	|ПОМЕСТИТЬ ВТ_ИзмененияВЭмитентах
	|ИЗ
	|	ВТ_ИзмененияВЮрлицахЭмитентах КАК ВТ_ИзмененияВЮрлицахЭмитентах
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ЮридическиеЛица КАК ЮридическиеЛица
	|		ПО ВТ_ИзмененияВЮрлицахЭмитентах.ЮрЛицо = ЮридическиеЛица.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.КодыЗагрузки КАК КодыНРД
	|		ПО ВТ_ИзмененияВЮрлицахЭмитентах.ЮрЛицо = КодыНРД.Владелец
	|			И (КодыНРД.Биржа = ЗНАЧЕНИЕ(Справочник.КлассификаторыЗагрузки.NrdCode))
	|			И (НЕ КодыНРД.ПометкаУдаления)
	|			И (ВЫБОР
	|				КОГДА КодыНРД.ДатаОкончанияДействия = ДАТАВРЕМЯ(1, 1, 1)
	|					ТОГДА ИСТИНА
	|				КОГДА КодыНРД.ДатаОкончанияДействия > &ТекущаяДата
	|					ТОГДА ИСТИНА
	|				ИНАЧЕ ЛОЖЬ
	|			КОНЕЦ)
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.КодыЗагрузки КАК КодыRuData
	|		ПО ВТ_ИзмененияВЮрлицахЭмитентах.ЮрЛицо = КодыRuData.Владелец
	|			И (КодыRuData.Биржа = ЗНАЧЕНИЕ(Справочник.КлассификаторыЗагрузки.RuData))
	|			И (НЕ КодыRuData.ПометкаУдаления)
	|			И (ВЫБОР
	|				КОГДА КодыRuData.ДатаОкончанияДействия = ДАТАВРЕМЯ(1, 1, 1)
	|					ТОГДА ИСТИНА
	|				КОГДА КодыRuData.ДатаОкончанияДействия > &ТекущаяДата
	|					ТОГДА ИСТИНА
	|				ИНАЧЕ ЛОЖЬ
	|			КОНЕЦ)
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.КодыЗагрузки КАК КодыLei
	|		ПО ВТ_ИзмененияВЮрлицахЭмитентах.ЮрЛицо = КодыLei.Владелец
	|			И (КодыLei.Биржа = ЗНАЧЕНИЕ(Справочник.КлассификаторыЗагрузки.LEI_Code))
	|			И (НЕ КодыLei.ПометкаУдаления)
	|			И (ВЫБОР
	|				КОГДА КодыLei.ДатаОкончанияДействия = ДАТАВРЕМЯ(1, 1, 1)
	|					ТОГДА ИСТИНА
	|				КОГДА КодыLei.ДатаОкончанияДействия > &ТекущаяДата
	|					ТОГДА ИСТИНА
	|				ИНАЧЕ ЛОЖЬ
	|			КОНЕЦ)
	|
	|СГРУППИРОВАТЬ ПО
	|	ВТ_ИзмененияВЮрлицахЭмитентах.ЮрЛицо,
	|	ВТ_ИзмененияВЮрлицахЭмитентах.ИНН
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_Изменения.ИНН КАК ИНН,
	|	ВТ_Изменения.Период КАК Период,
	|	ВТ_Изменения.КПП КАК КПП,
	|	ВТ_Изменения.ОГРН КАК ОГРН,
	|	ВТ_Изменения.Наименование КАК Наименование,
	|	ВТ_Изменения.ПолноеНаименование КАК ПолноеНаименование,
	|	ВТ_Изменения.ВидРазличия КАК ВидРазличия,
	|	ВТ_ИзмененияВЭмитентах.Юрлицо КАК ЮрлицоЭмитент,
	|	ВТ_ИзмененияВЭмитентах.НаименованиеЮЛ КАК НаименованиеЮЛ,
	|	ВТ_ИзмененияВЭмитентах.TIN КАК TIN,
	|	ЕСТЬNULL(ВТ_ИзмененияВЭмитентах.NrdCode, """") КАК NrdCode,
	|	ЕСТЬNULL(ВТ_ИзмененияВЭмитентах.RuDataCode, """") КАК RuDataCode,
	|	ЕСТЬNULL(ВТ_ИзмененияВЭмитентах.LeiCode, """") КАК LeiCode
	|ИЗ
	|	ВТ_Изменения КАК ВТ_Изменения
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ИзмененияВЭмитентах КАК ВТ_ИзмененияВЭмитентах
	|		ПО (ВТ_Изменения.ИНН = ВТ_ИзмененияВЭмитентах.ИНН)
	|";
	// BSLLS:FullOuterJoinQuery-on
	Запрос.УстановитьПараметр("ТекущаяДата", ТекущаяДатаСеанса());
	Запрос.УстановитьПараметр("ДатаАктуальности", ДатаАктуальности);
	Запрос.УстановитьПараметр("ДанныеДляЗагрузки", ДанныеДляЗагрузки);
	Запрос.УстановитьПараметр("Отсутствует", ВидыРазличий.Отсутствует);
	Запрос.УстановитьПараметр("Удалить", ВидыРазличий.Удалить);
	Запрос.УстановитьПараметр("Добавить", ВидыРазличий.Добавить);
	Запрос.УстановитьПараметр("Обновить", ВидыРазличий.Обновить);
	Выборка = Запрос.Выполнить().Выбрать();
	
	Возврат Выборка;
КонецФункции

Процедура ДобавитьОбновитьЗапись(Выборка, ВидыРазличий, Статистика, Ошибки)
	МенеджерЗаписи = РегистрыСведений.ЮридическиеЛицаЦБРФ.СоздатьМенеджерЗаписи();
	ЗаполнитьЗначенияСвойств(МенеджерЗаписи, Выборка);
	Попытка
		МенеджерЗаписи.Записать();
		Если Выборка.ВидРазличия = ВидыРазличий.Добавить Тогда
			Если Статистика <> Неопределено Тогда
				Статистика.Добавлено = Статистика.Добавлено + 1;
			КонецЕсли;
		Иначе
			Если Статистика <> Неопределено Тогда
				Статистика.Обновлено = Статистика.Обновлено + 1;
			КонецЕсли;
		КонецЕсли;
		Если ЗначениеЗаполнено(Выборка.ЮрлицоЭмитент) Тогда
			ОбменДаннымиКафка.ВыгрузитьИНН_ОГРН_ЦБРФ_ЭмитентаВBackQort(Выборка);
			Статистика.Выгружено = Статистика.Выгружено + 1;
		КонецЕсли;
	Исключение
		ИнформацияОбОшибке = ИнформацияОбОшибке();
		ТекстОшибки = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке);
		Комментарий = "Ошибка " + ?(Выборка.ВидРазличия = ВидыРазличий.Добавить, "добавления", "обновления") + " ИНН: " + Выборка.ИНН + "; ";
		Ошибки.Добавить(Комментарий + ТекстОшибки);
	КонецПопытки;
КонецПроцедуры

Процедура УдалитьЗапись(Выборка, Статистика, Ошибки)
	НаборЗаписей = РегистрыСведений.ЮридическиеЛицаЦБРФ.СоздатьНаборЗаписей();
	НаборЗаписей.Отбор.ИНН.Установить(Выборка.ИНН);
	НаборЗаписей.Отбор.Период.Установить(Выборка.Период);
	Попытка
		НаборЗаписей.Записать();
		Если Статистика <> Неопределено Тогда
			Статистика.Удалено = Статистика.Удалено + 1;
		КонецЕсли;
	Исключение
		ИнформацияОбОшибке = ИнформацияОбОшибке();
		ТекстОшибки = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке);
		Комментарий = "Ошибка удаления ИНН: " + Выборка.ИНН + "; ";
		Ошибки.Добавить(Комментарий + ТекстОшибки);
	КонецПопытки;
КонецПроцедуры

Функция ИтоговоеСообщениеОРезультатахЗагрузки(ОписаниеВызова, ДатаАктуальности, Статистика, Ошибки, Предупреждения)
	Шаблон = " Строк в DBF = %1, в т.ч. новых и измененных = %2. ";
	Комментарий = СтрШаблон(Шаблон, Статистика.СтрокDBF, Статистика.Изменений);
	Если Статистика.Добавлено > 0 Или Статистика.Обновлено > 0 Или Статистика.Удалено > 0 Тогда
		Комментарий = Комментарий + "Записей регистра ";
		Операции = Новый Массив;
		Если Статистика.Добавлено > 0 Тогда
			Операции.Добавить("добавлено = " + Строка(Статистика.Добавлено));
		КонецЕсли;
		Если Статистика.Обновлено > 0 Тогда
			Операции.Добавить("обновлено = " + Строка(Статистика.Обновлено));
		КонецЕсли;
		Если Статистика.Удалено > 0 Тогда
			Операции.Добавить("удалено = " + Строка(Статистика.Удалено));
		КонецЕсли;
		Если Статистика.Выгружено > 0 Тогда
			Операции.Добавить("Выгружено в Kafka для BQ = " + Строка(Статистика.Выгружено));
		КонецЕсли;		
		Комментарий = Комментарий + СтрСоединить(Операции, ", ") + ". ";
	КонецЕсли;
	Комментарий = Комментарий + "Время выполнения: " + Строка(ТекущаяДатаСеанса() - ОписаниеВызова.ДатаВызова) + " сек. ";
	Шаблон = "Ошибок = %1, предупреждений = %2.";
	Комментарий = Комментарий + СтрШаблон(Шаблон, Ошибки.Количество(), Предупреждения.Количество());
	
	ДатаАктуальностиСтрокой = Формат(ДатаАктуальности, "ДФ=""дд.ММ.гггг""");
	КомментарийВызова = "Дата актуальности: " + ДатаАктуальностиСтрокой + "; " + Комментарий;
	
	ПерваяСтрокаСообщения = "Обновление регистра ""ЮридическиеЛицаЦБРФ"" на " + ДатаАктуальностиСтрокой + " завершено ";
	Если Ошибки.Количество() > 0 Тогда
		СписокОшибок = " Ошибки:" + Символы.ПС + СтрСоединить(Ошибки, Символы.ПС + "    ");
		РегистрыСведений.ЖурналРегистрацииВызовов.ЗафиксироватьОшибку(ОписаниеВызова, КомментарийВызова + Символы.ПС + СписокОшибок);
		ПерваяСтрокаСообщения = ПерваяСтрокаСообщения + " с ошибками!";
	Иначе
		РегистрыСведений.ЖурналРегистрацииВызовов.ЗафиксироватьОкончание(ОписаниеВызова, КомментарийВызова);
		ПерваяСтрокаСообщения = ПерваяСтрокаСообщения + " успешно!";
	КонецЕсли;
	
	ТекстСообщения = ПерваяСтрокаСообщения + Символы.ПС + Комментарий;
	Если Ошибки.Количество() > 0 Тогда
		ТекстСообщения = ТекстСообщения + Символы.ПС + СписокОшибок;
	КонецЕсли;
	Если Предупреждения.Количество() > 0 Тогда
		ТекстСообщения = ТекстСообщения + Символы.ПС + " Предупреждения - нет данных в новой версии справочника по следующим ЮЛ:"
							+ Символы.ПС + СтрСоединить(Предупреждения, ", ");
	КонецЕсли;
	
	Возврат ТекстСообщения;
КонецФункции

#КонецОбласти


