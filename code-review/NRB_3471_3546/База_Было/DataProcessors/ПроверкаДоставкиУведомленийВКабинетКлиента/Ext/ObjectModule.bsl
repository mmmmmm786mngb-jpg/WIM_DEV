// ИНТЕРФЕЙС

Перем ОбработкаВебСервисы Экспорт;

// Заполняет переменную модуля "ОбработкаВебСервисы"
// Вызов не обязателен.
Процедура ИнициироватьСоединение(Параметры = Неопределено) Экспорт
	ВнешниеДанные.ИнициироватьСоединение(ОбработкаВебСервисы, "ВебСервисы", Параметры);
КонецПроцедуры

// Заполняет таб. часть "Уведомления" данными со статусом "ВыгруженИз1С" за период
Процедура ЗаполнитьУведомленияВыгруженныеИз1С(пНачалоПериода, пКонецПериода) Экспорт
		
	ЭтотОбъект.НачалоПериода = пНачалоПериода;
	ЭтотОбъект.КонецПериода = пКонецПериода;
	ЗаполнитьУведомленияПоСтатусам(Перечисления.СтатусыДоставкиУведомленийВКабинетКлиента.ВыгруженИз1С);
	
	Если НЕ РегистрыСведений.ПараметрыГлобальные.ЗначениеПараметра("ДоработкаWEBПовторногоГолосованияКлиента",Ложь) Тогда		
		
		ИсключитьПовторныеУведомленияОГолосовании();		
		
	КонецЕсли;
	
КонецПроцедуры

// Заполняет таб. часть "Уведомления" данными со статусом "ВыгруженИз1С" и "СбойОтправки" за период
//
// Параметры:
//  ДатаНачала		 - Дата - Начало периода для отбора уведомлений
//  ДатаОкончания	 - Дата - Окончание периода для отбора уведомлений
//
Процедура ЗаполнитьУведомленияВыгруженныеИз1СИСбойОтправки(ДатаНачала, ДатаОкончания) Экспорт
	
	НачалоПериода = ДатаНачала;
	КонецПериода = ДатаОкончания;
	Статусы = Новый Массив;
	Статусы.Добавить(Перечисления.СтатусыДоставкиУведомленийВКабинетКлиента.ВыгруженИз1С);
	Статусы.Добавить(Перечисления.СтатусыДоставкиУведомленийВКабинетКлиента.СбойОтправки);
	ЗаполнитьУведомленияПоСтатусам(Статусы);
	
КонецПроцедуры

// Заполняет таб. часть "Уведомления" данными с любым статусом за период
Процедура ЗаполнитьВсеУведомления(пНачалоПериода, пКонецПериода) Экспорт
	ЭтотОбъект.НачалоПериода = пНачалоПериода;
	ЭтотОбъект.КонецПериода = пКонецПериода;
	
	Статусы = Новый Массив;
	Для Каждого Элемент Из Метаданные.Перечисления.СтатусыДоставкиУведомленийВКабинетКлиента.ЗначенияПеречисления Цикл
		Статусы.Добавить(Перечисления.СтатусыДоставкиУведомленийВКабинетКлиента[Элемент.Имя]);
	КонецЦикла;
	Статусы.Добавить(Перечисления.СтатусыДоставкиУведомленийВКабинетКлиента.ПустаяСсылка());
	
	ЗаполнитьУведомленияПоСтатусам(Статусы);
КонецПроцедуры

// Загружает в таб.часть "Уведомления" статусы доставки уведомлений о корпоративных действиях
// Возвращаемое значение:
//	булево - Истина, если удалось выполнить загрузку, иначе Ложь
Функция РезультатЗагрузкиСтатусовДоставкиУведомлений() Экспорт
	Если Уведомления.Количество() = 0 Тогда
		Возврат Истина;
	КонецЕсли;
	
	ИдентификаторыУведомлений = Уведомления.Выгрузить(, "УникальныйИдентификатор");
	ИдентификаторыУведомлений.Свернуть("УникальныйИдентификатор");
	ИдентификаторыУведомлений = ИдентификаторыУведомлений.ВыгрузитьКолонку("УникальныйИдентификатор");
	
	ДанныеУведомлений = Новый ТаблицаЗначений;
	ДанныеУведомлений.Колонки.Добавить("УникальныйИдентификатор");
	ДанныеУведомлений.Колонки.Добавить("ИдентификаторыКлиентов");
	
	Для Каждого Идентификатор Из ИдентификаторыУведомлений Цикл
		Отбор = Новый Структура("УникальныйИдентификатор, СтатусДоставки", Идентификатор,
			Перечисления.СтатусыДоставкиУведомленийВКабинетКлиента.ВыгруженИз1С);
		СтрокиТЧУведомления = Уведомления.НайтиСтроки(Отбор);
		
		НоваяСтрока = ДанныеУведомлений.Добавить();
		НоваяСтрока.УникальныйИдентификатор = Идентификатор;
		НоваяСтрока.ИдентификаторыКлиентов = КодыЗагрузкиКлиентов(СтрокиТЧУведомления);
	КонецЦикла;
	
	СтатусыДоставки = ВебСервисыСервер.СтатусыДоставкиУведомленийОКД(ДанныеУведомлений, ОбработкаВебСервисы);
	Если СтатусыДоставки = Неопределено Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Для Каждого СтрокаСтатуса Из СтатусыДоставки Цикл
		Отбор = Новый Структура("УникальныйИдентификатор, КодЗагрузки, СтатусДоставки", СтрокаСтатуса.GUID,
			СтрокаСтатуса.ClientId, Перечисления.СтатусыДоставкиУведомленийВКабинетКлиента.ВыгруженИз1С);
		СтрокиТЧУведомления = Уведомления.НайтиСтроки(Отбор);
		Для Каждого СтрокаТЧУведомления Из СтрокиТЧУведомления Цикл
			Если СтрокаСтатуса.Успешно Тогда
				СтрокаТЧУведомления.СтатусДоставки = Перечисления.СтатусыДоставкиУведомленийВКабинетКлиента.ЗагруженВКабинетКлиента;
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;
	
	Возврат Истина;
КонецФункции

// Загружает в таб.часть "Уведомления" данные, имеющиеся в СУДК, но отсутствующие в 1С
// Возвращаемое значение:
//	булево - Истина, если удалось выполнить загрузку, иначе Ложь
Функция РезультатЗагрузкиУведомленийОтсутствующихВ1С() Экспорт
	ИдентификаторыУведомлений = Уведомления.Выгрузить(, "УникальныйИдентификатор");
	ИдентификаторыУведомлений.Свернуть("УникальныйИдентификатор");
	ИдентификаторыУведомлений = ИдентификаторыУведомлений.ВыгрузитьКолонку("УникальныйИдентификатор");
	
	ДанныеУведомлений = Новый ТаблицаЗначений;
	ДанныеУведомлений.Колонки.Добавить("УникальныйИдентификатор");
	ДанныеУведомлений.Колонки.Добавить("ИдентификаторыКлиентов");
	
	Для Каждого Идентификатор Из ИдентификаторыУведомлений Цикл
		Отбор = Новый Структура("УникальныйИдентификатор", Идентификатор);
		СтрокиТЧУведомления = Уведомления.НайтиСтроки(Отбор);
		
		НоваяСтрока = ДанныеУведомлений.Добавить();
		НоваяСтрока.УникальныйИдентификатор = Идентификатор;
		НоваяСтрока.ИдентификаторыКлиентов = КодыЗагрузкиКлиентов(СтрокиТЧУведомления);
	КонецЦикла;
	
	ОтсутствующиеУведомления = ВебСервисыСервер.УведомленияКДОтстутствующиеВ1С(ДанныеУведомлений, НачалоПериода,
		КонецПериода, ОбработкаВебСервисы);
	Если ОтсутствующиеУведомления = Неопределено Тогда
		Возврат Ложь;
	КонецЕсли;
	
	КодыКлиентов = ОтсутствующиеУведомления.Скопировать(, "ClientId");
	КодыКлиентов.Свернуть("ClientId");
	КодыКлиентов = КодыКлиентов.ВыгрузитьКолонку("ClientId");
	Клиенты = КлиентыПоКодамЗагрузки(КодыКлиентов);
	
	Для Каждого Строка Из ОтсутствующиеУведомления Цикл
		НоваяСтрока = Уведомления.Добавить();
		НоваяСтрока.УникальныйИдентификатор = Строка.GUID;
		НоваяСтрока.КодЗагрузки = Строка.ClientId;
		НоваяСтрока.Клиент = Клиенты[Строка.ClientId];
		НоваяСтрока.СтатусДоставки = Перечисления.СтатусыДоставкиУведомленийВКабинетКлиента.ПустаяСсылка();
	КонецЦикла;
	
	Возврат Истина;
КонецФункции

Процедура УстановитьСтатусЗагруженВРегистреУведомлений() Экспорт
	Отбор = Новый Структура("СтатусДоставки", Перечисления.СтатусыДоставкиУведомленийВКабинетКлиента.ЗагруженВКабинетКлиента);
	СтрокиСтатусЗагружен = Уведомления.НайтиСтроки(Отбор);
	Для Каждого Строка Из СтрокиСтатусЗагружен Цикл
		РегистрыСведений.УведомленияОтправленныеЧерезЛичныйКабинет.УстановитьСтатусДоставки(
			Строка.ДокументУведомления, Строка.Клиент, Перечисления.СтатусыДоставкиУведомленийВКабинетКлиента.ВыгруженИз1С,
			Перечисления.СтатусыДоставкиУведомленийВКабинетКлиента.ЗагруженВКабинетКлиента);
	КонецЦикла;
КонецПроцедуры

Процедура ЗаписатьВЖурналРегистрацииОшибкиДоставкиУведомлений() Экспорт
	Для Каждого Строка Из Уведомления Цикл
		ЗаписьЖурналаРегистрации("Проверка доставки уведомлений в кабинет клиента", УровеньЖурналаРегистрации.Ошибка,,
			Строка.Клиент, "Не загружено уведомление в кабинет клиента по документу " + Строка.ДокументУведомления);
	КонецЦикла;
КонецПроцедуры

Процедура ЗаписатьВЖурналРегистрацииОшибкиОтсутствияУведомлений() Экспорт
	Отбор = Новый Структура("ДокументУведомления", Документы.УведомлениеКлиентам.ПустаяСсылка());
	СтрокиБезДокумента = Уведомления.НайтиСтроки(Отбор);
	
	УИДы = Новый Массив;
	
	Для Каждого Строка Из СтрокиБезДокумента Цикл
		Если УИДы.Найти(Строка.УникальныйИдентификатор) = Неопределено Тогда
			УИДы.Добавить(Строка.УникальныйИдентификатор);
		КонецЕсли;
	КонецЦикла;
	
	Для Каждого УникальныйИдентификатор Из УИДы Цикл
		ЗаписьЖурналаРегистрации("Проверка отсутствующих уведомлений", УровеньЖурналаРегистрации.Ошибка,,
			УникальныйИдентификатор, "Уникальный идентификатор документа обнаружен в СУДК, но отсутствует в 1С");
	КонецЦикла;
КонецПроцедуры

Процедура ОтправитьСообщениеОНедоставленныхУведомлениях() Экспорт
	ОтправитьСообщениеПоЭлПочте("Уведомления, не доставленные в кабинет клиента",
		HTMLТекстПисьмаОНедоставленныхУведомлениях());
КонецПроцедуры

Процедура ОтправитьСообщениеОбОтсутствующихУведомлениях() Экспорт
	ОтправитьСообщениеПоЭлПочте("Уведомления СУДК, отсутствующие в 1С", HTMLТекстПисьмаОбОтсутствующихУведомлениях());
КонецПроцедуры

