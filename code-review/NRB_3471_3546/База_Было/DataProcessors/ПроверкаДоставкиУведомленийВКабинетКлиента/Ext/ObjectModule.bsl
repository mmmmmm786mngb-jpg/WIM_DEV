// ВСПОМОГАТЕЛЬНЫЕ ПРОЦЕДУРЫ И ФУНКЦИИ

// Возвращает массив неповторяющихся кодов загрузки клиентов из переданных строк таб.части обработки
//
// Параметры:
//	СтрокиТабЧастиУведомления - массив строк таб.части "Уведомления"
// Возвращаемое значение:
//	массив строк - неповторяющихся кодов загрузки
Функция КодыЗагрузкиКлиентов(СтрокиТабЧастиУведомления)
	Коды = Новый Массив;
	Для Каждого Строка Из СтрокиТабЧастиУведомления Цикл
		Если Коды.Найти(Строка.КодЗагрузки) = Неопределено Тогда
			Коды.Добавить(Строка.КодЗагрузки);
		КонецЕсли;
	КонецЦикла;
	Возврат Коды;
КонецФункции

// Заполняет таб. часть "Уведомления" по записям РС УведомленияОтправленныеЧерезЛичныйКабинет за период из обработки
// с отбором по статусам
//
// Параметры:
//	Статусы - массив или один элемент перечисления СтатусыДоставкиУведомленийВКабинетКлиента
Процедура ЗаполнитьУведомленияПоСтатусам(Статусы)
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	РегистрУведомлений.КД КАК ДокументУведомления,
	|	РегистрУведомлений.Клиент КАК Клиент,
	|	КодыЗагрузки.Код КАК КодЗагрузки,
	|	РегистрУведомлений.СтатусДоставкиУведомления КАК СтатусДоставки,
	|	РегистрУведомлений.ИдентификаторУведомления КАК УникальныйИдентификатор
	|ИЗ
	|	РегистрСведений.УведомленияОтправленныеЧерезЛичныйКабинет КАК РегистрУведомлений
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.КодыЗагрузки КАК КодыЗагрузки
	|		ПО РегистрУведомлений.Клиент = КодыЗагрузки.Владелец
	|			И (НЕ КодыЗагрузки.ПометкаУдаления)
	|			И (КодыЗагрузки.Биржа = &КлассификаторыЗагрузки)
	|			И (КодыЗагрузки.ДатаОкончанияДействия = ДАТАВРЕМЯ(1, 1, 1)
	|				ИЛИ КодыЗагрузки.ДатаОкончанияДействия > &КонецПериода)
	|ГДЕ
	|	РегистрУведомлений.СтатусДоставкиУведомления В(&Статусы)
	|	И РегистрУведомлений.Период МЕЖДУ &НачалоПериода И &КонецПериода
	|	И ВЫБОР
	|			КОГДА РегистрУведомлений.КД ССЫЛКА Документ.ЗаявлениеНаУчастиеВОферте
	|				ТОГДА ИСТИНА
	|			КОГДА РегистрУведомлений.КД ССЫЛКА Документ.УведомлениеКлиентам
	|					И ВЫРАЗИТЬ(РегистрУведомлений.КД КАК Документ.УведомлениеКлиентам).Дата <= &КонецПериода
	|				ТОГДА ИСТИНА
	|			КОГДА РегистрУведомлений.КД ССЫЛКА Документ.СводныйОтчетОСовершенныхОперациях
	|				ТОГДА ИСТИНА
	|			ИНАЧЕ ЛОЖЬ
	|		КОНЕЦ
	|
	|УПОРЯДОЧИТЬ ПО
	|	РегистрУведомлений.КД.Дата,
	|	РегистрУведомлений.Клиент.Наименование");
	Запрос.УстановитьПараметр("Статусы", Статусы);
	Запрос.УстановитьПараметр("НачалоПериода", ЭтотОбъект.НачалоПериода);
	Запрос.УстановитьПараметр("КонецПериода", ЭтотОбъект.КонецПериода);
	Запрос.УстановитьПараметр("КлассификаторыЗагрузки", Справочники.КлассификаторыЗагрузки.CrmContractNumber);
	Уведомления.Загрузить(Запрос.Выполнить().Выгрузить());
	
	Для Каждого ДанныеУведомления Из Уведомления Цикл
		ДанныеУведомления.КодЗагрузки = СокрЛП(ДанныеУведомления.КодЗагрузки);
	КонецЦикла;
КонецПроцедуры

Процедура ИсключитьПовторныеУведомленияОГолосовании()
	
	ТаблицаУведомлений = Уведомления.Выгрузить();
	ТаблицаУведомлений.Свернуть("ДокументУведомления");
	
	Для каждого Стр из ТаблицаУведомлений Цикл
		
		ДокументУведомления = Стр.ДокументУведомления;
		Если ТипЗнч(ДокументУведомления) = Тип("ДокументСсылка.СводныйОтчетОСовершенныхОперациях") Тогда
			Продолжить;
		КонецЕсли;
		
		Если СтрНайти(ДокументУведомления.ТелоСообщения,"#СсылкаДляУчастияВГолосовании#",НаправлениеПоиска.СКонца) <> 0 Тогда
			
			Удалить = ЗапросПодчиненныхУведомлений(ДокументУведомления);
			
			Если Удалить <> Неопределено Тогда
				
				ПараметрыОтбора = Новый Структура();
				ПараметрыОтбора.Вставить("ДокументУведомления",ДокументУведомления);
				НайденныеУведомления = Уведомления.НайтиСтроки(ПараметрыОтбора);

				Для каждого Увед из НайденныеУведомления Цикл
					Уведомления.Удалить(Увед);
				КонецЦикла;
				
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

Функция ЗапросПодчиненныхУведомлений(УведомлениеКлиентам)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	УведомлениеКлиентам.ДокументОснование КАК ДокументОснование,
		|	УведомлениеКлиентам.Ссылка КАК Уведомление
		|ПОМЕСТИТЬ втДокументОснование
		|ИЗ
		|	Документ.УведомлениеКлиентам КАК УведомлениеКлиентам
		|ГДЕ
		|	УведомлениеКлиентам.Ссылка = &УведомлениеКлиентам
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	УведомлениеКлиентам.Ссылка КАК Ссылка
		|ИЗ
		|	втДокументОснование КАК втДокументОснование
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.УведомлениеКлиентам КАК УведомлениеКлиентам
		|		ПО втДокументОснование.ДокументОснование = УведомлениеКлиентам.ДокументОснование
		|ГДЕ
		|	УведомлениеКлиентам.СозданаСтраницаГолосованияВКабинетеКлиента
		|	И втДокументОснование.Уведомление <> УведомлениеКлиентам.Ссылка";
	
	Запрос.УстановитьПараметр("УведомлениеКлиентам", УведомлениеКлиентам);
	
	Если НЕ Запрос.Выполнить().Пустой() Тогда
		
		Возврат Истина;
			
	КонецЕсли;
	
КонецФункции

// Получает по кодам загрузки клиентов ссылки на спр. Контрагенты
//
// Параметры:
//	КодыКлиентов - массив строк - кодов загрузки клиентов
//
// Возвращаемое значение:
//	соответствие КодЗагрузки-Клиент
Функция КлиентыПоКодамЗагрузки(КодыКлиентов)
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	КодыЗагрузки.Владелец КАК Клиент,
	|	КодыЗагрузки.Код КАК КодЗагрузки
	|ИЗ
	|	Справочник.КодыЗагрузки КАК КодыЗагрузки
	|ГДЕ
	|	НЕ КодыЗагрузки.ПометкаУдаления
	|	И КодыЗагрузки.Биржа = &КлассификаторыЗагрузкиКлиенты
	|	И (КодыЗагрузки.ДатаОкончанияДействия = ДАТАВРЕМЯ(1, 1, 1)
	|			ИЛИ КодыЗагрузки.ДатаОкончанияДействия > &КонецПериода)
	|	И КодыЗагрузки.Владелец ССЫЛКА Справочник.Контрагенты
	|	И КодыЗагрузки.Код В(&КодыКлиентов)");
	Запрос.УстановитьПараметр("КодыКлиентов", КодыКлиентов);
	Запрос.УстановитьПараметр("КонецПериода", ЭтотОбъект.КонецПериода);
	Запрос.УстановитьПараметр("КлассификаторыЗагрузкиКлиенты", Справочники.КлассификаторыЗагрузки.Клиенты);
	Клиенты = Новый Соответствие;
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		Клиенты.Вставить(СокрЛП(Выборка.КодЗагрузки), Выборка.Клиент);
	КонецЦикла;
	Возврат Клиенты;
КонецФункции

Функция HTMLТекстПисьмаОНедоставленныхУведомлениях()
	Строки = Новый Массив;
	
	Если Уведомления.Количество() = 0 Тогда
		Текст = "<p>За период с %1 по %2 <strong>доставлены все</strong> уведомления.</p>";
		Текст = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(Текст, ЭтотОбъект.НачалоПериода,
			ЭтотОбъект.КонецПериода);
		Строки.Добавить(Текст);
	Иначе
		Текст = "<p>За период с %1 по %2 <strong>не доставлены</strong> уведомления:</p>";
		Текст = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(Текст, ЭтотОбъект.НачалоПериода,
			ЭтотОбъект.КонецПериода);
		Строки.Добавить(Текст);
		
		Строки.Добавить("<table border=""1"" cellpadding=""5"" cellspacing=""0"" bordercolor=""gray"">");
		Строки.Добавить(
		"<tr>
		|<td>Документ уведомления</td>
		|<td>GUID</td>
		|<td>ContractNumber</td>
		|<td>Текущий статус</td>
		|</tr>");
		Для Каждого ДанныеУведомления Из Уведомления Цикл
			Текст =
			"<tr>
			|<td>%1</td>
			|<td>%2</td>
			|<td>%3</td>
			|<td>%4</td>
			|</tr>";
			Строки.Добавить(СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(Текст,
				СокрЛП(СтроковыеФункцииКлиентСервер.HTMLСтрока(ДанныеУведомления.ДокументУведомления)),
				СокрЛП(СтроковыеФункцииКлиентСервер.HTMLСтрока(ДанныеУведомления.УникальныйИдентификатор)),
				СокрЛП(СтроковыеФункцииКлиентСервер.HTMLСтрока(ДанныеУведомления.КодЗагрузки)),
				СокрЛП(СтроковыеФункцииКлиентСервер.HTMLСтрока(ДанныеУведомления.СтатусДоставки))));
		КонецЦикла;
		Строки.Добавить("</table>");
	КонецЕсли;
	
	Возврат СтроковыеФункцииКлиентСервер.ПолучитьСтрокуИзМассиваПодстрок(Строки, Символы.ПС);
КонецФункции

Функция HTMLТекстПисьмаОбОтсутствующихУведомлениях()
	Строки = Новый Массив;
	
	Отбор = Новый Структура("ДокументУведомления", Документы.УведомлениеКлиентам.ПустаяСсылка());
	СтрокиУведомлений = Уведомления.НайтиСтроки(Отбор);
	Если СтрокиУведомлений.Количество() = 0 Тогда
		Текст = "<p>За период с %1 по %2 <strong>не обнаружено</strong> уведомлений СУДК, отсутствующих в 1С.</p>";
		Текст = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(Текст, ЭтотОбъект.НачалоПериода,
			ЭтотОбъект.КонецПериода);
		Строки.Добавить(Текст);
	Иначе
		Текст = "<p>За период с %1 по %2 <strong>обнаружены</strong> уведомления СУДК, отсутствующие в 1С:</p>";
		Текст = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(Текст, ЭтотОбъект.НачалоПериода,
			ЭтотОбъект.КонецПериода);
		Строки.Добавить(Текст);
		
		Строки.Добавить("<table border=""1"" cellpadding=""5"" cellspacing=""0"" bordercolor=""gray"">");
		Строки.Добавить(
		"<tr>
		|<td>GUID</td>
		|<td>Клиент</td>
		|<td>Client ID</td>
		|</tr>");
		Для Каждого ДанныеУведомления Из СтрокиУведомлений Цикл
			Текст =
			"<tr>
			|<td>%1</td>
			|<td>%2</td>
			|<td>%3</td>
			|</tr>";
			Строки.Добавить(СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(Текст,
				СокрЛП(СтроковыеФункцииКлиентСервер.HTMLСтрока(ДанныеУведомления.УникальныйИдентификатор)),
				СокрЛП(СтроковыеФункцииКлиентСервер.HTMLСтрока(ДанныеУведомления.Клиент.Код)),
				СокрЛП(СтроковыеФункцииКлиентСервер.HTMLСтрока(ДанныеУведомления.КодЗагрузки))));
		КонецЦикла;
		Строки.Добавить("</table>");
		
		Если Уведомления.Количество() > СтрокиУведомлений.Количество() Тогда
			Строки.Добавить("<p>Уведомления, выгруженные из 1С/загруженные в кабинет клиента за период:</p>");
			Строки.Добавить("<table border=""1"" cellpadding=""5"" cellspacing=""0"" bordercolor=""gray"">");
			Строки.Добавить(
			"<tr>
			|<td>Документ уведомления</td>
			|<td>GUID</td>
			|<td>Клиент</td>
			|<td>Client ID</td>
			|<td>Статус</td>
			|</tr>");
			Для Каждого ДанныеУведомления Из Уведомления Цикл
				Если НЕ ЗначениеЗаполнено(ДанныеУведомления.ДокументУведомления) Тогда
					Продолжить;
				КонецЕсли;
				
				Текст =
				"<tr>
				|<td>%1</td>
				|<td>%2</td>
				|<td>%3</td>
				|<td>%4</td>
				|<td>%5</td>
				|</tr>";
				Строки.Добавить(СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(Текст,
					СокрЛП(СтроковыеФункцииКлиентСервер.HTMLСтрока(ДанныеУведомления.ДокументУведомления)),
					СокрЛП(СтроковыеФункцииКлиентСервер.HTMLСтрока(ДанныеУведомления.УникальныйИдентификатор)),
					СокрЛП(СтроковыеФункцииКлиентСервер.HTMLСтрока(ДанныеУведомления.Клиент.Код)),
					СокрЛП(СтроковыеФункцииКлиентСервер.HTMLСтрока(ДанныеУведомления.КодЗагрузки)),
					СокрЛП(СтроковыеФункцииКлиентСервер.HTMLСтрока(ДанныеУведомления.СтатусДоставки))));
			КонецЦикла;
			Строки.Добавить("</table>");
		Иначе
			Строки.Добавить("<p>Нет уведомлений, выгруженных из 1С или загруженных в кабинет клиента за период.</p>");			
		КонецЕсли;
	КонецЕсли;
	
	Возврат СтроковыеФункцииКлиентСервер.ПолучитьСтрокуИзМассиваПодстрок(Строки, Символы.ПС);
КонецФункции

Процедура ОтправитьСообщениеПоЭлПочте(ТемаПисьма, ТекстПисьма)
	ВнешнийИсточник = ПланыВидовХарактеристик.ВнешниеИсточники.РассылкаОтчетовОДоставкеУведомленийВКК;
	НастройкиОбмена = ВнешниеДанные.ПолучитьПараметрыВнешнегоИсточника(ВнешнийИсточник).Настройка;
	
	Если НастройкиОбмена = Неопределено Тогда
		ТекстОшибки = "Не заданы параметры внешнего источника " + ВнешнийИсточник;
		#Если Клиент Тогда
		ОбщегоНазначения.СообщитьОбОшибке(ТекстОшибки);
		#КонецЕсли
		ИмяСобытия = "Рассылка отчетов о доставке уведомлений в КК";
		ЗаписьЖурналаРегистрации(ИмяСобытия, УровеньЖурналаРегистрации.Ошибка,, ВнешнийИсточник, ТекстОшибки);
		Возврат;
	КонецЕсли;
	
	ПараметрыУведомления = Новый Соответствие;
	ПараметрыУведомления.Вставить("НастройкиОбмена",	НастройкиОбмена);
	ПараметрыУведомления.Вставить("Кодировка",			"UTF-8");
	ПараметрыУведомления.Вставить("ТемаПисьма",			ТемаПисьма);
	ПараметрыУведомления.Вставить("ТекстПисьма",		ТекстПисьма);
	ПараметрыУведомления.Вставить("ТипТекстаПисьма",	ТипТекстаПочтовогоСообщения.HTML);
	ПараметрыУведомления.Вставить("Важность",			ВажностьИнтернетПочтовогоСообщения.Обычная);
	
	РегистрыСведений.УведомленияКОтправке.ДобавитьУведомлениеКотправке(ПараметрыУведомления);				
КонецПроцедуры

ОбщегоНазначения.ЛогироватьИспользованиеОбъекта(ЭтотОбъект);
