///////////////////////////////////////////////////////////////////////////
// ОБРАБОТЧИКИ СОБЫТИЙ ФОРМЫ

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	ДатаОтбора = ТекущаяДата();
	Объект.НачалоПериода = НачалоДня(ДатаОтбора);
	Объект.КонецПериода = ДатаОтбора - 5*60;
	
	Если Параметры.Свойство("ИмяОбработкиВебСервисы") Тогда
		ИмяОбработкиВебСервисы = Параметры.ИмяОбработкиВебСервисы;
	КонецЕсли;
КонецПроцедуры

///////////////////////////////////////////////////////////////////////////
// ОБРАБОТЧИКИ КОМАНД ФОРМЫ

&НаКлиенте
Процедура ЗаполнитьВыгруженныеИз1С(Команда)
	ЗаполнитьВыгруженныеИз1СНаСервере();
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьВсе(Команда)
	ЗаполнитьВсеНаСервере();
КонецПроцедуры

///////////////////////////////////////////////////////////////////////////
// ВСПОМОГАТЕЛЬНЫЕ ПРОЦЕДУРЫ И ФУНКЦИИ

&НаСервере
Процедура ЗаполнитьВыгруженныеИз1СНаСервере()
	ОбработкаОбъект = РеквизитФормыВЗначение("Объект");
	ОбработкаОбъект.ЗаполнитьУведомленияВыгруженныеИз1С(Объект.НачалоПериода, Объект.КонецПериода);
	ЗначениеВРеквизитФормы(ОбработкаОбъект, "Объект");
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьВсеНаСервере()
	ОбработкаОбъект = РеквизитФормыВЗначение("Объект");
	ОбработкаОбъект.ЗаполнитьВсеУведомления(Объект.НачалоПериода, Объект.КонецПериода);
	ЗначениеВРеквизитФормы(ОбработкаОбъект, "Объект");
КонецПроцедуры
