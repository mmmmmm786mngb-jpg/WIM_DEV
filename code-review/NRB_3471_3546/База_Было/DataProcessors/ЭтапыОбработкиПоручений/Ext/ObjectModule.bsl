// ИНТЕРФЕЙС

Перем ВыполнениеПорученийВQUIK Экспорт;

Процедура ИнициироватьСоединениеQUIK(Параметры = Неопределено)
	ВнешниеДанные.ИнициироватьСоединение(ВыполнениеПорученийВQUIK, "ВыполнениеПорученийВQUIK", Параметры);
КонецПроцедуры

Процедура ЗаполнитьПоДокументам() Экспорт
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	ДокументПоручение.Ссылка КАК Документ
	|ИЗ
	|	Документ.Поручение КАК ДокументПоручение
	|ГДЕ
	|	ДокументПоручение.Проведен
	|	И ДокументПоручение.ПринятьВОбработку
	|
	|УПОРЯДОЧИТЬ ПО
	|	ДокументПоручение.МоментВремени");
	ДокументыКОбработке.Загрузить(Запрос.Выполнить().Выгрузить());
КонецПроцедуры

Процедура ЗаполнитьИзМассива(Ссылки) Экспорт
	ДокументыКОбработке.Очистить();
	Для Каждого Ссылка Из Ссылки Цикл
		НоваяСтрока = ДокументыКОбработке.Добавить();
		НоваяСтрока.Документ = Ссылка;
	КонецЦикла;
КонецПроцедуры

Функция РезультатИсполненияЭтапаОбработки() Экспорт
	Ошибки = "";
	Выборка = ВыборкаДокументовКОбработке();
	МаршрутЧастичногоИсполнения = МаршрутЧастичноеИсполнениеДокумента();
	
	Пока Выборка.Следующий() Цикл
		Если Не ПроверкаПолнотыПула(Выборка, Ошибки) Тогда
			Продолжить;
		КонецЕсли;
		
		Если Выборка.ПоручениеОтменено Тогда
			МаршрутОтменыПоручения = МаршрутОтменыПоручения(Выборка);
			Если МаршрутОтменыПоручения.Найти(Выборка.ТекущийЭтап) = Неопределено Тогда
				ЗавершитьТекущийЭтапБезИсполнения(Выборка, "Поручение отменено");
			КонецЕсли;
			ЭтапОбработки = ЭтапОбработкиОтменыПоручения(Выборка, МаршрутОтменыПоручения);
		ИначеЕсли ЗначениеЗаполнено(Выборка.ТекущийЭтап) И Не ЗначениеЗаполнено(Выборка.ДатаОкончания) Тогда
			ЭтапОбработки = Выборка.ТекущийЭтап;
		Иначе
			Если МаршрутЧастичногоИсполнения.Найти(Выборка.ТекущийЭтап) <> Неопределено
				И ЭтоТекущееЧастичноеИсполнение(Выборка.Документ) Тогда
				Маршрут = МаршрутЧастичногоИсполнения;
			Иначе
				Маршрут = МаршрутПолноеИсполнениеДокумента(Выборка);
			КонецЕсли;
			Результат = СледующийЭтапОбработки(Выборка.Документ, Выборка.ТекущийЭтап, Маршрут);
			Если ЗначениеЗаполнено(Результат.Ошибка) Тогда
				Ошибки = Ошибки + ?(ЗначениеЗаполнено(Ошибки), Символы.ПС, "") + Результат.Ошибка;
				Продолжить;
			КонецЕсли;
			ЭтапОбработки = Результат.СледующийЭтап;
		КонецЕсли;
		
		Если ЗначениеЗаполнено(ЭтапОбработки) Тогда
			ИсполнитьЭтапОбработкиПоручения(Выборка, ЭтапОбработки);
		Иначе
			ДокументОбъект = Выборка.Документ.ПолучитьОбъект();
			ДокументОбъект.ОбменДанными.Загрузка = Истина;
			ДокументОбъект.ПринятьВОбработку = Ложь;
			Попытка
				ДокументОбъект.Записать(РежимЗаписиДокумента.Запись);
			Исключение
				Ошибки = Ошибки + ?(ЗначениеЗаполнено(Ошибки), Символы.ПС, "") + "Не удалось записать "
					+ Выборка.Документ;
			КонецПопытки;
		КонецЕсли;
	КонецЦикла;
	Возврат Ошибки;
КонецФункции

Функция РезультатПереходаКСледующемуЭтапу() Экспорт
	Ошибки = "";
	Выборка = ВыборкаДокументовКОбработке();
	Пока Выборка.Следующий() Цикл
		Маршрут = МаршрутПолноеИсполнениеДокумента(Выборка);
		Результат = СледующийЭтапОбработки(Выборка.Документ, Выборка.ТекущийЭтап, Маршрут);
		Если ЗначениеЗаполнено(Результат.Ошибка) Тогда
			Ошибки = Ошибки + ?(ЗначениеЗаполнено(Ошибки), Символы.ПС, "") + Результат.Ошибка;
			Продолжить;
		КонецЕсли;
		
		Если ЗначениеЗаполнено(Результат.СледующийЭтап) Тогда
			РегистрыСведений.ЭтапыОбработкиПоручений.ОбновитьЭтап(Выборка.Документ, Результат.СледующийЭтап,
				ТекущаяДата(), '00010101', "Переведен принудительно");
		Иначе
			ДокументОбъект = Выборка.Документ.ПолучитьОбъект();
			ДокументОбъект.ОбменДанными.Загрузка = Истина;
			ДокументОбъект.ПринятьВОбработку = Ложь;
			Попытка
				ДокументОбъект.Записать(РежимЗаписиДокумента.Запись);
			Исключение
				Ошибки = Ошибки + ?(ЗначениеЗаполнено(Ошибки), Символы.ПС, "") + "Не удалось записать "
					+ Выборка.Документ;
			КонецПопытки;
		КонецЕсли;
	КонецЦикла;
	Возврат Ошибки;
КонецФункции

/////////////////////////////////////////////////////////////////////////////////////
// РЕАЛИЗАЦИЯ ФУНКЦИОНАЛА ОБРАБОТКИ

Функция СледующийЭтапОбработки(Документ, ПредыдущийЭтап, Маршрут)
	Результат = Новый Структура("СледующийЭтап,Ошибка", Справочники.ЭтапыОбработкиПоручений.ПустаяСсылка(), "");
	
	Если ЗначениеЗаполнено(ПредыдущийЭтап) Тогда
		ИндексЭтапа = Маршрут.Найти(ПредыдущийЭтап);
		Если ИндексЭтапа = Неопределено Тогда
			Результат.Ошибка = "Этап '" + ПредыдущийЭтап + "' не найден в маршруте обработки документа " + Документ;
		Иначе				
			ИндексСледующегоЭтапа = ИндексЭтапа + 1;
			Если ИндексСледующегоЭтапа < Маршрут.Количество() Тогда
				Результат.СледующийЭтап = Маршрут[ИндексСледующегоЭтапа];
			КонецЕсли;
		КонецЕсли;
	Иначе
		Результат.СледующийЭтап = Маршрут[0];
	КонецЕсли;
	Возврат Результат;
КонецФункции

// Возвращает этап обработки отмены поручения, который необходимо выполнить. Если текущий этап не входит в маршрут отмены
//  , то он должен быть отменен перед вызовом данной функции, а функция возвращает первый этап из маршрута отмены (если маршрут заполнен),
//  в остальных случаях логика такая же, как и при исполнении поручения, если этап не завершён, возвращается он,
//  если завершен, то следующий
//
// Параметры:
//  ДанныеПоручения			 - ВыборкаИзРезультатаЗапроса
//  МаршрутОтменыПоручения	 - Массив
// 
// Возвращаемое значение:
//  СправочникСсылка.ЭтапыОбработкиПоручений - этап обработки отмены поручения, который необходимо выполнить
//
Функция ЭтапОбработкиОтменыПоручения(ДанныеПоручения, МаршрутОтменыПоручения)
	ЭтапОбработки = Неопределено;
	
	Если МаршрутОтменыПоручения.Найти(ДанныеПоручения.ТекущийЭтап) = Неопределено Тогда
		Если МаршрутОтменыПоручения.Количество() > 0 Тогда
			ЭтапОбработки = МаршрутОтменыПоручения[0];
		КонецЕсли;
	ИначеЕсли Не ЗначениеЗаполнено(ДанныеПоручения.ДатаОкончания) Тогда
		ЭтапОбработки = ДанныеПоручения.ТекущийЭтап;
	Иначе
		СледующийЭтапОбработки = СледующийЭтапОбработки(ДанныеПоручения.Документ, ДанныеПоручения.ТекущийЭтап, МаршрутОтменыПоручения);
		ЭтапОбработки = СледующийЭтапОбработки.СледующийЭтап;
	КонецЕсли;
	
	Возврат ЭтапОбработки;
КонецФункции

Функция МаршрутПолноеИсполнениеДокумента(ДанныеДокумента)
	// В будущем предполагается получать данные из РС МаршрутыОбработкиПоручений
	
	Маршрут = Новый Массив;
	Маршрут.Добавить(Справочники.ЭтапыОбработкиПоручений.ПроверкаРеквизитов);
	
	Если ДанныеДокумента.ВидОперацииД = Справочники.ВидыОпераций.Депонирование Тогда
		Маршрут.Добавить(Справочники.ЭтапыОбработкиПоручений.КонтрольКвалификацииИнвестора);
	КонецЕсли;
	
	Если ДанныеДокумента.РасчетыНаDMA Тогда
		Маршрут.Добавить(Справочники.ЭтапыОбработкиПоручений.СверкаСВнешнимБрокером);
	КонецЕсли;
	
	Если ЭтоСписаниеЦБ(ДанныеДокумента) Тогда
		Маршрут.Добавить(Справочники.ЭтапыОбработкиПоручений.КонтрольДостаточности);
		Маршрут.Добавить(Справочники.ЭтапыОбработкиПоручений.ОткрытиеБлокировочногоРаздела);
		Маршрут.Добавить(Справочники.ЭтапыОбработкиПоручений.БлокировкаЦБ);
	КонецЕсли;
	
	Маршрут.Добавить(Справочники.ЭтапыОбработкиПоручений.СозданиеИнвентарнойОперации);
	Маршрут.Добавить(Справочники.ЭтапыОбработкиПоручений.ИсполнениеВНРД);
	
	Если ДанныеДокумента.ИсточникЗагрузки = Перечисления.ИсточникиЗагрузки.QUIK Тогда
		Маршрут.Добавить(Справочники.ЭтапыОбработкиПоручений.ОтправкаСтатусаВQUIK);
		Маршрут.Добавить(Справочники.ЭтапыОбработкиПоручений.ОжиданиеИсполненияВQUIK);
	ИначеЕсли ДанныеДокумента.ИсточникЗагрузки = Перечисления.ИсточникиЗагрузки.Панда Тогда
		Маршрут.Добавить(Справочники.ЭтапыОбработкиПоручений.ОтправкаСтатусаВПанда);
	КонецЕсли;
	
	ОтключитьЭтапОтправкиВЭДО =
		ОбщегоНазначенияПовтИсп.ЗначениеГлобальногоПараметра("83.ФормированиеСводныхОтчетовОСовершенныхОперациях", Ложь);
	Если Не ОтключитьЭтапОтправкиВЭДО Тогда
		Маршрут.Добавить(Справочники.ЭтапыОбработкиПоручений.ОтправкаВЭДО);
	КонецЕсли;
	
	Возврат Маршрут;
КонецФункции

Функция ЭтоСписаниеЦБ(ДанныеДокумента)
	Если ДанныеДокумента.ВидОперацииД <> Справочники.ВидыОпераций.СнятиеСДепонирования Тогда
		Возврат Ложь;
	ИначеЕсли ДанныеДокумента.РасчетыНаDMA И ДанныеДокумента.Количество <> Null Тогда
		// пока нетто-поручение не сформировано, считаем что может быть списание
		Возврат ДанныеДокумента.ВидОперации = Справочники.ВидыОпераций.СнятиеСДепонирования И ДанныеДокумента.Количество > 0;
	Иначе
		Возврат Истина;
	КонецЕсли;
КонецФункции

Функция МаршрутОтменыПоручения(ДанныеПоручения)
	Маршрут = Новый Массив;
	Если ДанныеПоручения.ИсточникЗагрузки = Перечисления.ИсточникиЗагрузки.QUIK Тогда
		Маршрут.Добавить(Справочники.ЭтапыОбработкиПоручений.ОтправкаСтатусаВQUIK);
		Маршрут.Добавить(Справочники.ЭтапыОбработкиПоручений.ОжиданиеОтменыВQUIK);
	ИначеЕсли ДанныеПоручения.ИсточникЗагрузки = Перечисления.ИсточникиЗагрузки.Панда Тогда
		Маршрут.Добавить(Справочники.ЭтапыОбработкиПоручений.ОтправкаСтатусаВПанда);
	КонецЕсли;
	Возврат Маршрут;
КонецФункции

Функция МаршрутЧастичноеИсполнениеДокумента()
	
	ОтключитьЭтапОтправкиВЭДО =
		ОбщегоНазначенияПовтИсп.ЗначениеГлобальногоПараметра("83.ФормированиеСводныхОтчетовОСовершенныхОперациях", Ложь);
	
	Маршрут = Новый Массив;
	Маршрут.Добавить(Справочники.ЭтапыОбработкиПоручений.ИсполнениеВНРД);
	Если Не ОтключитьЭтапОтправкиВЭДО Тогда
		Маршрут.Добавить(Справочники.ЭтапыОбработкиПоручений.ОтправкаВЭДО);
	КонецЕсли;
	Маршрут.Добавить(Справочники.ЭтапыОбработкиПоручений.ИсполнениеВНРД);
	Возврат Маршрут;
	
КонецФункции

Функция ЭтоТекущееЧастичноеИсполнение(Поручение)
	
	ДатаВвода = Константы.ДатаВводаЧастичногоИсполненияИнвентарныхПоручений.Получить();
	Если НЕ ЗначениеЗаполнено(ДатаВвода) ИЛИ Поручение.Дата < ДатаВвода Тогда
		Возврат Ложь;
	КонецЕсли;
	
	ДанныеИсполнения = Документы.ИсполнениеПоручения.ДанныеИсполненияПоручения(Поручение);
	
	Возврат ДанныеИсполнения.Статус = Перечисления.СтатусыПоручений.ИсполненоЧастично;
	
КонецФункции

Функция ВыборкаДокументовКОбработке()
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	ДокументПоручение.Ссылка КАК Документ,
	|	Этапы.Этап КАК ТекущийЭтап,
	|	Этапы.ДатаОкончания КАК ДатаОкончания,
	|	ДокументПоручение.ИдентификаторЗагрузки КАК ИдентификаторЗагрузки,
	|	ДокументПоручение.РасчетыНаDMA КАК РасчетыНаDMA,
	|	ДокументПоручение.ВидОперацииД КАК ВидОперацииД,
	|	ДокументПоручение.ВидИсполненияDVP КАК ВидИсполненияDVP,
	|	ДокументПоручение.КоличествоВПулеDVP3 КАК КоличествоВПулеDVP3,
	|	ДокументПоручение.НомерПулаDVP3 КАК НомерПулаDVP3,
	|	ДокументПоручение.ИсточникЗагрузки КАК ИсточникЗагрузки,
	|	НеттоПоручение.ВидОперации КАК ВидОперации,
	|	НеттоПоручение.Количество КАК Количество,
	|	НеттоПоручение.Сумма КАК Сумма,
	|	НеттоПоручение.Проведен КАК Проведен,
	|	ВЫБОР
	|		КОГДА СтатусыПорученийСрезПоследних.СтатусПоручения = ЗНАЧЕНИЕ(Перечисление.СтатусыПоручений.Отменено)
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК ПоручениеОтменено
	|ИЗ
	|	Документ.Поручение КАК ДокументПоручение
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ЭтапыОбработкиПоручений.СрезПоследних(, Поручение В (&ДокументыКОбработке)) КАК Этапы
	|		ПО ДокументПоручение.Ссылка = Этапы.Поручение
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.НеттоПоручение КАК НеттоПоручение
	|		ПО ДокументПоручение.Ссылка = НеттоПоручение.Поручения.Поручение
	|			И (НЕ НеттоПоручение.ПометкаУдаления)
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СтатусыПоручений.СрезПоследних(, Поручение В (&ДокументыКОбработке)) КАК СтатусыПорученийСрезПоследних
	|		ПО ДокументПоручение.Ссылка = СтатусыПорученийСрезПоследних.Поручение
	|ГДЕ
	|	ДокументПоручение.Ссылка В(&ДокументыКОбработке)
	|
	|УПОРЯДОЧИТЬ ПО
	|	ДокументПоручение.МоментВремени");
	Запрос.УстановитьПараметр("ДокументыКОбработке", ДокументыКОбработке.Выгрузить().ВыгрузитьКолонку("Документ"));
	Возврат Запрос.Выполнить().Выбрать();
КонецФункции

Функция ПроверкаПолнотыПула(ДанныеПоручения, Ошибки)
	
	Результат = Истина;
	
	Если Не(ДанныеПоручения.ВидИсполненияDVP = Перечисления.ВидыИсполненийDVP.DVP3
		И ЗначениеЗаполнено(ДанныеПоручения.НомерПулаDVP3)) Тогда
		
		Возврат Результат; // Проверка выполняется только для поручений объединенных в Пул DVP-3.
		
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = "
		|ВЫБРАТЬ
		|	ПорученияПула.Ссылка                   КАК ПоручениеПула,
		|	ПорученияПула.НомерПулаDVP3            КАК НомерПулаDVP3,
		|	ПорученияПула.КоличествоВПулеDVP3      КАК КоличествоВПулеDVP3,
		|	ПорученияПула.ПорядковыйНомерВПулеDVP3 КАК ПорядковыйНомерВПулеDVP3
		|ИЗ
		|	Документ.Поручение КАК Поручение
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.Поручение КАК ПорученияПула
		|		ПО НАЧАЛОПЕРИОДА(Поручение.Дата, ГОД) = НАЧАЛОПЕРИОДА(ПорученияПула.Дата, ГОД)
		|			И Поручение.ВидИсполненияDVP = ПорученияПула.ВидИсполненияDVP
		|			И Поручение.НомерПулаDVP3 = ПорученияПула.НомерПулаDVP3
		|			И Поручение.ВидПулаDVP3 = ПорученияПула.ВидПулаDVP3
		|			И ПорученияПула.Проведен
		|			И НЕ ПорученияПула.ПометкаУдаления
		|ГДЕ
		|	Поручение.Ссылка = &Поручение
		|УПОРЯДОЧИТЬ ПО
		|	ПорядковыйНомерВПулеDVP3";
	Запрос.УстановитьПараметр("Поручение", ДанныеПоручения.Документ);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	// Сначала проверим количество.
	Если Выборка.Количество() <> ДанныеПоручения.КоличествоВПулеDVP3 Тогда
		
		ШаблонОшибки = "В пуле номер %1 ожидается %2 документа, но в системе отражены %3.
		               |Проверьте корректность загрузки поручений в систему.";
		ТекстОшибки  = СтрШаблон(ШаблонОшибки,
		                         ДанныеПоручения.НомерПулаDVP3,
		                         ДанныеПоручения.КоличествоВПулеDVP3,
		                         Выборка.Количество());
		
		Ошибки = Ошибки + ?(ЗначениеЗаполнено(Ошибки), Символы.ПС, "") + ТекстОшибки;
		
		Результат = Ложь;
		
	КонецЕсли;
	
	// Теперь проверим нумерацию поручений в Пуле.
	н = 1;
	Пока Выборка.Следующий() Цикл
		
		Если Выборка.ПорядковыйНомерВПулеDVP3 <> н Тогда
			
			ШаблонОшибки = "В пуле номер %1 некорректная нумерация поручений.
			               |Проверьте корректность загрузки поручений в систему.";
			ТекстОшибки  = СтрШаблон(ШаблонОшибки,
			                         ДанныеПоручения.НомерПулаDVP3);
			
			Ошибки = Ошибки + ?(ЗначениеЗаполнено(Ошибки), Символы.ПС, "") + ТекстОшибки;
			
			Результат = Ложь;
			
		КонецЕсли;
		
		н = н + 1;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

// Функция - Количество ЦБДля блокировки с учетом пула
//
// Параметры:
//  ДанныеПоручения - ВыборкаИзРезультатаЗапроса - 
// 
// Возвращаемое значение:
//  Число, Неопределно - 0 - если не требуется блокировка, Неопределено - если нет пула.
//
Функция КоличествоЦБДляБлокировкиСУчетомПула(ДанныеПоручения)
	
	Результат = Неопределено;
	
	Если Не(ДанныеПоручения.ВидИсполненияDVP = Перечисления.ВидыИсполненийDVP.DVP3
		И ЗначениеЗаполнено(ДанныеПоручения.НомерПулаDVP3)) Тогда
		
		Возврат Результат;
		
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = "
		|ВЫБРАТЬ
		|	ПорученияПула.Ссылка                            КАК ПоручениеПула,
		|	ВЫБОР
		|		КОГДА ПорученияПула.ВидОперацииД = &ЗачислениеЦБ
		|			ТОГДА ПорученияПула.КоличествоЦБ
		|		ИНАЧЕ -1 * ПорученияПула.КоличествоЦБ
		|	КОНЕЦ                                           КАК КоличествоЦБ,
		|	ЕСТЬNULL(ПорученияБлокировкаЦБ.КоличествоЦБ, 0) КАК Блокировано
		|ПОМЕСТИТЬ ВТ_ПорученияПула
		|ИЗ
		|	Документ.Поручение КАК Поручение
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.Поручение КАК ПорученияПула
		|		ПО (НАЧАЛОПЕРИОДА(Поручение.Дата, ГОД) = НАЧАЛОПЕРИОДА(ПорученияПула.Дата, ГОД))
		|			И Поручение.ВидИсполненияDVP = ПорученияПула.ВидИсполненияDVP
		|			И Поручение.НомерПулаDVP3 = ПорученияПула.НомерПулаDVP3
		|			И Поручение.ВидПулаDVP3 = ПорученияПула.ВидПулаDVP3
		|			И ПорученияПула.Проведен
		|			И НЕ ПорученияПула.ПометкаУдаления
		|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.Поручение КАК ПорученияБлокировкаЦБ
		|		ПО ПорученияПула.Ссылка = ПорученияБлокировкаЦБ.ДокументОснование
		|			И ПорученияБлокировкаЦБ.ВидОперацииД = &ПереводЦБ
		|			И ПорученияБлокировкаЦБ.РазделСчетаДепоКонтрагента.ТипРазделаСчетаДЕПО = &БлокировочныйРаздел
		|			И ПорученияБлокировкаЦБ.Проведен
		|			И НЕ ПорученияБлокировкаЦБ.ПометкаУдаления
		|ГДЕ
		|	Поручение.Ссылка = &Поручение
		|;
		|
		|//////////////////////////////////////
		|ВЫБРАТЬ
		|	СУММА(ВТ_ПорученияПула.КоличествоЦБ) + СУММА(ВТ_ПорученияПула.Блокировано) КАК КоличествоЦБ
		|ПОМЕСТИТЬ ВТ_ДоступноЦБ
		|ИЗ
		|	ВТ_ПорученияПула КАК ВТ_ПорученияПула
		|ГДЕ
		|	НЕ ВТ_ПорученияПула.ПоручениеПула = &Поручение
		|;
		|
		|//////////////////////////////////////
		|ВЫБРАТЬ
		|	ВЫБОР
		|		КОГДА ВТ_ПорученияПула.КоличествоЦБ + ЕСТЬNULL(ВТ_ДоступноЦБ.КоличествоЦБ, 0) > 0
		|			ТОГДА 0
		|		КОГДА ЕСТЬNULL(ВТ_ДоступноЦБ.КоличествоЦБ, 0) < 0
		|			ТОГДА -1 * ВТ_ПорученияПула.КоличествоЦБ
		|		ИНАЧЕ -1 * (ВТ_ПорученияПула.КоличествоЦБ + ЕСТЬNULL(ВТ_ДоступноЦБ.КоличествоЦБ, 0))
		|	КОНЕЦ КАК КолБлокировать
		|ИЗ
		|	ВТ_ПорученияПула КАК ВТ_ПорученияПула
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ДоступноЦБ КАК ВТ_ДоступноЦБ
		|		ПО ИСТИНА
		|ГДЕ
		|	ВТ_ПорученияПула.ПоручениеПула = &Поручение
		|";
	Запрос.УстановитьПараметр("Поручение"          , ДанныеПоручения.Документ);
	Запрос.УстановитьПараметр("ПереводЦБ"          , Справочники.ВидыОпераций.ПереводМеждуРазделамиСчетаДепо);
	Запрос.УстановитьПараметр("ЗачислениеЦБ"       , Справочники.ВидыОпераций.Депонирование);
	Запрос.УстановитьПараметр("БлокировочныйРаздел", Перечисления.ТипыРазделовСчетовДЕПО.БлокированоРасчеты);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		
		Результат = Выборка.КолБлокировать;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция КоличествоПоПоручениямВПуле(Поручение)
	
	Результат = 0;
	
	Если Не ТипЗнч(Поручение) = тип("ДокументСсылка.Поручение") Тогда
		Возврат Результат;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = "
		|ВЫБРАТЬ
		|	Поручение.ВидИсполненияDVP         КАК ВидИсполненияDVP,
		|	Поручение.НомерПулаDVP3            КАК НомерПулаDVP3,
		|	Поручение.ВидПулаDVP3              КАК ВидПулаDVP3,
		|	НАЧАЛОПЕРИОДА(Поручение.Дата, ГОД) КАК ГодПоручения,
		|	Поручение.Ссылка                   КАК Поручение
		|ПОМЕСТИТЬ ВТ_ПараметрыПула
		|ИЗ
		|	Документ.Поручение КАК Поручение
		|ГДЕ
		|	Поручение.Ссылка = &ТекПоручение
		|	И Поручение.ВидИсполненияDVP = &DVP3
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВЫБОР
		|		КОГДА ДокументПоручение.ВидОперацииД = &ЗачислениеЦБ
		|			ТОГДА ДокументПоручение.КоличествоЦБ
		|		ИНАЧЕ -1 * ДокументПоручение.КоличествоЦБ
		|	КОНЕЦ КАК КоличествоЦБ
		|ПОМЕСТИТЬ ВТ_Количества
		|ИЗ
		|	Документ.Поручение КАК ДокументПоручение
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_ПараметрыПула КАК ВТ_ПараметрыПула
		|		ПО ДокументПоручение.ВидИсполненияDVP = ВТ_ПараметрыПула.ВидИсполненияDVP
		|			И ДокументПоручение.НомерПулаDVP3 = ВТ_ПараметрыПула.НомерПулаDVP3
		|			И ДокументПоручение.ВидПулаDVP3 = ВТ_ПараметрыПула.ВидПулаDVP3
		|			И НАЧАЛОПЕРИОДА(ДокументПоручение.Дата, ГОД) = ВТ_ПараметрыПула.ГодПоручения
		|			И ДокументПоручение.Ссылка <> ВТ_ПараметрыПула.Поручение
		|			И НЕ ДокументПоручение.ПометкаУдаления
		|			И ДокументПоручение.Проведен
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ЕСТЬNULL(СУММА(ВТ_Количества.КоличествоЦБ), 0) КАК КоличествоЦБ
		|ИЗ
		|	ВТ_Количества КАК ВТ_Количества";
	Запрос.УстановитьПараметр("ТекПоручение", Поручение);
	Запрос.УстановитьПараметр("DVP3"        , Перечисления.ВидыИсполненийDVP.DVP3);
	Запрос.УстановитьПараметр("ЗачислениеЦБ", Справочники.ВидыОпераций.Депонирование);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		
		Результат = Выборка.КоличествоЦБ;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

