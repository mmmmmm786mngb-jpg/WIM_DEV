КонецФункции

Функция ВыпискиПоручения(Поручение)
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	Выписка.Ссылка КАК ДокументВыписка
	|ИЗ
	|	Документ.Выписка КАК Выписка
	|ГДЕ
	|	Выписка.ДокументОснование = &Поручение
	|	И НЕ Выписка.ПометкаУдаления");
	Запрос.УстановитьПараметр("Поручение", Поручение);
	Возврат Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("ДокументВыписка");
КонецФункции

Функция ВыпискаПоручения(Поручение, ДатаИсполнения, КоличествоОтчета)
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Выписка.Ссылка КАК Выписка
	|ИЗ
	|	Документ.Выписка КАК Выписка
	|ГДЕ
	|	Выписка.ДокументОснование = &Поручение
	|	И НЕ Выписка.ПометкаУдаления
	|	И ВЫРАЗИТЬ(Выписка.ОперацияЦБ КАК Документ.ОперацииЦБ).Дата = &ДатаИсполнения
	|	И ВЫРАЗИТЬ(Выписка.ОперацияЦБ КАК Документ.ОперацииЦБ).Количество = &КоличествоОтчета
	|	И ВЫРАЗИТЬ(Выписка.ОперацияЦБ КАК Документ.ОперацииЦБ).Проведен";
	Запрос.УстановитьПараметр("Поручение", Поручение);
	Запрос.УстановитьПараметр("ДатаИсполнения", ДатаИсполнения);
	Запрос.УстановитьПараметр("КоличествоОтчета", КоличествоОтчета);
	Результат = Запрос.Выполнить();
	Если НЕ Результат.Пустой() Тогда
		Выборка = Результат.Выбрать();
		Если Выборка.Следующий() Тогда
			Возврат Выборка.Выписка;
		КонецЕсли;
	КонецЕсли;
	Возврат Документы.Выписка.ПустаяСсылка();
	
КонецФункции

Функция ЭтоПоручениеНаСписаниеНулевогоНеттоПоручения(Поручение)
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	НеттоПоручениеПоручения.Поручение КАК Поручение
	|ИЗ
	|	Документ.НеттоПоручение.Поручения КАК НеттоПоручениеПоручения
	|ГДЕ
	|	НеттоПоручениеПоручения.Ссылка.Количество = 0
	|	И (ВЫРАЗИТЬ(НеттоПоручениеПоручения.Поручение.ВидОперацииД КАК Справочник.ВидыОпераций)) = &Списание
	|	И НеттоПоручениеПоручения.Поручение = &Поручение";
	Запрос.УстановитьПараметр("Списание", Справочники.ВидыОпераций.СнятиеСДепонирования);
	Запрос.УстановитьПараметр("Поручение", Поручение);
	Результат = Запрос.Выполнить();
	Возврат НЕ Результат.Пустой();
	
КонецФункции

Функция ЕстьОперацияНаЗачислениеНулевогоНеттоПоручения(ПоручениеНаСписание)
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ОперацииЦБ.Ссылка КАК ОперацииЦБ
	|ИЗ
	|	Документ.ОперацииЦБ КАК ОперацииЦБ
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.НеттоПоручение.Поручения КАК НеттоПоручениеПоручения
	|		ПО (НеттоПоручениеПоручения.Поручение = (ВЫРАЗИТЬ(ОперацииЦБ.ДокументОснование КАК Документ.Поручение)))
	|ГДЕ
	|	ОперацииЦБ.ВидОперацииД = &Зачисление
	|	И (ВЫРАЗИТЬ(ВЫРАЗИТЬ(ОперацииЦБ.ДокументОснование КАК Документ.Поручение).ВидОперацииД КАК Справочник.ВидыОпераций)) = &Зачисление
	|	И НеттоПоручениеПоручения.Ссылка В
	|			(ВЫБРАТЬ
	|				НеттоПоручениеПоручения.Ссылка КАК НеттоПоручение
	|			ИЗ
	|				Документ.НеттоПоручение.Поручения КАК НеттоПоручениеПоручения
	|			ГДЕ
	|				НеттоПоручениеПоручения.Поручение = &ПоручениеНаСписание)";
	Запрос.УстановитьПараметр("Зачисление", Справочники.ВидыОпераций.Депонирование);
	Запрос.УстановитьПараметр("ПоручениеНаСписание", ПоручениеНаСписание);
	Результат = Запрос.Выполнить();
	Возврат НЕ Результат.Пустой();
	
КонецФункции

Процедура ПроверитьЗаполнениеРеквизитов(ПроверяемыйОбъект, ПоляДляПроверки, Результат)
	Для Каждого ПолеДляПроверки Из ПоляДляПроверки Цикл
		Если Не ЗначениеЗаполнено(ПроверяемыйОбъект[ПолеДляПроверки.Значение]) Тогда
			Результат.ВыполненУспешно = Ложь;
			Результат.Статус = Результат.Статус
			+ ?(ЗначениеЗаполнено(Результат.Статус), ", ", "Не все реквизиты заполнены: ")
			+ ПолеДляПроверки.Представление;
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

Процедура ОтправитьВыпискуВЭДО(Выписка, Результат)
	ДатаВыписки = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Выписка, "Дата");
	
	//проверка полной загрузки выгрузок по СПД для исключения дублей номеров в случае
	//появления выписки с более ранней датой
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	НАЧАЛОПЕРИОДА(Выписка.Дата, ДЕНЬ) КАК Дата,
	|	СУММА(ВЫБОР
	|			КОГДА РегистрацияДокументовВЭДО.Документ ЕСТЬ NULL
	|				ТОГДА 1
	|			ИНАЧЕ 0
	|		КОНЕЦ) КАК НеВыгружен
	|ИЗ
	|	Документ.Выписка КАК Выписка
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.РегистрацияДокументовВЭДО КАК РегистрацияДокументовВЭДО
	|		ПО Выписка.Ссылка = РегистрацияДокументовВЭДО.Документ
	|ГДЕ
	|	Выписка.Дата МЕЖДУ &ДатаНачала И &ДатаОкончания
	|	И ТИПЗНАЧЕНИЯ(Выписка.ДокументОснование) = ТИП(Документ.иц_СводноеПоручение)
	|	И Выписка.Проведен
	|
	|СГРУППИРОВАТЬ ПО
	|	НАЧАЛОПЕРИОДА(Выписка.Дата, ДЕНЬ)
	|
	|ИМЕЮЩИЕ
	|	СУММА(ВЫБОР
	|			КОГДА РегистрацияДокументовВЭДО.Документ ЕСТЬ NULL
	|				ТОГДА 1
	|			ИНАЧЕ 0
	|		КОНЕЦ) > 0";
	
	Запрос.УстановитьПараметр("ДатаНачала", НачалоДня(ДатаВыписки));
	Запрос.УстановитьПараметр("ДатаОкончания", КонецДня(ДатаВыписки));
	
	РезультатЗапроса = Запрос.Выполнить();
	Если Не РезультатЗапроса.Пустой() Тогда
		Результат.ВыполненУспешно = Ложь;
		Результат.Статус = Результат.Статус + "Не завершено помещение всех выписок по СПД в ЭДО за текущий день; ";
		Возврат;
	КонецЕсли;
	
	ДатаПоследнейВыгрузкиЭДО = РегистрыСведений.РегистрацияДокументовВЭДО.ПоследняяВыгруженнаяВыписка(ДатаВыписки);
	
	ВыпискаОбъект = Выписка.ПолучитьОбъект();
	ВыпискаОбъект.РучнойВвод = Ложь;
	ВыпискаОбъект.Дата = Мин(Макс(ДатаПоследнейВыгрузкиЭДО + 1, ДатаВыписки), КонецДня(ДатаВыписки));
	НачатьТранзакцию(РежимУправленияБлокировкойДанных.Управляемый);
	Попытка
		ВыпискаОбъект.ДополнительныеСвойства.Вставить("ИсключитьИзменениеВремениИсполнения",Истина);
		ВыпискаОбъект.Записать(РежимЗаписиДокумента.Проведение);
	Исключение
		ОтменитьТранзакцию();
		Результат.ВыполненУспешно = Ложь;
		Результат.Статус = Результат.Статус + "Не удалось провести документ " + Строка(ВыпискаОбъект) + ": " + ОписаниеОшибки() + "; ";
		Возврат;
	КонецПопытки;
	
	Если РегистрыСведений.РегистрацияДокументовВЭДО.ДокументВыгруженВЭДО(Выписка) Тогда
		ОтменитьТранзакцию();
		Результат.Статус = Результат.Статус + "Документ уже был помещен в ЭДО ранее: " + Выписка + "; ";
	Иначе
		Отчет = Отчеты.ОтчетОВыполненнойОперации_Новый.Создать();
		Отчет.Основание					= Выписка;
		Отчет.ДатаВыписки				= ДатаВыписки;
		Отчет.ВыводитьФаксимилеВОтчетах	= Истина;
		Отчет.ПоместитьВЭДО				= Истина;
		Отчет.СформироватьОтчет(Новый ТабличныйДокумент);
		
		Если РегистрыСведений.РегистрацияДокументовВЭДО.ДокументВыгруженВЭДО(Выписка) Тогда
			ЗафиксироватьТранзакцию();
			Результат.Статус = Результат.Статус + "Документ помещен в ЭДО: " + Выписка + "; ";
		Иначе
			ОтменитьТранзакцию();
			Результат.ВыполненУспешно = Ложь;
			Результат.Статус = Результат.Статус + "Документ не помещен в ЭДО: " + Выписка + "; ";
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

Функция РезультатИсполненияЭтапаОтправкаСтатусаВПанда(ДанныеДокумента)
	
	Результат = Новый Структура("ВыполненУспешно, Статус");
	
	НазваниеСтатуса = ?(ДанныеДокумента.ПоручениеОтменено, "Снято", "Исполнено");
	СтатусПоручения = ОбработкаНеторговыхПорученийИзПандаВызовСервера.СтатусПоНаименованию(НазваниеСтатуса);
	Поручение = ДанныеДокумента.Документ;
	ОбработкаНеторговыхПорученийИзПандаВызовСервера.СоздатьСообщениеОбИзмененииСтатусаПорученияВПанда(Поручение, СтатусПоручения);
	
	Результат.ВыполненУспешно = Истина;
	Результат.Статус = "Статус отправлен в CRM Панда";
	
	Возврат Результат;
КонецФункции

ОбщегоНазначения.ЛогироватьИспользованиеОбъекта(ЭтотОбъект);
