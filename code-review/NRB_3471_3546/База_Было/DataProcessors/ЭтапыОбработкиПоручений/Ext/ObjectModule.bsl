// ПРОЦЕДУРЫ ВЫПОЛНЕНИЯ ЭТАПОВ ОБРАБОТКИ ПОРУЧЕНИЯ

Процедура ИсполнитьЭтапОбработкиПоручения(ДанныеДокумента, Этап)
	ДатаНачала = ТекущаяДата();
	Документ = ДанныеДокумента.Документ;
	Если Этап = Справочники.ЭтапыОбработкиПоручений.ПроверкаРеквизитов Тогда
		Результат = РезультатИсполненияЭтапаПроверкаРеквизитов(Документ);
		
	ИначеЕсли Этап = Справочники.ЭтапыОбработкиПоручений.КонтрольКвалификацииИнвестора Тогда
		Результат = РезультатИсполненияЭтапаКонтрольКвалификацииИнвестора(Документ);
		
	ИначеЕсли Этап = Справочники.ЭтапыОбработкиПоручений.СверкаСВнешнимБрокером Тогда
		Результат = РезультатИсполненияЭтапаСверкаСВнешнимБрокером(ДанныеДокумента);
		
	ИначеЕсли Этап = Справочники.ЭтапыОбработкиПоручений.КонтрольДостаточности Тогда
		Результат = РезультатИсполненияЭтапаКонтрольДостаточности(ДанныеДокумента);
		
	ИначеЕсли Этап = Справочники.ЭтапыОбработкиПоручений.СозданиеИнвентарнойОперации Тогда
		Результат = РезультатИсполненияЭтапаСозданиеИнвентарнойОперации(Документ, ДатаНачала);
		
	ИначеЕсли Этап = Справочники.ЭтапыОбработкиПоручений.ОткрытиеБлокировочногоРаздела Тогда
		Результат = РезультатИсполненияЭтапаОткрытиеБлокировочногоРаздела(ДанныеДокумента);
		
	ИначеЕсли Этап = Справочники.ЭтапыОбработкиПоручений.БлокировкаЦБ Тогда
		Результат = РезультатИсполненияЭтапаБлокировкаЦБ(ДанныеДокумента);
				
	ИначеЕсли Этап = Справочники.ЭтапыОбработкиПоручений.ИсполнениеВНРД Тогда
		Результат = РезультатИсполненияЭтапаИсполнениеВНРД(ДанныеДокумента);
		
	ИначеЕсли Этап = Справочники.ЭтапыОбработкиПоручений.ОтправкаСтатусаВQUIK Тогда
		Результат = РезультатИсполненияЭтапаОтправкаСтатусаВQUIK(ДанныеДокумента);
		
	ИначеЕсли Этап = Справочники.ЭтапыОбработкиПоручений.ОжиданиеИсполненияВQUIK Тогда
		Результат = РезультатИсполненияЭтапаОжиданиеИсполненияВQUIK(ДанныеДокумента);
		
	ИначеЕсли Этап = Справочники.ЭтапыОбработкиПоручений.ОжиданиеОтменыВQUIK Тогда
		Результат = РезультатИсполненияЭтапаОжиданиеОтменыВQUIK(ДанныеДокумента);
		
	ИначеЕсли Этап = Справочники.ЭтапыОбработкиПоручений.ОтправкаСтатусаВПанда Тогда
		Результат = РезультатИсполненияЭтапаОтправкаСтатусаВПанда(ДанныеДокумента);
		
	ИначеЕсли Этап = Справочники.ЭтапыОбработкиПоручений.ОтправкаВЭДО Тогда
		Результат = РезультатИсполненияЭтапаОтправкаВЭДО(Документ);
		
	Иначе
		Результат = Новый Структура("ВыполненУспешно,Статус", Ложь, "Не предусмотрена обработка этапа: " + Этап);
	КонецЕсли;
	ДатаОкончания = ?(Результат.ВыполненУспешно, ТекущаяДата(), '00010101');
	РегистрыСведений.ЭтапыОбработкиПоручений.ОбновитьЭтап(Документ, Этап, ДатаНачала, ДатаОкончания, Результат.Статус);
КонецПроцедуры

Функция РезультатИсполненияЭтапаПроверкаРеквизитов(Документ)
	Результат = Новый Структура("ВыполненУспешно, Статус", Истина, "");
	
	// Поля документа из запроса ниже, которые проверяются на заполнение
	ОбщиеПоля = Новый СписокЗначений;
	ОбщиеПоля.Добавить("Инициатор",			"Инициатор");
	ОбщиеПоля.Добавить("Депонент",			"Депонент");
	ОбщиеПоля.Добавить("СчетДепо",			"Счет ДЕПО в группе 'Депонент'");
	ОбщиеПоля.Добавить("РазделСчетаДепо",	"Раздел счета ДЕПО в группе 'Депонент'");
	ОбщиеПоля.Добавить("МХДепонента",		"Место хранения в группе 'Депонент'");
	ОбщиеПоля.Добавить("СчетДепоМХ",		"Счет ДЕПО места хранения в группе 'Депонент'");
	ОбщиеПоля.Добавить("РазделСчетаДепоМХ",	"Раздел счета ДЕПО места хранения в группе 'Депонент'");
	ОбщиеПоля.Добавить("Контрагент",		"Контрагент");
	ОбщиеПоля.Добавить("СчетДепоКонтрагента", "Счет ДЕПО в группе 'Контрагент'");
	ОбщиеПоля.Добавить("МХКонтрагент",		"Место хранения в группе 'Контрагент'");
	ОбщиеПоляDVP = Новый СписокЗначений;
	ОбщиеПоляDVP.Добавить("ПланируемаяДатаРасчетов","Планируемая дата расчетов");
	ОбщиеПоляDVP.Добавить("ДатаСделки",				"Дата сделки");
	ОбщиеПоляDVP.Добавить("БанковскийСчет",			"Банковский счет");
	ПоляТабличнойЧасти = Новый СписокЗначений;
	ПоляТабличнойЧасти.Добавить("ЦеннаяБумага"		, "ЦеннаяБумага");
	ПоляТабличнойЧасти.Добавить("Количество"		, "Количество");
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	Поручение.Дата КАК Дата,
	|	Поручение.ВидОперацииД КАК ВидОперации,
	|	Поручение.Инициатор КАК Инициатор,
	|	Поручение.Депонент КАК Депонент,
	|	Поручение.СчетДепо КАК СчетДепо,
	|	Поручение.РазделСчетаДепо КАК РазделСчетаДепо,
	|	Поручение.МХДепонента КАК МХДепонента,
	|	Поручение.СчетДепоМХ КАК СчетДепоМХ,
	|	Поручение.РазделСчетаДепоМХ КАК РазделСчетаДепоМХ,
	|	Поручение.Контрагент КАК Контрагент,
	|	Поручение.СчетДепоКонтрагента КАК СчетДепоКонтрагента,
	|	Поручение.МХКонтрагент КАК МХКонтрагент,
	|	Поручение.ЦБ КАК ЦБ,
	|	Поручение.КоличествоЦБ КАК КоличествоЦБ,
	|	ВЫБОР
	|		КОГДА Поручение.СуммаСделки <> 0
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК ЭтоDVP,
	|	Поручение.ПланируемаяДатаРасчетов КАК ПланируемаяДатаРасчетов,
	|	Поручение.ДатаСделки КАК ДатаСделки,
	|	Поручение.БанковскийСчет КАК БанковскийСчет,
	|	ВЫРАЗИТЬ(Поручение.Контрагент.ЮридическиеФизическиеЛица КАК Справочник.ЮридическиеЛица).Страна КАК СтранаЮрлицаКонтрагента,
	|	Поручение.ЦенныеБумагиСписываемые.(
	|		ЦеннаяБумага КАК ЦеннаяБумага,
	|		Количество КАК Количество
	|	) КАК ЦенныеБумагиСписываемые
	|ИЗ
	|	Документ.Поручение КАК Поручение
	|ГДЕ
	|	Поручение.Ссылка = &ПоручениеДляПроверки");
	Запрос.УстановитьПараметр("ПоручениеДляПроверки", Документ);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		ЦенныеБумагиСписываемые = Выборка.ЦенныеБумагиСписываемые.Выбрать();
		Если ЦенныеБумагиСписываемые.Количество() = 0 Тогда
			Результат.ВыполненУспешно = Ложь;
			Результат.Статус = Результат.Статус + "Не указаны ЦБ в табличной части поручения; ";
		Иначе
			Пока ЦенныеБумагиСписываемые.Следующий() Цикл
				ПроверитьЗаполнениеРеквизитов(ЦенныеБумагиСписываемые, ПоляТабличнойЧасти, Результат);
			КонецЦикла;
		КонецЕсли;
		
		ПроверитьЗаполнениеРеквизитов(Выборка, ОбщиеПоля, Результат);
		
		Если Выборка.ЭтоDVP Тогда
			ПроверитьЗаполнениеРеквизитов(Выборка, ОбщиеПоляDVP, Результат);
			
			Если Выборка.МХКонтрагент <> Константы.МестоХраненияПоУмолчанию.Получить()
				И Не ЗначениеЗаполнено(Выборка.СтранаЮрлицаКонтрагента) Тогда
					Результат.ВыполненУспешно = Ложь;
					Результат.Статус = Результат.Статус
						+ ?(ЗначениеЗаполнено(Результат.Статус), ", ", "Не все реквизиты заполнены: ")
						+ "Страна юр.лица контрагента";
			КонецЕсли;
		КонецЕсли;
	Иначе
		Результат.ВыполненУспешно = Ложь;
		Результат.Статус = "Не найдено поручение " + Документ;
	КонецЕсли;
	Если Результат.ВыполненУспешно Тогда
		Результат.Статус = "Реквизиты корректны";
	КонецЕсли;
	Возврат Результат;
КонецФункции

Функция РезультатИсполненияЭтапаКонтрольКвалификацииИнвестора(Документ)
	
	Результат = Новый Структура("ВыполненУспешно, Статус", Истина, "");
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ПоручениеЦБСписываемые.ЦеннаяБумага.ВидЦББанкаРоссии.ВидИнструмента КАК ВидИнструмента,
	|	ПоручениеЦБСписываемые.ЦеннаяБумага.ВидЦББанкаРоссии КАК ВидЦББанкаРоссии,
	|	ПоручениеЦБСписываемые.ЦеннаяБумага.ДляКвалифицированныхИнвесторов КАК ДляКвалифицированныхИнвесторов,
	|	ПоручениеЦБСписываемые.ЦеннаяБумага КАК ЦБ,
	|	ВЫРАЗИТЬ(ПоручениеЦБСписываемые.Ссылка.Депонент КАК Справочник.Контрагенты).ЮридическиеФизическиеЛица КАК ЮрФизЛицо
	|ИЗ
	|	Документ.Поручение.ЦенныеБумагиСписываемые КАК ПоручениеЦБСписываемые
	|ГДЕ
	|	ПоручениеЦБСписываемые.Ссылка = &Ссылка
	|ИТОГИ
	|	МАКСИМУМ(ДляКвалифицированныхИнвесторов),
	|	МАКСИМУМ(ЮрФизЛицо)
	|ПО
	|	ОБЩИЕ";
	
	Запрос.УстановитьПараметр("Ссылка", Документ);
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() Тогда
		Результат.ВыполненУспешно = Ложь;
		Результат.Статус = "Не найдено поручение " + Документ;
		Возврат Результат;
	КонецЕсли;
	
	ВыборкаПроверкаКвалИнвестора = РезультатЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	ВыборкаПроверкаКвалИнвестора.Следующий();
	Если Не ВыборкаПроверкаКвалИнвестора.ДляКвалифицированныхИнвесторов Тогда
		Результат.Статус = "Для операций с ЦБ не требуется статус квал.инвестора";
		Возврат Результат;
	КонецЕсли;
	
	ЭтоКвалИнвестор = РегистрыСведений.РеестрКвалифицированныхИнвесторовПоЗакону.ЕстьКИПОЗакону(ВыборкаПроверкаКвалИнвестора.ЮрФизЛицо,
	ТекущаяДатаСеанса());
	Если ЭтоКвалИнвестор Тогда
		Результат.Статус = СтатусКвалифицированногоИнвестора(ЭтоКвалИнвестор);
		Возврат Результат;
	КонецЕсли;
	
	ВыборкаЦБ = ВыборкаПроверкаКвалИнвестора.Выбрать();
	Пока ВыборкаЦБ.Следующий() Цикл
		Если Не ВыборкаЦБ.ДляКвалифицированныхИнвесторов Тогда
			Продолжить;
		КонецЕсли;
		
		Если Не ЗначениеЗаполнено(ВыборкаЦБ.ВидИнструмента) Тогда
			Результат.ВыполненУспешно = Ложь;
			Результат.Статус = Результат.Статус + "Не заполнен вид инструмента у вида ЦБ Банка России '" + ВыборкаЦБ.ВидЦББанкаРоссии
			+ "' для ценной бумаги '" + ВыборкаЦБ.ЦБ + "'";
			Возврат Результат;
		КонецЕсли;
		
		ЕстьКвалификацияИнвестора = РегистрыСведений.РеестрКвалифицированныхИнвесторовРОФР.ЕстьКвалификацияИнвестора(
		ВыборкаЦБ.ЮрФизЛицо, ВыборкаЦБ.ВидИнструмента, ТекущаяДатаСеанса());
		Если Не ЕстьКвалификацияИнвестора Тогда
			Результат.ВыполненУспешно = Ложь;
		КонецЕсли;
	КонецЦикла;
	
	Результат.Статус = Результат.Статус + СтатусКвалифицированногоИнвестора(Результат.ВыполненУспешно);
	Возврат Результат;
	
КонецФункции

Функция РезультатИсполненияЭтапаСверкаСВнешнимБрокером(Данные)
	Результат = Новый Структура("ВыполненУспешно,Статус", Ложь, "");
	Если Данные.Проведен = Истина Тогда
		Результат.Статус = "Нетто-поручение сформировано и проведено.";
		Результат.ВыполненУспешно = Истина;
	ИначеЕсли Данные.Проведен = Null Тогда
		Результат.Статус = "Отсутствует нетто-поручение.";
	Иначе
		Результат.Статус = "Нетто-поручение не проведено.";
	КонецЕсли;
	Возврат Результат;
КонецФункции

Функция РезультатИсполненияЭтапаКонтрольДостаточности(ДанныеДокумента)
	
	Результат = Новый Структура("ВыполненУспешно, Статус", Истина, "");
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Поручение.СчетДепо КАК СчетДепо,
	|	Поручение.РазделСчетаДепо КАК РазделСчетаДепо,
	|	Поручение.СчетДепоМХ КАК СчетДепоМХ,
	|	Поручение.РазделСчетаДепоМХ КАК РазделСчетаДепоМХ,
	|	ПоручениеЦенныеБумагиСписываемые.ЦеннаяБумага КАК ЦеннаяБумага,
	|	ПоручениеЦенныеБумагиСписываемые.Количество КАК Количество
	|ПОМЕСТИТЬ ДанныеПоручения
	|ИЗ
	|	Документ.Поручение КАК Поручение
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.Поручение.ЦенныеБумагиСписываемые КАК ПоручениеЦенныеБумагиСписываемые
	|		ПО (ПоручениеЦенныеБумагиСписываемые.Ссылка = Поручение.Ссылка)
	|ГДЕ
	|	Поручение.Ссылка = &Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ОстаткиЦБОстатки.КоличествоОстаток КАК Остаток,
	|	ОстаткиЦБОстатки.ЦБ КАК ЦБ
	|ПОМЕСТИТЬ ОстаткиЦБ
	|ИЗ
	|	РегистрНакопления.ОстаткиЦБ.Остатки(
	|			&Период,
	|			(СчетДепо, РазделСчетаДепо, СчетДепоМХ, РазделСчетаДепоМХ, ЦБ) В
	|				(ВЫБРАТЬ
	|					ДанныеПоручения.СчетДепо,
	|					ДанныеПоручения.РазделСчетаДепо,
	|					ДанныеПоручения.СчетДепоМХ,
	|					ДанныеПоручения.РазделСчетаДепоМХ,
	|					ДанныеПоручения.ЦеннаяБумага
	|				ИЗ
	|					ДанныеПоручения)) КАК ОстаткиЦБОстатки
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ДанныеПоручения.ЦеннаяБумага КАК ЦеннаяБумага,
	|	ДанныеПоручения.Количество КАК Количество,
	|	ЕСТЬNULL(ОстаткиЦБ.Остаток, 0) КАК Остаток
	|ИЗ
	|	ДанныеПоручения КАК ДанныеПоручения
	|		ЛЕВОЕ СОЕДИНЕНИЕ ОстаткиЦБ КАК ОстаткиЦБ
	|		ПО ДанныеПоручения.ЦеннаяБумага = ОстаткиЦБ.ЦБ";
	
	Запрос.УстановитьПараметр("Период", ТекущаяДатаСеанса());
	Запрос.УстановитьПараметр("Ссылка", ДанныеДокумента.Документ);
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() Тогда
		Результат.ВыполненУспешно = Ложь;
		Результат.Статус = "Не найдено поручение " + ДанныеДокумента.Документ;
		Возврат Результат;
	КонецЕсли;
	
	КоличествоВПуле = КоличествоПоПоручениямВПуле(ДанныеДокумента.Документ);
	Выборка = РезультатЗапроса.Выбрать();
	Пока Выборка.Следующий() Цикл
		Количество = ?(ДанныеДокумента.РасчетыНаDMA, ДанныеДокумента.Количество, Выборка.Количество);
		Если Количество > Выборка.Остаток + КоличествоВПуле Тогда
			Результат.ВыполненУспешно = Ложь;
			Результат.Статус = Результат.Статус + СтрШаблон("Остаток по ЦБ %1 %2%3, количество в поручении %4; ",
			Выборка.ЦеннаяБумага, Выборка.Остаток + КоличествоВПуле, ?(КоличествоВПуле > 0, " (с учётом пула DVP3)", ""), Количество);
		КонецЕсли;
	КонецЦикла;
	
	Результат.Статус = Результат.Статус + "Остатков ЦБ " + ?(Результат.ВыполненУспешно, "", "не ") + "достаточно для исполнения поручения";
	Возврат Результат;
КонецФункции

Функция РезультатИсполненияЭтапаСозданиеИнвентарнойОперации(Поручение, ДатаНачала)
	
	ВремяНачалаЗамераОперацииЦБ = ОценкаПроизводительности.НачатьЗамерВремени();
	
	Результат = Новый Структура("ВыполненУспешно, Статус", Ложь, "");
	
	Если ЭтоПоручениеНаСписаниеНулевогоНеттоПоручения(Поручение)
		И НЕ ЕстьОперацияНаЗачислениеНулевогоНеттоПоручения(Поручение) Тогда
		Результат.Статус = "Не найдена встречная операция на зачисление для операции списания по нулевому нетто-поручению";
	Иначе
		Попытка
			ЭтоМультиПоручениеП35_2 = Документы.Поручение.ЭтоМультиПоручениеП35_2(Поручение);
			Если ЭтоМультиПоручениеП35_2 Тогда
				Результат.Статус = "Это поручение с видом инвентарной операции П35_2 и типом заявки MULTI_BUY";
			Иначе
				Документы.Поручение.СоздатьОбновитьОперацииЦБ(Поручение, РежимЗаписиДокумента.Запись, ДатаНачала, Результат.Статус);
			КонецЕсли;
			Результат.ВыполненУспешно = Истина;
		Исключение
			Результат.Статус = "Не удалось записать инвентарную операцию";
		КонецПопытки;
	КонецЕсли;
	
	ОценкаПроизводительности.ЗакончитьЗамерВремени("ЗаписьДокументаОперацииЦБ", ВремяНачалаЗамераОперацииЦБ,,, НЕ Результат.ВыполненУспешно);
	
	Возврат Результат;
	
КонецФункции

Функция РезультатИсполненияЭтапаОткрытиеБлокировочногоРаздела(ДанныеДокумента)
	
	Поручение = ДанныеДокумента.Документ;
	
	Результат = Новый Структура("ВыполненУспешно,Статус", Ложь, "");
	ТипРазделаБлокировки = Перечисления.ТипыРазделовСчетовДЕПО.БлокированоРасчеты;
	Если ЗначениеЗаполнено(Справочники.РазделыСчетаДепо.РазделСчетаДепо(Поручение.СчетДепо, ТипРазделаБлокировки)) Тогда
		Результат.ВыполненУспешно = Истина;
		Результат.Статус = "Блокировочный раздел уже открыт";
	ИначеЕсли ДанныеДокумента.ВидИсполненияDVP = Перечисления.ВидыИсполненийDVP.DVP3 И КоличествоЦБДляБлокировкиСУчетомПула(ДанныеДокумента) = 0 Тогда
		
		Результат.ВыполненУспешно = Истина;
		Результат.Статус = "С учетом поручений в пуле блокировка ЦБ не требуется";
		
	Иначе
		Результат.Статус = РезультатФормированияПорученияНаОткрытиеБлокировочногоРаздела(Поручение, ТипРазделаБлокировки);
		Если ЗначениеЗаполнено(Результат.Статус) Тогда
			Результат.ВыполненУспешно = Ложь;
		Иначе
			Результат.ВыполненУспешно = Истина;
			Результат.Статус = "Блокировочный раздел открыт";
		КонецЕсли;
	КонецЕсли;
	Возврат Результат;
КонецФункции

Функция РезультатФормированияПорученияНаОткрытиеБлокировочногоРаздела(Поручение, ТипРазделаБлокировки)
	
	ДокументОбъект = Документы.Поручение.СоздатьДокумент();
	ДокументОбъект.Дата = ТекущаяДата();
	ДокументОбъект.ДатаИсполненияПоручения = ДокументОбъект.Дата + 1;
	ДокументОбъект.Номер = НумераторыОбъектов.ПолучитьНомерДокумента(ДокументОбъект, "СА");
	ДокументОбъект.ВидОперацииД = Справочники.ВидыОпераций.ОткрытиеРазделаСчетаДепо;
	ДокументОбъект.ТипРазделаСчетаДЕПО = ТипРазделаБлокировки;
	ДокументОбъект.Инициатор = Константы.ОрганизацияПоУмолчанию.Получить();
	ДокументОбъект.ДокументОснование = Поручение;
	ЗаполнитьЗначенияСвойств(ДокументОбъект, Поручение, "Депонент,СчетДепо");
	Попытка
		ДокументОбъект.Записать(РежимЗаписиДокумента.Проведение);
	Исключение
		Возврат "Не удалось провести поручение на открытие блокировочного раздела";
	КонецПопытки;
	Возврат "";
	
КонецФункции

Функция РезультатИсполненияЭтапаБлокировкаЦБ(ДанныеПоручения)
	
	Результат = Новый Структура("ВыполненУспешно,Статус", Ложь, "");
	
	КоличествоЦБДляБлокировкиСУчетомПула = КоличествоЦБДляБлокировкиСУчетомПула(ДанныеПоручения);
	
	Если ДанныеПоручения.ВидИсполненияDVP = Перечисления.ВидыИсполненийDVP.DVP3
		И КоличествоЦБДляБлокировкиСУчетомПула = 0 Тогда
		
		Результат.ВыполненУспешно = Истина;
		Результат.Статус = "С учетом поручений в пуле блокировка ЦБ не требуется";
		
		Возврат Результат;
		
	КонецЕсли;
	
	ДокументОбъект = Документы.Поручение.СоздатьДокумент();
	ДокументОбъект.Дата = ТекущаяДата();
	ДокументОбъект.ДатаИсполненияПоручения = ДокументОбъект.Дата + 1;
	ДокументОбъект.ДатаИсполненияПорученияВДепозитарииМХ = ДокументОбъект.ДатаИсполненияПоручения;
	ДокументОбъект.ДатаИсполненияПорученияВМестеРасчетов = ДокументОбъект.ДатаИсполненияПоручения;
	ДокументОбъект.Номер = НумераторыОбъектов.ПолучитьНомерДокумента(ДокументОбъект, "СД");
	ДокументОбъект.ВидОперацииД = Справочники.ВидыОпераций.ПереводМеждуРазделамиСчетаДепо;
	ДокументОбъект.Инициатор = Константы.ОрганизацияПоУмолчанию.Получить();
	ЗаполнитьЗначенияСвойств(ДокументОбъект, ДанныеПоручения.Документ, "Депонент, СчетДепо, РазделСчетаДепо, МХДепонента, СчетДепоМХ,
		|РазделСчетаДепоМХ, ЦБ, КоличествоЦБ, ЦенаСделкиЦБ, СуммаСделки");
	
	Для Каждого Строка Из ДанныеПоручения.Документ.ЦенныеБумагиСписываемые Цикл
		НоваяСтрокаЦБ = ДокументОбъект.ЦенныеБумагиСписываемые.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрокаЦБ, Строка, , "ИдентификаторЗагрузки");
		Если ДанныеПоручения.РасчетыНаDMA Тогда
			НоваяСтрокаЦБ.Количество = ДанныеПоручения.Количество;
			НоваяСтрокаЦБ.Цена = 0;
			НоваяСтрокаЦБ.Сумма = ДанныеПоручения.Сумма;
		КонецЕсли;
		Если ЗначениеЗаполнено(КоличествоЦБДляБлокировкиСУчетомПула) Тогда
			НоваяСтрокаЦБ.Количество = КоличествоЦБДляБлокировкиСУчетомПула;
		КонецЕсли;
	КонецЦикла;
	
	ДокументОбъект.Контрагент = ДокументОбъект.Депонент;
	ДокументОбъект.СчетДепоКонтрагента = ДокументОбъект.СчетДепо;
	ДокументОбъект.РазделСчетаДепоКонтрагента = Справочники.РазделыСчетаДепо.РазделСчетаДепо(
		ДокументОбъект.СчетДепоКонтрагента, Перечисления.ТипыРазделовСчетовДЕПО.БлокированоРасчеты);
	ДокументОбъект.МХКонтрагент = ДокументОбъект.МХДепонента;
	ДокументОбъект.СчетДепоМХКонтрагента = ДокументОбъект.СчетДепоМХ;
	ДокументОбъект.РазделСчетаДепоМХКонтрагента = ДокументОбъект.РазделСчетаДепоМХ;
	ДокументОбъект.ДокументОснование = ДанныеПоручения.Документ;
	Попытка
		ДокументОбъект.Записать(РежимЗаписиДокумента.Проведение);
		Результат.ВыполненУспешно = Истина;
		Результат.Статус = "ЦБ переведена на блокировочный раздел";
	Исключение
		Результат.Статус = "Не удалось провести поручение на перевод ЦБ на блокировочный раздел";
	КонецПопытки;
	Возврат Результат;
КонецФункции

Функция РезультатИсполненияЭтапаИсполнениеВНРД(ДанныеДокумента)
	Результат = Новый Структура("ВыполненУспешно, Статус");
	
	Документ = ДанныеДокумента.Документ;
	ДатаВвода = Константы.ДатаВводаЧастичногоИсполненияИнвентарныхПоручений.Получить();
	СтатусыИсполнения = Новый Массив;
	СтатусыИсполнения.Добавить(Перечисления.СтатусыПоручений.ИсполненоЧастично);
	СтатусыИсполнения.Добавить(Перечисления.СтатусыПоручений.Исполнено);
	
	Если Документ.РасчетыНаDMA И ЗначениеЗаполнено(ДатаВвода) И Документ.Дата >= ДатаВвода Тогда
		ДанныеИсполнения = Документы.ИсполнениеПоручения.ДанныеИсполненияПоручения(Документ);
		Результат.ВыполненУспешно = Документ.Проведен
			И СтатусыИсполнения.Найти(ДанныеИсполнения.Статус) <> Неопределено;
		ТипИсполнения = ?(ДанныеИсполнения.Статус = Перечисления.СтатусыПоручений.ИсполненоЧастично,
			"частично исполнено", "исполнено");
		Результат.Статус = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку("Поручение %1, отчет %2",
			ТипИсполнения, СокрЛП(ДанныеИсполнения.КодОтчетаВышестоящегоДепозитария));
	Иначе
		Результат.ВыполненУспешно = (Документ.Проведен И ЗначениеЗаполнено(Документ.ДатаИсполненияПоручения));
		Результат.Статус = "Поручение исполнено, отчет " + СокрЛП(Документ.КодОтчетаНРД);
	КонецЕсли;
	
	Если Не Результат.ВыполненУспешно Тогда
		Результат.Статус = "Поручение не исполнено";
	КонецЕсли;
	Возврат Результат;
КонецФункции

Функция РезультатИсполненияЭтапаОтправкаСтатусаВQUIK(ДанныеДокумента)
	
	Результат = Новый Структура("ВыполненУспешно, Статус");
	
	Если ВыполнениеПорученийВQUIK = Неопределено Тогда
		ИнициироватьСоединениеQUIK();
	КонецЕсли;
	
	ВыполнениеПорученийВQUIK.ДокументыКОбработке.Очистить();
	ВыполнениеПорученийВQUIK.ДокументыКОбработке.Добавить().Документ = ДанныеДокумента.Документ;
	Если ДанныеДокумента.ПоручениеОтменено Тогда
		ОшибкиПриОтправке = ВыполнениеПорученийВQUIK.ОтправитьЗапросыНаОтменуПоручений();
	Иначе
		ОшибкиПриОтправке = ВыполнениеПорученийВQUIK.РезультатПодписанияПоручений();
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ОшибкиПриОтправке) Тогда
		Результат.ВыполненУспешно = Ложь;
		Результат.Статус = ОписаниеСтатусаОтправкиВQUIK(Результат.ВыполненУспешно) + ". " + ОшибкиПриОтправке;
	Иначе
		Результат.ВыполненУспешно = Истина;
		Результат.Статус = ОписаниеСтатусаОтправкиВQUIK(Результат.ВыполненУспешно);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция РезультатИсполненияЭтапаОжиданиеИсполненияВQUIK(ДанныеДокумента)
	
	Результат = Новый Структура("ВыполненУспешно, Статус");
	
	Если ВыполнениеПорученийВQUIK = Неопределено Тогда
		ИнициироватьСоединениеQUIK();
	КонецЕсли;
	
	ВыполнениеПорученийВQUIK.ДокументыКОбработке.Очистить();
	ВыполнениеПорученийВQUIK.ДокументыКОбработке.Добавить().Документ = ДанныеДокумента.Документ;
	РезультатИсполненияПоручений = ВыполнениеПорученийВQUIK.РезультатИсполненияПоручений();
	Результат.ВыполненУспешно = РезультатИсполненияПоручений.ВсеПорученияИсполнены;
	
	Если Результат.ВыполненУспешно Тогда
		Результат.Статус = "Исполнено в QUIK";
	ИначеЕсли ЗначениеЗаполнено(РезультатИсполненияПоручений.Описание) Тогда
		Результат.Статус = РезультатИсполненияПоручений.Описание;
	Иначе
		Результат.Статус = "Ожидает обработки в QUIK";
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция РезультатИсполненияЭтапаОжиданиеОтменыВQUIK(ДанныеДокумента)
	
	Результат = Новый Структура("ВыполненУспешно, Статус");
	
	Если ВыполнениеПорученийВQUIK = Неопределено Тогда
		ИнициироватьСоединениеQUIK();
	КонецЕсли;
	
	ВыполнениеПорученийВQUIK.ДокументыКОбработке.Очистить();
	ВыполнениеПорученийВQUIK.ДокументыКОбработке.Добавить().Документ = ДанныеДокумента.Документ;
	РезультатИсполненияПоручений = ВыполнениеПорученийВQUIK.РезультатОтменыПоручений();
	Результат.ВыполненУспешно = РезультатИсполненияПоручений.ВсеПорученияОтменены;
	
	Если Результат.ВыполненУспешно Тогда
		Результат.Статус = "Отменено в QUIK";
	ИначеЕсли ЗначениеЗаполнено(РезультатИсполненияПоручений.Описание) Тогда
		Результат.Статус = РезультатИсполненияПоручений.Описание;
	Иначе
		Результат.Статус = "Ожидает обработки в QUIK";
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция РезультатИсполненияЭтапаОтправкаВЭДО(Документ)
	
	ОтключитьЭтапОтправкиВЭДО =
		ОбщегоНазначенияПовтИсп.ЗначениеГлобальногоПараметра("83.ФормированиеСводныхОтчетовОСовершенныхОперациях", Ложь);
	Если ОтключитьЭтапОтправкиВЭДО Тогда
		Результат = Новый Структура("ВыполненУспешно, Статус",
			Истина,
			"Отправка в ЭДО производится через ""АРМ: Формирование и отправка отчетов о совершенных операциях""");
		Возврат Результат;
	КонецЕсли;
	
	Результат = Новый Структура("ВыполненУспешно,Статус", Истина, "");
	ДатаВвода = Константы.ДатаВводаЧастичногоИсполненияИнвентарныхПоручений.Получить();
	
	Если Документ.РасчетыНаDMA И ЗначениеЗаполнено(ДатаВвода) И Документ.Дата >= ДатаВвода Тогда
		ДанныеИсполнения = Документы.ИсполнениеПоручения.ДанныеИсполненияПоручения(Документ);
		Выписка = ВыпискаПоручения(Документ, ДанныеИсполнения.Дата, ДанныеИсполнения.КоличествоОтчета);
		Если Не ЗначениеЗаполнено(Выписка) Тогда
			Результат.ВыполненУспешно = Ложь;
			Результат.Статус = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
				"Документ не помещен в ЭДО: у поручения нет выписки на %1 на количество %2",
				ДанныеИсполнения.Дата, ДанныеИсполнения.КоличествоОтчета);
			Возврат Результат;
		КонецЕсли;
		Выписки = ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(Выписка);
	Иначе
		Выписки = ВыпискиПоручения(Документ);
		Если Не ЗначениеЗаполнено(Выписки) Тогда
			Результат.ВыполненУспешно = Ложь;
			Результат.Статус = "Документ не помещен в ЭДО: нет выписок у поручения";
			Возврат Результат;
		КонецЕсли;
	КонецЕсли;
	
	Для Каждого Выписка Из Выписки Цикл
		ОтправитьВыпискуВЭДО(Выписка, Результат);
	КонецЦикла;
	
	Возврат Результат;
КонецФункции

Процедура ЗавершитьТекущийЭтапБезИсполнения(ДанныеПоручения, Комментарий)
	Если Не ЗначениеЗаполнено(ДанныеПоручения.ДатаОкончания) Тогда
		РегистрыСведений.ЭтапыОбработкиПоручений.ОбновитьЭтап(ДанныеПоручения.Документ,
		ДанныеПоручения.ТекущийЭтап, ТекущаяДатаСеанса(), ТекущаяДатаСеанса(), Комментарий);
	КонецЕсли;
КонецПроцедуры

