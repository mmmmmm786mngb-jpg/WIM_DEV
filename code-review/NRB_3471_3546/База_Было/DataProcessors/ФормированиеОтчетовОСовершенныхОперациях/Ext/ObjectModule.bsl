#Область СлужебныйПрограммныйИнтерфейс

// Процедура - Сформировать
//
// Параметры:
//  ВключаяОтправленныеВЭДО	 - Булево		 - Признак того, брать ли операции уже переданные в ЭДО
//  НеобходимоПоместитьВЭДО	 - Булево		 - Признак необходимости помещения отчетов в ЭДО
//  ФаксимилеВОтчетах		 - Булево		 - Признак необходимости показать печать подпись
//  ПоСчетуДепо				 - СправочникСсылка.СчетаДепо	 - Отбор по счету депо
//  ПоВыписке				 - ДокументСсылка				 - Выписка по которой получаются данные
//  ПоОперации				 - ДокументСсылка				 - Операция по которой получаются данные
//
Процедура Сформировать(
	ВключаяОтправленныеВЭДО,
	НеобходимоПоместитьВЭДО,
	ФаксимилеВОтчетах,
	ПоСчетуДепо,
	ПоВыписке = Неопределено,
	ПоОперации = Неопределено) Экспорт
	
	ЭтоИнформационнаяВыписка = ЗначениеЗаполнено(ПоОперации);
	
	// Отправка в ЭДО (0) или в Kafka (1)
	ВыгрузкаВЭДО = ОбщегоНазначенияПовтИсп.ЗначениеГлобальногоПараметра("83.СводныеОтчетыВЭДОилиВKafka", 1) = 0;
	
	// 1 Очистить сводные отчеты о совершенных операциях +\- ДнейОчистки от даты формирования отчетов
	Если Не ЭтоИнформационнаяВыписка Тогда
		ДнейОчистки = 0;
		НачалоПериодаОчистки = ДатаФормированияОтчетов - ДнейОчистки;
		КонецПериодаОчистки  = ДатаФормированияОтчетов + ДнейОчистки;
		Попытка
			ОчисткаСводныхОтчетовНеВЭДО(НачалоПериодаОчистки, КонецПериодаОчистки, ПоСчетуДепо);
		Исключение
			ТекстОшибки = ОбработкаОшибок.КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстОшибки);
		КонецПопытки;
	КонецЕсли;
	
	// 2 Получить операции
	ЗаполнитьТаблицуОпераций(ДатаОпераций, ВключаяОтправленныеВЭДО, ПоСчетуДепо, ПоОперации);
	
	// 3 Сформировать сводные отчеты о совершенных операциях
	Если ЭтоИнформационнаяВыписка Тогда
		СформироватьИнформационнуюВыписку(ПоВыписке);
	Иначе
		СформироватьСводныеОтчеты(НеобходимоПоместитьВЭДО);
	КонецЕсли;
	
	Если НеобходимоПоместитьВЭДО Тогда
		// 4 Удалить Регистрацию в Документообороте для UPD
		УдалитьРегистрациюЭДО();
		
		// 5 Создать табличные документы печатных форм
		ПоказатьПечатьИПодписьВДокументе = ФаксимилеВОтчетах И (ВыгрузкаВЭДО Или Не НеобходимоПоместитьВЭДО);
		Если ЭтоИнформационнаяВыписка Тогда
			ТаблицаОпераций = Операции.Выгрузить();
			СформироватьПечатныеФормы(ПоказатьПечатьИПодписьВДокументе, ТаблицаОпераций);
		Иначе
			СформироватьПечатныеФормы(ПоказатьПечатьИПодписьВДокументе);
		КонецЕсли;
		
		// 6 Отправка в ЭДО (0) или в Kafka (любое число, кроме 0)
		Если ВыгрузкаВЭДО Тогда
			ПоместитьОтчетыВЭДО(ДокументыКЭДО, ДатаОпераций, ДатаОпераций);
		Иначе
			ОтправитьПечатьПодписьВОтчете 	= ФаксимилеВОтчетах И НеобходимоПоместитьВЭДО;
			
			ПоместитьОтчетыВKafka("DepoReport", ДокументыКЭДО, ОтправитьПечатьПодписьВОтчете);
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

// Процедура - Заполнить таблицу операций
//
// Параметры:
//  Период					 - Дата							 - День, за который выбираются операции
//  ВключаяОтправленныеВЭДО	 - Булево						 - Признак того, брать ли операции уже переданные в ЭДО
//  ПоСчетуДепо				 - СправочникСсылка.СчетаДепо	 - Отбор по счету депо
//  ПоОперации				 - ДокументСсылка				 - Операция по которой получаются данные
//
Процедура ЗаполнитьТаблицуОпераций(Период, ВключаяОтправленныеВЭДО, ПоСчетуДепо = Неопределено, ПоОперации = Неопределено) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = ТекстЗапросаВыборкиОпераций();
	Запрос.УстановитьПараметр("ПоВсемСчетамДепо", Не ЗначениеЗаполнено(ПоСчетуДепо));
	Запрос.УстановитьПараметр("НомерСчетаДепо", ПоСчетуДепо);
	Запрос.УстановитьПараметр("ПоВсемОперациям", Не ЗначениеЗаполнено(ПоОперации));
	Запрос.УстановитьПараметр("Операция", ПоОперации);
	Запрос.УстановитьПараметр("ТипОперации", ТипОперацииПоОперации(ПоОперации));
	Запрос.УстановитьПараметр("НачалоПериода", НачалоДня(Период));
	Запрос.УстановитьПараметр("КонецПериода", КонецДня(Период));
	Запрос.УстановитьПараметр("ОперацияИзменениеАнкетныхДанных", Справочники.ВидыОпераций.ВидОперацииИзменениеАнкетныхДанных());
	
	Запрос.УстановитьПараметр("ВключаяОтправленныеВЭДО", ВключаяОтправленныеВЭДО);
	ВалютыРублевогоНалога = Новый Массив;
	ВалютыРублевогоНалога.Добавить(Справочники.Валюты.ПустаяСсылка());
	ВалютыРублевогоНалога.Добавить(ОбщегоНазначенияПовтИсп.ЗначениеКонстанты("ВалютаРегламентированногоУчета"));
	Запрос.УстановитьПараметр("ВалютыРублевогоНалога", ВалютыРублевогоНалога);
	Выборка = Запрос.Выполнить().Выбрать();
	Операции.Очистить();
	Пока Выборка.Следующий() Цикл
		Если Справочники.Контрагенты.ОсобыеУсловия(Выборка.НомерСчетаДепо.Владелец) Тогда
			Если Не РегистрыСведений.ОтветственныеЛицаОрганизаций.ПользовательМожетРедактироватьОсобыеУсловия() Тогда
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Особые условия: " + Выборка.НомерСчетаДепо.Владелец
				+ ". Выполнение операции доступно Ответственному за особых клиентов");
				Продолжить;
			КонецЕсли;
		КонецЕсли;
		СтрокаОпераций = Операции.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаОпераций, Выборка);
	КонецЦикла;
	
КонецПроцедуры

// Возвращает табличный документ сводного отчета
//
// Параметры:
//  ПараметрыПечати				 - Структура		 - Структура с полями:
//  	*Период						 - Дата		 - Дата операции
//  	*ДатаОтчета					 - Дата		 - Дата\время формирования отчета
//  	*СчетДепо					 - СправочникСсылка.СчетаДепо	 - Счет депо
//  	*ДокументОснование			 - ДокументСсылка				 - Документ , на основании которого формируется сводный отчет
//  	*Клиент						 - СправочникСсылка.Контрагенты	 - Клиент
//  	*ОтчетыНаАнглийскомЯзыке	 - Булево						 - Признак формирование печатных форм с английским языком
//  	*ТаблицаОпераций			 - ТаблицаЗначений				 - Таблица операций, соотвествует табличной части Операции
//  	*ВыводитьФаксимилеВОтчетах	 - Булево						 - Признак вывода Факсимиле
// 
// Возвращаемое значение:
//   - ТабличныйДокумент - Табличный документ сформированного отчета
//
Функция СформироватьПечатнуюФорму(ПараметрыПечати) Экспорт
	
	ВсегоРазделов = 5;
	
	Период = 					ПараметрыПечати.Период;
	ДатаОтчета = 				ПараметрыПечати.ДатаОтчета;
	СчетДепо = 					ПараметрыПечати.СчетДепо;
	ДокументОснование = 		ПараметрыПечати.ДокументОснование;
	Клиент = 					ПараметрыПечати.Клиент;
	ОтчетНаАнглийскомЯзыке = 	ПараметрыПечати.ОтчетыНаАнглийскомЯзыке;
	ТаблицаОпераций = 			ПараметрыПечати.ТаблицаОпераций;
	ПоказатьФаксимилеВОтчете = 	ПараметрыПечати.ВыводитьФаксимилеВОтчетах;
	
	ИмяМакета = ПолучитьИмяМакета(Клиент, ОтчетНаАнглийскомЯзыке, Период);
	Макет = ПолучитьМакет(ИмяМакета);
	
	ТабличныйДокумент = Новый ТабличныйДокумент;
	ТабличныйДокумент.ОриентацияСтраницы = ОриентацияСтраницы.Ландшафт;
	ТабличныйДокумент.АвтоМасштаб		 = Истина;
	ТабличныйДокумент.ТолькоПросмотр	 = Истина;
	ТабличныйДокумент.РазмерСтраницы	 = "A4";
	
	ВидСчетаДепо = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СчетДепо, "ВидСчетаДепо");
	
	Основание = ДокументОснование.Ссылка;
	
	ОпределяющаяДата = Основание.Дата;
	
	ИмяСекции = "Заголовок";
	Область = Макет.ПолучитьОбласть(ИмяСекции);
	ПараметрыЗаголовка = СформироватьПараметрыЗаголовкаМакета(Период, ДокументОснование, Клиент, ОтчетНаАнглийскомЯзыке, СчетДепо, ИмяМакета);
	Область.Параметры.Заполнить(ПараметрыЗаголовка);
	ФормированиеПечатныхФорм.УстановитьЗаголовкиСекцииМакета(Область.Параметры, ИмяМакета, ИмяСекции, мТекстыЗаголовков, ВидСчетаДепо);
	ТабличныйДокумент.Вывести(Область);
	
	/////////////////////////////////////////////////////////////////////////////
	
	ПараметрыПереносаСтраницы = Новый Структура;
	// Структура ПараметрыПереносаСтраницы - содержит параметры необходимые для проверки размещения областей макета на одном листе
	//  * ПоследняяСтрока			 - Номер последней строки в последней таблице отчета (для "не последних" таблиц равен 0)
	//  * ШапкаРаздела				 - Область "Шапки" раздела (таблицы) отчета
	//  * ОбластьСтрока				 - Область "Строки" раздела (таблицы) отчета
	//  * ОбластьПустаяСтрокаОборот	 - Область "Пустой" строки - разделителя разделов (таблиц) в отчете
	//  * Подвал					 - Область "Подвала" отчета
	
	ОбластьПустаяСтрокаОборот = Макет.ПолучитьОбласть("ПустаяСтрокаОборот");
	ПараметрыПереносаСтраницы.Вставить("ОбластьПустаяСтрокаОборот", ОбластьПустаяСтрокаОборот);
	
	ИмяСекции = "Подвал";
	Подвал = Макет.ПолучитьОбласть(ИмяСекции);
	ФормированиеПечатныхФорм.УстановитьЗаголовкиСекцииМакета(Подвал.Параметры, ИмяМакета, ИмяСекции, мТекстыЗаголовков, ВидСчетаДепо);
	ПараметрыПодвала = СформироватьПараметрыПодвалаМакета(ДатаОтчета, Клиент, ОтчетНаАнглийскомЯзыке, СчетДепо, ИмяМакета);
	Подвал.Параметры.Заполнить(ПараметрыПодвала);
	
	ОпределитьПечатьПодпись(ОпределяющаяДата, ПоказатьФаксимилеВОтчете, Подвал.Рисунки.Печать.Картинка, Подвал.Рисунки.Faksimilie.Картинка);
	ПараметрыПереносаСтраницы.Вставить("Подвал", Подвал);
	
	НомерРазделаПоследний = 0;
	Для НомерРаздела = 1 По ВсегоРазделов Цикл
		НомерРазделаСтрокой = Формат(НомерРаздела, "ЧГ=0");
		
		ВыборкаОпераций = ВыборкаОперацийРаздела(НомерРазделаСтрокой, ТаблицаОпераций);
		Если ВыборкаОпераций.Количество() > 0 Тогда
			НомерРазделаПоследний = НомерРаздела;
		КонецЕсли;
	КонецЦикла;
	
	/////////////////////////////////////////////////////////////////////////////
	
	Для НомерРаздела = 1 По ВсегоРазделов Цикл
		НомерРазделаСтрокой = Формат(НомерРаздела, "ЧГ=0");
		
		ВыборкаОпераций				 = ВыборкаОперацийРаздела(НомерРазделаСтрокой, ТаблицаОпераций);
		ВыборкаОперацийКоличество	 = ВыборкаОпераций.Количество();
		Если ВыборкаОперацийКоличество > 0 Тогда
			
			Если НомерРаздела = НомерРазделаПоследний Тогда
				ПоследняяСтрока = ВыборкаОперацийКоличество;
			Иначе
				ПоследняяСтрока = 0;
			КонецЕсли;
			ПараметрыПереносаСтраницы.Вставить("ПоследняяСтрока", ПоследняяСтрока);
			
			ИмяСекции = "ШапкаРаздел" + НомерРазделаСтрокой;
			ШапкаРаздела = Макет.ПолучитьОбласть(ИмяСекции);
			ФормированиеПечатныхФорм.УстановитьЗаголовкиСекцииМакета(ШапкаРаздела.Параметры, ИмяМакета, ИмяСекции, мТекстыЗаголовков, ВидСчетаДепо);
			ПараметрыПереносаСтраницы.Вставить("ШапкаРаздела", ШапкаРаздела);
			
			СтрокаОборот = Макет.ПолучитьОбласть("СтрокаРаздел" + НомерРазделаСтрокой);
			ПараметрыПереносаСтраницы.Вставить("ОбластьСтрока", СтрокаОборот);
			
			ВывестиСекциюСтрокаОборот(ВыборкаОпераций, ТабличныйДокумент, СтрокаОборот, ОтчетНаАнглийскомЯзыке, ВидСчетаДепо,
				ПараметрыПереносаСтраницы);
			
			ТабличныйДокумент.Вывести(ОбластьПустаяСтрокаОборот);
		КонецЕсли;
		
	КонецЦикла;
	
	ТабличныйДокумент.Вывести(Подвал);
	
	Возврат ТабличныйДокумент;
	
КонецФункции

// Процедура - Поместить отчеты в kafka
//
// Параметры:
//  ТипДокумента					 - Строка			 - см. модель данных, поле DocumentTypeCode (название типа документа)
//  ТаблицаОтчетовЭДО				 - ТаблицаЗначений	 - см. таблицу Обработки\ФормированиеОтчетовОСовершенныхОперациях\ДокументыКЭДО
//  ОтправитьПечатьПодписьВОтчете	 - Булево			 - Признак отправки печати и подписи с отчетом
//
Процедура ПоместитьОтчетыВKafka(ТипДокумента, ТаблицаОтчетовЭДО, ОтправитьПечатьПодписьВОтчете) Экспорт
	
	Если ОтправитьПечатьПодписьВОтчете Тогда
		ТипШтампа	 = ОбщегоНазначенияПовтИсп.ЗначениеГлобальногоПараметра("189.ТипШтампа", Неопределено);
		ТипФаксимиле = ОбщегоНазначенияПовтИсп.ЗначениеГлобальногоПараметра("189.ТипФаксимиле", Неопределено);
	Иначе
		ТипШтампа	 = Неопределено;
		ТипФаксимиле = Неопределено;
	КонецЕсли;
	
	Для Каждого ДанныеОбработки Из ТаблицаОтчетовЭДО Цикл
		ОбработатьДанныеОтчетаДляПередачиВКафку(ДанныеОбработки, ТипДокумента, ТипШтампа, ТипФаксимиле);
	КонецЦикла;
	
КонецПроцедуры

// Процедура обрабатывает данные по сводному отчету и передает в Кафку
//
// Параметры:
//  ДанныеОбработки	 - ОбработкаТабличнаяЧастьСтрока.ФормированиеОтчетовОСовершенныхОперациях.ДокументыКЭДО - данные по отчету к обработке
//  ТипДокумента	 - Строка - тип документа для передачи в Кафка
//  ТипШтампа		 - Строка - тип штампа для передачи в Кафка
//  ТипФаксимиле	 - Строка - тип факсимиле для передачи в Кафка
//
Процедура ОбработатьДанныеОтчетаДляПередачиВКафку(ДанныеОбработки, ТипДокумента, ТипШтампа, ТипФаксимиле) Экспорт
	ДанныеОбработки.ТекстОшибки = "";
	УИДСообщения = "";
	Попытка
		УИДСообщения = СформироватьЗаписиВЖурналИсходящихСообщенийКафка(ТипДокумента, ДанныеОбработки, ТипШтампа, ТипФаксимиле);
	Исключение
		ТекстОшибки = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		ДанныеОбработки.ТекстОшибки = ТекстОшибки;
	КонецПопытки;
	УспешнаяОтправка = ЗначениеЗаполнено(УИДСообщения);
	
	Если УспешнаяОтправка Тогда
		ДокВыписка = ДанныеОбработки.Документ.ПолучитьОбъект();
		Если Не ЗначениеЗаполнено(ДокВыписка.ИсходящийНомер) Тогда
			ДокВыписка.ИсходящийНомер = УИДСообщения;
			ДокВыписка.СпособОтправкиОтчета = Справочники.СпособыПередачиИнформации.ЭДО;
			ДокВыписка.ОбменДанными.Загрузка = Истина;
			ДокВыписка.Записать(РежимЗаписиДокумента.Запись);
		КонецЕсли;
		ДанныеОбработки.ЭДО = Истина;
		ОбменДаннымиКафка.ЗаписатьОбъектВИсходящиеСообщенияКафкаПриЗаписиДокумента(ДокВыписка);
		
		Запись = РегистрыСведений.УведомленияОтправленныеЧерезЛичныйКабинет.СоздатьМенеджерЗаписи();
		Запись.Период = ТекущаяДатаСеанса();
		Запись.КД = ДанныеОбработки.Документ;
		Запись.Клиент = ДанныеОбработки.Клиент;
		Запись.СчетДепо = ДанныеОбработки.СчетДепо;
		Запись.ИдентификаторУведомления = УИДСообщения;
		Запись.СтатусДоставкиУведомления = Перечисления.СтатусыДоставкиУведомленийВКабинетКлиента.ВыгруженИз1С;
		Запись.Записать();
	КонецЕсли;
КонецПроцедуры

#КонецОбласти

#Область Инициализация

мТекстыЗаголовков = ФормированиеПечатныхФорм.ТекстыЗаголовковОтчетов(ПолучитьМакет("Заголовки").ПолучитьТекст());

#КонецОбласти
