Процедура ПоместитьОтчетыВЭДО(ТаблицаОтчетовЭДО, НачПериода, КонПериода)
	Перем Соединение, КомандаADO, RS;
	
	ВнешниеДанные.ADOConnect(Соединение, КомандаADO, RS, ПланыВидовХарактеристик.ВнешниеИсточники.Документооборот);
	
	ТаблицаПараметров = Новый ТаблицаЗначений();
	ТаблицаПараметров.Колонки.Добавить("ИмяПараметра");
	ТаблицаПараметров.Колонки.Добавить("ЗначениеПараметра");
	ТаблицаПараметров.Колонки.Добавить("НаправлениеПараметра");
	
	ОбработкаДокументооборот = Обработки.Документооборот.Создать();
	ОбработкаДокументооборот.Автовыгрузка = Истина;
	СписокПолейДляСтруктуры = "ПроцедураЗапроса, Клиент, ПолноеИмяФайла, ИмяФайла, ДатаДокумента, ИдентификаторКлиента, НомерДоговора,"
							+ "Комментарий, РасширениеДокумента, СтатусДокумента, ВходящийНомер, ДатаПоступления, ИсходящийНомер, ДатаОтправления,"
							+ "ТипДокумента, ДатаОткрытия, ДатаЗакрытия, Параметр1, Параметр2, Параметр3";
	ОбработкаДокументооборот.ПараметрыДокумента = Новый Структура(СписокПолейДляСтруктуры);
	
	ТипыНаправленийПараметраADO	= ВнешниеДанные.ИнициализацияТиповНаправленияПараметровADO();
	
	Для Каждого ДанныеОбработки Из ТаблицаОтчетовЭДО Цикл
		// Проверим, что выписка еще не была выгружена в ЭДО
		Если ЗначениеЗаполнено(ДанныеОбработки.Основание)
			И РегистрыСведений.РегистрацияДокументовВЭДО.ДокументВыгруженВЭДО(ДанныеОбработки.Основание) Тогда
			Сообщение = Новый СообщениеПользователю();
			Сообщение.Текст = "Документ уже был помещен в ЭДО ранее: " + ДанныеОбработки.Основание;
			Сообщение.Сообщить();
			Продолжить;
		КонецЕсли;
		// Очистим параметры для передачи файла в ЭДО перед перезаполнением
		ТаблицаПараметров.Очистить();
		// Сохраним файл в формате PDF для передачи в ЭДО
		ДанныеХранилища	= ПолучитьИзВременногоХранилища(ДанныеОбработки.АдресТаблицы);
		ФайлПриемник	= ПолучитьИмяВременногоФайла("PDF");
		ДанныеХранилища.Записать(ФайлПриемник, ТипФайлаТабличногоДокумента.PDF);
		// Заполним данные параметров для ЭДО 
		ЗаполнитьПараметрыДляДокументооборота(ТаблицаПараметров, ДанныеОбработки, ТипыНаправленийПараметраADO, НачПериода, КонПериода);
		// Выгружаем данные
		ОбработкаДокументооборот.ПараметрыДокумента = Новый Структура("ПроцедураЗапроса, ПолноеИмяФайла, ТаблицаПараметров");
		ОбработкаДокументооборот.ПараметрыДокумента.ПроцедураЗапроса	= "CreateDocumentFrom1C";
		ОбработкаДокументооборот.ПараметрыДокумента.ПолноеИмяФайла		= ФайлПриемник;
		ОбработкаДокументооборот.ПараметрыДокумента.ТаблицаПараметров	= ТаблицаПараметров;
		ОбработкаДокументооборот.ПараметрыДокумента.Вставить("ВозвращатьСтатусЗагрузки", Истина); // Требование возврата статуса из обработки
		// Вызываем функцию выгрузки
		ОбработкаДокументооборот.ЗагрузкаДанных();
		// Регистрация успешной выгрузки документа
		Если ОбработкаДокументооборот.ПараметрыДокумента.Свойство("ДокументУспешноЗарегистрирован")
			И ОбработкаДокументооборот.ПараметрыДокумента.ДокументУспешноЗарегистрирован
			И ЗначениеЗаполнено(ДанныеОбработки.Основание) Тогда
			
			РегистрыСведений.РегистрацияДокументовВЭДО.РегистрироватьВыгрузкуДокументаВЭДО(ДанныеОбработки.Основание, ТаблицаПараметров);
			
			ДокВыписка = ДанныеОбработки.Документ.ПолучитьОбъект();
			ДокВыписка.ИсходящийНомер = ДанныеОбработки.Документ.Номер;
			ДокВыписка.ОбменДанными.Загрузка = Истина;
			ДокВыписка.Записать(РежимЗаписиДокумента.Запись);
			
			ДанныеОбработки.ЭДО = Истина;
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти

#Область ОтправкаВKafka

Функция НаименованиеПоВидуОтчета(ДанныеКОтправке, ФорматДатыОпераций = "ДФ=dd.MM.yyyy", ОриентацияОтчетаПортрет = Ложь)
	
	ТипДокументСсылкаВыписка = Тип("ДокументСсылка.Выписка");
	Если ТипЗнч(ДанныеКОтправке.Основание) = ТипДокументСсылкаВыписка Тогда
		ВидОтчета = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДанныеКОтправке.Основание, "ВидОтчета");
		Если 		ВидОтчета = Перечисления.ВидыОтчетов.СводныйОтчетОСовершеннойОперации Тогда
			НаименованиеОтчета		= "Отчет о совершенной операции";
		ИначеЕсли 	ВидОтчета = Перечисления.ВидыОтчетов.ВыпискаОСостоянииСчетаДЕПО Тогда
			НаименованиеОтчета		= "Выписка о состоянии счета депо";
			ОриентацияОтчетаПортрет = Истина;
		ИначеЕсли 	ВидОтчета = Перечисления.ВидыОтчетов.ОтчетОбОперацияхПоСчетуДЕПО Тогда
			НаименованиеОтчета		= "Отчет об операциях депо";
		Иначе
			НаименованиеОтчета		= "Выписка";
		КонецЕсли;
	Иначе
		НаименованиеОтчета			= "Сводный отчет о совершенных операциях";
	КонецЕсли;
	
	НаименованиеОтчетаДетально = СтрШаблон("%1 по счету %2%3",
		НаименованиеОтчета,
		СокрЛП(ДанныеКОтправке.СчетДепо),
		?(ЗначениеЗаполнено(ДатаОпераций), " за " + Формат(ДатаОпераций, ФорматДатыОпераций), ""));
	
	Возврат НаименованиеОтчетаДетально;
	
КонецФункции

Функция СформироватьЗаписиВЖурналИсходящихСообщенийКафка(ТипДокумента, ДанныеКОтправке, ТипШтампа, ТипФаксимиле)
	
	ДанныеДляJSON = ПодготовленныеДанныеДляJSON(ДанныеКОтправке);
	
	ТекстJSON = СформироватьJSON(ДанныеДляJSON, ТипДокумента, ДанныеКОтправке, ТипШтампа, ТипФаксимиле);
	
	Если ЗначениеЗаполнено(ТекстJSON) Тогда
		Кафка.ПоместитьСообщениеВРегистрКОтправке(ДанныеДляJSON.ВнешнийИсточник, ДанныеДляJSON.Сущность, ТекстJSON,
			ДанныеДляJSON.УИДСообщения, ДанныеКОтправке.Документ);
		УИДСообщения = ДанныеДляJSON.УИДСообщения;
	Иначе
		УИДСообщения = "";
	КонецЕсли;
	
	Возврат УИДСообщения;
	
КонецФункции

Функция ПодготовленныеДанныеДляJSON(ДанныеКОтправке)
	
	ДанныеДляJSON = Новый Структура(
		"ВнешнийИсточник, Сущность, ActionType, CrmClientId, ЮридическиеФизическиеЛица, ЭтоЮрЛицо,УИДСообщения, УИДДокумента");
	
	ДанныеКлиента = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ДанныеКОтправке.Клиент,
		"ЮридическиеФизическиеЛица, ЮрФизЛицо, Код, СпособОтправкиОтчетов");
	
	СпособОтправкиОтчетов = СпособОтправкиОтчетовСУчетомВыбораПользователя(ДанныеКОтправке, ДанныеКлиента);
	НастройкиОтправки = Справочники.Контрагенты.НастройкиОтправкиОтчетовПоСпособуОтправки(СпособОтправкиОтчетов);
	
	ДанныеДляJSON.Вставить("СпособОтправкиОтчетов" , СпособОтправкиОтчетов);
	ДанныеДляJSON.Вставить("ContractNumber" , ДанныеКлиента.Код);
	
	ДанныеДляJSON.CrmClientId = Обработки.РегистрацияКлиентаЧерезKafka.CrmClientId(ДанныеКлиента.ЮридическиеФизическиеЛица);
	
	ЭтоЮрЛицо = ДанныеКлиента.ЮрФизЛицо = Перечисления.ЮрФизЛицо.ЮрЛицо;
	ДанныеДляJSON.ЭтоЮрЛицо = ЭтоЮрЛицо;
	ДанныеДляJSON.Сущность = НастройкиОтправки.Сущность;
	ДанныеДляJSON.ВнешнийИсточник = НастройкиОтправки.ВнешнийИсточник;
	ДанныеДляJSON.ЮридическиеФизическиеЛица = ДанныеКлиента.ЮридическиеФизическиеЛица;
	
	УИДДокумента = Строка(ДанныеКОтправке.Документ.УникальныйИдентификатор());
	ОтправлялсяВЭДО = Документы.СводныйОтчетОСовершенныхОперациях.БылОтправленВЭДО(ДанныеКОтправке.Документ);
	
	Если ДанныеКОтправке.ActionType = "INS" И Не ОтправлялсяВЭДО Тогда
		УИДСообщения = УИДДокумента;
		ActionType = "INS";
	Иначе
		УИДСообщения = Строка(Новый УникальныйИдентификатор);
		ActionType = "UPD";
	КонецЕсли;
	
	ДанныеДляJSON.УИДСообщения = УИДСообщения;
	ДанныеДляJSON.ActionType = ActionType;
	ДанныеДляJSON.УИДДокумента = УИДДокумента;
	
	Возврат ДанныеДляJSON;

КонецФункции

Функция СформироватьJSON(ДанныеДляJSON, ТипДокумента, ДанныеКОтправке, ТипШтампа, ТипФаксимиле)

	ContractNumber = ДанныеДляJSON.ContractNumber;
	CrmClientId = ДанныеДляJSON.CrmClientId;
	УИДДокумента = ДанныеДляJSON.УИДДокумента;
	УИДСообщения = ДанныеДляJSON.УИДСообщения;
	
	FileData = ДанныеFileData(ДанныеКОтправке, ТипШтампа, ТипФаксимиле);
	
	Если ДанныеДляJSON.СпособОтправкиОтчетов = Перечисления.СпособыОтправкиОтчетов.МП Тогда
		Если ЗначениеЗаполнено(CrmClientId) Тогда
			FilesData = Новый Массив;
			FilesData.Добавить(Новый Структура("FileData", FileData));
			Data = ДанныеData(CrmClientId, ContractNumber, ТипДокумента, ДанныеКОтправке, УИДДокумента, FilesData);
		Иначе
			ДанныеКОтправке.ТекстОшибки = "[CrmClientID] Нет кода загрузки: " + ДанныеДляJSON.ЮридическиеФизическиеЛица;
		КонецЕсли;
	ИначеЕсли ДанныеДляJSON.СпособОтправкиОтчетов = Перечисления.СпособыОтправкиОтчетов.EmailКлиента
		Или ДанныеДляJSON.СпособОтправкиОтчетов = Перечисления.СпособыОтправкиОтчетов.EmailCustody Тогда
		
		file = Новый Структура("fileName, fileExt, fileBody");
		ЗаполнитьЗначенияСвойств(file, FileData);
		attachments = Новый Массив;
		attachments.Добавить(Новый Структура("file", file));
		
		Если ДанныеДляJSON.СпособОтправкиОтчетов = Перечисления.СпособыОтправкиОтчетов.EmailКлиента Тогда
			Data = ДанныеДляЮрЛицData(CrmClientId, ДанныеКОтправке, attachments);
		Иначе
			Email = ОбщегоНазначенияПовтИсп.ЗначениеГлобальногоПараметра("EmailДепозитарногоОтдела");
			Data = ДанныеДляЮрЛицData(CrmClientId, ДанныеКОтправке, attachments, Email);
		КонецЕсли;
		
	Иначе
		ДанныеКОтправке.ТекстОшибки = "Не удалось определить ""Способ отправки отчетов""";
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ДанныеКОтправке.ТекстОшибки) Тогда
		ТекстJSON = "";
	Иначе
		MessageInfo = ОбменДаннымиКафка.ТиповыеДанныеMessageInfo(ДанныеДляJSON.Сущность, ДанныеДляJSON.ActionType, "1.0.0", УИДСообщения);
		MessageInfo.SystemSource = ВРЕГ(MessageInfo.SystemSource); //Необходимо для обхода обогащения сообщения данными клиента на стороне CRM
		ТекстJSON = РаботаСJSON.ТекстСообщенияJSON(MessageInfo, Data);
	КонецЕсли;
	
	Возврат ТекстJSON;
	
КонецФункции

Функция ДанныеData(CrmClientId, ContractNumber, ТипДокумента, ДанныеКОтправке, УИДДокумента, FilesData)
	
	Док = ДанныеКОтправке.Документ;
	ЭтоВыписка = ТипЗнч(Док) = Тип("ДокументСсылка.Выписка");
	ДокНомер = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Док, "Номер");
	ДокДата  = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Док, "Дата");
	ДокДатаНачПериода = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Док, "ДатаНачПериода");
	Если Не ЗначениеЗаполнено(ДокДатаНачПериода) Тогда
		Если ЭтоВыписка Тогда
			ДокДатаНачПериода = НачалоДня(ДатаОпераций);
		Иначе
			ДокДатаНачПериода = НачалоДня(ДокДата);
		КонецЕсли;
	КонецЕсли;
	ДокДатаКонПериода = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Док, "ДатаКонПериода");
	Если Не ЗначениеЗаполнено(ДокДатаКонПериода) Тогда
		Если ЭтоВыписка Тогда
			ДокДатаКонПериода = КонецДня(ДатаОпераций);
		Иначе
			ДокДатаКонПериода = КонецДня(ДокДата);
		КонецЕсли;
	КонецЕсли;
	
	ДанныеДокумента = Новый Структура;
	ДанныеДокумента.Вставить("DocumentId",					 УИДДокумента);
	ДанныеДокумента.Вставить("DocumentTypeCode",			 ТипДокумента);
	ДанныеДокумента.Вставить("ContractNumber",				 СокрЛП(ContractNumber));
	ДанныеДокумента.Вставить("CrmClientId",					 СокрЛП(CrmClientId));
	ДанныеДокумента.Вставить("DocumentNumber",				 ДокНомер);
	ДанныеДокумента.Вставить("CreateDate",					 ЗаписатьДатуJSON(ДокДата, ФорматДатыJSON.ISO));
	ДанныеДокумента.Вставить("OpenPeriodDate",				 ЗаписатьДатуJSON(ДокДатаНачПериода, ФорматДатыJSON.ISO));
	ДанныеДокумента.Вставить("ClosePeriodDate",				 ЗаписатьДатуJSON(ДокДатаКонПериода, ФорматДатыJSON.ISO));
	ДанныеДокумента.Вставить("Comment",						 ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Док, "Комментарий"));
	ДанныеДокумента.Вставить("Destination",					 ОбщегоНазначенияПовтИсп.ЗначениеГлобальногоПараметра("145.Destination", "MAPP"));
	
	ДанныеДокумента.Вставить("FilesData", FilesData);
	Возврат ДанныеДокумента;
	
КонецФункции

Функция ДанныеFileData(ДанныеКОтправке, ТипШтампа, ТипФаксимиле)
	
	ДанныеХранилища = ПолучитьИзВременногоХранилища(ДанныеКОтправке.АдресТаблицы);
	ФайлПриемник	= ПолучитьИмяВременногоФайла("PDF");
	ДанныеХранилища.Записать(ФайлПриемник, ТипФайлаТабличногоДокумента.PDF);
	ДанныеФайла = Новый ДвоичныеДанные(ФайлПриемник);
	FileBody = Base64Строка(ДанныеФайла);
	УдалитьФайлы(ФайлПриемник);
	
	IsPortraitOrientation = Ложь;
	НаименованиеОтчетаДетально = НаименованиеПоВидуОтчета(ДанныеКОтправке, "ДФ=dd_MM_yyyy", IsPortraitOrientation);
	
	FileData = Новый Структура;
	FileData.Вставить("FileName"				, НаименованиеОтчетаДетально);
	FileData.Вставить("FileExt"					, "PDF");
	FileData.Вставить("FileBody"				, FileBody);
	FileData.Вставить("Number"					, 1);
	FileData.Вставить("CreateDate"				, ЗаписатьДатуJSON(ТекущаяДатаСеанса(), ФорматДатыJSON.ISO));
	FileData.Вставить("StampType"				, ТипШтампа);
	FileData.Вставить("FacsimileType"			, ТипФаксимиле);
	FileData.Вставить("ConvertToPdf"			, Ложь);
	FileData.Вставить("IsPortraitOrientation"	, IsPortraitOrientation);
	
	FileData.Вставить("SignaturesData"	, Неопределено);
	
	Возврат FileData;
	
КонецФункции

Функция ДанныеДляЮрЛицData(CrmClientId, ДанныеКОтправке, attachments, Email = Неопределено)
	
	ДанныеДокумента = Новый Структура();
	Если Email = Неопределено Тогда
		ДанныеДокумента.Вставить("NotificationType", "Client");
		ДанныеДокумента.Вставить("CrmClientId", CrmClientId);
	КонецЕсли;
	ДанныеДокумента.Вставить("Email", Email);
	ДанныеДокумента.Вставить("MailTemplateId", Неопределено);
	ДанныеДокумента.Вставить("MailTemplateTitle", "ОтправкаОтчетаКлиентуЮЛ");
	
	ТемаПисьма = НаименованиеПоВидуОтчета(ДанныеКОтправке);
	ReplaceFields = Новый Структура;
	ReplaceFields.Вставить("ЗаголовокСообщения", ТемаПисьма);
	
	ДанныеДокумента.Вставить("ReplaceFields", ReplaceFields);
	
	ДанныеДокумента.Вставить("Attachments", attachments);
	Возврат ДанныеДокумента;
	
КонецФункции

Функция ЕстьРеквизитВДанныхКОтправке(ДанныеКОтправке, ИмяРеквизита)
	
	ТипДанныеКОтправке = ТипЗнч(ДанныеКОтправке);
	Если ТипДанныеКОтправке = Тип("Структура") Тогда
		ЕстьРеквизит = ДанныеКОтправке.Свойство(ИмяРеквизита);
	Иначе
		ОбъектМетаданныхПоТипу = Метаданные.НайтиПоТипу(ТипДанныеКОтправке);
		ЕстьРеквизит = ОбъектМетаданныхПоТипу.Реквизиты.Найти(ИмяРеквизита) <> Неопределено;
	КонецЕсли;
	Возврат ЕстьРеквизит;
	
КонецФункции

Функция СпособОтправкиОтчетовСУчетомВыбораПользователя(ДанныеКОтправке, ДанныеКлиента)
	
	СпособОтправкиОтчетов = Неопределено;
	ИмяРеквизитаСпособаОтправки = "СпособОтправкиОтчетов";
	Если ЕстьРеквизитВДанныхКОтправке(ДанныеКОтправке, ИмяРеквизитаСпособаОтправки) Тогда
		СпособОтправкиОтчетов = ДанныеКОтправке[ИмяРеквизитаСпособаОтправки];
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(СпособОтправкиОтчетов) Тогда
		СпособОтправкиОтчетов = ДанныеКлиента[ИмяРеквизитаСпособаОтправки];
	КонецЕсли;
	
	Возврат СпособОтправкиОтчетов;
КонецФункции

#КонецОбласти

