#Область СлужебныеПроцедурыИФункции

Функция ТипОперацииПоОперации(ПоОперации)
	
	Если Не ЗначениеЗаполнено(ПоОперации) Тогда
		Возврат 0;
	КонецЕсли;
	
	Если ТипЗнч(ПоОперации) = Тип("ДокументСсылка.ОперацииЦБ") Тогда
		Возврат 1;
	ИначеЕсли ТипЗнч(ПоОперации) = Тип("ДокументСсылка.ГлобальнаяОперация") Тогда
		Возврат 2;
	ИначеЕсли ТипЗнч(ПоОперации) = Тип("ДокументСсылка.УчастиеВКД") Тогда
		Возврат 3;
	ИначеЕсли ТипЗнч(ПоОперации) = Тип("ДокументСсылка.ОтменаПоручения") Тогда
		Возврат 4;
	ИначеЕсли ТипЗнч(ПоОперации) = Тип("ДокументСсылка.ИзменениеАнкетныхДанных") Тогда
		Возврат 5;
	ИначеЕсли ТипЗнч(ПоОперации) = Тип("ДокументСсылка.ОткрытиеРазделаСчетаДепо") Тогда
		Возврат 6;
	ИначеЕсли ТипЗнч(ПоОперации) = Тип("ДокументСсылка.ЗакрытиеРазделаСчетаДепо") Тогда
		Возврат 7;
	ИначеЕсли ТипЗнч(ПоОперации) = Тип("ДокументСсылка.ОткрытиеСчетаДепо") Тогда
		Возврат 8;
	ИначеЕсли ТипЗнч(ПоОперации) = Тип("ДокументСсылка.ЗакрытиеСчетаДепо") Тогда
		Возврат 9;
	Иначе
		Возврат 0;
	КонецЕсли;
	
КонецФункции

Процедура ОчисткаСводныхОтчетовНеВЭДО(НачалоПериода, КонецПериода, ПоСчетуДепо)
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("НачалоПериода", НачалоПериода);
	Запрос.УстановитьПараметр("КонецПериода", КонецПериода);
	Запрос.УстановитьПараметр("ПоВсемСчетамДепо", Не ЗначениеЗаполнено(ПоСчетуДепо));
	Запрос.УстановитьПараметр("СчетДепо", ПоСчетуДепо);
	Запрос.Текст =
	"ВЫБРАТЬ
	|	СводныйОтчетОСовершенныхОперациях.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.СводныйОтчетОСовершенныхОперациях.Операции КАК СводныйОтчетОСовершенныхОперацияхОперации
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.СводныйОтчетОСовершенныхОперациях КАК СводныйОтчетОСовершенныхОперациях
	|		ПО СводныйОтчетОСовершенныхОперацияхОперации.Ссылка = СводныйОтчетОСовершенныхОперациях.Ссылка
	|ГДЕ
	|	СводныйОтчетОСовершенныхОперациях.ИсходящийНомер = """"
	|	И НЕ СводныйОтчетОСовершенныхОперациях.ПометкаУдаления
	|	И СводныйОтчетОСовершенныхОперациях.Дата МЕЖДУ &НачалоПериода И &КонецПериода
	|	И (&ПоВсемСчетамДепо
	|			ИЛИ СводныйОтчетОСовершенныхОперациях.СчетДепо = &СчетДепо)
	|
	|СГРУППИРОВАТЬ ПО
	|	СводныйОтчетОСовершенныхОперациях.Ссылка";
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Если Не РезультатЗапроса.Пустой() Тогда
		ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
		
		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			ДокОбъект = ВыборкаДетальныеЗаписи.Ссылка.ПолучитьОбъект();
			ДокОбъект.Операции.Очистить();
			ДокОбъект.Комментарий = "";
			ДокОбъект.Записать();
		КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры

Функция ПолучитьТаблицуСводныхОтчетов(Период, СчетаДепо)
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	СводныйОтчетОСовершенныхОперациях.СчетДепо КАК СчетДепо,
	|	СводныйОтчетОСовершенныхОперациях.Ссылка КАК СводныйОтчетСсылка,
	|	НЕ СводныйОтчетОСовершенныхОперациях.ИсходящийНомер = """" КАК ЕстьВЭДО
	|ИЗ
	|	Документ.СводныйОтчетОСовершенныхОперациях КАК СводныйОтчетОСовершенныхОперациях
	|ГДЕ
	|	НЕ СводныйОтчетОСовершенныхОперациях.ПометкаУдаления
	|	И СводныйОтчетОСовершенныхОперациях.Дата МЕЖДУ &НачалоПериода И &КонецПериода
	|	И СводныйОтчетОСовершенныхОперациях.СчетДепо В(&СчетаДепо)";
	
	Запрос.УстановитьПараметр("НачалоПериода", НачалоДня(Период));
	Запрос.УстановитьПараметр("КонецПериода", КонецДня(Период));
	Запрос.УстановитьПараметр("СчетаДепо", СчетаДепо);
	
	СуществующиеСводныеОтчеты = Запрос.Выполнить().Выгрузить();
	
	ТаблицаОтчетов = Новый ТаблицаЗначений;
	ТаблицаОтчетов.Колонки.Добавить("СчетДепо");
	ТаблицаОтчетов.Колонки.Добавить("СводныйОтчетОбъект");
	ТаблицаОтчетов.Колонки.Добавить("ЕстьВЭДО");
	
	Для Каждого СчетДепо Из СчетаДепо Цикл
		
		ЕстьВЭДО = Ложь;
		
		СтруктураПоиска = Новый Структура("СчетДепо", СчетДепо);
		ЕстьСводныеОтчеты = СуществующиеСводныеОтчеты.НайтиСтроки(СтруктураПоиска);
		
		Если ЕстьСводныеОтчеты.Количество() = 0 Тогда
			СводныйОтчетОбъект = Документы.СводныйОтчетОСовершенныхОперациях.СоздатьДокумент();
		Иначе
			ВыборкаДетальныеЗаписи = ЕстьСводныеОтчеты[0];
			Если ВыборкаДетальныеЗаписи.ЕстьВЭДО Тогда
				ЕстьВЭДО = Истина;
			КонецЕсли;
			СводныйОтчетОбъект = ВыборкаДетальныеЗаписи.СводныйОтчетСсылка.ПолучитьОбъект();
		КонецЕсли;
		
		СводныйОтчетОбъект.Дата = Период;
		СводныйОтчетОбъект.ДатаНачПериода = Дата(1, 1, 1);
		СводныйОтчетОбъект.ДатаКонПериода = Дата(1, 1, 1);
		СводныйОтчетОбъект.СчетДепо = СчетДепо;
		СводныйОтчетОбъект.ВладелецСчета = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СчетДепо, "Владелец");
		СводныйОтчетОбъект.СпособОтправкиОтчета = Справочники.СпособыПередачиИнформации.ЭДО;
		
		НовыйОтчет = ТаблицаОтчетов.Добавить();
		НовыйОтчет.СчетДепо = СчетДепо;
		НовыйОтчет.СводныйОтчетОбъект = СводныйОтчетОбъект;
		НовыйОтчет.ЕстьВЭДО = ЕстьВЭДО;
		
	КонецЦикла;
	
	Возврат ТаблицаОтчетов;
	
КонецФункции

Процедура СформироватьСводныеОтчеты(НеобходимоПоместитьВЭДО)
	
	ИмяКолонкиСчетаДепо = "НомерСчетаДепо";
	
	тзДокументыКЭДО = ДокументыКЭДО.ВыгрузитьКолонки();
	
	НомераСчетовДепо = Операции.Выгрузить(, ИмяКолонкиСчетаДепо);
	НомераСчетовДепо.Свернуть(ИмяКолонкиСчетаДепо);
	СчетаДепо = НомераСчетовДепо.ВыгрузитьКолонку(ИмяКолонкиСчетаДепо);
	
	ТаблицаСводныхОтчетов = ПолучитьТаблицуСводныхОтчетов(ДатаФормированияОтчетов, СчетаДепо);
	Для Каждого СводныйОтчет Из ТаблицаСводныхОтчетов Цикл
		
		СтруктураОтбора = Новый Структура(ИмяКолонкиСчетаДепо, СводныйОтчет.СчетДепо);
		НайденыОперации = Операции.НайтиСтроки(СтруктураОтбора);
		
		Для Каждого НайденаОперация Из НайденыОперации Цикл
			
			Если СводныйОтчет.ЕстьВЭДО Тогда
				НайденаОперация.СводныйОтчетОСовершенныхОперациях = СводныйОтчет.СводныйОтчетОбъект.Ссылка;
			КонецЕсли;
			
			Если НеобходимоПоместитьВЭДО Или Не СводныйОтчет.ЕстьВЭДО Тогда
				
				НоваяОперацияДокумента = СводныйОтчет.СводныйОтчетОбъект.Операции.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяОперацияДокумента, НайденаОперация);
				
				НайденаОперация.СтатусОК = Истина;
			КонецЕсли;
			
		КонецЦикла;
		
		Если НеобходимоПоместитьВЭДО Или Не СводныйОтчет.ЕстьВЭДО Тогда
			СводныйОтчет.СводныйОтчетОбъект.Комментарий = "Сформирован " + ТекущаяДатаСеанса();
			СводныйОтчет.СводныйОтчетОбъект.Записать(РежимЗаписиДокумента.Проведение, РежимПроведенияДокумента.Неоперативный);
		КонецЕсли;
		
		ДокументКЭДО = тзДокументыКЭДО.Добавить();
		ДокументКЭДО.СчетДепо = СводныйОтчет.СчетДепо;
		ДокументКЭДО.Документ = СводныйОтчет.СводныйОтчетОбъект.Ссылка;
		ДокументКЭДО.Кво = НайденыОперации.Количество();
		ДокументКЭДО.Клиент = СводныйОтчет.СчетДепо.Владелец;
		ДокументКЭДО.Основание = СводныйОтчет.СводныйОтчетОбъект.Ссылка;
		
		Если СводныйОтчет.ЕстьВЭДО Тогда
			ДокументКЭДО.ActionType = "UPD";
		Иначе
			ДокументКЭДО.ActionType = "INS";
		КонецЕсли;
		
	КонецЦикла;
	тзДокументыКЭДО.Сортировать("ActionType УБЫВ");
	ДокументыКЭДО.Очистить();
	Для Каждого СтрокаДокументыКЭДО Из тзДокументыКЭДО Цикл
		Если Справочники.Контрагенты.ОсобыеУсловия(СтрокаДокументыКЭДО.Клиент) Тогда
			Если Не РегистрыСведений.ОтветственныеЛицаОрганизаций.ПользовательМожетРедактироватьОсобыеУсловия() Тогда
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Особые условия: " + СтрокаДокументыКЭДО.Клиент
				+ ". Выполнение операции доступно Ответственному за особых клиентов");
				Продолжить;
			КонецЕсли;
		КонецЕсли;
		СтрокаЭДО = ДокументыКЭДО.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаЭДО, СтрокаДокументыКЭДО);
	КонецЦикла;
	
КонецПроцедуры

Процедура СформироватьИнформационнуюВыписку(ПоВыписке)
	
	тзДокументыКЭДО = ДокументыКЭДО.ВыгрузитьКолонки();
	
	ДокументДляЭДО = тзДокументыКЭДО.Добавить();
	
	Если ЗначениеЗаполнено(ПоВыписке.ИсходящийНомер) Тогда
		ДокументДляЭДО.ActionType = "UPD";
	Иначе
		ДокументДляЭДО.ActionType = "INS";
	КонецЕсли;
	ДокументДляЭДО.СчетДепо = ПоВыписке.СчетДепо;
	ДокументДляЭДО.Документ = ПоВыписке.Ссылка;
	ДокументДляЭДО.Кво = Операции.Количество();
	ДокументДляЭДО.Клиент = ПоВыписке.СчетДепо.Владелец;
	ДокументДляЭДО.Основание = ПоВыписке.Ссылка;
	
	ДокументыКЭДО.Загрузить(тзДокументыКЭДО);
	
КонецПроцедуры

Функция ВыборкаОперацийРаздела(Раздел, ТаблицаОпераций)
	
	ПараметрыОтбора = Новый Структура("Раздел", Раздел);
	
	Возврат ТаблицаОпераций.НайтиСтроки(ПараметрыОтбора);
	
КонецФункции

Процедура УдалитьРегистрациюЭДО()
	
	НачатьТранзакцию();
	Попытка
		// Для каждого док из ДокументыВЭДО -> Удалить запись в РС РегистрацииЭДО, в док. очистить ИсходящийНомер - в транзакции
		ПараметрыОтбора = Новый Структура("ActionType", "UPD");
		ДокументыВЭДО = ДокументыКЭДО.НайтиСтроки(ПараметрыОтбора);
		Для Каждого ДокументыКУдалениюРегистрации Из ДокументыВЭДО Цикл
			
			НаборЗаписей = РегистрыСведений.РегистрацияДокументовВЭДО.СоздатьНаборЗаписей();
			НаборЗаписей.Отбор.Документ.Установить(ДокументыКУдалениюРегистрации.Документ);
			НаборЗаписей.Записать();
			
			ДокОбъект = ДокументыКУдалениюРегистрации.Документ.ПолучитьОбъект();
			ДокОбъект.ИсходящийНомер = "";
			ДокОбъект.Записать();
			
		КонецЦикла;
		ЗафиксироватьТранзакцию();
	Исключение
		ОтменитьТранзакцию();
		ТекстОшибки = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстОшибки);
		Возврат;
	КонецПопытки;
	
КонецПроцедуры

#Область ТекстыЗапросов

Функция Операции_1_ОперацииЦБ()
	Возврат
	"ВЫБРАТЬ
	|	1 КАК Раздел,
	|	ОперацииЦБ.Ссылка КАК ДокументОперации,
	|	НАЧАЛОПЕРИОДА(ОперацииЦБ.Дата, ДЕНЬ) КАК ДатаОперации,
	|	ОперацииЦБ.ВидОперацииД КАК ТипОперации,
	|	ОперацииЦБ.ДокументОснование КАК ОснованиеОперации,
	|	ОперацииЦБ.ДокументОснование.Инициатор КАК ИнициаторОперации,
	|	ВЫБОР
	|		КОГДА ОперацииЦБ.ДокументОснование ССЫЛКА Документ.иц_СводноеПоручение
	|			ТОГДА ""По итогам операций на бирже""
	|		КОГДА ОперацииЦБ.ДокументОснование ССЫЛКА Документ.Поручение
	|				И ВЫРАЗИТЬ(ОперацииЦБ.ДокументОснование КАК Документ.Поручение).ПаиТипЗаявки = ЗНАЧЕНИЕ(Перечисление.ПаиТипыЗаявок.MULTI_BUY)
	|			ТОГДА ОперацииЦБ.Комментарий
	|		ИНАЧЕ ОперацииЦБ.ДокументОснование.Комментарий
	|	КОНЕЦ КАК ДопИнформация,
	|	ОперацииЦБ.ЦБ КАК ЦБ,
	|	ОперацииЦБ.ЦБ.НаименованиеВыпуска КАК НаименованиеВыпуска,
	|	ОперацииЦБ.ЦБ.ISIN КАК ISIN,
	|	ОперацииЦБ.ЦБ.НомерРегистрации КАК РегНом,
	|	ОперацииЦБ.СчетДепо КАК НомерСчетаДепо,
	|	ОперацииЦБ.РазделСчетаДепо КАК РазделСчетаДепо,
	|	ОперацииЦБ.СчетДепо.ТипСчетаДепо КАК ТипСчетаДепо,
	|	ОперацииЦБ.РазделСчетаДепо.ТипРазделаСчетаДЕПО КАК ТипРазделаСчетаДепо,
	|	"""" КАК СтатусНомерОтменяемого,
	|	0 КАК КоличествоЦБ,
	|	ВЫБОР
	|		КОГДА ОстаткиЦБ.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход)
	|			ТОГДА ОперацииЦБ.Количество
	|		ИНАЧЕ 0
	|	КОНЕЦ КАК ОборотЗачислено,
	|	ВЫБОР
	|		КОГДА ОстаткиЦБ.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход)
	|			ТОГДА ОперацииЦБ.Количество
	|		ИНАЧЕ 0
	|	КОНЕЦ КАК ОборотСписано,
	|	ДАТАВРЕМЯ(1, 1, 1, 0, 0, 0) КАК ДатаФиксации,
	|	0 КАК РазмерВыплатыНа1ЦБ,
	|	0 КАК ОбщаяСуммаНачисленной,
	|	0 КАК СуммаНалогаУдержанного,
	|	0 КАК ДополнительныеУдержания,
	|	0 КАК СуммаКВыплате,
	|	0 КАК КоэффициентД1,
	|	0 КАК КоэффициентД2,
	|	"""" КАК ДоходПеречисленНа
	|ПОМЕСТИТЬ ВТ_Операции
	|ИЗ
	|	Документ.ОперацииЦБ КАК ОперацииЦБ
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ОстаткиЦБ КАК ОстаткиЦБ
	|		ПО ОперацииЦБ.Ссылка = ОстаткиЦБ.Регистратор
	|			И (ОстаткиЦБ.СтатусЦБ <> ЗНАЧЕНИЕ(Перечисление.СтатусыЦБ.Блокирована))
	|			И ОперацииЦБ.СчетДепо = ОстаткиЦБ.СчетДепо
	|			И ОперацииЦБ.РазделСчетаДепо = ОстаткиЦБ.РазделСчетаДепо
	|ГДЕ
	|	(&ПоВсемОперациям
	|			ИЛИ &ТипОперации = 1
	|				И ОперацииЦБ.Ссылка = &Операция)
	|	И (&ПоВсемСчетамДепо
	|			ИЛИ ОперацииЦБ.СчетДепо = &НомерСчетаДепо)
	|	И ОперацииЦБ.Проведен
	|	И ОперацииЦБ.Дата МЕЖДУ &НачалоПериода И &КонецПериода
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	1,
