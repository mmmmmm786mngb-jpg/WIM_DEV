	|	И ЗакрытиеСчетаДепо.СчетДепо ССЫЛКА Справочник.СчетаДепо";
КонецФункции

Функция ОперацииСводно()
	
	Возврат
	"ВЫБРАТЬ
	|	ВТ_Операции.ДокументОперации КАК ДокументОперации,
	|	ЕСТЬNULL(СводныйОтчетОСовершенныхОперациях.Ссылка, НЕОПРЕДЕЛЕНО) КАК СводныйОтчетОСовершенныхОперациях
	|ПОМЕСТИТЬ ВТ_Свод
	|ИЗ
	|	ВТ_Операции КАК ВТ_Операции
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.СводныйОтчетОСовершенныхОперациях.Операции КАК СводныйОтчетОСовершенныхОперацияхОперации
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.СводныйОтчетОСовершенныхОперациях КАК СводныйОтчетОСовершенныхОперациях
	|			ПО СводныйОтчетОСовершенныхОперацияхОперации.Ссылка = СводныйОтчетОСовершенныхОперациях.Ссылка
	|		ПО ВТ_Операции.ДокументОперации = СводныйОтчетОСовершенныхОперацияхОперации.ДокументОперации
	|			И (НЕ СводныйОтчетОСовершенныхОперациях.ПометкаУдаления)
	|			И (ВТ_Операции.НомерСчетаДепо = СводныйОтчетОСовершенныхОперациях.СчетДепо)
	|
	|СГРУППИРОВАТЬ ПО
	|	ВТ_Операции.ДокументОперации,
	|	СводныйОтчетОСовершенныхОперациях.Ссылка";
	
КонецФункции

Функция ОбъединитьВсе()
	Возврат
	"
	|
	| ОБЪЕДИНИТЬ ВСЕ
	|
	|";
КонецФункции

Функция Разделитель()
	Возврат
	"
	|
	|";
КонецФункции

Функция ОперацииВыборкаОпераций()
	Возврат
	"ВЫБРАТЬ
	|	ВТ_Операции.Раздел КАК Раздел,
	|	ВТ_Операции.ДокументОперации КАК ДокументОперации,
	|	ВТ_Операции.ДатаОперации КАК ДатаОперации,
	|	ВТ_Операции.ТипОперации КАК ТипОперации,
	|	ВТ_Операции.ОснованиеОперации КАК ОснованиеОперации,
	|	ВТ_Операции.ИнициаторОперации КАК ИнициаторОперации,
	|	ВТ_Операции.ДопИнформация КАК ДопИнформация,
	|	ВТ_Операции.ЦБ КАК ЦБ,
	|	ВТ_Операции.НаименованиеВыпуска КАК НаименованиеВыпуска,
	|	ВТ_Операции.ISIN КАК ISIN,
	|	ВТ_Операции.РегНом КАК РегНом,
	|	ВТ_Операции.НомерСчетаДепо КАК НомерСчетаДепо,
	|	ВТ_Операции.РазделСчетаДепо КАК РазделСчетаДепо,
	|	ВТ_Операции.ТипСчетаДепо КАК ТипСчетаДепо,
	|	ВТ_Операции.ТипРазделаСчетаДепо КАК ТипРазделаСчетаДепо,
	|	ВТ_Операции.СтатусНомерОтменяемого КАК СтатусНомерОтменяемого,
	|	ВТ_Операции.КоличествоЦБ КАК КоличествоЦБ,
	|	ВТ_Операции.ОборотЗачислено КАК ОборотЗачислено,
	|	ВТ_Операции.ОборотСписано КАК ОборотСписано,
	|	ВТ_Операции.ДатаФиксации КАК ДатаФиксации,
	|	ВТ_Операции.РазмерВыплатыНа1ЦБ КАК РазмерВыплатыНа1ЦБ,
	|	ВТ_Операции.ОбщаяСуммаНачисленной КАК ОбщаяСуммаНачисленной,
	|	ВТ_Операции.СуммаНалогаУдержанного КАК СуммаНалогаУдержанного,
	|	ВТ_Операции.ДополнительныеУдержания КАК ДополнительныеУдержания,
	|	ВТ_Операции.СуммаКВыплате КАК СуммаКВыплате,
	|	ВТ_Операции.КоэффициентД1 КАК КоэффициентД1,
	|	ВТ_Операции.КоэффициентД2 КАК КоэффициентД2,
	|	ВТ_Операции.ДоходПеречисленНа КАК ДоходПеречисленНа,
	|	ВТ_Свод.СводныйОтчетОСовершенныхОперациях КАК СводныйОтчетОСовершенныхОперациях
	|ИЗ
	|	ВТ_Операции КАК ВТ_Операции
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_Свод КАК ВТ_Свод
	|		ПО ВТ_Операции.ДокументОперации = ВТ_Свод.ДокументОперации
	|ГДЕ
	|	(&ВключаяОтправленныеВЭДО
	|			ИЛИ ВТ_Свод.СводныйОтчетОСовершенныхОперациях = НЕОПРЕДЕЛЕНО)
	|
	|УПОРЯДОЧИТЬ ПО
	|	Раздел,
	|	ТипОперации,
	|	ДокументОперации";
КонецФункции

Функция ТекстЗапросаВыборкиОпераций()
	
	Возврат Операции_1_ОперацииЦБ() 						+ ОбъединитьВсе()
	+ Операции_2_ГлобальныеОперацииЦБ() 					+ ОбъединитьВсе()
	+ Операции_2_ГлобальныеОперацииДС() 					+ ОбъединитьВсе()
	+ Операции_3_УчастиеВКД() 								+ ОбъединитьВсе()
	+ Операции_4_ОтменаПоручения() 							+ ОбъединитьВсе()
	+ Операции_5_ИзменениеАнкетныхДанных() 					+ ОбъединитьВсе()
	+ Операции_5_ИзменениеКатегорииСчетовДепонента()		+ ОбъединитьВсе()
	+ Операции_6_ОткрытиеРазделаСчетаДепо() 				+ ОбъединитьВсе()
	+ Операции_7_ЗакрытиеРазделаСчетаДепо() 				+ ОбъединитьВсе()
	+ Операции_8_ОткрытиеСчетаДепо() 						+ ОбъединитьВсе()
	+ Операции_9_ЗакрытиеСчетаДепо() + "; " 				+ Разделитель()
	+ ОперацииСводно()				 + "; " 				+ Разделитель()
	+ ОперацииВыборкаОпераций();
	
КонецФункции

#КонецОбласти

#Область ФормированиеПечатныхФорм

Функция ПолучитьИмяМакета(Контрагент, ОтчетыНаАнглийскомЯзыке, Период)
	
	ЗначениеПоУмолчанию = ДАТА(1, 1, 1);
	ДатаПереходаНаПечатнуюФорму2026 =
		РегистрыСведений.ПараметрыГлобальные.ЗначениеПараметра("3490.ДатаПереходаНаПечатныеФормыВыписок2026",
			ЗначениеПоУмолчанию);
	
	Если Период >= ДатаПереходаНаПечатнуюФорму2026 Тогда
		ИмяМакета = "Макет2026";
	Иначе
		ИмяМакета = "Макет2023";
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Контрагент) И ОтчетыНаАнглийскомЯзыке Тогда
		ИмяМакета = ИмяМакета + "en";
	КонецЕсли;
	
	Возврат ИмяМакета;
	
КонецФункции

Функция СформироватьПараметрыЗаголовкаМакета(Период, ВыпискаДокумент, Контрагент, ОтчетыНаАнглийскомЯзыке, СчетДЕПО, ИмяМакета)
	
	стПараметры = Новый Структура;
	
	ОрганизацияПоУмолчанию = ОбщегоНазначенияПовтИсп.ЗначениеКонстанты("ОрганизацияПоУмолчанию");
	
	НачПериода = НачалоДня(Период);
	КонПериода = КонецДня(Период);
	
	Депозитарий			= ОрганизацияПоУмолчанию;
	ДанныеЛицензии		= ФормированиеПечатныхФорм.ДанныеЛицензииОрганизации(ОрганизацияПоУмолчанию);
	
	стПараметры.Вставить("Дата", 			"с " + Формат(НачПериода, "ДЛФ=DD") + " по " + Формат(КонПериода, "ДЛФ=DD"));
	стПараметры.Вставить("ИсходящийНомер", СокрЛП(ВыпискаДокумент.Номер));
	стПараметры.Вставить("Депозитарий",		"ДЕПОЗИТАРИЙ" + Символы.ПС + СокрЛП(Депозитарий.Наименование));
	стПараметры.Вставить("Лицензия",		"Лицензия № " + СокрЛП(ДанныеЛицензии.НомерЛицензии));
	стПараметры.Вставить("ЛицензияДата",	"выдана " + Формат(ДанныеЛицензии.ДатаЛицензии, "ДФ=dd.MM.yyyy") + " г. ФСФР России");
	стПараметры.Вставить("Custody",			"");
	
	Если ОтчетыНаАнглийскомЯзыке Тогда
		стПараметры.Депозитарий = стПараметры.Депозитарий + Символы.ПС + стПараметры.Лицензия + Символы.ПС + стПараметры.ЛицензияДата;
		стПараметры.Custody     = "CUSTODY" + Символы.ПС + СокрЛП(Депозитарий.АнглийскоеНаименование) + Символы.ПС
			+ "License No. " + СокрЛП(ДанныеЛицензии.НомерЛицензии) + Символы.ПС
			+ "issued by FFMS of Russia on " + Формат(ДанныеЛицензии.ДатаЛицензии, "ДЛФ=D");
		
		Для Индекс = 1 По 12 Цикл
			стПараметры.Вставить("ор" + Индекс, Сред(стПараметры.ИсходящийНомер, Индекс, 1));
		КонецЦикла;
		
	КонецЕсли;
	
	стПараметры.Вставить("НомерВыписки", "Отчет № " + стПараметры.ИсходящийНомер + " о совершенных операциях по счету ДЕПО");
	
	стПараметры.Вставить("НаименованиеДепонента",
		ОбщегоНазначенияКлиентСервер.НаименованиеЮрФизЛицаКлиента(Контрагент, Период, ОтчетыНаАнглийскомЯзыке));
	стПараметры.Вставить("ДокументыДепонента",
		ОбщегоНазначенияКлиентСервер.ДокументКлиента(Контрагент, Период));
	стПараметры.Вставить("НаименованиеСчетаДЕПО",
		ОбщегоНазначенияКлиентСервер.НаименованиеКлиента(Контрагент, ОтчетыНаАнглийскомЯзыке));
	стПараметры.Вставить("НомерСчетаДЕПО",
		?(ЗначениеЗаполнено(СчетДЕПО), СокрЛП(СчетДЕПО.Код), ""));
	
	ФормированиеПечатныхФорм.СформироватьДатуДДММГГ(стПараметры, "", Период);
	
	ФормированиеПечатныхФорм.СформироватьДатуДДММГГ(стПараметры, "С", НачПериода);
	ФормированиеПечатныхФорм.СформироватьДатуДДММГГ(стПараметры, "По", КонПериода);
	
	Если СтрНайти(ИмяМакета, "Макет2023") > 0 Тогда
		Инфо = ФормированиеПечатныхФорм.ИнформацияОДепозитарии(Период, СчетДЕПО.ВидСчетаДепо)
		+ Символы.ПС + Символы.ПС + ФормированиеПечатныхФорм.ИнформацияОДепозитарииНаАнглийском(Период, СчетДЕПО.ВидСчетаДепо);
		стПараметры.Вставить("ИнформацияОДепозитарии", Инфо);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(СчетДЕПО) Тогда
		Если РегистрыСведений.КлиентыСУчетомНаСчетахТипаC.ЦБКлиентаУчитываютсяНаСчетеТипаС(Период, Контрагент) Тогда
			ТипСчетаДепо = "" + СчетДЕПО.ТипСчетаДепо + " типа С";
		Иначе
			ТипСчетаДепо = СчетДЕПО.ТипСчетаДепо;
		КонецЕсли;
		НаименованиеСчетаДЕПО =
			?(ОтчетыНаАнглийскомЯзыке, ПереводТекстаНаДругиеЯзыки.ДополнитьТекстПереводом(ТипСчетаДепо), СокрЛП(ТипСчетаДепо));
	Иначе
		НаименованиеСчетаДЕПО = "";
	КонецЕсли;
	стПараметры.Вставить("НаименованиеСчетаДЕПО", НаименованиеСчетаДЕПО);
	
	Возврат стПараметры;
	
КонецФункции

Функция СформироватьПараметрыПодвалаМакета(Период, Контрагент, ОтчетыНаАнглийскомЯзыке, СчетДепо, ИмяМакета)
	
	стПараметры = Новый Структура;
	
	ТекПользователь = ПараметрыСеанса.ТекущийПользователь; 
	Если Не ЗначениеЗаполнено(ТекПользователь) Или Не РольДоступна("ПравоПодписанияОтчетов") Тогда
		Отбор = Новый Структура;
		Отбор.Вставить("ОтветственноеЛицо", Перечисления.ОтветственныеЛицаОрганизаций.ПодписантОтчетовПоУмолчанию);
		ОтветственноеЛицо = РегистрыСведений.ОтветственныеЛицаОрганизаций.ПолучитьПоследнее(Период, Отбор).ФизическоеЛицо;
	Иначе
		ОтветственноеЛицо	= ТекПользователь.ФизЛицо;
	КонецЕсли;
	
	стПараметры.Вставить("ФИО",
		?(ОтветственноеЛицо = Неопределено, ПараметрыСеанса.ТекущийПользователь.ПолноеНаименование(), ОтветственноеЛицо.Наименование));
	
	Если ОтчетыНаАнглийскомЯзыке Тогда
		стПараметры.ФИО = стПараметры.ФИО + " / " + ОбщегоНазначенияКлиентСервер.Транслит(стПараметры.ФИО);
	КонецЕсли;
	
	ФормированиеПечатныхФорм.СформироватьДатуВремяДДММГГЧЧММ(стПараметры, "", Период);
	
	Если СчетДепо.ВидСчетаДепо = Перечисления.ВидыСчетовДепо.СчетДЕПО Тогда
		стПараметры.Вставить("РеквизитыПриказа", РегистрыСведений.РеквизитыПриказовПриложенийКРДО.Реквизиты(Период));
	КонецЕсли;
	
	Возврат стПараметры;
	
КонецФункции

Процедура ВывестиСекциюСтрокаОборот(
	ВыборкаОпераций,
	ТабличныйДокумент,
	СтрокаОборот,
	ОтчетыНаАнглийскомЯзыке,
	ВидСчетаДепо,
	ПараметрыПереносаСтраницы)
	
	// --> Проверка на "разрыв" страницы: не отделять первую строку таблицы от шапки
	// 			Заполнение данными области первой строки таблицы
	ПерваяСтрока = ВыборкаОпераций[0];
	ОбластьСтрока = ПараметрыПереносаСтраницы.ОбластьСтрока;
	ЗаполнитьЗначенияСвойств(ОбластьСтрока.Параметры, ПерваяСтрока);
	Если ПерваяСтрока.Раздел <> "5" Тогда
		ОбластьСтрока.Параметры.ПредставлениеЦБ = ОбщегоНазначенияКлиентСервер.ПредставлениеЦБ(ПерваяСтрока.ЦБ, ОтчетыНаАнглийскомЯзыке);
	КонецЕсли;
	ТипОперацииСтрокой = ОбщегоНазначенияКлиентСервер.ТипОперацииСтрокой(ПерваяСтрока.ТипОперации, ОтчетыНаАнглийскомЯзыке, ВидСчетаДепо);
	ОбластьСтрока.Параметры.ТипОперации = ТипОперацииСтрокой;
	ОснованиеОперации = ОбщегоНазначенияКлиентСервер.ДокументОснованиеСтрокой(ПерваяСтрока.ОснованиеОперации, ОтчетыНаАнглийскомЯзыке);
	ОбластьСтрока.Параметры.ОснованиеОперации = ОснованиеОперации;
	// 			Подготовка массива областей макета, проверяемых на потенциальный "разрыв" страницы между ними
	// 			: области "шапка" таблицы и "первая строка" таблицы должны быть на одном листе
	СтрокаСШапкой = Новый Массив;
	СтрокаСШапкой.Добавить(ПараметрыПереносаСтраницы.ШапкаРаздела);
	СтрокаСШапкой.Добавить(ОбластьСтрока);
	// 			Подготовка массива областей макета, проверяемых на потенциальный "разрыв" страницы между ними
	// 			: если таблица последняя и в ней одна строка, то на одном листе должна быть и таблица, и "подвал"
	Если ПараметрыПереносаСтраницы.ПоследняяСтрока = 1 Тогда
		СтрокаСШапкой.Добавить(ПараметрыПереносаСтраницы.ОбластьПустаяСтрокаОборот);
		СтрокаСШапкой.Добавить(ПараметрыПереносаСтраницы.Подвал);
	КонецЕсли;
	БылПереносСПодвалом = Ложь;
	// Если проверяемые области не помещаются на один лист - начать их вывод с нового листа
	Если Не ФормированиеПечатныхФорм.ПроверитьВыводТабличногоДокумента(ТабличныйДокумент, СтрокаСШапкой) Тогда
		ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();
		БылПереносСПодвалом = ПараметрыПереносаСтраницы.ПоследняяСтрока = 1;
	КонецЕсли;
	// <--
	
	ТабличныйДокумент.Вывести(ПараметрыПереносаСтраницы.ШапкаРаздела);
	
	НомерТекущейСтроки = 0;
	СквозныеПараметры = Новый Структура;
	СквозныеПараметры.Вставить("ВидСчетаДепо", 				ВидСчетаДепо);
	СквозныеПараметры.Вставить("ОтчетыНаАнглийскомЯзыке",	ОтчетыНаАнглийскомЯзыке);
	СквозныеПараметры.Вставить("НомерТекущейСтроки", 		0);
	СквозныеПараметры.Вставить("БылПереносСПодвалом", 		БылПереносСПодвалом);
	Для Каждого Данные Из ВыборкаОпераций Цикл
		ВывестиОднуСтрокуСекцииСтрокаОборот(ТабличныйДокумент, Данные, СтрокаОборот, ПараметрыПереносаСтраницы, СквозныеПараметры);
	КонецЦикла;
	
КонецПроцедуры

Процедура ВывестиОднуСтрокуСекцииСтрокаОборот(ТабличныйДокумент, Данные, СтрокаОборот, ПараметрыПереносаСтраницы, СквозныеПараметры)
	СквозныеПараметры.НомерТекущейСтроки = СквозныеПараметры.НомерТекущейСтроки + 1;
	Раздел = Данные.Раздел;
	ОтчетыНаАнглийскомЯзыке = СквозныеПараметры.ОтчетыНаАнглийскомЯзыке;
	
	ЗаполнитьЗначенияСвойств(СтрокаОборот.Параметры, Данные);
	
	Если Раздел <> "5" Тогда
		СтрокаОборот.Параметры.ПредставлениеЦБ = ОбщегоНазначенияКлиентСервер.ПредставлениеЦБ(Данные.ЦБ, ОтчетыНаАнглийскомЯзыке);
	КонецЕсли;
	
	Если Раздел = "1" Или Раздел = "2" Или Раздел = "5" Тогда
		Представление = ОбщегоНазначенияКлиентСервер.ПредставлениеРазделаСчетаДепо(Данные.РазделСчетаДепо, ОтчетыНаАнглийскомЯзыке);
		СтрокаОборот.Параметры.РазделСчетаДепо = Представление;
	КонецЕсли;
	
	Если Раздел = "5" Тогда
		Представление = ОбщегоНазначенияКлиентСервер.ПредставлениеТипаРазделаСчетаДепоДляОтчета(Данные.ТипРазделаСчетаДепо,
																									ОтчетыНаАнглийскомЯзыке);
		СтрокаОборот.Параметры.ТипРазделаСчетаДепо = Представление;
	КонецЕсли;
	
	Если Раздел = "5" Тогда
		Если РегистрыСведений.КлиентыСУчетомНаСчетахТипаC.ЦБКлиентаУчитываютсяНаСчетеТипаС(Данные.ДатаОперации, Данные.ИнициаторОперации) Тогда
			ТипСчетаДепо = "" + Данные.ТипСчетаДепо + " типа С";
		Иначе
			ТипСчетаДепо = Данные.ТипСчетаДепо;
		КонецЕсли;
		НаименованиеСчетаДЕПО =
		?(ОтчетыНаАнглийскомЯзыке, ПереводТекстаНаДругиеЯзыки.ДополнитьТекстПереводом(ТипСчетаДепо), СокрЛП(ТипСчетаДепо));
		СтрокаОборот.Параметры.ТипСчетаДепо = НаименованиеСчетаДЕПО;
	КонецЕсли;
		
	СтрокаОборот.Параметры.ТипОперации = ОбщегоНазначенияКлиентСервер.ТипОперацииСтрокой(Данные.ТипОперации,
												 							ОтчетыНаАнглийскомЯзыке, СквозныеПараметры.ВидСчетаДепо);
	
	ОснованиеОперации = ОбщегоНазначенияКлиентСервер.ДокументОснованиеСтрокой(Данные.ОснованиеОперации, ОтчетыНаАнглийскомЯзыке);
	СтрокаОборот.Параметры.ОснованиеОперации = ОснованиеОперации;
	
	// --> Проверка на "разрыв" страницы: если подвал не вмещается на страницу, то вывести его с последней строкой таблицы на след. лист
	Если Не СквозныеПараметры.БылПереносСПодвалом И СквозныеПараметры.НомерТекущейСтроки = ПараметрыПереносаСтраницы.ПоследняяСтрока Тогда
	// 		Подготовка массива областей макета, проверяемых на потенциальный "разрыв" страницы между ними
	// 		: области "последняя строка" последней таблицы и "подвал" таблицы должны быть на одном листе
		СтрокаСПодвалом = Новый Массив;
		СтрокаСПодвалом.Добавить(СтрокаОборот);
		СтрокаСПодвалом.Добавить(ПараметрыПереносаСтраницы.ОбластьПустаяСтрокаОборот);
		СтрокаСПодвалом.Добавить(ПараметрыПереносаСтраницы.Подвал);
		Если Не ФормированиеПечатныхФорм.ПроверитьВыводТабличногоДокумента(ТабличныйДокумент, СтрокаСПодвалом) Тогда
			// Если проверяемые области не помещаются на один лист - начать их вывод с нового листа
			ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();
		КонецЕсли;
	КонецЕсли;
	// <--
	
	ТабличныйДокумент.Вывести(СтрокаОборот);
КонецПроцедуры

Процедура СформироватьПечатныеФормы(ПоказатьПечатьИПодписьВДокументе, ТаблицаОпераций = Неопределено)
	
	Для Каждого СтрокаСДокументом Из ДокументыКЭДО Цикл
		
		Адрес = Документы.СводныйОтчетОСовершенныхОперациях.АдресПечатнойФормы(
			СтрокаСДокументом.Документ,
			ТаблицаОпераций,
			ПоказатьПечатьИПодписьВДокументе,
			Новый УникальныйИдентификатор);
		Описатель = ПолучитьИзВременногоХранилища(Адрес);
		
		Если Описатель.Свойство("Ошибка") Тогда
			СтрокаСДокументом.АдресТаблицы = "";
		Иначе
			СтрокаСДокументом.АдресТаблицы = ПоместитьВоВременноеХранилище(Описатель.ТабДок);
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

Процедура ОпределитьПечатьПодпись(ОпределяющаяДата, ПоказатьПечатьПодписьВОтчете, ПечатьКартинка, FaksimilieКартинка)
	
	FaksimilieКартинка	= Новый Картинка;
	ПечатьКартинка		= Новый Картинка;
	Если Не ПоказатьПечатьПодписьВОтчете Тогда
		Возврат;
	КонецЕсли;
	
	ТекПользователь = ПараметрыСеанса.ТекущийПользователь;
	Если Не ЗначениеЗаполнено(ТекПользователь) Или Не РольДоступна("ПравоПодписанияОтчетов") Тогда
		Отбор = Новый Структура;
		Отбор.Вставить("ОтветственноеЛицо", Перечисления.ОтветственныеЛицаОрганизаций.ПодписантОтчетовПоУмолчанию);
		ОтветственноеЛицо 	= РегистрыСведений.ОтветственныеЛицаОрганизаций.ПолучитьПоследнее(ОпределяющаяДата, Отбор).ФизическоеЛицо;
	Иначе
		ОтветственноеЛицо	= ТекПользователь.ФизЛицо;
	КонецЕсли;
	
	ФормированиеПечатныхФорм.ПолучитьФаксимилье(ОтветственноеЛицо, FaksimilieКартинка);
	ПечатьКартинка		= БиблиотекаКартинок.ПечатьДепозитарий;
	
КонецПроцедуры

#КонецОбласти

#Область ОтправкаВЭДО

