
Процедура ИсправитьВходящиеНомераПоручений() Экспорт 
	
	Поручения = Документы.Поручение.Выбрать(НачалоДня(ДатаПоручений), КонецДня(ДатаПоручений));
	Пока Поручения.Следующий() Цикл
		Если ЗначениеЗаполнено(Поручения.НомерПорученияВБО) Тогда
			Продолжить;
		КонецЕсли;
		Поручение = Поручения.ПолучитьОбъект();
		Поручение.ВходящийНомерПоручения = Поручение.Номер;
		Поручение.ОбменДанными.Загрузка = Истина;
		Поручение.Записать(РежимЗаписиДокумента.Запись);
	КонецЦикла;
	
КонецПроцедуры
