Функция ПроверкаДанныхСтрокиУспешна(Строка)
	Поля = Новый СписокЗначений;
	// Сведения
	Поля.Добавить("Адрес",	"Адрес");
	Поля.Добавить("Страна",	"Страна");
	Поля.Добавить("НДИНД",	"НД/ИНД");
	Поля.Добавить("КодНРД",	"Код НРД");
	Поля.Добавить("Статус",	"Статус");
	// Документ
	Поля.Добавить("ДокументНомер",	"Номер документа");
	Поля.Добавить("ДокументТип",	"Тип документа");
	
	Ошибка = Ложь;
	Для Каждого Поле Из Поля Цикл
		Если НЕ ЗначениеЗаполнено(Строка.Параметры[Поле.Значение]) Тогда
			ОбщегоНазначения.СообщитьОбОшибке(СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
				"По клиенту %1 не указано поле '%2'!", Строка.Параметры.Наименование, Поле.Представление), Ошибка);
		КонецЕсли;
	КонецЦикла;
	
	// Счета
	Если 
		Не ЗначениеЗаполнено(Строка.Параметры.НД) И
		Не ЗначениеЗаполнено(Строка.Параметры.ИНД) И
		Не ЗначениеЗаполнено(Строка.Параметры.Владелец) И
		Не ЗначениеЗаполнено(Строка.Параметры.ДУ) И
		Не ЗначениеЗаполнено(Строка.Параметры.ДП)
		Тогда
		ОбщегоНазначения.СообщитьОбОшибке(СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
			"По клиенту %1 не указано ни одного счета!", Строка.Параметры.Наименование), Ошибка);
	КонецЕсли;
	
	Возврат НЕ Ошибка;
КонецФункции

Функция ЗапросПоДаннымКлиентов() Экспорт
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	ГФЛ.ФизЛицо,
	|	ГФЛ.Страна,
	|	ГФЛ.НеЯвляетсяНалоговымРезидентомРФ
	|ПОМЕСТИТЬ ГФЛ
	|ИЗ
	|	РегистрСведений.ГражданствоФизЛиц.СрезПоследних(&ДатаЗапроса, ) КАК ГФЛ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ПДФЛ.ФизЛицо,
	|	ПДФЛ.ДокументВид,
	|	ПДФЛ.ДокументСерия,
	|	ПДФЛ.ДокументНомер,
	|	ПДФЛ.ДокументДатаВыдачи,
	|	ПДФЛ.ДокументКемВыдан,
	|	ПДФЛ.ДокументКодПодразделения
	|ПОМЕСТИТЬ ПДФЛ
	|ИЗ
	|	РегистрСведений.ПаспортныеДанныеФизЛиц.СрезПоследних(&ДатаЗапроса, ) КАК ПДФЛ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	КИ.Объект,
	|	КИ.Представление
	|ПОМЕСТИТЬ КИК
	|ИЗ
	|	РегистрСведений.КонтактнаяИнформация.СрезПоследних(
	|			&ДатаЗапроса,
	|			Объект ССЫЛКА Справочник.ЮридическиеЛица
	|				ИЛИ Объект ССЫЛКА Справочник.ФизическиеЛица) КАК КИ
	|ГДЕ
	|	КИ.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыКонтактнойИнформации.Адрес)
	|	И КИ.Вид В(&ВидыКИ)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Договор.Владелец КАК Клиент,
	|	Договор.Владелец.Код КАК КодКлиента,
	|	ЕСТЬNULL(ГФЛ.НеЯвляетсяНалоговымРезидентомРФ, Договор.Владелец.ЮридическиеФизическиеЛица.НеРезидент) КАК НеРезидент,
	|	СчетаДепо.Ссылка КАК СчетДЕПО,
	|	СчетаДепо.ТипСчетаДепо КАК ТипСчета,
	|	Договор.Владелец.ЮридическиеФизическиеЛица КАК ЮФЛ
	|ПОМЕСТИТЬ втЮрФизЛица
	|ИЗ
	|	Справочник.ДоговорыКонтрагентов КАК Договор
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.СчетаДепо КАК СчетаДепо
	|		ПО (СчетаДепо.Код = Договор.Владелец.Код)
	|		ЛЕВОЕ СОЕДИНЕНИЕ ГФЛ КАК ГФЛ
	|		ПО (ГФЛ.ФизЛицо = Договор.Владелец.ЮридическиеФизическиеЛица)
	|ГДЕ
	|	НЕ Договор.ПометкаУдаления
	|	И НЕ Договор.ЭтоГруппа
	|	И Договор.ТипДоговора = ЗНАЧЕНИЕ(Перечисление.ТипыДоговоров.Депозитарный)
	|	И Договор.Родитель = ЗНАЧЕНИЕ(Справочник.ДоговорыКонтрагентов.ПустаяСсылка)
	|	И Договор.ДатаНачалоДействия <= &ДатаЗапроса
	|	И (Договор.ДатаОкончанияДействия = ДАТАВРЕМЯ(1, 1, 1)
	|			ИЛИ Договор.ДатаОкончанияДействия > &ДатаЗапроса)
	|	И НЕ ЕСТЬNULL(ГФЛ.НеЯвляетсяНалоговымРезидентомРФ, Договор.Владелец.ЮридическиеФизическиеЛица.НеРезидент) ЕСТЬ NULL 
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЮрФизЛица.Клиент КАК Клиент,
	|	ЮрФизЛица.КодКлиента КАК КодКлиента,
	|	ЮрФизЛица.НеРезидент КАК НеРезидент,
	|	ЮрФизЛица.СчетДЕПО КАК СчетДЕПО,
	|	ЮрФизЛица.ТипСчета КАК ТипСчета,
	|	ЮрФизЛица.ЮФЛ КАК ЮФЛ,
	|	ВЫБОР
	|		КОГДА ЮрФизЛица.ЮФЛ ССЫЛКА Справочник.ФизическиеЛица
	|			ТОГДА ЮрФизЛица.ЮФЛ.Наименование
	|		ИНАЧЕ ВЫРАЗИТЬ(ЮрФизЛица.ЮФЛ.ПолноеНаименование КАК СТРОКА(1000))
	|	КОНЕЦ КАК Наименование,
	|	КИК.Представление КАК Адрес,
	|	ЕСТЬNULL(ЮрФизЛица.ЮФЛ.Страна.КодАльфа2, ГФЛ.Страна.КодАльфа2) КАК Страна,
	|	&НаименованиеОрганизации КАК НДИНД,
	|	&КодНРД КАК КодНРД,
	|	""A"" КАК Статус,
	|	ВЫБОР
	|		КОГДА ЮрФизЛица.ЮФЛ ССЫЛКА Справочник.ФизическиеЛица
	|			ТОГДА ПДФЛ.ДокументСерия + "" "" + ПДФЛ.ДокументНомер
	|		ИНАЧЕ ВЫБОР
	|				КОГДА НЕ ЮрФизЛица.НеРезидент
	|					ТОГДА ВЫБОР
	|							КОГДА ЮрФизЛица.ЮФЛ.ОГРН <> """"
	|								ТОГДА ЮрФизЛица.ЮФЛ.ОГРН
	|							КОГДА ЮрФизЛица.ЮФЛ.ИНН <> """"
	|								ТОГДА ЮрФизЛица.ЮФЛ.ИНН
	|							ИНАЧЕ """"
	|						КОНЕЦ
	|				ИНАЧЕ ВЫБОР
	|						КОГДА ЮрФизЛица.ЮФЛ.ОГРН <> """"
	|							ТОГДА ЮрФизЛица.ЮФЛ.ОГРН
	|						КОГДА ЮрФизЛица.ЮФЛ.РегНомер <> """"
	|							ТОГДА ЮрФизЛица.ЮФЛ.РегНомер
	|						КОГДА ЮрФизЛица.ЮФЛ.ИНН <> """"
	|							ТОГДА ЮрФизЛица.ЮФЛ.ИНН
	|						КОГДА ЮрФизЛица.ЮФЛ.TIN <> """"
	|							ТОГДА ЮрФизЛица.ЮФЛ.TIN
	|						ИНАЧЕ """"
	|					КОНЕЦ
	|			КОНЕЦ
	|	КОНЕЦ КАК ДокументНомер,
	|	ВЫБОР
	|		КОГДА ЮрФизЛица.ЮФЛ ССЫЛКА Справочник.ФизическиеЛица
	|			ТОГДА ПДФЛ.ДокументВид.КодНРД
	|		ИНАЧЕ ВЫБОР
	|				КОГДА НЕ ЮрФизЛица.НеРезидент
	|					ТОГДА ВЫБОР
	|							КОГДА ЮрФизЛица.ЮФЛ.ОГРН <> """"
	|								ТОГДА ""OGRN""
	|							КОГДА ЮрФизЛица.ЮФЛ.ИНН <> """"
	|								ТОГДА ""TXID""
	|							ИНАЧЕ ""OTHR""
	|						КОНЕЦ
	|				ИНАЧЕ ВЫБОР
	|						КОГДА ЮрФизЛица.ЮФЛ.ОГРН <> """"
	|								ИЛИ ЮрФизЛица.ЮФЛ.РегНомер <> """"
	|							ТОГДА ""INCR""
	|						ИНАЧЕ ""OTHR""
	|					КОНЕЦ
	|			КОНЕЦ
	|	КОНЕЦ КАК ДокументТип,
	|	ВЫБОР
	|		КОГДА ЮрФизЛица.ЮФЛ ССЫЛКА Справочник.ФизическиеЛица
	|			ТОГДА ГФЛ.Страна.КодАльфа2
	|		КОГДА ЮрФизЛица.ЮФЛ ССЫЛКА Справочник.ЮридическиеЛица
	|			ТОГДА ЮрФизЛица.ЮФЛ.Страна.КодАльфа2
	|		ИНАЧЕ """"
	|	КОНЕЦ КАК ДокументСтранаВыдачи,
	|	""Y"" КАК ДокументОсновной,
	|	ВЫБОР
	|		КОГДА ЮрФизЛица.ТипСчета В (&СчетаНД)
	|			ТОГДА ЮрФизЛица.СчетДЕПО.Код
	|		ИНАЧЕ """"
	|	КОНЕЦ КАК НД,
	|	ВЫБОР
	|		КОГДА ЮрФизЛица.ТипСчета В (&СчетаИНД)
	|			ТОГДА ЮрФизЛица.СчетДЕПО.Код
	|		ИНАЧЕ """"
	|	КОНЕЦ КАК ИНД,
	|	ВЫБОР
	|		КОГДА ЮрФизЛица.ТипСчета В (&СчетаВладельца)
	|			ТОГДА ЮрФизЛица.СчетДЕПО.Код
	|		ИНАЧЕ """"
	|	КОНЕЦ КАК Владелец,
	|	ВЫБОР
	|		КОГДА ЮрФизЛица.ТипСчета В (&СчетаДУ)
	|			ТОГДА ЮрФизЛица.СчетДЕПО.Код
	|		ИНАЧЕ """"
	|	КОНЕЦ КАК ДУ,
	|	"""" КАК ДП
	|ИЗ
	|	втЮрФизЛица КАК ЮрФизЛица
	|		ЛЕВОЕ СОЕДИНЕНИЕ ГФЛ КАК ГФЛ
	|		ПО (ГФЛ.ФизЛицо = ЮрФизЛица.ЮФЛ)
	|		ЛЕВОЕ СОЕДИНЕНИЕ ПДФЛ КАК ПДФЛ
	|		ПО (ПДФЛ.ФизЛицо = ЮрФизЛица.ЮФЛ)
	|		ЛЕВОЕ СОЕДИНЕНИЕ КИК КАК КИК
	|		ПО (КИК.Объект = ЮрФизЛица.ЮФЛ)
	|
	|УПОРЯДОЧИТЬ ПО
	|	ЮрФизЛица.КодКлиента");	
	СчетаНД = Новый Массив;
	СчетаНД.Добавить(Перечисления.ТипыСчетовДепо.НоминальногоДержателя);
	
	СчетаИНД = Новый Массив;
	СчетаИНД.Добавить(Перечисления.ТипыСчетовДепо.ИностранногоНоминальногоДержателя);
	СчетаИНД.Добавить(Перечисления.ТипыСчетовДепо.ИностранногоУполномоченногоДержателя);
	
	СчетаВладельца = Новый Массив;
	СчетаВладельца.Добавить(Перечисления.ТипыСчетовДепо.Владельца);
	СчетаВладельца.Добавить(Перечисления.ТипыСчетовДепо.КазначейскийСчетЭмитента);
	СчетаВладельца.Добавить(Перечисления.ТипыСчетовДепо.Залогодержателя);
	СчетаВладельца.Добавить(Перечисления.ТипыСчетовДепо.ЭмиссионныйСчет);
	
	СчетаДУ = Новый Массив;
	СчетаДУ.Добавить(Перечисления.ТипыСчетовДепо.ДоверительногоУправляющего);
	СчетаДУ.Добавить(Перечисления.ТипыСчетовДепо.ДоверительногоУправляющегоТорговый);
	
	Организация = Константы.ОрганизацияПоУмолчанию.Получить();
	
	ВидыКИ = Новый СписокЗначений;
	ВидыКИ.Добавить(Справочники.ВидыКонтактнойИнформации.ЮрАдресФизЛица);
	ВидыКИ.Добавить(Справочники.ВидыКонтактнойИнформации.ЮрАдресЮрЛица);
	ВидыКИ.Добавить(Справочники.ВидыКонтактнойИнформации.ЮрАдресКонтрагента);
	ВидыКИ.Добавить(Справочники.ВидыКонтактнойИнформации.ЮрАдресОрганизации);
		
	Запрос.УстановитьПараметр("ДатаЗапроса"				, ДатаЗапроса);
	Запрос.УстановитьПараметр("ВидыКИ"					, ВидыКИ);
	Запрос.УстановитьПараметр("НаименованиеОрганизации"	, ?(ЗначениеЗаполнено(Организация.НаименованиеПолное),
		Организация.НаименованиеПолное, Организация.Наименование));
	Запрос.УстановитьПараметр("КодНРД"					, КодНРДОрганизации(Организация));
	Запрос.УстановитьПараметр("СчетаНД"					, СчетаНД);
	Запрос.УстановитьПараметр("СчетаИНД"				, СчетаИНД);
	Запрос.УстановитьПараметр("СчетаВладельца"			, СчетаВладельца);
	Запрос.УстановитьПараметр("СчетаДУ"					, СчетаДУ);
	
	Результат = Запрос.Выполнить().Выгрузить();
	Если Результат.Количество() > 0 Тогда
		ТабДок = Новый ТабличныйДокумент;
		ДокCSV = Новый ТекстовыйДокумент;
		ДокCSV.УстановитьТипФайла("windows-1251");
		ДокCSV.ДобавитьСтроку("ID;Сведения;;;;;;Документ;;;;Счета;;;;;;;;;");
		ДокCSV.ДобавитьСтроку("ID клиента;ФИО/Наименование;Адрес регистрации/Юридический адрес;Страна;НД/ДУ/ИНД;"
			+ "Код НРД;Статус;Номер;Тип;Страна выдачи документа;Основной;НД;ИНД;Владелец;ДУ;ДП;Иной;Казначейский;Общедолевой В;"
			+ "Общедолевой Д;Общедолевой И");
		Макет = ПолучитьМакет("Макет");
		Шапка = Макет.ПолучитьОбласть("Шапка");
		ТабДок.Вывести(Шапка);
		Для Каждого СтрокаДанных ИЗ Результат Цикл
			КодКлиента = СокрЛП(СтрокаДанных.КодКлиента); 
			ФИОНаименование = СокрЛП(?(ЗначениеЗаполнено(СтрокаДанных.Наименование), СтрокаДанных.Наименование,
				СтрокаДанных.Клиент.Наименование));
			Страна = ?(ЗначениеЗаполнено(СтрокаДанных.Страна), СокрЛП(СтрокаДанных.Страна),
				?(Не СтрокаДанных.НеРезидент, "RU", ""));
			
			// Расшифровка по строке			
			Строка = Макет.ПолучитьОбласть("Строка");
			Строка.Параметры.Клиент				= СтрокаДанных.Клиент;
			Строка.Параметры.Код				= КодКлиента;
			Строка.Параметры.Наименование		= ФИОНаименование;
			Строка.Параметры.Адрес				= СокрЛП(СтрокаДанных.Адрес);
			Строка.Параметры.Страна				= Страна;
			Строка.Параметры.НДИНД				= СокрЛП(СтрокаДанных.НДИНД);
			Строка.Параметры.КодНРД				= СокрЛП(СтрокаДанных.КодНРД);
			Строка.Параметры.Статус				= СокрЛП(СтрокаДанных.Статус);
			Строка.Параметры.ДокументНомер		= СокрЛП(СтрокаДанных.ДокументНомер);
			Строка.Параметры.ДокументТип		= СокрЛП(СтрокаДанных.ДокументТип);
			Строка.Параметры.ДокументСтранаВыдачи = СокрЛП(СтрокаДанных.ДокументСтранаВыдачи);
			Строка.Параметры.ДокументОсновной	= СокрЛП(СтрокаДанных.ДокументОсновной);
			Строка.Параметры.НД					= СокрЛП(СтрокаДанных.НД);
			Строка.Параметры.ИНД				= СокрЛП(СтрокаДанных.ИНД);
			Строка.Параметры.Владелец			= СокрЛП(СтрокаДанных.Владелец);
			Строка.Параметры.ДУ					= СокрЛП(СтрокаДанных.ДУ);
			Строка.Параметры.ДП					= СокрЛП(СтрокаДанных.ДП);
			Если ПроверкаДанныхСтрокиУспешна(Строка) Тогда
				НаименованиеДляCSV = ФИОНаименование;
				НаименованиеДляCSV = СтрЗаменить(НаименованиеДляCSV, """", """""");
				НаименованиеДляCSV = """"+НаименованиеДляCSV+"""";
				ДокCSV.ДобавитьСтроку(""
				+ КодКлиента+";"
				+ НаименованиеДляCSV+";"
				+ СокрЛП(СтрокаДанных.Адрес)+";"
				+ Страна+";"
				+ СокрЛП(СтрокаДанных.НДИНД)+";"
				+ СокрЛП(СтрокаДанных.КодНРД)+";"
				+ СокрЛП(СтрокаДанных.Статус)+";"
				+ СокрЛП(СтрокаДанных.ДокументНомер)+";"
				+ СокрЛП(СтрокаДанных.ДокументТип)+";"
				+ СокрЛП(СтрокаДанных.ДокументСтранаВыдачи)+";"
				+ СокрЛП(СтрокаДанных.ДокументОсновной)+";"
				+ СокрЛП(СтрокаДанных.НД)+";"
				+ СокрЛП(СтрокаДанных.ИНД)+";"
				+ СокрЛП(СтрокаДанных.Владелец)+";"
				+ СокрЛП(СтрокаДанных.ДУ)+";"
				+ СокрЛП(СтрокаДанных.ДП)+";"
				+ СокрЛП(Строка.Параметры.Иной)+";"
				+";"
				+ СокрЛП(Строка.Параметры.ОбщедолевойВ)+";"
				+ СокрЛП(Строка.Параметры.ОбщедолевойД)+";"
				+ СокрЛП(Строка.Параметры.ОбщедолевойИ)
				+ ""
				);
			Иначе
				Строка.Области.Строка.ЦветФона	= WebЦвета.Коралловый;
			КонецЕсли;
			ТабДок.Вывести(Строка);
		КонецЦикла;
		// Настройки табличного документа
		ТабДок.АвтоМасштаб			= Истина;
		ТабДок.ТолькоПросмотр		= Истина;
		ТабДок.ОтображатьСетку		= Ложь;
		ТабДок.ОтображатьЗаголовки	= Ложь;
		
		ДанныеДляОтображения = Новый Соответствие;
		ДанныеДляОтображения.Вставить("ТабличныйДокумент"	, ТабДок);
		ДанныеДляОтображения.Вставить("CSV"					, ДокCSV);
		Возврат ДанныеДляОтображения;
	КонецЕсли;
	Возврат Неопределено;
КонецФункции

Функция Сформировать(Выгружать) Экспорт
	ДанныеДляОтображения	= ЗапросПоДаннымКлиентов();
	Если Не ДанныеДляОтображения = Неопределено Тогда
		Если Выгружать Тогда
			ДанныеДляОтображения.Получить("CSV").Записать(КаталогВыгрузки+"\"+"Данные о клиентах для WEB - "
				+ Формат(ДатаЗапроса, "ДФ=yyyyMMdd")+".csv", "windows-1251");
		КонецЕсли;
		Возврат ДанныеДляОтображения.Получить("ТабличныйДокумент");
	КонецЕсли;
	Возврат Новый ТабличныйДокумент;
КонецФункции

Функция КодНРДОрганизации(Организация)
	Запрос = Новый Запрос(
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	ЕСТЬNULL(КодыЗагрузки.Код, """") КАК Код
	|ИЗ
	|	Справочник.Организации КАК Организации
	|	ЛЕВОЕ СОЕДИНЕНИЕ Справочник.КодыЗагрузки КАК КодыЗагрузки
	|	ПО (КодыЗагрузки.Владелец = Организации.ЮридическоеЛицо)
	|		И ((ВЫРАЗИТЬ(КодыЗагрузки.Биржа КАК Справочник.КлассификаторыЗагрузки)) = &НДЦ)
	|		И (КодыЗагрузки.ДатаОкончанияДействия = ДАТАВРЕМЯ(1, 1, 1)
	|			ИЛИ КодыЗагрузки.ДатаОкончанияДействия > &ДатаСреза)
	|
	|ГДЕ
	|	Организации.Ссылка = &Организация");
	Запрос.УстановитьПараметр("НДЦ", Константы.КлассификаторЗагрузкиНДЦ.Получить());
	Запрос.УстановитьПараметр("ДатаСреза", ДатаЗапроса);
	Запрос.УстановитьПараметр("Организация", Организация);
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат СокрЛП(Выборка.Код);
	Иначе
		Возврат "";
	КонецЕсли;
КонецФункции

ОбщегоНазначения.ЛогироватьИспользованиеОбъекта(ЭтотОбъект);
