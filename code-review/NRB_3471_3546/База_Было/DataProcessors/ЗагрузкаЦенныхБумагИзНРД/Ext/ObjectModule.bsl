// ВСПОМОГАТЕЛЬНЫЕ ПРОЦЕДУРЫ И ФУНКЦИИ

Процедура ПрочитатьКупон(Элемент, code_nsd)
	
	СтрокаКупон = Купоны.Добавить();
	СтрокаКупон.code_nsd = code_nsd;
	ЗаполнитьЗначенияСвойств(СтрокаКупон, Элемент);
	
	ЗаполнитьXMLЗначениеСвойстваДаты(СтрокаКупон, Элемент, "payment_date_fact");
	
	ЗаполнитьXMLЗначениеСвойстваДаты(СтрокаКупон, Элемент, "payment_date_calc");
	ЗаполнитьXMLЗначениеСвойстваДаты(СтрокаКупон, Элемент, "payment_date_plan");
	
	ЗаполнитьXMLЗначениеСвойстваДаты(СтрокаКупон, Элемент, "record_date_calc");
	
	ЗаполнитьXMLЗначениеСвойстваДаты(СтрокаКупон, Элемент, "record_date_plan");
	
КонецПроцедуры

Процедура ЗаполнитьXMLЗначениеСвойстваДаты(Приемник, Источник, Имя)
	
	Если Источник.Свойства().Получить(Имя) <> Неопределено Тогда
		Приемник[Имя] = XMLЗначение(Тип("Дата"), Источник[Имя]);
	КонецЕсли;
	
КонецПроцедуры

Процедура ОчиститьПустоеСвойствоXDTO(Объект, ИмяСвойства)
	Свойство = Объект.Свойства().Получить(ИмяСвойства);
	Если Свойство <> Неопределено И ТипЗнч(Объект[ИмяСвойства]) = Тип("ОбъектXDTO") Тогда
		Объект[ИмяСвойства] = "";
	КонецЕсли;
КонецПроцедуры

// Возвращает Истина, если все поля из набора 1 равны соответствующим полям из набора 2, иначе Ложь
Функция ВсеЗначенияРавны(Набор1, Набор2, СписокПолей)
	Для Каждого Поле из СписокПолей Цикл
		Если ТипЗнч(Набор1[Поле]) <> ТипЗнч(Набор2[Поле]) Тогда
			ВызватьИсключение "Не совпадают типы сравниваемых полей """+Поле+""" "+ТипЗнч(Набор1[Поле])+" и "+ТипЗнч(Набор2[Поле]);
		КонецЕсли;
		
		Если ТипЗнч(Набор1[Поле]) = Тип("Строка") Тогда
			Если СокрЛП(Набор1[Поле]) <> СокрЛП(Набор2[Поле]) Тогда
				Возврат Ложь;
			КонецЕсли;
		ИначеЕсли Набор1[Поле] <> Набор2[Поле] Тогда
			Возврат Ложь;
		КонецЕсли;
	КонецЦикла;
	Возврат Истина;
КонецФункции

