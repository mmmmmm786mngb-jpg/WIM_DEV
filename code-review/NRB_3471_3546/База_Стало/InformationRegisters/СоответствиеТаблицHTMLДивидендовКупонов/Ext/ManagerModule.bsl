Функция СтолбецДивидендовКупонов(ДатаСреза, СтолбецHTML) Экспорт
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ДатаСреза",		ДатаСреза);
	Запрос.УстановитьПараметр("СтолбецHTML",	СтолбецHTML);
	Запрос.Текст =
	"ВЫБРАТЬ
	|	СоответствиеТаблиц.СтолбецДивидендовКупонов
	|ИЗ
	|	РегистрСведений.СоответствиеТаблицHTMLДивидендовКупонов.СрезПоследних(&ДатаСреза, СтолбецHTML = &СтолбецHTML) КАК СоответствиеТаблиц";
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Значение = Выборка.СтолбецДивидендовКупонов;
		Возврат Значение.Метаданные().ЗначенияПеречисления[Перечисления.СтолбцыДивидендовКупонов.Индекс(Значение)]["Имя"];
	Иначе
		Возврат Неопределено;
	КонецЕсли;
КонецФункции
