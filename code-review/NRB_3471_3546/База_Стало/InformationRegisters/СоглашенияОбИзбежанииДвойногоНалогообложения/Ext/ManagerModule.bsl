
#Область ПрограммныйИнтерфейс

// Возвращает действующие налоговые ставки для указанной страны на выбранную дату
//
// Параметры:
//  Дата	 - Дата									 - дата, на которую нужно получить ставки налога
//  Страна	 - СправочникСсылка.КлассификаторСтранМира	 - страна, для которой нужно получить ставки
// 
// Возвращаемое значение:
//  Структура - ставки налога для разных видов дохода
//
Функция ДействующиеНалоговыеСтавки(Дата, Страна) Экспорт
	
	НалоговыеСтавки = Новый Структура;
	НалоговыеСтавки.Вставить("СтавкаПоРеализации", 0);
	НалоговыеСтавки.Вставить("СтавкаПоКупонам", 0);
	НалоговыеСтавки.Вставить("СтавкаПоДивидендам", 0);
	НалоговыеСтавки.Вставить("СтавкаПоИнымДоходам", 0);
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Дата", Дата);
	Запрос.УстановитьПараметр("Страна", Страна);
	Запрос.Текст =
	"ВЫБРАТЬ
	|	СоглашенияОбИзбежанииДвойногоНалогообложенияСрезПоследних.СтавкаПоРеализации КАК СтавкаПоРеализации,
	|	СоглашенияОбИзбежанииДвойногоНалогообложенияСрезПоследних.СтавкаПоКупонам КАК СтавкаПоКупонам,
	|	СоглашенияОбИзбежанииДвойногоНалогообложенияСрезПоследних.СтавкаПоДивидендам КАК СтавкаПоДивидендам,
	|	СоглашенияОбИзбежанииДвойногоНалогообложенияСрезПоследних.СтавкаПоИнымДоходам КАК СтавкаПоИнымДоходам
	|ИЗ
	|	РегистрСведений.СоглашенияОбИзбежанииДвойногоНалогообложения.СрезПоследних(&Дата, Страна = &Страна) КАК СоглашенияОбИзбежанииДвойногоНалогообложенияСрезПоследних
	|ГДЕ
	|	СоглашенияОбИзбежанииДвойногоНалогообложенияСрезПоследних.ФлагАктивности";
	
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		ЗаполнитьЗначенияСвойств(НалоговыеСтавки, Выборка);
	КонецЕсли;
	
	Возврат НалоговыеСтавки;
	
КонецФункции

// Функция - Ставка по виду операции
//
// Параметры:
//  ВидОперации		 - СправочникСсылка.ВидыОпераций - Вид операции
//  НалоговыеСтавки	 - Структура					 - см. возвращаемое значение функции ДействующиеНалоговыеСтавки
// 
// Возвращаемое значение:
//   - Число - Ставка
//
Функция СтавкаПоВидуОперации(ВидОперации, НалоговыеСтавки) Экспорт
	
	Если ВидОперации = Справочники.ВидыОпераций.НачислениеДивидендов Тогда
		Возврат НалоговыеСтавки.СтавкаПоДивидендам;
	ИначеЕсли ВидОперации = Справочники.ВидыОпераций.Выкуп Или ВидОперации = Справочники.ВидыОпераций.ПогашениеНКД Тогда
		Возврат НалоговыеСтавки.СтавкаПоКупонам;
	ИначеЕсли ВидОперации = Справочники.ВидыОпераций.НачислениеДоходаПрочие Тогда
		Возврат НалоговыеСтавки.СтавкаПоИнымДоходам;
	Иначе
		Возврат НалоговыеСтавки.СтавкаПоРеализации;
	КонецЕсли;
	
КонецФункции

#КонецОбласти
