
// Добавляет сообщение в регистр
// Параметры:
//  ВнешнийИсточник - ПланВидовХарактеристик.ВнешниеИсточники - Внешний источник, по которому получено сообщение
//  Ключ - строка - Ключ сообщения JSON
//  Сообщение - строка - текст сообщения JSON
//  ВремяСообщения - строка - дата сообщения в формате "yyyyMMddHHmmss"
Процедура Добавить(ВнешнийИсточник, Ключ, Сообщение, ВремяСообщения) Экспорт
	Идентификатор = Строка(Новый УникальныйИдентификатор);
	Попытка
		Набор = НаборСОтбором(ВнешнийИсточник, Идентификатор);
		СообщениеВНаборе = Набор.Добавить();
		СообщениеВНаборе.ВнешнийИсточник = ВнешнийИсточник;
		СообщениеВНаборе.Идентификатор = Идентификатор;
		СообщениеВНаборе.Ключ = Ключ;
		СообщениеВНаборе.ТипСообщения = Кафка.ТипСообщенияИзКлючаСообщения(Ключ);
		СообщениеВНаборе.Сообщение = Сообщение;
		СообщениеВНаборе.ПериодСообщения = Дата(ВремяСообщения);
		Набор.Записать();
	Исключение
		ОписаниеОшибки = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		ЗаписьЖурналаРегистрации(
			"Чтение топика kafka " + ВнешнийИсточник,
			УровеньЖурналаРегистрации.Ошибка, , ,
			ОписаниеОшибки);
		ПолноеСообщениеKafka = ВремяСообщения + Символы.ПС + Ключ + Символы.ПС + Сообщение;
		РегистрыСведений.ОшибкиОнлайнЗагрузкиИзВнешнихИсточников.Добавить(ВнешнийИсточник, ПолноеСообщениеKafka);
	КонецПопытки;
КонецПроцедуры

Функция НаборСОтбором(ВнешнийИсточник, Идентификатор)
	Набор = РегистрыСведений.ЖурналВходящихСообщенийKafka.СоздатьНаборЗаписей();
	Набор.Отбор.ВнешнийИсточник.Установить(ВнешнийИсточник, Истина);
	Набор.Отбор.Идентификатор.Установить(Идентификатор, Истина);
	Возврат Набор;
КонецФункции

// Устанавливает флаг ОшибкаОбработки сообщению
// Параметры:
//  ВнешнийИсточник - ПланВидовХарактеристик.ВнешниеИсточники - Внешний источник, по которому поступило сообщение
//  Идентификатор - Строка - ГУИД сообщения
//  ОписаниеОшибки - Строка - Описание возникшей ошибки
Процедура ЗаписатьОшибку(ВнешнийИсточник, Идентификатор, ОписаниеОшибки) Экспорт
	Набор = НаборСОтбором(ВнешнийИсточник, Идентификатор);
	Набор.Прочитать();
	Если Набор.Количество() > 0 Тогда
		СообщениеСОшибкой = Набор[0];
		СообщениеСОшибкой.ОшибкаОбработки = Истина;
		СообщениеСОшибкой.ОписаниеОшибки = ОписаниеОшибки;
	Набор.Записать();
	КонецЕсли;
	
КонецПроцедуры

// Устанавливает флаг Обработан сообщению
// Параметры:
//  ВнешнийИсточник - ПланВидовХарактеристик.ВнешниеИсточники - Внешний источник, по которому поступило сообщение
//  Идентификатор - Строка - ГУИД сообщения
Процедура ЗавершитьОбработку(ВнешнийИсточник, Идентификатор) Экспорт
	Набор = НаборСОтбором(ВнешнийИсточник, Идентификатор);
	Набор.Прочитать();
	Если Набор.Количество() > 0 Тогда
		ОбработанноеСообщение = Набор[0];
		ОбработанноеСообщение.Обработан = Истина;
		ОбработанноеСообщение.ПериодОбработкиСообщения = ТекущаяДатаСеанса();
	Набор.Записать();
	КонецЕсли;
	
КонецПроцедуры