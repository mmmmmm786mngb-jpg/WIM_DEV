
Процедура УдалитьЗаписи(КД, ДоговорСубброкера) Экспорт
	НаборЗаписей = РегистрыСведений.ПодтвержденияСубброкераПоРСВ.СоздатьНаборЗаписей();
	НаборЗаписей.Отбор.КД.Установить(КД);
	НаборЗаписей.Отбор.ДоговорСубброкера.Установить(ДоговорСубброкера);
	НаборЗаписей.Записать();
КонецПроцедуры

Процедура ДобавитьЗапись(КД, ПоляПодтверждения) Экспорт
	Запись = РегистрыСведений.ПодтвержденияСубброкераПоРСВ.СоздатьМенеджерЗаписи();
	ЗаполнитьЗначенияСвойств(Запись, ПоляПодтверждения);
	Запись.КД = КД;
	Запись.Записать();
КонецПроцедуры

Функция ПолученыПодтвержденияПоВсемСубброкерам(КД, ДоговорыДокумента) Экспорт
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	ТЗ.Договор КАК Договор
	|ПОМЕСТИТЬ втДоговорыДокумента
	|ИЗ
	|	&ТЗ КАК ТЗ
	|;
	|
	|///////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Подтверждения.ДоговорСубброкера КАК Договор
	|ПОМЕСТИТЬ втПодтвержденныеДоговоры
	|ИЗ
	|	РегистрСведений.ПодтвержденияСубброкераПоРСВ КАК Подтверждения
	|ГДЕ
	|	Подтверждения.КД = &КД
	|;
	|
	|///////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ДоговорыДокумента.Договор КАК Договор
	|ИЗ
	|	втДоговорыДокумента КАК ДоговорыДокумента
	|
	|	ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ДоговорыКонтрагентов КАК ДоговорыКонтрагентов
	|	ПО
	|		ДоговорыКонтрагентов.Ссылка = ДоговорыДокумента.Договор
	|
	|	ЛЕВОЕ СОЕДИНЕНИЕ втПодтвержденныеДоговоры КАК ПодтвержденныеДоговоры
	|	ПО
	|		ДоговорыДокумента.Договор = ПодтвержденныеДоговоры.Договор
	|
	|ГДЕ
	|	ДоговорыКонтрагентов.Владелец.Субброкер
	|	И ПодтвержденныеДоговоры.Договор ЕСТЬ NULL
	|");
	Запрос.УстановитьПараметр("ТЗ", ДоговорыДокумента);
	Запрос.УстановитьПараметр("КД", КД);
	Возврат Запрос.Выполнить().Пустой();
КонецФункции

Функция ДанныеПоНалогам(КД, ЦеннаяБумага, СчетДепо, РазделСчетаДепо) Экспорт
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	Подтверждения.Количество КАК Количество,
	|	Подтверждения.СтатусНалогоплательщика КАК СтатусНалогоплательщика,
	|	Подтверждения.НаличиеНалоговыхЛьгот КАК НаличиеНалоговыхЛьгот,
	|	Подтверждения.НалоговаяСтавка КАК НалоговаяСтавка
	|ИЗ
	|	РегистрСведений.ПодтвержденияСубброкераПоРСВ КАК Подтверждения
	|ГДЕ
	|	Подтверждения.КД = &КД
	|	И Подтверждения.ДоговорСубброкера.Владелец = &Депонент
	|	И Подтверждения.СчетДепо = &СчетДепо
	|	И Подтверждения.Субклиент = &Субклиент
	|	И Подтверждения.ЦеннаяБумага = &ЦеннаяБумага");
	Запрос.УстановитьПараметр("КД", КД);
	Запрос.УстановитьПараметр("Депонент", СчетДепо.Владелец);
	Запрос.УстановитьПараметр("СчетДепо", СчетДепо);
	Запрос.УстановитьПараметр("Субклиент", РазделСчетаДепо.Субклиент);
	Запрос.УстановитьПараметр("ЦеннаяБумага", ЦеннаяБумага);
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Результат = Новый Структура("Количество, СтатусНалогоплательщика, НаличиеНалоговыхЛьгот, НалоговаяСтавка");
		ЗаполнитьЗначенияСвойств(Результат, Выборка);
	Иначе
		Результат = Неопределено;
	КонецЕсли;
	Возврат Результат;
КонецФункции
