
// Добавляет сообщение в регистр
// Параметры:
//  ВнешнийИсточник - ПланВидовХарактеристик.ВнешниеИсточники - Внешний источник, по которому будет отправлено сообщение в Kafka
//  КлючИзJSON - строка - Ключ сообщения JSON
//  Сообщение - строка - текст сообщения JSON
//  Идентификатор - строка - ручной ГУИД сообщения в РС
//  ОтправляемыйОбъект - Ссылка - ссылка выгружаемого объекта
Процедура Добавить(ВнешнийИсточник, КлючИзJSON, Сообщение, Идентификатор = Неопределено, ОтправляемыйОбъект = Неопределено) Экспорт
	Если Идентификатор = Неопределено Тогда
		Идентификатор = Строка(Новый УникальныйИдентификатор);
	КонецЕсли;
	Ключ = КлючИзJSON + ":" + Идентификатор;
	
	Набор = НаборСОтбором(ВнешнийИсточник, Идентификатор);
	СообщениеВНаборе = Набор.Добавить();
	СообщениеВНаборе.ВнешнийИсточник = ВнешнийИсточник;
	СообщениеВНаборе.Идентификатор = Идентификатор;
	СообщениеВНаборе.Ключ = Ключ;
	СообщениеВНаборе.ТипСообщения = КлючИзJSON;
	СообщениеВНаборе.Сообщение = Сообщение;
	СообщениеВНаборе.ОтправляемыйОбъект = ОтправляемыйОбъект;
	СообщениеВНаборе.ПериодСообщения = ТекущаяДатаСеанса();
	
	// Ограничения по длине ключа сообщения самой Кафки не существенны - так ограничение состоит в том что, длина ключа + длина служебных
	// атрибутов + длина самого сообщения не должны превысть максимальной длины сообщения, определенной настройками брокера Kafka
	// Однако тип ресурса "ключ" в этом регистре - строка длиной 100, так что больше 100 символов не влезет
	МаксимальнаяДлинаСтрокиВРесурсеКлюч = 100;
	Если СтрДлина(Ключ) > МаксимальнаяДлинаСтрокиВРесурсеКлюч Тогда
		СообщениеВНаборе.ОшибкаОтправки = Истина;
		СообщениеВНаборе.ОписаниеОшибки = "Длина ключа сообщения больше 100 символов";
	КонецЕсли;
		
	Набор.Записать();
КонецПроцедуры

Функция НаборСОтбором(ВнешнийИсточник, Идентификатор)
	Набор = РегистрыСведений.ЖурналИсходящихСообщенийKafka.СоздатьНаборЗаписей();
	Набор.Отбор.ВнешнийИсточник.Установить(ВнешнийИсточник, Истина);
	Набор.Отбор.Идентификатор.Установить(Идентификатор, Истина);
	Возврат Набор;
КонецФункции

// Отправляет сообщения из регистра в Kafka
// Параметры:
// КоличествоСообщенийКОтправке - Число - количество сообщений которые могут быть отправлены пр изапуске рег. задания
// УсловиеОтбораСообщений - Текст - Произвольное условие для отбора сообщений
Процедура ОтправитьСообщениеИсходящее(КоличествоСообщенийКОтправке = Неопределено, УсловиеОтбораСообщений = "") Экспорт
	
	ДанныеОтправкиСообщения = ДанныеКОтправке(КоличествоСообщенийКОтправке, УсловиеОтбораСообщений);
	Пока ДанныеОтправкиСообщения.Следующий() Цикл
		Если Не ЗаполненыКлючевыеПоля(ДанныеОтправкиСообщения) Тогда
			Продолжить;
		КонецЕсли;
		КафкаКлиент = Обработки.KafkaClient.Создать();
		Ответ = КафкаКлиент.РезультатОтправкиСообщенияПоВнешнемуИсточнику(ДанныеОтправкиСообщения);
		ЗафиксироватьРезультатОтправки(ДанныеОтправкиСообщения, Ответ);
	КонецЦикла;
	
КонецПроцедуры

Функция ДанныеКОтправке(КоличествоСообщенийКОтправке, УсловиеОтбораСообщений)
	ТекстЗапроса = 
	"ВЫБРАТЬ
	|	ЖурналИсходящихСообщенийKafka.ВнешнийИсточник КАК ВнешнийИсточник,
	|	ЖурналИсходящихСообщенийKafka.Идентификатор КАК Идентификатор,
	|	ЖурналИсходящихСообщенийKafka.Ключ КАК Ключ,
	|	ЖурналИсходящихСообщенийKafka.Сообщение КАК Сообщение
	|ИЗ
	|	РегистрСведений.ЖурналИсходящихСообщенийKafka КАК ЖурналИсходящихСообщенийKafka
	|ГДЕ
	|	НЕ ЖурналИсходящихСообщенийKafka.Отправлено
	|	И НЕ ЖурналИсходящихСообщенийKafka.ОшибкаОтправки
	|	&УсловиеОтбораСообщений
	|
	|УПОРЯДОЧИТЬ ПО
	|	ЖурналИсходящихСообщенийKafka.ПериодСообщения";
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&УсловиеОтбораСообщений", УсловиеОтбораСообщений);
	Если ЗначениеЗаполнено(КоличествоСообщенийКОтправке) Тогда
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "ВЫБРАТЬ", "ВЫБРАТЬ ПЕРВЫЕ " + Строка(КоличествоСообщенийКОтправке));
	КонецЕсли;
	Запрос = Новый Запрос;
	Запрос.Текст = ТекстЗапроса;
	Возврат Запрос.Выполнить().Выбрать();
КонецФункции

Процедура ЗафиксироватьРезультатОтправки(ДанныеОтправкиСообщения, Ответ)
	Набор = НаборСОтбором(ДанныеОтправкиСообщения.ВнешнийИсточник, ДанныеОтправкиСообщения.Идентификатор);
	Набор.Прочитать();
	ДатаОтправки = ТекущаяДатаСеанса();
	Если Ответ = "Persisted" Тогда
		Набор[0].Отправлено = Истина;
		Набор[0].ПериодОтправкиСообщения = ДатаОтправки;
	Иначе
		Набор[0].ОшибкаОтправки = Истина;
		Набор[0].ОписаниеОшибки = Ответ;
		Набор[0].ПериодОтправкиСообщения = ДатаОтправки;
	КонецЕсли;
	Набор.Записать();
	
КонецПроцедуры

Функция ЗаполненыКлючевыеПоля(ДанныеОтправкиСообщения)
	ПоляЗаполнены = ЗначениеЗаполнено(ДанныеОтправкиСообщения.ВнешнийИсточник)
		И ЗначениеЗаполнено(ДанныеОтправкиСообщения.Идентификатор)
		И ЗначениеЗаполнено(ДанныеОтправкиСообщения.Ключ)
		И ЗначениеЗаполнено(ДанныеОтправкиСообщения.Сообщение);
	Возврат ПоляЗаполнены;
КонецФункции