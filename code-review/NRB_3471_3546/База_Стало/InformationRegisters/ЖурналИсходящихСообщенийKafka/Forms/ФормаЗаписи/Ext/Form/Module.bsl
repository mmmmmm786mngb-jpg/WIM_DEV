
&НаКлиенте
Процедура ПриОткрытии(Отказ)
	УправлениеВидимостью();
КонецПроцедуры

&НаКлиенте
Процедура ОшибкаОтправкиПриИзменении(Элемент)
	УправлениеВидимостью();
КонецПроцедуры

&НаКлиенте
Процедура УправлениеВидимостью()
	Элементы.ОписаниеОшибки.Видимость = Запись.ОшибкаОтправки;	
КонецПроцедуры

&НаКлиенте
Процедура ОтправитьСообщение(Команда)
	ОтправитьСообщениеНаСервере();
КонецПроцедуры

&НаСервере
Процедура ОтправитьСообщениеНаСервере()
	
	КафкаКлиент = Обработки.KafkaClient.Создать();
	Ответ = КафкаКлиент.РезультатОтправкиСообщенияПоВнешнемуИсточнику(Запись);
	ДатаОтправки = ТекущаяДатаСеанса();
	Если Ответ = "Persisted" Тогда
		Запись.Отправлено = Истина;
		Запись.ПериодОтправкиСообщения = ДатаОтправки;
	Иначе
		Запись.ОшибкаОтправки = Истина;
		Запись.ОписаниеОшибки = Ответ;
		Запись.ПериодОтправкиСообщения = ДатаОтправки;
	КонецЕсли;
	Записать();

КонецПроцедуры

&НаКлиенте
Процедура ОткрытьJSON(Команда)
	ПараметрыОткрытия = Новый Структура("СтрокаJSON", Запись.Сообщение);
	ОткрытьФорму("Обработка.ПросмотрJSON.Форма.Форма",
		ПараметрыОткрытия, ЭтотОбъект, , , , , РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
КонецПроцедуры
