&НаКлиенте
Процедура ОтправленныеУведомления(Команда)
	Если Элементы.Список.ТекущиеДанные.ЭтапКД.Код = "NOTE" Тогда
		Парам = Новый Структура;
		Парам.Вставить("КД", Элементы.Список.ТекущиеДанные.КД); 
		Парам.Вставить("ДатаСообщения", Элементы.Список.ТекущиеДанные.Период); 
		ОткрытьФорму("РегистрСведений.УведомленияОтправленныеЧерезЛичныйКабинет.ФормаСписка", Парам);
	КонецЕсли;
КонецПроцедуры
