
Процедура УдалитьЗаписиЗаПериод(НачалоПериода, КонецПериода) Экспорт
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	ЖурналИсходящихДокументов.Период
	|ИЗ
	|	РегистрСведений.ЖурналИсходящихДокументов КАК ЖурналИсходящихДокументов
	|ГДЕ
	|	ЖурналИсходящихДокументов.Период МЕЖДУ &НачалоПериода И &КонецПериода
	|
	|СГРУППИРОВАТЬ ПО
	|	ЖурналИсходящихДокументов.Период");
	Запрос.УстановитьПараметр("НачалоПериода",	НачалоПериода);
	Запрос.УстановитьПараметр("КонецПериода",	КонецПериода);
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		НаборЗаписей = РегистрыСведений.ЖурналИсходящихДокументов.СоздатьНаборЗаписей();
		НаборЗаписей.Отбор.Период.Установить(Выборка.Период);
		НаборЗаписей.Записать();
	КонецЦикла;
КонецПроцедуры
