
// Удаляет записи регистра с отбором Период+КД
// Добавляет в регистр по одной записи на каждую строку таблицы Клиенты
//
// Параметры:
//	ПериодЗаписи - дата
//	КД - ссылка на док.УведомлениеКлиентам, док. КорпоративноеДействие_Новый, док.РаскрытиеСпискаВладельцев, задача ОбработкаWTRCСообщения
//	Клиенты - таблица значений с полями: Клиент, Договор, СчетДепо, РазделСчетаДепо, ЦеннаяБумага, Количество
//
Процедура ЗафиксироватьУведомления(ПериодЗаписи, КД, Клиенты) Экспорт
	НаборЗаписей = РегистрыСведений.УведомленияОтправленныеЧерезЛичныйКабинет.СоздатьНаборЗаписей();
	НаборЗаписей.Отбор.Период.Установить(ПериодЗаписи);
	НаборЗаписей.Отбор.КД.Установить(КД);
	НаборЗаписей.Записать(); // Удалить старые записи
	
	// Добавить клиентов из списка
	Для Каждого Строка из Клиенты Цикл
		НоваяЗапись = НаборЗаписей.Добавить();
		НоваяЗапись.Период = ПериодЗаписи;
		НоваяЗапись.КД = КД;
		НоваяЗапись.СтатусДоставкиУведомления = Перечисления.СтатусыДоставкиУведомленийВКабинетКлиента.ВыгруженИз1С;
		НоваяЗапись.ИдентификаторУведомления = Строка.MessageId;
		ЗаполнитьЗначенияСвойств(НоваяЗапись, Строка);
	КонецЦикла;
	НаборЗаписей.Записать();
КонецПроцедуры

// Добавляет в регистр по одной записи на каждую строку таблицы Клиенты
//
// Параметры:
//	ПериодЗаписи - дата
//	КД - ссылка на док.УведомлениеКлиентам, док. КорпоративноеДействие_Новый, док.РаскрытиеСпискаВладельцев, задача ОбработкаWTRCСообщения
//	Клиенты - таблица значений с полями: Клиент, Договор, СчетДепо, РазделСчетаДепо, ЦеннаяБумага, Количество
//
Процедура ДобавитьКлиентов(ПериодЗаписи, КД, Клиенты) Экспорт
	
	Для Каждого Строка из Клиенты Цикл
		НоваяЗапись = РегистрыСведений.УведомленияОтправленныеЧерезЛичныйКабинет.СоздатьМенеджерЗаписи();
		НоваяЗапись.Период	= ПериодЗаписи;
		НоваяЗапись.КД		= КД;
		НоваяЗапись.СтатусДоставкиУведомления = Перечисления.СтатусыДоставкиУведомленийВКабинетКлиента.ВыгруженИз1С;
		ЗаполнитьЗначенияСвойств(НоваяЗапись, Строка);
		НоваяЗапись.Записать();
	КонецЦикла;
КонецПроцедуры

// Получает клиентов, имеющих на указанную дату ценные бумаги ЦеннаяБумага1 или ЦеннаяБумага2
//
// Параметры:
//	ДатаОстатков - дата
//	ЦеннаяБумага1, ЦеннаяБумага2 - СправочникСсылка.ЦенныеБумаги
//
// Возвращаемое значение:
//	таблица значений
Функция КлиентыИмеющиеЦенныеБумаги(ДатаОстатков, ЦеннаяБумага1, ЦеннаяБумага2, СчетДепоМХ) Экспорт
	СписокЦБ = Новый Массив;
	Если ЗначениеЗаполнено(ЦеннаяБумага1) Тогда
		СписокЦБ.Добавить(ЦеннаяБумага1);
	КонецЕсли;
	Если ЗначениеЗаполнено(ЦеннаяБумага2) Тогда
		СписокЦБ.Добавить(ЦеннаяБумага2);
	КонецЕсли;
	
	Возврат КлиентыИмеющиеЦенныеБумагиИзСписка(ДатаОстатков, СписокЦБ, СчетДепоМХ);
КонецФункции

// Получает клиентов, имеющих на указанную дату ценные бумаги из списка
//
// Параметры:
//	ДатаОстатков - дата
//	СписокЦенныхБумаг - массив значений СправочникСсылка.ЦенныеБумаги
//
// Возвращаемое значение:
//	таблица значений
Функция КлиентыИмеющиеЦенныеБумагиИзСписка(ДатаОстатков, СписокЦенныхБумаг, СчетДепоМХ) Экспорт
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	ОстаткиЦБОстатки.СчетДепо.Владелец КАК Клиент,
	|	Договоры.Ссылка КАК Договор,
	|	ОстаткиЦБОстатки.СчетДепо КАК СчетДепо,
	|	ОстаткиЦБОстатки.ЦБ КАК ЦеннаяБумага,
	|	ОстаткиЦБОстатки.КоличествоОстаток КАК Количество,
	|	ЕСТЬNULL(Договоры.ДатаНачалоДействия, ДАТАВРЕМЯ(1, 1, 1)) КАК ДатаДоговора,
	|	ЕСТЬNULL(Договоры.Наименование, """") КАК НомерДоговора
	|ПОМЕСТИТЬ ВТ_ОстаткиЦБ
	|ИЗ
	|	РегистрНакопления.ОстаткиЦБ.Остатки(
	|			&ДатаОстатков,
	|			ЦБ В (&СписокЦБ)
	|				И СчетДепоМХ = &СчетДепоМХ) КАК ОстаткиЦБОстатки
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ДоговорыКонтрагентов КАК Договоры
	|		ПО ОстаткиЦБОстатки.СчетДепо.Владелец = Договоры.Владелец
	|			И ОстаткиЦБОстатки.СчетДепо.Владелец.Код = Договоры.Код
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_ОстаткиЦБ.Клиент КАК Клиент,
	|	ВТ_ОстаткиЦБ.Договор КАК Договор,
	|	ВТ_ОстаткиЦБ.СчетДепо КАК СчетДепо,
	|	ЗНАЧЕНИЕ(Справочник.РазделыСчетаДепо.ПустаяСсылка) КАК РазделСчетаДепо,
	|	ВТ_ОстаткиЦБ.ЦеннаяБумага КАК ЦеннаяБумага,
	|	ВТ_ОстаткиЦБ.Количество КАК Количество,
	|	КодыЗагрузки.Код КАК ClientId,
	|	ВЫБОР
	|		КОГДА КодыЗагрузки.Ссылка ЕСТЬ NULL
	|			ТОГДА ЛОЖЬ
	|		ИНАЧЕ ИСТИНА
	|	КОНЕЦ КАК ЕстьКодЗагрузкиКлиенты,
	|	ВЫБОР
	|		КОГДА ВТ_ОстаткиЦБ.Клиент.ЮрФизЛицо = ЗНАЧЕНИЕ(Перечисление.ЮрФизЛицо.ФизЛицо)
	|			ТОГДА ""физ""
	|		ИНАЧЕ ""юр""
	|	КОНЕЦ КАК ЮрФизЛицо,
	|	ВТ_ОстаткиЦБ.Клиент.Наименование КАК КлиентНаименование,
	|	ВТ_ОстаткиЦБ.ДатаДоговора КАК ДатаДоговора,
	|	ВТ_ОстаткиЦБ.НомерДоговора КАК НомерДоговора,
	|	ВЫБОР
	|		КОГДА Контрагенты.ЮридическиеФизическиеЛица ССЫЛКА Справочник.ФизическиеЛица
	|			ТОГДА ЕСТЬNULL(ФИОФизЛицСрезПоследних.Фамилия, """")
	|		ИНАЧЕ ""клиент""
	|	КОНЕЦ КАК Фамилия,
	|	ВЫБОР
	|		КОГДА Контрагенты.ЮридическиеФизическиеЛица ССЫЛКА Справочник.ФизическиеЛица
	|			ТОГДА ЕСТЬNULL(ФИОФизЛицСрезПоследних.Имя, """")
	|		ИНАЧЕ Контрагенты.Наименование
	|	КОНЕЦ КАК Имя,
	|	ВТ_ОстаткиЦБ.Клиент.Субброкер КАК Субброкер
	|ИЗ
	|	ВТ_ОстаткиЦБ КАК ВТ_ОстаткиЦБ
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Контрагенты КАК Контрагенты
	|			ЛЕВОЕ СОЕДИНЕНИЕ Справочник.КодыЗагрузки КАК КодыЗагрузки
	|			ПО Контрагенты.ЮридическиеФизическиеЛица = КодыЗагрузки.Владелец
	|				И (КодыЗагрузки.Биржа = &КлассификаторыЗагрузкиКлиенты)
	|				И (НЕ КодыЗагрузки.ПометкаУдаления)
	|				И (КодыЗагрузки.ДатаНачалаДействия <= &ДатаОстатка)
	|				И (КодыЗагрузки.ДатаОкончанияДействия = ДАТАВРЕМЯ(1, 1, 1)
	|					ИЛИ КодыЗагрузки.ДатаОкончанияДействия >= &ДатаОстатка)
	|		ПО ВТ_ОстаткиЦБ.СчетДепо.Владелец = Контрагенты.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ФИОФизЛиц.СрезПоследних(
	|				,
	|				ФизЛицо В
	|					(ВЫБРАТЬ
	|						ВТ_ОстаткиЦБ.Клиент.ЮридическиеФизическиеЛица КАК КлиентЮридическиеФизическиеЛица
	|					ИЗ
	|						ВТ_ОстаткиЦБ КАК ВТ_ОстаткиЦБ)) КАК ФИОФизЛицСрезПоследних
	|		ПО ВТ_ОстаткиЦБ.Клиент.ЮридическиеФизическиеЛица = ФИОФизЛицСрезПоследних.ФизЛицо");
	Запрос.УстановитьПараметр("ДатаОстатков",	ДатаОстатков);
	Запрос.УстановитьПараметр("СписокЦБ",		СписокЦенныхБумаг);
	Запрос.УстановитьПараметр("СчетДепоМХ",		СчетДепоМХ);
	Запрос.УстановитьПараметр("КлассификаторыЗагрузкиКлиенты", Справочники.КлассификаторыЗагрузки.Клиенты);
	Если ТипЗнч(ДатаОстатков) = Тип("Граница") Тогда
		Запрос.УстановитьПараметр("ДатаОстатка", ДатаОстатков.Значение);
	Иначе
		Запрос.УстановитьПараметр("ДатаОстатка", ДатаОстатков);
	КонецЕсли;
	Возврат Запрос.Выполнить().Выгрузить();
КонецФункции

// Получает клиентов которые не являются НД или ИНД, имеющих на указанную дату ценные бумаги из списка
//
// Параметры:
//	ДатаОстатков - дата
//	СписокЦенныхБумаг - массив значений СправочникСсылка.ЦенныеБумаги
//
// Возвращаемое значение:
//	таблица значений
Функция КлиентыНеНДИНДИмеющиеЦенныеБумагиИзСписка(ДатаОстатков, СписокЦенныхБумаг, СчетДепоМХ) Экспорт
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	ОстаткиЦБОстатки.СчетДепо.Владелец КАК Клиент,
	|	Договоры.Ссылка КАК Договор,
	|	ОстаткиЦБОстатки.СчетДепо КАК СчетДепо,
	//|	ОстаткиЦБОстатки.РазделСчетаДепо КАК РазделСчетаДепо,
	|	ОстаткиЦБОстатки.ЦБ КАК ЦеннаяБумага,
	|	ОстаткиЦБОстатки.КоличествоОстаток КАК Количество,
	|	КодыЗагрузкиКлиента.Код КАК ClientId
	|ИЗ
	|	РегистрНакопления.ОстаткиЦБ.Остатки(
	|			&ДатаОстатков,
	|			ЦБ В (&СписокЦБ)
	|				И СчетДепоМХ = &СчетДепоМХ
	|				И НЕ СчетДепо.ТипСчетаДепо В (&ТипыСчетаДепоНДИНД)) КАК ОстаткиЦБОстатки
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ДоговорыКонтрагентов КАК Договоры
	|		ПО ОстаткиЦБОстатки.СчетДепо.Владелец = Договоры.Владелец
	|			И ОстаткиЦБОстатки.СчетДепо.Владелец.Код = Договоры.Код
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.КодыЗагрузки КАК КодыЗагрузкиКлиента
	|		ПО ОстаткиЦБОстатки.СчетДепо.Владелец = КодыЗагрузкиКлиента.Владелец
	|			И (НЕ КодыЗагрузкиКлиента.ПометкаУдаления)
	|			И (КодыЗагрузкиКлиента.Биржа = &КлассификаторыЗагрузкиКлиенты)");
	Запрос.УстановитьПараметр("ДатаОстатков",	ДатаОстатков);
	Запрос.УстановитьПараметр("СписокЦБ",		СписокЦенныхБумаг);
	Запрос.УстановитьПараметр("СчетДепоМХ",		СчетДепоМХ);
	Запрос.УстановитьПараметр("КлассификаторыЗагрузкиКлиенты", Справочники.КлассификаторыЗагрузки.Клиенты);
	Запрос.УстановитьПараметр("ТипыСчетаДепоНДИНД",		БизнесПроцессы.ОбработкаWTRCСообщения.ТипыСчетовНДИНД());

	Возврат Запрос.Выполнить().Выгрузить();
КонецФункции

