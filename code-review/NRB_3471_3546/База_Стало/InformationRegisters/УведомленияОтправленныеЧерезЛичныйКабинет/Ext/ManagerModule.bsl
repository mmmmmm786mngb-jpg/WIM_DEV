// Устанавливает новый статус доставки для записей с указанным отбором
//
// Параметры:
//	ДокументУведомления - ссылка на документ УведомлениеКлиентам для отбора записей
//	Клиент - ссылка на спр. Контрагенты для отбора записей
//	СтатусДоставки - перечисление СтатусыДоставкиУведомленийВКабинетКлиента для отбора записей
//	НовыйСтатусДоставки - перечисление СтатусыДоставкиУведомленийВКабинетКлиента для установки
Процедура УстановитьСтатусДоставки(ДокументУведомления, Клиент, СтатусДоставки, НовыйСтатусДоставки) Экспорт
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	РегистрУведомлений.Период КАК Период,
	|	РегистрУведомлений.КД КАК КД,
	|	РегистрУведомлений.Клиент КАК Клиент,
	|	РегистрУведомлений.Договор КАК Договор,
	|	РегистрУведомлений.СчетДепо КАК СчетДепо,
	|	РегистрУведомлений.РазделСчетаДепо КАК РазделСчетаДепо,
	|	РегистрУведомлений.ЦеннаяБумага КАК ЦеннаяБумага,
	|	РегистрУведомлений.Количество КАК Количество,
	|	РегистрУведомлений.ИдентификаторУведомления КАК ИдентификаторУведомления
	|ИЗ
	|	РегистрСведений.УведомленияОтправленныеЧерезЛичныйКабинет КАК РегистрУведомлений
	|ГДЕ
	|	(РегистрУведомлений.КД = &ДокументУведомления
	|				И РегистрУведомлений.Клиент = &Клиент
	|				И РегистрУведомлений.СтатусДоставкиУведомления = &СтатусДоставки
	|				И (РегистрУведомлений.КД ССЫЛКА Документ.УведомлениеКлиентам
	|					ИЛИ РегистрУведомлений.КД ССЫЛКА Документ.Поручение)
	|			ИЛИ РегистрУведомлений.КД ССЫЛКА Документ.ЗаявлениеНаУчастиеВОферте)
	|
	|ДЛЯ ИЗМЕНЕНИЯ
	|	РегистрСведений.УведомленияОтправленныеЧерезЛичныйКабинет");
	Запрос.УстановитьПараметр("ДокументУведомления", ДокументУведомления);
	Запрос.УстановитьПараметр("Клиент", Клиент);
	Запрос.УстановитьПараметр("СтатусДоставки", СтатусДоставки);
	
	НачатьТранзакцию();
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		МЗ = РегистрыСведений.УведомленияОтправленныеЧерезЛичныйКабинет.СоздатьМенеджерЗаписи();
