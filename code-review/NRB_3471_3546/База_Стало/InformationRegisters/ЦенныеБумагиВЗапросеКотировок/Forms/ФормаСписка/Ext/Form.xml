	<Attributes>
		<Attribute name="Список" id="1">
			<Type>
				<v8:Type>cfg:DynamicList</v8:Type>
			</Type>
			<MainAttribute>true</MainAttribute>
			<Settings xsi:type="DynamicList">
				<ManualQuery>true</ManualQuery>
				<DynamicDataRead>true</DynamicDataRead>
				<QueryText>ВЫБРАТЬ
	РегистрСведенийЦенныеБумагиВЗапросеКотировок.ЦеннаяБумага КАК ЦеннаяБумага
ПОМЕСТИТЬ ЦенныеБумаги
ИЗ
	РегистрСведений.ЦенныеБумагиВЗапросеКотировок КАК РегистрСведенийЦенныеБумагиВЗапросеКотировок
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	ВЫБОР
		КОГДА РегистрСведенийЦенныеБумагиВЗапросеКотировок.ЦеннаяБумага.ТипЦБ = ЗНАЧЕНИЕ(Перечисление.ТипыЦБ.Облигация)
			ТОГДА КОЛИЧЕСТВО(РАЗЛИЧНЫЕ РегистрСведенийЦенныеБумагиВЗапросеКотировок.ISIN)
		ИНАЧЕ 0
	КОНЕЦ КАК КоличествоОблигаций,
	ВЫБОР
		КОГДА РегистрСведенийЦенныеБумагиВЗапросеКотировок.ЦеннаяБумага.ТипЦБ = ЗНАЧЕНИЕ(Перечисление.ТипыЦБ.Облигация)
				И (НЕ ВЫБОР
							КОГДА РегистрСведенийЦенныеБумагиВЗапросеКотировок.ЦеннаяБумага.ДатаСнятияСОбслуживания = ДАТАВРЕМЯ(1, 1, 1, 0, 0, 0)
								ТОГДА ИСТИНА
							ИНАЧЕ РегистрСведенийЦенныеБумагиВЗапросеКотировок.ЦеннаяБумага.ДатаСнятияСОбслуживания &gt;= &amp;Период
						КОНЕЦ
					ИЛИ НЕ ВЫБОР
							КОГДА РегистрСведенийЦенныеБумагиВЗапросеКотировок.ЦеннаяБумага.ДатаПогашения = ДАТАВРЕМЯ(1, 1, 1, 0, 0, 0)
								ТОГДА ИСТИНА
							ИНАЧЕ РегистрСведенийЦенныеБумагиВЗапросеКотировок.ЦеннаяБумага.ДатаПогашения &gt;= &amp;Период
						КОНЕЦ)
			ТОГДА КОЛИЧЕСТВО(РАЗЛИЧНЫЕ РегистрСведенийЦенныеБумагиВЗапросеКотировок.ISIN)
		ИНАЧЕ 0
	КОНЕЦ КАК КоличествоОблигацийНеактуальных,
	ВЫБОР
		КОГДА РегистрСведенийЦенныеБумагиВЗапросеКотировок.ЦеннаяБумага.ТипЦБ = ЗНАЧЕНИЕ(Перечисление.ТипыЦБ.Облигация)
			ТОГДА 0
		ИНАЧЕ КОЛИЧЕСТВО(РАЗЛИЧНЫЕ РегистрСведенийЦенныеБумагиВЗапросеКотировок.ISIN)
	КОНЕЦ КАК КоличествоПрочихЦенныхБумаг
ПОМЕСТИТЬ ОБЩИЕИТОГИПоТипам
ИЗ
	РегистрСведений.ЦенныеБумагиВЗапросеКотировок КАК РегистрСведенийЦенныеБумагиВЗапросеКотировок

СГРУППИРОВАТЬ ПО
	РегистрСведенийЦенныеБумагиВЗапросеКотировок.ЦеннаяБумага,
	РегистрСведенийЦенныеБумагиВЗапросеКотировок.ЦеннаяБумага.ТипЦБ,
	РегистрСведенийЦенныеБумагиВЗапросеКотировок.ЦеннаяБумага.ДатаСнятияСОбслуживания,
	РегистрСведенийЦенныеБумагиВЗапросеКотировок.ЦеннаяБумага.ДатаПогашения
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ ПЕРВЫЕ 1
	СУММА(ОБЩИЕИТОГИПоТипам.КоличествоОблигаций + ОБЩИЕИТОГИПоТипам.КоличествоПрочихЦенныхБумаг) КАК ИтогоВСписке,
	СУММА(ОБЩИЕИТОГИПоТипам.КоличествоОблигаций) КАК КоличествоОблигаций,
	СУММА(ОБЩИЕИТОГИПоТипам.КоличествоОблигацийНеактуальных) КАК КоличествоОблигацийНеактуальных,
	СУММА(ОБЩИЕИТОГИПоТипам.КоличествоПрочихЦенныхБумаг) КАК КоличествоПрочихЦенныхБумаг
ПОМЕСТИТЬ ОБЩИЕИТОГИ
ИЗ
	ОБЩИЕИТОГИПоТипам КАК ОБЩИЕИТОГИПоТипам
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	ОстаткиЦБОстатки.ЦБ КАК ЦБ,
	СУММА(ОстаткиЦБОстатки.КоличествоОстаток) КАК КоличествоОстаток
ПОМЕСТИТЬ Остатки
ИЗ
	РегистрНакопления.ОстаткиЦБ.Остатки(
			,
			ЦБ В
				(ВЫБРАТЬ
					ЦенныеБумаги.ЦеннаяБумага
				ИЗ
					ЦенныеБумаги)) КАК ОстаткиЦБОстатки

СГРУППИРОВАТЬ ПО
	ОстаткиЦБОстатки.ЦБ
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	ОстаткиЦБОбороты.ЦБ КАК ЦБ,
	СУММА(ОстаткиЦБОбороты.КоличествоОборот) КАК КоличествоОборот
ПОМЕСТИТЬ Обороты
ИЗ
	РегистрНакопления.ОстаткиЦБ.Обороты(
			{(&amp;НачалоМесяца)},
			{(&amp;КонецМесяца)},
			,
			ЦБ В
				(ВЫБРАТЬ
					ЦенныеБумаги.ЦеннаяБумага
				ИЗ
					ЦенныеБумаги)) КАК ОстаткиЦБОбороты

СГРУППИРОВАТЬ ПО
	ОстаткиЦБОбороты.ЦБ
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	КотировкиСрезПоследних.ЦеннаяБумага КАК ЦеннаяБумага,
	МАКСИМУМ(КотировкиСрезПоследних.Период) КАК Период
ПОМЕСТИТЬ КотировкиCBonds
ИЗ
	РегистрСведений.Котировки.СрезПоследних(
			,
			ЦеннаяБумага В
				(ВЫБРАТЬ
					ЦенныеБумаги.ЦеннаяБумага
				ИЗ
					ЦенныеБумаги)) КАК КотировкиСрезПоследних
ГДЕ
	КотировкиСрезПоследних.Биржа = &amp;CBonds

СГРУППИРОВАТЬ ПО
	КотировкиСрезПоследних.ЦеннаяБумага
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	КотировкиСрезПоследних.ЦеннаяБумага КАК ЦеннаяБумага,
	МАКСИМУМ(КотировкиСрезПоследних.Период) КАК Период
ПОМЕСТИТЬ КотировкиНРД
ИЗ
	РегистрСведений.Котировки.СрезПоследних(
			,
			ЦеннаяБумага В
				(ВЫБРАТЬ
					ЦенныеБумаги.ЦеннаяБумага
				ИЗ
					ЦенныеБумаги)) КАК КотировкиСрезПоследних
ГДЕ
	КотировкиСрезПоследних.Биржа = &amp;НРД

СГРУППИРОВАТЬ ПО
	КотировкиСрезПоследних.ЦеннаяБумага
;

////////////////////////////////////////////////////////////////////////////////
