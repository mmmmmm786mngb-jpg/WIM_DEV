
#Область ПрограммныйИнтерфейс

// Возвращает количество уникальных (по ISIN) ценных бумаг в регистре сведений ЦенныеБумагиВЗапросеКотировок
//
// Параметры:
//  Биржа	 - Справочник.ИнформационноАналитическиеСистемы	 - Вид источника котировок
// 
// Возвращаемое значение:
//   - Число - Количество уникальных ISIN для запроса котировок
//
Функция КоличествоУникальныхЦенныхБумагВЗапросеКотировок(Биржа) Экспорт
	
	Если Биржа = Справочники.ИнформационноАналитическиеСистемы.CBonds Тогда
		ЭтоОблигация = Истина;
	ИначеЕсли Биржа = Справочники.ИнформационноАналитическиеСистемы.НРД Тогда
		ЭтоОблигация = Ложь;
	Иначе
		Возврат 0;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ЭтоОблигация", ЭтоОблигация);
	Запрос.Текст =
	"ВЫБРАТЬ
	|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ РегистрСведенийЦенныеБумагиВЗапросеКотировок.ISIN) КАК КоличествоУникальныхЦенныхБумаг
	|ИЗ
	|	РегистрСведений.ЦенныеБумагиВЗапросеКотировок КАК РегистрСведенийЦенныеБумагиВЗапросеКотировок
	|ГДЕ
	|	ВЫБОР
	|			КОГДА &ЭтоОблигация
	|				ТОГДА РегистрСведенийЦенныеБумагиВЗапросеКотировок.ЦеннаяБумага.ТипЦБ = ЗНАЧЕНИЕ(Перечисление.ТипыЦБ.Облигация)
	|			ИНАЧЕ РегистрСведенийЦенныеБумагиВЗапросеКотировок.ЦеннаяБумага.ТипЦБ <> ЗНАЧЕНИЕ(Перечисление.ТипыЦБ.Облигация)
	|		КОНЕЦ";
	РезультатЗапроса = Запрос.Выполнить();
	Выборка = РезультатЗапроса.Выбрать();
	Выборка.Следующий();
	
	Возврат Выборка.КоличествоУникальныхЦенныхБумаг;
	
КонецФункции

// Возвращает иностранные ценные бумаги для добавления в регистр сведений ЦенныеБумагиВЗапросеКотировок
//
// Параметры:
//  ТекущаяДата	 - Дата	 - Дата определения списка ценных бумаг к запросу котировок (по-умолчанию текущая дата)
// 
// Возвращаемое значение:
//   - Массив - Массив структур найденных ценных бумаг (свойства структуры соответствуют полям РС ЦенныеБумагиВЗапросеКотировок)
//
Функция ИностранныеЦенныеБумагиДляДобавленияВЗапросКотировок(Знач ТекущаяДата = Неопределено) Экспорт
	
	Если Не ЗначениеЗаполнено(ТекущаяДата) Тогда
		ТекущаяДата = ТекущаяДатаСеанса();
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ТекущаяДата"			, ТекущаяДата);
	Запрос.УстановитьПараметр("ПрошедшаяДата"		, НачалоДня(НачалоДня(ТекущаяДата) - 1));
	Запрос.УстановитьПараметр("НачалоПрошлогоМесяца", НачалоМесяца(НачалоМесяца(ТекущаяДата) - 1));
	Запрос.УстановитьПараметр("КромеЦенныхБумагRU"	, Истина);
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ЦенныеБумагиВЗапросеКотировок.ЦеннаяБумага КАК ЦеннаяБумага
	|ПОМЕСТИТЬ ЦенныеБумагиДляКотировок
	|ИЗ
	|	РегистрСведений.ЦенныеБумагиВЗапросеКотировок КАК ЦенныеБумагиВЗапросеКотировок
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ОстаткиЦБОстаткиИОбороты.ЦБ КАК ЦБ,
	|	ОстаткиЦБОстаткиИОбороты.КоличествоКонечныйОстаток КАК КоличествоКонечныйОстаток,
	|	ОстаткиЦБОстаткиИОбороты.КоличествоПриход КАК КоличествоПриход,
	|	ОстаткиЦБОстаткиИОбороты.КоличествоРасход КАК КоличествоРасход
	|ПОМЕСТИТЬ ОстаткиОборотыДетально
	|ИЗ
	|	РегистрНакопления.ОстаткиЦБ.ОстаткиИОбороты(
	|			{(&НачалоПрошлогоМесяца)},
	|			{(&ТекущаяДата)},
	|			Регистратор,
	|			,
	|			НЕ ЦБ В
	|						(ВЫБРАТЬ
	|							ЦенныеБумагиДляКотировок.ЦеннаяБумага КАК ЦеннаяБумага
	|						ИЗ
	|							ЦенныеБумагиДляКотировок)
	|				И НЕ ЦБ.ПометкаУдаления
	|				И ЦБ.ISIN <> """"
	|				И ВЫБОР
	|					КОГДА ЦБ.ТипЦБ = ЗНАЧЕНИЕ(Перечисление.ТипыЦБ.ДепозитарнаяРасписка)
	|						ТОГДА НЕ ЕСТЬNULL(ВЫРАЗИТЬ(ЦБ.БазовыйАктив КАК Справочник.ЦенныеБумаги).Эмитент.ЮридическиеФизическиеЛица.Страна, ЗНАЧЕНИЕ(Справочник.КлассификаторСтранМира.ПустаяСсылка)) В (ЗНАЧЕНИЕ(Справочник.КлассификаторСтранМира.ПустаяСсылка), ЗНАЧЕНИЕ(Справочник.КлассификаторСтранМира.РОССИЯ))
	|					ИНАЧЕ НЕ ЕСТЬNULL(ЦБ.Эмитент.ЮридическиеФизическиеЛица.Страна, ЗНАЧЕНИЕ(Справочник.КлассификаторСтранМира.ПустаяСсылка)) В (ЗНАЧЕНИЕ(Справочник.КлассификаторСтранМира.ПустаяСсылка), ЗНАЧЕНИЕ(Справочник.КлассификаторСтранМира.РОССИЯ))
	|				КОНЕЦ
	|				И ВЫБОР
	|					КОГДА ЦБ.ДатаСнятияСОбслуживания = ДАТАВРЕМЯ(1, 1, 1, 0, 0, 0)
	|						ТОГДА ИСТИНА
	|					ИНАЧЕ ЦБ.ДатаСнятияСОбслуживания >= &ТекущаяДата
	|				КОНЕЦ
	|				И ВЫБОР
	|					КОГДА НЕ ЦБ.ТипЦБ = ЗНАЧЕНИЕ(Перечисление.ТипыЦБ.Облигация)
	|						ТОГДА ИСТИНА
	|					ИНАЧЕ ВЫБОР
	|							КОГДА ЦБ.ДатаПогашения = ДАТАВРЕМЯ(1, 1, 1, 0, 0, 0)
	|								ТОГДА ИСТИНА
	|							ИНАЧЕ ЦБ.ДатаПогашения >= &ТекущаяДата
	|						КОНЕЦ
	|				КОНЕЦ) КАК ОстаткиЦБОстаткиИОбороты
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ОстаткиОборотыДетально.ЦБ КАК ЦеннаяБумага,
	|	ОстаткиОборотыДетально.ЦБ.ISIN КАК ISIN,
	|	&ПрошедшаяДата КАК ДатаВнесенияВСписок,
	|	ИСТИНА КАК СозданоАвтоматически
	|ИЗ
	|	ОстаткиОборотыДетально КАК ОстаткиОборотыДетально
	|
	|СГРУППИРОВАТЬ ПО
	|	ОстаткиОборотыДетально.ЦБ,
	|	ОстаткиОборотыДетально.ЦБ.ISIN
	|
	|УПОРЯДОЧИТЬ ПО
	|	ISIN";
	
	ТаблицаЦенныхБумаг = Запрос.Выполнить().Выгрузить();
	
	Возврат ОбщегоНазначения.ТаблицаЗначенийВМассив(ТаблицаЦенныхБумаг);
	
КонецФункции

// Процедура - Рассылка отчета о ценных бумагах внесенных в запрос котировок за дату
//
// Параметры:
//  ВнешнийИсточник		 - ПланВидовХарактеристик	 - Внешний источник рассылки
//  ДатаВнесенияВСписок	 - Дата						 - Дата внесения
//  ТипыЦенныхБумаг		 - Массив					 - Типы ценных бумаг
//
Процедура РассылкаОтчетаОЦенныхБумагахВнесенныхВЗапросКотировокЗаДату(ВнешнийИсточник, ДатаВнесенияВСписок, ТипыЦенныхБумаг) Экспорт
	
	ТаблицаНовыхБумаг = ЦенныеБумагиВнесенныеВЗапросКотировокЗаДату(ДатаВнесенияВСписок, ТипыЦенныхБумаг);
	Если Не ЗначениеЗаполнено(ТаблицаНовыхБумаг) Тогда
		Возврат;
	КонецЕсли;
	
	ПолучательЗапроса = "НРД";
	ДатаВнесенияВСписокСтрокой = Формат(ДатаВнесенияВСписок, "ДФ=dd.MM.yyyy");
	
	НастройкиОбмена = ВнешниеДанные.ПолучитьПараметрыВнешнегоИсточника(ВнешнийИсточник).Настройка;
	Если НастройкиОбмена = Неопределено Тогда
		ТекстОшибки = "Не заданы параметры внешнего источника """ + Строка(ВнешнийИсточник) + """";
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстОшибки);
		ИмяСобытия = "Уведомление о новых облигациях для запроса котировок не отправлено";
		ЗаписьЖурналаРегистрации(ИмяСобытия, УровеньЖурналаРегистрации.Предупреждение, , , ТекстОшибки);
		Возврат;
	КонецЕсли;
	
	ИмяФайлаОтчета = "Новые ценные бумаги для запроса котировок";
	ТабличныйДокумент = ОбщегоНазначения.ДанныеТаблицыЗначенийВТабличныйДокументСКД(ТаблицаНовыхБумаг);
	ФайлОтчета = ПолучитьИмяВременногоФайла("XLS");
	ТабличныйДокумент.Записать(ФайлОтчета, ТипФайлаТабличногоДокумента.XLS);
	
	ИмяФайлаШаблона = "Шаблон заказа ISIN";
	ФайлШаблона = ПолучитьИмяВременногоФайла("CSV");
	ISINs = ОбщегоНазначения.ВыгрузитьКолонку(ТаблицаНовыхБумаг, "ISIN", Истина, Истина);
	ТекстШаблона = "ISIN" + Символы.ПС + СтрСоединить(ISINs, Символы.ПС);
	ЗаписатьCSV(ТекстШаблона, ФайлШаблона);
	
	СписокВложений = Новый Соответствие;
	СписокВложений.Вставить(ИмяФайлаОтчета + ".xls", Новый ДвоичныеДанные(ФайлОтчета));
	СписокВложений.Вставить(ИмяФайлаШаблона + ".csv", Новый ДвоичныеДанные(ФайлШаблона));
	Попытка
		УдалитьФайлы(ФайлОтчета);
		УдалитьФайлы(ФайлШаблона);
	Исключение
		ТекстОшибки = ОбработкаОшибок.КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстОшибки);
	КонецПопытки;
	
	ТемаПисьма = "Запрос в " + ПолучательЗапроса
		+ " на добавление новых ценных бумаг для получения котировок от " + ДатаВнесенияВСписокСтрокой;
	ТекстПисьма = ТекстУведомленияОНовыхЦенныхБумагахВЗапросКотировок(ТаблицаНовыхБумаг, ДатаВнесенияВСписокСтрокой);
	
	ПараметрыУведомления = Новый Соответствие;
	ПараметрыУведомления.Вставить("Вложения",			СписокВложений);
	ПараметрыУведомления.Вставить("НастройкиОбмена",	НастройкиОбмена);
	ПараметрыУведомления.Вставить("Кодировка",			"UTF-8");
	ПараметрыУведомления.Вставить("ТемаПисьма",			ТемаПисьма);
	ПараметрыУведомления.Вставить("ТекстПисьма",		ТекстПисьма);
	ПараметрыУведомления.Вставить("ТипТекстаПисьма",	ТипТекстаПочтовогоСообщения.HTML);
	ПараметрыУведомления.Вставить("Важность",			ВажностьИнтернетПочтовогоСообщения.Обычная);
	
	РегистрыСведений.УведомленияКОтправке.ДобавитьУведомлениеКотправке(ПараметрыУведомления);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныйПрограммныйИнтерфейс

// Процедура - Добавить записи
//
// Параметры:
//  ЗаписиКДобавлению	 - Массив	 - Массив структур с записями регистра
//
Процедура ДобавитьЗаписи(ЗаписиКДобавлению) Экспорт
	
	Для Каждого СтруктураЗаписи Из ЗаписиКДобавлению Цикл
		
		ДобавитьЗапись(СтруктураЗаписи);
		
	КонецЦикла;
	
КонецПроцедуры

// Процедура - Добавить запись
//
// Параметры:
//  СтруктураЗаписи	 - Структура - Структура записи регистра с данными
//
Процедура ДобавитьЗапись(СтруктураЗаписи) Экспорт
	
	ОбменДаннымиСервер.ДобавитьЗаписьВРегистрСведений(СтруктураЗаписи, "ЦенныеБумагиВЗапросеКотировок");
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ТекстУведомленияОНовыхЦенныхБумагахВЗапросКотировок(ТаблицаНовыхБумаг, ДатаВнесенияВСписокСтрокой)
	
	ПС = "<br>";			// Тег HTML означает перевод строки
	ВключитьBold = "<b>";	// Тег HTML означает включить жирный шрифт
	ОтключитьBold = "</b>";	// Тег HTML означает отключить жирный шрифт
	
	ТекстЗаголовка = "Добрый день!" + ПС + ПС
		+ "Уведомление о добавлении новых ценных бумаг"
		+ " от " + ВключитьBold + ДатаВнесенияВСписокСтрокой + ОтключитьBold + ПС + Символы.ПС + ПС + Символы.ПС
		+ "Требуется загрузить список новых ISIN (из файла шаблона) в портфель организации на сайте НРД: https://nsddata.ru/ru/products/eod"
		+ ПС + Символы.ПС;
	Текст = "<html><BODY>" + Символы.ПС
			+ ТекстЗаголовка + ПС + Символы.ПС;
	
	ПараметрыТрансформацииВHTML = Новый Структура;
	ПараметрыТрансформацииВHTML.Вставить("ПунктПорядкуИспользуется", Истина);
	ПараметрыТрансформацииВHTML.Вставить("ШиринаТаблицы", "1430");
	ПараметрыТрансформацииВHTML.Вставить("Ширина1", "350");
	ПараметрыТрансформацииВHTML.Вставить("Ширина2", "550");
	ПараметрыТрансформацииВHTML.Вставить("ЦветШапки", "eadbaf");
	ПараметрыТрансформацииВHTML.Вставить("Заголовок1", "ISIN");
	ПараметрыТрансформацииВHTML.Вставить("Заголовок2", "Наименование ценной бумаги");
	
	ТаблицаНовыхБумагHTML = ОбщегоНазначения.ТаблицаЗначенийВТаблицуHTML(ТаблицаНовыхБумаг, ПараметрыТрансформацииВHTML);
	Организация = СокрЛП(ОбщегоНазначенияПовтИсп.ОрганизацияПоУмолчанию().Наименование);
	
	Текст = Текст + ВключитьBold + ТаблицаНовыхБумагHTML + ОтключитьBold + ПС + Символы.ПС + ПС + Символы.ПС;
	Текст = Текст + Организация + ПС + Символы.ПС;
	Текст = Текст + "</BODY></html>";
	
	Возврат Текст;
	
КонецФункции

Функция ЦенныеБумагиВнесенныеВЗапросКотировокЗаДату(ДатаВнесенияВСписок, ТипыЦБ)
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ЦенныеБумагиВЗапросеКотировок.ISIN КАК ISIN,
	|	ЦенныеБумагиВЗапросеКотировок.ЦеннаяБумага КАК ЦеннаяБумага,
	|	ЦенныеБумагиВЗапросеКотировок.СозданоАвтоматически КАК СозданоАвтоматически
	|ИЗ
	|	РегистрСведений.ЦенныеБумагиВЗапросеКотировок КАК ЦенныеБумагиВЗапросеКотировок
	|ГДЕ
	|	ЦенныеБумагиВЗапросеКотировок.ДатаВнесенияВСписок = &ДатаВнесенияВСписок
	|	И ЦенныеБумагиВЗапросеКотировок.ЦеннаяБумага.ТипЦБ В(&ТипыЦБ)";
	
	Запрос.УстановитьПараметр("ДатаВнесенияВСписок", НачалоДня(ДатаВнесенияВСписок));
	Запрос.УстановитьПараметр("ТипыЦБ", ТипыЦБ);
	
	ТаблицаНовыхБумаг = Запрос.Выполнить().Выгрузить();
	
	Возврат ТаблицаНовыхБумаг;
	
КонецФункции

Процедура ЗаписатьCSV(ТекстФайла, ИмяФайла)
	
	КодировкаФайла = КодировкаТекста.Системная;
	ТекстовыйФайлЗапись = Новый ЗаписьТекста(ИмяФайла, КодировкаФайла);
	ТекстовыйФайлЗапись.ЗаписатьСтроку(ТекстФайла);
	ТекстовыйФайлЗапись.Закрыть();
	
КонецПроцедуры

#КонецОбласти
