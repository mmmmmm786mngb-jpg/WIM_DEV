#Область ПрограммныйИнтерфейс

// Функция возвращает найденный по переданным параметрам постфикс из РС ПравилаГенерацииНомеровСчетовДепо
//
// Параметры:
//  Дата		 - Дата - Дата на которую нужно получить постфикс
//  СчетДепоМХ	 - СправочникСсылка.СчетаДепоМХ - СчетаДепоМХ
//  ВидСчетаДепо - ПеречислениеСсылка.ВидыСчетовДепо - ВидыСчетовДепо
//  ТипСчетаДепо - ПеречислениеСсылка.ТипыСчетовДепо - ТипыСчетовДепо
// 
// Возвращаемое значение:
//  Строка - Постфикс
//
Функция ПостфиксНаДату(Дата, СчетДепоМХ, ВидСчетаДепо, ТипСчетаДепо) Экспорт
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ПравилаГенерацииНомеровСчетовДепоСрезПоследних.Постфикс КАК Постфикс
	|ИЗ
	|	РегистрСведений.ПравилаГенерацииНомеровСчетовДепо.СрезПоследних(
	|			&Дата,
	|			СчетДепоМХ = &СчетДепоМХ
	|				И ВидСчетаДепо = &ВидСчетаДепо
	|				И ТипСчетаДепо = &ТипСчетаДепо) КАК ПравилаГенерацииНомеровСчетовДепоСрезПоследних";
	
	Запрос.УстановитьПараметр("Дата", Дата);
	Запрос.УстановитьПараметр("СчетДепоМХ", СчетДепоМХ);
	Запрос.УстановитьПараметр("ВидСчетаДепо", ВидСчетаДепо);
	Запрос.УстановитьПараметр("ТипСчетаДепо", ТипСчетаДепо);
	
	РезультатЗапроса = Запрос.Выполнить();
	Выборка = РезультатЗапроса.Выбрать();
	
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Постфикс;
	Иначе
		Возврат Неопределено;
	КонецЕсли;
КонецФункции

#КонецОбласти