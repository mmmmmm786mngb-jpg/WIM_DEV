
Процедура УстановитьСвязи(ДокументРСВ, Поручения) Экспорт
	Для Каждого Строка Из Поручения Цикл
		Запись = РегистрыСведений.Поручения1_10ПоРСВ.СоздатьМенеджерЗаписи();
		Запись.РаскрытиеСпискаВладельцев	= ДокументРСВ;
		Запись.Поручение1_10				= Строка.Поручение;
		Запись.Записать();
	КонецЦикла;
КонецПроцедуры

Функция СвязанныеПоручения(ДокументРСВ) Экспорт
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	Поручения.Поручение1_10 КАК Поручение
	|ИЗ
	|	РегистрСведений.Поручения1_10ПоРСВ КАК Поручения
	|ГДЕ
	|	Поручения.РаскрытиеСпискаВладельцев = &РаскрытиеСпискаВладельцев");
	Запрос.УстановитьПараметр("РаскрытиеСпискаВладельцев", ДокументРСВ);
	Возврат Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Поручение");
КонецФункции
