#Область ЭкспортныеПроцедурыИФункции

// Функция определяет возможна ли загрузка новых данных справочника ИНН и ОГРН ЦБ РФ на указанную дату актуальности.
// Необходимость проверки связана с тем, что в регистре ЮридическиеЛицаЦБРФ при загрузке сохраняются не целиком,
// а только измененные по сравнению с предыдущими. Если загрузить новые данные "в середину", последующие изменения
// перестают быть корректными, так как меняется исходное состояние, от которых они должны были быть расчитаны.
//
// Параметры:
//	НоваяДатаАктуальности - Дата
//	ТекстОшибки - Строка - возвращаемый параметр
//
// Возвращаемое значение:
//	Булево
Функция ВозможнаЗагрузкаДанныхНаДату(НоваяДатаАктуальности, ТекстОшибки) Экспорт
	ВозможнаЗагрузка = Истина;
	
	ТекущаяДатаАктуальности = РегистрыСведений.ПараметрыГлобальные.ЗначениеПараметра("2773.ДатаАктуальностиСправочникаИННИОГРНЦБРФ");
	Если НоваяДатаАктуальности < ТекущаяДатаАктуальности Тогда
		ВозможнаЗагрузка = Ложь;
		ТекстОшибки = "Загрузка данных справочника ИНН и ОГРН ЦБ РФ на дату актуальности " 
						+ Формат(НоваяДатаАктуальности, "ДФ=""дд.ММ.гггг""")
						+ " невозможна, так как уже загружены данные на более позднюю дату актуальности ("
						+ Формат(ТекущаяДатаАктуальности, "ДФ=""дд.ММ.гггг""") + ") !";
	КонецЕсли;
	
	Возврат ВозможнаЗагрузка;
КонецФункции

#КонецОбласти