// Устанавливает новое значение глобальному параметру
//
// Параметры:
//  ИмяПараметра	 - Строка - Имя параметра
//  НовоеЗначение	 - Число, Строка, Дата, Булево - значение параметра, которое требуется установить
//  Комментарий		 - Строка - комментарий к записи
//
Процедура УстановитьЗначениеПараметра(ИмяПараметра, НовоеЗначение, Комментарий = "") Экспорт
	МенеджерЗаписи = РегистрыСведений.ПараметрыГлобальные.СоздатьМенеджерЗаписи(); 
	МенеджерЗаписи.ИмяПараметра = ИмяПараметра;
	МенеджерЗаписи.Значение = НовоеЗначение;
	МенеджерЗаписи.Комментарий = Комментарий;
	МенеджерЗаписи.Записать(Истина);
КонецПроцедуры

// Удаляет глобальный параметр
//
// Параметры:
//  ИмяПараметра - Строка	 - Имя параметра
//
Процедура УдалитьПараметр(ИмяПараметра) Экспорт
	Если ЗначениеЗаполнено(ИмяПараметра) Тогда
		НаборЗаписей = РегистрыСведений.ПараметрыГлобальные.СоздатьНаборЗаписей();
		НаборЗаписей.Отбор.ИмяПараметра.Установить(ИмяПараметра);
		НаборЗаписей.Записать();
	КонецЕсли;
КонецПроцедуры

// Возвращает значение глобального параметра
//
// Параметры:
//  ИмяПараметра		 - Строка - Имя параметра
//  ЗначениеПоУмолчанию	 - Произвольный - Возвращаемое значение в случае отсутствия заданного параметра в РС
// 
// Возвращаемое значение:
//  Произвольный - Значение параметра из РС или переданное значение в случае отсутствия заданного параметра в РС
//
Функция ЗначениеПараметра(ИмяПараметра, ЗначениеПоУмолчанию = Неопределено) Экспорт 
	
	Если Не ЗначениеЗаполнено(ИмяПараметра) Тогда 
		Возврат Неопределено;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ПараметрыГлобальные.ИмяПараметра КАК ИмяПараметра,
	|	ПараметрыГлобальные.Значение КАК Значение
	|ИЗ
	|	РегистрСведений.ПараметрыГлобальные КАК ПараметрыГлобальные
	|ГДЕ
	|	ПараметрыГлобальные.ИмяПараметра = &ИмяПараметра";
	Запрос.УстановитьПараметр("ИмяПараметра", ИмяПараметра);
	
	Параметры = Запрос.Выполнить().Выбрать();
	Если Параметры.Следующий() Тогда 
		Возврат Параметры.Значение;
	Иначе 
		Возврат ЗначениеПоУмолчанию;
	КонецЕсли;
	
КонецФункции

// Устанавливает значение ресурса "Пароль" глобальному параметру
//
// Параметры:
//  ИмяПараметра	 - Строка - Имя параметра
//  НовыйПароль		 - Строка - пароль, который требуется установить
//  Комментарий		 - Строка - комментарий к записи
//
Процедура УстановитьЗначениеПароля(ИмяПараметра, НовыйПароль, Комментарий = "") Экспорт
	МенеджерЗаписи = РегистрыСведений.ПараметрыГлобальные.СоздатьМенеджерЗаписи(); 
	МенеджерЗаписи.ИмяПараметра = ИмяПараметра;
	МенеджерЗаписи.Пароль = НовыйПароль;
	МенеджерЗаписи.Комментарий = Комментарий;
	МенеджерЗаписи.Записать(Истина);
КонецПроцедуры

// Возвращает значение ресурса "Пароль" по имени глобального параметра
//
// Параметры:
//  ИмяПараметра		 - Строка - Имя параметра
//  ПарольПоУмолчанию	 - Произвольный - Возвращаемый пароль в случае отсутствия заданного параметра в РС
// 
// Возвращаемое значение:
//  Произвольный - Значение пароля из РС или переданное значение пароля в случае отсутствия заданного параметра в РС
//
Функция ЗначениеПароля(ИмяПараметра, ПарольПоУмолчанию = Неопределено) Экспорт 
	
	Если Не ЗначениеЗаполнено(ИмяПараметра) Тогда 
		Возврат Неопределено;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ПараметрыГлобальные.ИмяПараметра КАК ИмяПараметра,
	|	ПараметрыГлобальные.Пароль КАК Пароль
	|ИЗ
	|	РегистрСведений.ПараметрыГлобальные КАК ПараметрыГлобальные
	|ГДЕ
	|	ПараметрыГлобальные.ИмяПараметра = &ИмяПараметра";
	Запрос.УстановитьПараметр("ИмяПараметра", ИмяПараметра);
	
	Параметры = Запрос.Выполнить().Выбрать();
	Если Параметры.Следующий() Тогда 
		Возврат Параметры.Пароль;
	Иначе 
		Возврат ПарольПоУмолчанию;
	КонецЕсли;
	
КонецФункции

