
Функция НастройкиСреды(Сервер, ИнформационнаяБаза) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	НастройкиСред.ЗначениеНастройки КАК Настройки,
	|	НастройкиСред.НастройкиКодирования КАК НастройкиКодирования,
	|	НастройкиСред.Боевая КАК Боевая
	|ИЗ
	|	РегистрСведений.НастройкиСред КАК НастройкиСред
	|ГДЕ
	|	НастройкиСред.Сервер = &Сервер
	|	И НастройкиСред.ИнформационнаяБаза = &ИнформационнаяБаза";
	Запрос.УстановитьПараметр("Сервер"				, Сервер);
	Запрос.УстановитьПараметр("ИнформационнаяБаза"	, ИнформационнаяБаза);
	Результат = Запрос.Выполнить();
	
	Если Результат.Пустой() Тогда
		Возврат Неопределено;
	Иначе
		Выборка = Результат.Выбрать();
		Выборка.Следующий();
		Возврат Выборка;
	КонецЕсли;
	
КонецФункции
