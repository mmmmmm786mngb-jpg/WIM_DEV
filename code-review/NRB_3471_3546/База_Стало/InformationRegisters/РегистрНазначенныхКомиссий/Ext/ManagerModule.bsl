
Процедура ЗакрытьКомиссииПоДоговору(ДоговорКонтрагента) Экспорт
	
	ДатаЗакрытия = ДоговорКонтрагента.ДатаОкончанияДействия;
	Если Не ЗначениеЗаполнено(ДатаЗакрытия) Тогда
		Возврат;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	РегистрНазначенныхКомиссийСрезПоследних.Услуга КАК Услуга
	|ИЗ
	|	РегистрСведений.РегистрНазначенныхКомиссий.СрезПоследних(
	|			&Период, 
	|			ДоговорКонтрагента = &ДоговорКонтрагента) КАК РегистрНазначенныхКомиссийСрезПоследних
	|ГДЕ
	|	РегистрНазначенныхКомиссийСрезПоследних.ФлагАктивности";
	Запрос.УстановитьПараметр("Период", ДатаЗакрытия);
	Запрос.УстановитьПараметр("ДоговорКонтрагента", ДоговорКонтрагента);
	
	Результат = Запрос.Выполнить();
	Если Результат.Пустой() Тогда
		Возврат;
	КонецЕсли;
	
	НаборЗаписей = СоздатьНаборЗаписей();
	НаборЗаписей.Отбор.Период.Установить(ДатаЗакрытия);
	НаборЗаписей.Отбор.ДоговорКонтрагента.Установить(ДоговорКонтрагента);
	
	Выборка = Результат.Выбрать();
	Пока Выборка.Следующий() Цикл
		НоваяЗапись = НаборЗаписей.Добавить();
		НоваяЗапись.Период = ДатаЗакрытия;
		НоваяЗапись.ДоговорКонтрагента = ДоговорКонтрагента;
		НоваяЗапись.Услуга = Выборка.Услуга;
		НоваяЗапись.ФлагАктивности = Ложь;
	КонецЦикла;
	НаборЗаписей.Записать();
	
	УровеньИнформация = УровеньЖурналаРегистрации.Информация;
	ТекстСообщения = "Закрыты услуги на " + Формат(ДатаЗакрытия, "ДФ = ""дд.ММ.гггг""") + " по договору";
	ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения + " " + ДоговорКонтрагента);
	ЗаписьЖурналаРегистрации("Регистр назначенных комиссий", УровеньИнформация,, ДоговорКонтрагента, ТекстСообщения);
	
КонецПроцедуры