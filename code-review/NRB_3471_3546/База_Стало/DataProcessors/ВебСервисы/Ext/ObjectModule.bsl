// Возвращает статусы доставки уведомлений о КД из веб-сервиса или Неопределено в случае ошибки
//
// Параметры:
//	ДанныеУведомлений - таблица значений с колонками:
//		УникальныйИдентификатор - строка, УИД документа УведомлениеКлиентам
//		ИдентификаторыКлиентов - массив строк, содержащих код загрузки контрагента по классификатору "Клиенты"
//
// Возвращаемое значение:
//	Неопределено в случае ошибки
//	Иначе таблица значений с колонками:
//		GUID - строка, УИД документа УведомлениеКлиентам
//		ClientID - строка, содержащая код загрузки контрагента по классификатору "Клиенты"
//		Успешно - булево, Истина, если по данному документу и клиенту уведомление было доставлено, иначе Ложь
//
Функция СтатусыДоставкиУведомленийОКД(ДанныеУведомлений) Экспорт
	СтатусыДоставки = Новый ТаблицаЗначений;
	СтатусыДоставки.Колонки.Добавить("GUID");
	СтатусыДоставки.Колонки.Добавить("ClientId");
	СтатусыДоставки.Колонки.Добавить("Успешно");

	Попытка	
		Прокси = ВебСервисыПовтИсп.ПолучитьПроксиСУДК();
		ПространствоИмен = Прокси.ТочкаПодключения.Интерфейс.URIПространстваИмен;
		Фабрика = Прокси.ФабрикаXDTO;
		
		ТипЗапроса = Фабрика.Тип(ПространствоИмен, "CorpActionMessageRequest");
		КоллекцияУведомлений = Фабрика.Создать(Фабрика.Тип(ПространствоИмен, "ArrayOfCorpActionMessageRequest"));	
		
		Для Каждого Уведомление Из ДанныеУведомлений Цикл
			ЭкземплярЗапроса = Фабрика.Создать(ТипЗапроса); 
			ЭкземплярЗапроса.ExternalMessageId = Уведомление.УникальныйИдентификатор;
			
			ЭкземплярМассиваСтрок = Фабрика.Создать(Фабрика.Тип(ПространствоИмен, "ArrayOfString"));
			Для Каждого ClientID Из Уведомление.ИдентификаторыКлиентов Цикл
				ЭкземплярМассиваСтрок.String.Добавить(ClientID);
			КонецЦикла;
			
			ЭкземплярЗапроса.Установить("ClientIdList", ЭкземплярМассиваСтрок);
			КоллекцияУведомлений["CorpActionMessageRequest"].Добавить(ЭкземплярЗапроса);	
		КонецЦикла;
		
		ОтветВебСервиса = Прокси.CheckDeliveryForCorporateActions(КоллекцияУведомлений);
		
		Для Каждого ОбъектXDTO Из ОтветВебСервиса.CorpActionMessageResponse Цикл
			Если ОбъектXDTO.MessageNotFound Тогда
				ТекстОшибки = "Уведомление по УИД " + ОбъектXDTO.ExternalMessageId + " не найдено в СУДК";
				ЗаписьЖурналаРегистрации("Проверка доставки уведомлений в кабинет клиента",
					УровеньЖурналаРегистрации.Ошибка,,, ТекстОшибки);
			Иначе 
				Для Каждого CorpActionMessageResponseDetail Из ОбъектXDTO.ClientsList.CorpActionMessageResponseDetail Цикл
					НоваяСтрока = СтатусыДоставки.Добавить();
					НоваяСтрока.GUID = ОбъектXDTO.ExternalMessageId;
					НоваяСтрока.ClientId = CorpActionMessageResponseDetail.ClientId;
					НоваяСтрока.Успешно = CorpActionMessageResponseDetail.IsDelivery;
				КонецЦикла;
			КонецЕсли;
		КонецЦикла;
		
	Исключение
		СтатусыДоставки = Неопределено;
		ИнформацияОбОшибке = ИнформацияОбОшибке();
		ПодробноеПредставлениеОшибки = ПодробноеПредставлениеОшибки(ИнформацияОбОшибке);
		ЗаписьЖурналаРегистрации("Вызов внешнего веб-сервиса CheckDeliveryForCorporateActions",
			УровеньЖурналаРегистрации.Ошибка,,, ПодробноеПредставлениеОшибки);
	КонецПопытки;

	Возврат СтатусыДоставки;
	
КонецФункции

// Возвращает уведомления о КД в СУДК, отсутствующие в базе 1С веб-сервиса или Неопределено в случае ошибки
//
// Параметры:
//	ДанныеУведомлений - таблица значений с колонками:
//		УникальныйИдентификатор - строка, УИД документа УведомлениеКлиентам
//		ИдентификаторыКлиентов - массив строк, содержащих код загрузки контрагента по классификатору "Клиенты"
//
// Возвращаемое значение:
//	Неопределено в случае ошибки
//	Иначе таблица значений с колонками:
//		GUID - строка, УИД документа УведомлениеКлиентам
//		ClientID - строка, содержащая код загрузки контрагента по классификатору "Клиенты"
//
Функция УведомленияКДОтстутствующиеВ1С(ДанныеУведомлений, НачалоПериода, КонецПериода) Экспорт
	ОтсутствующиеУведомления = Новый ТаблицаЗначений;
	ОтсутствующиеУведомления.Колонки.Добавить("GUID");
	ОтсутствующиеУведомления.Колонки.Добавить("ClientId");

	Попытка	
		Прокси = ВебСервисыПовтИсп.ПолучитьПроксиСУДК();
		ПространствоИмен = Прокси.ТочкаПодключения.Интерфейс.URIПространстваИмен;
		Фабрика = Прокси.ФабрикаXDTO;
		
		ТипОсновнойКоллекции = Фабрика.Тип(ПространствоИмен, "CheckMissingMessagesForCorporateActions");
		ТипЗапроса = Фабрика.Тип(ПространствоИмен, "CorpActionMessageRequest");
		
		КоллекцияУведомлений = Фабрика.Создать(Фабрика.Тип(ПространствоИмен, "ArrayOfCorpActionMessageRequest"));	
		
		Для Каждого Уведомление Из ДанныеУведомлений Цикл
			ЭкземплярЗапроса = Фабрика.Создать(ТипЗапроса); 
			ЭкземплярЗапроса.ExternalMessageId = Уведомление.УникальныйИдентификатор;
			
			ЭкземплярМассиваСтрок = Фабрика.Создать(Фабрика.Тип(ПространствоИмен, "ArrayOfString"));
			Для Каждого ClientID Из Уведомление.ИдентификаторыКлиентов Цикл
				ЭкземплярМассиваСтрок.String.Добавить(ClientID);
			КонецЦикла;
			
			ЭкземплярЗапроса.Установить("ClientIdList", ЭкземплярМассиваСтрок);
			КоллекцияУведомлений["CorpActionMessageRequest"].Добавить(ЭкземплярЗапроса);	
		КонецЦикла;
		
		ЭкземплярCheckMissingMessages = Фабрика.Создать(ТипОсновнойКоллекции);
		ЭкземплярCheckMissingMessages.Установить("actualMessages", КоллекцияУведомлений);
		ЭкземплярCheckMissingMessages.beginDate = НачалоПериода; 
		ЭкземплярCheckMissingMessages.endDate = КонецПериода; 
		
		ТипОсновнойКоллекции.Проверить(ЭкземплярCheckMissingMessages);
		
		ОтветВебСервиса = Прокси.CheckMissingMessagesForCorporateActions(КоллекцияУведомлений,
			ЭкземплярCheckMissingMessages.beginDate, ЭкземплярCheckMissingMessages.endDate);
		
		Для Каждого ОбъектXDTO Из ОтветВебСервиса.CorpActionMessageResponse Цикл
			Для Каждого CorpActionMessageResponseDetail Из ОбъектXDTO.ClientsList.CorpActionMessageResponseDetail Цикл
				НоваяСтрока = ОтсутствующиеУведомления.Добавить();
				НоваяСтрока.GUID = ОбъектXDTO.ExternalMessageId;
				НоваяСтрока.ClientId = CorpActionMessageResponseDetail.ClientId;
			КонецЦикла;
		КонецЦикла;
		
	Исключение
		ОтсутствующиеУведомления = Неопределено;
		ИнформацияОбОшибке = ИнформацияОбОшибке();
		ПодробноеПредставлениеОшибки = ПодробноеПредставлениеОшибки(ИнформацияОбОшибке);
		ЗаписьЖурналаРегистрации("Вызов внешнего веб-сервиса CheckMissingMessagesForCorporateActions",
			УровеньЖурналаРегистрации.Ошибка,,, ПодробноеПредставлениеОшибки);
	КонецПопытки;

	Возврат ОтсутствующиеУведомления;
	
КонецФункции

// Возвращает таблицу с данными о всех созданных в кабинете клиента (КК) заявлениях на участие в оферте,
// которые подписаны клиентом, но еще не были загруженны в 1С ДЕПО
// Возвращаемое значение:
//	ТаблицаЗначений - со следующими колонками:
//							DocumentNumber - номер в СЭД
//							ClientId - идентификатор клиента в СУДК (строка(9))
//							ISIN - ISIN ЦБ
//							RegNumber - государственный регистрационный номер ЦБ
//							StockBondsCount - число ЦБ к оферте
//							OfferDate - дата оферты
//							DocumentId - ID заявки
//							CreatedAt - дата создания заявки в кабинете клиента 
Функция НовыеЗаявленияНаУчастиеВОферте() Экспорт
	
	Заявления = Документы.ЗаявлениеНаУчастиеВОферте.НоваяТаблицаДляЗаявленийИзКабинетаКлиента();
	
	Попытка
		Прокси = ВебСервисыПовтИсп.ПолучитьПроксиСУДК();
		ПространствоИмен 		= Прокси.ТочкаПодключения.Интерфейс.URIПространстваИмен;
		WSМетодТип 				= Прокси.ФабрикаXDTO.Тип(ПространствоИмен, "GetSignedOfferRequests");
		ПараметрыМетода = Прокси.ФабрикаXDTO.Создать(WSМетодТип);
		
		ОтветВебСервиса = Прокси.GetSignedOfferRequests(ПараметрыМетода);
		
		Для Каждого ОбъектXDTO Из ОтветВебСервиса.GetSignedOfferRequestsResult.OfferRequestResult Цикл
			НоваяСтрокаТЗ = Заявления.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрокаТЗ, ОбъектXDTO);
		КонецЦикла;
	Исключение
		ИнформацияОбОшибке = ИнформацияОбОшибке();
		ПодробноеПредставлениеОшибки = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке);
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ПодробноеПредставлениеОшибки);
		ЗаписьЖурналаРегистрации("Вызов внешнего веб-сервиса для получения из КК новых заявлений на участие в оферте",
									УровеньЖурналаРегистрации.Ошибка, Метаданные(), , ПодробноеПредставлениеОшибки);
	КонецПопытки;
	
	Возврат Заявления;
	
КонецФункции

// Возвращает таблицу с данными о всех имеющихся в кабинете клиента (КК) подписанных заявлениях на участие в оферте
// за указанный период.
// Параметры:
//	ДатаНачала - дата
//	ДатаОкончания - дата
// Возвращаемое значение:
//	ТаблицаЗначений - со следующими колонками:
//							DocumentNumber - номер в СЭД
//							ClientId - идентификатор клиента в СУДК (строка(9))
//							ISIN - ISIN ЦБ
//							RegNumber - государственный регистрационный номер ЦБ
//							StockBondsCount - число ЦБ к оферте
//							OfferDate - дата оферты
//							DocumentId - ID заявки
//							Exported1C - завка была выгружена в 1С
//							CreatedAt - дата создания заявки в кабинете клиента
Функция ЗаявленияНаУчастиеВОфертеЗаПериод(ДатаНачала, ДатаОкончания) Экспорт
	
	Заявления = Документы.ЗаявлениеНаУчастиеВОферте.НоваяТаблицаДляЗаявленийИзКабинетаКлиента();
	
	Попытка
		Прокси = ВебСервисыПовтИсп.ПолучитьПроксиСУДК();
		
		ОтветВебСервиса = Прокси.GetSignedOfferRequestsByPeriod(ДатаНачала, ДатаОкончания);
		
		Для Каждого ОбъектXDTO Из ОтветВебСервиса.OfferRequestResult Цикл
			НоваяСтрокаТЗ = Заявления.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрокаТЗ, ОбъектXDTO);
		КонецЦикла;
	Исключение
		ИнформацияОбОшибке = ИнформацияОбОшибке();
		ПодробноеПредставлениеОшибки = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке);
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ПодробноеПредставлениеОшибки);
		ЗаписьЖурналаРегистрации("Вызов внешнего веб-сервиса для получения из КК заявлений на участие в оферте за период",
									УровеньЖурналаРегистрации.Ошибка, Метаданные(), , ПодробноеПредставлениеОшибки);
	КонецПопытки;
	
	Возврат Заявления;
	
КонецФункции

// Сообщает СУДК какие заявления были успешно загружены в 1С ДЕПО
// Параметры:
//	ЗагруженныеЗаявления - Массив - массив DocumentId, представляющих собой целые числа
Процедура СообщитьСУДКЧтоЗаявленияНаУчастиеВОфертеЗагружены(ЗагруженныеЗаявления) Экспорт
	
	Попытка
		Прокси = ВебСервисыПовтИсп.ПолучитьПроксиСУДК();
		ПространствоИмен = Прокси.ТочкаПодключения.Интерфейс.URIПространстваИмен;
		Фабрика = Прокси.ФабрикаXDTO;
		WSМетодТип = Фабрика.Тип(ПространствоИмен, "SetOfferRequestExported1C");
		ПараметрыМетода = Прокси.ФабрикаXDTO.Создать(WSМетодТип);
		ТипArrayOfInt = Фабрика.Тип(ПространствоИмен, "ArrayOfInt");
		documentIds = Фабрика.Создать(ТипArrayOfInt);
		Для Каждого id Из ЗагруженныеЗаявления Цикл
			documentIds.Int.Добавить(id);
		КонецЦикла;
		ПараметрыМетода.documentIds = documentIds;
		
		Прокси.SetOfferRequestExported1C(ПараметрыМетода);
	Исключение
		ИнформацияОбОшибке = ИнформацияОбОшибке();
		ПодробноеПредставлениеОшибки = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке);
		ЗаписьЖурналаРегистрации("Вызов внешнего веб-сервиса для получения из КК новых заявлений на участие в оферте",
									УровеньЖурналаРегистрации.Ошибка, Метаданные(), , ПодробноеПредставлениеОшибки);
		
	КонецПопытки;
	
КонецПроцедуры


