Перем Прокси Экспорт; // Прокси "PersonalDataService"
Перем ПространствоИмен Экспорт; // URIПространстваИмен "PersonalDataService"
Перем мИмяСобытия;
Перем мИмяСобытияУведомлениеОКД;

Процедура ИнициироватьСоединение(Параметры = Неопределено) Экспорт
	Прокси = ВебСервисыПовтИсп.ПолучитьПроксиСУДК();
	ПространствоИмен = Прокси.ТочкаПодключения.Интерфейс.URIПространстваИмен;
КонецПроцедуры

Функция НовыеПараметрыМетода(ИмяМетода) Экспорт
	ИнициироватьСоединение();
	ТипПараметра = Прокси.ФабрикаXDTO.Тип(ПространствоИмен, ИмяМетода);
	Возврат Прокси.ФабрикаXDTO.Создать(ТипПараметра);
КонецФункции

Процедура ПроверитьЗаполнениеПараметров(ПараметрыМетода) Экспорт
	ПараметрыМетода.Тип().Проверить(ПараметрыМетода);
КонецПроцедуры

Функция РезультатОтправкиУведомленияПоВыкупам(ТаблицаОпций, РезультатЗапросаПоКлиентам,
	РезультатЗапросаПоДокументуКД, ЗаголовокСообщения, ТекстСообщения, УникальныйИдентификатор) Экспорт
	
	ВыборкаДокументов = РезультатЗапросаПоДокументуКД.Выбрать();
	ВыборкаДокументов.Следующий();
	
	ВыборкаКлиентов = РезультатЗапросаПоКлиентам.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	Попытка	
		Прокси = ВебСервисыПовтИсп.ПолучитьПроксиСУДК();
		ПространствоИмен = Прокси.ТочкаПодключения.Интерфейс.URIПространстваИмен;
		Фабрика = Прокси.ФабрикаXDTO;
			
		СтруктураКоллекции	= ВебСервисыСервер.СтруктураДляСозданияКоллекции("ArrayOfCorporateActionBidsOption1",
			"CorporateActionBidsOption1", Неопределено);
		КоллекцияОпций		= ВебСервисыСервер.СоздатьИЗаполнитьКоллекциюОбъектаXDTO(Фабрика, ТаблицаОпций, ПространствоИмен,
			СтруктураКоллекции);
			
		СтруктураКоллекции	= ВебСервисыСервер.СтруктураДляСозданияКоллекции("ArrayOfCorporateActionClientSecurity1",
			"CorporateActionClientSecurity1", Неопределено);
		СтруктураКоллекции	= ВебСервисыСервер.СтруктураДляСозданияКоллекции("ArrayOfCorporateActionClient1",
			"CorporateActionClient1", СтруктураКоллекции, "CorporateActionClientSecurityCollection");
		КоллекцияКлиентов	= ВебСервисыСервер.СоздатьИЗаполнитьКоллекциюОбъектаXDTO(Фабрика, ВыборкаКлиентов, ПространствоИмен,
			СтруктураКоллекции);
		
		ТипОсновнойКоллекции = Фабрика.Тип(ПространствоИмен, "CreateCorporateActionBids");
		
		ЭкземплярCorporateActionBid = Фабрика.Создать(ТипОсновнойКоллекции);
		ЗаполнитьЗначенияСвойств(ЭкземплярCorporateActionBid, ВыборкаДокументов); 
		ЭкземплярCorporateActionBid.Установить("optionsCollection", КоллекцияОпций);
		ЭкземплярCorporateActionBid.Установить("clientsCollection", КоллекцияКлиентов);
		
		ЭкземплярCorporateActionBid.emailSubject		= ЗаголовокСообщения;
		ЭкземплярCorporateActionBid.emailBody			= ТекстСообщения;
		ЭкземплярCorporateActionBid.externalMessageId	= УникальныйИдентификатор;
		Если Не ЗначениеЗаполнено(ЭкземплярCorporateActionBid.cutOffDate) Тогда
			ЭкземплярCorporateActionBid.cutOffDate = ТекущаяДатаСеанса();
		КонецЕсли;
		
		ТипОсновнойКоллекции.Проверить(ЭкземплярCorporateActionBid);
		Прокси.CreateCorporateActionBids(ЭкземплярCorporateActionBid);
		
		ОпубликованоУспешно = Истина;
		
	Исключение
		ОпубликованоУспешно = Ложь;
		ИнформацияОбОшибке = ИнформацияОбОшибке();
		ПодробноеПредставлениеОшибки = ПодробноеПредставлениеОшибки(ИнформацияОбОшибке);
		ЗаписьЖурналаРегистрации(мИмяСобытияУведомлениеОКД, УровеньЖурналаРегистрации.Ошибка,,, ПодробноеПредставлениеОшибки);
	КонецПопытки;
	
	Возврат ОпубликованоУспешно;
	
КонецФункции

Функция РезультатОтправкиУведомленияПоСобраниям(РезультатЗапросаПоКлиентам, РезультатЗапросаПоВопросам,
	РезультатЗапросаПоДокументуКД, ЗаголовокСообщения, ТекстСообщения, УникальныйИдентификатор) Экспорт
	
	ВыборкаДокументов = РезультатЗапросаПоДокументуКД.Выбрать();
	ВыборкаДокументов.Следующий();
	
	ВыборкаВопросов = РезультатЗапросаПоВопросам.Выбрать();
	ВыборкаКлиентов = РезультатЗапросаПоКлиентам.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	МассивИменXDTO = Новый Массив;
	МассивИменXDTO.Добавить("ArrayOfCorporateActionMeetResolution1");         
	МассивИменXDTO.Добавить("CorporateActionMeetResolution1");
	МассивИменXDTO.Добавить("ArrayOfCorporateActionMeetResolutionVote1");              
	МассивИменXDTO.Добавить("CorporateActionMeetResolutionVote1");         
	МассивИменXDTO.Добавить("ArrayOfCorporateActionMeetResolutionDetail1");              
	МассивИменXDTO.Добавить("CorporateActionMeetResolutionDetail1");         
									 
	Попытка
		Прокси = ВебСервисыПовтИсп.ПолучитьПроксиСУДК();
		ПространствоИмен = Прокси.ТочкаПодключения.Интерфейс.URIПространстваИмен;
		Фабрика = Прокси.ФабрикаXDTO;
		
		ТипыПространстваИмен = Новый Структура;
		Для Каждого ИмяОбъектаXDTO Из МассивИменXDTO Цикл
			ТипыПространстваИмен.Вставить(ИмяОбъектаXDTO, Фабрика.Тип(ПространствоИмен, ИмяОбъектаXDTO));
		КонецЦикла;
		
		КоллекцияВопросов = Фабрика.Создать(ТипыПространстваИмен.ArrayOfCorporateActionMeetResolution1);
		ТекущийНомерВопроса = "";
		ЭкземплярResolution = Неопределено;
		КоллекцияДеталей = Неопределено;
		Пока ВыборкаВопросов.Следующий() Цикл
			НомерВопроса = ВыборкаВопросов.Number;
			Если ВыборкаВопросов.CumulativeVoting
				И ЗначениеЗаполнено(ТекущийНомерВопроса)
				И Найти(НомерВопроса, ТекущийНомерВопроса + ".") > 0
				И ЭкземплярResolution <> Неопределено Тогда
				ЭкземплярDetails = Фабрика.Создать(ТипыПространстваИмен.CorporateActionMeetResolutionDetail1);
				ЗаполнитьЗначенияСвойств(ЭкземплярDetails, ВыборкаВопросов);
				КоллекцияДеталей.CorporateActionMeetResolutionDetail1.Добавить(ЭкземплярDetails);
				ЭкземплярResolution.Установить("CorporateActionMeetResolutionDetailCollection", КоллекцияДеталей);
			Иначе 
				ЭкземплярResolution = Фабрика.Создать(ТипыПространстваИмен.CorporateActionMeetResolution1);
				ЗаполнитьЗначенияСвойств(ЭкземплярResolution, ВыборкаВопросов);
				КоллекцияВопросов.CorporateActionMeetResolution1.Добавить(ЭкземплярResolution);
				Если ВыборкаВопросов.CumulativeVoting Тогда
					ТекущийНомерВопроса = НомерВопроса;
					КоллекцияДеталей = Фабрика.Создать(ТипыПространстваИмен.ArrayOfCorporateActionMeetResolutionDetail1);
				КонецЕсли;
				КоллекцияРаскрытияСписка = Фабрика.Создать(ТипыПространстваИмен.ArrayOfCorporateActionMeetResolutionVote1);
				Пока ВыборкаКлиентов.Следующий() Цикл
					ЭкземплярClientVote = Фабрика.Создать(ТипыПространстваИмен.CorporateActionMeetResolutionVote1);
					ЗаполнитьЗначенияСвойств(ЭкземплярClientVote, ВыборкаКлиентов);
					ЭкземплярClientVote.VoteMultiplier = ВыборкаВопросов.VoteMultiplier;
					Если ВыборкаВопросов.ForInformationOnly Тогда
						ЭкземплярClientVote.VoteNb = 0;
					КонецЕсли;
					КоллекцияРаскрытияСписка.CorporateActionMeetResolutionVote1.Добавить(ЭкземплярClientVote);
				КонецЦикла;
				ВыборкаКлиентов.Сбросить();
				ЭкземплярResolution.Установить("CorporateActionMeetResolutionVoteCollection", КоллекцияРаскрытияСписка);
			КонецЕсли;
		КонецЦикла;
		
		СтруктураКоллекции = ВебСервисыСервер.СтруктураДляСозданияКоллекции("ArrayOfCorporateActionClientSecurity1", "CorporateActionClientSecurity1", Неопределено);
		СтруктураКоллекции = ВебСервисыСервер.СтруктураДляСозданияКоллекции("ArrayOfCorporateActionClient1", "CorporateActionClient1", СтруктураКоллекции, "CorporateActionClientSecurityCollection");
		КоллекцияКлиентов = ВебСервисыСервер.СоздатьИЗаполнитьКоллекциюОбъектаXDTO(Фабрика, ВыборкаКлиентов, ПространствоИмен, СтруктураКоллекции);
		
		ТипОсновнойКоллекции = Фабрика.Тип(ПространствоИмен, "CreateCorporateActionMeet");
		
		ЭкземплярCorporateActionMeet = Фабрика.Создать(ТипОсновнойКоллекции);
		ЗаполнитьЗначенияСвойств(ЭкземплярCorporateActionMeet, ВыборкаДокументов); 
		ЭкземплярCorporateActionMeet.Установить("resolutionsCollection", КоллекцияВопросов);
		ЭкземплярCorporateActionMeet.Установить("clientsCollection", КоллекцияКлиентов);
		
		ЭкземплярCorporateActionMeet.emailSubject		= ЗаголовокСообщения;
		ЭкземплярCorporateActionMeet.emailBody			= ТекстСообщения;
		ЭкземплярCorporateActionMeet.externalMessageId	= УникальныйИдентификатор;
		
		ТипОсновнойКоллекции.Проверить(ЭкземплярCorporateActionMeet);
		Прокси.CreateCorporateActionMeet(ЭкземплярCorporateActionMeet);
		
		ОпубликованоУспешно = Истина;
		
	Исключение
		ОпубликованоУспешно = Ложь;
		ИнформацияОбОшибке = ИнформацияОбОшибке();
		ПодробноеПредставлениеОшибки = ПодробноеПредставлениеОшибки(ИнформацияОбОшибке);
		ЗаписьЖурналаРегистрации(мИмяСобытия, УровеньЖурналаРегистрации.Ошибка,,, ПодробноеПредставлениеОшибки);
	КонецПопытки;
	
	Возврат ОпубликованоУспешно;
	
КонецФункции

Функция РезультатСохраненияКорпоративногоДействияWTRC(ТаблицаКлиентов, ТаблицаРазделов, ПараметрыWebСервиса,
	УникальныйИдентификатор) Экспорт
	
	Попытка	
		Прокси = ВебСервисыПовтИсп.ПолучитьПроксиСУДК();
		ПространствоИмен = Прокси.ТочкаПодключения.Интерфейс.URIПространстваИмен;
		Фабрика = Прокси.ФабрикаXDTO;
			
		СтруктураКоллекции = ВебСервисыСервер.СтруктураДляСозданияКоллекции("ArrayOfCorporateActionClientSecurity1",
			"CorporateActionClientSecurity1", Неопределено);
		СтруктураКоллекции = ВебСервисыСервер.СтруктураДляСозданияКоллекции("ArrayOfCorporateActionClient1",
			"CorporateActionClient1", СтруктураКоллекции, "CorporateActionClientSecurityCollection");
		КоллекцияКлиентов = ВебСервисыСервер.СоздатьИЗаполнитьКоллекциюОбъектаXDTO(Фабрика,
			ТаблицаКлиентов, ПространствоИмен, СтруктураКоллекции);
		
		СтруктураКоллекции = ВебСервисыСервер.СтруктураДляСозданияКоллекции("ArrayOfClientWtrc",
			"ClientWtrc", Неопределено);
		КоллекцияРазделов = ВебСервисыСервер.СоздатьИЗаполнитьКоллекциюОбъектаXDTO(Фабрика,
			ТаблицаРазделов, ПространствоИмен, СтруктураКоллекции);
			
		ТипОсновнойКоллекции = Фабрика.Тип(ПространствоИмен, "CreateCorporateActionWtrc");
		
		ЭкземплярCorporateActionWtrc = Фабрика.Создать(ТипОсновнойКоллекции);
		ЭкземплярCorporateActionWtrc.Установить("clientsCollection", КоллекцияКлиентов);
		ЭкземплярCorporateActionWtrc.Установить("depoAccountSectionCollection", КоллекцияРазделов);		
		ЭкземплярCorporateActionWtrc.reference		= СокрЛП(ПараметрыWebСервиса.РеференсКД);
		ЭкземплярCorporateActionWtrc.issuerName		= СокрЛП(ПараметрыWebСервиса.НаименованиеЭмитента);
		ЭкземплярCorporateActionWtrc.information	= "";	// Дополнительная информация (особые условия)
		ЭкземплярCorporateActionWtrc.deadLineDateCorporateAction= ПараметрыWebСервиса.ДатаОкончанияПриемаПоручений1_10;
		ЭкземплярCorporateActionWtrc.deadLineDateInstruction	= ПараметрыWebСервиса.ДатаОкончанияПриемаПоручений1_5;
		ЭкземплярCorporateActionWtrc.emailSubject	= ПараметрыWebСервиса.ЗаголовокСообщения;
		ЭкземплярCorporateActionWtrc.emailBody		= ПараметрыWebСервиса.ТекстСообщения;
		ЭкземплярCorporateActionWtrc.secName 		= ПараметрыWebСервиса.НаименованиеЦБ;
		ЭкземплярCorporateActionWtrc.externalMessageId = УникальныйИдентификатор;
		
		ТипОсновнойКоллекции.Проверить(ЭкземплярCorporateActionWtrc);
		Прокси.CreateCorporateActionWtrc(ЭкземплярCorporateActionWtrc);
		
		ОпубликованоУспешно = Истина;
		
	Исключение
		ОпубликованоУспешно = Ложь;
		ИнформацияОбОшибке = ИнформацияОбОшибке();
		ПодробноеПредставлениеОшибки = "Ошибка при вызове Web-сервиса CreateCorporateActionWtrc. "
			+ ПодробноеПредставлениеОшибки(ИнформацияОбОшибке);
		ЗаписьЖурналаРегистрации(мИмяСобытияУведомлениеОКД, УровеньЖурналаРегистрации.Ошибка,,, ПодробноеПредставлениеОшибки);
	КонецПопытки;
	
	Возврат ОпубликованоУспешно;
	
КонецФункции

Функция РезультатДобавленияКлиентаВСуществующееКорпоративноеДействиеWTRC(ПараметрыWebСервиса,
	УникальныйИдентификатор) Экспорт
	
	Для Каждого СтрокаДанных Из ПараметрыWebСервиса.Данные Цикл
		Попытка	
			Прокси = ВебСервисыПовтИсп.ПолучитьПроксиСУДК();
			ПространствоИмен = Прокси.ТочкаПодключения.Интерфейс.URIПространстваИмен;
			Фабрика = Прокси.ФабрикаXDTO;
				
			ТипЭкземпляра = Фабрика.Тип(ПространствоИмен, "CorporateActionClient1");
			ЭкземплярCorporateActionClient1 = Фабрика.Создать(ТипЭкземпляра);
			ЭкземплярCorporateActionClient1.ClientId = СтрокаДанных.ClientId;
			СтруктураКоллекции = ВебСервисыСервер.СтруктураДляСозданияКоллекции("ArrayOfCorporateActionClientSecurity1",
			"CorporateActionClientSecurity1", Неопределено);
			КоллекцияЦБКлиентов = ВебСервисыСервер.СоздатьИЗаполнитьКоллекциюОбъектаXDTO(Фабрика,
											СтрокаДанных, ПространствоИмен, СтруктураКоллекции);
			ЭкземплярCorporateActionClient1.Установить("CorporateActionClientSecurityCollection", КоллекцияЦБКлиентов);
			
			ТипЭкземпляра = Фабрика.Тип(ПространствоИмен, "ClientWtrc");
			ЭкземплярClientWtrc = Фабрика.Создать(ТипЭкземпляра);
			ЗаполнитьЗначенияСвойств(ЭкземплярClientWtrc, СтрокаДанных,
				"ClientId, DepoAccountFrom, DepoSectionFrom, DepoAccountTo, DepoSectionTo");
			
			ТипОсновнойКоллекции = Фабрика.Тип(ПространствоИмен, "AddClientToCorporateActionWtrc");
			
			ЭкземплярAddClientToCorporateActionWtrc = Фабрика.Создать(ТипОсновнойКоллекции);
			ЭкземплярAddClientToCorporateActionWtrc.clientProfile	= ЭкземплярCorporateActionClient1;
			ЭкземплярAddClientToCorporateActionWtrc.depoProfile		= ЭкземплярClientWtrc;
			ЭкземплярAddClientToCorporateActionWtrc.reference		= СокрЛП(ПараметрыWebСервиса.РеференсКД);
			ЭкземплярAddClientToCorporateActionWtrc.deadLineDateInstruction	= ПараметрыWebСервиса.ДатаОкончанияПриемаПоручений1_5;
			ЭкземплярAddClientToCorporateActionWtrc.emailSubject	= ПараметрыWebСервиса.ЗаголовокСообщения;
			ЭкземплярAddClientToCorporateActionWtrc.emailBody		= ПараметрыWebСервиса.ТекстСообщения;
			ЭкземплярAddClientToCorporateActionWtrc.secName 		= ПараметрыWebСервиса.НаименованиеЦБ;
			ЭкземплярAddClientToCorporateActionWtrc.externalMessageId = УникальныйИдентификатор;
			
			ТипОсновнойКоллекции.Проверить(ЭкземплярAddClientToCorporateActionWtrc);
			Прокси.AddClientToCorporateActionWtrc(ЭкземплярAddClientToCorporateActionWtrc);
			
			ОпубликованоУспешно = Истина;
			
		Исключение
			ОпубликованоУспешно = Ложь;
			ИнформацияОбОшибке = ИнформацияОбОшибке();
			ПодробноеПредставлениеОшибки = "Ошибка при вызове Web-сервиса AddClientToCorporateActionWtrc. "
				+ ПодробноеПредставлениеОшибки(ИнформацияОбОшибке);
			ЗаписьЖурналаРегистрации(мИмяСобытияУведомлениеОКД, УровеньЖурналаРегистрации.Ошибка,,, ПодробноеПредставлениеОшибки);
		КонецПопытки;
	КонецЦикла;

	Возврат ОпубликованоУспешно;
	
КонецФункции

Функция РезультатОтправкиУведомленияПоВозвратуЧастиНалога(ТаблицаКлиентов, РезультатЗапросаПоДокументуКД,
	ЗаголовокСообщения, ТекстСообщения, УникальныйИдентификатор, ВидКД) Экспорт

	ВыборкаДокументов = РезультатЗапросаПоДокументуКД.Выбрать();
	ВыборкаДокументов.Следующий();
	
	Попытка	
		Прокси				= ВебСервисыПовтИсп.ПолучитьПроксиСУДК();
		ПространствоИмен	= Прокси.ТочкаПодключения.Интерфейс.URIПространстваИмен;
		Фабрика				= Прокси.ФабрикаXDTO;
			
		СтруктураКоллекции	= ВебСервисыСервер.СтруктураДляСозданияКоллекции("ArrayOfCorporateActionClientSecurity1",
			"CorporateActionClientSecurity1", Неопределено);
		СтруктураКоллекции	= ВебСервисыСервер.СтруктураДляСозданияКоллекции("ArrayOfCorporateActionClient1",
			"CorporateActionClient1", СтруктураКоллекции, "CorporateActionClientSecurityCollection");
		КоллекцияКлиентов	= ВебСервисыСервер.СоздатьИЗаполнитьКоллекциюОбъектаXDTO(Фабрика, ТаблицаКлиентов,
			ПространствоИмен, СтруктураКоллекции);
		
		ТипОсновнойКоллекции = Фабрика.Тип(ПространствоИмен, "CreateCorporateActionTrec");		
		ЭкземплярCorporateActionTrec = Фабрика.Создать(ТипОсновнойКоллекции);
		ЗаполнитьЗначенияСвойств(ЭкземплярCorporateActionTrec, ВыборкаДокументов); 
		ЭкземплярCorporateActionTrec.Установить("clientsCollection", КоллекцияКлиентов);
		
		ЭкземплярCorporateActionTrec.emailSubject		= ЗаголовокСообщения;
		ЭкземплярCorporateActionTrec.emailBody			= ТекстСообщения;
		ЭкземплярCorporateActionTrec.externalMessageId	= УникальныйИдентификатор;
		ЭкземплярCorporateActionTrec.type 				= ВидКД;
		
		ТипОсновнойКоллекции.Проверить(ЭкземплярCorporateActionTrec);
		Прокси.CreateCorporateActionTrec(ЭкземплярCorporateActionTrec);
		
		ОпубликованоУспешно = Истина;
		
	Исключение
		ОпубликованоУспешно = Ложь;
		ИнформацияОбОшибке = ИнформацияОбОшибке();
		ПодробноеПредставлениеОшибки = ПодробноеПредставлениеОшибки(ИнформацияОбОшибке);
		ЗаписьЖурналаРегистрации(мИмяСобытияУведомлениеОКД, УровеньЖурналаРегистрации.Ошибка,,, ПодробноеПредставлениеОшибки);
	КонецПопытки;
	
	Возврат ОпубликованоУспешно;
	
КонецФункции

// Вызывает метод ws для отправки информационного уведомления в кабинет клиента и на e-mail клиента
//
// Параметры:
//	ИдентификаторыКлиентов - массив строк, содержащий коды загрузки контрагентов по классификатору "Клиенты"
//	ЗаголовокСообщения - строка, тема сообщения эл.почты
//	ТекстСообщения - строка, тело сообщения эл.почты
//	УникальныйИдентификатор - строка, УИД документа
Функция РезультатОтправкиУведомленияИнформационного(ИдентификаторыКлиентов,	ЗаголовокСообщения, ТекстСообщения,
	УникальныйИдентификатор) Экспорт

	Попытка
		Прокси = ВебСервисыПовтИсп.ПолучитьПроксиСУДК();
		ПространствоИмен = Прокси.ТочкаПодключения.Интерфейс.URIПространстваИмен;
		Фабрика = Прокси.ФабрикаXDTO;
		
		ТипОсновнойКоллекции = Фабрика.Тип(ПространствоИмен, "SendEmailAboutCorporateActionToClients");
		ЭкземплярSendEmail = Фабрика.Создать(ТипОсновнойКоллекции);
		
		ТипСпискаКлиентов = Фабрика.Тип(ПространствоИмен, "ArrayOfString");
		МассивИД = Фабрика.Создать(ТипСпискаКлиентов);
		
		Для Каждого Ид Из ИдентификаторыКлиентов Цикл
			МассивИД.string.Добавить(СокрЛП(Ид));
		КонецЦикла;
		
		ЭкземплярSendEmail.clientsCollection	= МассивИД;
		ЭкземплярSendEmail.emailSubject			= ЗаголовокСообщения;
		ЭкземплярSendEmail.emailBody			= ТекстСообщения;
