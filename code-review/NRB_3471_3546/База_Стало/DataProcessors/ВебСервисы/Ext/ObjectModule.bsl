		ТипОсновнойКоллекции.Проверить(ЭкземплярSendEmail);
		Прокси.SendEmailAboutCorporateActionToClients(ЭкземплярSendEmail);
		
		ОпубликованоУспешно = Истина;
		
	Исключение
		ОпубликованоУспешно = Ложь;
		ИнформацияОбОшибке = ИнформацияОбОшибке();
		ПодробноеПредставлениеОшибки = ПодробноеПредставлениеОшибки(ИнформацияОбОшибке);
		ЗаписьЖурналаРегистрации(мИмяСобытияУведомлениеОКД, УровеньЖурналаРегистрации.Ошибка,,, ПодробноеПредставлениеОшибки);
	КонецПопытки;
	
	Возврат ОпубликованоУспешно;
	
КонецФункции

