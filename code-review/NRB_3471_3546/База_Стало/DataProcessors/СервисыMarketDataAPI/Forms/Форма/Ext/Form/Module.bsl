&НаКлиенте
Функция НовыеПараметрыФормыНастроек()
	
	ПараметрыФормыНастроек = Новый Структура;
	ПараметрыФормыНастроек.Вставить("ИмяНастроекСервиса", ИмяНастроекСервиса);
	
	Возврат ПараметрыФормыНастроек;
	
КонецФункции

&НаКлиенте
Процедура УстановитьИмяНастроекСервиса()
	
	ПредставлениеВидаОперации = Элементы.ВидОперации.СписокВыбора.НайтиПоЗначению(Объект.ВидОперации).Представление;
	Если СтрНайти(ПредставлениеВидаОперации, "RuData") > 0 Тогда
		ИмяНастроекСервиса = "НастройкиИнтерфакс";
		ИмяВнешнегоСервиса = "Интерфакс";
	ИначеЕсли СтрНайти(ПредставлениеВидаОперации, "NSD") > 0 Тогда
		ИмяНастроекСервиса = "НастройкиНРД";
		ИмяВнешнегоСервиса = "НРД";
	ИначеЕсли СтрНайти(ПредставлениеВидаОперации, "CBonds") > 0 Тогда
		ИмяНастроекСервиса = "НастройкиCBonds";
		ИмяВнешнегоСервиса = "CBonds";
	Иначе
		ИмяНастроекСервиса = Неопределено;
		ИмяВнешнегоСервиса = Неопределено;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция ТекущийОбъект()
	
	Если мТекущийОбъектНаСервере = Неопределено Тогда
		мТекущийОбъектНаСервере = РеквизитФормыВЗначение("Объект");
	КонецЕсли;
	
	Возврат мТекущийОбъектНаСервере;
	
КонецФункции

&НаКлиенте
Процедура УправлениеФормой()
	
	УстановитьИмяНастроекСервиса();
	
	СтраницаГруппаСтраницы = Элементы.ЗагрузкаСтатикиЦенныхБумагПоСпискуISIN;
	
	Элементы.Настройки.Видимость								 = Ложь;
	Элементы.ГруппаДополнительныхПараметровЗагрузки.Видимость	 = Ложь;
	Элементы.ГруппаДополнительныхКоманд.Видимость				 = Ложь;
	Элементы.ГруппаОтбораISINДляЗагрузкиЦенныхБумаг.Видимость	 = Истина;
	
	Настройки	= MarketData.НастройкиСервисаAPI(ИмяНастроекСервиса);
	ПериодИзНастройки = MarketData.ПериодОтчета(Неопределено, Настройки);
	
	Если Объект.ВидОперации = "Загрузка котировок за период" Тогда
		Элементы.ГруппаКотировки.Видимость = Истина;
		Элементы.ГруппаКотировкиCBonds.Видимость = Ложь;
		Элементы.ГруппаНКДCBonds.Видимость = Ложь;
		
		СтраницаГруппаСтраницы = Элементы.СтраницаЗагрузкиКотировок;
		Элементы.Настройки.Видимость = Истина;
		
		Объект.ДатаНачала = ПериодИзНастройки.ДатаНачала;
		Объект.ДатаОкончания = ПериодИзНастройки.ДатаОкончания;
		
	ИначеЕсли Объект.ВидОперации = "Загрузка статики ценных бумаг по списку ISIN" Тогда
		
		СтраницаГруппаСтраницы = Элементы.ЗагрузкаСтатикиЦенныхБумагПоСпискуISIN;
		Элементы.ГруппаДополнительныхПараметровЗагрузки.Видимость = Истина;
		Элементы.ГруппаДополнительныхКоманд.Видимость = Истина;
		
		Объект.ДатаНачала = Дата(1, 1, 1);
		Объект.ДатаОкончания = Объект.ДатаНачала;
		
	ИначеЕсли Объект.ВидОперации = "Загрузка курсов валют" Тогда
		
		СтраницаГруппаСтраницы = Элементы.ЗагрузкаКурсовВалют;
		Элементы.ГруппаОтбораISINДляЗагрузкиЦенныхБумаг.Видимость = Ложь;
		
		Объект.ДатаНачала = ПериодИзНастройки.ДатаНачала;
		Объект.ДатаОкончания = ПериодИзНастройки.ДатаОкончания;
		Объект.ЗагрузитьКурсыВалют = Истина;
		
	ИначеЕсли Объект.ВидОперации = "НРД Загрузка котировок за период" Тогда
		Элементы.ГруппаКотировки.Видимость = Ложь;
		Элементы.ГруппаКотировкиCBonds.Видимость = Ложь;
		Элементы.ГруппаНКДCBonds.Видимость = Ложь;
		
		СтраницаГруппаСтраницы = Элементы.СтраницаЗагрузкиКотировок;
		Элементы.Настройки.Видимость = Истина;
		
		Объект.ДатаНачала = ПериодИзНастройки.ДатаНачала;
		Объект.ДатаОкончания = ПериодИзНастройки.ДатаОкончания;
		
	ИначеЕсли Объект.ВидОперации = "CBonds Загрузка котировок за период" Тогда
		Элементы.ГруппаКотировки.Видимость = Ложь;
		Элементы.ГруппаКотировкиCBonds.Видимость = Истина;
		Элементы.ГруппаНКДCBonds.Видимость = Ложь;
		
		СтраницаГруппаСтраницы = Элементы.СтраницаЗагрузкиКотировок;
		Элементы.Настройки.Видимость = Истина;
		
		Объект.ДатаНачала = ПериодИзНастройки.ДатаНачала;
		Объект.ДатаОкончания = ПериодИзНастройки.ДатаОкончания;
		
	ИначеЕсли Объект.ВидОперации = "CBonds Загрузка НКД за период" Тогда
		Элементы.ГруппаКотировки.Видимость = Ложь;
		Элементы.ГруппаКотировкиCBonds.Видимость = Ложь;
		Элементы.ГруппаНКДCBonds.Видимость = Истина;
		
		СтраницаГруппаСтраницы = Элементы.СтраницаЗагрузкиКотировок;
		Элементы.Настройки.Видимость = Ложь;
		
		Объект.ДатаНачала = ПериодИзНастройки.ДатаНачала;
		Объект.ДатаОкончания = ПериодИзНастройки.ДатаОкончания;
		Объект.ЗагрузитьНКДCBonds = Истина;
		
	Иначе
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Страница " + Объект.ВидОперации + " не существует!");
	КонецЕсли;
	
	Элементы.ГруппаСтраницы.ТекущаяСтраница = СтраницаГруппаСтраницы;
	
КонецПроцедуры

&НаКлиенте
Функция ПолучитьСписокОперацийДляВыполнения()
	
	СписокОпераций = Новый СписокЗначений;
	
	Если Объект.ВидОперации = "Загрузка котировок за период" Тогда
		
		ПолучитьСписокОперацийДляВыполненияRuData(СписокОпераций);
		
	ИначеЕсли Объект.ВидОперации = "Загрузка статики ценных бумаг по списку ISIN" Тогда
		
		СписокОпераций.Добавить("ЗагрузкаСтатикиЦенныхБумагПоСпискуISIN", Объект.ВидОперации);
		
	ИначеЕсли Объект.ВидОперации = "Загрузка курсов валют" Тогда
		
		Если Объект.ЗагрузитьКурсыВалют Тогда
			СписокОпераций.Добавить("ЗагрузкаКурсовВалют", Объект.ВидОперации);
		КонецЕсли;
		
	ИначеЕсли Объект.ВидОперации = "НРД Загрузка котировок за период" Тогда
		
		СписокОпераций.Добавить("ЗагрузитьКотировкиТорговыхПлощадокНРД", "Загрузка котировок торговых площадок НРД.");
		
	ИначеЕсли Объект.ВидОперации = "CBonds Загрузка котировок за период" Тогда
		
		ПолучитьСписокОперацийДляВыполненияCBonds(СписокОпераций);
		
	ИначеЕсли Объект.ВидОперации = "CBonds Загрузка НКД за период" Тогда
		
		Если Объект.ЗагрузитьНКДCBonds Тогда
			СписокОпераций.Добавить("ЗагрузитьКупоныCBonds", Объект.ВидОперации);
		КонецЕсли;
		
	Иначе
		
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Операций " + Объект.ВидОперации + " не существует!");
		
	КонецЕсли;
	
	Возврат СписокОпераций;
	
КонецФункции

