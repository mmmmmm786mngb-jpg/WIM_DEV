&НаСервере
Процедура ЗагрузкаКурсовВалют(ТабличныйДокумент, ПараметрыЗагрузки = Неопределено)
	
	Отказ = Ложь;
	ТекстОтказа = "";
	Если ВыводитьПолученнуюИнформациюВЛогеЗагрузки Тогда
		ЛогПолученныхДанных = Новый ТекстовыйДокумент;
	Иначе
		ЛогПолученныхДанных = Неопределено;
	КонецЕсли;
	
	ТабличныйДокумент.НачатьАвтогруппировкуСтрок(); 
	
	// Лог загрузки
	Макет = Обработки.СервисыMarketDataAPI.ПолучитьМакет("Лог");
	ОбластьВидИнформации = Макет.ПолучитьОбласть("ВидИнформации");
	ПериодЗагрузки = Формат(Объект.ДатаНачала, "ДФ=dd.MM.yyyy") + " - " + Формат(Объект.ДатаОкончания, "ДФ=dd.MM.yyyy");
	ОбластьВидИнформации.Параметры.ВидЗагружаемойИнформации = СтрШаблон(НСтр("ru ='Загрузка курсов валют за %1'"), ПериодЗагрузки);
	ТабличныйДокумент.Вывести(ОбластьВидИнформации, 0);
	
	////////////////////////////
	// Загрузка курсов валют
	
	МассивВалют = Новый Массив;
	Для Каждого ТекЭлемент Из СписокВалют Цикл
		Если ТекЭлемент.Пометка = Ложь Тогда
			Продолжить;
		КонецЕсли;
		МассивВалют.Добавить(ТекЭлемент.Значение);
	КонецЦикла;
	
	МассивБазовыхВалют = Новый Массив;
	Для Каждого ТекЭлемент Из СписокБазовыхВалют Цикл
		Если ТекЭлемент.Пометка = Ложь Тогда
			Продолжить;
		КонецЕсли;
		МассивБазовыхВалют.Добавить(ТекЭлемент.Значение);
	КонецЦикла;
	
	Период = Новый СтандартныйПериод(Объект.ДатаНачала, Объект.ДатаОкончания);
	MarketData.ЗагрузитьКурсыВалютИнтерфакс(Период,
		МассивБазовыхВалют, МассивВалют, Отказ, ТекстОтказа, ТабличныйДокумент, ЛогПолученныхДанных);
	
	// Если отказ, то выводим ошибку.
	Если Отказ Тогда
		ОбластьОшибкаЗагрузки = Макет.ПолучитьОбласть("ОшибкаЗагрузки");
		ОбластьОшибкаЗагрузки.Параметры.ТекстОтказа = ТекстОтказа;
		ТабличныйДокумент.Вывести(ОбластьОшибкаЗагрузки);
	КонецЕсли;
	
	// Выводим информацию полученную из Интерфакс
	Если ВыводитьПолученнуюИнформациюВЛогеЗагрузки Тогда
		ВывестиВЛогеЗагрузкиИнформациюИзСервиса(ЛогПолученныхДанных, ТабличныйДокумент, Макет);
	КонецЕсли;
	
	ТабличныйДокумент.ЗакончитьАвтогруппировкуСтрок();
	
КонецПроцедуры

&НаСервере
Процедура ЗагрузитьКупоныCBonds(ТабличныйДокумент, ПараметрыЗагрузки = Неопределено)
	
	ИмяДействия = "ЗагрузитьКупоныCBonds";
	ВидИсточника = ИмяДействия;
	Комментарий = "ru ='Загрузка НКД CBonds за %1'";
	
	Отказ = Ложь;
	ТекстОтказа = "";
	Если ВыводитьПолученнуюИнформациюВЛогеЗагрузки Тогда
		ЛогПолученныхДанных = Новый ТекстовыйДокумент;
	Иначе
		ЛогПолученныхДанных = Неопределено;
	КонецЕсли;
	
	ТабличныйДокумент.НачатьАвтогруппировкуСтрок();
	
	// Лог загрузки
	Макет = Обработки.СервисыMarketDataAPI.ПолучитьМакет("Лог");
	ОбластьВидИнформации = Макет.ПолучитьОбласть("ВидИнформации");
	ПериодЗагрузки = Формат(Объект.ДатаНачала, "ДФ=dd.MM.yyyy") + " - " + Формат(Объект.ДатаОкончания, "ДФ=dd.MM.yyyy");
	ОбластьВидИнформации.Параметры.ВидЗагружаемойИнформации = СтрШаблон(НСтр(Комментарий), ПериодЗагрузки);
	ТабличныйДокумент.Вывести(ОбластьВидИнформации, 0);
	
	////////////////////////////
	// Загрузка котировок
	
	Период = Новый СтандартныйПериод(Объект.ДатаНачала, Объект.ДатаОкончания);
	ПараметрыИсточника = Новый Структура;
	ПараметрыИсточника.Вставить("ИмяДействия"	, ИмяДействия);
	ПараметрыИсточника.Вставить("ВидИсточника"	, ВидИсточника);
	ПараметрыИсточника.Вставить("ТаблицаISIN"	, Объект.ЦенныеБумаги.Выгрузить());
	
	MarketData.ЗагрузитьНКДВнешнегоСервиса(ИмяНастроекСервиса, Период, ПараметрыИсточника,
		Отказ, ТекстОтказа, ТабличныйДокумент, ЛогПолученныхДанных);
	
	// Если отказ, то выводим ошибку.
	Если Отказ Тогда
		ОбластьОшибкаЗагрузки = Макет.ПолучитьОбласть("ОшибкаЗагрузки");
		ОбластьОшибкаЗагрузки.Параметры.ТекстОтказа = ТекстОтказа;
		ТабличныйДокумент.Вывести(ОбластьОшибкаЗагрузки);
	КонецЕсли;
	
	// Выводим информацию полученную из Внешнего сервиса
	Если ВыводитьПолученнуюИнформациюВЛогеЗагрузки Тогда
		ВывестиВЛогеЗагрузкиИнформациюИзСервиса(ЛогПолученныхДанных, ТабличныйДокумент, Макет);
	КонецЕсли;
	
	ТабличныйДокумент.ЗакончитьАвтогруппировкуСтрок();
	
КонецПроцедуры

