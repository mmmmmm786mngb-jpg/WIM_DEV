&НаСервере
Процедура ЗаполнитьISINНаСервере(РезультатОтбора)
	
	Если РезультатОтбора = Неопределено Тогда
		
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Заполнение ISIN отменено");
		
	Иначе
		
		КопироватьДанныеФормы(РезультатОтбора.ЦенныеБумаги, Объект.ЦенныеБумаги);
		
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Заполнение ISIN произведено");
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервереБезКонтекста
Процедура ЗагрузкаСтатикиЦенныхБумагПоСпискуISIN(ТабличныйДокумент, ПараметрыЗагрузки)
	
	Объект_ДатаНачала									 = ПараметрыЗагрузки.ДатаНачала;
	Объект_ДополнительныеСтатусыДляЗагрузки				 = ПараметрыЗагрузки.ДополнительныеСтатусыДляЗагрузки;
	Объект_ОбновитьЭмитентовВсехЗагружаемыхЦБ			 = ПараметрыЗагрузки.ОбновитьЭмитентовВсехЗагружаемыхЦБ;
	Объект_СоздатьОбновитьТолькоЭмитентов				 = ПараметрыЗагрузки.СоздатьОбновитьТолькоЭмитентов;
	Объект_ЦенныеБумаги									 = ПараметрыЗагрузки.ЦенныеБумаги;
	Объект_ОбновитьБумагиВНеактуальномСтатусе			 = ПараметрыЗагрузки.ОбновитьБумагиВНеактуальномСтатусе;
	
	Макет = Обработки.СервисыMarketDataAPI.ПолучитьМакет("Лог");
	ТабличныйДокумент.НачатьАвтогруппировкуСтрок();
	ДатаЗагрузки = ?(Объект_ДатаНачала <> '00010101', Объект_ДатаНачала, ТекущаяДатаСеанса());
	
	ОбластьСтрокаСервис = Макет.ПолучитьОбласть("СтрокаСервис");
	ОбластьВидИнформации = Макет.ПолучитьОбласть("ВидИнформации");
	ПериодЗагрузки = Формат(ДатаЗагрузки, "ДФ=dd.MM.yyyy");
	ОбластьВидИнформации.Параметры.ВидЗагружаемойИнформации
		= СтрШаблон(НСтр("ru ='Загрузка статики ценных бумаг по списку ISIN по данным из сервисов Интерфакс на %1.'"),
			ПериодЗагрузки);
	ТабличныйДокумент.Вывести(ОбластьВидИнформации, 0);
	
	ФильтрСтатусов = RuDataAPI.ФильтрПоАктуальнымСтатусамЦБ();
	Если ЗначениеЗаполнено(Объект_ДополнительныеСтатусыДляЗагрузки) Тогда
		ФильтрСтатусов = ФильтрСтатусов + ", " + СокрЛП(Объект_ДополнительныеСтатусыДляЗагрузки);
	КонецЕсли;
	
	ВходныеПараметры = Новый Структура;
	ЦенныеБумаги = Объект_ЦенныеБумаги.Выгрузить(, "ISIN");
	ISINs = ЦенныеБумаги.ВыгрузитьКолонку("ISIN");
	ВходныеПараметры.Вставить("ISINs", ISINs);
	ВходныеПараметры.Вставить("ДатаВремяОбновленияДанных", Объект_ДатаНачала);
	ВходныеПараметры.Вставить("ОбновитьБумагиВНеактуальномСтатусе", Объект_ОбновитьБумагиВНеактуальномСтатусе);
	ВходныеПараметры.Вставить("ОбновитьЭмитентовВсехЗагружаемыхЦБ", Объект_ОбновитьЭмитентовВсехЗагружаемыхЦБ);
	ВходныеПараметры.Вставить("СоздатьОбновитьТолькоЭмитентов", Объект_СоздатьОбновитьТолькоЭмитентов);
	ВходныеПараметры.Вставить("ФильтрСтатусовЦБ", ФильтрСтатусов);
		
	ОбластьСтрокаСервис.Параметры.СтрокаДанных = "Начало: " + ТекущаяДатаСеанса();
	ТабличныйДокумент.Вывести(ОбластьСтрокаСервис);
	
	УспешноеСозданиеОбновлениеЦенныхБумагИЭмитентов = RuDataAPI.СозданиеОбновлениеЦенныхБумагИЭмитентов(ВходныеПараметры);
	
	Если Не УспешноеСозданиеОбновлениеЦенныхБумагИЭмитентов Тогда
		ОбластьОшибкаЗагрузки = Макет.ПолучитьОбласть("ОшибкаЗагрузки");
		ОбластьОшибкаЗагрузки.Параметры.ТекстОтказа = "Данные не загружены, или загружены с ошибкой (см. журнал регистрации)";
		ТабличныйДокумент.Вывести(ОбластьОшибкаЗагрузки);
	КонецЕсли;
	ОбластьСтрокаСервис.Параметры.СтрокаДанных =
		"Завершение: ?успех = [" + УспешноеСозданиеОбновлениеЦенныхБумагИЭмитентов + "] " + ТекущаяДатаСеанса();
	ТабличныйДокумент.Вывести(ОбластьСтрокаСервис);
	
	ТабличныйДокумент.ЗакончитьАвтогруппировкуСтрок();
	
КонецПроцедуры

&НаСервере
Функция ПолучитьОтчетОЦеннойБумагеИзRudataAPIНаСервере()
	
	Если  Объект.ЦенныеБумаги.Количество() = 0 И Не ЗначениеЗаполнено(Объект.ДатаНачала) Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Укажите ISIN  и \ или Дату");
		Возврат Неопределено;
	КонецЕсли;
	
	ФильтрСтатусов = RuDataAPI.ФильтрПоАктуальнымСтатусамЦБ();
	Если ЗначениеЗаполнено(Объект.ДополнительныеСтатусыДляЗагрузки) Тогда
		ФильтрСтатусов = ФильтрСтатусов + ", " + СокрЛП(Объект.ДополнительныеСтатусыДляЗагрузки);
	КонецЕсли;
	
	ВходныеПараметры = Новый Структура;
	ЦенныеБумаги = Объект.ЦенныеБумаги.Выгрузить(, "ISIN");
	ISINs = ЦенныеБумаги.ВыгрузитьКолонку("ISIN");
	ВходныеПараметры.Вставить("ISINs", ISINs);
	ВходныеПараметры.Вставить("ДатаВремяОбновленияДанных", Объект.ДатаНачала);
	ВходныеПараметры.Вставить("ОбновитьБумагиВНеактуальномСтатусе", Объект.ОбновитьБумагиВНеактуальномСтатусе);
	ВходныеПараметры.Вставить("ФильтрСтатусовЦБ", ФильтрСтатусов);
	ВходныеПараметры.Вставить("ЭтоОтчет", Истина);
	
	ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Начало: "	 + ТекущаяДатаСеанса());
	ВыходныеПараметры = RuDataAPI.ДанныеДляСозданияОбновленияЦенныхБумаг(ВходныеПараметры);
	ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Завершение: " + ТекущаяДатаСеанса());
	
	Если ЗначениеЗаполнено(ВыходныеПараметры.ТаблицаДанныхЦБ) Тогда
		
		ТабличныйДокумент = ОбщегоНазначения.ДанныеТаблицыЗначенийВТабличныйДокументСКД(ВыходныеПараметры.ТаблицаДанныхЦБ);
		Возврат ТабличныйДокумент;
		
	Иначе
		Возврат Неопределено;
	КонецЕсли;
	
КонецФункции

