&НаКлиенте
Процедура ЗагрузитьДанные(Команда)
	
	Если ПроверитьЗаполнение() Тогда
		
		// Лог загрузки
		ТабличныйДокумент = Новый ТабличныйДокумент;
		ТабличныйДокумент.ОриентацияСтраницы = ОриентацияСтраницы.Портрет;
		ТабличныйДокумент.ОтображатьЗаголовки = Ложь;
		ТабличныйДокумент.ОтображатьСетку = Ложь;
		ТабличныйДокумент.ТолькоПросмотр = Истина;
		ВывестиШапку(ТабличныйДокумент);
		
		// Загрузка данных
		СписокОпераций = ПолучитьСписокОперацийДляВыполнения();
		ТекстСостояния = НСтр("ru = 'Выполняется загрузка данных из Внешнего сервиса'");
		Картинка = БиблиотекаКартинок.ЗапуститьОтдельныйСеансДляВыполненияРегламентныхЗаданий;
		
		ЗагрузитьДанныеПоОперации(ТабличныйДокумент, СписокОпераций, ТекстСостояния, Картинка);
		
		Состояние(ТекстСостояния, 100, , Картинка);
		
		// Вывести лог
		ТабличныйДокумент.Показать();
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗагрузитьДанныеПоОперации(ТабличныйДокумент, СписокОпераций, ТекстСостояния, Картинка)
	
	ЧислоСто = 100;
	ТекЗначение = 0;
	МаксимальноеЗначение = СписокОпераций.Количество();
	
	Для каждого ТекОперация Из СписокОпераций Цикл
		ПараметрыЗагрузки = Новый Структура;
		Если СтрНайти(ТекОперация.Значение, "Загрузить") > 0 Тогда
			Если Не ЗначениеЗаполнено(Объект.ДатаНачала) Тогда
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не указан период", , "Объект.ДатаНачала");
				Возврат;
			КонецЕсли;
			Если Не ЗначениеЗаполнено(Объект.ДатаОкончания) Тогда
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не указан период", , "Объект.ДатаОкончания");
				Возврат;
			КонецЕсли;
		КонецЕсли;
		Если СтрНайти(ТекОперация.Значение, "ЗагрузкаСтатикиЦенныхБумагПоСпискуISIN") > 0 Тогда
			ЗагружатьСтатику = ЗагрузитьДанныеПоСтатике(ПараметрыЗагрузки);
			Если Не ЗагружатьСтатику Тогда
				Возврат;
			КонецЕсли;
		КонецЕсли;
		
		Состояние(ТекстСостояния, Окр(ЧислоСто * ТекЗначение / МаксимальноеЗначение), ТекОперация.Представление, Картинка);
		ТекЗначение = ТекЗначение + 1;
		
		Выполнить(ТекОперация.Значение + "(ТабличныйДокумент, ПараметрыЗагрузки)");
		
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Функция ЗагрузитьДанныеПоСтатике(ПараметрыЗагрузки)
	
	Если Объект.ЦенныеБумаги.Количество() = 0 Тогда
		ТекстВопроса = "Будут загружены все Ценные бумаги (Время загрузки: 2 - 3 часа). Продолжить операцию?";
		Ответ = Вопрос(ТекстВопроса, РежимДиалогаВопрос.ДаНетОтмена, 60);
		Если Ответ <> КодВозвратаДиалога.Да Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не выбраны ISIN", , "Объект.ЦенныеБумаги");
			Возврат Ложь;
		КонецЕсли;
	КонецЕсли;
	ПараметрыЗагрузки.Вставить("ДатаНачала"									, Объект.ДатаНачала);
	ПараметрыЗагрузки.Вставить("ДополнительныеСтатусыДляЗагрузки"			, Объект.ДополнительныеСтатусыДляЗагрузки);
	ПараметрыЗагрузки.Вставить("ОбновитьЭмитентовВсехЗагружаемыхЦБ"			, Объект.ОбновитьЭмитентовВсехЗагружаемыхЦБ);
	ПараметрыЗагрузки.Вставить("СоздатьОбновитьТолькоЭмитентов"				, Объект.СоздатьОбновитьТолькоЭмитентов);
	ПараметрыЗагрузки.Вставить("ЦенныеБумаги"								, Объект.ЦенныеБумаги);
	ПараметрыЗагрузки.Вставить("ОбновитьБумагиВНеактуальномСтатусе"			, Объект.ОбновитьБумагиВНеактуальномСтатусе);
	Возврат Истина;
	
КонецФункции

