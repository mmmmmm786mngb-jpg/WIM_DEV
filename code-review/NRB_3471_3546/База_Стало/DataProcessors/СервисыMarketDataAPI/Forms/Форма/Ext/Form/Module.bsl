&НаСервере
Процедура ВывестиШапку(ТабличныйДокумент)
	
	Макет = Обработки.СервисыMarketDataAPI.ПолучитьМакет("Лог");
	ОбластьШапка = Макет.ПолучитьОбласть("Шапка");
	ОбластьШапка.Параметры.ДатаЗагрузки = Формат(ТекущаяДатаСеанса(), "ДЛФ=DD");
	ОбластьШапка.Параметры.ВнешнийСервис = ИмяВнешнегоСервиса;
	ТабличныйДокумент.Вывести(ОбластьШапка, 0);
	
КонецПроцедуры

&НаСервере
Процедура ВывестиВЛогеЗагрузкиИнформациюИзСервиса(ЛогПолученныхДанных, ТабличныйДокумент, Макет)
	
	Если ТипЗнч(ЛогПолученныхДанных) = Тип("ТекстовыйДокумент") Тогда
		
		ОбластьШапкаВнешнийСервис = Макет.ПолучитьОбласть("ШапкаСервис");
		ТабличныйДокумент.Вывести(ОбластьШапкаВнешнийСервис, 0);
		
		ОбластьГруппировки = Макет.ПолучитьОбласть("ОбластьГруппировки");
		ТабличныйДокумент.Вывести(ОбластьГруппировки, 1, , Ложь);
		
		Для НомерСтроки = 1 По ЛогПолученныхДанных.КоличествоСтрок() Цикл
			
			ТекущаяСтрока = ЛогПолученныхДанных.ПолучитьСтроку(НомерСтроки);
			
			ОбластьСтрокаВнешнийСервис = Макет.ПолучитьОбласть("СтрокаСервис");
			ОбластьОписаниеВнешнийСервис = Макет.ПолучитьОбласть("ОписаниеСервис");
			
			// Форматируем строку XML
			Если СтрНайти(ТекущаяСтрока, "<?xml") > 0 Тогда
				Попытка
					ЧтениеXML = Новый ЧтениеXML;
					ЧтениеXML.УстановитьСтроку(ТекущаяСтрока);
					
					ПостроительDOM = Новый ПостроительDOM;
					ДокументDOM = ПостроительDOM.Прочитать(ЧтениеXML);
					
					// Здесь как раз и содержится явное указание 1С отформатировать XML при записи
					ЗаписьXML = Новый ЗаписьXML;
					ЗаписьXML.УстановитьСтроку(Новый ПараметрыЗаписиXML(, , Истина, Ложь));
					
					ЗаписьDOM = Новый ЗаписьDOM;
					ЗаписьDOM.Записать(ДокументDOM, ЗаписьXML);
					ОтформатированныйТекст = ЗаписьXML.Закрыть();
					
					ОбластьСтрокаВнешнийСервис.Параметры.СтрокаДанных = ОтформатированныйТекст;
					ТабличныйДокумент.Вывести(ОбластьСтрокаВнешнийСервис, 3, , Ложь);
				Исключение
					ОбластьСтрокаВнешнийСервис.Параметры.СтрокаДанных = ТекущаяСтрока;
					ТабличныйДокумент.Вывести(ОбластьСтрокаВнешнийСервис, 3, , Ложь);
				КонецПопытки;
			Иначе
				ОбластьОписаниеВнешнийСервис.Параметры.СтрокаДанных = ТекущаяСтрока;
				ТабличныйДокумент.Вывести(ОбластьОписаниеВнешнийСервис, 2);
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЕсли;
	
КонецПроцедуры

