
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если Параметры.Свойство("ВидАктива") Тогда
		ВидАктива = Параметры.ВидАктива;
	КонецЕсли;
	
	Если Параметры.Свойство("ИмяНастроекСервиса") И ЗначениеЗаполнено(Параметры.ИмяНастроекСервиса) Тогда
		ИмяНастроекСервиса = Параметры.ИмяНастроекСервиса;
	Иначе
		Отказ = Истина;
		Возврат;
	КонецЕсли;
	
	ЗаполнитьПоляКотировок();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ВыбратьИЗакрытьКоманда(Команда)
	ВыбратьИЗакрыть();
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура ЗаполнитьПоляКотировок()
	
	Отказ = Ложь;
	ТекстОтказа = "";
	
	Попытка
		
		ПараметрыМетода = Новый Структура();
		Если ИмяНастроекСервиса = "НастройкиИнтерфакс" Тогда
			ПараметрыМетода.Вставить("count", 9999999);
			ПолученныеДанные = RuDataAPI.ДанныеМетода_V2_Info_Fields(ПараметрыМетода, Отказ, ТекстОтказа);
		ИначеЕсли ИмяНастроекСервиса = "НастройкиНРД" Тогда
			ПолученныеДанные = ПолучитьПоляКотировокНРД(ПараметрыМетода, Отказ, ТекстОтказа);
		ИначеЕсли ИмяНастроекСервиса = "НастройкиCBonds" Тогда
			ПараметрыМетода.Вставить("ВидАктива", ВидАктива);
			ПолученныеДанные = ПолучитьПоляКотировокCBonds(ПараметрыМетода, Отказ, ТекстОтказа);
		Иначе
			ПолученныеДанные = Новый Массив;
		КонецЕсли;
		Если Отказ Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(
				"Не удалось получить поля котировок [" + ИмяНастроекСервиса + "]" + Символы.ПС + ТекстОтказа);
			Возврат;
		КонецЕсли;
		
		ТипыСтрокой = Новый Соответствие;
		ТипыСтрокой.Вставить("System.String", "Строка");
		ТипыСтрокой.Вставить("System.Int64", "Число");
		ТипыСтрокой.Вставить("System.Double", "Число");
		ТипыСтрокой.Вставить("System.DateTim", "Дата");
		
		Для Каждого ПолеКотировки Из ПолученныеДанные Цикл
			
			Если ПолеКотировки["activity"] <> 1 Тогда
				Продолжить;
			КонецЕсли;
			ТипСтрокой = ТипыСтрокой.Получить(ПолеКотировки["ctype"]);
			Если Не ЗначениеЗаполнено(ТипСтрокой) Тогда
				Продолжить;
			КонецЕсли;
			
			НоваяСтрока = Поля.Добавить();
			НоваяСтрока.Идентификатор = ПолеКотировки["name"];
			НоваяСтрока.Наименование = ПолеКотировки["full_name_rus"];
			НоваяСтрока.Описание = ПолеКотировки["comment_rus"];
			НоваяСтрока.Тип = ТипСтрокой;
			
		КонецЦикла;
		
		Поля.Сортировать("Идентификатор");
		
	Исключение
		ТекстОтказа = СтрШаблон("Не удалось получить поля котировок [%1]. Техническая информация: %2",
			ИмяНастроекСервиса, ОписаниеОшибки());
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстОтказа);
	КонецПопытки;
	
КонецПроцедуры

&НаСервере
Функция ПолучитьПоляКотировокНРД(ПараметрыМетода, Отказ, ТекстОтказа)
	
	ЛогПолученныхДанных = Неопределено;
	// --> filter
	МассивУсловий = Новый Массив;
	// Условие 1: Isin
	МассивISINs = Новый Массив;
	МассивISINs.Добавить("MHY8565N3002");
	УсловиеISIN = Новый Структура("_S_in", МассивISINs);
	Условие1 = Новый Структура("isin", УсловиеISIN);
	МассивУсловий.Добавить(Условие1);
	// Условие 2: Категории ценных бумаг
	Условие2 = Новый Структура("security_category", "акции");
	МассивУсловий.Добавить(Условие2);
	filter = Новый Структура("_S_and", МассивУсловий);
	ПараметрыМетода.Вставить("filter", filter);
	// <-- filter
	ПараметрыМетода.Вставить("limit", 1);
	ПолученныеДанныеНРД = NSDAPI.ДанныеМетода_getValuation(ПараметрыМетода,
		Отказ, ТекстОтказа, ЛогПолученныхДанных, , , "Выбор полей котировки");
	ПолученныеДанные = Новый Массив;
	Если ЗначениеЗаполнено(ПолученныеДанныеНРД) Тогда
		ДанныеКотировки = ПолученныеДанныеНРД[0];
		Для Каждого ПолеКотировки Из ДанныеКотировки Цикл
			Если ОбщегоНазначенияКлиентСервер.ЭтоЧисло(ПолеКотировки.Значение) Тогда
				НовоеПоле = Новый Структура;
				НовоеПоле.Вставить("activity"		, 1);
				НовоеПоле.Вставить("ctype"			, "System.Int64");
				НовоеПоле.Вставить("name"			, ПолеКотировки.Ключ);
				НовоеПоле.Вставить("full_name_rus"	, ПолеКотировки.Ключ);
				НовоеПоле.Вставить("comment_rus"	, ПолеКотировки.Ключ);
				ПолученныеДанные.Добавить(НовоеПоле);
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	Возврат ПолученныеДанные;
	
КонецФункции

&НаКлиенте
Процедура ПоляКотировокВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	ВыбратьИЗакрыть();
	
КонецПроцедуры

&НаКлиенте
Процедура ВыбратьИЗакрыть()
	
	ВыделенныеСтроки = Элементы.Поля.ВыделенныеСтроки;
	ВыбранныеДанные = ВыбранныеДанные(ВыделенныеСтроки);
	Если ЗначениеЗаполнено(ВыбранныеДанные) Тогда
		Закрыть(ВыбранныеДанные);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция ВыбранныеДанные(ИдентификаторыВыделенныхСтрок)
	
	Результат = Новый Массив;
	Для Каждого Идентификатор Из ИдентификаторыВыделенныхСтрок Цикл
		Строка = Поля.НайтиПоИдентификатору(Идентификатор);
		Если Не ЗначениеЗаполнено(Строка.Идентификатор) Тогда
			Продолжить;
		КонецЕсли;
		ЭлементРезультата = Новый Структура("Идентификатор, Наименование, Описание, Тип");
		ЗаполнитьЗначенияСвойств(ЭлементРезультата, Строка);
		Результат.Добавить(ЭлементРезультата);
	КонецЦикла;
	Возврат Результат;
	
КонецФункции

&НаСервере
Функция ПолучитьПоляКотировокCBonds(ПараметрыМетода, Отказ, ТекстОтказа)
	
	Если Отказ Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	ТЗ_Поля = Новый ТаблицаЗначений;
	ТЗ_Поля.Колонки.Добавить("activity"			, ОбщегоНазначения.ОписаниеТипаЧисло(1));
	ТЗ_Поля.Колонки.Добавить("name"				, ОбщегоНазначения.ОписаниеТипаСтрока(150));
	ТЗ_Поля.Колонки.Добавить("full_name_rus"	, ОбщегоНазначения.ОписаниеТипаСтрока(150));
	ТЗ_Поля.Колонки.Добавить("comment_rus"		, ОбщегоНазначения.ОписаниеТипаСтрока(150));
	ТЗ_Поля.Колонки.Добавить("ctype"			, ОбщегоНазначения.ОписаниеТипаСтрока(150));
	
	МакетСтруктуры = Обработки.СервисыMarketDataAPI.ПолучитьМакет("ТорговыеПлощадки_ПоляCBonds");
	
	// Чтение данных
	ОбластьЧтения = МакетСтруктуры.Области["Таблица_" + ПараметрыМетода.ВидАктива];
	КоличествоКолонок = ОбластьЧтения.Право;
	НачальнаяКолонка = ОбластьЧтения.Лево;
	
	Для Индекс = ОбластьЧтения.Верх По ОбластьЧтения.Низ Цикл
		
		// Получаем данные
		ДанныеСтроки = ПолучитьСтрокуВВидеСтруктуры(МакетСтруктуры, НачальнаяКолонка, Индекс, КоличествоКолонок);
		
		Если ЗначениеЗаполнено(ДанныеСтроки.Поле1) Тогда
			НоваяСтрока = ТЗ_Поля.Добавить();
			НоваяСтрока.activity		 = 1;
			НоваяСтрока.name			 = ДанныеСтроки.Поле1;
			НоваяСтрока.full_name_rus	 = ДанныеСтроки.Поле1;
			НоваяСтрока.ctype			 = ДанныеСтроки.Поле3;
			НоваяСтрока.comment_rus		 = ДанныеСтроки.Поле2;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат ТЗ_Поля;
	
КонецФункции

&НаСервере
Функция ПолучитьСтрокуВВидеСтруктуры(ТабличныйДокумент, НачальнаяКолонка, Индекс, КоличествоКолонок)
	
	НомерСтроки = Формат(Индекс, "ЧГ=");
	СтрокаТабличногоДокумента = ТабличныйДокумент.ПолучитьОбласть("R" + НомерСтроки + "C1:R" + НомерСтроки + "C" + КоличествоКолонок);
	
	ДанныеСтроки = Новый Структура;
	НомерКолонки = 1;
	Для Номер = НачальнаяКолонка По СтрокаТабличногоДокумента.ШиринаТаблицы Цикл
		ЗначениеЯчейки = СтрокаТабличногоДокумента.Область("R1C" + Номер).Текст;
		ДанныеСтроки.Вставить("Поле" + НомерКолонки, СокрЛП(ЗначениеЯчейки));
		НомерКолонки = НомерКолонки + 1;
	КонецЦикла;
	
	Возврат ДанныеСтроки;
	
КонецФункции

#КонецОбласти