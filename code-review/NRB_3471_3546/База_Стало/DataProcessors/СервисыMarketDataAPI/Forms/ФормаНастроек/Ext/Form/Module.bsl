&НаКлиенте
Процедура УправлениеФормой()
	
	Если ИмяНастроекСервиса = "НастройкиИнтерфакс" Тогда
		
		Элементы.СтраницаНастройкиТорговыхПлощадокСПБ.Видимость		 = Истина;
		Элементы.СтраницаНастройкиПрочихТорговыхПлощадок.Видимость	 = Истина;
		Элементы.НеПроцентныеПоля.Видимость							 = Истина;
		Элементы.СтраницаНастройкиТорговыхПлощадокНРД.Видимость		 = Ложь;
		Элементы.ГруппаГлобальнаяНастройкаБиржа.Видимость			 = Ложь;
		
		Элементы.СтраницаНастройкиТорговыхПлощадокСПБ.Заголовок		 = "Торговые площадки СПБ";
		Элементы.СтрТорговыеПлощадкиСПБ_Котировки.Заголовок			 = "Котировки СПБ";
		Элементы.СтраницаТорговыеПлощадкиСПБ.Заголовок				 = "Торговые площадки СПБ (по убыванию приоритета)";
		
	КонецЕсли;
	Если ИмяНастроекСервиса = "НастройкиНРД" Тогда
		
		Элементы.СтраницаНастройкиТорговыхПлощадокСПБ.Видимость		 = Ложь;
		Элементы.СтраницаНастройкиПрочихТорговыхПлощадок.Видимость	 = Ложь;
		Элементы.НеПроцентныеПоля.Видимость							 = Ложь;
		Элементы.СтраницаНастройкиТорговыхПлощадокНРД.Видимость		 = Истина;
		Элементы.ГруппаГлобальнаяНастройкаБиржа.Видимость			 = Истина;
		
	КонецЕсли;
	Если ИмяНастроекСервиса = "НастройкиCBonds" Тогда
		
		Элементы.СтраницаНастройкиТорговыхПлощадокСПБ.Видимость		 = Истина;
		Элементы.СтраницаНастройкиПрочихТорговыхПлощадок.Видимость	 = Истина;
		Элементы.НеПроцентныеПоля.Видимость							 = Истина;
		Элементы.СтраницаНастройкиТорговыхПлощадокНРД.Видимость		 = Ложь;
		Элементы.ГруппаГлобальнаяНастройкаБиржа.Видимость			 = Ложь;
		
		Элементы.СтраницаНастройкиТорговыхПлощадокСПБ.Заголовок		 = "Торговые площадки [индикативные котировки]";
		Элементы.СтрТорговыеПлощадкиСПБ_Котировки.Заголовок			 = "Котировки [индикативные]";
		Элементы.СтраницаТорговыеПлощадкиСПБ.Заголовок				 = "Торговые площадки [индикативные котировки] (по убыванию приоритета)";
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура НастроитьТабличныеЧасти(Настройки)
	
	ТипХранилище = Тип("ХранилищеЗначения");
	
	Если Настройки.Свойство("ТЗ_ТорговыеПлощадкиСПБ") И ЗначениеЗаполнено(Настройки.ТЗ_ТорговыеПлощадкиСПБ) Тогда
		ТЗ_ТорговыеПлощадкиСПБ = XMLЗначение(ТипХранилище, Настройки.ТЗ_ТорговыеПлощадкиСПБ).Получить();
		ТорговыеПлощадкиСПБ_Котировки.Загрузить(ТЗ_ТорговыеПлощадкиСПБ);
	КонецЕсли;
	
	Если Настройки.Свойство("ТЗ_ПоляКотировокСПБ") И ЗначениеЗаполнено(Настройки.ТЗ_ПоляКотировокСПБ) Тогда
		ТЗ_ПоляКотировокСПБ = XMLЗначение(ТипХранилище, Настройки.ТЗ_ПоляКотировокСПБ).Получить();
		ТорговыеПлощадкиСПБ_Котировки_Поля.Загрузить(ТЗ_ПоляКотировокСПБ);
	КонецЕсли;
	
	Если Настройки.Свойство("ТЗ_ПрочиеТорговыеПлощадки") И ЗначениеЗаполнено(Настройки.ТЗ_ПрочиеТорговыеПлощадки) Тогда
		ТЗ_ПрочиеТорговыеПлощадки = XMLЗначение(ТипХранилище, Настройки.ТЗ_ПрочиеТорговыеПлощадки).Получить();
		ПрочиеТорговыеПлощадки_Котировки.Загрузить(ТЗ_ПрочиеТорговыеПлощадки);
	КонецЕсли;
	
	Если Настройки.Свойство("ТЗ_ПоляКотировок") И ЗначениеЗаполнено(Настройки.ТЗ_ПоляКотировок) Тогда
		ТЗ_ПоляКотировок = XMLЗначение(ТипХранилище, Настройки.ТЗ_ПоляКотировок).Получить();
		ПрочиеТорговыеПлощадки_Котировки_Поля.Загрузить(ТЗ_ПоляКотировок);
	КонецЕсли;
	
	Если Настройки.Свойство("ТЗ_ТорговыеПлощадкиНРД") И ЗначениеЗаполнено(Настройки.ТЗ_ТорговыеПлощадкиНРД) Тогда
		ТЗ_ТорговыеПлощадкиНРД = XMLЗначение(ТипХранилище, Настройки.ТЗ_ТорговыеПлощадкиНРД).Получить();
		ТорговыеПлощадкиНРД_Котировки.Загрузить(ТЗ_ТорговыеПлощадкиНРД);
	КонецЕсли;
	
	Если Настройки.Свойство("ТЗ_ПоляКотировокНРД") И ЗначениеЗаполнено(Настройки.ТЗ_ПоляКотировокНРД) Тогда
		ТЗ_ПоляКотировокНРД = XMLЗначение(ТипХранилище, Настройки.ТЗ_ПоляКотировокНРД).Получить();
		ТорговыеПлощадкиНРД_Котировки_Поля.Загрузить(ТЗ_ПоляКотировокНРД);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПараметрыГлобальныеРедактирование(ИмяПараметра)
	
	#Если ВебКлиент Тогда
		ПоказатьПредупреждение(, НСтр("ru = 'В веб-клиенте редактирование невозможно.'"));
