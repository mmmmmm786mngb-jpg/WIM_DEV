
#Область ОбработчикиСобытийФормы

// BSLLS:CognitiveComplexity-off

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если Параметры.Свойство("ИмяНастроекСервиса") И ЗначениеЗаполнено(Параметры.ИмяНастроекСервиса) Тогда
		ИмяНастроекСервиса = Параметры.ИмяНастроекСервиса;
	Иначе
		Отказ = Истина;
		Возврат;
	КонецЕсли;
	Настройки	= MarketData.НастройкиСервисаAPI(ИмяНастроекСервиса);
	
	// Период загрузки
	Если Настройки.Свойство("ТипПериодаЗагрузкиКотировок") Тогда
		ТипПериодаЗагрузкиКотировок = Настройки.ТипПериодаЗагрузкиКотировок;
	Иначе
		ТипПериодаЗагрузкиКотировок = Перечисления.ПериодыДней.ПредыдущийДень;
	КонецЕсли;
	
	// Не процентные поля котировок
	Если Настройки.Свойство("НеПроцентныеПоля") Тогда
		НеПроцентныеПоля = Настройки.НеПроцентныеПоля;
	Иначе
		НеПроцентныеПоля = "vol,val";
	КонецЕсли;
	
	// Не процентные поля котировок
	Если Настройки.Свойство("КромеЦенныхБумагRU") Тогда
		КромеЦенныхБумагRU = Настройки.КромеЦенныхБумагRU;
	Иначе
		КромеЦенныхБумагRU = Ложь;
	КонецЕсли;
	
	// Ограничение на количество ценных бумаг
	Если Настройки.Свойство("ОграничениеПоКоличествуISIN") Тогда
		ОграничениеПоКоличествуISIN = Настройки.ОграничениеПоКоличествуISIN;
	Иначе
		ОграничениеПоКоличествуISIN = 0;
	КонецЕсли;
	
	// Биржа
	Если Настройки.Свойство("ЗагружатьКотировкиПоПервичнойБирже") Тогда
		ЗагружатьКотировкиПоПервичнойБирже = Настройки.ЗагружатьКотировкиПоПервичнойБирже;
	Иначе
		ЗагружатьКотировкиПоПервичнойБирже = Ложь;
	КонецЕсли;
	
	// Прочий поиск площадок
	Если Настройки.Свойство("ОбязательныйВыборПлощадкиСогласноСортировке") Тогда
		ОбязательныйВыборПлощадкиСогласноСортировке = Настройки.ОбязательныйВыборПлощадкиСогласноСортировке;
	Иначе
		ОбязательныйВыборПлощадкиСогласноСортировке = Ложь;
	КонецЕсли;
	Если Настройки.Свойство("ОбязательныйВыборПлощадкиПолеСортировки") Тогда
		ОбязательныйВыборПлощадкиПолеСортировки = Настройки.ОбязательныйВыборПлощадкиПолеСортировки;
	Иначе
		ОбязательныйВыборПлощадкиПолеСортировки = "";
	КонецЕсли;
	
	// Список выбора полей котировок
	MarketData.ДопустимыеГрафыКотировок(ИменаГрафКотировок);
	Для Каждого ИмяГрафыКотировки Из ИменаГрафКотировок Цикл
		Элементы.ПоляКотировокКолонкаКотировки.СписокВыбора.Добавить(ИмяГрафыКотировки.Значение,
			ИмяГрафыКотировки.Представление);
		Элементы.ПоляКотировокСПБКолонкаКотировки.СписокВыбора.Добавить(ИмяГрафыКотировки.Значение,
			ИмяГрафыКотировки.Представление);
		Элементы.ПоляКотировокНРДКолонкаКотировки.СписокВыбора.Добавить(ИмяГрафыКотировки.Значение,
			ИмяГрафыКотировки.Представление);
	КонецЦикла;
	
	НастроитьТабличныеЧасти(Настройки);
	
	ОбновитьСписокРегламентныхЗаданий();
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	УправлениеФормой();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыТорговыеПлощадкиКотировки

// ТОРГОВЫЕ ПЛОЩАДКИ НРД (КОТИРОВКИ)

&НаКлиенте
Процедура ПоляКотировокНРДКолонкаКотировкиПриИзменении(Элемент)
	
	СтрокаТЧ = Элементы.ТорговыеПлощадкиНРД_Котировки_Поля.ТекущиеДанные;
	Если СтрокаТЧ = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	НайденноеЗначение = ИменаГрафКотировок.НайтиПоЗначению(СтрокаТЧ.КолонкаКотировки);
	Если НайденноеЗначение = Неопределено Тогда
		СтрокаТЧ.КолонкаКотировкиСиноним = "";
	Иначе
		СтрокаТЧ.КолонкаКотировкиСиноним = НайденноеЗначение.Представление;
	КонецЕсли;
	
КонецПроцедуры

// ТОРГОВЫЕ ПЛОЩАДКИ СПБ (КОТИРОВКИ)

&НаКлиенте
Процедура ПоляКотировокСПБКолонкаКотировкиПриИзменении(Элемент)
	
	СтрокаТЧ = Элементы.ТорговыеПлощадкиСПБ_Котировки_Поля.ТекущиеДанные;
	Если СтрокаТЧ = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	НайденноеЗначение = ИменаГрафКотировок.НайтиПоЗначению(СтрокаТЧ.КолонкаКотировки);
	Если НайденноеЗначение = Неопределено Тогда
		СтрокаТЧ.КолонкаКотировкиСиноним = "";
	Иначе
		СтрокаТЧ.КолонкаКотировкиСиноним = НайденноеЗначение.Представление;
	КонецЕсли;
	
КонецПроцедуры

// ПРОЧИЕ ТОРГОВЫЕ ПЛОЩАДКИ (КОТИРОВКИ)

&НаКлиенте
Процедура ПоляКотировокКолонкаКотировкиПриИзменении(Элемент)
	
