	Если НайденноеЗначение = Неопределено Тогда
		СтрокаТЧ.КолонкаКотировкиСиноним = "";
	Иначе
		СтрокаТЧ.КолонкаКотировкиСиноним = НайденноеЗначение.Представление;
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыСписокРегламентныхЗаданий

&НаКлиенте
Процедура СписокРегламентныхЗаданийПриАктивизацииСтроки(Элемент)
	ТекущаяСтрока = Элементы.СписокРегламентныхЗаданий.ТекущаяСтрока;
	Если ТекущаяСтрока = Неопределено Тогда
		Возврат;
	КонецЕсли;
		
	ТекущиеДанные = СписокРегламентныхЗаданий.НайтиПоИдентификатору(ТекущаяСтрока);
	Если ТекущиеДанные <> Неопределено Тогда
		СвойстваПоследнегоВыполненного = ПолучитьСвойстваПоследнегоВыполненного(ТекущиеДанные.Идентификатор);
		ТекущиеДанные.Состояние = СвойстваПоследнегоВыполненного.Состояние;
		ТекущиеДанные.Выполнялось = СвойстваПоследнегоВыполненного.Выполнялось;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура СписокРегламентныхЗаданийПередНачаломИзменения(Элемент, Отказ)
	Отказ = Истина;
	ВыделенныеСтроки = Элементы.СписокРегламентныхЗаданий.ВыделенныеСтроки;
	Если ВыделенныеСтроки.Количество() > 0 Тогда
		
		Строка = СписокРегламентныхЗаданий.НайтиПоИдентификатору(ВыделенныеСтроки.Получить(0));
		
		СтруктураПараметров = Новый Структура;
		Ид = Строка.Идентификатор;
		СтруктураПараметров.Вставить("ИдентификаторЗадания", Ид);
		
		ОписаниеОповещенияОЗакрытии =
			Новый ОписаниеОповещения("СписокРегламентныхЗаданийПередНачаломИзмененияЗавершение", ЭтотОбъект);
		
		ОткрытьФорму(ПолучитьПолноеИмяФормы("ДиалогРегламентногоЗадания"), СтруктураПараметров,
			ЭтотОбъект, , , , ОписаниеОповещенияОЗакрытии, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
		
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура СписокРегламентныхЗаданийПередНачаломИзмененияЗавершение(РезультатЗакрытия, ДополнительныеПараметры) Экспорт
	Если РезультатЗакрытия <> Неопределено Тогда
		ОбновитьСписокРегламентныхЗаданий();
	КонецЕсли;
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура СохранитьНастройки(Команда)
	
	Отказ = Ложь;
	ПроверитьВозможностьСохраненияНастроекПередЗаписьюНаСервере(Отказ);
	Если Отказ Тогда
		Возврат;
	КонецЕсли;
	СохранитьНастройкиНаСервере();
	Закрыть();
	
КонецПроцедуры

&НаСервере
Процедура ПроверитьВозможностьСохраненияНастроекПередЗаписьюНаСервере(Отказ)
	
	// 1. Проверяем заполнение полей котировок
	Для Индекс = 0 По ПрочиеТорговыеПлощадки_Котировки_Поля.Количество() - 1 Цикл
		СтрокаПолейКотировок = ПрочиеТорговыеПлощадки_Котировки_Поля.Получить(Индекс);
		Если Не ЗначениеЗаполнено(СтрокаПолейКотировок.КолонкаКотировки) Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не заполнено значение колонки котировки", ,
				"ПрочиеТорговыеПлощадки_Котировки_Поля[" + Индекс + "].КолонкаКотировки", , Отказ);
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура СохранитьНастройкиНаСервере()
	
	СтруктураНастроек = Новый Структура();
	СтруктураНастроек.Вставить("ТЗ_ТорговыеПлощадкиСПБ",
		XMLСтрока(Новый ХранилищеЗначения(ТорговыеПлощадкиСПБ_Котировки.Выгрузить())));
	СтруктураНастроек.Вставить("ТЗ_ПоляКотировокСПБ",
		XMLСтрока(Новый ХранилищеЗначения(ТорговыеПлощадкиСПБ_Котировки_Поля.Выгрузить())));
	СтруктураНастроек.Вставить("ТЗ_ПрочиеТорговыеПлощадки",
		XMLСтрока(Новый ХранилищеЗначения(ПрочиеТорговыеПлощадки_Котировки.Выгрузить())));
	СтруктураНастроек.Вставить("ТЗ_ПоляКотировок",
		XMLСтрока(Новый ХранилищеЗначения(ПрочиеТорговыеПлощадки_Котировки_Поля.Выгрузить())));
	СтруктураНастроек.Вставить("ТЗ_ТорговыеПлощадкиНРД",
		XMLСтрока(Новый ХранилищеЗначения(ТорговыеПлощадкиНРД_Котировки.Выгрузить())));
	СтруктураНастроек.Вставить("ТЗ_ПоляКотировокНРД",
		XMLСтрока(Новый ХранилищеЗначения(ТорговыеПлощадкиНРД_Котировки_Поля.Выгрузить())));
	
	СтруктураНастроек.Вставить("ТипПериодаЗагрузкиКотировок"					, ТипПериодаЗагрузкиКотировок);
	СтруктураНастроек.Вставить("НеПроцентныеПоля"								, НеПроцентныеПоля);
	СтруктураНастроек.Вставить("КромеЦенныхБумагRU"								, КромеЦенныхБумагRU);
	СтруктураНастроек.Вставить("ОграничениеПоКоличествуISIN"					, ОграничениеПоКоличествуISIN);
	СтруктураНастроек.Вставить("ЗагружатьКотировкиПоПервичнойБирже"				, ЗагружатьКотировкиПоПервичнойБирже);
	СтруктураНастроек.Вставить("ОбязательныйВыборПлощадкиПолеСортировки"		, ОбязательныйВыборПлощадкиПолеСортировки);
	СтруктураНастроек.Вставить("ОбязательныйВыборПлощадкиСогласноСортировке"	, ОбязательныйВыборПлощадкиСогласноСортировке);
	
	MarketData.УстановитьНастройкиСервиса(ИмяНастроекСервиса, СтруктураНастроек);
	ОбновитьПовторноИспользуемыеЗначения();
	
КонецПроцедуры

&НаКлиенте
Процедура ГлобальнаяНастройкаПроксиАдрес(Команда)
	
	ПараметрыГлобальныеРедактирование("ПроксиСерверАдрес");
	
КонецПроцедуры

&НаКлиенте
Процедура ГлобальнаяНастройкаПроксиПорт(Команда)
	
	ПараметрыГлобальныеРедактирование("ПроксиСерверПорт");
	
КонецПроцедуры

&НаКлиенте
Процедура ПодобратьТорговуюПлощадкуИзКлассификатора(Команда)
	
	ПараметрыФормыНастроек = Новый Структура;
	ПараметрыФормыНастроек.Вставить("ИмяНастроекСервиса", ИмяНастроекСервиса);
	
	ОписаниеОповещения = Новый ОписаниеОповещения("ПодобратьТорговуюПлощадкуИзКлассификатораЗавершение", ЭтотОбъект);
	ИмяФормыОткрытия = "Обработка.СервисыMarketDataAPI.Форма.ВыборПрочейТорговойПлощадки";
	ОткрытьФорму(ИмяФормыОткрытия, ПараметрыФормыНастроек, ЭтотОбъект, УникальныйИдентификатор, , , ОписаниеОповещения);
	
КонецПроцедуры

&НаКлиенте
Процедура ПодобратьТорговуюПлощадкуИзКлассификатораЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	Если Не ЗначениеЗаполнено(Результат) Тогда
		Возврат;
	КонецЕсли;
	
	Для Каждого ЭлементРезультата Из Результат Цикл
		
		ПараметрыПоиска = Новый Структура("Идентификатор", ЭлементРезультата.Идентификатор);
		НайденныеСтроки = ПрочиеТорговыеПлощадки_Котировки.НайтиСтроки(ПараметрыПоиска);
		Если ЗначениеЗаполнено(НайденныеСтроки) Тогда
			Продолжить;
		КонецЕсли;
		
		НоваяСтрока = ПрочиеТорговыеПлощадки_Котировки.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, ЭлементРезультата);
		Если ИмяНастроекСервиса = "НастройкиCBonds" Тогда
			НоваяСтрока.Биржа = ПредопределенноеЗначение("Справочник.ИнформационноАналитическиеСистемы.CBonds");
		Иначе
			НоваяСтрока.Биржа = ПредопределенноеЗначение("Справочник.ИнформационноАналитическиеСистемы.Интерфакс");
		КонецЕсли;
		Модифицированность = Истина;
		
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ПодобратьПолеКотировкиИзКлассификатора(Команда)
	
	ПараметрыФормыНастроек = Новый Структура;
	ПараметрыФормыНастроек.Вставить("ИмяНастроекСервиса", ИмяНастроекСервиса);
	Если ИмяНастроекСервиса = "НастройкиCBonds" Тогда
		ПараметрыФормыНастроек.Вставить("ВидАктива", "Облигации");
	Иначе
		ПараметрыФормыНастроек.Вставить("ВидАктива", "");
	КонецЕсли;
	
	ОписаниеОповещения = Новый ОписаниеОповещения("ПодобратьПолеКотировкиИзКлассификатораЗавершение", ЭтотОбъект);
	ИмяФормыОткрытия = "Обработка.СервисыMarketDataAPI.Форма.ВыборПолейПрочейТорговойПлощадки";
	ОткрытьФорму(ИмяФормыОткрытия, ПараметрыФормыНастроек, ЭтотОбъект, УникальныйИдентификатор, , , ОписаниеОповещения);
	
КонецПроцедуры

&НаКлиенте
Процедура ПодобратьПолеКотировкиИзКлассификатораЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	Если Не ЗначениеЗаполнено(Результат) Тогда
		Возврат;
	КонецЕсли;
	
	ТекДанные = Элементы.ПрочиеТорговыеПлощадки_Котировки.ТекущиеДанные;
	Если ТекДанные = Неопределено Или Не ЗначениеЗаполнено(ТекДанные.Идентификатор) Тогда
		Возврат;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(ТекДанные.Биржа) Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не выбрана Биржа.");
		Возврат;
	КонецЕсли;
	
	Для Каждого ЭлементРезультата Из Результат Цикл
		
		Отбор = Новый Структура("Идентификатор, ИдентификаторБиржи",
			ЭлементРезультата.Идентификатор, 0);
		Если ПрочиеТорговыеПлощадки_Котировки_Поля.НайтиСтроки(Отбор).Количество() = 0 Тогда
			
			НоваяСтрока = ПрочиеТорговыеПлощадки_Котировки_Поля.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, ЭлементРезультата);
			НоваяСтрока.ИдентификаторБиржи = 0;
			
			Модифицированность = Истина;
		КонецЕсли;
		
	КонецЦикла;
	
	Элементы.ПрочиеТорговыеПлощадки_Котировки_Поля.Обновить();
	
КонецПроцедуры

&НаКлиенте
Процедура ПодобратьТорговуюПлощадкуСПБИзКлассификатора(Команда)
	
	ПараметрыФормыНастроек = Новый Структура;
	ПараметрыФормыНастроек.Вставить("ИмяНастроекСервиса", ИмяНастроекСервиса);
	
	ОписаниеОповещения = Новый ОписаниеОповещения("ПодобратьТорговуюПлощадкуСПБИзКлассификатораЗавершение", ЭтотОбъект);
	ИмяФормыОткрытия = "Обработка.СервисыMarketDataAPI.Форма.ВыборПрочейТорговойПлощадки";
	ОткрытьФорму(ИмяФормыОткрытия, ПараметрыФормыНастроек, ЭтотОбъект, УникальныйИдентификатор, , , ОписаниеОповещения);
	
КонецПроцедуры

&НаКлиенте
Процедура ПодобратьТорговуюПлощадкуСПБИзКлассификатораЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	Если Не ЗначениеЗаполнено(Результат) Тогда
		Возврат;
	КонецЕсли;
	
	Для Каждого ЭлементРезультата Из Результат Цикл
		
		ПараметрыПоиска = Новый Структура("Идентификатор", ЭлементРезультата.Идентификатор);
		НайденныеСтроки = ТорговыеПлощадкиСПБ_Котировки.НайтиСтроки(ПараметрыПоиска);
		Если ЗначениеЗаполнено(НайденныеСтроки) Тогда
			Продолжить;
		КонецЕсли;
		
		НоваяСтрока = ТорговыеПлощадкиСПБ_Котировки.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, ЭлементРезультата);
		Если ИмяНастроекСервиса = "НастройкиCBonds" Тогда
			НоваяСтрока.Биржа = ПредопределенноеЗначение("Справочник.ИнформационноАналитическиеСистемы.CBonds");
		Иначе
			НоваяСтрока.Биржа = ПредопределенноеЗначение("Справочник.Биржи.GPBEX");
		КонецЕсли;
		Модифицированность = Истина;
		
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ПодобратьПолеКотировкиСПБИзКлассификатора(Команда)
	
	ПараметрыФормыНастроек = Новый Структура;
	ПараметрыФормыНастроек.Вставить("ИмяНастроекСервиса", ИмяНастроекСервиса);
	Если ИмяНастроекСервиса = "НастройкиCBonds" Тогда
		ПараметрыФормыНастроек.Вставить("ВидАктива", "Облигации");
	Иначе
		ПараметрыФормыНастроек.Вставить("ВидАктива", "");
	КонецЕсли;
	
	ОписаниеОповещения = Новый ОписаниеОповещения("ПодобратьПолеКотировкиСПБИзКлассификатораЗавершение", ЭтотОбъект);
	ИмяФормыОткрытия = "Обработка.СервисыMarketDataAPI.Форма.ВыборПолейПрочейТорговойПлощадки";
	ОткрытьФорму(ИмяФормыОткрытия, ПараметрыФормыНастроек, ЭтотОбъект, УникальныйИдентификатор, , , ОписаниеОповещения);
	
КонецПроцедуры

&НаКлиенте
Процедура ПодобратьПолеКотировкиСПБИзКлассификатораЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	Если Не ЗначениеЗаполнено(Результат) Тогда
		Возврат;
	КонецЕсли;
	
	ТекДанные = Элементы.ТорговыеПлощадкиСПБ_Котировки.ТекущиеДанные;
	Если ТекДанные = Неопределено Или Не ЗначениеЗаполнено(ТекДанные.Идентификатор) Тогда
		Возврат;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(ТекДанные.Биржа) Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не выбрана Биржа.");
		Возврат;
	КонецЕсли;
	
	Для Каждого ЭлементРезультата Из Результат Цикл
		
		Отбор = Новый Структура("Идентификатор, ИдентификаторБиржи",
			ЭлементРезультата.Идентификатор, 0);
		Если ТорговыеПлощадкиСПБ_Котировки_Поля.НайтиСтроки(Отбор).Количество() = 0 Тогда
			
			НоваяСтрока = ТорговыеПлощадкиСПБ_Котировки_Поля.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, ЭлементРезультата);
			НоваяСтрока.ИдентификаторБиржи = 0;
			
			Модифицированность = Истина;
		КонецЕсли;
		
	КонецЦикла;
	
	Элементы.ТорговыеПлощадкиСПБ_Котировки_Поля.Обновить();
	
КонецПроцедуры

&НаКлиенте
Процедура ПодобратьПолеКотировкиНРДИзКлассификатора(Команда)
	
	ПараметрыФормыНастроек = Новый Структура;
	ПараметрыФормыНастроек.Вставить("ИмяНастроекСервиса", ИмяНастроекСервиса);
	
	ОписаниеОповещения = Новый ОписаниеОповещения("ПодобратьПолеКотировкиНРДИзКлассификатораЗавершение", ЭтотОбъект);
	ИмяФормыОткрытия = "Обработка.СервисыMarketDataAPI.Форма.ВыборПолейПрочейТорговойПлощадки";
	ОткрытьФорму(ИмяФормыОткрытия, ПараметрыФормыНастроек, ЭтотОбъект, УникальныйИдентификатор, , , ОписаниеОповещения);
	
КонецПроцедуры

&НаКлиенте
Процедура ПодобратьПолеКотировкиНРДИзКлассификатораЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	Если Не ЗначениеЗаполнено(Результат) Тогда
		Возврат;
	КонецЕсли;
	
	Для Каждого ЭлементРезультата Из Результат Цикл
		
		Отбор = Новый Структура("Идентификатор, ИдентификаторБиржи",
			ЭлементРезультата.Идентификатор, "0");
		Если ТорговыеПлощадкиНРД_Котировки_Поля.НайтиСтроки(Отбор).Количество() = 0 Тогда
			
			НоваяСтрока = ТорговыеПлощадкиНРД_Котировки_Поля.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, ЭлементРезультата);
			НоваяСтрока.ИдентификаторБиржи = "0";
			
			Модифицированность = Истина;
		КонецЕсли;
		
	КонецЦикла;
	
	Элементы.ТорговыеПлощадкиНРД_Котировки_Поля.Обновить();
	
КонецПроцедуры

