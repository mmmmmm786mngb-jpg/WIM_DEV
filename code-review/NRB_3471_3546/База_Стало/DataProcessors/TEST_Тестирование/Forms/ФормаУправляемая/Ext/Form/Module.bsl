&НаСервереБезКонтекста
Функция ФормыОбъектаМетаданных(ПолноеИмяОбъектаМетаданных)
	
	МетаданныеОбъекта = Метаданные.НайтиПоПолномуИмени(ПолноеИмяОбъектаМетаданных);
	Возврат Новый Структура("ОсновнаяФормаДляВыбора, ОсновнаяФормаОбъекта",МетаданныеОбъекта.ОсновнаяФормаДляВыбора.Имя,МетаданныеОбъекта.ОсновнаяФормаОбъекта.Имя);
	
КонецФункции

&НаКлиенте
Процедура ОткрытьФормуВыбранногоОбъектаВРежимеТестирования(ПолноеИмяОбъектаМетаданных)
	
	Если Не ЗначениеЗаполнено(ПолноеИмяОбъектаМетаданных) Тогда 
		ВызватьИсключение "Неверное значение параметра";	
	КонецЕсли;
	ФормыОбъектаМетаданных = ФормыОбъектаМетаданных(ПолноеИмяОбъектаМетаданных);
	ФормаВыбора = ПолучитьФорму(СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку("%1.Форма.%2",ПолноеИмяОбъектаМетаданных, ФормыОбъектаМетаданных.ОсновнаяФормаДляВыбора));
	ДокументСсылка = ФормаВыбора.ОткрытьМодально();
	Если Не ДокументСсылка = Неопределено Тогда
		ФормаОбъекта = ПолучитьФорму(СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку("%1.Форма.%2",ПолноеИмяОбъектаМетаданных, ФормыОбъектаМетаданных.ОсновнаяФормаОбъекта),
						Новый Структура("Ключ, Тестирование",ДокументСсылка, Истина));
		ФормаОбъекта.Заголовок = ФормаОбъекта.Заголовок + " [ТЕСТИРОВАНИЕ]";
		ФормаОбъекта.Открыть();
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ТОДокументОснованиеПриИзмененииНаСервере()

	ОбработкаОбъект = РеквизитФормыВЗначение("Объект");
	
	Объект.ТОНомер	= ОбработкаОбъект.ТОДокументОснование.Номер + "-1";
	Объект.ТОДата	= ОбработкаОбъект.ТОДокументОснование.Дата;
	Объект.ТОНомерДокументаОснования	= ОбработкаОбъект.ТОДокументОснование.Номер;
	Объект.ТОДатаДокументаОснования		= ОбработкаОбъект.ТОДокументОснование.Дата;
	Объект.ТОРегистрационнаяДата		= ОбработкаОбъект.ТОДокументОснование.Дата;
	
КонецПроцедуры

&НаСервере
Процедура СформироватьИсполнениеПорученияНаСервере()
	ОбработкаОбъект = РеквизитФормыВЗначение("Объект");
	ОбработкаОбъект.СформироватьИсполнениеПоручения(Объект.НеттоПоручение, Объект.КодОтчетаВышестоящегоДепозитария,
		Объект.ИсполненноеКоличествоЦБ, Объект.ДатаИсполнения);
КонецПроцедуры

&НаСервере
Процедура СформироватьТехОперациюНаСервере()
	ОбработкаОбъект = РеквизитФормыВЗначение("Объект");
	ОбработкаОбъект.СформироватьТехОперацию(Объект.ТОНомер, Объект.ТОДата,
		Объект.ТОНомерДокументаОснования, Объект.ТОДатаДокументаОснования,
		Объект.ТОДокументОснование,
		Объект.ТОТипОперации, Объект.ТОКодОперации, Объект.ТОПорядковыйНомерВнутриДня,
		Объект.ТОРегистрационнаяДата, Объект.ТОРегистрационныйНомер,
		Объект.ТОДатаИсполнения, Объект.ТОКодОтчетаНРД);
КонецПроцедуры

&НаСервере
Процедура ДобавитьЗаписьРССостоянияДокументовВФайловомШлюзеНаСервере()
	ОбработкаОбъект = РеквизитФормыВЗначение("Объект");
