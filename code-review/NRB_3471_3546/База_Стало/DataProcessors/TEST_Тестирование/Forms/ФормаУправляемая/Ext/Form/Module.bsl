#Область ЗагрузкаФайловДепозитария

&НаСервереБезКонтекста
Функция ПредопределенныеФайлыДепозитарияНаСервере()
	
	ОбработкаTEST_ФайлыНРД = Обработки.TEST_ФайлыНРД.Создать();
	Возврат ОбработкаTEST_ФайлыНРД.ДоступныеМакетыФайловНРД();
	
КонецФункции

&НаКлиенте
Процедура ЗаполнитьПредопределеннымиФайламиДепозитария(Команда)
	
	ПредопредленныеФайлыДепозитария = ПредопределенныеФайлыДепозитарияНаСервере();
	
	Для Каждого ФайлДепозитария Из ПредопредленныеФайлыДепозитария Цикл
		
		НоваяСтрока = ФайлыДепозитария.Добавить();
		НоваяСтрока.Представление = ФайлДепозитария.Ключ;
		НоваяСтрока.Значение = ФайлДепозитария.Значение;
		
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ФайлыДепозитарияПриАктивизацииСтроки(Элемент)
	
	Если Элементы.ФайлыДепозитария.ТекущиеДанные <> Неопределено Тогда
		
		СодержимоеФайла = Элементы.ФайлыДепозитария.ТекущиеДанные.Значение;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗагрузитьФайлВОбработкуЗагрузки(Команда)
	
	ФайлыДляЗагрузки = Новый Массив;
	ФайлыДляЗагрузки.Добавить(СодержимоеФайла);
	
	ПараметрыОткрытия = Новый Структура("ТестовыеXML", ФайлыДляЗагрузки);
	ОткрытьФорму("Обработка.ЗагрузкаКДИзДепозитария.Форма.Форма", ПараметрыОткрытия);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗагрузитьФайлВОбработкуЗагрузкиОтмеченные(Команда)
	
	Отбор = Новый Структура("Пометка", Истина);
	ОтмеченныеСтроки = ФайлыДепозитария.НайтиСтроки(Отбор);
	
	Если ОтмеченныеСтроки.Количество() Тогда
		
		ФайлыДляЗагрузки = Новый Массив;
		
		Для Каждого ТекСтрока Из ОтмеченныеСтроки Цикл
			ФайлыДляЗагрузки.Добавить(ТекСтрока.Значение);
		КонецЦикла;
		
		ПараметрыОткрытия = Новый Структура("ТестовыеXML", ФайлыДляЗагрузки);
		ОткрытьФорму("Обработка.ЗагрузкаКДИзДепозитария.Форма.Форма", ПараметрыОткрытия);
		
	Иначе
		
		ПоказатьПредупреждение(, "Не выбрано ни одного файла из истории");
		
	КонецЕсли;
	
КонецПроцедуры


&НаКлиенте
Процедура СохранитьВСписокФайловДепозитария(Команда)
	Оповещение = Новый ОписаниеОповещения("ПослеВводаСтроки", ЭтаФорма);
	ПоказатьВводСтроки(Оповещение, "", "Имя в списке");
КонецПроцедуры

&НаКлиенте
Процедура ПослеВводаСтроки(Строка, Параметры) Экспорт
	
	Если НЕ Строка = Неопределено Тогда
		
		НоваяСтрока = ФайлыДепозитария.Добавить();
		НоваяСтрока.Дата = ТекущаяДата();
		НоваяСтрока.Представление = Строка;
		НоваяСтрока.Значение = СодержимоеФайла;
		
	КонецЕсли;
	
КонецПроцедуры;

