Функция ОбработатьMeetingNotification(Чтение)
	Документ = СтруктураДокументаXML(Чтение);
	ПараметрыКД	= Новый Структура;
	
	// Параметры документа раскрытия
	// Параметры уведомления
	ПараметрыКД.Вставить("ВходящийДокументНомер", ЗначениеСвойства(Документ, "AppHdr.BizMsgIdr"));
	
	ВходящийДокументДата = СтроковыеФункцииКлиентСерверПереопределяемый.ДатаВремяИзСтроки(ЗначениеСвойства(Документ, "AppHdr.CreDt"));
	ПараметрыКД.Вставить("ВходящийДокументДата", ВходящийДокументДата + СмещениеСтандартногоВремени(ЧасовойПояс()));
	
	ПараметрыКД.Вставить("КДРеференсВходящий",	ЗначениеСвойства(Документ, "Document.MtgNtfctn.Mtg.MtgId"));
	ПараметрыКД.Вставить("ТипСобрания",	ЗначениеСвойства(Документ, "Document.MtgNtfctn.Mtg.TP"));
	ПараметрыКД.Вставить("КодОтчета",	ЗначениеСвойства(Документ, "AppHdr.BizSvc"));
	
	КлассСобрания = ЗначениеСвойства(Документ, "Document.MtgNtfctn.Mtg.Clssfctn.Cd");
	Если КлассСобрания <> Неопределено Тогда
		ПараметрыКД.Вставить("КлассСобрания", КлассСобрания);
	КонецЕсли;
	
	ПараметрыКД.Вставить("ДатаПроведенияСобрания",	Дата(1,1,1));
	ПараметрыКД.Вставить("ДатаОкончания",			Дата(1,1,1));
	ПараметрыКД.Вставить("Комментарий",				"");
	
	ДатаОкончанияПриемаИнструкцийНРД = СтроковыеФункцииКлиентСерверПереопределяемый.ДатаВремяИзСтроки(ЗначениеСвойства(Документ,
		"Document.MtgNtfctn.Vote.VoteDdln.Dt",
		"Document.MtgNtfctn.Vote.VoteDdln.DtTm"));
	ПараметрыКД.Вставить("ДатаОкончанияПриемаИнструкцийНРД", ДатаОкончанияПриемаИнструкцийНРД);
	
	Xtnsn = ЗначениеСвойства(Документ, "Document.MtgNtfctn.Xtnsn");
	Если ЗначениеЗаполнено(Xtnsn) И ТипЗнч(Xtnsn) = Тип("Массив") И Xtnsn.Количество() > 0 Тогда
		ЗаполнитьДатаОкончанияПриемаИнструкцийНРДИностранногоЭмитента(Документ.Document.MtgNtfctn.Xtnsn[0], ПараметрыКД);
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(ДатаОкончанияПриемаИнструкцийНРД)
		И ПараметрыКД.Свойство("ДатаОкончанияПриемаИнструкцийНРДИностранногоЭмитента")
		И ЗначениеЗаполнено(ПараметрыКД.ДатаОкончанияПриемаИнструкцийНРДИностранногоЭмитента) Тогда
		ДатаОкончанияПриемаИнструкцийНРД = ПараметрыКД.ДатаОкончанияПриемаИнструкцийНРДИностранногоЭмитента; 
	КонецЕсли;
	
	ДатаОкончанияПриемаИнструкцийВТБКБ = Документы.УведомлениеКлиентам.ДобавитьРабочийДень(ДатаОкончанияПриемаИнструкцийНРД, -2);
	СкопироватьВремя(ДатаОкончанияПриемаИнструкцийВТБКБ, ДатаОкончанияПриемаИнструкцийНРД);
	ПараметрыКД.Вставить("ДатаОкончанияПриемаИнструкцийВТБКБ", ДатаОкончанияПриемаИнструкцийВТБКБ);
	
	ПараметрыКД.Вставить("Комментарий", ЗначениеСвойства(Документ, "Document.MtgNtfctn.Vote.AddtlVtngRqrmnts"));
	
	ПараметрыКД.Вставить("ДатаФиксации", СтроковыеФункцииКлиентСерверПереопределяемый.ДатаВремяИзСтроки(ЗначениеСвойства(Документ,
		"Document.MtgNtfctn.EntitlmntSpcfctn.EntitlmntFxgDt.Dt",
		"Document.MtgNtfctn.EntitlmntSpcfctn.EntitlmntFxgDt.DtTm")));
		
	ПараметрыКД.Вставить("АдресВСетиИнтернет", АдресВСетиИнтернет(Документ, "Document.MtgNtfctn.Xtnsn"));
	МестоПроведенияСобрания = ЗначениеСвойства(Документ, "Document.MtgNtfctn.MtgDtls.Lctn.Adr.AdrLine");
	ПараметрыКД.Вставить("МестоПроведенияСобрания", МестоПроведенияСобрания);
	
	ПараметрыКД.Вставить("ДатаПроведенияСобрания", СтроковыеФункцииКлиентСерверПереопределяемый.ДатаВремяИзСтроки(ЗначениеСвойства(Документ,
		"Document.MtgNtfctn.MtgDtls.DtAndTm.Dt",
		"Document.MtgNtfctn.MtgDtls.DtAndTm.DtTm")));
		
	УзелScty = ЗначениеСвойства(Документ, "Document.MtgNtfctn.Scty");
	СтруктураПолей = Новый Структура("ISIN,Desc,КодНРД,ГосРегНомер,НомерСчетаДепо,FaceAmnt,Unit,BalTp,Dt,SfkpgPlc");
	ПараметрыКД.Вставить("МассивИнформацииОЦБ", МассивИнформацииОЦБ(УзелScty, СтруктураПолей));
	
	// Заполним вопросы
	Вопросы = ЗначениеСвойства(Документ, "Document.MtgNtfctn.Rsltn");
	Расширения = ЗначениеСвойства(Документ, "Document.MtgNtfctn.Xtnsn");
	НормальныеВопросы = Новый Массив;
	Если Вопросы <> Неопределено Тогда
		Для Каждого Вопрос Из Вопросы Цикл
			СтрВопроса = Новый Структура(
				"НомерВопроса, ДляИнформации, КуммулятивныйВопрос, ТекстВопроса, Коэффициент, ВариантыГолосования");
			СтрВопроса.НомерВопроса = Вопрос.IssrLabl;
			СтрВопроса.ТекстВопроса = Вопрос.Desc;
			СтрВопроса.ДляИнформации = Вопрос.ForInfOnly;
			СтрВопроса.КуммулятивныйВопрос = Ложь;
			СтрВопроса.Коэффициент = 1;
			
			//Определим кумулятивные вопросы
			Для Каждого Расширение Из Расширения Цикл
				СписокКум = ЗначениеСвойства(Расширение, "XtnsnEnvlp.XtnsnDt.VtAddRqrmnts");
				Если СписокКум <> Неопределено Тогда
					Для Каждого Вопр Из СписокКум Цикл
						Если Вопр.IssrLabl = Вопрос.IssrLabl Тогда
							// Нашли вопрос, берем признак кумулятивности
							СтрВопроса.КуммулятивныйВопрос = Булево(Вопр.CmltvVtngIndctr);
							Коэффициент = ЗначениеСвойства(Вопр, "MltplcFctr");
							Если Коэффициент <> Неопределено Тогда
								СтрВопроса.Коэффициент = Число(Коэффициент);
							КонецЕсли;
							Прервать;
						КонецЕсли;
					КонецЦикла;
				КонецЕсли;
			КонецЦикла;
			СтрВопроса.ВариантыГолосования = ИзДвоичнойВДесятичную(ДвоичнаяСтрокаВариантов(Вопрос.VoteInstrTp));
			НормальныеВопросы.Добавить(СтрВопроса);
		КонецЦикла;
	КонецЕсли;
	ПараметрыКД.Вставить("ВариантыГолосования",НормальныеВопросы);
	
	Для Каждого Расширение Из Расширения Цикл
		ВариантыГолосования = ЗначениеСвойства(Расширение, "XtnsnEnvlp.XtnsnDt.CorpActnOptnDtls");
		Если ВариантыГолосования = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		ДополнитьВариантыУчастияВКД(ВариантыГолосования, ПараметрыКД);
	КонецЦикла;
	
	ДобавитьДополнительнуюИнформацию(Xtnsn, ПараметрыКД);
	DocumentMtgNtfctn = ЗначениеСвойства(Документ, "Document.MtgNtfctn");
	ДобавитьДополнительнуюИнформацию(DocumentMtgNtfctn, ПараметрыКД);
	ДобавитьФиксированныеСтрокиВДополнительнуюИнформацию(ПараметрыКД);
	
	Если ПараметрыКД.МассивИнформацииОЦБ.Количество() = 0 Тогда
		Возврат Неопределено;
	Иначе
		Возврат ПараметрыКД;
	КонецЕсли;
КонецФункции

Функция ОбработатьMeetingCancelation(Чтение)
	Документ = СтруктураДокументаXML(Чтение);
	ПараметрыКД	= Новый Структура;
	
	// Параметры документа раскрытия
	// Параметры уведомления
	ПараметрыКД.Вставить("ВходящийДокументНомер", ЗначениеСвойства(Документ, "AppHdr.BizMsgIdr"));
	
	ВходящийДокументДата = СтроковыеФункцииКлиентСерверПереопределяемый.ДатаВремяИзСтроки(ЗначениеСвойства(Документ, "AppHdr.CreDt"));
	ПараметрыКД.Вставить("ВходящийДокументДата", ВходящийДокументДата + СмещениеСтандартногоВремени(ЧасовойПояс()));
	
	ПараметрыКД.Вставить("КДРеференсВходящий",	ЗначениеСвойства(Документ, "Document.MtgCxl.MtgRef.MtgId"));
	ПараметрыКД.Вставить("КодОтчета",	ЗначениеСвойства(Документ, "AppHdr.BizSvc"));
	
	КодПричиныОтмены = ЗначениеСвойства(Документ, "Document.MtgCxl.Rsn.CxlRsnCd.Cd");
	ПараметрыКД.Вставить("ПричинаОтмены", Справочники.ПричиныОтмены.НайтиПоКоду(КодПричиныОтмены));
	
	УзелScty = ЗначениеСвойства(Документ, "Document.MtgCxl.Scty");
	СтруктураПолей = Новый Структура("КодНРД,НомерСчетаДепо,Unit,BalTp,Dt");
	ПараметрыКД.Вставить("МассивИнформацииОЦБ", МассивИнформацииОЦБ(УзелScty, СтруктураПолей));
	
	ВариантыГолосования = Новый Массив;
	ПараметрыКД.Вставить("ВариантыГолосования", ВариантыГолосования);
	
	ПараметрыКД.Вставить("АдресВСетиИнтернет", АдресВСетиИнтернет(Документ, "Document.MtgCxl.Xtnsn"));
	
	Расширения = ЗначениеСвойства(Документ, "Document.MtgCxl.Xtnsn");
	Для Каждого Расширение Из Расширения Цикл
		ВариантыДляГолосования = ЗначениеСвойства(Расширение, "XtnsnEnvlp.XtnsnDt.CorpActnOptnDtls");
		Если ВариантыДляГолосования = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		ДополнитьВариантыУчастияВКД(ВариантыДляГолосования, ПараметрыКД);
	КонецЦикла;
	
	ДобавитьДополнительнуюИнформацию(Расширения, ПараметрыКД);
	ДобавитьФиксированныеСтрокиВДополнительнуюИнформацию(ПараметрыКД);
	
	Возврат ПараметрыКД;
КонецФункции

Функция ОбработатьMeetingResultDissemination(Чтение)
	Документ = СтруктураДокументаXML(Чтение);
	ПараметрыКД	= Новый Структура;
	
	// Параметры документа раскрытия
	// Параметры уведомления
	ПараметрыКД.Вставить("ВходящийДокументНомер", ЗначениеСвойства(Документ, "AppHdr.BizMsgIdr"));
	
	ВходящийДокументДата = СтроковыеФункцииКлиентСерверПереопределяемый.ДатаВремяИзСтроки(ЗначениеСвойства(Документ, "AppHdr.CreDt"));
	ПараметрыКД.Вставить("ВходящийДокументДата", ВходящийДокументДата + СмещениеСтандартногоВремени(ЧасовойПояс()));
	
	ПараметрыКД.Вставить("КДРеференсВходящий",	ЗначениеСвойства(Документ, "Document.MtgRsltDssmntn.MtgRef.MtgId"));
	ПараметрыКД.Вставить("КодОтчета",	ЗначениеСвойства(Документ, "AppHdr.BizSvc"));
	
	ПараметрыКД.Вставить("АдресВСетиИнтернет", АдресВСетиИнтернет(Документ, "Document.MtgRsltDssmntn.Xtnsn"));

	УзелScty = ЗначениеСвойства(Документ, "Document.MtgRsltDssmntn.Scty");
	СтруктураПолей = Новый Структура("КодНРД,НомерСчетаДепо,Unit,BalTp,Dt");
	ПараметрыКД.Вставить("МассивИнформацииОЦБ", МассивИнформацииОЦБ(УзелScty, СтруктураПолей));
	
	ПараметрыВариантов = ПараметрыВариантовГолосования(Документ, "Document.MtgRsltDssmntn.Xtnsn", ПараметрыКД.КДРеференсВходящий);
	ВариантыГолосования = Новый Массив;
	Вопросы = ЗначениеСвойства(Документ, "Document.MtgRsltDssmntn.VoteRslt");
	Если Вопросы <> Неопределено Тогда
		Для Каждого Вопрос Из Вопросы Цикл
			СтрВопроса = Новый Структура("НомерВопроса,За,Против,Воздержался,Принято,
				|КуммулятивныйВопрос,Коэффициент,ТекстВопроса,ДляИнформации,ВариантыГолосования");
			СтрВопроса.НомерВопроса	= ЗначениеСвойства(Вопрос, "IssrLabl");
			СтрВопроса.Принято		= ЗначениеСвойства(Вопрос, "Accptd");
			СтрВопроса.За			= ЗначениеСвойства(Вопрос, "For");
			СтрВопроса.Против		= ЗначениеСвойства(Вопрос, "Agnst");
			СтрВопроса.Воздержался	= ЗначениеСвойства(Вопрос, "Abstn");
			СтрВопроса.КуммулятивныйВопрос = Ложь;
			СтрВопроса.Коэффициент = 1;
			
			Строка = ПараметрыВариантов.Найти(СтрВопроса.НомерВопроса, "НомерВопроса");
			Если Строка = Неопределено Тогда
				СтрВопроса.ТекстВопроса = "";
				СтрВопроса.ДляИнформации = Ложь;
				СтрВопроса.ВариантыГолосования = 0;
			Иначе
				ЗаполнитьЗначенияСвойств(СтрВопроса, Строка, "ТекстВопроса, ДляИнформации, ВариантыГолосования");
			КонецЕсли;
			
			ВариантыГолосования.Добавить(СтрВопроса);
		КонецЦикла; 
	КонецЕсли;
	
	ПараметрыКД.Вставить("ВариантыГолосования", ВариантыГолосования);
	
	Расширения = ЗначениеСвойства(Документ, "Document.MtgRsltDssmntn.Xtnsn");
	Для Каждого Расширение Из Расширения Цикл
		ВариантыДляГолосования = ЗначениеСвойства(Расширение, "XtnsnEnvlp.XtnsnDt.CorpActnOptnDtls");
		Если ВариантыДляГолосования = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		ДополнитьВариантыУчастияВКД(ВариантыДляГолосования, ПараметрыКД);
	КонецЦикла;
	
	ДобавитьДополнительнуюИнформацию(Расширения, ПараметрыКД);
	DocumentMtgRsltDssmntn = ЗначениеСвойства(Документ, "Document.MtgRsltDssmntn");
	ДобавитьДополнительнуюИнформацию(DocumentMtgRsltDssmntn, ПараметрыКД);
	ДобавитьФиксированныеСтрокиВДополнительнуюИнформацию(ПараметрыКД);
	
	Возврат ПараметрыКД;
КонецФункции

Функция МассивИнформацииОЦБ(УзелScty, СтруктураПолей)
	Результат = Новый Массив;
	
	Если УзелScty = Неопределено Тогда
		Возврат Результат;
	КонецЕсли;
	
	ТегIdDesc = "Id.Desc";
	
	Для Каждого ЗаписьСхемыXDTO Из УзелScty Цикл
		ПараметрыЦБ	= Новый Структура;
		
		Если СтруктураПолей.Свойство("ISIN") Тогда
			ТегISIN = ТегИзСтруктурыИлиПоУмолчанию(СтруктураПолей.ISIN, "Id.Id.ISIN");
			ПараметрыЦБ.Вставить("ISIN", ЗначениеСвойства(ЗаписьСхемыXDTO, ТегISIN));
		КонецЕсли;
		
		Если СтруктураПолей.Свойство("Desc") Тогда
			ТегDesc = ТегИзСтруктурыИлиПоУмолчанию(СтруктураПолей.Desc, ТегIdDesc);
			ПараметрыЦБ.Вставить("Desc", ЗначениеСвойства(ЗаписьСхемыXDTO, ТегDesc));
		КонецЕсли;
			
		Если СтруктураПолей.Свойство("КодНРД") Тогда
			ТегDesc = ТегИзСтруктурыИлиПоУмолчанию(СтруктураПолей.КодНРД, ТегIdDesc);
			ОбработатьКодНРД(ЗаписьСхемыXDTO, ТегDesc, ПараметрыЦБ);
		КонецЕсли;
		
		Если СтруктураПолей.Свойство("ГосРегНомер") Тогда
			ТегDesc = ТегИзСтруктурыИлиПоУмолчанию(СтруктураПолей.ГосРегНомер, ТегIdDesc);
			ОстатокСтроки = Сред(ЗначениеСвойства(ЗаписьСхемыXDTO, ТегDesc),
				СтрНайти(ЗначениеСвойства(ЗаписьСхемыXDTO, ТегDesc), "#") + 1);
			ОстатокСтроки = Сред(ОстатокСтроки, СтрНайти(ОстатокСтроки, "#") + 1);
			ГосРегНомер = Лев(ОстатокСтроки, СтрНайти(ОстатокСтроки, "#") - 1);
			ПараметрыЦБ.Вставить("ГосРегНомер", ГосРегНомер);
		КонецЕсли;
		
		// Получим данные по ЦБ на счетах ДЕПО
		ПараметрыЦБНаСчетах	= Новый Структура;
		Если ЗаписьСхемыXDTO.Pos <> Неопределено Тогда
			Для Каждого ЗаписьPOSСхемыXDTO Из ЗаписьСхемыXDTO.Pos Цикл
				ТаблицаПоЦБ	= СоздатьТаблицуДляЦБ();
				
				Если СтруктураПолей.Свойство("НомерСчетаДепо") Тогда
					ПараметрыЦБНаСчетах.Вставить("НомерСчетаДепо", ЗаписьPOSСхемыXDTO.AcctId);
				КонецЕсли;
				
				ОбработатьУзелHldgBal(ЗаписьPOSСхемыXDTO, ТаблицаПоЦБ, СтруктураПолей);
				ПараметрыЦБНаСчетах.Вставить("ДанныеПоСчету", ТаблицаПоЦБ);
			КонецЦикла;
		КонецЕсли;
		ПараметрыЦБ.Вставить("ПараметрыЦБНаСчетах", ПараметрыЦБНаСчетах);
		Результат.Добавить(ПараметрыЦБ);
	КонецЦикла;
	
	Возврат Результат;
КонецФункции

Процедура ОбработатьУзелHldgBal(ЗаписьPOS, ТаблицаПоЦБ, СтруктураПолей)
	УзелHldgBal = ЗначениеСвойства(ЗаписьPOS, "HldgBal");
	Если ТипЗнч(УзелHldgBal) = Тип("Массив") Тогда
		// Создадим структуру данных о количестве
		Для Каждого ЗаписьHldgBal Из УзелHldgBal Цикл
			НовСтр = ТаблицаПоЦБ.Добавить();
			ЗаполнитьСтрокуТаблицыПоЦБ(НовСтр, ЗаписьHldgBal, СтруктураПолей, "FaceAmnt", "Bal.FaceAmt");
			ЗаполнитьСтрокуТаблицыПоЦБ(НовСтр, ЗаписьHldgBal, СтруктураПолей, "Unit", "Bal.Unit");
			ЗаполнитьСтрокуТаблицыПоЦБ(НовСтр, ЗаписьHldgBal, СтруктураПолей, "BalTp", "BalTp");
			ЗаполнитьСтрокуТаблицыПоЦБ(НовСтр, ЗаписьHldgBal, СтруктураПолей, "Dt", "Dt");
			ЗаполнитьСтрокуТаблицыПоЦБ(НовСтр, ЗаписьHldgBal, СтруктураПолей, "SfkpgPlc", "SfkpgPlc");
		КонецЦикла;
	КонецЕсли;
КонецПроцедуры

Процедура ОбработатьКодНРД(ЗаписьСхемыXDTO, ТегDesc, ПараметрыЦБ)
	КодНРД = "";
	УзелСКодомНРД = ЗначениеСвойства(ЗаписьСхемыXDTO, ТегDesc);
	Если ТипЗнч(УзелСКодомНРД) = Тип("Строка") Тогда
		ПозицияРазделителя = СтрНайти(УзелСКодомНРД, "#");
		КодНРД = Лев(УзелСКодомНРД, ПозицияРазделителя - 1);
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(КодНРД) Тогда
		УзелOthrId = ЗначениеСвойства(ЗаписьСхемыXDTO, "FinInstrmId.OthrId");
		Если ТипЗнч(УзелOthrId) = Тип("Массив") Тогда
			Для Каждого Элемент Из УзелOthrId Цикл
				ТипИдентификатора = ЗначениеСвойства(Элемент, "Tp.Prtry");
				Если ТипИдентификатора = "NSDR" Тогда
					КодНРД = ЗначениеСвойства(Элемент, "Id");
					Прервать;
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
	КонецЕсли;
	ПараметрыЦБ.Вставить("КодНРД", КодНРД);
КонецПроцедуры

Функция ТегИзСтруктурыИлиПоУмолчанию(ТегИзСтруктуры, ТегПоУмолчанию)
	Возврат ?(ЗначениеЗаполнено(ТегИзСтруктуры), ТегИзСтруктуры, ТегПоУмолчанию);
КонецФункции

Процедура ЗаполнитьСтрокуТаблицыПоЦБ(СтрокаТаблицы, ЗаписьHldgBal, СтруктураПолей, ИмяТегаИзСтруктурыПолей, ИмяТегаПоУмолчанию)
	Если СтруктураПолей.Свойство(ИмяТегаИзСтруктурыПолей) Тогда
		ИмяТега = ТегИзСтруктурыИлиПоУмолчанию(СтруктураПолей[ИмяТегаИзСтруктурыПолей], ИмяТегаПоУмолчанию);
		СтрокаТаблицы[ИмяТегаИзСтруктурыПолей] = ЗначениеСвойства(ЗаписьHldgBal, ИмяТега);
	КонецЕсли;
КонецПроцедуры

Функция ПараметрыВариантовГолосования(Документ, УзелXtnsn, КДРеференсВходящий)
	ПараметрыВариантов = Новый ТаблицаЗначений;
	ПараметрыВариантов.Колонки.Добавить("НомерВопроса");
	ПараметрыВариантов.Колонки.Добавить("ТекстВопроса");
	ПараметрыВариантов.Колонки.Добавить("ДляИнформации");
	ПараметрыВариантов.Колонки.Добавить("ВариантыГолосования");
	
	Xtnsns = ЗначениеСвойства(Документ, УзелXtnsn);
	Если Xtnsns <> Неопределено И ТипЗнч(Xtnsns) = Тип("Массив") Тогда
		Для Каждого Xtnsn Из Xtnsns Цикл
			MtgId = ЗначениеСвойства(Xtnsn, "XtnsnEnvlp.XtnsnDt.Mtg.MtgId");
			Если MtgId = КДРеференсВходящий Тогда
				Rsltns = ЗначениеСвойства(Xtnsn, "XtnsnEnvlp.XtnsnDt.Rsltn");
				Если Rsltns <> Неопределено И ТипЗнч(Rsltns) = Тип("Массив") Тогда
					Для Каждого Rsltn Из Rsltns Цикл
						НоваяСтрока = ПараметрыВариантов.Добавить();
						НоваяСтрока.НомерВопроса = ЗначениеСвойства(Rsltn, "IssrLabl");
						НоваяСтрока.ТекстВопроса = ЗначениеСвойства(Rsltn, "Desc");
						НоваяСтрока.ДляИнформации = ?(ВРЕГ(ЗначениеСвойства(Rsltn, "ForInfOnly")) = "FALSE", Ложь, Истина);
						
						VoteInstrTp = ЗначениеСвойства(Rsltn, "VoteInstrTp");
						Если VoteInstrTp <> Неопределено И ТипЗнч(VoteInstrTp) = Тип("Массив") Тогда
							НоваяСтрока.ВариантыГолосования = ИзДвоичнойВДесятичную(ДвоичнаяСтрокаВариантов(VoteInstrTp));
						Иначе
							НоваяСтрока.ВариантыГолосования = 0;
						КонецЕсли;
					КонецЦикла;
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	Возврат ПараметрыВариантов;
КонецФункции

Функция ДвоичнаяСтрокаВариантов(Варианты)
	Результат = "000";
	
	Для Каждого Вариант ИЗ Варианты Цикл
		Если Вариант = "CFOR" Тогда
			Результат = "1" + Прав(Результат, 2);
		ИначеЕсли Вариант = "CAGS" Тогда
			Результат = Лев(Результат, 1) + "1" + Прав(Результат, 1);
		ИначеЕсли Вариант = "ABST" Тогда
			Результат = Лев(Результат, 2) + "1";
		КонецЕсли;
	КонецЦикла;
	
	Возврат Результат;
КонецФункции

// Считывает узел XML CorporateActionNotification в таблицу значений
//
// Возвращаемое значение:
//  структура для заполнения таблицы значений ДанныеКорпоративныхДействий
Функция ОбработатьCorporateActionNotification(Чтение)
	Документ = СтруктураДокументаXML(Чтение);
	ПараметрыКД	= Новый Структура;
	ПараметрыКД.Вставить("КодОтчета", ЗначениеСвойства(Документ, "AppHdr.BizSvc"));
	
	// Параметры документа раскрытия
	// Параметры уведомления
	ПараметрыКД.Вставить("ВходящийДокументНомер", ЗначениеСвойства(Документ, "AppHdr.BizMsgIdr"));
	
	ВходящийДокументДата = СтроковыеФункцииКлиентСерверПереопределяемый.ДатаВремяИзСтроки(ЗначениеСвойства(Документ, "AppHdr.CreDt"));
	ПараметрыКД.Вставить("ВходящийДокументДата", ВходящийДокументДата + СмещениеСтандартногоВремени(ЧасовойПояс()));
	
	ТипУведомленияКод = ЗначениеСвойства(Документ, "Document.CorpActnNtfctn.NtfctnGnlInf.NtfctnTp");
	ПараметрыКД.Вставить("ТипУведомления", Справочники.ТипыУведомления.НайтиПоКоду(ТипУведомленияКод));
	
	ПараметрыКД.Вставить("КДРеференсВходящий", ЗначениеСвойства(Документ,
		"Document.CorpActnNtfctn.CorpActnGnlInf.CorpActnEvtId"));
	
	ПараметрыКД.Вставить("ВидКД", ЗначениеСвойства(Документ, "Document.CorpActnNtfctn.CorpActnGnlInf.EvtTp.Cd"));
	
	ИндексЭлементаМассиваEvtsLkg = ?(ПараметрыКД.ВидКД = "WTRC", 1, 0);
	ПараметрыКД.Вставить("КДРеференсСвязанный", ЗначениеСвойстваИзСтруктурыМассива(Документ,
		"Document.CorpActnNtfctn.EvtsLkg.EvtId.LkdCorpActnId", ИндексЭлементаМассиваEvtsLkg));
	
	КодПризнакаОбязательности = ЗначениеСвойства(Документ, "Document.CorpActnNtfctn.CorpActnGnlInf.MndtryVlntryEvtTp.Cd");
	Признаки = Справочники.ПризнакиОбязательностиКорпоративныхДействий.ПризнакиПоКоду(КодПризнакаОбязательности);
	Если ЗначениеЗаполнено(Признаки) Тогда
		ПараметрыКД.Вставить("ВидВыкупа", Признаки.ТипКорпоративногоДействия);
		ПараметрыКД.Вставить("ПризнакОбязательностиКД", Признаки.ПризнакОбязательностиКД);
	КонецЕсли;
		
	ПараметрыКД.Вставить("НомерСчетаДепо", ЗначениеСвойства(Документ,
		"Document.CorpActnNtfctn.AcctDtls.AcctsListAndBalDtls.SfkpgAcct"));
		
	ISIN = ЗначениеСвойства(Документ, "Document.CorpActnNtfctn.CorpActnGnlInf.UndrlygScty.FinInstrmId.ISIN");
	ПараметрыКД.Вставить("ISINДляПоискаЭмитента", ISIN);
	
	// Узлы OthrId
	// Найдем КодЗагрузкиНДЦ
	OthrId = ЗначениеСвойства(Документ, "Document.CorpActnNtfctn.CorpActnGnlInf.UndrlygScty.FinInstrmId.OthrId");
	Если OthrId <> Неопределено Тогда
		OthrId = Документ.Document.CorpActnNtfctn.CorpActnGnlInf.UndrlygScty.FinInstrmId.OthrId;
		Если ТипЗнч(OthrId) = Тип("Массив") Тогда
			Для Каждого Стр ИЗ OthrId Цикл
				ПрочитатьУзелOthrId(Стр, ПараметрыКД);
			КонецЦикла;
			
		ИначеЕсли ТипЗнч(OthrId) = Тип("Структура") Тогда
			ПрочитатьУзелOthrId(OthrId, ПараметрыКД);
		КонецЕсли;
	КонецЕсли;
	
	ПараметрыКД.Вставить("ЦеннаяБумага1Остаток", СтроковыеФункцииКлиентСерверПереопределяемый.ПолучитьЧислоИзСтроки(ЗначениеСвойства(Документ,
		"Document.CorpActnNtfctn.AcctDtls.AcctsListAndBalDtls.Bal.TtlElgblBal.QtyChc.SgndQty.Qty.Unit",
		"Document.CorpActnNtfctn.AcctDtls.AcctsListAndBalDtls.Bal.SttlmPosBal.Bal.QtyChc.Qty.Unit")));
	
	ПараметрыКД.Вставить("МинимальноеКодичествоДляУчастияВКД", СтроковыеФункцииКлиентСерверПереопределяемый.ПолучитьЧислоИзСтроки(ЗначениеСвойства(Документ,
		"Document.CorpActnNtfctn.CorpActnDtls.SctiesQty.MinExrcblQty.Utit")));
		
	ДатаНачалаПриемаЗаявокНаВыкуп = СтроковыеФункцииКлиентСерверПереопределяемый.ДатаВремяИзСтроки(ЗначениеСвойства(Документ,
		"Document.CorpActnNtfctn.CorpActnDtls.PrdDtls.PricClctnPrd.Prd.StartDt",
		"Document.CorpActnNtfctn.CorpActnDtls.PrdDtls.PricClctnPrd.Prd.StartDtTm"));
	Если ЗначениеЗаполнено(ДатаНачалаПриемаЗаявокНаВыкуп) Тогда
		ПараметрыКД.Вставить("ДатаНачалаПриемаЗаявокНаВыкуп", ДатаНачалаПриемаЗаявокНаВыкуп);
	КонецЕсли;
	
	ДатаОкончанияПриемаЗаявокНаВыкуп = СтроковыеФункцииКлиентСерверПереопределяемый.ДатаВремяИзСтроки(ЗначениеСвойства(Документ,
		"Document.CorpActnNtfctn.CorpActnDtls.PrdDtls.PricClctnPrd.Prd.EndDt",
		"Document.CorpActnNtfctn.CorpActnDtls.PrdDtls.PricClctnPrd.Prd.EndDtTm"));
	Если ЗначениеЗаполнено(ДатаОкончанияПриемаЗаявокНаВыкуп) Тогда
		ПараметрыКД.Вставить("ДатаОкончанияПриемаЗаявокНаВыкуп", ДатаОкончанияПриемаЗаявокНаВыкуп);
	КонецЕсли;
	
	// Узлы CorpActnOptnDtls
	// Найти выплату на 1 ЦБ, валюту и др. параметры
	CorpActnOptnDtls = ЗначениеСвойства(Документ, "Document.CorpActnNtfctn.CorpActnOptnDtls");
	Если CorpActnOptnDtls <> Неопределено Тогда
		CorpActnOptnDtls = Документ.Document.CorpActnNtfctn.CorpActnOptnDtls;
		Если ТипЗнч(CorpActnOptnDtls) = Тип("Массив") Тогда
			Для каждого Стр Из CorpActnOptnDtls Цикл
				ПрочитатьУзелCorpActnOptnDtls(Стр, ПараметрыКД);
			КонецЦикла;
			
		ИначеЕсли ТипЗнч(CorpActnOptnDtls) = Тип("Структура") Тогда
			ПрочитатьУзелCorpActnOptnDtls(CorpActnOptnDtls, ПараметрыКД);
		КонецЕсли;
	КонецЕсли;
	
	Если Не ПараметрыКД.Свойство("СтавкаКупонногоДоходаГодовых") Тогда
		СтавкаКупонногоДоходаГодовыхСтр = ЗначениеСвойства(Документ,
			"Document.CorpActnNtfctn.CorpActnDtls.RateAndAmtDtls.Intrst.Rate");
		Если ЗначениеЗаполнено(СтавкаКупонногоДоходаГодовыхСтр) Тогда
			ПараметрыКД.Вставить("СтавкаКупонногоДоходаГодовых", СтроковыеФункцииКлиентСерверПереопределяемый.ПолучитьЧислоИзСтроки(СтавкаКупонногоДоходаГодовыхСтр));
		КонецЕсли;
	КонецЕсли;
	
	Если Не ПараметрыКД.Свойство("КоличествоДнейВКупонномПериоде") Тогда
		КоличествоДнейВКупонномПериодеСтр = ЗначениеСвойства(Документ,
			"Document.CorpActnNtfctn.CorpActnDtls.IntrstAcrdNbOfDays");
		Если ЗначениеЗаполнено(КоличествоДнейВКупонномПериодеСтр) Тогда
			ПараметрыКД.Вставить("КоличествоДнейВКупонномПериоде", СтроковыеФункцииКлиентСерверПереопределяемый.ПолучитьЧислоИзСтроки(КоличествоДнейВКупонномПериодеСтр));
		КонецЕсли;
	КонецЕсли;
	
	ДатаФиксацииСтр = ЗначениеСвойства(Документ,
		"Document.CorpActnNtfctn.CorpActnDtls.DtDtls.RcrdDt.Dt.Dt",
		"Document.CorpActnNtfctn.CorpActnDtls.DtDtls.RcrdDt.Dt.DtTm");
	ПараметрыКД.Вставить("ДатаФиксации", СтроковыеФункцииКлиентСерверПереопределяемый.ДатаВремяИзСтроки(ДатаФиксацииСтр));
	ПараметрыКД.Вставить("ДатаФиксацииНеизвестна", (ДатаФиксацииСтр = "UNWN"));
		
	ПараметрыКД.Вставить("Комментарий", "");
	
	// Узлы SplmtryData
	// Найти АдресВСетиИнтернет, КоэффициентКонвертации, НомерСтатьи
	SplmtryData = ЗначениеСвойства(Документ, "Document.CorpActnNtfctn.SplmtryData");
	Если SplmtryData <> Неопределено Тогда
		SplmtryData = Документ.Document.CorpActnNtfctn.SplmtryData;
		Если ТипЗнч(SplmtryData) = Тип("Массив") Тогда
			Для Каждого Стр Из SplmtryData Цикл
				ПрочитатьУзелSplmtryData(Стр, ПараметрыКД);
			КонецЦикла;
			
		ИначеЕсли ТипЗнч(SplmtryData) = Тип("Структура") Тогда
			ПрочитатьУзелSplmtryData(SplmtryData, ПараметрыКД);
		КонецЕсли;
	КонецЕсли;
	
	// Узлы CorpActnDtls.AddtlInf
	// Найти ИнициаторВыкупа
	AddtlInf = ЗначениеСвойства(Документ, "Document.CorpActnNtfctn.CorpActnDtls.AddtlInf");
	Если AddtlInf <> Неопределено Тогда
		AddtlInf = Документ.Document.CorpActnNtfctn.CorpActnDtls.AddtlInf;
		Если ТипЗнч(AddtlInf) = Тип("Массив") Тогда
			Для Каждого Стр Из AddtlInf Цикл
				ПрочитатьУзелCorpActnDtls_AddtlInf(Стр, ПараметрыКД);
			КонецЦикла;
			
		ИначеЕсли ТипЗнч(AddtlInf) = Тип("Структура") Тогда
			ПрочитатьУзелCorpActnDtls_AddtlInf(AddtlInf, ПараметрыКД);
		КонецЕсли;
	КонецЕсли;
	
	ПараметрыКД.Вставить("ХДивДата", СтроковыеФункцииКлиентСерверПереопределяемый.ДатаВремяИзСтроки(ЗначениеСвойства(Документ,
		"Document.CorpActnNtfctn.CorpActnDtls.DtDtls.ExDvddDt.Dt.Dt",
		"Document.CorpActnNtfctn.CorpActnDtls.DtDtls.ExDvddDt.Dt.DtTm")));
	
	ПараметрыКД.Вставить("ДатаНачалаКупонногоПериода", СтроковыеФункцииКлиентСерверПереопределяемый.ДатаВремяИзСтроки(ЗначениеСвойства(Документ,
		"Document.CorpActnNtfctn.CorpActnDtls.PrdDtls.IntrstPrd.Prd.StartDt.Dt.Dt",
		"Document.CorpActnNtfctn.CorpActnDtls.PrdDtls.IntrstPrd.Prd.StartDt.Dt.DtTm")));
		
	ПараметрыКД.Вставить("ДатаОкончанияКупонногоПериода", СтроковыеФункцииКлиентСерверПереопределяемый.ДатаВремяИзСтроки(ЗначениеСвойства(Документ,
		"Document.CorpActnNtfctn.CorpActnDtls.PrdDtls.IntrstPrd.Prd.EndDt.Dt.Dt",
		"Document.CorpActnNtfctn.CorpActnDtls.PrdDtls.IntrstPrd.Prd.EndDt.Dt.DtTm")));
		
	ДатаКДПланСтр = ЗначениеСвойства(Документ, "Document.CorpActnNtfctn.CorpActnDtls.DtDtls.RcrdDt.Dt.Dt");
	Если ПараметрыКД.ВидКД = "WTRC" И ЗначениеЗаполнено(ДатаКДПланСтр) Тогда
		ПараметрыКД.Вставить("ДатаКДПлан",
			СтроковыеФункцииКлиентСерверПереопределяемый.ДатаВремяИзСтроки(ДатаКДПланСтр));
	КонецЕсли;
	
	ПараметрыКД.Вставить("ПоследнийСрокПодачиИнструкцийПоНалоговымЛьготам",
		СтроковыеФункцииКлиентСерверПереопределяемый.ДатаВремяИзСтроки(ЗначениеСвойства(Документ,
			"Document.CorpActnNtfctn.CorpActnDtls.DtDtls.DdlnForTaxBrkdwnInstr.Dt.Dt",
			"Document.CorpActnNtfctn.CorpActnDtls.DtDtls.DdlnForTaxBrkdwnInstr.Dt.DtTm")));
	
	Если ПараметрыКД.ВидКД = "TREC" Тогда
		ПоследнийСрокСертификации = СтроковыеФункцииКлиентСерверПереопределяемый.ДатаВремяИзСтроки(
			ЗначениеСвойства(Документ, "Document.CorpActnNtfctn.CorpActnDtls.DtDtls.CertfctnDdln.Dt.Dt"));
			
		Если НЕ ЗначениеЗаполнено(ПоследнийСрокСертификации) Тогда
			ПоследнийСрокСертификации = ДатаФиксацииИзТекста(
				ЗначениеСвойства(Документ, "Document.CorpActnNtfctn.AddtlInf.AddtlTxt.AddtlInf"));
		КонецЕсли;
			
		ПараметрыКД.Вставить("ДатаФиксации", ПоследнийСрокСертификации);
	КонецЕсли;
	
	ВариантыГолосования = ЗначениеСвойства(Документ, "Document.CorpActnNtfctn.CorpActnOptnDtls");
	Если ВариантыГолосования <> Неопределено Тогда
		ДополнитьВариантыУчастияВКД(ВариантыГолосования, ПараметрыКД);
	КонецЕсли;
	CorpActnNtfctn = ЗначениеСвойства(Документ, "Document.CorpActnNtfctn");
	ДобавитьДополнительнуюИнформацию(CorpActnNtfctn, ПараметрыКД);
	ДобавитьФиксированныеСтрокиВДополнительнуюИнформацию(ПараметрыКД);
	
	Возврат ПараметрыКД;
КонецФункции

Функция ДатаФиксацииИзТекста(Текст)
	Метка = "Дата фиксации списка владельцев";
	ДатаВозврата = Дата(1, 1, 1);
	Если Текст <> Неопределено Тогда
		ПозицияМетки = Найти(Текст, Метка);
		Если ПозицияМетки > 0 Тогда
			Блок = Сред(Текст, ПозицияМетки);
			ПозицияПС = Найти(Блок, Символы.ПС);
			Если ПозицияПС > 0 Тогда
				Блок = Лев(Блок, ПозицияПС-1);
			КонецЕсли;
			ДатаВозврата = СтроковыеФункцииКлиентСерверПереопределяемый.ДатаИзСтрокиПрописью(Блок);
		КонецЕсли;
	КонецЕсли;
	Возврат ДатаВозврата;
КонецФункции

Процедура ЗагрузитьКоэффициентКонвертацииПоФормату2(Стр, ПараметрыКД)
	ИменаБлоковИсточников = Новый Массив;
	ИменаБлоковИсточников.Добавить("Envlp.XtnsnDt.XtnsnCorpActnOptnDtls.SctiesMvmntDtls.RateDtls.NewToOdFrctn");
	ИменаБлоковИсточников.Добавить("Envlp.XtnsnDt.XtnsnCorpActnOptnDtls.SctiesMvmntDtls.RateDtls.AddtlQtyForExstgSctiesFrctn");
	
	Для Каждого ИмяИсточника Из ИменаБлоковИсточников Цикл
		Колво1Коэф1	= ЗначениеСвойства(Стр, ИмяИсточника + ".Ratio1.Qty1");
		Колво2Коэф1	= ЗначениеСвойства(Стр, ИмяИсточника + ".Ratio1.Qty2");
		Колво1Коэф2	= ЗначениеСвойства(Стр, ИмяИсточника + ".Ratio2.Qty1");
		Колво2Коэф2	= ЗначениеСвойства(Стр, ИмяИсточника + ".Ratio2.Qty2");
		Если ЗначениеЗаполнено(Колво1Коэф1)
			И ЗначениеЗаполнено(Колво2Коэф1)
			И ЗначениеЗаполнено(Колво1Коэф2)
			И ЗначениеЗаполнено(Колво2Коэф2) Тогда
			ПараметрыКД.Вставить("КоэффициентКонвертации",
				Колво1Коэф1 + ":" + Колво2Коэф1 + "/" + Колво1Коэф2 + ":" + Колво2Коэф2);
			Прервать;
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

// Считывает узел XML MeetingInstructionStatus в таблицу значений
//
// Возвращаемое значение:
//  структура для заполнения таблицы значений ДанныеКорпоративныхДействий
Функция ОбработатьMeetingInstructionStatus(Чтение)
	BizSvc = "AppHdr.BizSvc";
	Rltd_BizMsgIdr = "AppHdr.Rltd.BizMsgIdr";
	Rltd_BizSvc = "AppHdr.Rltd.BizSvc";
	BizMsgIdr = "AppHdr.BizMsgIdr";
	CreDt = "AppHdr.CreDt";
	MtgId = "Document.MtgInstrSts.MtgRef.MtgId";
	Sts = "Document.MtgInstrSts.InstrTpSts.InstrSts.GblInstrSts.PrcgSts.Sts";
	
	Документ = СтруктураДокументаXML(Чтение);
	
	ПараметрыКД	= Новый Структура;
	ПараметрыКД.Вставить("КодОтчета", ЗначениеСвойства(Документ, BizSvc));
	
	// Параметры документа раскрытия
	// Параметры уведомления
	ПараметрыКД.Вставить("ИсходныйДокументНомер",	ЗначениеСвойства(Документ, Rltd_BizMsgIdr));
	ПараметрыКД.Вставить("RltdBizSvc",				ЗначениеСвойства(Документ, Rltd_BizSvc));
	ПараметрыКД.Вставить("ВходящийДокументНомер",	ЗначениеСвойства(Документ, BizMsgIdr));
	
	ВходящийДокументДата = СтроковыеФункцииКлиентСерверПереопределяемый.ДатаВремяИзСтроки(ЗначениеСвойства(Документ, CreDt));
	ПараметрыКД.Вставить("ВходящийДокументДата", ВходящийДокументДата + СмещениеСтандартногоВремени(ЧасовойПояс()));
	
	ПараметрыКД.Вставить("КДРеференсВходящий", ЗначениеСвойства(Документ, MtgId));
	ПараметрыКД.Вставить("Статус", ЗначениеСвойства(Документ, Sts));
	
	СодержимоеФайла = Новый Структура;
	СодержимоеФайла.Вставить("AppHdr_BizSvc", ЗначениеСвойства(Документ, BizSvc));
	СодержимоеФайла.Вставить("AppHdr_Rltd_BizMsgIdr", ЗначениеСвойства(Документ, Rltd_BizMsgIdr));
	СодержимоеФайла.Вставить("AppHdr_Rltd_BizSvc", ЗначениеСвойства(Документ, Rltd_BizSvc));
	СодержимоеФайла.Вставить("AppHdr_BizMsgIdr", ЗначениеСвойства(Документ, BizMsgIdr));
	СодержимоеФайла.Вставить("AppHdr_CreDt", ЗначениеСвойства(Документ, CreDt));
	СодержимоеФайла.Вставить("Document_MtgInstrSts_MtgRef_MtgId", ЗначениеСвойства(Документ, MtgId));
	СодержимоеФайла.Вставить("Document_MtgInstrSts_InstrTpSts_InstrSts_GblInstrSts_PrcgSts_Sts", ЗначениеСвойства(Документ, Sts));
	
	Запись = Новый ЗаписьJSON;
	Запись.УстановитьСтроку();
	ЗаписатьJSON(Запись, СодержимоеФайла);
	СодержимоеФайлаТекст = Запись.Закрыть();
	ПараметрыКД.Вставить("СодержимоеФайла", СодержимоеФайлаТекст);
	
	Возврат ПараметрыКД;
КонецФункции

// Считывает узел XML CorporateActionCancellationAdvice
//
// Возвращаемое значение:
//  структура для заполнения таблицы значений ДанныеКорпоративныхДействий
Функция ОбработатьCorporateActionCancellationAdvice(Чтение)
	Документ = СтруктураДокументаXML(Чтение);
	ПараметрыКД	= Новый Структура;
	ПараметрыКД.Вставить("КодОтчета", ЗначениеСвойства(Документ, "AppHdr.BizSvc"));
	ПараметрыКД.Вставить("ВходящийДокументНомер", ЗначениеСвойства(Документ, "AppHdr.BizMsgIdr"));
	ВходящийДокументДата = СтроковыеФункцииКлиентСерверПереопределяемый.ДатаВремяИзСтроки(ЗначениеСвойства(Документ, "AppHdr.CreDt"));
	ПараметрыКД.Вставить("ВходящийДокументДата", ВходящийДокументДата + СмещениеСтандартногоВремени(ЧасовойПояс()));
	ПараметрыКД.Вставить("КДРеференсВходящий", ЗначениеСвойства(Документ, "Document.CorpActnCxlAdvc.CorpActnGnlInf.CorpActnEvtId"));
	КодПричиныОтмены = ЗначениеСвойства(Документ, "Document.CorpActnCxlAdvc.CxlAdvcGnlInf.CxlRsnCd");
	ПараметрыКД.Вставить("ПричинаОтмены", Справочники.ПричиныОтмены.НайтиПоКоду(КодПричиныОтмены));
	ПараметрыКД.Вставить("НомерСчетаДепо", ЗначениеСвойства(Документ, "Document.CorpActnCxlAdvc.AcctsDtls.AcctsList.SfkpgAcct"));
	ПараметрыКД.Вставить("АдресВСетиИнтернетОтмена", АдресВСетиИнтернет(Документ, "Document.CorpActnCxlAdvc.SplmtryData",
		"Envlp"));
	
	CorpActnCxlAdvc = ЗначениеСвойства(Документ, "Document.CorpActnCxlAdvc");
	ДобавитьДополнительнуюИнформацию(CorpActnCxlAdvc, ПараметрыКД);
	ДобавитьФиксированныеСтрокиВДополнительнуюИнформацию(ПараметрыКД);
	
	Возврат ПараметрыКД;
КонецФункции

Процедура ПрочитатьУзелOthrId(УзелИсточник, ПараметрыПриемник)
	Prtry = ЗначениеСвойства(УзелИсточник, "Tp.Prtry");
	Если СокрЛП(ВРег(Prtry)) = "NSDR" Тогда
		ПараметрыПриемник.Вставить("КодЗагрузкиНДЦ", ЗначениеСвойства(УзелИсточник,	"Id"));
	КонецЕсли;
КонецПроцедуры

Процедура ПрочитатьУзелCorpActnOptnDtls(УзелИсточник, ПараметрыПриемник)
	OptnNb = ЗначениеСвойства(УзелИсточник, "OptnNb");
	Если OptnNb = "001" Тогда
		
		УзлыВыплатыНа1ЦБ = Новый Массив;
		УзлыВыплатыНа1ЦБ.Добавить("CshMvmntDtls.PricDtls.GncCshPricRcvdPerPdct.AmtPric.PricVal");
		УзлыВыплатыНа1ЦБ.Добавить("CshMvmntDtls.PricDtls.GncCshPricPdPerPdct.AmtPric.PricVal");
		УзлыВыплатыНа1ЦБ.Добавить("CshMvmntDtls.RateAndAmtDtls.IntrstRateUsdForPmt.Amt");
		УзлыВыплатыНа1ЦБ.Добавить("CshMvmntDtls.RateAndAmtDtls.GrssDvddRate.Amt");
		
		Для Каждого УзелВыплатыНа1ЦБ Из УзлыВыплатыНа1ЦБ Цикл
			СтрВыплатаНа1ЦБ = ЗначениеСвойстваИзСтруктурыМассива(УзелИсточник, УзелВыплатыНа1ЦБ);
			Если ЗначениеЗаполнено(СтрВыплатаНа1ЦБ) Тогда
				ПараметрыПриемник.Вставить("ВыплатаНа1ЦБ", СтроковыеФункцииКлиентСерверПереопределяемый.ПолучитьЧислоИзСтроки(СтрВыплатаНа1ЦБ));
				ПараметрыПриемник.Вставить("НаименованиеВалюты",
					СокрЛП(ЗначениеСвойстваИзСтруктурыМассива(УзелИсточник, УзелВыплатыНа1ЦБ + "_Attribute_Ccy")));
				Прервать;
			КонецЕсли;
		КонецЦикла;
		
		ДатаОкончанияПриемаИнструкцийНРД = СтроковыеФункцииКлиентСерверПереопределяемый.ДатаВремяИзСтроки(ЗначениеСвойства(УзелИсточник,
			"DtDtls.RspnDdln.Dt.Dt",
			"DtDtls.RspnDdln.Dt.DtTm"));
		ПараметрыПриемник.Вставить("ДатаОкончанияПриемаИнструкцийНРД", ДатаОкончанияПриемаИнструкцийНРД);
		
		ДатаОкончанияПриемаИнструкцийВТБКБ = Документы.УведомлениеКлиентам.ДобавитьРабочийДень(ДатаОкончанияПриемаИнструкцийНРД, -2);
		СкопироватьВремя(ДатаОкончанияПриемаИнструкцийВТБКБ, ДатаОкончанияПриемаИнструкцийНРД);
		ПараметрыПриемник.Вставить("ДатаОкончанияПриемаИнструкцийВТБКБ", ДатаОкончанияПриемаИнструкцийВТБКБ);
		
		ДатаВалютированияСтрокой = ЗначениеСвойства(УзелИсточник,
			"CshMvmntDtls.DtDtls.ValDt.Dt.Dt",
			"CshMvmntDtls.DtDtls.ValDt.Dt.DtTm");
		ДатаВалютирования = СтроковыеФункцииКлиентСерверПереопределяемый.ДатаВремяИзСтроки(ДатаВалютированияСтрокой);
		
		ДатаПроведенияСтрокой = ЗначениеСвойства(УзелИсточник,
			"CshMvmntDtls.DtDtls.PmtDt.Dt.Dt",
			"CshMvmntDtls.DtDtls.PmtDt.Dt.DtTm");
		ДатаПроведения = СтроковыеФункцииКлиентСерверПереопределяемый.ДатаВремяИзСтроки(ДатаПроведенияСтрокой);
		
		Если ЗначениеЗаполнено(ДатаВалютирования) Тогда
			ПараметрыПриемник.Вставить("ДатаВыплатыНеПозднее", ДатаВалютирования);
			ПараметрыПриемник.Вставить("ДатаПроведенияСобрания", ДатаВалютирования);
		Иначе
			ПараметрыПриемник.Вставить("ДатаВыплатыНеПозднее", ДатаПроведения);
			ПараметрыПриемник.Вставить("ДатаПроведенияСобрания", ДатаПроведения);
		КонецЕсли;
			
		ПараметрыПриемник.Вставить("ПоследнийСрокРынка", СтроковыеФункцииКлиентСерверПереопределяемый.ДатаВремяИзСтроки(ЗначениеСвойства(УзелИсточник,
			"DtDtls.MktDdln.Dt.DtTm")));
			
		ПараметрыПриемник.Вставить("СтавкаНалога", СтроковыеФункцииКлиентСерверПереопределяемый.ПолучитьЧислоИзСтроки(ЗначениеСвойства(УзелИсточник,
			"CshMvmntDtls.RateAndAmtDtls.WhldgTaxRate.Rate")));
		
		ПараметрыПриемник.Вставить("ЧистаяСтавкаДивидендов", СтроковыеФункцииКлиентСерверПереопределяемый.ПолучитьЧислоИзСтроки(ЗначениеСвойства(УзелИсточник,
			"CshMvmntDtls.RateAndAmtDtls.NetDvddRate.Amt")));
		
		ПараметрыПриемник.Вставить("ВалютаЧистойСтавкиДивидендов", ВалютаПоНаименованию(ЗначениеСвойства(УзелИсточник,
			"CshMvmntDtls.RateAndAmtDtls.NetDvddRate.Amt_Attribute_Ccy")));
			
		ПараметрыПриемник.Вставить("ВалютаПлатежа", ВалютаПоНаименованию(ЗначениеСвойства(УзелИсточник, "CcyOptn")));
			
		ПараметрыПриемник.Вставить("Период", ЗначениеСвойства(УзелИсточник,	"AddtlInf.AddtlTxt.AddtlInf"));
		
		ПараметрыПриемник.Вставить("ПогашаемаяЧасть", СтроковыеФункцииКлиентСерверПереопределяемый.ПолучитьЧислоИзСтроки(ЗначениеСвойства(УзелИсточник,
			"CshMvmntDtls.RateAndAmtDtls.AplblRate.Rate")));
			
		ПараметрыПриемник.Вставить("РазмерПогашаемойЧасти", СтроковыеФункцииКлиентСерверПереопределяемый.ПолучитьЧислоИзСтроки(ЗначениеСвойства(УзелИсточник,
			"CshMvmntDtls.PricDtls.GncCshPricRcvdPerPdct.AmtPric.PricVal")));
			
		СтавкаКупонногоДоходаГодовыхСтр = ЗначениеСвойства(УзелИсточник, "CshMvmntDtls.RateAndAmtDtls.Intrst.Rate");
		Если ЗначениеЗаполнено(СтавкаКупонногоДоходаГодовыхСтр) Тогда
			ПараметрыПриемник.Вставить("СтавкаКупонногоДоходаГодовых", СтроковыеФункцииКлиентСерверПереопределяемый.ПолучитьЧислоИзСтроки(СтавкаКупонногоДоходаГодовыхСтр));
		КонецЕсли;
			
		КоличествоДнейВКупонномПериодеСтр = ЗначениеСвойства(УзелИсточник,
			"CshMvmntDtls.RateAndAmtDtls.IntrstAcrdNbOfDays");
		Если ЗначениеЗаполнено(КоличествоДнейВКупонномПериодеСтр) Тогда
			ПараметрыПриемник.Вставить("КоличествоДнейВКупонномПериоде", СтроковыеФункцииКлиентСерверПереопределяемый.ПолучитьЧислоИзСтроки(КоличествоДнейВКупонномПериодеСтр));
		КонецЕсли;
		
		ДатаКДПланСтрокой = ЗначениеСвойства(УзелИсточник,
			"CshMvmntDtls.DtDtls.EarlstPmtDt.Dt.Dt",
			"CshMvmntDtls.DtDtls.EarlstPmtDt.Dt.DtTm");
		ДатаКДПлан = СтроковыеФункцииКлиентСерверПереопределяемый.ДатаВремяИзСтроки(ДатаКДПланСтрокой);
		Если ЗначениеЗаполнено(ДатаВалютирования) Тогда
			ПараметрыПриемник.Вставить("ДатаКДПлан", ДатаВалютирования);
		ИначеЕсли ЗначениеЗаполнено(ДатаКДПлан) Тогда
			ПараметрыПриемник.Вставить("ДатаКДПлан", ДатаКДПлан);
		Иначе
			ПараметрыПриемник.Вставить("ДатаКДПлан", ДатаПроведения);
		КонецЕсли;
	
		SctiesMvmntDtls = ЗначениеСвойства(УзелИсточник, "SctiesMvmntDtls");
		Если SctiesMvmntDtls <> Неопределено Тогда
			SctiesMvmntDtls = УзелИсточник.SctiesMvmntDtls;
			Если ТипЗнч(SctiesMvmntDtls) = Тип("Массив") Тогда
				Для каждого Стр из SctiesMvmntDtls Цикл
					ПрочитатьУзелSctiesMvmntDtls(Стр, ПараметрыПриемник);
				КонецЦикла;
				
			ИначеЕсли ТипЗнч(SctiesMvmntDtls) = Тип("Структура") Тогда
				ПрочитатьУзелSctiesMvmntDtls(SctiesMvmntDtls, ПараметрыПриемник);
			КонецЕсли;
		КонецЕсли;
		
		Если НЕ ПараметрыПриемник.Свойство("ЦенаРазмещения") Тогда
			ПараметрыПриемник.Вставить("ЦенаРазмещения", СтроковыеФункцииКлиентСерверПереопределяемый.ПолучитьЧислоИзСтроки(ЗначениеСвойства(УзелИсточник,
				"CshMvmntDtls.PricDtls.GncCshPricPdPerPdct.AmtPric.PricVal")));
			ПараметрыПриемник.Вставить("ВалютаЦеныРазмещения", ВалютаПоНаименованию(ЗначениеСвойства(УзелИсточник,
				"CshMvmntDtls.PricDtls.GncCshPricPdPerPdct.AmtPric.PricVal_Attribute_Ccy")));
		КонецЕсли;
		
		Если НЕ ПараметрыПриемник.Свойство("ДатаНачалаПриемаЗаявокНаВыкуп") Тогда
			ПараметрыПриемник.Вставить("ДатаНачалаПриемаЗаявокНаВыкуп", СтроковыеФункцииКлиентСерверПереопределяемый.ДатаВремяИзСтроки(ЗначениеСвойства(УзелИсточник,
				"PrdDtls.ActnPrd.Prd.StartDt.Dt.Dt",
				"PrdDtls.ActnPrd.Prd.StartDt.Dt.DtTm")));
		КонецЕсли;
		
		Если НЕ ПараметрыПриемник.Свойство("ДатаОкончанияПриемаЗаявокНаВыкуп") Тогда
			ПараметрыПриемник.Вставить("ДатаОкончанияПриемаЗаявокНаВыкуп", СтроковыеФункцииКлиентСерверПереопределяемый.ДатаВремяИзСтроки(ЗначениеСвойства(УзелИсточник,
				"PrdDtls.ActnPrd.Prd.EndDt.Dt.Dt",
				"PrdDtls.ActnPrd.Prd.EndDt.Dt.DtTm")));
		КонецЕсли;
		
	КонецЕсли;
КонецПроцедуры

Процедура ПрочитатьУзелSctiesMvmntDtls(УзелИсточник, ПараметрыПриемник)
	ДатаКДРеестрСтр = ЗначениеСвойства(УзелИсточник,
		"DtDtls.PmtDt.Dt.Dt",
		"DtDtls.PmtDt.Dt.DtTm");
	Если ЗначениеЗаполнено(ДатаКДРеестрСтр) Тогда
		ПараметрыПриемник.Вставить("ДатаКДРеестр", СтроковыеФункцииКлиентСерверПереопределяемый.ДатаВремяИзСтроки(ДатаКДРеестрСтр));
	КонецЕсли;
	ПараметрыПриемник.Вставить("ДатаКДРеестрНеизвестна", (ДатаКДРеестрСтр = "UKWN"));
	
	ДатаКДНРДСтр = ЗначениеСвойства(УзелИсточник,
		"DtDtls.EarlstPmtDt.Dt.Dt",
		"DtDtls.EarlstPmtDt.Dt.DtTm");
	Если ЗначениеЗаполнено(ДатаКДНРДСтр) Тогда
		ПараметрыПриемник.Вставить("ДатаКДНРД", СтроковыеФункцииКлиентСерверПереопределяемый.ДатаВремяИзСтроки(ДатаКДНРДСтр));
	КонецЕсли;
	ПараметрыПриемник.Вставить("ДатаКДНРДНеизвестна", (ДатаКДНРДСтр = "UKWN"));
	
	ЦенаРазмещения = ЗначениеСвойства(УзелИсточник, "SctyDtls.IssePric");
	Если ЦенаРазмещения <> Неопределено Тогда
		ПараметрыПриемник.Вставить("ЦенаРазмещения", СтроковыеФункцииКлиентСерверПереопределяемый.ПолучитьЧислоИзСтроки(ЦенаРазмещения));
		ПараметрыПриемник.Вставить("ВалютаЦеныРазмещения", ВалютаПоНаименованию(ЗначениеСвойства(УзелИсточник,
			"SctyDtls.IssePric_Attribute_Ccy")));
	КонецЕсли;
		
	Числитель	= ЗначениеСвойства(УзелИсточник, "RateDtls.NewToOd.QtyToQty.Qty1");
	Знаменатель	= ЗначениеСвойства(УзелИсточник, "RateDtls.NewToOd.QtyToQty.Qty2");
	Если ЗначениеЗаполнено(Числитель) И ЗначениеЗаполнено(Знаменатель) Тогда
		ПараметрыПриемник.Вставить("КоэффициентКонвертации", Числитель + "/" + Знаменатель);
	КонецЕсли;
		
	// Заполнить ценные бумаги
	ISIN = ЗначениеСвойства(УзелИсточник, "SctyDtls.FinInstrmId.ISIN");
	CdtDbtInd = ЗначениеСвойства(УзелИсточник, "CdtDbtInd");
	Если ЗначениеЗаполнено(ISIN) И ЗначениеЗаполнено(CdtDbtInd) Тогда
		ОписаниеЦБ = Новый Структура("ЦеннаяБумага,ДтКт",
			Справочники.ЦенныеБумаги.НайтиПоРеквизиту("ISIN", ISIN), CdtDbtInd);
		
		// Обновить массив ЦенныеБумаги в структуре описания документа
		Если ПараметрыПриемник.Свойство("ЦенныеБумаги") Тогда
			мЦенныеБумаги = ПараметрыПриемник.ЦенныеБумаги;
		Иначе
			мЦенныеБумаги = Новый Массив;
		КонецЕсли;
		мЦенныеБумаги.Добавить(ОписаниеЦБ);
		ПараметрыПриемник.Вставить("ЦенныеБумаги", мЦенныеБумаги);
	КонецЕсли;
КонецПроцедуры

Процедура ПрочитатьУзелSplmtryData(УзелИсточник, ПараметрыПриемник)
	Если Не ПараметрыПриемник.Свойство("АдресВСетиИнтернет") Тогда
		UpdDesc = ЗначениеСвойства(УзелИсточник, "Envlp.XtnsnDt.AddtlInf.AddtlTxt.UpdDesc");
		Если ВРег(UpdDesc) = ВРег("FtpFile") Тогда
			AddtlInf = ЗначениеСвойства(УзелИсточник, "Envlp.XtnsnDt.AddtlInf.AddtlTxt.AddtlInf");
			ПозицияРешеток = Найти(AddtlInf,"##");
			Если ПозицияРешеток > 0 Тогда
				AddtlInf = Прав(AddtlInf, СтрДлина(AddtlInf) - ПозицияРешеток - 1); 
				ПараметрыПриемник.Вставить("АдресВСетиИнтернет", AddtlInf);
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	Если Не ПараметрыПриемник.Свойство("КоэффициентКонвертации") Тогда
		ЗагрузитьКоэффициентКонвертацииПоФормату2(УзелИсточник, ПараметрыПриемник);
	КонецЕсли;
	
	Если Не ПараметрыПриемник.Свойство("НомерСтатьи") Тогда
		ПараметрыПриемник.Вставить("НомерСтатьи", ЗначениеСвойства(УзелИсточник,
			"Envlp.XtnsnDt.RgltrRprtng.LwsInPlc.LwsInPlcCd"));
	КонецЕсли;
	
	Если Не ПараметрыПриемник.Свойство("ВыплатаНа1ЦБ") Тогда
		
		AddtlInf = ЗначениеСвойства(УзелИсточник, "Envlp.XtnsnDt.XtnsnCorpActnOptnDtls");
		Если AddtlInf <> Неопределено Тогда
			
			Если ТипЗнч(AddtlInf) = Тип("Массив") Тогда
				Для Каждого Стр Из AddtlInf Цикл
					ПрочитатьУзелXtnsnCorpActnOptnDtls(Стр, ПараметрыПриемник);
				КонецЦикла;
				
			ИначеЕсли ТипЗнч(AddtlInf) = Тип("Структура") Тогда
				ПрочитатьУзелXtnsnCorpActnOptnDtls(AddtlInf, ПараметрыПриемник);
			КонецЕсли;
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

Процедура ПрочитатьУзелXtnsnCorpActnOptnDtls(УзелИсточник, ПараметрыПриемник)
	OptnNb = ЗначениеСвойства(УзелИсточник, "OptnNb");
	Если OptnNb = "001" Тогда
		
		УзлыВыплатыНа1ЦБ = Новый Массив;
		УзлыВыплатыНа1ЦБ.Добавить("CshMvmntDtls.PricDtls.GncCshPricRcvdPerPdct.AmtPric.PricVal");
		УзлыВыплатыНа1ЦБ.Добавить("CshMvmntDtls.PricDtls.GncCshPricPdPerPdct.AmtPric.PricVal");
		УзлыВыплатыНа1ЦБ.Добавить("CshMvmntDtls.RateAndAmtDtls.IntrstRateUsdForPmt.Amt");
		УзлыВыплатыНа1ЦБ.Добавить("CshMvmntDtls.RateAndAmtDtls.GrssDvddRate.Amt");
		
		Для Каждого УзелВыплатыНа1ЦБ Из УзлыВыплатыНа1ЦБ Цикл
			СтрВыплатаНа1ЦБ = ЗначениеСвойстваИзСтруктурыМассива(УзелИсточник, УзелВыплатыНа1ЦБ);
			Если ЗначениеЗаполнено(СтрВыплатаНа1ЦБ) Тогда
				ПараметрыПриемник.Вставить("ВыплатаНа1ЦБ", СтроковыеФункцииКлиентСерверПереопределяемый.ПолучитьЧислоИзСтроки(СтрВыплатаНа1ЦБ)); 
				ПараметрыПриемник.Вставить("НаименованиеВалюты",
					СокрЛП(ЗначениеСвойстваИзСтруктурыМассива(УзелИсточник, УзелВыплатыНа1ЦБ + "_Attribute_Ccy"))); 
				Прервать;
			КонецЕсли;
		КонецЦикла;
		
	КонецЕсли;
КонецПроцедуры

Процедура ПрочитатьУзелCorpActnDtls_AddtlInf(УзелИсточник, ПараметрыПриемник)
	Если Не ПараметрыПриемник.Свойство("ИнициаторВыкупа") Тогда
		Если ТипЗнч(ЗначениеСвойства(УзелИсточник, "Offerr")) = Тип("Структура") Тогда
			UpdDesc = ЗначениеСвойства(УзелИсточник, "Offerr.UpdDesc");
			Если ВРЕГ(UpdDesc) = ВРЕГ("Name") Тогда
				AddtlInf = ЗначениеСвойства(УзелИсточник, "Offerr.AddtlInf");
				ПараметрыПриемник.Вставить("ИнициаторВыкупа", AddtlInf);
			КонецЕсли;
		ИначеЕсли ТипЗнч(ЗначениеСвойства(УзелИсточник, "Offerr")) = Тип("Массив") Тогда
			UpdDesc = ЗначениеСвойстваИзСтруктурыМассива(УзелИсточник, "Offerr.UpdDesc");
			Если ВРЕГ(UpdDesc) = ВРЕГ("Name") Тогда
				AddtlInf = ЗначениеСвойстваИзСтруктурыМассива(УзелИсточник, "Offerr.AddtlInf");
				ПараметрыПриемник.Вставить("ИнициаторВыкупа", AddtlInf);
			КонецЕсли;
		Иначе
			Возврат;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

Процедура ЗаполнитьДатаОкончанияПриемаИнструкцийНРДИностранногоЭмитента(УзелXtnsn0, ПараметрыКД)
	Перем Дата;
	Дата = "";
	ИмяСвойства = "DtDtls.RspnDdln.Dt.DtTm";
	
	CorpActnOptnDtls = ЗначениеСвойства(УзелXtnsn0, "XtnsnEnvlp.XtnsnDt.CorpActnOptnDtls");
	Если CorpActnOptnDtls <> Неопределено Тогда
		CorpActnOptnDtls = УзелXtnsn0.XtnsnEnvlp.XtnsnDt.CorpActnOptnDtls;
		Если ТипЗнч(CorpActnOptnDtls) = Тип("Массив") Тогда
			Для Каждого Стр Из CorpActnOptnDtls Цикл
				DtTm = СтроковыеФункцииКлиентСерверПереопределяемый.ДатаВремяИзСтроки(ЗначениеСвойства(Стр, ИмяСвойства));
				Если ЗначениеЗаполнено(DtTm) Тогда
					Если ЗначениеЗаполнено(Дата) Тогда
						Дата = Мин(Дата, DtTm);
					Иначе
						Дата = DtTm;
					КонецЕсли;
				КонецЕсли;
			КонецЦикла;
			
		ИначеЕсли ТипЗнч(CorpActnOptnDtls) = Тип("Структура") Тогда
			DtTm = СтроковыеФункцииКлиентСерверПереопределяемый.ДатаВремяИзСтроки(ЗначениеСвойства(CorpActnOptnDtls, ИмяСвойства));
			Если ЗначениеЗаполнено(DtTm) Тогда
				Дата = DtTm;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Дата) Тогда
		ПараметрыКД.Вставить("ДатаОкончанияПриемаИнструкцийНРДИностранногоЭмитента", Дата);
	КонецЕсли;
КонецПроцедуры

// Заполняет таблицу значений ДанныеКорпоративныхДействий из структуры ДанныеФайла
Процедура ОбработатьДанныеCorporateActionNotification(ДанныеФайла, ФайлZIP)
	// Создание строки по раскрытию
	НоваяСтрока	= ДанныеКорпоративныхДействий.Добавить();
	
	// Перенос значений одноименных реквизитов
	ЗаполнитьЗначенияСвойств(НоваяСтрока, ДанныеФайла);
	
	// Перенос остальных полей
	НоваяСтрока.Обрабатывать	= Истина;
	НоваяСтрока.Организация		= Константы.ОрганизацияПоУмолчанию.Получить();
	НоваяСтрока.Инициатор		= ВышестоящийДепозитарий;
	
	// Определить ВидКД
	ВидКДКод = ЗначениеСвойства(ДанныеФайла, "ВидКД");
	ВидКД = Справочники.ВидыКорпоративныхДействий.НайтиПоКоду(ВидКДКод);
	Если Не ЗначениеЗаполнено(ВидКД) И ЗначениеЗаполнено(ВидКДКод) Тогда
		ВидКДОбъект = Справочники.ВидыКорпоративныхДействий.СоздатьЭлемент();
		ВидКДОбъект.Код = ВидКДКод;
		ВидКДОбъект.Наименование = ВидКДКод;
		ВидКДОбъект.Записать();
		ВидКД = ВидКДОбъект.Ссылка;
	КонецЕсли;
	НоваяСтрока.ВидКД = ВидКД;
	
	// Определить СчетДЕПО
	НомерСчетаДепо = ЗначениеСвойства(ДанныеФайла, "НомерСчетаДепо");
	ЗаполнитьСчетДепоИРеференс(НоваяСтрока, НомерСчетаДепо);
	ОтключитьОбработкуСобственныхСчетов(НоваяСтрока, НомерСчетаДепо);
	
	НоваяСтрока.ДокументКД = Документы.КорпоративноеДействие_Новый.КДПоВходящемуРеференсуИСчетуДепо(
		НоваяСтрока.КДРеференсВходящий, НоваяСтрока.СчетДЕПО);
	Если ЗначениеЗаполнено(НоваяСтрока.КДРеференсСвязанный) Тогда
		НоваяСтрока.КДРеференсСвязанныйСсылка = СвязанноеКД(НоваяСтрока.КДРеференсСвязанный, НоваяСтрока.СчетДЕПО);
	КонецЕсли;
	
	// Найти ЦБ и эмитента
	НоваяСтрока.ЦеннаяБумага1 = ЦеннаяБумагаПоКодуЗагрузкиНДЦ(ЗначениеСвойства(ДанныеФайла, "КодЗагрузкиНДЦ"),
		НоваяСтрока.ВходящийДокументДата);
	Если ЗначениеЗаполнено(НоваяСтрока.ЦеннаяБумага1) Тогда
		НоваяСтрока.Эмитент = НоваяСтрока.ЦеннаяБумага1.Эмитент;
	Иначе
		ЦБ = Справочники.ЦенныеБумаги.НайтиПоРеквизиту("ISIN", ЗначениеСвойства(ДанныеФайла, "ISINДляПоискаЭмитента"));
		НоваяСтрока.Эмитент = ЦБ.Эмитент;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(НоваяСтрока.КДРеференсСвязанныйСсылка) И НужноИскатьСвязанноеКД(ВидКДКод) Тогда
		НоваяСтрока.КДРеференсСвязанныйСсылка = СвязанноеКДПоПервымСимволамРеференсаИСчетуДепо(
			НоваяСтрока.КДРеференсСвязанный, НоваяСтрока.СчетДЕПО, ВидКДКод);
		Если ВидКДКод = "WTRC" И Не ЗначениеЗаполнено(НоваяСтрока.КДРеференсСвязанныйСсылка) Тогда
			Если ЗначениеЗаполнено(НоваяСтрока.ЦеннаяБумага1) Тогда
				ISIN = НоваяСтрока.ЦеннаяБумага1.ISIN;
			Иначе
				ISIN = ЗначениеСвойства(ДанныеФайла, "ISINДляПоискаЭмитента");
			КонецЕсли;
			ОтправитьУведомлениеОНеопределенномСвязанномКДДляWTRC(НоваяСтрока.ВидКД, НоваяСтрока.КДРеференс,
			НоваяСтрока.Эмитент, ISIN);
		КонецЕсли;
	КонецЕсли;
	
	Если ВидКДКод = "WTRC" // Подтверждение освобождения от налогов
		И НЕ Справочники.ЦенныеБумаги.ЦБПодпадаетПодНалоговоеРегулированиеСША(НоваяСтрока.ЦеннаяБумага1) Тогда
		НоваяСтрока.ДатаОкончанияПриемаИнструкцийНРД = ДанныеФайла.ПоследнийСрокПодачиИнструкцийПоНалоговымЛьготам;
		НоваяСтрока.ДатаОкончанияПриемаИнструкцийВТБКБ = Документы.УведомлениеКлиентам.ДобавитьРабочийДень(
			НоваяСтрока.ДатаОкончанияПриемаИнструкцийНРД, -2);
		ОбщегоНазначения.СкопироватьВремя(НоваяСтрока.ДатаОкончанияПриемаИнструкцийВТБКБ,
			НоваяСтрока.ДатаОкончанияПриемаИнструкцийНРД);
	КонецЕсли;
	
	Валюта = ВалютаПоНаименованию(ЗначениеСвойства(ДанныеФайла, "НаименованиеВалюты"));
	НоваяСтрока.ВалютаДивидендаКупона = Валюта;
	НоваяСтрока.БанковскийСчет = ПолучитьБанковскийСчет(НоваяСтрока.Организация, Валюта);
	
	НоваяСтрока.КлючЦенныеБумаги = НовыйКлючСвязиДанныхКДиЦБ();
	
	// Заполнение строк с ценными бумагами для данного документа КД
	Если ДанныеФайла.Свойство("ЦенныеБумаги") Тогда
		Для каждого Строка Из ДанныеФайла.ЦенныеБумаги Цикл
			НоваяСтрокаЦБ = ЦенныеБумаги.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрокаЦБ, Строка);
			НоваяСтрокаЦБ.КлючДанныеКорпоративныхДействий = НоваяСтрока.КлючЦенныеБумаги;
		КонецЦикла;
	КонецЕсли;
	
	ДанныеВариантыУчастия = ЗначениеСвойства(ДанныеФайла, "ВариантыУчастия");
	Если ДанныеВариантыУчастия <> Неопределено Тогда
		Для Каждого Вариант Из ДанныеВариантыУчастия Цикл
			НовыйВариант = ВариантыУчастия.Добавить();
			ЗаполнитьЗначенияСвойств(НовыйВариант, Вариант);
		КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры

// Заполняет таблицу значений ДанныеКорпоративныхДействий из структуры ДанныеФайла
Процедура ОбработатьДанныеMeetingInstructionStatus(ДанныеФайла, ФайлZIP)
	// Создание строки по раскрытию
	НоваяСтрока	= ДанныеКорпоративныхДействий.Добавить();
	НоваяСтрока.ПолноеИмяФайла = ЗначениеСвойства(ДанныеФайла, "ПолноеИмяФайла");
	НоваяСтрока.Обрабатывать				= Истина;
	НоваяСтрока.Организация					= Константы.ОрганизацияПоУмолчанию.Получить();
	НоваяСтрока.Инициатор					= ВышестоящийДепозитарий;
	НоваяСтрока.КодОтчета					= ЗначениеСвойства(ДанныеФайла, "КодОтчета");
	НоваяСтрока.ВходящийДокументДата		= ЗначениеСвойства(ДанныеФайла, "ВходящийДокументДата");
	НоваяСтрока.ВходящийДокументНомер		= ЗначениеСвойства(ДанныеФайла, "ВходящийДокументНомер");
	НоваяСтрока.ИсходныйДокументНомер		= ЗначениеСвойства(ДанныеФайла, "ИсходныйДокументНомер");
	НоваяСтрока.КДРеференсВходящий			= ЗначениеСвойства(ДанныеФайла, "КДРеференсВходящий");
	НоваяСтрока.НеСоздаватьНовоеКД = Истина;
	НоваяСтрока.ДополнительнаяИнформация = ЗначениеСвойства(ДанныеФайла, "СодержимоеФайла");
	
	// Определить СчетДЕПО
	НомерСчетаДепо = ЗначениеСвойства(ДанныеФайла, "НомерСчетаДепо");
	ЗаполнитьСчетДепоИРеференс(НоваяСтрока, НомерСчетаДепо);
	ОтключитьОбработкуСобственныхСчетов(НоваяСтрока, НомерСчетаДепо);
	
	ДокументКД = Неопределено;
	СвязанныйДокументПоКарточкеКД = Неопределено;
	ЗаполнитьДокументыКДПоСообщениюКД(НоваяСтрока.ИсходныйДокументНомер, ДокументКД, СвязанныйДокументПоКарточкеКД);
	Если Не ЗначениеЗаполнено(ДокументКД) Тогда
		ДокументКД = Документы.КорпоративноеДействие_Новый.КДПоВходящемуРеференсуИСчетуДепо(
			НоваяСтрока.КДРеференсВходящий, НоваяСтрока.СчетДЕПО);
	КонецЕсли;
	Если Не ЗначениеЗаполнено(СвязанныйДокументПоКарточкеКД) Тогда
		СвязанныйДокументПоКарточкеКД = ПолучитьРаскрытиеСпискаВладельцев(НоваяСтрока.ИсходныйДокументНомер,
			ДокументКД, ЗначениеСвойства(ДанныеФайла, "RltdBizSvc"), НоваяСтрока.КДРеференсВходящий);
	КонецЕсли;
	НоваяСтрока.ДокументКД = ДокументКД;
	НоваяСтрока.СвязанныйДокументПоКарточкеКД = СвязанныйДокументПоКарточкеКД;
	Если ЗначениеЗаполнено(СвязанныйДокументПоКарточкеКД) Тогда
		СтатусСтрока = ВРЕГ(СокрЛП(ЗначениеСвойства(ДанныеФайла, "Статус")));
		Если ЗначениеЗаполнено(СтатусСтрока) Тогда
			Если СтатусСтрока = "CAND" Тогда
				НоваяСтрока.СвязанныйДокументПоКарточкеКДСтатус = Перечисления.СтатусыРаскрытияСписковВладельцев.Отменено;
			ИначеЕсли СтатусСтрока = "PACK" Тогда
				НоваяСтрока.СвязанныйДокументПоКарточкеКДСтатус = Перечисления.СтатусыРаскрытияСписковВладельцев.Принято;
			ИначеЕсли СтатусСтрока = "COMP" Тогда
				НоваяСтрока.СвязанныйДокументПоКарточкеКДСтатус = Перечисления.СтатусыРаскрытияСписковВладельцев.ОбработкаЗавершена;
			КонецЕсли;
		КонецЕсли;
	Иначе
		Текст = "В регистре сведений 'Этапы КД' не найден документ КД 'Раскрытие списка владельцев'"
			+ " по номеру отправленного сообщения " + НоваяСтрока.ВходящийДокументНомер;
		#Если Клиент Тогда
			Сообщить(Текст, СтатусСообщения.Внимание);
		#Иначе
			ЗаписьЖурналаРегистрации("Загрузка 'Корпоративных действий'", УровеньЖурналаРегистрации.Информация,,, Текст);
		#КонецЕсли
		ОтправитьУведомлениеОНеопределенномРСВ(НоваяСтрока.КДРеференсВходящий);
	КонецЕсли;
КонецПроцедуры

// Заполняет таблицу значений ДанныеКорпоративныхДействий из структуры ДанныеФайла
Процедура ОбработатьДанныеCorporateActionCancellationAdvice(ДанныеФайла)
	// Создание строки по раскрытию
	НоваяСтрока	= ДанныеКорпоративныхДействий.Добавить();
	
	// Перенос значений одноименных реквизитов
	ЗаполнитьЗначенияСвойств(НоваяСтрока, ДанныеФайла);
	
	// Перенос остальных полей
	НоваяСтрока.Обрабатывать	= Истина;
	НоваяСтрока.Организация		= Константы.ОрганизацияПоУмолчанию.Получить();
	НоваяСтрока.Инициатор		= ВышестоящийДепозитарий;
	
	// Определить СчетДЕПО
	НомерСчетаДепо = ЗначениеСвойства(ДанныеФайла, "НомерСчетаДепо");
	ЗаполнитьСчетДепоИРеференс(НоваяСтрока, НомерСчетаДепо);
	ОтключитьОбработкуСобственныхСчетов(НоваяСтрока, НомерСчетаДепо);
	
	НоваяСтрока.ДокументКД = Документы.КорпоративноеДействие_Новый.КДПоВходящемуРеференсуИСчетуДепо(
		НоваяСтрока.КДРеференсВходящий, НоваяСтрока.СчетДЕПО);
	Если ЗначениеЗаполнено(НоваяСтрока.КДРеференсСвязанный) Тогда
		НоваяСтрока.КДРеференсСвязанныйСсылка = СвязанноеКД(НоваяСтрока.КДРеференсСвязанный, НоваяСтрока.СчетДЕПО);
	КонецЕсли;
КонецПроцедуры

