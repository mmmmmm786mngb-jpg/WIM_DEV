// Пакетно загружает документы КД из файлов
//
Процедура ЗагрузитьДокументыКДИзФайлов() Экспорт
	УстановитьПутьККаталогу();
	Если Не ЗначениеЗаполнено(ПутьККаталогу) Тогда
		Возврат;
	КонецЕсли;
	
	ФайлыFCDR_2017_02 = Неопределено;
	ПрочитатьФайлы(ФайлыFCDR_2017_02);
	
	ТребуетсяЗагрузкаFCDR = (ВышестоящийДепозитарий = ОбщегоНазначенияПовтИсп.ЗначениеКонстанты("МестоХраненияПоУмолчанию"));
	ФайлыFCDRЗагружены = Ложь;
	ВходящиеНомераДокументов = Новый Массив;
	
	Если ТребуетсяЗагрузкаFCDR Тогда
		РезультатFCDR = Обработки.РаскрытиеСписковВладельцевFCDR_2017_02.ЗагрузитьВходящиеДокументы(ФайлыFCDR_2017_02);
		ФайлыFCDRЗагружены = РезультатFCDR.Успех;
		ВходящиеНомераДокументов = РезультатFCDR.ВходящиеНомераДокументов;
	КонецЕсли;
	
	СформироватьДокументы();
	Если Не ТребуетсяЗагрузкаFCDR Или ФайлыFCDRЗагружены Тогда
		ПеренестиВАрхив(ВходящиеНомераДокументов);
	КонецЕсли;
КонецПроцедуры

Процедура СоздатьДокументыФайловогоШлюзаПоСтатусуРСВ(РаскрытиеСпискаВладельцевОбъект, СтрокаДанных)
	
	Если ТипЗнч(РаскрытиеСпискаВладельцевОбъект) <> Тип("ДокументОбъект.РаскрытиеСпискаВладельцев")
		Или СтрокаДанных.КодОтчета <> "CA061" Тогда
		Возврат;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	ТехническаяОперация.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.ТехническаяОперация КАК ТехническаяОперация
	|ГДЕ
	|	ТехническаяОперация.ДокументОснование = &ДокументОснование
	|
	|УПОРЯДОЧИТЬ ПО
	|	ТехническаяОперация.Дата УБЫВ";
	
	Запрос.УстановитьПараметр("ДокументОснование", РаскрытиеСпискаВладельцевОбъект.Ссылка);
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда	// По входящему пакету из файлового шлюза сопоставлен документ ""Техническая операция"
		ТехническаяОперация = Выборка.Ссылка;
		ВходящийПакет = Документы.ВходящийПакетИзФайловогоШлюза.СоздатьДокумент();
		ВходящийПакет.ДокументОснование = ТехническаяОперация;
		ВходящийПакет.Дата = ТекущаяДатаСеанса();
		Если ЗначениеЗаполнено(СтрокаДанных.ДополнительнаяИнформация) Тогда
			Чтение = Новый ЧтениеJSON;
			Чтение.УстановитьСтроку(СтрокаДанных.ДополнительнаяИнформация);
			СодержимоеФайла = ПрочитатьJSON(Чтение);
			Чтение.Закрыть();
			Если ТипЗнч(СодержимоеФайла) = Тип("Структура") Тогда
				Для Каждого Элемент Из СодержимоеФайла Цикл
					ПолныйПутьТега = СтрЗаменить(Элемент.Ключ, "_", ".");
					НоваяСтрока = ВходящийПакет.СодержимоеФайла.Добавить();
					НоваяСтрока.Элемент = ПолныйПутьТега;
					НоваяСтрока.Значение = Элемент.Значение;
				КонецЦикла;
				ВходящийПакет.СодержимоеФайла.Сортировать("Элемент");
			КонецЕсли;
		КонецЕсли;
		ВходящийПакет.Записать();
	КонецЕсли;
	
КонецПроцедуры

