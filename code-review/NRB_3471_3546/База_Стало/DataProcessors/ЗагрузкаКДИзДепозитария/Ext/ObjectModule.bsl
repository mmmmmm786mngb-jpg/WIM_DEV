Процедура ОтправитьУведомлениеОНеопределенномСвязанномКДДляWTRC(ВидКД, Знач КДРеференс, Знач Эмитент, Знач ISIN)
	ПВХ = ПланыВидовХарактеристик.ВнешниеИсточники.РассылкаУведомленийОНеопределенномСвязанномКДДляWTRC;
	НастройкиОбмена = ВнешниеДанные.ПолучитьПараметрыВнешнегоИсточника(ПВХ).Настройка;
	Если НастройкиОбмена = Неопределено Тогда
		ОбщегоНазначения.СообщитьОбОшибке("Не удалось получить параметры внешнего источника """ + ПВХ + """");
		Возврат;
	КонецЕсли;
	
	НайденнаяСтрока = НастройкиОбмена.Параметры.Найти("Тема письма", "Наименование");
	Если НайденнаяСтрока = Неопределено Тогда
		ТемаПисьма = "<Без темы>";
	Иначе
		ТемаПисьма = НайденнаяСтрока.Значение;
	КонецЕсли;
	
	КДРеференс	= ?(ЗначениеЗаполнено(КДРеференс), СокрЛП(КДРеференс), "нет данных");
	Эмитент		= ?(ЗначениеЗаполнено(Эмитент), СокрЛП(Эмитент), "нет данных");
	ISIN		= ?(ЗначениеЗаполнено(ISIN), СокрЛП(ISIN), "нет данных");
	ТекстУведомления = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
		"Для КД '%1' КД Референс '%2' (ЦБ '%3' ISIN '%4') не удалось автоматически определить связанное КД. "
		+ "Необходимо ввести данные вручную.", СокрЛП(ВидКД.Наименование), КДРеференс, Эмитент, ISIN);

	ПараметрыУведомления = Новый Соответствие;
	ПараметрыУведомления.Вставить("НастройкиОбмена",	НастройкиОбмена);
	ПараметрыУведомления.Вставить("Кодировка",			"UTF-8");
	ПараметрыУведомления.Вставить("ТемаПисьма",			ТемаПисьма);
	ПараметрыУведомления.Вставить("ТекстПисьма",		ТекстУведомления);
	ПараметрыУведомления.Вставить("ТипТекстаПисьма",	ТипТекстаПочтовогоСообщения.ПростойТекст);
	ПараметрыУведомления.Вставить("Важность",			ВажностьИнтернетПочтовогоСообщения.Обычная);
	
	РегистрыСведений.УведомленияКОтправке.ДобавитьУведомлениеКотправке(ПараметрыУведомления);
КонецПроцедуры

Функция СтруктураДокументаXML(ЧтениеXML, Знач ИмяУзла = "")
	СтрУровень = Новый Структура;
	
	Пока ЧтениеXML.Прочитать() И Не ЧтениеXML.ТипУзла = ТипУзлаXML.КонецЭлемента Цикл
		
		Если ЧтениеXML.ТипУзла = ТипУзлаXML.Текст Тогда
			СтрУровень = ЧтениеXML.Значение;
			Если ИмяУзла = "AddtlInf" Тогда
				СтрУровень = СтрУровень + Символы.ПС;
			КонецЕсли;
			
		ИначеЕсли Не ЧтениеXML.ТипУзла = ТипУзлаXML.КонецЭлемента Тогда
			
			// Добавить атрибуты тега
			Если ЧтениеXML.КоличествоАтрибутов() > 0 Тогда
				Владелец = ЧтениеXML.Имя;
				Пока ЧтениеXML.ПрочитатьАтрибут() Цикл
					ИмяАтрибута = Владелец + "_Attribute_" + ЧтениеXML.Имя; // Формат обращения к атрибуту тега
					СтрУровень.Вставить(ИмяАтрибута, ЧтениеXML.Значение);
				КонецЦикла;
			КонецЕсли;
			
			ВложУровень = СтруктураДокументаXML(ЧтениеXML, ЧтениеXML.Имя);
			
			Если Не СтрУровень.Свойство(ЧтениеXML.Имя) Тогда
				Если ЧтениеXML.Имя = "Scty"
					Или ЧтениеXML.Имя = "Rsltn" 
					Или ЧтениеXML.Имя = "Xtnsn" 
					Или ЧтениеXML.Имя = "Pos"
					Или ЧтениеXML.Имя = "HldgBal"
					Или ЧтениеXML.Имя = "VoteInstrTp"
					Или ЧтениеXML.Имя = "VoteRslt"
					Или ЧтениеXML.Имя = "VtAddRqrmnts"
					Тогда
					СвойствоМассив = Новый Массив;
					СвойствоМассив.Добавить(ВложУровень);
					СтрУровень.Вставить(ЧтениеXML.Имя,СвойствоМассив);
				Иначе
					СтрУровень.Вставить(ЧтениеXML.Имя,ВложУровень);
				КонецЕсли;
				
			ИначеЕсли ТипЗнч(СтрУровень[ЧтениеXML.Имя]) = Тип("Структура") Тогда
				// Заменить структуру на массив и из структуры перекинуть в массив
				СвойствоМассив = Новый Массив;
				СвойствоМассив.Добавить(СтрУровень[ЧтениеXML.Имя]);
				СвойствоМассив.Добавить(ВложУровень);
				СтрУровень.Вставить(ЧтениеXML.Имя, СвойствоМассив);
				
			ИначеЕсли ТипЗнч(СтрУровень[ЧтениеXML.Имя]) = Тип("Массив") Тогда 
				СтрУровень[ЧтениеXML.Имя].Добавить(ВложУровень);
				
			ИначеЕсли ТипЗнч(СтрУровень[ЧтениеXML.Имя]) = Тип("Строка") Тогда
				СтрУровень[ЧтениеXML.Имя] = СтрУровень[ЧтениеXML.Имя] + ВложУровень;
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
	Возврат СтрУровень;
КонецФункции

Функция СоздатьТаблицуДляЦБ()
	ТаблицаПоЦБ	= Новый ТаблицаЗначений;
	ТаблицаПоЦБ.Колонки.Добавить("FaceAmnt");
	ТаблицаПоЦБ.Колонки.Добавить("Unit");
	ТаблицаПоЦБ.Колонки.Добавить("BalTp");
	ТаблицаПоЦБ.Колонки.Добавить("Dt");
	ТаблицаПоЦБ.Колонки.Добавить("SfkpgPlc");
	Возврат ТаблицаПоЦБ;
КонецФункции

// Возвращает значение свойства ИмяСвойства из исходной структуры.
// Если имя свойства содержит точки, то возвращается значение самого глубокого вложенного свойства.
Функция ЗначениеСвойстваИзСтруктуры(ИсходнаяСтруктура, ИмяСвойства)
	Если ТипЗнч(ИсходнаяСтруктура) = Тип("Структура") Тогда
		ПоложениеТочки = Найти(ИмяСвойства, ".");
		Если ПоложениеТочки > 0 Тогда
			ИмяВложеннойСтруктуры = Лев(ИмяСвойства, ПоложениеТочки-1);
			ВложеннаяСтруктура = ?(ИсходнаяСтруктура.Свойство(ИмяВложеннойСтруктуры),
				ИсходнаяСтруктура[ИмяВложеннойСтруктуры], Неопределено);
			ИмяВложенногоСвойства = Прав(ИмяСвойства, СтрДлина(ИмяСвойства)- ПоложениеТочки);
			Возврат ЗначениеСвойства(ВложеннаяСтруктура, ИмяВложенногоСвойства);
		Иначе
			Возврат ?(ИсходнаяСтруктура.Свойство(ИмяСвойства), ИсходнаяСтруктура[ИмяСвойства], Неопределено);
		КонецЕсли;
	Иначе
		Возврат Неопределено;
	КонецЕсли;
КонецФункции

// Возвращает первое непустое значение из перечисленных свойств
Функция ЗначениеСвойства(ИсходнаяСтруктура, ИмяСвойства1, ИмяСвойства2 = "", ИмяСвойства3 = "", ИмяСвойства4 = "")
	ЗначениеСвойства = ЗначениеСвойстваИзСтруктуры(ИсходнаяСтруктура, ИмяСвойства1);
	
	Если ЗначениеСвойства = Неопределено И ЗначениеЗаполнено(ИмяСвойства2) Тогда
		ЗначениеСвойства = ЗначениеСвойстваИзСтруктуры(ИсходнаяСтруктура, ИмяСвойства2);
	КонецЕсли;
	
	Если ЗначениеСвойства = Неопределено И ЗначениеЗаполнено(ИмяСвойства3) Тогда
		ЗначениеСвойства = ЗначениеСвойстваИзСтруктуры(ИсходнаяСтруктура, ИмяСвойства3);
	КонецЕсли;
	
	Если ЗначениеСвойства = Неопределено И ЗначениеЗаполнено(ИмяСвойства4) Тогда
		ЗначениеСвойства = ЗначениеСвойстваИзСтруктуры(ИсходнаяСтруктура, ИмяСвойства4);
	КонецЕсли;
	
	Возврат ЗначениеСвойства;
КонецФункции

// Возвращает значение свойства ИмяСвойства из исходной структуры или первое значение из массива ИсходныеДанные.
// Если имя свойства содержит точки, то возвращается значение самого глубокого вложенного свойства.
Функция ЗначениеСвойстваИзСтруктурыМассива(ИсходныеДанные, ИмяСвойства, ИндексЗаполненногоЭлемента = 0)
	ПоложениеТочки = Найти(ИмяСвойства, ".");
	Если ПоложениеТочки > 0 Тогда
		ИмяВложенныхДанных = Лев(ИмяСвойства, ПоложениеТочки - 1);
		ИмяВложенногоСвойства = Прав(ИмяСвойства, СтрДлина(ИмяСвойства) - ПоложениеТочки);
	КонецЕсли;
	
	Если ТипЗнч(ИсходныеДанные) = Тип("Массив") Тогда
		ТекущииЗаполненныйЭлемент = 0;
		Для Каждого ЭлементИсходныхДанных Из ИсходныеДанные Цикл
			Если ПоложениеТочки > 0 Тогда
				ВложенныеДанные = ?(ЭлементИсходныхДанных.Свойство(ИмяВложенныхДанных),
					ЭлементИсходныхДанных[ИмяВложенныхДанных], Неопределено);
				ЗначениеСвойства = ЗначениеСвойстваИзСтруктурыМассива(ВложенныеДанные, ИмяВложенногоСвойства,
					ИндексЗаполненногоЭлемента);
			Иначе
				ЗначениеСвойства = ?(ЭлементИсходныхДанных.Свойство(ИмяСвойства),
					ЭлементИсходныхДанных[ИмяСвойства], Неопределено);
			КонецЕсли;
			Если ЗначениеЗаполнено(ЗначениеСвойства) Тогда
				Если ТекущииЗаполненныйЭлемент = ИндексЗаполненногоЭлемента Тогда
					Возврат ЗначениеСвойства;
				Иначе
					ТекущииЗаполненныйЭлемент = ТекущииЗаполненныйЭлемент + 1;
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;
		
	ИначеЕсли ТипЗнч(ИсходныеДанные) = Тип("Структура") Тогда
		Если ПоложениеТочки > 0 Тогда
			ВложенныеДанные = ?(ИсходныеДанные.Свойство(ИмяВложенныхДанных), ИсходныеДанные[ИмяВложенныхДанных], Неопределено);
			Возврат ЗначениеСвойстваИзСтруктурыМассива(ВложенныеДанные, ИмяВложенногоСвойства,
				ИндексЗаполненногоЭлемента);
		Иначе
			Возврат ?(ИсходныеДанные.Свойство(ИмяСвойства), ИсходныеДанные[ИмяСвойства], Неопределено);
		КонецЕсли;
	КонецЕсли;
	
	Возврат Неопределено;
КонецФункции

Функция ИзДвоичнойВДесятичную(Двоичное)
	//"000"
	МассивБитов = Новый Массив;
	
	Для НомерБита = 0 По СтрДлина(Двоичное)-1 Цикл
		СтрБита = Новый Структура("Значение, Разряд");
		Бит = Сред(Двоичное,СтрДлина(Двоичное) - НомерБита,1);
		СтрБита.Значение	= Бит;
		СтрБита.Разряд		= СтрДлина(Двоичное)-1 - НомерБита;
		МассивБитов.Добавить(СтрБита);
	КонецЦикла;
	
	Итог = 0;
	Для Каждого Бит ИЗ МассивБитов  Цикл
		Итог = Итог + Бит.Значение * Pow(2, Бит.Разряд);
	КонецЦикла;
	Возврат Итог;
КонецФункции

Функция АдресВСетиИнтернет(Документ, ИмяСвойства, Конверт = "XtnsnEnvlp")
	СтрАдрес = "";
	СвойстваСАдресом = ЗначениеСвойства(Документ, ИмяСвойства);
	Если СвойстваСАдресом <> Неопределено Тогда
		Если ТипЗнч(СвойстваСАдресом) = Тип("Массив") Тогда
			Для Каждого Стр Из СвойстваСАдресом Цикл
				СтрАдрес = АдресВСетиИнтернетИзСвойства(Стр, Конверт);
				Если ЗначениеЗаполнено(СтрАдрес) Тогда
					Прервать;
				КонецЕсли;
			КонецЦикла;
			
		ИначеЕсли ТипЗнч(СвойстваСАдресом) = Тип("Структура") Тогда
			СтрАдрес = АдресВСетиИнтернетИзСвойства(СвойстваСАдресом, Конверт);
		КонецЕсли;
	КонецЕсли;
	Возврат СтрАдрес;
КонецФункции

Функция АдресВСетиИнтернетИзСвойства(Свойство, Конверт)
	СтрАдрес = "";
	СтрПризнак = ЗначениеСвойства(Свойство, Конверт + ".XtnsnDt.AddtlInf.AddtlTxt.UpdDesc");
	Если ВРЕГ(СтрПризнак) = ВРЕГ("FtpFile") Тогда
		СтрАдрес = ЗначениеСвойства(Свойство, Конверт + ".XtnsnDt.AddtlInf.AddtlTxt.AddtlInf");
		ПозицияРешеток = Найти(СтрАдрес, "##");
		Если ПозицияРешеток > 0 Тогда
			СтрАдрес = Прав(СтрАдрес, СтрДлина(СтрАдрес)-ПозицияРешеток-1); 
		КонецЕсли;
	КонецЕсли;
	Возврат СтрАдрес;
КонецФункции

Процедура СкопироватьВремя(Приемник, Источник)
	Приемник = Дата(Год(Приемник), Месяц(Приемник), День(Приемник), Час(Источник), Минута(Источник), Секунда(Источник));
КонецПроцедуры

Функция ЦеннаяБумагаПоКодуЗагрузкиНДЦ(КодЗагрузкиНДЦ, ДатаОтбора)
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("НДЦ", Константы.КлассификаторЗагрузкиНДЦ.Получить());
	Запрос.УстановитьПараметр("Код", Сокрлп(КодЗагрузкиНДЦ));
	Запрос.УстановитьПараметр("ДатаОтбора", ДатаОтбора);
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	ВЫРАЗИТЬ(КодыЗагрузки.Владелец КАК Справочник.ЦенныеБумаги).Ссылка КАК ЦеннаяБумага
	|ИЗ
	|	Справочник.КодыЗагрузки КАК КодыЗагрузки
	|ГДЕ
	|	ВЫРАЗИТЬ(КодыЗагрузки.Биржа КАК Справочник.КлассификаторыЗагрузки).Ссылка = &НДЦ
	|	И КодыЗагрузки.Код = &Код
	|	И КодыЗагрузки.Владелец ССЫЛКА Справочник.ЦенныеБумаги
	|	И НЕ КодыЗагрузки.ПометкаУдаления	
	|	И (КодыЗагрузки.ДатаОкончанияДействия = ДАТАВРЕМЯ(1,1,1)
	|		ИЛИ КодыЗагрузки.ДатаОкончанияДействия >= КОНЕЦПЕРИОДА(&ДатаОтбора, ДЕНЬ))";
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.ЦеннаяБумага;
	Иначе
		Возврат Справочники.ЦенныеБумаги.ПустаяСсылка();
	КонецЕсли;
КонецФункции

Функция ВалютаПоНаименованию(НаименованиеВалюты)
	Если ВРЕГ(НаименованиеВалюты) = "RUB" Тогда
		НаименованиеДляПоиска = "SUR";
	Иначе
		НаименованиеДляПоиска = ВРЕГ(НаименованиеВалюты);
	КонецЕсли;
	Возврат Справочники.Валюты.НайтиПоНаименованию(НаименованиеДляПоиска, Истина);
КонецФункции

// Ищет связанный документ "Корпоративное действие новый" по счету Депо
// и переданному референсу в КДРеференс и КДРеференсВходящий
//
// Параметры:
//  КДРеференсСвязанный	 - Строка - референс, по которому осуществляется поиск связанного КД
//  СчетДЕПО			 - СправочникСсылка.СчетаДепоМХ - Счет ДЕПО
// 
// Возвращаемое значение:
//  ДокументСсылка.КорпоративноеДействие_Новый - ссылка на найденный документ
//
Функция СвязанноеКД(КДРеференсСвязанный, СчетДЕПО) Экспорт
	КД = Документы.КорпоративноеДействие_Новый.НайтиПоРеференсуИСчетуДепо(КДРеференсСвязанный, СчетДЕПО);
	
	Если Не ЗначениеЗаполнено(КД) И ЗначениеЗаполнено(КДРеференсСвязанный) И ЗначениеЗаполнено(СчетДЕПО) Тогда
		КД = Документы.КорпоративноеДействие_Новый.КДПоВходящемуРеференсуИСчетуДепо(КДРеференсСвязанный, СчетДЕПО);
	КонецЕсли;
	
	Возврат КД;
КонецФункции

Функция СвязанноеКДПоПервымСимволамРеференсаИСчетуДепо(Референс, СчетДЕПО, ВидКДКод)
	
	Если Не ЗначениеЗаполнено(Референс) Тогда
		Возврат Документы.КорпоративноеДействие_Новый.ПустаяСсылка();
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	КорпоративноеДействие_Новый.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.КорпоративноеДействие_Новый КАК КорпоративноеДействие_Новый
	|ГДЕ
	|	НЕ КорпоративноеДействие_Новый.ПометкаУдаления
	|	И КорпоративноеДействие_Новый.СчетДЕПО = &СчетДЕПО
	|	И ПОДСТРОКА(КорпоративноеДействие_Новый.КДРеференс, 1, 6) = ПОДСТРОКА(&СтрокаПоиска, 1, 6)
	|	И КорпоративноеДействие_Новый.ВидКД.Код <> &ВидКДКод";
	
	Запрос.УстановитьПараметр("ВидКДКод", ВидКДКод);
	Запрос.УстановитьПараметр("СтрокаПоиска", Лев(Референс, 6));
	Запрос.УстановитьПараметр("СчетДЕПО", СчетДЕПО);
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() Тогда
		Возврат Документы.КорпоративноеДействие_Новый.ПустаяСсылка();
	КонецЕсли;
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	Если ВыборкаДетальныеЗаписи.Количество() = 1 Тогда
		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			Возврат ВыборкаДетальныеЗаписи.Ссылка;
		КонецЦикла;
	Иначе
		Возврат Документы.КорпоративноеДействие_Новый.ПустаяСсылка();
	КонецЕсли;
		
КонецФункции

Функция НужноИскатьСвязанноеКД(ВидКДКод)
	Возврат СтрНайти("WTRC,INTR,DVCA,CAPG,MCAL", ВРег(ВидКДКод)) > 0;
КонецФункции

Процедура ОбновитьСвязанныйКДРеференс(КорпоративноеДействиеОбъект)
	
	Если Не ЗначениеЗаполнено(КорпоративноеДействиеОбъект.КДРеференсСвязанныйСсылка) Тогда
		Возврат;
	КонецЕсли;
	
	КорпоративноеДействиеСвязанныйСсылка = КорпоративноеДействиеОбъект.КДРеференсСвязанныйСсылка;
	КорпоративноеДействиеСвязанныйОбъект = КорпоративноеДействиеСвязанныйСсылка.ПолучитьОбъект();
	КорпоративноеДействиеСвязанныйОбъект.КДРеференсСвязанный = КорпоративноеДействиеОбъект.КДРеференс;
	КорпоративноеДействиеСвязанныйОбъект.КДРеференсСвязанныйСсылка = КорпоративноеДействиеОбъект.Ссылка;
	
	Попытка
		КорпоративноеДействиеСвязанныйОбъект.ОбменДанными.Загрузка = Истина;
		КорпоративноеДействиеСвязанныйОбъект.Записать();
	Исключение
		ТекстСообщения = "Не удалось изменить референс связанного корпоративного действия в " + КорпоративноеДействиеСвязанныйСсылка;
		ЗаписьЖурналаРегистрации(ИмяСобытия, УровеньЖурналаРегистрации.Предупреждение,, КорпоративноеДействиеСвязанныйСсылка, ТекстСообщения);
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
	КонецПопытки;
	
КонецПроцедуры

Процедура ЗаполнитьСчетДепоИРеференс(СтрокаТаблицы, НомерСчетаДепо)
	
	СтрокаТаблицы.КДРеференс = СокрЛП(СтрокаТаблицы.КДРеференсВходящий);
	
	Если НомерСчетаДепо <> Неопределено Тогда
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	СчетаДепоМХ.Ссылка КАК СчетДепоМХ,
		|	СчетаДепоМХ.КраткийКод КАК КраткийКод
		|ИЗ
		|	Справочник.СчетаДепоМХ КАК СчетаДепоМХ
		|ГДЕ
		|	СчетаДепоМХ.Код = &НомерСчетаДепо";
		
		Запрос.УстановитьПараметр("НомерСчетаДепо", СокрЛП(НомерСчетаДепо));
		РезультатЗапроса = Запрос.Выполнить();
		
		Если Не РезультатЗапроса.Пустой() Тогда
			Выборка = РезультатЗапроса.Выбрать();
			Выборка.Следующий();
			СтрокаТаблицы.СчетДЕПО = Выборка.СчетДепоМХ;
			СтрокаТаблицы.КДРеференс = СтрокаТаблицы.КДРеференс + СокрЛП(Выборка.КраткийКод);
		КонецЕсли;
		
	Иначе
		
		КраткийКодСчетаДепо = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СчетДЕПО_ПоУмолчанию, "КраткийКод");
		СтрокаТаблицы.СчетДЕПО = СчетДЕПО_ПоУмолчанию;
		СтрокаТаблицы.КДРеференс = СтрокаТаблицы.КДРеференс + СокрЛП(КраткийКодСчетаДепо);
		
	КонецЕсли;
	
КонецПроцедуры

// Определяет код отчета из наименования файла по фрагменту между вторым и третьим нижним подчеркиванием
//
// Параметры:
//  Имяфайла - Строка - имя файла, например, 007600000N_64571659_MN_MEET_ref_689032.xml
// 
// Возвращаемое значение:
//  Строка - код отчета
//
Функция КодОтчетаПоНаименованиюФайла(Имяфайла)
	
	ПоляИмениФайла = СтрРазделить(ИмяФайла, "_", Истина);
	Если ПоляИмениФайла.Количество() < 3 Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	МаркерКодаОтчета = ПоляИмениФайла[2];
	
	Если МаркерКодаОтчета = "MN" Тогда
		Возврат "CA012";
	ИначеЕсли МаркерКодаОтчета = "MC" Тогда
		Возврат "CA021";
	ИначеЕсли МаркерКодаОтчета = "MRD" Тогда
		Возврат "CA081";
	ИначеЕсли МаркерКодаОтчета = "CANO" Тогда
		Возврат "CA311";
	ИначеЕсли МаркерКодаОтчета = "CACN" Тогда
		Возврат "CA391";
	Иначе
		Возврат Неопределено;
	КонецЕсли;
	
КонецФункции

// Устанавливает пусть к файловому шлюзу в зависимости от выбранного депозитария
//
Процедура УстановитьПутьККаталогу() Экспорт
	МестоХраненияНРД = ОбщегоНазначенияПовтИсп.ЗначениеКонстанты("МестоХраненияПоУмолчанию");
	МестоХраненияБЭБ = ОбщегоНазначенияПовтИсп.ЗначениеКонстанты("МестоХраненияБЭБ");
	МестоХраненияРДЦ = ОбщегоНазначенияПовтИсп.ЗначениеКонстанты("МестоХраненияРДЦ");
	Если ВышестоящийДепозитарий = МестоХраненияНРД Тогда
		ВнешнийИсточник = ПланыВидовХарактеристик.ВнешниеИсточники.ШлюзНРД;
	ИначеЕсли ВышестоящийДепозитарий = МестоХраненияБЭБ Тогда
		ВнешнийИсточник = ПланыВидовХарактеристик.ВнешниеИсточники.ФайловыйШлюзБЭБКаталогВходящих;
	ИначеЕсли ВышестоящийДепозитарий = МестоХраненияРДЦ Тогда
		ВнешнийИсточник = ПланыВидовХарактеристик.ВнешниеИсточники.ФайловыйШлюзРДЦКаталогВходящих;
	Иначе
		ТекстСообщения = СтрШаблон("Для вышестоящего депозитария '%1' загрузка не предусмотрена!", ВышестоящийДепозитарий);
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
		ЗаписьЖурналаРегистрации("Загрузка корпоративных действий", УровеньЖурналаРегистрации.Ошибка,,, ТекстСообщения);
		Возврат;
	КонецЕсли;
	
	ПараметрыВИ = ВнешниеДанные.ПолучитьПараметрыВнешнегоИсточника(ВнешнийИсточник);
	Если Не ЗначениеЗаполнено(ПараметрыВИ.Папка) Тогда
		ТекстСообщения = СтрШаблон("Не указан каталог во внешнем источнике '%1'!", ВнешнийИсточник);
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
		ЗаписьЖурналаРегистрации("Загрузка корпоративных действий", УровеньЖурналаРегистрации.Ошибка,,, ТекстСообщения);
		Возврат;
	КонецЕсли;
	ПутьККаталогу = ПараметрыВИ.Папка;
КонецПроцедуры

Процедура ДополнитьВариантыУчастияВКД(ВариантыГолосования, ПараметрыКД)
	Если ПараметрыКД.Свойство("ВариантыУчастия") Тогда
		ВариантыУчастияПоДокументу = ПараметрыКД.ВариантыУчастия;
	Иначе
		ВариантыУчастияПоДокументу = Новый Массив;
	КонецЕсли;
	
	Если ТипЗнч(ВариантыГолосования) = Тип("Структура") Тогда
		ВариантыДляГолосования = Новый Массив;
		ВариантыДляГолосования.Добавить(ВариантыГолосования);
		ВариантыГолосования = ВариантыДляГолосования;
	КонецЕсли;
	
	Для Каждого Вариант Из ВариантыГолосования Цикл
		СпособыПодачиТребования = ЗначениеСвойства(Вариант, "OptnFeatrs");
		Если ТипЗнч(СпособыПодачиТребования) <> Тип("Массив") Тогда
			СпособыПодачиТребований = ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(СпособыПодачиТребования);
		Иначе
			СпособыПодачиТребований = СпособыПодачиТребования;
		КонецЕсли;
		Для каждого СпособПодачи Из СпособыПодачиТребований Цикл
			ДанныеВарианта = Новый Структура(
			"НомерВариантаУчастияКД, КодВариантаУчастияКД, КраткоеОписаниеВариантаУчастияКД, ИнструкцияДляУчастия,
			|КодСпособаПодачиТребования, КраткоеОписаниеСпособаПодачиТребования, ВходящийДокументНомер");
			ДанныеВарианта.НомерВариантаУчастияКД = ЗначениеСвойства(Вариант, "OptnNb");
			ДанныеВарианта.КодВариантаУчастияКД = ЗначениеСвойства(Вариант, "OptnTp.Cd");
			КраткоеОписаниеВариантаУчастияКД = Справочники.ВариантыУчастияВКД.НайтиПоКоду(ДанныеВарианта.КодВариантаУчастияКД).КраткоеОписание;
			ДанныеВарианта.КраткоеОписаниеВариантаУчастияКД = КраткоеОписаниеВариантаУчастияКД;
			ИнструкцияДляУчастия = ЗначениеСвойства(Вариант, "DfltPrcgOrStgInstr.DfltOptnInd");
			// Это не ошибка, по задаче false = Требуется
			ДанныеВарианта.ИнструкцияДляУчастия = ?(ИнструкцияДляУчастия = "false", "Требуется", "Не требуется");
			Если СпособПодачи <> Неопределено И СпособПодачи.Свойство("Prtry") Тогда
				ДанныеВарианта.КодСпособаПодачиТребования = СпособПодачи.Prtry.Id;
				КраткоеОписаниеСпособаПодачиТребования = 
					Справочники.СпособыПодачиТребований.НайтиПоКоду(ДанныеВарианта.КодСпособаПодачиТребования).КраткоеОписание;
				ДанныеВарианта.КраткоеОписаниеСпособаПодачиТребования = КраткоеОписаниеСпособаПодачиТребования;
			КонецЕсли;
			ДанныеВарианта.ВходящийДокументНомер = ПараметрыКД.ВходящийДокументНомер;
			ВариантыУчастияПоДокументу.Добавить(ДанныеВарианта);
		КонецЦикла;
	КонецЦикла;
	ПараметрыКД.Вставить("ВариантыУчастия",ВариантыУчастияПоДокументу);
КонецПроцедуры

// Обработчики дополнительной информации КД

Процедура ОбработатьСодержимоеСообщения(Сообщение, ДополнительнаяИнформация)
	
	Если Не ЗначениеЗаполнено(Сообщение) Тогда
		Возврат;
	КонецЕсли;
	
	UpdDesc = ЗначениеСвойства(Сообщение, "UpdDesc");
	Обрабатывать = Истина;
	Если UpdDesc <> Неопределено И UpdDesc <> "FtpFile" Тогда
		РасшифровкаUpdDesc = СоответствиеРасшифровкиUpdDesc();
		ЗначениеUpdDesc = ?(РасшифровкаUpdDesc[UpdDesc] = Неопределено, UpdDesc, РасшифровкаUpdDesc[UpdDesc]);
		
		Если UpdDesc <> "" Тогда
			ДополнительнаяИнформация = ДополнительнаяИнформация + Символы.ПС + ЗначениеUpdDesc + ":" + Символы.ПС;
		КонецЕсли;
	ИначеЕсли UpdDesc = Неопределено Тогда
		Обрабатывать = Истина;
	Иначе
		Обрабатывать = Ложь;
	КонецЕсли;
	
	Если Обрабатывать Тогда
		AddtlInf = ЗначениеСвойства(Сообщение, "AddtlInf");
		Если ЗначениеЗаполнено(AddtlInf) Тогда
			Если ТипЗнч(AddtlInf) = Тип("Массив") И AddtlInf.Количество() > 0 Тогда
				Для Каждого ПунктAddtlInf Из AddtlInf Цикл
					ДополнительнаяИнформация = ДополнительнаяИнформация + Символы.ПС + ПунктAddtlInf + Символы.ПС;
				КонецЦикла;
			Иначе
				ДополнительнаяИнформация = ДополнительнаяИнформация + Символы.ПС + AddtlInf + Символы.ПС;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

Функция СоответствиеРасшифровкиUpdDesc()
	РасшифровкаUpdDesc = Новый Соответствие;
	РасшифровкаUpdDesc.Вставить("agenda", "Повестка дня");
	РасшифровкаUpdDesc.Вставить("RSLTN", "Структура Повестка дня + проекты решений");
	РасшифровкаUpdDesc.Вставить("AddInform", "Дополнительная информация");
	РасшифровкаUpdDesc.Вставить("RecordDateInform", "Предупреждение, что остатки будут взяты на утро следующего дня после ДФ");
	РасшифровкаUpdDesc.Вставить("CHAN_Comment", "Описание параметров для российских CHAN ");
	РасшифровкаUpdDesc.Вставить("resolution", "Решения собрания");
	РасшифровкаUpdDesc.Вставить("IssONGO", "Пояснения о причине приостановке размещения");
	РасшифровкаUpdDesc.Вставить("ETYP", "Сведения по налоговым льготам");
	РасшифровкаUpdDesc.Вставить("PRPR", "Описание порядка определения цены/ price procedure");
	РасшифровкаUpdDesc.Вставить("comment", "Уточнение результатов голосования с учетом дробного количества");
	РасшифровкаUpdDesc.Вставить("LwsInPlcInf", "Описание основания повлекшее возникновение/прекращение КД");
	РасшифровкаUpdDesc.Вставить("Name", "Наименование (ФИО) выкупающего лица");
	РасшифровкаUpdDesc.Вставить("Date", "Дата подачи обязательного/добровольного предложения выкупающим лицом в общество");
	
	Возврат РасшифровкаUpdDesc;

КонецФункции

Процедура ОбработатьПунктДополнительнаяИнформация(ПунктДопИнфо, ДополнительнаяИнформация)
	
	Если ЗначениеЗаполнено(ЗначениеСвойства(ПунктДопИнфо, "XtnsnEnvlp")) Тогда
		ТребуемыйТег = ЗначениеСвойства(ПунктДопИнфо, "XtnsnEnvlp");
	ИначеЕсли ЗначениеЗаполнено(ЗначениеСвойства(ПунктДопИнфо, "SplmtryData")) Тогда
		ТребуемыйТег = ЗначениеСвойства(ПунктДопИнфо, "SplmtryData");
	Иначе
		Возврат;
	КонецЕсли;
	
	Если ТипЗнч(ТребуемыйТег) = Тип("Массив") Тогда
		Для Каждого ТребуемыйЭлемент Из ТребуемыйТег Цикл
			Если ЗначениеЗаполнено(ЗначениеСвойства(ТребуемыйЭлемент, "XtnsnDt")) Тогда
				ТребуемыйПодпункт = ЗначениеСвойства(ТребуемыйЭлемент, "XtnsnDt");
			ИначеЕсли ЗначениеЗаполнено(ЗначениеСвойства(ТребуемыйЭлемент, "Envlp.XtnsnDt")) Тогда
				ТребуемыйПодпункт = ЗначениеСвойства(ТребуемыйЭлемент, "Envlp.XtnsnDt");
			Иначе
				Продолжить;
			КонецЕсли;
			ОбработатьТегДополнительнойИнформации(ТребуемыйПодпункт, ДополнительнаяИнформация);
		КонецЦикла;
	Иначе
		Если ЗначениеЗаполнено(ЗначениеСвойства(ТребуемыйТег, "XtnsnDt")) Тогда
			ТребуемыйПодпункт = ЗначениеСвойства(ТребуемыйТег, "XtnsnDt");
			ОбработатьТегДополнительнойИнформации(ТребуемыйПодпункт, ДополнительнаяИнформация);
		ИначеЕсли ЗначениеЗаполнено(ЗначениеСвойства(ТребуемыйТег, "Envlp.XtnsnDt")) Тогда
			ТребуемыйПодпункт = ЗначениеСвойства(ТребуемыйТег, "Envlp.XtnsnDt");
			ОбработатьТегДополнительнойИнформации(ТребуемыйПодпункт, ДополнительнаяИнформация);
		Иначе
		КонецЕсли;
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ЗначениеСвойства(ПунктДопИнфо, "AddtlInf")) Тогда
		ОбработатьТегДополнительнойИнформации(ПунктДопИнфо, ДополнительнаяИнформация);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ЗначениеСвойства(ПунктДопИнфо, "CorpActnOptnDtls.AddtlInf")) Тогда
		ОбработатьТегДополнительнойИнформации(ЗначениеСвойства(ПунктДопИнфо, "CorpActnOptnDtls"), ДополнительнаяИнформация);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ЗначениеСвойства(ПунктДопИнфо, "CorpActnDtls.AddtlInf")) Тогда
		ОбработатьТегДополнительнойИнформации(ЗначениеСвойства(ПунктДопИнфо, "CorpActnDtls"), ДополнительнаяИнформация);
	КонецЕсли;
	
	
	ДополнительнаяИнформация = СтрЗаменить(ДополнительнаяИнформация, "Направляем Вам поступившие в НКО АО НРД итоги общего"
	+ " собрания акционеров с целью доведения указанной информации до лиц, имеющих право на участие в данном корпоративном действии.*", "");
	ДополнительнаяИнформация = СтрЗаменить(ДополнительнаяИнформация, "* НРД не отвечает за полноту и достоверность информации, "
	+ "полученной от третьих лиц.", "");
	
КонецПроцедуры

Процедура ОбработатьТегДополнительнойИнформации(ТребуемыйПодпункт, ДополнительнаяИнформация)
	
	Если ЗначениеЗаполнено(ЗначениеСвойства(ТребуемыйПодпункт, "AddtlInf")) Тогда
		AddtlTxt = ЗначениеСвойства(ТребуемыйПодпункт, "AddtlInf.AddtlTxt");
		ОбработатьСодержимоеСообщения(AddtlTxt, ДополнительнаяИнформация);
		
		NrrtvVrsn = ЗначениеСвойства(ТребуемыйПодпункт, "AddtlInf.NrrtvVrsn");
		ОбработатьСодержимоеСообщения(NrrtvVrsn, ДополнительнаяИнформация);
		
		InfConds = ЗначениеСвойства(ТребуемыйПодпункт, "AddtlInf.InfConds");
		ОбработатьСодержимоеСообщения(InfConds, ДополнительнаяИнформация);
		
		InfToCmplyWth = ЗначениеСвойства(ТребуемыйПодпункт, "AddtlInf.InfToCmplyWth");
		ОбработатьСодержимоеСообщения(InfToCmplyWth, ДополнительнаяИнформация);
		
		TaxtnConds = ЗначениеСвойства(ТребуемыйПодпункт, "AddtlInf.TaxtnConds");
		ОбработатьСодержимоеСообщения(TaxtnConds, ДополнительнаяИнформация);
		
		Dsclmr = ЗначениеСвойства(ТребуемыйПодпункт, "AddtlInf.Dsclmr");
		ОбработатьСодержимоеСообщения(Dsclmr, ДополнительнаяИнформация);
		
		DclrtnDtls = ЗначениеСвойства(ТребуемыйПодпункт, "AddtlInf.DclrtnDtls");
		ОбработатьСодержимоеСообщения(DclrtnDtls, ДополнительнаяИнформация);
		
		RegnDtls = ЗначениеСвойства(ТребуемыйПодпункт, "AddtlInf.RegnDtls");
		ОбработатьСодержимоеСообщения(RegnDtls, ДополнительнаяИнформация);
		
		BsktOrIndxInf = ЗначениеСвойства(ТребуемыйПодпункт, "AddtlInf.BsktOrIndxInf");
		ОбработатьСодержимоеСообщения(BsktOrIndxInf, ДополнительнаяИнформация);
		
		Offerr = ЗначениеСвойства(ТребуемыйПодпункт, "AddtlInf.Offerr");
		ОбработатьСодержимоеСообщения(Offerr, ДополнительнаяИнформация);
	Иначе
		Если ЗначениеЗаполнено(ЗначениеСвойства(ТребуемыйПодпункт , "SbLwsInPlc")) Тогда
			AddtlInf = ЗначениеСвойства(ТребуемыйПодпункт, "SbLwsInPlc.AddtlInf");
			ОбработатьСодержимоеСообщения(AddtlInf, ДополнительнаяИнформация);
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

Процедура ДобавитьДополнительнуюИнформацию(Xtnsn, ПараметрыКД)
	
	ОбрабатыватьКД = НеобходимоОбрабатыватьКД(ПараметрыКД.КодОтчета);
	ШапкаДополнительнойИнформации = ЗначениеСвойства(ПараметрыКД, "ДополнительнаяИнформация");
	
	ДополнительнаяИнформация = "";
	Если ОбрабатыватьКД Тогда
		Если ЗначениеЗаполнено(Xtnsn) Тогда
			Если ТипЗнч(Xtnsn) = Тип("Массив") И Xtnsn.Количество() > 0 Тогда
				Для Каждого ПунктДопИнфо Из Xtnsn Цикл
					ОбработатьПунктДополнительнаяИнформация(ПунктДопИнфо, ДополнительнаяИнформация);
				КонецЦикла;
			Иначе
				ОбработатьПунктДополнительнаяИнформация(Xtnsn, ДополнительнаяИнформация);
			КонецЕсли;
		КонецЕсли;
		Если ЗначениеЗаполнено(ШапкаДополнительнойИнформации) Тогда
			ДополнительнаяИнформация = ШапкаДополнительнойИнформации
				+ ?(ЗначениеЗаполнено(ДополнительнаяИнформация), Символы.ПС + ДополнительнаяИнформация, "");
		КонецЕсли;
	КонецЕсли;
	ПараметрыКД.Вставить("ДополнительнаяИнформация", ДополнительнаяИнформация);
КонецПроцедуры

Функция НеобходимоОбрабатыватьКД(КодОтчета)
	ПодходящиеКодыОтчета = Новый Соответствие;
	ПодходящиеКодыОтчета.Вставить("CA011", Истина);
	ПодходящиеКодыОтчета.Вставить("CA012", Истина);
	ПодходящиеКодыОтчета.Вставить("CA013", Истина);
	ПодходящиеКодыОтчета.Вставить("CA014", Истина);
	ПодходящиеКодыОтчета.Вставить("CA021", Истина);
	ПодходящиеКодыОтчета.Вставить("CA081", Истина);
	ПодходящиеКодыОтчета.Вставить("CA082", Истина);
	ПодходящиеКодыОтчета.Вставить("CA311", Истина);
	ПодходящиеКодыОтчета.Вставить("CA312", Истина);
	ПодходящиеКодыОтчета.Вставить("CA313", Истина);
	ПодходящиеКодыОтчета.Вставить("CA391", Истина);
	
	Возврат ПодходящиеКодыОтчета[КодОтчета] <> Неопределено;
	
КонецФункции

Процедура ЗаполнитьДокументыКДПоСообщениюКД(ВходящийДокументНомер, ДокументКД, СвязанныйДокументПоКарточкеКД)
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	ВЫБОР
	|		КОГДА ТИПЗНАЧЕНИЯ(ЭтапыКДСрезПоследних.КД) = ТИП(Документ.РаскрытиеСпискаВладельцев)
	|			ТОГДА ЭтапыКДСрезПоследних.КД.КарточкаКД
	|		ИНАЧЕ ЭтапыКДСрезПоследних.КД
	|	КОНЕЦ КАК КД,
	|	ЭтапыКДСрезПоследних.ДокументКД КАК ДокументКД
	|ИЗ
	|	РегистрСведений.ЭтапыКД КАК ЭтапыКДСрезПоследних
	|ГДЕ
	|	ЭтапыКДСрезПоследних.НомерСообщения = &НомерСообщения
	|
	|УПОРЯДОЧИТЬ ПО
	|	ЭтапыКДСрезПоследних.Период УБЫВ";
	Запрос.УстановитьПараметр("НомерСообщения", ВходящийДокументНомер);
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		ДокументКД = Выборка.КД;
		СвязанныйДокументПоКарточкеКД = Выборка.ДокументКД;
	КонецЕсли;
	
КонецПроцедуры

Процедура ОтправитьУведомлениеОНеопределенномРСВ(РеференсКД)
	ПВХ = ПланыВидовХарактеристик.ВнешниеИсточники.РассылкаУведомленийОНеопределенномСвязанномКД;
	НастройкиОбмена = ВнешниеДанные.ПолучитьПараметрыВнешнегоИсточника(ПВХ).Настройка;
	
	ТемаПисьма = "Ошибка. Не удалось загрузить статус РСВ (Референс КД " + РеференсКД + ")";
	ТекстУведомления = "При обработке файла статуса собрания:
	|Референс КД " + РеференсКД;
	
	ПараметрыУведомления = Новый Соответствие;
	ПараметрыУведомления.Вставить("НастройкиОбмена",	НастройкиОбмена);
	ПараметрыУведомления.Вставить("Кодировка",			"UTF-8");
	ПараметрыУведомления.Вставить("ТемаПисьма",			ТемаПисьма);
	ПараметрыУведомления.Вставить("ТекстПисьма",		ТекстУведомления);
	ПараметрыУведомления.Вставить("ТипТекстаПисьма",	ТипТекстаПочтовогоСообщения.ПростойТекст);
	ПараметрыУведомления.Вставить("Важность",			ВажностьИнтернетПочтовогоСообщения.Обычная);
	
	РегистрыСведений.УведомленияКОтправке.ДобавитьУведомлениеКотправке(ПараметрыУведомления);
КонецПроцедуры

Процедура ДобавитьФиксированныеСтрокиВДополнительнуюИнформацию(ПараметрыКД)
	
	ДополнительнаяИнформация = ЗначениеСвойства(ПараметрыКД, "ДополнительнаяИнформация");
	Если ЗначениеЗаполнено(ДополнительнаяИнформация) Тогда
		ОрганизацияПоУмолчанию = ОбщегоНазначенияПовтИсп.ЗначениеКонстанты("ОрганизацияПоУмолчанию");
		ШапкаДопИнфо = "В адрес Депозитария " + ОрганизацияПоУмолчанию + " поступило следующее сообщение:";
		ДополнительнаяИнформация = ШапкаДопИнфо + Символы.ПС + ДополнительнаяИнформация;
		ПараметрыКД.Вставить("ДополнительнаяИнформация", ДополнительнаяИнформация);
	КонецЕсли;
	
КонецПроцедуры

Процедура ОтключитьОбработкуСобственныхСчетов(Строка, НомерСчетаДепо = Неопределено)
	
	Если ВышестоящийДепозитарий = ОбщегоНазначенияПовтИсп.ЗначениеКонстанты("МестоХраненияПоУмолчанию") Тогда
		
		Если НомерСчетаДепо = Неопределено Тогда
			НомерСчетаДепо = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Строка.СчетДЕПО, "Код");
		КонецЕсли;
		
		Если НомерСчетаДепо <> Неопределено И Не ЗначениеЗаполнено(Справочники.СчетаДепоМХ.НайтиПоКоду(НомерСчетаДепо)) Тогда
			Строка.Обрабатывать = Ложь;
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

Процедура ОтправитьУведомлениеОЗагруженномКДсЭЗО(КДДата, Знач КДРеференс)
	ПВХ = ПланыВидовХарактеристик.ВнешниеИсточники.РассылкаУведомленийОЗагруженномКДсЭЗО;
	НастройкиОбмена = ВнешниеДанные.ПолучитьПараметрыВнешнегоИсточника(ПВХ).Настройка;
	Если НастройкиОбмена = Неопределено Тогда
		ОбщегоНазначения.СообщитьОбОшибке("Не удалось получить параметры внешнего источника """ + ПВХ + """");
		Возврат;
	КонецЕсли;
	
	ТемаПисьма = "КД по Экономически значимой организации";
	
	КДРеференс	= ?(ЗначениеЗаполнено(КДРеференс), СокрЛП(КДРеференс), "нет данных");
	ТекстУведомления = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
		"Внимание! Поступила информация об Экономически значимой организации." + Символы.ВК 
		+ "Входящий документ ""Корпоративное действие Новый"" КД Референс '%1', '%2'." + Символы.ВК
		+ "Необходимо ввести данные вручную!", КДРеференс, КДДата);
	
	ПараметрыУведомления = Новый Соответствие;
	ПараметрыУведомления.Вставить("НастройкиОбмена",	НастройкиОбмена);
	ПараметрыУведомления.Вставить("Кодировка",			"UTF-8");
	ПараметрыУведомления.Вставить("ТемаПисьма",			ТемаПисьма);
	ПараметрыУведомления.Вставить("ТекстПисьма",		ТекстУведомления);
	ПараметрыУведомления.Вставить("ТипТекстаПисьма",	ТипТекстаПочтовогоСообщения.ПростойТекст);
	ПараметрыУведомления.Вставить("Важность",			ВажностьИнтернетПочтовогоСообщения.Обычная);
	
	РегистрыСведений.УведомленияКОтправке.ДобавитьУведомлениеКотправке(ПараметрыУведомления);
КонецПроцедуры


