Перем мКлючСвязиДанныхКДиЦБ;
Перем ИмяСобытия;
Перем ОбработкаНРД Экспорт;
Перем МассивВхНомеров;

Процедура ИнициироватьСоединение(Параметры = Неопределено) Экспорт
	ВнешниеДанные.ИнициироватьСоединение(ОбработкаНРД, "ФайлыНРД", Параметры);
КонецПроцедуры

// Читает данные из файлового шлюза в табличную часть обработки
//
// Параметры:
//  ФайлыFCDR_2017_02	 - Массив, Неопределено - массив структур, в которых содержатся данные файлов FCDR
//  (см. ПолучитьДанныеИзФайла)
//
Процедура ПрочитатьФайлы(ФайлыFCDR_2017_02 = Неопределено) Экспорт
	ДанныеКорпоративныхДействий.Очистить();
	ВопросыКГолосованию.Очистить();
	ЦенныеБумаги.Очистить();
	ВариантыУчастия.Очистить();
	
	Если ВышестоящийДепозитарий = ОбщегоНазначенияПовтИсп.ЗначениеКонстанты("МестоХраненияБЭБ") Тогда
		ОбработатьФайлыБЭБ();
	ИначеЕсли ВышестоящийДепозитарий = ОбщегоНазначенияПовтИсп.ЗначениеКонстанты("МестоХраненияРДЦ") Тогда
		ОбработатьФайлыРДЦ();
	Иначе
		ОбработатьISOФайл(ФайлыFCDR_2017_02);
	КонецЕсли;
КонецПроцедуры

Процедура ОбработатьISOФайл(ФайлыFCDR_2017_02=Неопределено)
	Если ОбработкаНРД = Неопределено Тогда
		ИнициироватьСоединение();
	КонецЕсли;
	
	ФайлыFCDR_2017_02 = Новый Массив;
	ВременныеФайлыСтруктура = ОбработкаНРД.ВременныеФайлыНРД(ПутьККаталогу);
	ВременныеФайлы = ВременныеФайлыСтруктура.Файлы;
	Для Каждого ВременныйФайл Из ВременныеФайлы Цикл
		// Обработать файл
		ОписаниеДанных = ПолучитьДанныеИзФайла(ВременныйФайл.ИмяВременногоФайлаXML, ВременныйФайл.ИсходноеИмяФайла,
												ВременныйФайл.Каталог, ФайлыFCDR_2017_02);
		ОбработатьДанные(ОписаниеДанных);
		
		// Удалить xml-файл из временного каталога
		Попытка
			УдалитьФайлы(ВременныйФайл.ИмяВременногоФайлаXML);
		Исключение
			Сообщить(ОписаниеОшибки());
		КонецПопытки;
	КонецЦикла;
	
	КаталогиКвитанцийКУдалению = ВременныеФайлыСтруктура.КаталогиКвитанцийКУдалению;
	Для Каждого ИнформацияДляАрхивации Из КаталогиКвитанцийКУдалению Цикл
		АрхивироватьВыпискиОтРегистраторов(ИнформацияДляАрхивации.ИмяРегистратора, "W", ИнформацияДляАрхивации.КаталогW);
		ПеренестиКаталогВАрхив("W", ИнформацияДляАрхивации.КаталогW);
	КонецЦикла;
	
	ДанныеКорпоративныхДействий.Сортировать("ВходящийДокументДата,КодОтчета");
КонецПроцедуры

Процедура ОбработатьФайлыБЭБ()
	КаталогБЭБ = ОбщегоНазначенияКлиентСервер.ДобавитьКонечныйРазделительПути(СокрЛП(ПутьККаталогу));
	МаскиИмениФайла = Новый Массив;
	МаскиИмениФайла.Добавить("corp_*.xml");
	
	ТекДата = ПериодНачало;
	СекундВСутках = ОбщегоНазначенияПовтИсп.СекундВСутках();
	Пока ТекДата <= ПериодКонец Цикл
		КаталогБЭБЗаДату = КаталогБЭБ + Формат(ТекДата, "ДФ=yyyy_MM_dd");
		Для Каждого Маска Из МаскиИмениФайла Цикл
			ИнфоСообщенияБЭБЗаДату = НайтиФайлы(КаталогБЭБЗаДату, Маска);
			Для Каждого Файл Из ИнфоСообщенияБЭБЗаДату Цикл
				ОписаниеДанных = ПолучитьДанныеИзФайла(Файл.ПолноеИмя);
				Если ТипЗнч(ОписаниеДанных.ДанныеФайла) = Тип("Структура") Тогда
					ОписаниеДанных.ДанныеФайла.Вставить("ПолноеИмяФайла", Файл.ПолноеИмя);
				КонецЕсли;
				ОбработатьДанные(ОписаниеДанных);
			КонецЦикла;
		КонецЦикла;
		ТекДата = ТекДата + СекундВСутках;
	КонецЦикла;
КонецПроцедуры

// Находит и обрабатывает файлы КД РДЦ
//
Процедура ОбработатьФайлыРДЦ()
	
	КаталогРДЦ = ОбщегоНазначенияКлиентСервер.ДобавитьКонечныйРазделительПути(СокрЛП(ПутьККаталогу));
	ТекДата = ПериодНачало;
	
	СекундВСутках = ОбщегоНазначенияПовтИсп.СекундВСутках();
	
	Пока ТекДата <= ПериодКонец Цикл
		
		КаталогРДЦЗаДату = КаталогРДЦ + Формат(ТекДата, "ДФ=yyyy_MM_dd");
		ИнфоСообщенияРДЦЗаДату = НайтиФайлы(КаталогРДЦЗаДату, "*.xml");
		
		Для Каждого Файл Из ИнфоСообщенияРДЦЗаДату Цикл
			ОписаниеДанных = ПолучитьДанныеИзФайла(Файл.ПолноеИмя);
			Если ТипЗнч(ОписаниеДанных.ДанныеФайла) = Тип("Структура") Тогда
				ОписаниеДанных.ДанныеФайла.Вставить("ПолноеИмяФайла", Файл.ПолноеИмя);
				Если Не ЗначениеЗаполнено(ЗначениеСвойства(ОписаниеДанных.ДанныеФайла, "КодОтчета")) Тогда
					ОписаниеДанных.ДанныеФайла.Вставить("КодОтчета", КодОтчетаПоНаименованиюФайла(Файл.Имя));
				КонецЕсли;
			КонецЕсли;
			ОбработатьДанные(ОписаниеДанных);
		КонецЦикла;
		
		ТекДата = ТекДата + СекундВСутках;
		
	КонецЦикла;
	
КонецПроцедуры

///////////////////////////////////////////////////////////////////////////////////////////////////
// Работа с ISO файлами

Процедура ОбработатьДанные(ОписаниеДанных)
	Если ОписаниеДанных.ДанныеФайла = Неопределено Тогда
		Возврат;
		
	ИначеЕсли ОписаниеДанных.Обработка = "ОбработатьДанныеИзФайлаISO" Тогда
		ОбработатьДанныеИзФайлаISO(ОписаниеДанных.ДанныеФайла, "");
		
	ИначеЕсли ОписаниеДанных.Обработка = "ОбработатьДанныеCorporateActionNotification" Тогда
		ОбработатьДанныеCorporateActionNotification(ОписаниеДанных.ДанныеФайла, "");
		
	ИначеЕсли ОписаниеДанных.Обработка = "ОбработатьДанныеMeetingInstructionStatus" Тогда
		ОбработатьДанныеMeetingInstructionStatus(ОписаниеДанных.ДанныеФайла, "");
		
	ИначеЕсли ОписаниеДанных.Обработка = "ОбработатьДанныеCorporateActionCancellationAdvice" Тогда
		ОбработатьДанныеCorporateActionCancellationAdvice(ОписаниеДанных.ДанныеФайла);
	КонецЕсли;
КонецПроцедуры

// BSLLS:LatinAndCyrillicSymbolInWord-off

Функция ПолучитьДанныеИзФайла(ПолныйПутьФайла, ИсходноеИмяФайлаСПутем = Неопределено, Каталог = Неопределено, 
								ФайлыFCDR_2017_02 = Неопределено)
	ЧтениеXML = Новый ЧтениеXML;
	ЧтениеXML.ОткрытьФайл(ПолныйПутьФайла,,, "windows-1251");
	Результат = Новый Структура("ДанныеФайла,Обработка");
	Пока ЧтениеXML.Прочитать() Цикл
		ЭтоФормат2017 = ЧтениеXML.Имя = "DISCLOSURE_CANCELLATION_REQUEST"
			Или ЧтениеXML.Имя = "DISCLOSURE_REQUEST"
			Или ЧтениеXML.Имя = "REGISTER_OF_SHAREHOLDERS_STATUS_ADVICE"
			Или ЧтениеXML.Имя = "STATEMENT_OF_HOLDINGS";
		
		Если ЧтениеXML.Имя = "xml-stylesheet" Тогда
			Продолжить;
		ИначеЕсли ЧтениеXML.Имя = "MeetingNotification" Тогда
			Результат.Вставить("ДанныеФайла", ОбработатьMeetingNotification(ЧтениеXML));
			Результат.Вставить("Обработка", "ОбработатьДанныеИзФайлаISO");
			
		ИначеЕсли ЧтениеXML.Имя = "MeetingCancellation" Тогда 
			Результат.Вставить("ДанныеФайла", ОбработатьMeetingCancelation(ЧтениеXML));
			Результат.Вставить("Обработка", "ОбработатьДанныеИзФайлаISO");
			
		ИначеЕсли ЧтениеXML.Имя = "MeetingResultDissemination" Тогда
			Результат.Вставить("ДанныеФайла", ОбработатьMeetingResultDissemination(ЧтениеXML));
			Результат.Вставить("Обработка", "ОбработатьДанныеИзФайлаISO");
			
		ИначеЕсли ЧтениеXML.Имя = "CorporateActionNotification" Тогда
			Результат.Вставить("ДанныеФайла", ОбработатьCorporateActionNotification(ЧтениеXML));
			Результат.Вставить("Обработка", "ОбработатьДанныеCorporateActionNotification");
			
		ИначеЕсли ЧтениеXML.Имя = "MeetingInstructionStatus" Тогда
			Результат.Вставить("ДанныеФайла", ОбработатьMeetingInstructionStatus(ЧтениеXML));
			Результат.Вставить("Обработка", "ОбработатьДанныеMeetingInstructionStatus");
			
		ИначеЕсли ЧтениеXML.Имя = "CorporateActionCancellationAdvice" Тогда
			Результат.Вставить("ДанныеФайла", ОбработатьCorporateActionCancellationAdvice(ЧтениеXML));
			Результат.Вставить("Обработка", "ОбработатьДанныеCorporateActionCancellationAdvice");
			
		ИначеЕсли ЭтоФормат2017 Тогда
			ЧтениеXML.Закрыть();
			Файл = Новый ЧтениеТекста(ПолныйПутьФайла,"windows-1251");
			Текст = Файл.Прочитать();
			Файл.Закрыть();
			Результат.Вставить("ДанныеФайла", Текст);
			Результат.Вставить("Обработка", "FCDR_2017_02");
			ФайлыFCDR_2017_02.Добавить(Результат);
		ИначеЕсли ЧтениеXML.Имя = "SRDIIMessages" Тогда
			Результат = РезультатОбработкиSRDIIMessages(ЧтениеXML);
		КонецЕсли;
		
		Прервать;
	КонецЦикла;
	
	Результат.Вставить("ПолныйПутьФайла", ПолныйПутьФайла);
	Результат.Вставить("ИсходноеИмяФайлаСПутем", ИсходноеИмяФайлаСПутем);
	Результат.Вставить("Каталог", Каталог);
	
	Возврат Результат;
КонецФункции
// BSLLS:LatinAndCyrillicSymbolInWord-on

Функция РезультатОбработкиSRDIIMessages(Чтение)
	Результат = Новый Структура("ДанныеФайла,Обработка");
	Результат.Обработка = "ОбработатьДанныеИзФайлаISO";
	
	Документ = СтруктураДокументаXML(Чтение);
	ТипСообщения = ЗначениеСвойства(Документ, "AppHdr.MsgDefIdr");
	Если ТипСообщения = "seev.001.001.10" Тогда
		Результат.ДанныеФайла = РезультатОбработкиMeetingNotificationSRDII(Документ);
	КонецЕсли;
	Если ТипСообщения = "seev.002.001.09" Тогда
		Результат.ДанныеФайла = РезультатОбработкиMeetingCancelationSRDII(Документ);
	КонецЕсли;
	
	Возврат Результат;
КонецФункции

Функция РезультатОбработкиMeetingNotificationSRDII(Документ)
	ПараметрыКД	= Новый Структура;
	
	ПараметрыКД.Вставить("ВходящийДокументНомер", ЗначениеСвойства(Документ, "AppHdr.BizMsgIdr"));
	
	ВходящийДокументДата = СтроковыеФункцииКлиентСерверПереопределяемый.ДатаВремяИзСтроки(ЗначениеСвойства(Документ, "AppHdr.CreDt"));
	ПараметрыКД.Вставить("ВходящийДокументДата", ВходящийДокументДата + СмещениеСтандартногоВремени(ЧасовойПояс()));
	
	ПараметрыКД.Вставить("КДРеференсВходящий",	ЗначениеСвойства(Документ, "Document.MtgNtfctn.Mtg.MtgId"));
	ПараметрыКД.Вставить("ТипСобрания",	ЗначениеСвойства(Документ, "Document.MtgNtfctn.Mtg.TP"));
	ПараметрыКД.Вставить("КодОтчета",	ЗначениеСвойства(Документ, "AppHdr.BizSvc"));
	
	ТипУведомленияКод = ЗначениеСвойства(Документ, "Document.MtgNtfctn.NtfctnGnlInf.NtfctnTp");
	ТипУведомления = Справочники.ТипыУведомления.НайтиПоКоду(ТипУведомленияКод);
	ПараметрыКД.Вставить("ТипУведомления", ТипУведомления);
	
	КлассСобрания = ЗначениеСвойства(Документ, "Document.MtgNtfctn.Mtg.Clssfctn.Cd");
	Если КлассСобрания <> Неопределено Тогда
		ПараметрыКД.Вставить("КлассСобрания", КлассСобрания);
	КонецЕсли;
	
	ПараметрыКД.Вставить("Комментарий", ЗначениеСвойства(Документ, "Document.MtgNtfctn.Vote.AddtlVtngRqrmnts"));
	
	ДатаСтрокой = ЗначениеСвойства(Документ,
		"Document.MtgNtfctn.Vote.VoteDdln.DtOrDtTm.Dt",
		"Document.MtgNtfctn.Vote.VoteDdln.DtOrDtTm.DtTm",
		"Document.MtgNtfctn.Vote.VoteMktDdln.DtOrDtTm.Dt",
		"Document.MtgNtfctn.Vote.VoteMktDdln.DtOrDtTm.DtTm");
	ДатаОкончанияПриемаИнструкцийНРД = СтроковыеФункцииКлиентСерверПереопределяемый.ДатаВремяИзСтроки(ДатаСтрокой);
	ПараметрыКД.Вставить("ДатаОкончанияПриемаИнструкцийНРД", ДатаОкончанияПриемаИнструкцийНРД);
	
	ДатаСтрокой = ЗначениеСвойства(Документ,
			"Document.MtgNtfctn.Vote.VoteMktDdln.DtOrDtTm.Dt",
			"Document.MtgNtfctn.Vote.VoteMktDdln.DtOrDtTm.DtTm");
	ДатаОкончанияПриемаИнструкцийНРДИностранногоЭмитента = СтроковыеФункцииКлиентСерверПереопределяемый.ДатаВремяИзСтроки(ДатаСтрокой);
	ПараметрыКД.Вставить("ДатаОкончанияПриемаИнструкцийНРДИностранногоЭмитента", ДатаОкончанияПриемаИнструкцийНРДИностранногоЭмитента);
	
	ДатаОкончанияПриемаИнструкцийВТБКБ = Документы.УведомлениеКлиентам.ДобавитьРабочийДень(ДатаОкончанияПриемаИнструкцийНРД, -2);
	СкопироватьВремя(ДатаОкончанияПриемаИнструкцийВТБКБ, ДатаОкончанияПриемаИнструкцийНРД);
	ПараметрыКД.Вставить("ДатаОкончанияПриемаИнструкцийВТБКБ", ДатаОкончанияПриемаИнструкцийВТБКБ);
	
	ДатаСтрокой = ЗначениеСвойства(Документ,
		"Document.MtgNtfctn.Mtg.EntitlmntFxgDt.Dt.Dt",
		"Document.MtgNtfctn.Mtg.EntitlmntFxgDt.Dt.DtCd");
	ПараметрыКД.Вставить("ДатаФиксации", СтроковыеФункцииКлиентСерверПереопределяемый.ДатаВремяИзСтроки(ДатаСтрокой));
	
	ПараметрыКД.Вставить("АдресВСетиИнтернет", ЗначениеСвойства(Документ, "Document.MtgNtfctn.Mtg.AddtlDcmnttnURLAdr"));
	МестоПроведенияСобрания = ЗначениеСвойства(Документ, "Document.MtgNtfctn.MtgDtls.Lctn.Adr.AdrLine");
	ПараметрыКД.Вставить("МестоПроведенияСобрания", МестоПроведенияСобрания);
	
	ДатаСтрокой = ЗначениеСвойства(Документ,
		"Document.MtgNtfctn.MtgDtls.DtAndTm.DtOrDtTm.Dt",
		"Document.MtgNtfctn.MtgDtls.DtAndTm.DtOrDtTm.DtTm",
		"Document.MtgNtfctn.MtgDtls.DtAndTm.DtCd");
	ПараметрыКД.Вставить("ДатаПроведенияСобрания", СтроковыеФункцииКлиентСерверПереопределяемый.ДатаВремяИзСтроки(ДатаСтрокой));
		
	УзелScty = ЗначениеСвойства(Документ, "Document.MtgNtfctn.Scty");
	FinInstrmId_Desc = "FinInstrmId.Desc";
	СтруктураПолей = Новый Структура("ISIN,Desc,КодНРД,ГосРегНомер,НомерСчетаДепо,FaceAmnt,Unit,BalTp,Dt,SfkpgPlc");
	СтруктураПолей.ISIN = "FinInstrmId.ISIN";
	СтруктураПолей.Desc = "FinInstrmId.Desc";
	СтруктураПолей.FaceAmnt = "Bal.Qty.FaceAmnt";
	СтруктураПолей.Unit = "Bal.Qty.Unit";
	СтруктураПолей.КодНРД = FinInstrmId_Desc;
	СтруктураПолей.ГосРегНомер = FinInstrmId_Desc;
	ПараметрыКД.Вставить("МассивИнформацииОЦБ", МассивИнформацииОЦБ(УзелScty, СтруктураПолей));
	
	Вопросы = ЗначениеСвойства(Документ, "Document.MtgNtfctn.Rsltn");
	НормальныеВопросы = Новый Массив;
	Если Вопросы <> Неопределено Тогда
		Для Каждого Вопрос Из Вопросы Цикл
			
			// BSLLS:Typo-off
			СтрВопроса = Новый Структура(
				"НомерВопроса, ДляИнформации, КуммулятивныйВопрос, ТекстВопроса, Коэффициент, ВариантыГолосования");
			// BSLLS:Typo-on
			СтрВопроса.НомерВопроса = Вопрос.IssrLabl;
			СтрВопроса.ТекстВопроса = "";
			СтрВопроса.ДляИнформации = Вопрос.ForInfOnly;
			// BSLLS:Typo-off
			СтрВопроса.КуммулятивныйВопрос = Ложь;
			// BSLLS:Typo-on
			СтрВопроса.Коэффициент = 1;
			ОбработатьВложенныйТегКоллекции(Вопрос.Desc, "Desc", СтрВопроса.ТекстВопроса);
			
			СтрокиВариантовГолосования = ВариантыГолосованияВСтрокиДляSRDII(Вопрос);
			СтрВопроса.ВариантыГолосования = ИзДвоичнойВДесятичную(ДвоичнаяСтрокаВариантов(СтрокиВариантовГолосования));
			НормальныеВопросы.Добавить(СтрВопроса);
		КонецЦикла;
	КонецЕсли;
	ПараметрыКД.Вставить("ВариантыГолосования", НормальныеВопросы);
	
	ДобавитьДополнительнуюИнформацию_SRDII(Документ, ПараметрыКД);
	
	Если ПараметрыКД.МассивИнформацииОЦБ.Количество() = 0 Тогда
		Возврат Неопределено;
	Иначе
		Возврат ПараметрыКД;
	КонецЕсли;
КонецФункции

Функция РезультатОбработкиMeetingCancelationSRDII(Документ)
	ПараметрыКД	= Новый Структура;
	
	ПараметрыКД.Вставить("ВходящийДокументНомер", ЗначениеСвойства(Документ, "AppHdr.BizMsgIdr"));
	
	ВходящийДокументДата = СтроковыеФункцииКлиентСерверПереопределяемый.ДатаВремяИзСтроки(ЗначениеСвойства(Документ, "AppHdr.CreDt"));
	ПараметрыКД.Вставить("ВходящийДокументДата", ВходящийДокументДата + СмещениеСтандартногоВремени(ЧасовойПояс()));
	
	ПараметрыКД.Вставить("КДРеференсВходящий",	ЗначениеСвойства(Документ, "Document.MtgCxl.MtgRef.MtgId"));
	ПараметрыКД.Вставить("КодОтчета",	ЗначениеСвойства(Документ, "AppHdr.BizSvc"));
	ПараметрыКД.Вставить("ТипСобрания",	ЗначениеСвойства(Документ, "Document.MtgCxl.MtgRef.TP"));
	
	КлассСобрания = ЗначениеСвойства(Документ, "Document.MtgCxl.MtgRef.Clssfctn.Cd");
	Если КлассСобрания <> Неопределено Тогда
		ПараметрыКД.Вставить("КлассСобрания", КлассСобрания);
	КонецЕсли;
	
	КодПричиныОтмены = ЗначениеСвойства(Документ, "Document.MtgCxl.Rsn.CxlRsnCd.Cd");
	ПричинаОтмена = Справочники.ПричиныОтмены.НайтиПоКоду(КодПричиныОтмены);
	Если Не ЗначениеЗаполнено(ПричинаОтмена) И ЗначениеЗаполнено(КодПричиныОтмены) Тогда
		ПричинаОтменаОбъект = Справочники.ПричиныОтмены.СоздатьЭлемент();
		ПричинаОтменаОбъект.Код = КодПричиныОтмены;
		ПричинаОтменаОбъект.Наименование = КодПричиныОтмены;
		ПричинаОтменаОбъект.Записать();
		ПричинаОтмена = ПричинаОтменаОбъект.Ссылка;
	КонецЕсли;
	ПараметрыКД.Вставить("ПричинаОтмены", ПричинаОтмена);
	
	УзелScty = ЗначениеСвойства(Документ, "Document.MtgCxl.Scty");
	СтруктураПолей = Новый Структура("КодНРД,НомерСчетаДепо,Unit,BalTp,Dt");
	СтруктураПолей.КодНРД = "FinInstrmId.Desc";
	СтруктураПолей.Unit = "Bal.Qty.Unit";
	ПараметрыКД.Вставить("МассивИнформацииОЦБ", МассивИнформацииОЦБ(УзелScty, СтруктураПолей));
	
	ДобавитьДополнительнуюИнформацию_SRDII(Документ, ПараметрыКД);
	
	Возврат ПараметрыКД;
КонецФункции

Функция ВариантыГолосованияВСтрокиДляSRDII(Вопрос)
	Результат = Новый Массив;
	VoteInstrTp = ЗначениеСвойства(Вопрос, "VoteInstrTp");
	Если ТипЗнч(VoteInstrTp) = Тип("Массив") Тогда
		Для Каждого Элемент Из VoteInstrTp Цикл
			Tp = ЗначениеСвойства(Элемент, "VoteInstrTpCd.Tp");
			Результат.Добавить(Tp);
		КонецЦикла;
	КонецЕсли;
	Возврат Результат;
КонецФункции

Процедура ДобавитьДополнительнуюИнформацию_SRDII(Документ, ПараметрыКД)
	
	ПараметрыКД.Вставить("ДополнительнаяИнформация", "");
	
	ТегКоллекция = ЗначениеСвойства(Документ, "Document.MtgNtfctn.AddtlInf.Dsclmr");
	ОбработатьВложенныйТегКоллекции(ТегКоллекция, "AddtlInf", ПараметрыКД.ДополнительнаяИнформация);
	
	ТегКоллекция = ЗначениеСвойства(Документ, "Document.MtgNtfctn.SplmtryData");
	ОбработатьВложенныйТегКоллекции(ТегКоллекция, "PlcAndNm", ПараметрыКД.ДополнительнаяИнформация);
	
	ТегКоллекция = ЗначениеСвойства(Документ, "Document.MtgCxl.SplmtryData");
	ОбработатьВложенныйТегКоллекции(ТегКоллекция, "PlcAndNm", ПараметрыКД.ДополнительнаяИнформация);
	
	Если ЗначениеЗаполнено(ПараметрыКД.ДополнительнаяИнформация) Тогда
		ДобавитьФиксированныеСтрокиВДополнительнуюИнформацию(ПараметрыКД);
	КонецЕсли;
	
КонецПроцедуры

Процедура ОбработатьВложенныйТегКоллекции(ТегКоллекция, ИмяВложенногоТега, ПараметрДляОбновления)
	
	ЗначениеВложенногоТега = "";
	Если ТипЗнч(ТегКоллекция) = Тип("Массив") Тогда
		Для Каждого ТребуемыйЭлемент Из ТегКоллекция Цикл
			ДополнительнаяИнформацияИзФайла = ЗначениеСвойства(ТребуемыйЭлемент, ИмяВложенногоТега);
			Если ЗначениеЗаполнено(ДополнительнаяИнформацияИзФайла) Тогда
				ЗначениеВложенногоТега = ЗначениеВложенногоТега + ?(ЗначениеЗаполнено(ЗначениеВложенногоТега), Символы.ПС, "")
					+ ДополнительнаяИнформацияИзФайла;
			КонецЕсли;
		КонецЦикла;
	ИначеЕсли ТипЗнч(ТегКоллекция) = Тип("Структура") Тогда
		ЗначениеВложенногоТега = ЗначениеСвойства(ТегКоллекция, ИмяВложенногоТега);
	Иначе
		Возврат;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ЗначениеВложенногоТега) Тогда
		ПараметрДляОбновления = ПараметрДляОбновления + ?(ЗначениеЗаполнено(ПараметрДляОбновления), Символы.ПС, "")
			+ ЗначениеВложенногоТега;
	КонецЕсли;
	
КонецПроцедуры

Процедура ОбработатьДанныеИзФайлаISO(ДанныеФайла, ФайлZIP)
	// Создание строки по раскрытию
	НоваяСтрока	= ДанныеКорпоративныхДействий.Добавить();
	НоваяСтрока.ПолноеИмяФайла = ЗначениеСвойства(ДанныеФайла, "ПолноеИмяФайла");
	НоваяСтрока.Обрабатывать						= Истина;
	НоваяСтрока.Организация							= Константы.ОрганизацияПоУмолчанию.Получить();
	НоваяСтрока.Инициатор							= ВышестоящийДепозитарий;
	НоваяСтрока.ВходящийДокументДата				= ЗначениеСвойства(ДанныеФайла,"ВходящийДокументДата");
	НоваяСтрока.ВходящийДокументНомер				= ЗначениеСвойства(ДанныеФайла,"ВходящийДокументНомер");
	НоваяСтрока.КДРеференсВходящий					= ЗначениеСвойства(ДанныеФайла,"КДРеференсВходящий");
	НоваяСтрока.Комментарий							= ЗначениеСвойства(ДанныеФайла,"Комментарий");
	НоваяСтрока.АдресВСетиИнтернет					= ЗначениеСвойства(ДанныеФайла,"АдресВСетиИнтернет");
	НоваяСтрока.АдресВСетиИнтернетОтмена			= ЗначениеСвойства(ДанныеФайла,"АдресВСетиИнтернетОтмена");
	НоваяСтрока.МестоПроведенияСобрания				= ЗначениеСвойства(ДанныеФайла,"МестоПроведенияСобрания");
	НоваяСтрока.ДатаОкончанияПриемаИнструкцийНРД	= ЗначениеСвойства(ДанныеФайла,"ДатаОкончанияПриемаИнструкцийНРД");
	НоваяСтрока.ДатаОкончанияПриемаИнструкцийНРДИностранногоЭмитента = ЗначениеСвойства(ДанныеФайла,
		"ДатаОкончанияПриемаИнструкцийНРДИностранногоЭмитента");
	НоваяСтрока.ДатаОкончанияПриемаИнструкцийВТБКБ	= ЗначениеСвойства(ДанныеФайла,"ДатаОкончанияПриемаИнструкцийВТБКБ");
	НоваяСтрока.КодОтчета 							= ЗначениеСвойства(ДанныеФайла,"КодОтчета"); 
	НоваяСтрока.ПричинаОтмены 						= ЗначениеСвойства(ДанныеФайла,"ПричинаОтмены"); 
	НоваяСтрока.ДатаФиксации                        = ЗначениеСвойства(ДанныеФайла,"ДатаФиксации"); 
	НоваяСтрока.ТипУведомления 						= ЗначениеСвойства(ДанныеФайла, "ТипУведомления");

	// Определим вид КД
	КодТипСобрания	= СокрЛП(ЗначениеСвойства(ДанныеФайла,"ТипСобрания"));
	ТипСобрания		= Справочники.РСВ_ТипСобрания.НайтиПоКоду(КодТипСобрания);
	Если Не ЗначениеЗаполнено(ТипСобрания) И ЗначениеЗаполнено(КодТипСобрания) Тогда
		ТипСобранияОбъект				= Справочники.РСВ_ТипСобрания.СоздатьЭлемент();
		ТипСобранияОбъект.Код			= КодТипСобрания;
		ТипСобранияОбъект.Наименование	= КодТипСобрания;
		ТипСобранияОбъект.Записать();
		
		ТипСобрания	= ТипСобранияОбъект.Ссылка;
	КонецЕсли;
	НоваяСтрока.ТипСобрания	= ТипСобрания;
	
	КодКлассСобрания = СокрЛП(ЗначениеСвойства(ДанныеФайла,"КлассСобрания"));
	Если Не КодКлассСобрания = Неопределено Тогда
		КлассСобрания = Справочники.РСВ_КлассСобрания.НайтиПоКоду(КодКлассСобрания);
		Если Не ЗначениеЗаполнено(КлассСобрания) И ЗначениеЗаполнено(КодКлассСобрания) Тогда
			КлассСобранияОбъект					= Справочники.РСВ_КлассСобрания.СоздатьЭлемент();
			КлассСобранияОбъект.Код				= КодКлассСобрания;
			КлассСобранияОбъект.Наименование	= КодКлассСобрания;
			КлассСобранияОбъект.Записать();
			
			КлассСобрания = КлассСобранияОбъект.Ссылка;
		КонецЕсли;
		НоваяСтрока.КлассСобрания = КлассСобрания;
	КонецЕсли;
	
	Если КодТипСобрания = "GMET" Тогда
		Если КодКлассСобрания = "AMET" Или КодКлассСобрания = Неопределено Тогда
			ВидКДКод = "MEET";
		ИначеЕсли КодКлассСобрания = "OMET" Тогда
			ВидКДКод = "OMET";
		Иначе
			ВидКДКод	= "BMET";
		КонецЕсли;
	ИначеЕсли КодТипСобрания = "XMET" Тогда
		Если КодКлассСобрания = "CORT" Тогда
			ВидКДКод = "CMET";
		Иначе
			ВидКДКод = "XMET";
		КонецЕсли;
	Иначе
		ВидКДКод = "XMET";
	КонецЕсли;
	
	ВидКД = Справочники.ВидыКорпоративныхДействий.НайтиПоКоду(ВидКДКод);
	Если Не ЗначениеЗаполнено(ВидКД) И ЗначениеЗаполнено(ВидКДКод) Тогда
		ВидКДОбъект				= Справочники.ВидыКорпоративныхДействий.СоздатьЭлемент();
		ВидКДОбъект.Код			= ВидКДКод;
		ВидКДОбъект.Наименование= ВидКДКод;
		ВидКДОбъект.Записать();
		
		ВидКД	= ВидКДОбъект.Ссылка;
	КонецЕсли;
	НоваяСтрока.ВидКД	= ВидКД;
	// Обработаем даты проведения собраний
	НоваяСтрока.ДатаПроведенияСобрания	= ЗначениеСвойства(ДанныеФайла,"ДатаПроведенияСобрания");
	// Обработаем данные по ЦБ и заполним на основании их поля таблицы
	МассивИнформацииЦБ	= ЗначениеСвойства(ДанныеФайла,"МассивИнформацииОЦБ");
	Если МассивИнформацииЦБ <> Неопределено Тогда
		Для Каждого ИнформацияЦБ Из МассивИнформацииЦБ Цикл
			ЦеннаяБумага		= ЦеннаяБумагаПоКодуЗагрузкиНДЦ(ИнформацияЦБ.КодНРД, ТекущаяДатаСеанса());
			Если Не ЗначениеЗаполнено(ЦеннаяБумага) Тогда 
				ВызватьИсключение "При загрузке корпоративного действия не удалось определить ценную бумагу по коду загрузки - " + ИнформацияЦБ.КодНРД;
			КонецЕсли;
			НомерСчетаДепо		= ИнформацияЦБ.ПараметрыЦБНаСчетах.НомерСчетаДепо;
			ЗаполнитьСчетДепоИРеференс(НоваяСтрока, НомерСчетаДепо);
			ОтключитьОбработкуСобственныхСчетов(НоваяСтрока, НомерСчетаДепо);
			
			ДанныеПоСчету = ИнформацияЦБ.ПараметрыЦБНаСчетах.ДанныеПоСчету;
			Если ДанныеПоСчету <> Неопределено Тогда
				Если ДанныеПоСчету.Количество()>0 Тогда
					КоличествоЦБ = ДанныеПоСчету[0].Unit;
				Иначе
					КоличествоЦБ = 0;
				КонецЕсли;
			Иначе
				КоличествоЦБ = 0;
			КонецЕсли;
			
			Если Не ЗначениеЗаполнено(НоваяСтрока.ЦеннаяБумага1) Тогда
				НоваяСтрока.Эмитент					= ЦеннаяБумага.Эмитент;
				НоваяСтрока.ЦеннаяБумага1			= ЦеннаяБумага;
				НоваяСтрока.ЦеннаяБумага1Остаток	= КоличествоЦБ;
			Иначе
				Если НоваяСтрока.ЦеннаяБумага1.Эмитент <> ЦеннаяБумага.Эмитент Тогда
					ВызватьИсключение "При формирова списка 'Раскрытие списка владельцев' - по входящему №"+НоваяСтрока.ВходящийДокументНомер+" от: "+НоваяСтрока.ВходящийДокументДата+" - определены ЦБ с разными 'Эмитентами'";
				КонецЕсли;
				НоваяСтрока.ЦеннаяБумага2			= ЦеннаяБумага;
				НоваяСтрока.ЦеннаяБумага2Остаток	= КоличествоЦБ;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;

	Вопросы = ЗначениеСвойства(ДанныеФайла, "ВариантыГолосования");
	Если Вопросы <> Неопределено Тогда
		Для Каждого Вопрос Из Вопросы Цикл
			НовыйВопрос = ВопросыКГолосованию.Добавить();
			ЗаполнитьЗначенияСвойств(НовыйВопрос, Вопрос);
			НовыйВопрос.ВходящийДокументНомер = ЗначениеСвойства(ДанныеФайла,"ВходящийДокументНомер");
		КонецЦикла;
	КонецЕсли;
	
	ВариантыУчастияФайла = ЗначениеСвойства(ДанныеФайла, "ВариантыУчастия");
	Если ВариантыУчастияФайла <> Неопределено Тогда
		Для Каждого Вариант Из ВариантыУчастияФайла Цикл
			НовыйВариант = ВариантыУчастия.Добавить();
			ЗаполнитьЗначенияСвойств(НовыйВариант, Вариант);
		КонецЦикла;
	КонецЕсли;
	
	НоваяСтрока.ДокументКД = Документы.КорпоративноеДействие_Новый.КДПоВходящемуРеференсуИСчетуДепо(
		НоваяСтрока.КДРеференсВходящий, НоваяСтрока.СчетДЕПО);
		
	НоваяСтрока.ДополнительнаяИнформация = ЗначениеСвойства(ДанныеФайла, "ДополнительнаяИнформация");
КонецПроцедуры

// Переносит загруженные файлы в архивный каталог
//
// Параметры:
//  ВхНомераFCDR2017 - Массив - входящие номера документов FCDR
//
Процедура ПеренестиВАрхив(ВхНомераFCDR2017) Экспорт
	Если ВышестоящийДепозитарий = ОбщегоНазначенияПовтИсп.ЗначениеКонстанты("МестоХраненияПоУмолчанию") Тогда
		ПеренестиВАрхивФайлыНРД(ВхНомераFCDR2017);
	ИначеЕсли ВышестоящийДепозитарий = ОбщегоНазначенияПовтИсп.ЗначениеКонстанты("МестоХраненияБЭБ") Тогда
		ПеренестиФайлыВАрхивПоДатам(ПланыВидовХарактеристик.ВнешниеИсточники.ФайловыйШлюзБЭБКаталогАрхив);
	ИначеЕсли ВышестоящийДепозитарий = ОбщегоНазначенияПовтИсп.ЗначениеКонстанты("МестоХраненияРДЦ") Тогда
		ПеренестиФайлыВАрхивПоДатам(ПланыВидовХарактеристик.ВнешниеИсточники.ФайловыйШлюзРДЦКаталогАрхив);
	КонецЕсли;
КонецПроцедуры

Процедура ПеренестиФайлыВАрхивПоДатам(ВнешнийИсточникАрхив)
	КаталогАрхива = ВнешниеДанные.ПолучитьПараметрыВнешнегоИсточника(ВнешнийИсточникАрхив).Папка;
	Если Не ЗначениеЗаполнено(КаталогАрхива) Тогда
		ОбщегоНазначения.СообщитьОбОшибке("Не удалось получить параметры внешнего источника """ + ВнешнийИсточникАрхив + """");
		Возврат;
	КонецЕсли;
	ПолныйПутьАрхива = ОбщегоНазначенияКлиентСервер.ДобавитьКонечныйРазделительПути(СокрЛП(КаталогАрхива));
	
	ИмяСобытия = "Архивация файлов КД";
	Если ВышестоящийДепозитарий = ОбщегоНазначенияПовтИсп.ЗначениеКонстанты("МестоХраненияБЭБ") Тогда
		ИмяСобытия = ИмяСобытия + " от БЭБ";
	ИначеЕсли ВышестоящийДепозитарий = ОбщегоНазначенияПовтИсп.ЗначениеКонстанты("МестоХраненияРДЦ") Тогда
		ИмяСобытия = ИмяСобытия + " от РДЦ";
	КонецЕсли;
	
	Для Каждого СтрокаТаблицы Из ДанныеКорпоративныхДействий Цикл
		Если МассивВхНомеров.Найти(СтрокаТаблицы.ВходящийДокументНомер) = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		// Из полного имени файла нужно получить имя каталога с датой вида '2021_05_14'
		// Полное имя файла выглядит как ПутьККаталогу + '\' + '2021_05_14' + ИмяФайла
		НаДату = Сред(СтрЗаменить(СтрокаТаблицы.ПолноеИмяФайла, ПутьККаталогу, ""), 2, 10);
		ПолныйПутьАрхиваНаДату = ПолныйПутьАрхива + НаДату;
		ФайлАрхив = Новый Файл(ПолныйПутьАрхиваНаДату);
		Если Не ФайлАрхив.Существует() Тогда
			СоздатьКаталог(ПолныйПутьАрхиваНаДату);
		КонецЕсли;
		ПолноеИмяФайлаВАрхиве = СтрЗаменить(СтрокаТаблицы.ПолноеИмяФайла, ПутьККаталогу, ПолныйПутьАрхива);
		ПереместитьФайл(СтрокаТаблицы.ПолноеИмяФайла, ПолноеИмяФайлаВАрхиве);
		ЗаписьЖурналаРегистрации(ИмяСобытия,
			УровеньЖурналаРегистрации.Информация,
			Метаданные.Обработки.ЗагрузкаКДИзДепозитария,
			,
			"Файл перемещен: " + СтрокаТаблицы.ПолноеИмяФайла + " => " + ПолноеИмяФайлаВАрхиве);
	КонецЦикла;
КонецПроцедуры

Процедура ПеренестиВАрхивФайлыНРД(ВхНомераFCDR2017)
	
	ОбщегоНазначенияКлиентСервер.ЗаменитьНедопустимыеСимволыВИменахФайлов(ВхНомераFCDR2017, "_");
	
	// Найти все каталоги с именем, начинающимся на "Q"
	КаталогиInboxQ = НайтиФайлы(ПутьККаталогу + "\inbox", "Q*");
	Для Каждого КаталогInboxQ ИЗ КаталогиInboxQ Цикл
		Если НЕ КаталогInboxQ.ЭтоКаталог() Тогда
			Продолжить;
		КонецЕсли;
		
		АрхивироватьФайл = Истина;
		ФайлыZIP = НайтиФайлы(КаталогInboxQ.ПолноеИмя,"*.zip",Истина);
		Для Каждого ФайлZIP Из ФайлыZIP Цикл
				НайденныйНомер = МассивВхНомеров.Найти(СокрЛП(ФайлZIP.ИмяБезРасширения));
				НайденныйНомерFCDR2017 = ВхНомераFCDR2017.Найти(СокрЛП(ФайлZIP.ИмяБезРасширения));
				Если НайденныйНомер = Неопределено И НайденныйНомерFCDR2017 = Неопределено Тогда
					АрхивироватьФайл = Ложь;
				КонецЕсли;
		КонецЦикла;
		
		Если Не АрхивироватьФайл Тогда
			Продолжить;
		КонецЕсли;
		
		ПеренестиКаталогВАрхив("Q", КаталогInboxQ);
		
	КонецЦикла;
	
	КаталогиInboxW = НайтиФайлы(ПутьККаталогу + "\inbox", "W*");
	Для Каждого КаталогInboxW Из КаталогиInboxW Цикл
		Если НЕ КаталогInboxW.ЭтоКаталог() Тогда
			Продолжить;
		КонецЕсли;
		АрхивироватьФайл = Ложь;
		ФайлыXML = НайтиФайлы(КаталогInboxW.ПолноеИмя, "*.xml", Истина);
		Для Каждого ФайлXML Из ФайлыXML Цикл
			Если АрхивироватьФайл Тогда
				Прервать;
			КонецЕсли;
			Для Каждого ВхНомер Из ВхНомераFCDR2017 Цикл
				Если АрхивироватьФайл Тогда
					Прервать;
				КонецЕсли;
				Если СтрНайти(ФайлXML.ИмяБезРасширения, ВхНомер) > 0 Тогда
					АрхивироватьФайл = Истина;
				КонецЕсли;
			КонецЦикла;
		КонецЦикла;
		
		Если Не АрхивироватьФайл Тогда
			Продолжить;
		КонецЕсли;
		
		ПеренестиКаталогВАрхив("W", КаталогInboxW);
		
	КонецЦикла;
КонецПроцедуры

Процедура ПеренестиКаталогВАрхив(ВидОтчета, КаталогInbox)
	ПолныйПутьАрхива = ПутьККаталогу + "\Archive";
	ПолныйПутьАрхиваНаТекущуюДату = Обработки.ЗагрузкаКДИзДепозитария.ОбщийКаталогПеремещаемогоФайлаВАрхив(ПолныйПутьАрхива, ВидОтчета);
	
	// Перенос каждого Q/W*-каталога:
	// Пройти по дереву от корня и создать каталоги в папке архива
	КаталогАрхива = ПолныйПутьАрхиваНаТекущуюДату + "\" + КаталогInbox.Имя;
	СоздатьКаталог(КаталогАрхива);
	КлонироватьСтруктуруКаталоговВНовойПапке(КаталогInbox, КаталогАрхива);
	
	// Пройти по дереву от корня: перенести файлы в архив
	ПеренестиФайлыВСтруктуреКаталогов(КаталогInbox, КаталогАрхива);
	
	ЗаписьЖурналаРегистрации("Архивация файлов входящих пакетов (" + ВидОтчета + ")", УровеньЖурналаРегистрации.Информация,
	Метаданные.Обработки.ЗагрузкаКДИзДепозитария,,
	"Каталог " + КаталогInbox.Имя + " перемещен: " + КаталогInbox.ПолноеИмя + " => " + КаталогАрхива);
	
	// Удалить старый каталог и все вложенные каталоги и файлы
	Попытка
		УдалитьФайлы(КаталогInbox.ПолноеИмя);
	Исключение
		Сообщить(ОписаниеОшибки());
	КонецПопытки;
	
КонецПроцедуры

Процедура ПеренестиФайлыВСтруктуреКаталогов(ИсходныйКаталог, ИмяНовогоКаталога, УдалятьВИсточнике = Истина)
	Файлы = НайтиФайлы(ИсходныйКаталог.ПолноеИмя, "*.*");
	Для Каждого Файл Из Файлы Цикл
		Если Файл.ЭтоФайл() Тогда
			Если УдалятьВИсточнике Тогда
				ПереместитьФайл(Файл.ПолноеИмя, ИмяНовогоКаталога + "\" + Файл.Имя);
			Иначе
				КопироватьФайл(Файл.ПолноеИмя, ИмяНовогоКаталога + "\" + Файл.Имя);
			КонецЕсли;
		ИначеЕсли Файл.ЭтоКаталог() Тогда
			ПеренестиФайлыВСтруктуреКаталогов(Файл, ИмяНовогоКаталога + "\" + Файл.Имя)
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

Процедура КлонироватьСтруктуруКаталоговВНовойПапке(ИсходныйКаталог, ИмяНовогоКаталога)
	Каталоги = НайтиФайлы(ИсходныйКаталог.ПолноеИмя, "*.*");
	Для Каждого Каталог Из Каталоги Цикл
		Если Каталог.ЭтоКаталог() Тогда
			ИмяВложенногоКаталога = ИмяНовогоКаталога + "\" + Каталог.Имя;
			СоздатьКаталог(ИмяВложенногоКаталога);
			КлонироватьСтруктуруКаталоговВНовойПапке(Каталог, ИмяВложенногоКаталога);
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

Процедура АрхивироватьВыпискиОтРегистраторов(ИмяРегистратора, ВидОтчета, КаталогInbox)
	
	Если Не ЗначениеЗаполнено(ИмяРегистратора) Тогда
		Возврат;
	КонецЕсли;
	ВнешнийИсточник = ПланыВидовХарактеристик.ВнешниеИсточники.КаталогВыписокОтРегистраторов;
	ПараметрыИсточника = ВнешниеДанные.ПолучитьПараметрыВнешнегоИсточника(ВнешнийИсточник);
	Если ПараметрыИсточника.Папка <> "" Тогда
		ПолныйПутьАрхива = ПараметрыИсточника.Папка + "\" + ИмяРегистратора;
		ТолькоКаталогАрхиваНаДату = Истина;
		ПолныйПутьАрхиваНаТекущуюДату = Обработки.ЗагрузкаКДИзДепозитария.ОбщийКаталогПеремещаемогоФайлаВАрхив(ПолныйПутьАрхива,
											ВидОтчета, ТолькоКаталогАрхиваНаДату);
		КаталогАрхива = ПолныйПутьАрхиваНаТекущуюДату + "\" + КаталогInbox.Имя;
		СоздатьКаталог(КаталогАрхива);
		КлонироватьСтруктуруКаталоговВНовойПапке(КаталогInbox, КаталогАрхива);
		УдалятьВИсточнике = Ложь;
		ПеренестиФайлыВСтруктуреКаталогов(КаталогInbox, КаталогАрхива, УдалятьВИсточнике);
	КонецЕсли;
	
КонецПроцедуры

