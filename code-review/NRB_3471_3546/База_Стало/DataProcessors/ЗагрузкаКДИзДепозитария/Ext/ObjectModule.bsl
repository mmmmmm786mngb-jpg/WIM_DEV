// Работа с данными

Функция ПолучитьБанковскийСчет(Организация, Валюта)
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	БанковскиеСчета.Ссылка
	|ИЗ
	|	Справочник.БанковскиеСчета КАК БанковскиеСчета
	|ГДЕ
	|	НЕ БанковскиеСчета.ПометкаУдаления
	|	И БанковскиеСчета.ВалютаДенежныхСредств = &ВалютаДенежныхСредств
	|	И БанковскиеСчета.ТипНазначения = &ТипНазначения
	|	И БанковскиеСчета.Владелец = &Организация
	|	И (БанковскиеСчета.ДатаЗакрытия > &ТекущаяДата
	|			ИЛИ БанковскиеСчета.ДатаЗакрытия = ДАТАВРЕМЯ(1, 1, 1))");

	Запрос.УстановитьПараметр("Организация"				, Организация);
	Запрос.УстановитьПараметр("ВалютаДенежныхСредств"	, Валюта);
	Запрос.УстановитьПараметр("ТипНазначения"			, ?(Валюта = Константы.ВалютаРегламентированногоУчета.Получить(), Перечисления.ТипыНазначенияБанковскихСчетов.Депозитарный, Перечисления.ТипыНазначенияБанковскихСчетов.ДепозитарныйТранзит));
	Запрос.УстановитьПараметр("ТекущаяДата"				, ТекущаяДата());
	
	Результат = Запрос.Выполнить().Выгрузить();
	
	Если Результат.Количество()>0 Тогда
		Возврат Результат[0].Ссылка;
	Иначе
		Возврат Справочники.БанковскиеСчета.ПустаяСсылка();
	КонецЕсли;
КонецФункции

// Функция - Получить раскрытие списка владельцев
// Ищет РСВ по КДРеференс, если более 1, то берет самое последее по этапам КД по номеру сообщения
// Если RltdBizSvc = "CA044" (на раскрытие списка получили раскрытие списка), то поиск продолжается:
// берется последнее РСВ с указанным КД Референс по данному КД
// Параметры:
//  НомерСообщенияОтправленного	 - Строка - Номер сообщения отправленного
//  КД							 - ДокументСсылка.КорпоративноеДействие_Новый - Ссылка на КД
//  RltdBizSvc					 - Строка - Код формы
//  КДРеференс					 - Строка - КД референс РСВ
// 
// Возвращаемое значение:
//  - ДокументСсылка.РаскрытиеСпискаВладельцев
//
Функция ПолучитьРаскрытиеСпискаВладельцев(НомерСообщенияОтправленного, КД, RltdBizSvc, КДРеференс)
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	РаскрытиеСпискаВладельцев.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.РаскрытиеСпискаВладельцев КАК РаскрытиеСпискаВладельцев
	|ГДЕ
	|	РаскрытиеСпискаВладельцев.КДРеференс = &КДРеференс";
	Запрос.УстановитьПараметр("КДРеференс", КДРеференс);
	Выгрузка = Запрос.Выполнить().Выгрузить();
	Если Выгрузка.Количество() = 1 Тогда
		Возврат Выгрузка[0].Ссылка;
	ИначеЕсли Выгрузка.Количество() > 1 Тогда
		ДокументыРСВ = Выгрузка.ВыгрузитьКолонку("Ссылка");
	Иначе
		Возврат Документы.РаскрытиеСпискаВладельцев.ПустаяСсылка();
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	ЭтапыКД.ДокументКД КАК ДокументКД
	|ИЗ
	|	РегистрСведений.ЭтапыКД КАК ЭтапыКД
	|ГДЕ
	|	ЭтапыКД.НомерСообщения = &НомерСообщения
	|	И ЭтапыКД.ДокументКД В(&ДокументыРСВ)
	|
	|УПОРЯДОЧИТЬ ПО
	|	ЭтапыКД.Период УБЫВ";
	Запрос.УстановитьПараметр("НомерСообщения", СокрЛП(НомерСообщенияОтправленного));
	Запрос.УстановитьПараметр("ДокументыРСВ", ДокументыРСВ);
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.ДокументКД;
	КонецЕсли;
	
	Если СокрЛП(RltdBizSvc) = "CA044" Тогда
		// На раскрытие списка получили раскрытие списка: берется последнее РСВ по данному КД
		Запрос.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	ЭтапыКД.ДокументКД КАК ДокументКД,
		|	ЭтапыКД.Период КАК Период
		|ИЗ
		|	РегистрСведений.ЭтапыКД КАК ЭтапыКД
		|ГДЕ
		|	ЭтапыКД.КД = &КД
		|	И ЭтапыКД.ДокументКД ССЫЛКА Документ.РаскрытиеСпискаВладельцев
		|	И ЭтапыКД.ДокументКД В(&ДокументыРСВ)
		|
		|УПОРЯДОЧИТЬ ПО
		|	Период УБЫВ";
		Запрос.УстановитьПараметр("КД", КД);
		Запрос.УстановитьПараметр("ДокументыРСВ", ДокументыРСВ);
		Выборка = Запрос.Выполнить().Выбрать();
		Если Выборка.Следующий() Тогда
			Возврат Выборка.ДокументКД;
		КонецЕсли;
	КонецЕсли;
	
	Возврат Документы.РаскрытиеСпискаВладельцев.ПустаяСсылка();
КонецФункции

///////////////////////////////////////////////////////////////////////////////////////////////////
// Формирование документов

// Создает/перезаписывает документ "Корпоративное действие новый"
//
Процедура СформироватьДокументы() Экспорт
	ИмяСобытия	= "Загрузка 'Корпоративных действий'";
	Сообщение	= Новый СообщениеПользователю();
	МассивВхНомеров = Новый Массив;
	НачатьТранзакцию();
	Для Каждого Строка Из ДанныеКорпоративныхДействий Цикл
		
		Если Не Строка.Обрабатывать Тогда
			Продолжить;
		КонецЕсли;
		
		ОтключитьОбработкуСобственныхСчетов(Строка);
		
		Если Не Строка.Обрабатывать Тогда
			Продолжить;
		КонецЕсли;
		
		МассивВхНомеров.Добавить(СокрЛП(Строка.ВходящийДокументНомер));
		
		Если Не ЗначениеЗаполнено(Строка.ДокументКД) Тогда
			Строка.ДокументКД = Документы.КорпоративноеДействие_Новый.КДПоВходящемуРеференсуИСчетуДепо(
				Строка.КДРеференсВходящий, Строка.СчетДЕПО);
		КонецЕсли;
		Если Не ЗначениеЗаполнено(Строка.ДокументКД) Тогда
			Строка.ДокументКД = Документы.КорпоративноеДействие_Новый.КДПоВходящемуРеференсуИСчетуДепо(
				Строка.КДРеференсВходящий, Справочники.СчетаДепоМХ.ПустаяСсылка());
		КонецЕсли;
		
		Если ЗначениеЗаполнено(Строка.ДокументКД) Тогда
			КД = Строка.ДокументКД.ПолучитьОбъект();
		ИначеЕсли Строка.НеСоздаватьНовоеКД Тогда
			Если ЗначениеЗаполнено(Строка.СвязанныйДокументПоКарточкеКД) Тогда
				РСВ = Строка.СвязанныйДокументПоКарточкеКД.ПолучитьОбъект();
				РСВ.Статус = Строка.СвязанныйДокументПоКарточкеКДСтатус;
				РСВ.Записать(?(РСВ.Проведен, РежимЗаписиДокумента.Проведение, РежимЗаписиДокумента.Запись));
				МЗ = РегистрыСведений.ЭтапыКД.СоздатьМенеджерЗаписи();
				МЗ.Активность				= Истина;
				МЗ.Период					= Строка.ВходящийДокументДата;
				МЗ.ЭтапКД					= Справочники.ЭтапыКД.НайтиПоКоду(Строка.КодОтчета);
				МЗ.КодОтчета				= Строка.КодОтчета;
				МЗ.НомерСообщения			= Строка.ВходящийДокументНомер;
				МЗ.НомерСообщенияИсходный	= Строка.ИсходныйДокументНомер;
				МЗ.ТипУведомления			= Строка.ТипУведомления;
				МЗ.Исходящее				= Ложь;
				МЗ.КД = Строка.СвязанныйДокументПоКарточкеКД;
				МЗ.ДокументКД = Строка.СвязанныйДокументПоКарточкеКД;
				МЗ.ВозможноФормированиеУведомленияКлиентам = Истина;
				МЗ.Записать();
				СоздатьДокументыФайловогоШлюзаПоСтатусуРСВ(РСВ, Строка);
			КонецЕсли;
			
			Продолжить;
		Иначе
			КД = Документы.КорпоративноеДействие_Новый.СоздатьДокумент();
			КД.Дата = ТекущаяДатаСеанса();
		КонецЕсли;
		ЭтоНовыйКД = КД.ЭтоНовый();
		
		Этап = Справочники.ЭтапыКД.НайтиПоКоду(Строка.КодОтчета);
		Если Этап.Пустая() Тогда
			ТекстСообщения = "Строка " + Строка.НомерСтроки
				+ " не загружена. В справочнике 'Этапы КД' не найден этап с кодом " + Строка.КодОтчета;
			ЗаписьЖурналаРегистрации(ИмяСобытия, УровеньЖурналаРегистрации.Ошибка, , , ТекстСообщения);
			Сообщение.Текст = ТекстСообщения;
			Сообщение.Сообщить();
			Продолжить;
		КонецЕсли;
		
		ЗаполнитьСвойстваКД(КД, Строка, Этап);
		
		// Изменим статус документа раскрытия списка владельцев
		Если (Строка.КодОтчета = "CA061") // Статус обработки инструкции
			И ЗначениеЗаполнено(Строка.СвязанныйДокументПоКарточкеКД)
			И ТипЗнч(Строка.СвязанныйДокументПоКарточкеКД) = Тип("ДокументСсылка.РаскрытиеСпискаВладельцев") Тогда
			
			мОбъект = Строка.СвязанныйДокументПоКарточкеКД.ПолучитьОбъект();
			ЕстьИзменения = Ложь;
			
			СоздатьДокументыФайловогоШлюзаПоСтатусуРСВ(мОбъект, Строка);
			
			Если ЗначениеЗаполнено(Строка.СвязанныйДокументПоКарточкеКДСтатус)
				И Строка.СвязанныйДокументПоКарточкеКД.Статус <> Строка.СвязанныйДокументПоКарточкеКДСтатус Тогда
				мОбъект.Статус = Строка.СвязанныйДокументПоКарточкеКДСтатус;
				ЕстьИзменения = Истина;
			КонецЕсли;
			Если Строка.СвязанныйДокументПоКарточкеКДСтатус = Перечисления.СтатусыРаскрытияСписковВладельцев.ОбработкаЗавершена И Не ЗначениеЗаполнено(мОбъект.ДатаИсполнения) Тогда
				мОбъект.ДатаИсполнения = Строка.ВходящийДокументДата;
				мОбъект.REPORT_ID = Строка.ВходящийДокументНомер;
				ЕстьИзменения = Истина;
			КонецЕсли; 
			Если ЕстьИзменения Тогда
				Попытка
					мОбъект.Записать();
				Исключение
					ТекстСообщения = "Не удалось записать документ с новым статусом.";
					ЗаписьЖурналаРегистрации(ИмяСобытия, УровеньЖурналаРегистрации.Ошибка, , Строка.СвязанныйДокументПоКарточкеКД, ТекстСообщения);
					Сообщение.Текст = ТекстСообщения + " " + Строка.СвязанныйДокументПоКарточкеКДСтатус;
					Сообщение.Сообщить();
				КонецПопытки;
			КонецЕсли; 
			
		КонецЕсли;
		
		// Запишем ЭтапКД
		МЗ = РегистрыСведений.ЭтапыКД.СоздатьМенеджерЗаписи();
		МЗ.Активность				= Истина;
		МЗ.Период					= Строка.ВходящийДокументДата;
		МЗ.ЭтапКД					= Этап;
		МЗ.КодОтчета				= Строка.КодОтчета;
		МЗ.НомерСообщения			= Строка.ВходящийДокументНомер;
		МЗ.НомерСообщенияИсходный	= Строка.ИсходныйДокументНомер;
		МЗ.ТипУведомления			= Строка.ТипУведомления;
		МЗ.Исходящее				= Ложь;
		
		ОбновитьЭтап = Истина;
		Если Не ЭтоНовыйКД Тогда
			СрезЭтапов = РегистрыСведений.ЭтапыКД.СрезПоследних(ТекущаяДатаСеанса(), Новый Структура("КД", КД.Ссылка));
			Если СрезЭтапов.Количество() > 0 Тогда
				Если СрезЭтапов.Получить(0).ЭтапКД = Этап
					И СрезЭтапов.Получить(0).КодОтчета = Строка.КодОтчета
					И СрезЭтапов.Получить(0).НомерСообщения = Строка.ВходящийДокументНомер Тогда
					ОбновитьЭтап = Ложь;
				КонецЕсли;
			КонецЕсли; 
		КонецЕсли;
		
		// КД с видом "Выплата дивидендов в виде денежных средств" должно быть проведено
		Если СокрЛП(КД.ВидКД.Код) = "DVCA" Тогда
			РежимЗаписи = РежимЗаписиДокумента.Проведение;
		Иначе
			РежимЗаписи = РежимЗаписиДокумента.Запись;
		КонецЕсли;
		
		// Запись документа КорпоративноеДействие_Новый
		Попытка
			КД.Записать(РежимЗаписи);
		Исключение
			ТекстСообщения = "Не удалось записать документ.";
			ЗаписьЖурналаРегистрации(ИмяСобытия, УровеньЖурналаРегистрации.Ошибка, ,КД.Ссылка, ТекстСообщения);
			Сообщение.Текст = ТекстСообщения + " " + КД.Ссылка;
			Сообщение.Сообщить();
			Продолжить;
		КонецПопытки;
		
		// Проверить КД на наличие текста Экономически связанная организация
		Если СтрНайти(Строка.ДополнительнаяИнформация, "Экономически значимая организация") > 0 Тогда
			ОтправитьУведомлениеОЗагруженномКДсЭЗО(КД.Дата, КД.КДРеференс);
		КонецЕсли;
		
		ОбновитьСвязанныйКДРеференс(КД);
		
		Если ОбновитьЭтап Тогда
			МЗ.КД = КД.Ссылка;
			Если Строка.КодОтчета = "CA061" И ЗначениеЗаполнено(Строка.СвязанныйДокументПоКарточкеКД) Тогда
				МЗ.ДокументКД = Строка.СвязанныйДокументПоКарточкеКД;
			Иначе
				МЗ.ДокументКД = КД.Ссылка;
			КонецЕсли;
			
			Если ЭтоПодтверждениеОсвобожденияОтНалогов(КД.Ссылка) Тогда
				Если ЭтоНовыйКД Тогда
					МЗ.БПОбработкиWTRCСообщения = НовыйБизнесПроцессОбработкиСообщенияWTRC(МЗ.Период, КД,
						ИмяСобытия);
				Иначе
					МЗ.БПОбработкиWTRCСообщения = БизнесПроцессОбработкиСообщенияWTRCИзЭтаповКД(ТекущаяДатаСеанса(),
						КД.Ссылка);
				КонецЕсли;
			КонецЕсли;
			
			МЗ.ВозможноФормированиеУведомленияКлиентам = Истина;
			// Для НЕ американских ЦБ, формирование всех уведомлений полностью в зоне ответственности БП.
			// Для американских ЦБ формирование уведомлений в зоне ответственности БП начиная с даты указанной в константе ДатаВводаСхемыУведомленийWTRC_QI
			Если ОбщегоНазначения.ЗначениеРеквизитаОбъекта(КД.ВидКД, "Код") = "WTRC" Тогда
				Если Справочники.ЦенныеБумаги.ЦБПодпадаетПодНалоговоеРегулированиеСША(КД.ЦеннаяБумага1) И Не WTRCСообщенияQI.ИспользоватьСхемуУведомленийWTRC_QI(КД.Дата) Тогда 
					РегистрыСведений.ДокументыДляФормированияУведомлений.ДобавитьКорпоративноеДействие(КД.Ссылка, Ложь);	
				КонецЕсли;
			Иначе 
				РегистрыСведений.ДокументыДляФормированияУведомлений.ДобавитьКорпоративноеДействие(КД.Ссылка, Ложь);
			КонецЕсли;
			
			Попытка
				МЗ.Записать();
			Исключение
				ТекстСообщения = "Не удалось сохранить запись в регистре сведений 'ЭтапыКД'";
				ЗаписьЖурналаРегистрации(ИмяСобытия, УровеньЖурналаРегистрации.Ошибка, , КД.Ссылка, ТекстСообщения);
				Сообщение.Текст = ТекстСообщения + " " + КД.Ссылка;
				Сообщение.Сообщить();
				Продолжить;
			КонецПопытки;
			
		КонецЕсли;
		
		Если Не ЭтоНовыйКД Тогда 
			ОбновитьДатыВСвязанныхДокументах(КД.Ссылка, Строка);
		КонецЕсли;
				
		ТекстСообщения = "Документ " + ?(ЭтоНовыйКД, "создан", "изменен");
		ЗаписьЖурналаРегистрации(ИмяСобытия, УровеньЖурналаРегистрации.Информация, , КД.Ссылка, ТекстСообщения);
		Сообщение.Текст = ТекстСообщения + " " + КД.Ссылка;
		Сообщение.Сообщить();
		
		Строка.Обрабатывать	= Ложь;
		Строка.ДокументКД	= КД.Ссылка;
	КонецЦикла;
	ЗафиксироватьТранзакцию();
КонецПроцедуры

Процедура ОбновитьДатыВСвязанныхДокументах(КорпоративноеДействиеСсылка, СтрокаДанныхКорпоративныхДействий)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	РаскрытиеСпискаВладельцев.Ссылка КАК Ссылка,
	|	""РаскрытиеСпискаВладельцев"" КАК ИмяОбъекта,
	|	РаскрытиеСпискаВладельцев.ДатаФиксации КАК ДатаФиксации
	|ИЗ
	|	Документ.РаскрытиеСпискаВладельцев КАК РаскрытиеСпискаВладельцев
	|ГДЕ
	|	РаскрытиеСпискаВладельцев.КарточкаКД = &КорпоративноеДействиеСсылка
	|	И НЕ РаскрытиеСпискаВладельцев.ПометкаУдаления
	|	И (РаскрытиеСпискаВладельцев.ДатаФиксации <> &ДатаФиксации
	|			ИЛИ РаскрытиеСпискаВладельцев.ДатаОкончанияПриема <> &ДатаОкончанияПриемаИнструкцийНРД)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ОбработкаWTRCСообщения.Ссылка,
	|	""ОбработкаWTRCСообщения"",
	|	ОбработкаWTRCСообщения.ДатаФиксации
	|ИЗ
	|	БизнесПроцесс.ОбработкаWTRCСообщения КАК ОбработкаWTRCСообщения
	|ГДЕ
	|	ОбработкаWTRCСообщения.КД = &КорпоративноеДействиеСсылка
	|	И НЕ ОбработкаWTRCСообщения.ПометкаУдаления
	|	И НЕ ОбработкаWTRCСообщения.Завершен
	|	И (ОбработкаWTRCСообщения.ДатаФиксации <> &ДатаФиксации
	|			ИЛИ ОбработкаWTRCСообщения.ДатаОкончанияРаскрытия <> &ДатаОкончанияПриемаИнструкцийНРД)";
	
	Запрос.УстановитьПараметр("КорпоративноеДействиеСсылка", КорпоративноеДействиеСсылка);
	Запрос.УстановитьПараметр("ДатаФиксации", СтрокаДанныхКорпоративныхДействий.ДатаФиксации);
	Запрос.УстановитьПараметр("ДатаОкончанияПриемаИнструкцийНРД", СтрокаДанныхКорпоративныхДействий.ДатаОкончанияПриемаИнструкцийНРД);

	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() Тогда
		Возврат;
	КонецЕсли;
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		
		ДанныеЗаполнения = Новый Структура();
		Если ВыборкаДетальныеЗаписи.ИмяОбъекта = "ОбработкаWTRCСообщения" Тогда
			ДанныеЗаполнения.Вставить("ДатаФиксации", СтрокаДанныхКорпоративныхДействий.ДатаФиксации);
			ДанныеЗаполнения.Вставить("ДатаОкончанияРаскрытия", СтрокаДанныхКорпоративныхДействий.ДатаОкончанияПриемаИнструкцийНРД);
		ИначеЕсли ВыборкаДетальныеЗаписи.ИмяОбъекта = "РаскрытиеСпискаВладельцев"
			И (СтрокаДанныхКорпоративныхДействий.ВидКД = Справочники.ВидыКорпоративныхДействий.WTRC()
			Или Документы.КорпоративноеДействие_Новый.ЭтоВидКДВыкупа(СтрокаДанныхКорпоративныхДействий.ВидКД)
			Или Документы.КорпоративноеДействие_Новый.ЭтоВидКДСобрания(СтрокаДанныхКорпоративныхДействий.ВидКД)) Тогда
			ДанныеЗаполнения.Вставить("ДатаФиксации", СтрокаДанныхКорпоративныхДействий.ДатаФиксации);
			ДанныеЗаполнения.Вставить("ДатаОкончанияПриема",СтрокаДанныхКорпоративныхДействий.ДатаОкончанияПриемаИнструкцийНРД);
		КонецЕсли;
		
		Если ЗначениеЗаполнено(ДанныеЗаполнения) Тогда
			СвязанныйОбъект = ВыборкаДетальныеЗаписи.Ссылка.ПолучитьОбъект();
			ЗаполнитьЗначенияСвойств(СвязанныйОбъект, ДанныеЗаполнения);
			СвязанныйОбъект.Записать();
			
			Сообщение	= Новый СообщениеПользователю();
			ТекстСообщения = СтрШаблон("У связанного объекта %1 изменена дата фиксации и дата окончания приема инструкций НРД", СвязанныйОбъект.Ссылка);
			ЗаписьЖурналаРегистрации(ИмяСобытия, УровеньЖурналаРегистрации.Информация,, СвязанныйОбъект.Ссылка, ТекстСообщения);
			Сообщение.Текст = ТекстСообщения;
			Сообщение.Сообщить();
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

Функция ЭтоПодтверждениеОсвобожденияОтНалогов(КД)
	Возврат ЗначениеЗаполнено(КД)
			И ТипЗнч(КД) = Тип("ДокументСсылка.КорпоративноеДействие_Новый")
			И СокрЛП(КД.ВидКД.Код) = "WTRC";
КонецФункции

Функция НовыйБизнесПроцессОбработкиСообщенияWTRC(ДатаСообщения, КД, ИмяСобытия)
	Сообщение = Новый СообщениеПользователю();
	
	БП = БизнесПроцессы.ОбработкаWTRCСообщения.СоздатьБизнесПроцесс();
	БП.Дата				= ТекущаяДата();
	БП.КД				= КД.Ссылка;
	БП.КДРеференс		= КД.КДРеференс;
	БП.СчетДепоМХ		= КД.СчетДЕПО;
	БП.ЦеннаяБумага1	= КД.ЦеннаяБумага1;
	БП.ЦеннаяБумага2	= КД.ЦеннаяБумага2;
	БП.ДатаКДПлан		= КД.ДатаКДПлан;
	БП.ДатаФиксации		= КД.ДатаФиксации;
	БП.ДатаОкончанияРаскрытия = КД.ДатаОкончанияПриемаИнструкцийНРД;
	
	БП.ДатаОкончанияПриемаФормыW8		= Документы.КорпоративноеДействие_Новый.WTRC_ДатаОкончанияПриемаФормыW8(КД.Ссылка);
	БП.ДатаОкончанияПриемаПоручений1_5	= Документы.КорпоративноеДействие_Новый.WTRC_ДатаОкончанияПриемаПоручений1_5(КД.Ссылка);
	БП.ДатаОкончанияПриемаПоручений1_10	= Документы.КорпоративноеДействие_Новый.WTRC_ДатаОкончанияПриемаПоручений1_10(КД.Ссылка);
	
	БП.ИспользоватьСхемуУсловногоДлящегосяПоручения = Истина; // Все БП, созданные после обновления, работают по этой схеме
	БП.ДатаСообщения = ДатаСообщения;
	БП.ЗаполнитьТаблицуДепонентов();
	
	Попытка
		БП.Записать();
	Исключение
		ТекстСообщения = "Не удалось записать бизнес-процесс 'ОбработкаWTRCСообщения'";
		ЗаписьЖурналаРегистрации(ИмяСобытия, УровеньЖурналаРегистрации.Ошибка,, БП.Ссылка, ТекстСообщения);
		Сообщение.Текст = ТекстСообщения + " " + БП.Ссылка;
		Сообщение.Сообщить();
		Возврат БизнесПроцессы.ОбработкаWTRCСообщения.ПустаяСсылка();
	КонецПопытки;
	
	ТекстСообщения = "Создан новый бизнес-процесс";
	ЗаписьЖурналаРегистрации(ИмяСобытия, УровеньЖурналаРегистрации.Информация,, БП.Ссылка, ТекстСообщения);
	Сообщение.Текст = ТекстСообщения + " " + БП.Ссылка;
	Сообщение.Сообщить();
	
	Возврат БП.Ссылка;
КонецФункции

Функция БизнесПроцессОбработкиСообщенияWTRCИзЭтаповКД(ДатаСреза, КД)
	СрезЭтапов = РегистрыСведений.ЭтапыКД.СрезПоследних(ДатаСреза, Новый Структура("КД", КД));
	Если СрезЭтапов.Количество() > 0 Тогда
		Возврат СрезЭтапов.Получить(0).БПОбработкиWTRCСообщения;
	Иначе
		Возврат БизнесПроцессы.ОбработкаWTRCСообщения.ПустаяСсылка();
	КонецЕсли; 
КонецФункции

Процедура ЗаполнитьСвойстваКД(КД, Строка, Этап)
	ЗаполнятьСвойства		= Истина;
	СвойстваДляЗаполнения	= Неопределено;
	ИсключаяСвойства		= Неопределено;
	
	Если Строка.КодОтчета = "CA021" 			// Сообщение об отмене собрания
		Или Строка.КодОтчета = "ME021" Тогда 	// Сообщение об отмене собрания (SRDII)
		СвойстваДляЗаполнения = "ПричинаОтмены, КДРеференс, КДРеференсВходящий, АдресВСетиИнтернет";
		
	ИначеЕсли Строка.КодОтчета = "CA011"			// Сообщение о собрании по существенному факту
			Или Строка.КодОтчета = "CA012"			// Сообщение о собрании
			Или Строка.КодОтчета = "ME011"			// Сообщение о собрании (SRDII)
			Или Строка.КодОтчета = "CA014" Тогда	// Информация из бюллетеня
		ИсключаяСвойства = "ПричинаОтмены";
		
		ЗаполнитьСвойстваТабЧастиВопросыКГолосованию(КД, Строка.ВходящийДокументНомер,
			"ДляИнформации,КуммулятивныйВопрос,ТекстВопроса,Коэффициент,ВариантыГолосования,НомерВопроса");
		
	ИначеЕсли Строка.КодОтчета = "CA081"			// Сообщение об итогах собрания по существенному факт
			Или Строка.КодОтчета = "CA082" Тогда	// Сообщение об итогах собрания
		СвойстваДляЗаполнения = "КДРеференс, КДРеференсВходящий, АдресВСетиИнтернет";
		
		ЗаполнитьСвойстваТабЧастиВопросыКГолосованию(КД, Строка.ВходящийДокументНомер,
			"За,Против,Воздержался,Принято,НомерВопроса,
			|ДляИнформации,КуммулятивныйВопрос,ТекстВопроса,Коэффициент,ВариантыГолосования");
		
	ИначеЕсли Строка.КодОтчета = "CA061" Тогда	// Статус обработки инструкции (MeetingInstructionStatus). Ничего не заполнять. Только факт в РС.
		ЗаполнятьСвойства = Ложь;
		
	ИначеЕсли Строка.КодОтчета = "CA391" Тогда	// Сообщение об отмене корпоративного действия. Ничего не заполнять. Только факт в РС.
		ЗаполнитьЗначенияСвойств(КД, Строка, "АдресВСетиИнтернетОтмена");
		ЗаполнятьСвойства = Ложь;
	КонецЕсли;
	
	Если ЗаполнятьСвойства Тогда
		Если ЗначениеЗаполнено(ИсключаяСвойства) Тогда
			ИсключаяСвойства = "ДополнительнаяИнформация, " + ИсключаяСвойства;
		Иначе
			ИсключаяСвойства = "ДополнительнаяИнформация";
		КонецЕсли;
		ЗаполнитьЗначенияСвойств(КД, Строка, СвойстваДляЗаполнения, ИсключаяСвойства);
		
		КД.Этап = Этап;
		
		// Заполнение таб.части ЦенныеБумаги данного документа КД
		КД.ЦенныеБумаги.Очистить();
		Отбор = Новый Структура("КлючДанныеКорпоративныхДействий", Строка.КлючЦенныеБумаги);
		Строки = ЦенныеБумаги.НайтиСтроки(Отбор);
		Для Каждого СтрокаЦБ Из Строки Цикл
			НоваяСтрокаЦБ = КД.ЦенныеБумаги.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрокаЦБ, СтрокаЦБ);
		КонецЦикла;
		
		ОтборПоНомеру = Новый Структура("ВходящийДокументНомер", Строка.ВходящийДокументНомер);
		ВариантыУчастияФайла = ВариантыУчастия.НайтиСтроки(ОтборПоНомеру);
		КД.ВариантыУчастия.Очистить();
		Для Каждого Вариант Из ВариантыУчастияФайла Цикл
			СтрокаВариант = КД.ВариантыУчастия.Добавить();
			ЗаполнитьЗначенияСвойств(СтрокаВариант, Вариант);
		КонецЦикла;
		
		КД.ДополнительнаяИнформация = Строка.ДополнительнаяИнформация;
		
	КонецЕсли;
КонецПроцедуры

Процедура ЗаполнитьСвойстваТабЧастиВопросыКГолосованию(КД, ВходящийДокументНомер, СвойстваДляЗаполненияТЧ)
	ВопросыПоНомеруСообщения = ВопросыКГолосованию.НайтиСтроки(Новый Структура("ВходящийДокументНомер", ВходящийДокументНомер));
	КД.ВопросыКГолосованию.Очистить();
	Для Каждого Вопрос Из ВопросыПоНомеруСообщения Цикл
		СтрокаВопрос = КД.ВопросыКГолосованию.Найти(Вопрос.НомерВопроса, "НомерВопроса");
		Если СтрокаВопрос = Неопределено Тогда
			СтрокаВопрос = КД.ВопросыКГолосованию.Добавить();
		КонецЕсли;
		ЗаполнитьЗначенияСвойств(СтрокаВопрос, Вопрос, СвойстваДляЗаполненияТЧ);
	КонецЦикла;
КонецПроцедуры

