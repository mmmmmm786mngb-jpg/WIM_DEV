
&НаКлиенте
Процедура ЗаполнитьДанные(Команда)
	ЗаполнитьДанныеНаСервере();
КонецПроцедуры

&НаКлиенте
Процедура ОтправитьУведомления(Команда)
	ОтправитьУведомленияНаСервере();
	ЗаполнитьДанныеНаСервере();
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьДанныеНаСервере()
	ОбработкаОбъект = РеквизитФормыВЗначение("Объект");
	Если ЗначениеЗаполнено(ОбработкаОбъект.Поручение) Тогда
		Отбор = Новый Структура("Поручение", ОбработкаОбъект.Поручение);
	Иначе
		Отбор = Неопределено;
	КонецЕсли;	
	ОбработкаОбъект.ЗаполнитьДанные(Отбор);
	ЗначениеВРеквизитФормы(ОбработкаОбъект, "Объект");
КонецПроцедуры

&НаСервере
Процедура ОтправитьУведомленияНаСервере()
	ОбработкаОбъект = РеквизитФормыВЗначение("Объект");
	ОбработкаОбъект.ПодготовитьУведомления();
	ЗначениеВРеквизитФормы(ОбработкаОбъект, "Объект");
КонецПроцедуры
