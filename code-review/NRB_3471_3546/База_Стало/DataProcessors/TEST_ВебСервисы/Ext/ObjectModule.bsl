////#Область Вспомогательные методы

Функция ДанныеИзТаблицыМакета(ИмяПроцедуры)
	ИндексСтроки = 1;
	ИндексКолонки = 2;
	КоличествоПропусков = 0;
	ПроцедураНайдена = Ложь;
	ТаблицаВозврата = Новый ТаблицаЗначений;
	
	// Ищем имя процедуры
	Пока Истина Цикл 
		ОбластьЗаголовок = Макет.Область(ИндексСтроки, 1, ИндексСтроки, 1).Текст;
		Если ЗначениеЗаполнено(ОбластьЗаголовок) Тогда 
			Если ОбластьЗаголовок = ИмяПроцедуры Тогда 
				ПроцедураНайдена = Истина;
				Прервать;
			КонецЕсли;
			КоличествоПропусков = 0;
		Иначе 
			КоличествоПропусков = КоличествоПропусков + 1;
		КонецЕсли;
		
		Если КоличествоПропусков > 20 Тогда  // если данных больше, нужно увеличить этот порог
			КоличествоПропусков = 0;
			Прервать;
		КонецЕсли;
		
		ИндексСтроки = ИндексСтроки + 1;
	КонецЦикла;
	
	Если Не ПроцедураНайдена Тогда 
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("В макете тестирования не найдена процедура: " + ИмяПроцедуры);
		Возврат ТаблицаВозврата;
	КонецЕсли;
	
	// Читаем поля таблицы и типы
	ИндексСтрокиИмени = ИндексСтроки + 1; // В этой строке имена полей таблицы возврата
	ИндексСтрокиТипа  = ИндексСтрокиИмени + 1; // В этой строке типы полей таблицы возврата
	Пока Истина Цикл 
		ИмяПоляТаблицы = Макет.Область(ИндексСтрокиИмени, ИндексКолонки, ИндексСтрокиИмени, ИндексКолонки).Текст;
		ТипПоляТаблицы = Макет.Область(ИндексСтрокиТипа, ИндексКолонки, ИндексСтрокиТипа, ИндексКолонки).Текст;
		Если ЗначениеЗаполнено(ИмяПоляТаблицы) И ЗначениеЗаполнено(ТипПоляТаблицы) Тогда 
			ИндексПоискаНачало = Найти(ТипПоляТаблицы, "(");
			ИндексПоискаКонец  = Найти(ТипПоляТаблицы, ")");
			Если ИндексПоискаНачало > 0 Тогда // Обработка для строки
				ИндексПоискаНачало = ИндексПоискаНачало + 1;
				ИскомоеЧисло = Сред(ТипПоляТаблицы, ИндексПоискаНачало, ИндексПоискаКонец - ИндексПоискаНачало);
				ИскомыйТип   = Лев(ТипПоляТаблицы, ИндексПоискаНачало - 2);
				Если Лев(ТипПоляТаблицы,1) = "С" Тогда 
					КС = Новый КвалификаторыСтроки(ИскомоеЧисло);
					ОписаниеТипов = Новый ОписаниеТипов(ИскомыйТип,,КС);
				Иначе 
					КЧ = Новый КвалификаторыЧисла(ИскомоеЧисло);
					ОписаниеТипов = Новый ОписаниеТипов(ИскомыйТип,,,КЧ);
				КонецЕсли;
			Иначе
				ОписаниеТипов = Новый ОписаниеТипов(ТипПоляТаблицы);
			КонецЕсли;
			ТаблицаВозврата.Колонки.Добавить(ИмяПоляТаблицы, ОписаниеТипов);
			ИндексКолонки = ИндексКолонки + 1;
		Иначе 
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	// Читаем данные в таблицу возврата
	Колонки = ТаблицаВозврата.Колонки;
	Если Колонки.Количество() = 0 Тогда 
		Возврат ТаблицаВозврата;
	КонецЕсли;
	
	ВсегоКолонок = ИндексКолонки -1;
	ИндексСтроки = ИндексСтрокиТипа;
	Пока Истина Цикл 
		ИндексКолонки = 2;
		ИндексСтроки = ИндексСтроки + 1; // Строка данных
		ЗначениеПоляТаблицы = Макет.Область(ИндексСтроки, ИндексКолонки, ИндексСтроки, ИндексКолонки).Текст;
		Если ЗначениеЗаполнено(ЗначениеПоляТаблицы) И ЗначениеПоляТаблицы <> "Ограничитель" Тогда 
			НоваяСтрока = ТаблицаВозврата.Добавить();
			УстановитьЗначениеВТаблицу(НоваяСтрока, Колонки, ИндексКолонки, ЗначениеПоляТаблицы);
			ИндексКолонки = ИндексКолонки + 1;
			Пока ИндексКолонки <= ВсегоКолонок Цикл 
				ЗначениеПоляТаблицы = Макет.Область(ИндексСтроки, ИндексКолонки, ИндексСтроки, ИндексКолонки).Текст;
				Если ЗначениеЗаполнено(ЗначениеПоляТаблицы) Тогда 
					УстановитьЗначениеВТаблицу(НоваяСтрока, Колонки, ИндексКолонки, ЗначениеПоляТаблицы);
				КонецЕсли;
				ИндексКолонки = ИндексКолонки + 1;
			КонецЦикла;
		Иначе
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	Возврат ТаблицаВозврата;
	
КонецФункции

Процедура УстановитьЗначениеВТаблицу(НоваяСтрока,Колонки,ИндексКолонки,ЗначениеПоляТаблицы)
	Колонка		= Колонки[ИндексКолонки -2];
	ИмяКолонки	= Колонка.Имя;
	ТипКолонки	= Колонка.ТипЗначения;
	НоваяСтрока[ИмяКолонки] = ТипизироватьЗначение(ЗначениеПоляТаблицы,ТипКолонки);
КонецПроцедуры

Функция ТипизироватьЗначение(ЗначениеПоляТаблицы,ТипКолонки)
	Результат = ЗначениеПоляТаблицы;
	Если ТипКолонки.Типы().Найти(Тип("Дата")) <> Неопределено Тогда 
		Результат = Дата(ЗначениеПоляТаблицы);
	ИначеЕсли ТипКолонки.Типы().Найти(("Число")) <> Неопределено Тогда 
		Результат = Число(ЗначениеПоляТаблицы);
	ИначеЕсли ТипКолонки.Типы().Найти(Тип("Булево")) <> Неопределено Тогда 
		Результат = ?(ЗначениеПоляТаблицы = "1", Истина, Ложь);
	КонецЕсли;
	Возврат Результат;
КонецФункции

Процедура ВывестиТаблицуЗначений(ТЗ)
	СписокКолонок = "Колонки:";
	Для Каждого Колонка Из ТЗ.Колонки Цикл
		СписокКолонок = СписокКолонок + Символы.Таб + Колонка.Имя;
	КонецЦикла;
	Сообщить(СписокКолонок);
	
	Если ТЗ.Количество() = 0 Тогда
		Сообщить("(таблица пустая)");
	КонецЕсли;
	
	НомСтр = 1;
	Для Каждого Строка Из ТЗ Цикл
		ПредставлениеСтроки = "Стр." + НомСтр + ":	";
		Для Каждого Колонка Из ТЗ.Колонки Цикл
			ПредставлениеСтроки = ПредставлениеСтроки + Символы.Таб + СокрЛП(Строка[Колонка.Имя]);
		КонецЦикла;
		Сообщить(ПредставлениеСтроки);
		НомСтр = НомСтр+1;
	КонецЦикла;
КонецПроцедуры

Процедура ВывестиСтруктуру(Стр)
	Если Стр.Количество() = 0 Тогда
		Сообщить("(структура пустая)");
	КонецЕсли;
	
	Для Каждого КлючИЗначение Из Стр Цикл
		Сообщить(СокрЛП(КлючИЗначение.Ключ) + "=" + СокрЛП(КлючИЗначение.Значение));
	КонецЦикла;
КонецПроцедуры

