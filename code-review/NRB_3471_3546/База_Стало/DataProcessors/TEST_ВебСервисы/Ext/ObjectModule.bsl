	НовСтрока.ClientId = "000001017";
	НовСтрока.ISIN = "RU0009843239";
	НовСтрока.RegNumber = "1-02-00609-D";
	НовСтрока.StockBondsCount = 125;
	НовСтрока.OfferDate = Дата(2023, 2, 22, 16, 03, 58);
	НовСтрока.DocumentId = 3966253;
	НовСтрока.Exported1C = Ложь;
