//							DocumentNumber - строка - номер в СЭД
//							ClientId - строка(9) - идентификатор клиента в СУДК
//							ISIN - строка - ISIN ЦБ
//							RegNumber - строка - государственный регистрационный номер ЦБ
//							StockBondsCount - число - число ЦБ к оферте
//							OfferDate - дата - дата оферты
