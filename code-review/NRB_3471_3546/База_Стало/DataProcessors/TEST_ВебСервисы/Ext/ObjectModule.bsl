Функция СтатусыДоставкиУведомленийОКД(ДанныеУведомлений) Экспорт
	СтатусыДоставки = Новый ТаблицаЗначений;
	СтатусыДоставки.Колонки.Добавить("GUID");
	СтатусыДоставки.Колонки.Добавить("ClientId");
	СтатусыДоставки.Колонки.Добавить("Успешно");
	
	ТаблицаМакета = ДанныеИзТаблицыМакета("СтатусыДоставкиУведомленийОКД");
	
	Для Каждого СтрокаУведомления Из ДанныеУведомлений Цикл
		Для Каждого КодЗагрузки Из СтрокаУведомления.ИдентификаторыКлиентов Цикл
			Отбор = Новый Структура("GUID, ClientId", СтрокаУведомления.УникальныйИдентификатор, КодЗагрузки);
			СтрокиДанных = ТаблицаМакета.НайтиСтроки(Отбор);
			
			НоваяСтрока = СтатусыДоставки.Добавить();
			НоваяСтрока.GUID = СтрокаУведомления.УникальныйИдентификатор;
			НоваяСтрока.ClientId = КодЗагрузки;
			НоваяСтрока.Успешно = ?(СтрокиДанных.Количество() > 0, СтрокиДанных[0].Успешно, Ложь);
		КонецЦикла;
	КонецЦикла;
	
	Возврат СтатусыДоставки;
КонецФункции

