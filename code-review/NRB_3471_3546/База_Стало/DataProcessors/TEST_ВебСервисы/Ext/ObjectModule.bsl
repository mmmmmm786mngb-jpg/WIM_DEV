	Сообщить("ЗаголовокСообщения: " + ЗаголовокСообщения);
	Сообщить("ТекстСообщения:" + Символы.ПС + ТекстСообщения);
	Сообщить("УникальныйИдентификатор: " + УникальныйИдентификатор);
	
	Возврат Истина;
	
КонецФункции

