Функция РезультатЗаписиXMLСписаниеВДругойДепозитарий(ЗаписьXML, Данные, КодЗагрузкиОрганизации)
	// {{ MF036
	ЗаписьXML.ЗаписатьНачалоЭлемента("MF036");
	// Отправитель
	ЗаписатьЭлементXML(ЗаписьXML, "deponent_c",	КодЗагрузкиОрганизации);
	// Отправитель - Счет депо
	ЗаписатьЭлементXML(ЗаписьXML, "dep_acc_c",	СокрЛП(Данные.СчетДепоМХКод));
	// Отправитель - Раздел счета депо
	ЗаписатьЭлементXML(ЗаписьXML, "sec_c",		СокрЛП(Данные.РазделСчетаДепоМХКод));
	// SWIFT код стороннего депозитария
	Если ЗначениеЗаполнено(Данные.СчетДепоКонтрагента) И ЗначениеЗаполнено(Данные.СчетДепоКонтрагента.БИКМестаРасчетов) Тогда
		ЗаписатьЭлементXML(ЗаписьXML, "reestr_bic", СокрЛП(Данные.СчетДепоКонтрагента.БИКМестаРасчетов));
	КонецЕсли;	
	Если ЗначениеЗаполнено(Данные.СчетДепоКонтрагента) И ЗначениеЗаполнено(Данные.СчетДепоКонтрагента.КодМестаРасчетов) Тогда
		ЗаписатьЭлементXML(ЗаписьXML, "reestr_cod", СокрЛП(Данные.СчетДепоКонтрагента.КодМестаРасчетов));
	КонецЕсли;
	// Тип счета
	ЗаписатьЭлементXML(ЗаписьXML, "acc_type",	Справочники.СчетаДепо.КодТипаСчетаДЕПО(Данные.СчетДепоКонтрагента.ТипСчетаДепо));
	// Юр./физ. лицо (получатель)
	ЗаписатьЭлементXML(ЗаписьXML, "pr_jur_or_ind",	Данные.ЮрФизЛицо);
	
	// Получатель
	//
	
	// BIC/BEI получателя
	Если ЗначениеЗаполнено(Данные.СчетДепоКонтрагента)
		И ЗначениеЗаполнено(Данные.СчетДепоКонтрагента.БикОтправителя) Тогда
		person_bic = Данные.СчетДепоКонтрагента.БикОтправителя;
	Иначе
		person_bic = Данные.БикКлиентаДепозитария;
	КонецЕсли;
	Если ЗначениеЗаполнено(person_bic) Тогда
		ЗаписатьЭлементXML(ЗаписьXML, "person_bic",	СокрЛП(person_bic));
	КонецЕсли; 
	
	// Полное имя получателя
	Если НЕ ЗначениеЗаполнено(person_bic) Тогда // полное имя заполняем только если нет BIC/BEI
		Если ЗначениеЗаполнено(Данные.СчетДепоКонтрагента)
			И ЗначениеЗаполнено(Данные.СчетДепоКонтрагента.СчетВМестеРасчетовНаименование) Тогда
			full_name = Данные.СчетДепоКонтрагента.СчетВМестеРасчетовНаименование;
		Иначе	
			full_name = Данные.НаименованиеКонтрагента;
		КонецЕсли;
		ЗаписатьЭлементXML(ЗаписьXML, "full_name", СокрЛП(full_name));
	КонецЕсли;
	
	// Дата операции
	ЗаписатьЭлементXML(ЗаписьXML, "oper_date",	ФорматДаты(Данные.ПланируемаяДатаРасчетов));
	// Дата сделки
	Если ЗначениеЗаполнено(Данные.ДатаСделки) Тогда
		ЗаписатьЭлементXML(ЗаписьXML, "trad_dt", ФорматДаты(Данные.ДатаСделки));
	КонецЕсли;
	// Код ЦБ в НДЦ
	Если ЗначениеЗаполнено(Данные.КодЦБ) Тогда
		ЗаписатьЭлементXML(ЗаписьXML, "security_c",	СокрЛП(Данные.КодЦБ));
	Иначе
		Возврат ОшибкаПустойКодЗагрузкиЦеннойБумаги(Данные);
	КонецЕсли;
	// Количество ЦБ
	ЗаписатьЭлементXML(ЗаписьXML, "security_q",	ФорматКоличества(Данные.КоличествоЦБ));
	
	Если ЗначениеЗаполнено(Данные.СчетДепоКонтрагента)
		И ЗначениеЗаполнено(Данные.СчетДепоКонтрагента.СчетВМестеРасчетовНомерСчета) Тогда
		recv_acc_c = Данные.СчетДепоКонтрагента.СчетВМестеРасчетовНомерСчета;
	Иначе
		recv_acc_c = Данные.СчетДепоКонтрагентаКод;
	КонецЕсли;
	ЗаписатьЭлементXML(ЗаписьXML, "recv_acc_c",	СокрЛП(recv_acc_c));
	
	ЗаписатьЭлементыXMLИнформацияОСчетеВМестеРасчетов(ЗаписьXML, Данные);
	
	ЗаписатьЭлементXML(ЗаписьXML, "need_cvit",	"Y");
	
	Если Данные.СуммаСделки <> 0 Тогда
		Ошибка = РезультатЗаписиXMLAddInforms(ЗаписьXML, Данные);
		Если ЗначениеЗаполнено(Ошибка) Тогда
			Возврат Ошибка;
		КонецЕсли;
		Ошибка = РезультатЗаписиXMLСуммаСделкиВалюта(ЗаписьXML, Данные);
		Если ЗначениеЗаполнено(Ошибка) Тогда
			Возврат Ошибка;
		КонецЕсли;
	КонецЕсли;
	Ошибка = РезультатЗаписиXMLПодтверждающиеДокументы(ЗаписьXML, Данные);	
	Если ЗначениеЗаполнено(Ошибка) Тогда
		Возврат Ошибка;
	КонецЕсли;
	// }} MF036
	ЗаписьXML.ЗаписатьКонецЭлемента();
	Возврат Неопределено;
КонецФункции

Функция ДатаИсполненияПоручения(Данные)
	Если Данные.КодОперации = "37"
			ИЛИ Данные.КодОперации = "36"
			ИЛИ Данные.КодОперации = "19/0"
			ИЛИ Данные.КодОперации = "19/1" Тогда
		execute_dt = Данные.ПланируемаяДатаРасчетов;
	Иначе
		execute_dt = Данные.Дата;
	КонецЕсли;
	
	Возврат Формат(НачалоДня(execute_dt), "ДФ=""гггг-ММ-дд ЧЧ:мм:сс""");
КонецФункции

Функция ДатаИстеченияСрокаИсполненияПоручения(Данные)
	Если Данные.КодОперации = "37"
			ИЛИ Данные.КодОперации = "36" Тогда
			//ИЛИ Данные.КодОперации = "19/0"
			//ИЛИ Данные.КодОперации = "19/1" Тогда
		expirat_dt = ДобавитьМесяц(Данные.ПланируемаяДатаРасчетов, 1);
	ИначеЕсли	Данные.КодОперации = "90" Тогда
		expirat_dt = Данные.Дата;
	ИначеЕсли Данные.КодОперации = "16" 
		  ИЛИ Данные.КодОперации = "16/1"
		  ИЛИ Данные.КодОперации = "19/0"
		  ИЛИ Данные.КодОперации = "19/1" Тогда
		ДнейВУсловномМесяце = 30;
		expirat_dt = НачалоДня(Данные.ПланируемаяДатаРасчетов) + ОбщегоНазначенияПовтИсп.СекундВСутках(ДнейВУсловномМесяце) - 1;
	Иначе
		expirat_dt = ОбщегоНазначения.ДобавитьРабочийДень(Данные.Дата, 3);
	КонецЕсли;
	
	Возврат Формат(КонецДня(expirat_dt), "ДФ=""гггг-ММ-дд ЧЧ:мм:сс""");
КонецФункции

Функция РезультатЗаписиXMLAddInforms(ЗаписьXML, Данные)
	
	ДопИнформация = РегистрыСведений.ПараметрыСделокДляЭкспортаВЛуч.ПараметрыДокумента(Данные.Поручение);
	Если ЗначениеЗаполнено(ДопИнформация) Тогда
			
		ЗаписьXML.ЗаписатьНачалоЭлемента("add_informs");
		
		Для Каждого Параметр Из ДопИнформация Цикл
			ЗаписьXML.ЗаписатьНачалоЭлемента("add_info");
			ЗаписатьЭлементXML(ЗаписьXML, "param_code", Параметр.Ключ);
			ЗаписатьЭлементXML(ЗаписьXML, "param_value", Параметр.Значение);
			ЗаписьXML.ЗаписатьКонецЭлемента(); // }} add_info
		КонецЦикла;
		
		ЗаписьXML.ЗаписатьКонецЭлемента(); // }} add_informs
		Возврат Неопределено;
			
	ИначеЕсли Не ЗначениеЗаполнено(Данные.КодАльфа2СтраныЮрлицаКонтрагента) Тогда
		Ошибка = Новый Структура("СообщениеПользователю,СообщениеВЖурнал,Данные");
		Ошибка.СообщениеВЖурнал = "Не указан код страны 'Альфа-2' у юр.лица контрагента";
		Ошибка.СообщениеПользователю = Ошибка.СообщениеВЖурнал + " " + Данные.Контрагент;
		Ошибка.Данные = Данные.Контрагент;
		Возврат Ошибка;
	КонецЕсли;
	
	ЗаписьXML.ЗаписатьНачалоЭлемента("add_informs");
	
	ЗаписьXML.ЗаписатьНачалоЭлемента("add_info");
	ЗаписатьЭлементXML(ЗаписьXML, "param_code", "DVP");
	ЗаписатьЭлементXML(ЗаписьXML, "param_value", "DVP");
	ЗаписьXML.ЗаписатьКонецЭлемента(); // }} add_info
	
	ЗаписьXML.ЗаписатьНачалоЭлемента("add_info");
	ЗаписатьЭлементXML(ЗаписьXML, "param_code", "STRANA");
	ЗаписатьЭлементXML(ЗаписьXML, "param_value", Данные.КодАльфа2СтраныЮрлицаКонтрагента);
	ЗаписьXML.ЗаписатьКонецЭлемента(); // }} add_info
	
	ЗаписьXML.ЗаписатьНачалоЭлемента("add_info");
	ЗаписатьЭлементXML(ЗаписьXML, "param_code", "OTHR");
	ЗаписатьЭлементXML(ЗаписьXML, "param_value", "DVP STRANA " + Данные.КодАльфа2СтраныЮрлицаКонтрагента);
	ЗаписьXML.ЗаписатьКонецЭлемента(); // }} add_info
	
	ЗаписьXML.ЗаписатьКонецЭлемента(); // }} add_informs
	Возврат Неопределено;
КонецФункции

Функция РезультатЗаписиXMLПодтверждающиеДокументы(ЗаписьXML, Данные)
	// {{ documents
	ЗаписьXML.ЗаписатьНачалоЭлемента("documents");
	// {{ document
	ЗаписьXML.ЗаписатьНачалоЭлемента("document");
	
	ЗаписатьЭлементXML(ЗаписьXML, "ndc_code",		"VLCN");
	ЗаписатьЭлементXML(ЗаписьXML, "partad_code",	"OTHR");
