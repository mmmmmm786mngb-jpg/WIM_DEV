Функция РезультатЗаписиXMLСписаниеМеждуСчетамиДепо(ЗаписьXML, Данные, КодЗагрузкиОрганизации)
	// {{ MF010
	ЗаписьXML.ЗаписатьНачалоЭлемента("MF010");
	// Отправитель
	ЗаписатьЭлементXML(ЗаписьXML, "deponent_c",	КодЗагрузкиОрганизации);
	// Отправитель - Счет депо
	ЗаписатьЭлементXML(ЗаписьXML, "dep_acc_c",	СокрЛП(Данные.СчетДепоМХКод));
	// Отправитель - Раздел счета депо
	ЗаписатьЭлементXML(ЗаписьXML, "sec_c",		СокрЛП(Данные.РазделСчетаДепоМХКод));
	// Заполняем информацию по получателю
	ЗаписатьЭлементыXMLДанныеПолучателяПриСнятииСДепонирования(ЗаписьXML, Данные);
	Если ЗначениеЗаполнено(Данные.НомерДепозитарногоДоговораКонтрагента) Тогда
		// Основание (депозитарный договор)
		ЗаписатьЭлементXML(ЗаписьXML, "based_on",	"Депозитарный договор");
		// Номер документа-основания
		ЗаписатьЭлементXML(ЗаписьXML, "based_numb",	СокрЛП(Данные.НомерДепозитарногоДоговораКонтрагента));
	КонецЕсли;
	Если ЗначениеЗаполнено(Данные.СчетДепоКонтрагента.ДатаЗаключенияДепозитарногоДоговора) Тогда
		// Дата документа основания
		ЗаписатьЭлементXML(ЗаписьXML, "based_date", ФорматДаты(
			Данные.СчетДепоКонтрагента.ДатаЗаключенияДепозитарногоДоговора));
	КонецЕсли;
	
	// {{ Электронный Matching в НРД
	Если ЗначениеЗаполнено(Данные.РазделСчетаДепоКраткийКодНРД) Тогда
		ЗаписатьЭлементXML(ЗаписьXML, "section_id", СокрЛП(Данные.РазделСчетаДепоКраткийКодНРД));
	КонецЕсли;
	Если ЗначениеЗаполнено(Данные.РазделСчетаДепоКонтрагентаКраткийКодНРД)
		ИЛИ ЗначениеЗаполнено(Данные.КраткийКодНРД) Тогда
		ЗаписатьЭлементXML(ЗаписьXML, "corr_sec_id", СокрЛП(?(ЗначениеЗаполнено(Данные.КраткийКодНРД),
			Данные.КраткийКодНРД, Данные.РазделСчетаДепоКонтрагентаКраткийКодНРД)));
	КонецЕсли;
	Если ЗначениеЗаполнено(Данные.Референс) Тогда
		ЗаписатьЭлементXML(ЗаписьXML, "deal_reference", СокрЛП(Данные.Референс));
	КонецЕсли;
	Если ЗначениеЗаполнено(Данные.ДатаСделки) Тогда
		ЗаписатьЭлементXML(ЗаписьXML, "date_deal", ФорматДаты(Данные.ДатаСделки));
	КонецЕсли;
	// }} Электронный Matching в НРД
	
	Ошибка = РезультатЗаписиXMLЦенныеБумагиСУчетомISIN(ЗаписьXML, Данные);
	Если ЗначениеЗаполнено(Ошибка) Тогда
		Возврат Ошибка;
	КонецЕсли;
	
	// }} MF010
	ЗаписьXML.ЗаписатьКонецЭлемента();
	Возврат Неопределено;
