Функция ОшибкаПустойКодЗагрузкиЦеннойБумаги(Данные)
	Ошибка = Новый Структура("СообщениеПользователю,СообщениеВЖурнал,Данные");
	Ошибка.СообщениеВЖурнал = "Не указан код загрузки 'НДЦ' на " + Формат(Данные.Дата, "ДЛФ=Д") + " у ценной бумаги";
	Ошибка.СообщениеПользователю = Ошибка.СообщениеВЖурнал + " " + Данные.ЦеннаяБумага;
	Ошибка.Данные = Данные.ЦеннаяБумага;
	Возврат Ошибка;
КонецФункции

