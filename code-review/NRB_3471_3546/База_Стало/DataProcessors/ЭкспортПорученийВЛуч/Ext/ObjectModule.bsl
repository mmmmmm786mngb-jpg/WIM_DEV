	|				ИЛИ КодыЗагрузкиЦБ.ДатаОкончанияДействия > НАЧАЛОПЕРИОДА(Документы.Дата, ДЕНЬ))
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.КодыЗагрузки КАК КодыЗагрузкиКонтрагента
	|		ПО ((ВЫРАЗИТЬ(КодыЗагрузкиКонтрагента.Владелец КАК Справочник.Контрагенты)) = Документы.Контрагент)
	|			И ((ВЫРАЗИТЬ(КодыЗагрузкиКонтрагента.Биржа КАК Справочник.КлассификаторыЗагрузки)) = &НДЦ)
	|			И (НЕ КодыЗагрузкиКонтрагента.ПометкаУдаления)
