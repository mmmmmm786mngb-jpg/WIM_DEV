// Возвращает структуру с описанием ошибки, если она обнаружена. Иначе - неопределено.
// Параметры:
//	Данные - СтрокаТабличнойЧасти - Строка ТЧ Поручения этой обработки
//	КодЗагрузкиОрганизации - Строка
//	ПутьДляВыгрузки - Строка
// Возвращаемое значение:
//	- Структура
Функция РезультатФормированияПакетаXML(Данные, КодЗагрузкиОрганизации, ПутьДляВыгрузки)
	Ошибка = Новый Структура("СообщениеПользователю,СообщениеВЖурнал,Данные");
	
	НачатьТранзакцию();
	ТекущаяДата = ТекущаяДатаСеанса();
	ПовторнаяВыгрузка = Данные.Выгружен;
	Если ПовторнаяВыгрузка Тогда
		РеквизитыВыгрузки		= РегистрыСведений.ДокументыВыгруженныеВЛуч.РеквизитыВыгрузки(Данные.Поручение);
		ИсходящийНомер			= РеквизитыВыгрузки.ИсходящийНомер;
		РегистрационныйНомер	= РеквизитыВыгрузки.РегистрационныйНомер;
	Иначе
		НовыйПорядковыйНомер	= РегистрыСведений.ДокументыВыгруженныеВЛуч.НовыйПорядковыйНомерВТечениеДня(ТекущаяДата);
		Если НовыйПорядковыйНомер = 0 Тогда
			ОтменитьТранзакцию();
			Ошибка.СообщениеВЖурнал = "Не удалось получить новый порядковый номер за " + Формат(ТекущаяДата, "ДЛФ=Д");
			Ошибка.СообщениеПользователю = Ошибка.СообщениеВЖурнал;
			Возврат Ошибка;
		КонецЕсли;
		ПозицияПервойЦифры = 2;
		Если ПустаяСтрока(Данные.КодДепонента) Тогда
			ИсходящийНомер = "D" + Сред(Данные.Номер, ПозицияПервойЦифры, СтрНайти(Данные.Номер, "-") - ПозицияПервойЦифры);
		Иначе
			ИсходящийНомер = СокрЛП(Данные.КодДепонента);
		КонецЕсли;
		ИсходящийНомер = ИсходящийНомер + "-" + Формат(НовыйПорядковыйНомер, "ЧЦ=4;ЧВН=1;ЧГ=0;");
		РегистрационныйНомер = "";
	КонецЕсли;
	
	ИмяФайлаXML = ПутьДляВыгрузки + "\" + ДопустимыеСимволы(СокрЛП(Данные.Номер)) + "_" + ИсходящийНомер + ".xml";

	ЗаписьXML = Новый ЗаписьXML;
	Попытка
		ЗаписьXML.ОткрытьФайл(ИмяФайлаXML, "windows-1251");
	Исключение
		ОтменитьТранзакцию();
		Ошибка.СообщениеВЖурнал = "Не удалось открыть файл " + ИмяФайлаXML;
		Ошибка.СообщениеПользователю = Ошибка.СообщениеВЖурнал;
		Возврат Ошибка;
	КонецПопытки;	
	
	Ошибка = РезультатЗаполненияXML(ЗаписьXML, Данные, КодЗагрузкиОрганизации, ИсходящийНомер);
	
	Если ЗначениеЗаполнено(Ошибка) Тогда
		ОтменитьТранзакцию();
		Возврат Ошибка;
	КонецЕсли;
	
	ЗаписьXML.Закрыть();
	
	РегистрыСведений.ДокументыВыгруженныеВЛуч.ДобавитьДокумент(Данные.Поручение, ТекущаяДата, ИсходящийНомер, РегистрационныйНомер, ПараметрыСеанса.ТекущийПользователь);
	
	ЗафиксироватьТранзакцию();
	
	Возврат Неопределено;
	
КонецФункции

// Возвращает структуру с описанием ошибки, если она обнаружена. Иначе - неопределено.
// Возвращаемое значение:
//	- Структура
Функция РезультатФормированияПакетаXML_ФШ(Данные, КодЗагрузкиОрганизации)
	Ошибка = Новый Структура("СообщениеПользователю,СообщениеВЖурнал,Данные");
	
	НачатьТранзакцию();
	
	ЗаписьXML = Новый ЗаписьXML;
	ЗаписьXML.УстановитьСтроку("Windows-1251");
	
	ИсходящийНомер = Обработки.ЭкспортПорученийВЛуч.ФорматИсходящегоНомера(Данные.Номер);
	Ошибка = РезультатЗаполненияXML(ЗаписьXML, Данные, КодЗагрузкиОрганизации, ИсходящийНомер);
	
	Если ЗначениеЗаполнено(Ошибка) Тогда
		ОтменитьТранзакцию();
		Возврат Ошибка;
	КонецЕсли;
	
	ТекстДокумента = ЗаписьXML.Закрыть();
	
	Ошибка = Обработки.ЭкспортПорученийВЛуч.СформироватьИсходящийПакетВФайловыйШлюз(ИсходящийНомер, Данные.Дата, ТипОперации(Данные.КодОперации), Данные.КодОперации, Данные.Поручение, ТекстДокумента);
	
	Если ЗначениеЗаполнено(Ошибка) Тогда
		ОтменитьТранзакцию();
		Возврат Ошибка;
	КонецЕсли;
	
	ЗафиксироватьТранзакцию();
	
	Возврат Неопределено;
	
КонецФункции

Функция ТипОперации(КодОперации)
	Если КодОперации = "16/1" ИЛИ КодОперации = "16" ИЛИ КодОперации = "10" Тогда
		Возврат "MF010";
		
	ИначеЕсли КодОперации = "19/1" ИЛИ КодОперации = "19/0" Тогда
		Возврат "MF190";
		
	ИначеЕсли КодОперации = "37" Тогда
		Возврат "MF035";
		
	ИначеЕсли КодОперации = "36" Тогда
		Возврат "MF036";
		
	ИначеЕсли КодОперации = "20" Тогда
		Возврат "MF020";
		
	ИначеЕсли КодОперации = "90" Тогда
		Возврат "AF090";
		
	КонецЕсли;
КонецФункции // ()
 
Функция РезультатЗаполненияXML(ЗаписьXML, Данные, КодЗагрузкиОрганизации, ИсходящийНомер)
	Ошибка = Новый Структура("СообщениеПользователю,СообщениеВЖурнал,Данные");
	
	ЗаписьXML.ЗаписатьОбъявлениеXML();
	
	// {{ Batch
	ЗаписьXML.ЗаписатьНачалоЭлемента("Batch");
	ЗаписатьЭлементXML(ЗаписьXML, "Documents_amount", 1);
	
	НомерВерсии = НомерВерсии(Данные.КодОперации);
	Если Не ЗначениеЗаполнено(НомерВерсии) Тогда
		Ошибка.СообщениеВЖурнал = "Не удалось определить номер версии для кода операции " + Данные.КодОперации;
		Ошибка.СообщениеПользователю = Ошибка.СообщениеВЖурнал + " " + Данные.Поручение;
		Ошибка.СообщениеВЖурнал = Ошибка.СообщениеВЖурнал;
		Ошибка.Данные = Данные.Поручение;
		Возврат Ошибка;
	КонецЕсли;
	
	// {{ Document
	ЗаписьXML.ЗаписатьНачалоЭлемента("Document");
	ЗаписьXML.ЗаписатьАтрибут("DOC_ID", "1");
	ЗаписьXML.ЗаписатьАтрибут("version", НомерВерсии);
	
	// {{ ORDER_HEADER
	ЗаписьXML.ЗаписатьНачалоЭлемента("ORDER_HEADER");
	// Код депозитария-получателя поручения (ставим значение по-умолчанию)
	ЗаписатьЭлементXML(ЗаписьXML, "deposit_c",	"NDC000000000");
	// Код инициатора поручения
	ЗаписатьЭлементXML(ЗаписьXML, "contrag_c",	КодЗагрузкиОрганизации);
	// Исходящий номер документа
	ЗаписатьЭлементXML(ЗаписьXML, "contr_d_id",	ИсходящийНомер);
	// Дата формирования документа
	ЗаписатьЭлементXML(ЗаписьXML, "createdate",	ФорматДаты(Данные.Дата));
	// Код операции
	ЗаписатьЭлементXML(ЗаписьXML, "order_t_id",	Данные.КодОперации);
	// Дата исполнения поручения
	ЗаписатьЭлементXML(ЗаписьXML, "execute_dt",	ДатаИсполненияПоручения(Данные));
	// Дата истечения срока исполнения поручения
	ЗаписатьЭлементXML(ЗаписьXML, "expirat_dt",	ДатаИстеченияСрокаИсполненияПоручения(Данные));
	// }} ORDER_HEADER
	ЗаписьXML.ЗаписатьКонецЭлемента();
		
	Если Данные.КодОперации = "16/1" Тогда
		Ошибка = РезультатЗаписиXMLЗачислениеМеждуСчетамиДепо(ЗаписьXML, Данные, КодЗагрузкиОрганизации);
		
	ИначеЕсли Данные.КодОперации = "16" Тогда
		Ошибка = РезультатЗаписиXMLСписаниеМеждуСчетамиДепо(ЗаписьXML, Данные, КодЗагрузкиОрганизации);
		
	ИначеЕсли Данные.КодОперации = "19/1" Тогда
		Ошибка = РезультатЗаписиXMLЗачислениеМеждуСчетамиДепоССуммойСделки(ЗаписьXML, Данные);
		
	ИначеЕсли Данные.КодОперации = "19/0" Тогда
		Ошибка = РезультатЗаписиXMLСписаниеМеждуСчетамиДепоССуммойСделки(ЗаписьXML, Данные);
		
	ИначеЕсли Данные.КодОперации = "37" Тогда
		Ошибка = РезультатЗаписиXMLЗачислениеИзДругогоДепозитария(ЗаписьXML, Данные, КодЗагрузкиОрганизации);
		
	ИначеЕсли Данные.КодОперации = "36" Тогда
		Ошибка = РезультатЗаписиXMLСписаниеВДругойДепозитарий(ЗаписьXML, Данные, КодЗагрузкиОрганизации);
		
	ИначеЕсли Данные.КодОперации = "10" Тогда
		Ошибка = РезультатЗаписиXMLПереводМеждуСчетамиДепо(ЗаписьXML, Данные, КодЗагрузкиОрганизации);
		
	ИначеЕсли Данные.КодОперации = "20" Тогда
		Ошибка = РезультатЗаписиXMLПереводМеждуРазделамиПоОдномуСчетуДепо(ЗаписьXML, Данные, КодЗагрузкиОрганизации);
		
	ИначеЕсли Данные.КодОперации = "90" Тогда
		Ошибка = РезультатЗаписиXMLОткрытиеРазделаСчетаМХ(ЗаписьXML, Данные);
		
	Иначе
		Ошибка.СообщениеВЖурнал = "Не удалось определить код операции поручения";
		ДопРасшифровка = "Счет депо в разделе 'Контрагент' может быть не указан или должен иметь признак 'Счет контрагента'";
		Ошибка.СообщениеПользователю = Ошибка.СообщениеВЖурнал + " " + Данные.Поручение + Символы.ПС
			+ ДопРасшифровка;
		Ошибка.СообщениеВЖурнал = Ошибка.СообщениеВЖурнал + Символы.ПС + ДопРасшифровка;
		Ошибка.Данные = Данные.Поручение;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Ошибка) Тогда
		Возврат Ошибка;
	КонецЕсли;
	
	// }} Document
	ЗаписьXML.ЗаписатьКонецЭлемента();
	
	// }} Batch
	ЗаписьXML.ЗаписатьКонецЭлемента();
	
	Возврат Неопределено;
	
КонецФункции

Процедура ЗаписатьЭлементXML(ЗаписьXML, Тег, Значение)
	ЗаписьXML.ЗаписатьНачалоЭлемента(Строка(Тег));						// Начало элемента
	ЗаписьXML.ЗаписатьТекст(СтрЗаменить(Строка(Значение), " ", ""));	// Значение элемента
	ЗаписьXML.ЗаписатьКонецЭлемента();									// Конец элемента
КонецПроцедуры

Функция ДопустимыеСимволы(СтрокаНаПроверку)
	Результат = СтрЗаменить(СтрокаНаПроверку, "Д", "D");
	Возврат Результат;
КонецФункции

// Поиск кода участника фондового рынка по владельцу
// Возвращаемое значение:
//	- Строка
Функция КодУчастникаФондовогоРынка(ВладелецКода)
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	КодыЗагрузки.Код
	|ИЗ
	|	Справочник.КодыЗагрузки КАК КодыЗагрузки
	|ГДЕ
	|	КодыЗагрузки.Владелец = &Владелец
	|	И КодыЗагрузки.Биржа = &Биржа
	|	И НЕ КодыЗагрузки.ПометкаУдаления";
	Запрос.УстановитьПараметр("Биржа",		Константы.КлассификаторЗагрузкиУчастники.Получить());
	Запрос.УстановитьПараметр("Владелец",	ВладелецКода);
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат СокрЛП(Выборка.Код);
	Иначе
		Возврат "";
	КонецЕсли;
КонецФункции

Процедура ЗаписатьЭлементыXMLДанныеОтправителяПриДепонировании(ЗаписьXML, Данные, КодЗагрузкиОрганизации)
	Если Данные.КодОперации = "37" Тогда
		deponent_c	= КодЗагрузкиОрганизации;
		dep_acc_c	= СокрЛП(Данные.СчетДепоМХКод);
		sec_c		= СокрЛП(Данные.РазделСчетаДепоМХКод);
	Иначе
		deponent_c	= СокрЛП(Данные.КонтрагентКод);
		dep_acc_c	= СокрЛП(Данные.СчетДепоКонтрагентаКод);
		sec_c		= СокрЛП(Данные.РазделСчетаДепоКонтрагентаКод);
	КонецЕсли;
	ЗаписатьЭлементXML(ЗаписьXML, "deponent_c",	deponent_c);	// Отправитель
	ЗаписатьЭлементXML(ЗаписьXML, "dep_acc_c",	dep_acc_c);		// Отправитель - Счет депо
	ЗаписатьЭлементXML(ЗаписьXML, "sec_c",		sec_c);			// Отправитель - Раздел счета депо
КонецПроцедуры

Процедура ЗаписатьЭлементыXMLДанныеПолучателяПриСнятииСДепонирования(ЗаписьXML, Данные)
	КодУчастникаФР	= КодУчастникаФондовогоРынка(Данные.Контрагент);
	ЗаписатьЭлементXML(ЗаписьXML, "corr_code",	?(ЗначениеЗаполнено(КодУчастникаФР), КодУчастникаФР,
		СокрЛП(Данные.КонтрагентКод)));															// Получатель
	ЗаписатьЭлементXML(ЗаписьXML, "corr_acc_c",	СокрЛП(Данные.СчетДепоКонтрагентаКод));			// Счет депо
	ЗаписатьЭлементXML(ЗаписьXML, "corr_sec_c",	СокрЛП(Данные.РазделСчетаДепоКонтрагентаКод));	// Раздел счета депо
КонецПроцедуры

Функция РезультатЗаписиXMLЗачислениеМеждуСчетамиДепо(ЗаписьXML, Данные, КодЗагрузкиОрганизации)
	// {{ MF010
	ЗаписьXML.ЗаписатьНачалоЭлемента("MF010");
	
	ЗаписатьЭлементыXMLДанныеОтправителяПриДепонировании(ЗаписьXML, Данные, КодЗагрузкиОрганизации);
	
	ЗаписатьЭлементXML(ЗаписьXML, "corr_acc_c",	СокрЛП(Данные.СчетДепоМХКод));			// Счет депо получателя
	ЗаписатьЭлементXML(ЗаписьXML, "corr_sec_c",	СокрЛП(Данные.РазделСчетаДепоМХКод));	// Раздел счета депо получателя
	ЗаписатьЭлементXML(ЗаписьXML, "corr_code",	КодЗагрузкиОрганизации);				// Получатель
	
	ЗаписатьЭлементыXMLДепозитарныйДоговор(ЗаписьXML, Данные);
	
	// {{ Электронный Matching в НРД
	Если ЗначениеЗаполнено(Данные.РазделСчетаДепоКонтрагентаКраткийКодНРД)
		ИЛИ ЗначениеЗаполнено(Данные.КраткийКодНРД) Тогда
		section_id = ?(ЗначениеЗаполнено(Данные.КраткийКодНРД), Данные.КраткийКодНРД,
			Данные.РазделСчетаДепоКонтрагентаКраткийКодНРД);
		ЗаписатьЭлементXML(ЗаписьXML, "section_id", СокрЛП(section_id));
	КонецЕсли;
	Если ЗначениеЗаполнено(Данные.РазделСчетаДепоКраткийКодНРД) Тогда
		ЗаписатьЭлементXML(ЗаписьXML, "corr_sec_id", СокрЛП(Данные.РазделСчетаДепоКраткийКодНРД));
	КонецЕсли;
	Если ЗначениеЗаполнено(Данные.Референс) Тогда
		ЗаписатьЭлементXML(ЗаписьXML, "deal_reference", СокрЛП(Данные.Референс));
	КонецЕсли;
	Если ЗначениеЗаполнено(Данные.ДатаСделки) Тогда
		ЗаписатьЭлементXML(ЗаписьXML, "date_deal", ФорматДаты(Данные.ДатаСделки));
	КонецЕсли;
	// }} Электронный Matching в НРД
	
	Ошибка = РезультатЗаписиXMLЦенныеБумагиСУчетомISIN(ЗаписьXML, Данные);
	Если ЗначениеЗаполнено(Ошибка) Тогда
		Возврат Ошибка;
	КонецЕсли;
	
	// }} MF010
	ЗаписьXML.ЗаписатьКонецЭлемента();
	Возврат Неопределено;
КонецФункции

Процедура ЗаписатьЭлементыXMLДепозитарныйДоговор(ЗаписьXML, Данные);
	ДепозитарныйДоговор		= Справочники.ДоговорыКонтрагентов.ПустаяСсылка();
	ДепозитарныеДоговоры	= Справочники.ДоговорыКонтрагентов.Выбрать(, Данные.Депонент);
	Пока ДепозитарныеДоговоры.Следующий() Цикл
		Если ЗначениеЗаполнено(ДепозитарныеДоговоры.ДатаОкончанияДействия)
			И (ДепозитарныеДоговоры.ДатаОкончанияДействия < Данные.Дата) Тогда
			Продолжить;
		Иначе
			ДепозитарныйДоговор = ДепозитарныеДоговоры.Ссылка;
		КонецЕсли;
	КонецЦикла;
	Если НЕ ДепозитарныйДоговор.Пустая() Тогда
		// Основание (депозитарный договор)
		ЗаписатьЭлементXML(ЗаписьXML, "based_on",	"Депозитарный договор");
		// Номер документа-основания
		ЗаписатьЭлементXML(ЗаписьXML, "based_numb",	СокрЛП(ДепозитарныйДоговор.Код));
		Если ЗначениеЗаполнено(ДепозитарныйДоговор.ДатаНачалоДействия) Тогда
			// Дата документа основания
			ЗаписатьЭлементXML(ЗаписьXML, "based_date", ФорматДаты(ДепозитарныйДоговор.ДатаНачалоДействия));
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

Функция РезультатЗаписиXMLЗачислениеИзДругогоДепозитария(ЗаписьXML, Данные, КодЗагрузкиОрганизации)
	// {{ MF035
	ЗаписьXML.ЗаписатьНачалоЭлемента("MF035");
	// Заполняем информацию по отправителю
	ЗаписатьЭлементыXMLДанныеОтправителяПриДепонировании(ЗаписьXML, Данные, КодЗагрузкиОрганизации);
	// SWIFT код стороннего депозитария
	Если ЗначениеЗаполнено(Данные.СчетДепоКонтрагента) И ЗначениеЗаполнено(Данные.СчетДепоКонтрагента.БИКМестаРасчетов) Тогда
		ЗаписатьЭлементXML(ЗаписьXML, "reestr_bic", СокрЛП(Данные.СчетДепоКонтрагента.БИКМестаРасчетов));
	КонецЕсли;	
	Если ЗначениеЗаполнено(Данные.СчетДепоКонтрагента) И ЗначениеЗаполнено(Данные.СчетДепоКонтрагента.КодМестаРасчетов) Тогда
		ЗаписатьЭлементXML(ЗаписьXML, "reestr_cod", СокрЛП(Данные.СчетДепоКонтрагента.КодМестаРасчетов));
	КонецЕсли;
	
	// Отправитель
	//
	
	// BIC/BEI отправителя
	Если ЗначениеЗаполнено(Данные.СчетДепоКонтрагента)
		И ЗначениеЗаполнено(Данные.СчетДепоКонтрагента.БикОтправителя) Тогда
		person_bic = Данные.СчетДепоКонтрагента.БикОтправителя;
	Иначе
		person_bic = Данные.БикКлиентаДепозитария;
	КонецЕсли;
	Если ЗначениеЗаполнено(person_bic) Тогда
		ЗаписатьЭлементXML(ЗаписьXML, "person_bic",	СокрЛП(person_bic));
	КонецЕсли; 
	
	// Полное имя отправителя
	Если Не ЗначениеЗаполнено(person_bic) Тогда // полное имя заполняем только если нет BIC/BEI
		Если ЗначениеЗаполнено(Данные.СчетДепоКонтрагента)
			И ЗначениеЗаполнено(Данные.СчетДепоКонтрагента.СчетВМестеРасчетовНаименование) Тогда
			full_name = Данные.СчетДепоКонтрагента.СчетВМестеРасчетовНаименование;
		Иначе
			Если ЗначениеЗаполнено(Данные.ПолноеНаименованиеКонтрагента) Тогда
				full_name = Данные.ПолноеНаименованиеКонтрагента;
			Иначе
				full_name = Данные.НаименованиеКонтрагента;
			КонецЕсли;
		КонецЕсли;
		ЗаписатьЭлементXML(ЗаписьXML, "full_name", СокрЛП(full_name));
	КонецЕсли;
	
	// Счет депо получателя
	Если ЗначениеЗаполнено(Данные.СчетДепоКонтрагента)
		И ЗначениеЗаполнено(Данные.СчетДепоКонтрагента.СчетВМестеРасчетовНомерСчета) Тогда
		sr_acc_c = Данные.СчетДепоКонтрагента.СчетВМестеРасчетовНомерСчета;
	Иначе
		sr_acc_c = Данные.СчетДепоКонтрагентаКод;
	КонецЕсли;
	ЗаписатьЭлементXML(ЗаписьXML, "sr_acc_c", СокрЛП(sr_acc_c));
	
	ЗаписатьЭлементыXMLИнформацияОСчетеВМестеРасчетов(ЗаписьXML, Данные);
	
	// Операция иcполнена/не исполнена
	ЗаписатьЭлементXML(ЗаписьXML, "oper_mark", "N");
	// Дата операции
	ЗаписатьЭлементXML(ЗаписьXML, "oper_date", ФорматДаты(Данные.ПланируемаяДатаРасчетов));
	// Дата сделки
	Если ЗначениеЗаполнено(Данные.ДатаСделки) Тогда
		ЗаписатьЭлементXML(ЗаписьXML, "trad_dt", ФорматДаты(Данные.ДатаСделки));
	КонецЕсли;
	// Нужно встречное поручение
	ЗаписатьЭлементXML(ЗаписьXML, "need_cvit", "Y");
	// Оплата операции в месте расчетов получателем
	ЗаписатьЭлементXML(ЗаписьXML, "reciv_payment", "N");
	// Код ЦБ в НДЦ
	Если ЗначениеЗаполнено(Данные.КодЦБ) Тогда
		ЗаписатьЭлементXML(ЗаписьXML, "security_c", СокрЛП(Данные.КодЦБ));
	Иначе
		Возврат ОшибкаПустойКодЗагрузкиЦеннойБумаги(Данные);
	КонецЕсли;
	// Количество ЦБ
	ЗаписатьЭлементXML(ЗаписьXML, "security_q", ФорматКоличества(Данные.КоличествоЦБ));
	
	Если Данные.СуммаСделки <> 0 Тогда
		Ошибка = РезультатЗаписиXMLAddInforms(ЗаписьXML, Данные);
		Если ЗначениеЗаполнено(Ошибка) Тогда
			Возврат Ошибка;
		КонецЕсли;
		Ошибка = РезультатЗаписиXMLСуммаСделкиВалюта(ЗаписьXML, Данные);
		Если ЗначениеЗаполнено(Ошибка) Тогда
			Возврат Ошибка;
		КонецЕсли;
	КонецЕсли;
	Ошибка = РезультатЗаписиXMLПодтверждающиеДокументы(ЗаписьXML, Данные);
	Если ЗначениеЗаполнено(Ошибка) Тогда
		Возврат Ошибка;
	КонецЕсли;
	// }} MF035
	ЗаписьXML.ЗаписатьКонецЭлемента();
	Возврат Неопределено;
