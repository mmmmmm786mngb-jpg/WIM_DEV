	КонецЕсли;
	Возврат Неопределено;
КонецФункции

Процедура ЗаписатьЭлементыXMLИнформацияОСчетеВМестеРасчетов(ЗаписьXML, Данные)
	Если ЗначениеЗаполнено(Данные.СчетДепоКонтрагента) Тогда
		СчетДепо = Данные.СчетДепоКонтрагента;
		Если ЗначениеЗаполнено(СчетДепо.СчетВМестеРасчетовКодКлиента) Тогда
			ЗаписатьЭлементXML(ЗаписьXML, "pr_client_code", СокрЛП(СчетДепо.СчетВМестеРасчетовКодКлиента));
		КонецЕсли;
		Если ЗначениеЗаполнено(СчетДепо.СчетВМестеРасчетовНаименованиеКлиента) Тогда
			ЗаписатьЭлементXML(ЗаписьXML, "pr_client_name", СокрЛП(СчетДепо.СчетВМестеРасчетовНаименованиеКлиента));
		КонецЕсли;
		Если ЗначениеЗаполнено(СчетДепо.СчетВМестеРасчетовНомерСчетаКлиента) Тогда
			ЗаписатьЭлементXML(ЗаписьXML, "pr_client_acc", СокрЛП(СчетДепо.СчетВМестеРасчетовНомерСчетаКлиента));
		КонецЕсли;
		Если ЗначениеЗаполнено(СчетДепо.БикКлиентаОтправителяПолучателя) Тогда
			ЗаписатьЭлементXML(ЗаписьXML, "pr_client_bic", СокрЛП(СчетДепо.БикКлиентаОтправителяПолучателя));
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

Функция РезультатЗаписиXMLЦенныеБумагиВсеДанные(ЗаписьXML, Данные, ВыводитьISIN)
	// {{ Ценные бумаги
	ЗаписьXML.ЗаписатьНачалоЭлемента("securities");
	// {{ Ценная бумага
	ЗаписьXML.ЗаписатьНачалоЭлемента("security");
	// Код ЦБ в НДЦ
	Если ЗначениеЗаполнено(Данные.КодЦБ) Тогда
		ЗаписатьЭлементXML(ЗаписьXML, "security_c", СокрЛП(Данные.КодЦБ));
	Иначе
		Возврат ОшибкаПустойКодЗагрузкиЦеннойБумаги(Данные);
	КонецЕсли;
	// Количество ЦБ
	ЗаписатьЭлементXML(ЗаписьXML, "security_q", ФорматКоличества(Данные.КоличествоЦБ));
	// ISIN
	Если ВыводитьISIN И НЕ ПустаяСтрока(Данные.ISIN) Тогда
		ЗаписатьЭлементXML(ЗаписьXML, "security_isin", СокрЛП(Данные.ISIN));
	КонецЕсли;
	// }} Ценная бумага
	ЗаписьXML.ЗаписатьКонецЭлемента();
	// }} Ценные бумаги
	ЗаписьXML.ЗаписатьКонецЭлемента();
	Возврат Неопределено;
КонецФункции

Функция РезультатЗаписиXMLЦенныеБумагиСУчетомISIN(ЗаписьXML, Данные)
