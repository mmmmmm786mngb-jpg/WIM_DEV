Процедура ЗаполнитьПоручения(ВыгружаемыйДокумент = Неопределено) Экспорт

	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	
	Запрос.Текст =
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ТЧПоручения.Поручение КАК Основание
	|ПОМЕСТИТЬ втНеттоПоручения
	|ИЗ
	|	Документ.НеттоПоручение.Поручения КАК ТЧПоручения
	|ГДЕ
	|	ТЧПоручения.Ссылка.Проведен";
	Запрос.Выполнить();
	
	Запрос.Текст = ТекстЗапросаПоручений();
	Запрос.УстановитьПараметр("НДЦ",			Константы.КлассификаторЗагрузкиНДЦ.Получить());
	Запрос.УстановитьПараметр("МестоХранения",	Константы.МестоХраненияПоУмолчанию.Получить());
	Запрос.УстановитьПараметр("ВнешнийБрокер",	Константы.ВнешнийБрокер.Получить());
	
	Запрос.УстановитьПараметр("ТолькоПроверенные",			ТолькоПроверенные);
	Запрос.УстановитьПараметр("ТолькоПринятыеВОбработку",	ТолькоПринятыеВОбработку);
	
	Если ЗначениеЗаполнено(ВыгружаемыйДокумент) Тогда
		Запрос.УстановитьПараметр("ВыгружаемыйДокумент", ВыгружаемыйДокумент);
		Запрос.УстановитьПараметр("ВыгрузитьБезусловно", Истина);
		ДополнительныеУсловияОтбора = "Ссылка В (&ВыгружаемыйДокумент)";
		Запрос.УстановитьПараметр("КонецДня",	КонецДня(ТекущаяДатаСеанса()));
	Иначе
		Запрос.УстановитьПараметр("НачалоДня",	НачалоДня(ОбщегоНазначения.ДобавитьРабочийДень(ДатаВыгрузки, -3)));
		Запрос.УстановитьПараметр("КонецДня",	КонецДня(ДатаВыгрузки));
		Запрос.УстановитьПараметр("ВыгрузитьБезусловно", Ложь);
		ДополнительныеУсловияОтбора = "Дата МЕЖДУ &НачалоДня И &КонецДня";
	КонецЕсли;
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "&ДополнительныеУсловияОтбора", ДополнительныеУсловияОтбора);
	
	Запрос.УстановитьПараметр("СчетКонтрагента",		Перечисления.ПризнакиСчетаДепо.СчетКонтрагента);
	Запрос.УстановитьПараметр("ПустойСчетДепо",			Справочники.СчетаДепо.ПустаяСсылка());
	Запрос.УстановитьПараметр("ПустаяВалюта",			Справочники.Валюты.ПустаяСсылка());
	Запрос.УстановитьПараметр("Депонирование",			Справочники.ВидыОпераций.Депонирование);
	Запрос.УстановитьПараметр("СнятиеСДепонирования",	Справочники.ВидыОпераций.СнятиеСДепонирования);
	Запрос.УстановитьПараметр("ПереводМеждуРазделамиСчетаДепо",
		Справочники.ВидыОпераций.ПереводМеждуРазделамиСчетаДепо);
	Запрос.УстановитьПараметр("ОткрытиеРазделаСчетаДепо",
		Справочники.ВидыОпераций.ОткрытиеРазделаСчетаДепо);
	Запрос.УстановитьПараметр("ЗакрытиеРазделаСчетаДепо",Справочники.ВидыОпераций.ЗакрытиеРазделаСчетаДепо);
	Запрос.УстановитьПараметр("Перемещение",			Справочники.ВидыОпераций.Перемещение);
	Запрос.УстановитьПараметр("Налоговый",				Перечисления.ТипыРазделовСчетовДЕПО.Налоговый);
	Запрос.УстановитьПараметр("ЮрЛицо",					Перечисления.ЮрФизЛицо.ЮрЛицо);
	Запрос.УстановитьПараметр("ФизЛицо",				Перечисления.ЮрФизЛицо.ФизЛицо);
	Запрос.УстановитьПараметр("БезСтатусаОтменено",		БезСтатусаОтменено);
	Запрос.УстановитьПараметр("ТолькоПроведенные",		ТолькоПроведенные);
	
	МассивСтатусовКВыгрузке = Новый Массив;
	МассивСтатусовКВыгрузке.Добавить(Перечисления.СтатусыДокументовФайловыйШлюз.ВыгрузитьФайловыйШлюз);
	МассивСтатусовКВыгрузке.Добавить(Перечисления.СтатусыДокументовФайловыйШлюз.ОшибкаФайловыйШлюз);
	МассивСтатусовКВыгрузке.Добавить(Перечисления.СтатусыДокументовФайловыйШлюз.НеПринятоКИсполнению);
	МассивСтатусовКВыгрузке.Добавить(Перечисления.СтатусыДокументовФайловыйШлюз.НеИсполнено);	
	
	Запрос.УстановитьПараметр("МассивСтатусовКВыгрузке", МассивСтатусовКВыгрузке);
	
	Поручения.Загрузить(Запрос.Выполнить().Выгрузить());
КонецПроцедуры

// Возвращает структуру с описанием ошибки, если она обнаружена. Иначе - Неопределено.
// Возвращаемое значение:
//	- Структура
Функция РезультатВыгрузкиПоручений() Экспорт
	
	Ошибка = ВнешниеДанные.НовоеОписаниеОшибкиДляРегистрацииИОповещения();
	Ошибка = Новый Структура("СообщениеПользователю,СообщениеВЖурнал,Данные");
	
	ФормироватьФайлыПоСхемеВидовИнвентарныхПоручений = Константы.ФормироватьФайлыПоСхемеВидовИнвентарныхПоручений.Получить();	
	
	Организация = Константы.ОрганизацияПоУмолчанию.Получить();
	НДЦ = Константы.КлассификаторЗагрузкиНДЦ.Получить();
	КодЗагрузкиОрганизации = Справочники.Организации.КодЗагрузки(Организация, НДЦ, ДатаВыгрузки);
	Если НЕ ЗначениеЗаполнено(КодЗагрузкиОрганизации) Тогда
		Ошибка.СообщениеВЖурнал = "На " + Формат(ДатаВыгрузки, "ДЛФ=Д") + " не указан код загрузки юр.лица организации";
		Ошибка.Данные = Организация;
		Ошибка.СообщениеПользователю = Ошибка.СообщениеВЖурнал + " " + Ошибка.Данные;
		Возврат Ошибка;
	КонецЕсли;
	
	Если ПолучитьФункциональнуюОпцию("ИспользоватьФайловыйШлюзДляОтправкиПоручений") Тогда 
		
		ВремяНачалаРезультатВыгрузкиПоручений = ОценкаПроизводительности.НачатьЗамерВремени();
		ОшибкаВыгрузки = Неопределено;
		
		Для Каждого Строка Из Поручения Цикл
			
			Если Строка.КВыгрузке Тогда
				
				Если ФормироватьФайлыПоСхемеВидовИнвентарныхПоручений Тогда
					ОшибкаВыгрузки = Обработки.ЭкспортПорученийВЛуч.ВыгрузитьПоСхеме(Строка.Поручение);
					Если ЗначениеЗаполнено(ОшибкаВыгрузки) Тогда
						Прервать;
					КонецЕсли;
				Иначе
					ОшибкаВыгрузки = РезультатФормированияПакетаXML_ФШ(Строка, КодЗагрузкиОрганизации);
					Если ЗначениеЗаполнено(ОшибкаВыгрузки) Тогда
						Прервать;
					КонецЕсли;
				КонецЕсли;
				
			КонецЕсли;
			
		КонецЦикла;
		
		ОценкаПроизводительности.ЗакончитьЗамерВремени("ЭкспортПорученийВЛуч_РезультатВыгрузкиПоручений", 
			ВремяНачалаРезультатВыгрузкиПоручений, , , ЗначениеЗаполнено(ОшибкаВыгрузки));
		
		Если ЗначениеЗаполнено(ОшибкаВыгрузки) Тогда
			Возврат ОшибкаВыгрузки;
		КонецЕсли;
		
	Иначе	
		
		ВнешнийИсточникКаталогВыгрузки = ПланыВидовХарактеристик.ВнешниеИсточники.КаталогВыгрузкиПорученийВЛуч;
		ПутьДляВыгрузки = ВнешниеДанные.ПутьКВнешнемуИсточникуКаталогу(ВнешнийИсточникКаталогВыгрузки, Ошибка);
		
		Папка = Новый Файл(ПутьДляВыгрузки);
		Если Папка.Существует() И Папка.ЭтоКаталог() Тогда
			
			ВремяНачалаРезультатВыгрузкиПоручений = ОценкаПроизводительности.НачатьЗамерВремени();
			ОшибкаВыгрузки = Неопределено;
			
			Для Каждого Строка Из Поручения Цикл
				
				Если Строка.КВыгрузке Тогда
					ОшибкаВыгрузки = РезультатФормированияПакетаXML(Строка, КодЗагрузкиОрганизации, ПутьДляВыгрузки);
					Если ЗначениеЗаполнено(ОшибкаВыгрузки) Тогда
						Прервать;
					КонецЕсли;
				КонецЕсли;
				
			КонецЦикла;
			
			ОценкаПроизводительности.ЗакончитьЗамерВремени("ЭкспортПорученийВЛуч_РезультатВыгрузкиПоручений", 
				ВремяНачалаРезультатВыгрузкиПоручений, , , ЗначениеЗаполнено(ОшибкаВыгрузки));
			
			Если ЗначениеЗаполнено(ОшибкаВыгрузки) Тогда
				Возврат ОшибкаВыгрузки;
			КонецЕсли;
			
		Иначе
			Ошибка.СообщениеВЖурнал = "Не существует или отсутствует доступ к каталогу " + ПутьДляВыгрузки
			+ " внешнего источника";
			Ошибка.Данные = ВнешнийИсточникКаталогВыгрузки;
			Ошибка.СообщениеПользователю = Ошибка.СообщениеВЖурнал + " " + Ошибка.Данные;
			Возврат Ошибка;
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Неопределено;
	
КонецФункции

Процедура СохранитьЗначенияРеквизитовПоУмолчанию() Экспорт
	
	Если НЕ ПроверитьЗаполнение() Тогда
		Возврат;
	КонецЕсли;
	
	НомераВерсийПоУмолчанию = НомераВерсий.Выгрузить();
	НомераВерсийПроверка = НомераВерсийПоУмолчанию.Скопировать(, "КодОперации");
	НомераВерсийПроверка.Свернуть("КодОперации");
	Если НомераВерсийПоУмолчанию.Количество() > НомераВерсийПроверка.Количество() Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Дублируются кода операций, сохранение настройки невозможно!");
		Возврат;	
	КонецЕсли;
	
	ИмяОбъекта = Метаданные().ПолноеИмя();
	ЗначенияРеквизитов = Новый Структура();
	ЗначенияРеквизитов.Вставить("НомераВерсий", НомераВерсийПоУмолчанию);
	ОбщегоНазначения.НоваяНастройкаЗаполненияДанныхПоУмолчанию(ИмяОбъекта, "Номера версий", Истина, ЗначенияРеквизитов, ДатаВыгрузки);
	
	ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Настройка заполнения данных по умолчанию сохранена.");
	
КонецПроцедуры

Процедура ВосстановитьЗначенияРеквизитовПоУмолчанию() Экспорт
	
	Если НомераВерсий.Количество() = 0 Тогда	
		ИмяОбъекта = Метаданные().ПолноеИмя();
		НомераВерсийПоУмолчанию = ОбщегоНазначения.ПолучитьЗначенияРеквизитовТабличныхЧастейОбъектаПоУмолчанию(ИмяОбъекта, "НомераВерсий",, "Номера версий", Истина, ДатаВыгрузки);
		Если НомераВерсийПоУмолчанию <> Неопределено Тогда
			НомераВерсий.Загрузить(НомераВерсийПоУмолчанию);
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры


