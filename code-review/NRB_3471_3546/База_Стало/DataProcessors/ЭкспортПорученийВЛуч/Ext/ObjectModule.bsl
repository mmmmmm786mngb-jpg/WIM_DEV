Функция НомерВерсии(КодОперации)
	
	НомерВерсии = "";
	Если ЗначениеЗаполнено(КодОперации) Тогда
		ВосстановитьЗначенияРеквизитовПоУмолчанию();
		
		Отбор = Новый Структура;
		Отбор.Вставить("КодОперации", КодОперации);
		НайденныеСтроки = НомераВерсий.НайтиСтроки(Отбор);
		Если НайденныеСтроки.Количество() = 1 Тогда
			НомерВерсии = СокрЛП(НайденныеСтроки[0].НомерВерсии);
		КонецЕсли;
	КонецЕсли;
	
	Возврат НомерВерсии;
	
КонецФункции 

Функция РезультатЗаписиXMLПереводМеждуСчетамиДепо(ЗаписьXML, Данные, КодЗагрузкиОрганизации)
	// {{ MF010
	ЗаписьXML.ЗаписатьНачалоЭлемента("MF010");
	
	// Отправитель
	ЗаписатьЭлементXML(ЗаписьXML, "deponent_c",	КодЗагрузкиОрганизации);
	// Счет депо отправителя
	ЗаписатьЭлементXML(ЗаписьXML, "dep_acc_c",	СокрЛП(Данные.СчетДепоМХКод));
	// Раздел счета депо отправителя
	ЗаписатьЭлементXML(ЗаписьXML, "sec_c",		СокрЛП(Данные.РазделСчетаДепоМХКод));
	
	// Получатель
	ЗаписатьЭлементXML(ЗаписьXML, "corr_code",	КодЗагрузкиОрганизации);
	
	// Счет депо получателя
	Если ЗначениеЗаполнено(Данные.СчетДепоКонтрагента)
		И ЗначениеЗаполнено(Данные.СчетДепоКонтрагента.СчетВМестеРасчетовНомерСчета) Тогда
		corr_acc_c = Данные.СчетДепоКонтрагента.СчетВМестеРасчетовНомерСчета;
	Иначе
		corr_acc_c = Данные.СчетДепоКонтрагентаКод;
	КонецЕсли;
	ЗаписатьЭлементXML(ЗаписьXML, "corr_acc_c",	СокрЛП(corr_acc_c));
	
	// Раздел счета депо получателя	
	ЗаписатьЭлементXML(ЗаписьXML, "corr_sec_c",	СокрЛП(Данные.РазделСчетаДепоМХКонтрагентаКод));
	
	Если ЗначениеЗаполнено(Данные.НомерДепозитарногоДоговораКонтрагента) Тогда
		// Основание (депозитарный договор)
		ЗаписатьЭлементXML(ЗаписьXML, "based_on",	"Депозитарный договор");
		// Номер документа-основания
		ЗаписатьЭлементXML(ЗаписьXML, "based_numb",	СокрЛП(Данные.НомерДепозитарногоДоговораКонтрагента));
	КонецЕсли;
	Если ЗначениеЗаполнено(Данные.СчетДепоКонтрагента.ДатаЗаключенияДепозитарногоДоговора) Тогда
		// Дата документа основания
		ЗаписатьЭлементXML(ЗаписьXML, "based_date", ФорматДаты(
			Данные.СчетДепоКонтрагента.ДатаЗаключенияДепозитарногоДоговора));
	КонецЕсли;
	
	Ошибка = РезультатЗаписиXMLЦенныеБумагиСУчетомISIN(ЗаписьXML, Данные);
	Если ЗначениеЗаполнено(Ошибка) Тогда
		Возврат Ошибка;
	КонецЕсли;
	
	// }} MF010
	ЗаписьXML.ЗаписатьКонецЭлемента();
	Возврат Неопределено;
КонецФункции

Функция РезультатЗаписиXMLПереводМеждуРазделамиПоОдномуСчетуДепо(ЗаписьXML, Данные, КодЗагрузкиОрганизации)
	// {{ MF020
	ЗаписьXML.ЗаписатьНачалоЭлемента("MF020");
	
	// Номер счета депо
	ЗаписатьЭлементXML(ЗаписьXML, "deponent_c",	КодЗагрузкиОрганизации);
	// Счет депо отправителя
	ЗаписатьЭлементXML(ЗаписьXML, "dep_acc_c",	СокрЛП(Данные.СчетДепоМХКод));
	// Раздел счета депо отправителя
	ЗаписатьЭлементXML(ЗаписьXML, "sec_c",		СокрЛП(Данные.РазделСчетаДепоМХКод));	
	// Раздел счета депо получателя	
	ЗаписатьЭлементXML(ЗаписьXML, "corr_sec_c",	СокрЛП(Данные.РазделСчетаДепоМХКонтрагентаКод));
	
	Ошибка = РезультатЗаписиXMLЦенныеБумагиСУчетомISIN(ЗаписьXML, Данные);
	Если ЗначениеЗаполнено(Ошибка) Тогда
		Возврат Ошибка;
	КонецЕсли;
	
	// }} MF020
	ЗаписьXML.ЗаписатьКонецЭлемента();
	Возврат Неопределено;
КонецФункции

