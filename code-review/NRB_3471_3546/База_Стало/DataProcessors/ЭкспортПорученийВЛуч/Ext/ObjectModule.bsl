Функция РезультатЗаписиXMLСуммаСделкиВалюта(ЗаписьXML, Данные)
	ЗаписатьЭлементXML(ЗаписьXML, "sec_price", Формат(Данные.СуммаСделки, "ЧГ=;ЧРД=."));
	Если ЗначениеЗаполнено(Данные.ВалютаБанковскогоСчета) Тогда
		ЗаписатьЭлементXML(ЗаписьXML, "curr_code", Справочники.Валюты.ПредставлениеВалюты(Данные.ВалютаБанковскогоСчета));
	Иначе
