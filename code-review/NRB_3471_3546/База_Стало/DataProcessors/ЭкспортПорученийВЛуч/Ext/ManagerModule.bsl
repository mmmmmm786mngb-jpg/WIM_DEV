							СоздатьОтменуПоручения(ТехническаяОперация.ДокументОснование, НомерОтчета, ДатаОтчета);
						КонецЕсли;
						
						Если ЗначениеЗаполнено(ДатаПереходаНаНовыйМеханизмБлокировокЦБ) Тогда
							ОбработатьБлокировкуЦБ(НовыйВходящийПакет, ДатаПереходаНаНовыйМеханизмБлокировокЦБ, ДанныеФайлов);
						КонецЕсли;
						
						ЭтоТехническаяОперацияПоПоручению = ЗначениеЗаполнено(ТехническаяОперация.ДокументОснование)
							И ТипЗнч(ТехническаяОперация.ДокументОснование) = Тип("ДокументСсылка.Поручение");
						Если ЭтоТехническаяОперацияПоПоручению Тогда
							Поручение = ТехническаяОперация.ДокументОснование;
							ЭтоМультиПоручениеП35_2 = Документы.Поручение.ЭтоМультиПоручениеП35_2(Поручение);
							Is352FormGS036 = ЭтоМультиПоручениеП35_2 И ВРЕГ(ФормаОтчета) = "GS036";
							Is352FormMS035 = ЭтоМультиПоручениеП35_2 И ВРЕГ(ФормаОтчета) = "MS035";
						Иначе
							ЭтоМультиПоручениеП35_2 = Ложь;
							Is352FormGS036 = Ложь;
							Is352FormMS035 = Ложь;
						КонецЕсли;
						Если Is352FormGS036 Тогда
							ФормаСообщенияКК = Перечисления.ФормыСообщенийКК.УведомлениеОРегистрацииЗаявкиВУКПаи;
							Документы.УведомлениеКлиентам.СоздатьИОтправитьУведомление(Поручение, ФормаСообщенияКК, НовыйВходящийПакет.Ссылка);
						КонецЕсли;
						
						Если ЗначениеЗаполнено(СтатусПоручения) И ЗначениеЗаполнено(ТехническаяОперация)
							И Не НовыйВходящийПакет.ПовторныйОтчет Тогда
							
							НачатьТранзакцию();
							ЗаписатьСтатусПоручения = Истина;
							
							Если СтатусПоручения = Перечисления.СтатусыДокументовФайловыйШлюз.Исполнено
								Или СтатусПоручения = Перечисления.СтатусыДокументовФайловыйШлюз.ИсполненоЧастично Тогда
								ДокументОснования = ТехническаяОперация.ДокументОснование;
								Если ЗначениеЗаполнено(ДокументОснования) Тогда
									Если НачалоДня(ДатаОтчета) = НачалоДня(ТекущаяДата()) Тогда
										ДатаПоследнейВыгрузкиЭДО = РегистрыСведений.РегистрацияДокументовВЭДО.ПоследнееВремяРегистрации(ДатаОтчета);
										Если ДатаОтчета < ДатаПоследнейВыгрузкиЭДО Тогда
											ДатаОтчета = ДатаПоследнейВыгрузкиЭДО + 1;
										КонецЕсли;
									КонецЕсли;
									Комментарий = "Отчет/выписка №" + ?(ЭтоМультиПоручениеП35_2, НомерОтчета, РегистрационныйНомер)
										+ " от " + Формат(ДатаОтчета, "ДФ=dd.MM.yyyy");
									Если ЭтоМультиПоручениеП35_2 И ЗначениеЗаполнено(Поручение.ДатаИсполненияПоручения) Тогда
										ТекстОшибки = "";
									Иначе
										ТекстОшибки = РезультатЗаполненияПоручения(ДокументОснования,
											РегистрационныйНомер, ДатаОтчета, ДатаИсполненияВМестеРасчетов, НомерОтчета, Комментарий);
									КонецЕсли;
									Если ТекстОшибки = "" И Is352FormMS035 Тогда
										ЗначенияПараметровОперацииЦБ = Новый Структура;
										КодЦБвНРД = ДанныеФайлов.КодЦБвНРД;
										ЦБ = Справочники.ЦенныеБумаги.ЦеннаяБумагаПоКодуЗагрузкиНДЦ(КодЦБвНРД, ДатаОтчета);
										ЗначенияПараметровОперацииЦБ.Вставить("ЦБ", ?(ЗначениеЗаполнено(КодЦБвНРД), ЦБ, Неопределено));
										ЗначенияПараметровОперацииЦБ.Вставить("КоличествоЦБ", ИсполненноеКоличествоЦБ);
										ЗначенияПараметровОперацииЦБ.Вставить("ДатаИсполненияВДепозитарииМХ", ДатаОтчета);
										ЗначенияПараметровОперацииЦБ.Вставить("ДатаИсполненияВМестеРасчетов", ДатаИсполненияВМестеРасчетов);
										КомментарийОперацииЦБ = СокрЛП(ТехническаяОперация.Комментарий)
											+ ?(ЗначениеЗаполнено(ТехническаяОперация.Комментарий), " | ", "") + Комментарий;
										ЗначенияПараметровОперацииЦБ.Вставить("КомментарийОперацииЦБ", КомментарийОперацииЦБ);
										Документы.Поручение.СоздатьОбновитьОперацииЦБ(Поручение, РежимЗаписиДокумента.Проведение, ДатаОтчета, ,
											НомерОтчета, ЗначенияПараметровОперацииЦБ);
									КонецЕсли;
									Если ТекстОшибки = "" И (ТипЗнч(ДокументОснования) = Тип("ДокументСсылка.Поручение")
											Или ТипЗнч(ДокументОснования) = Тип("ДокументСсылка.НеттоПоручение")) Тогда
										ДокументыКПеренумерации.Добавить(ДокументОснования);
										
									ИначеЕсли Не СокрЛП(ТекстОшибки) = "" Тогда
										ПомещатьВАрхив = Ложь;
										ЗаписьЖурналаРегистрации("Заполнение поручений по данным Луча", 
											УровеньЖурналаРегистрации.Предупреждение, ДокументОснования.Метаданные(), 
											ДокументОснования, ТекстОшибки);
									КонецЕсли;
									
									ТекстОшибки = РезультатЗаполненияДанныхДепонента(ДокументОснования, КодКонтрагентаНРД, НаименованиеКонтрагентаНРД);
									
									Если Не СокрЛП(ТекстОшибки) = "" Тогда
										ПомещатьВАрхив = Ложь;
										ЗаписьЖурналаРегистрации("Заполнение поручений по данным Луча", 
											УровеньЖурналаРегистрации.Предупреждение, ДокументОснования.Метаданные(), 
											ДокументОснования, ТекстОшибки);
									КонецЕсли;
									
									Если ТипЗнч(ДокументОснования) = Тип("ДокументСсылка.НеттоПоручение")
										И ИсполненноеКоличествоЦБ > 0 Тогда
										
										ВидОперацииНетто = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДокументОснования, "ВидОперации");
										ТекстОшибки = Документы.ИсполнениеПоручения.РезультатФормированияИсполненияПоручения(ДокументОснования,
											ВидОперацииНетто, НомерОтчета, ИсполненноеКоличествоЦБ, ДатаОтчета,
											ДатаИсполненияВДепозитарииМХ, ДатаИсполненияВМестеРасчетов);
										
										Если ЗначениеЗаполнено(ТекстОшибки) Тогда
											ОтменитьТранзакцию();
											ЗаписатьСтатусПоручения = Ложь;
											
											Если НовыйВходящийПакет.Обработан Тогда
												УстановитьФлажокОбработан(НовыйВходящийПакет.Ссылка, Ложь);
											КонецЕсли;
											
											ПомещатьВАрхив = Ложь;
											ЗаписьЖурналаРегистрации("Формирование исполнения поручения",
												УровеньЖурналаРегистрации.Ошибка, ДокументОснования.Метаданные(),
												ДокументОснования, ТекстОшибки);
										КонецЕсли;
									КонецЕсли;
									
								Иначе
									ОбъектТО = ТехническаяОперация.ПолучитьОбъект();
									ОбъектТО.КодОтчетаНРД = НомерОтчета;
									ОбъектТО.ДатаИсполнения = ДатаОтчета;
									ОбъектТО.Записать();
								КонецЕсли;
							КонецЕсли;
							
							Если ЗаписатьСтатусПоручения Тогда
								Если Не НовыйВходящийПакет.Обработан Тогда
									УстановитьФлажокОбработан(НовыйВходящийПакет.Ссылка, Истина);
								КонецЕсли;
								
								КомментарийОтчета = ДанныеФайлов.ПричинаОтмены;
								РегистрыСведений.СостоянияДокументовВФайловомШлюзе.ДобавитьЗапись(ТекущаяДатаСеанса(), ТехническаяОперация,
									СтатусПоручения, НовыйВходящийПакет.Ссылка, КомментарийОтчета, ИсполненноеКоличествоЦБ);
								ЭтоОтказПоПричинеОкончанияКлиринга = СтрНайти(КомментарийОтчета, "INSTRUCTION UNSETTLED - END OF RECYCLING")> 0;
								Если ЭтоОтказПоПричинеОкончанияКлиринга Тогда
									ДокументОснования = ТехническаяОперация.ДокументОснование;
									Если ЗначениеЗаполнено(ДокументОснования) Тогда
										ВыгрузитьПоручениеПовторно(ДокументОснования);
									КонецЕсли;
								КонецЕсли;
								ЗафиксироватьТранзакцию();
							КонецЕсли;
							
						ИначеЕсли Не ЗначениеЗаполнено(СтатусПоручения) И ЗначениеЗаполнено(ТехническаяОперация) Тогда
							Если ЗначениеЗаполнено(ДанныеФайлов.СообщениеОтНРД) Тогда
								СообщениеОтНРД = ДанныеФайлов.СообщениеОтНРД;
							ИначеЕсли ЗначениеЗаполнено(ДанныеФайлов.ПричинаПриостановки) Тогда
								СообщениеОтНРД = ДанныеФайлов.ПричинаПриостановки;
							Иначе
								СообщениеОтНРД = "";
							КонецЕсли;
							
							Если ЗначениеЗаполнено(СообщениеОтНРД) Тогда
