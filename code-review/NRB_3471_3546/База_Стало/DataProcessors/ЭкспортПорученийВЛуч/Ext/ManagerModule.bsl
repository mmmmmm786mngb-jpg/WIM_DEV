Функция ОстаткиПоЦБ(Дата, ЦБ, СчетДепоМХ, РазделСчетаДепоМХ)
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	ОстаткиЦБОстатки.СчетДепо КАК СчетДепо,
	|	ОстаткиЦБОстатки.РазделСчетаДепо КАК РазделСчетаДепо,
	|	ОстаткиЦБОстатки.ЦБ КАК ЦеннаяБумага,
	|	ОстаткиЦБОстатки.КоличествоОстаток КАК Количество,
	|	ОстаткиЦБОстатки.СчетДепоМХ,
	|	ОстаткиЦБОстатки.РазделСчетаДепоМХ
	|ИЗ
	|	РегистрНакопления.ОстаткиЦБ.Остатки(
	|			&Период,
	|			ЦБ = &ЦеннаяБумага
	|				И СчетДепоМХ = &СчетДепоМХ
	|				И РазделСчетаДепоМХ = &РазделСчетаДепоМХ) КАК ОстаткиЦБОстатки
	|
	|УПОРЯДОЧИТЬ ПО
	|	ОстаткиЦБОстатки.СчетДепо.Владелец.Наименование,
	|	ОстаткиЦБОстатки.СчетДепо,
	|	ОстаткиЦБОстатки.РазделСчетаДепо");
	
	Запрос.УстановитьПараметр("Период", Дата);
	Запрос.УстановитьПараметр("ЦеннаяБумага", ЦБ);
	Запрос.УстановитьПараметр("СчетДепоМХ", СчетДепоМХ);
	Запрос.УстановитьПараметр("РазделСчетаДепоМХ", РазделСчетаДепоМХ);
	
	Результат = Запрос.Выполнить();
	//Если Результат.Пустой() Тогда
	//	Возврат;
	//КонецЕсли;
	
	Возврат Результат.Выгрузить();
КонецФункции // ()
 
Функция СформироватьИсходящийПакетВФайловыйШлюз(Номер, Дата, ТипОперации, КодОперации, ДокументОснование, ТекстСообщения,
	НомерТехническойОперации = Неопределено) Экспорт
	
	РасширениеXML = ".xml";
	
	ВнешнийИсточникФайловыйШлюзКаталогКОтправке = ПланыВидовХарактеристик.ВнешниеИсточники.ФайловыйШлюзКаталогКОтправке;
	Ошибка = ВнешниеДанные.НовоеОписаниеОшибкиДляРегистрацииИОповещения();
	ПутьДляВыгрузки = ВнешниеДанные.ПутьКВнешнемуИсточникуКаталогу(ВнешнийИсточникФайловыйШлюзКаталогКОтправке, Ошибка);
	
	ТекущаяДата = ТекущаяДатаСеанса();
	
	НовыйПорядковыйНомер = Документы.ТехническаяОперация.НовыйПорядковыйНомерВТечениеДня(ТекущаяДата);
	Если НовыйПорядковыйНомер = 0 Тогда
		Ошибка.СообщениеВЖурнал = "Не удалось получить новый порядковый номер за " + Формат(ТекущаяДата, "ДЛФ=Д");
		Ошибка.СообщениеПользователю = Ошибка.СообщениеВЖурнал;
		Возврат Ошибка;
	КонецЕсли;
	
	ЭтоТранзит = Документы.РаскрытиеСпискаВладельцев.ЭтоТранзитЧерезСЭДНРД(ДокументОснование);
	Если ЭтоТранзит Тогда
		Префикс = "W";
	Иначе
		Префикс = "K";
	КонецЕсли;
	
	НомерДня = Формат(ТекущаяДата, "ДФ=dd");
	НомерМесяца = СтроковыеФункцииКлиентСервер.МесяцВШестнадцатеричнойСистеме(Месяц(ТекущаяДата));
	
	ИмяФайлаXML = Префикс + НомерДня + НомерМесяца + Формат(НовыйПорядковыйНомер, "ЧЦ=4; ЧВН=; ЧГ=0");
	ИмяКаталогДляФайла = ПутьДляВыгрузки + "\" + ИмяФайлаXML;
	
	КаталогДляФайла = Новый Файл(ИмяКаталогДляФайла);
	Пока КаталогДляФайла.Существует() Цикл
		НовыйПорядковыйНомер = НовыйПорядковыйНомер + 1;
		ИмяФайлаXML = Префикс + НомерДня + НомерМесяца + Формат(НовыйПорядковыйНомер, "ЧЦ=4; ЧВН=; ЧГ=0");
		
		ИмяКаталогДляФайла = ПутьДляВыгрузки + "\" + ИмяФайлаXML;
		КаталогДляФайла = Новый Файл(ИмяКаталогДляФайла);
	КонецЦикла; 
	СоздатьКаталог(ИмяКаталогДляФайла);
	
	ПолноеИмяФайлаXML = ИмяКаталогДляФайла + "\" + ИмяФайлаXML + РасширениеXML;

	ИмяВременногоФайла = ПолучитьИмяВременногоФайла(РасширениеXML);
	
	ЗаписьXML = Новый ЗаписьXML;
	Попытка
		ЗаписьXML.ОткрытьФайл(ИмяВременногоФайла, "windows-1251");
	Исключение
		Ошибка.СообщениеВЖурнал = "Не удалось открыть файл " + ИмяФайлаXML + РасширениеXML;
		Ошибка.СообщениеПользователю = Ошибка.СообщениеВЖурнал;
		Возврат Ошибка;
	КонецПопытки;	
	
	НоваяТехническаяОперация = Документы.ТехническаяОперация.СоздатьДокумент();
	НоваяТехническаяОперация.Дата = ТекущаяДатаСеанса();
	НоваяТехническаяОперация.НомерДокументаОснования = СокрЛП(Номер);
	НоваяТехническаяОперация.ДатаДокументаОснования = Дата;
	НоваяТехническаяОперация.ТипОперации = ТипОперации;
	НоваяТехническаяОперация.КодОперации = КодОперации;
	НоваяТехническаяОперация.ДокументОснование = ДокументОснование;
	НоваяТехническаяОперация.ПорядковыйНомерВнутриДня = НовыйПорядковыйНомер;
	НоваяТехническаяОперация.УстановитьНовыйНомер();
	Если ТипЗнч(ДокументОснование) = Тип("ДокументСсылка.Поручение") И Документы.Поручение.ЭтоМультиПоручениеП35_2(ДокументОснование) Тогда
		НоваяТехническаяОперация.Комментарий = ДокументОснование.Комментарий;
	КонецЕсли;
	НоваяТехническаяОперация.Записать(РежимЗаписиДокумента.Проведение);
	НомерТехническойОперации = НоваяТехническаяОперация.Номер;
	
	РегистрыСведений.СостоянияДокументовВФайловомШлюзе.ДобавитьЗапись(ТекущаяДата,
		НоваяТехническаяОперация.Ссылка, Перечисления.СтатусыДокументовФайловыйШлюз.ВыгрузитьФайловыйШлюз);
	
	НовыйИсходящийПакет = Документы.ИсходящийПакетВФайловыйШлюз.СоздатьДокумент();
	НовыйИсходящийПакет.Дата = ТекущаяДатаСеанса();
	НовыйИсходящийПакет.ДокументОснование = НоваяТехническаяОперация.Ссылка;
	НовыйИсходящийПакет.ОтносительныйПуть = ИмяФайлаXML;
	НовыйИсходящийПакет.ПолныйПуть = ИмяКаталогДляФайла;
	НовыйИсходящийПакет.Статус = Перечисления.СтатусыДокументовФайловыйШлюз.ВыгруженоФайловыйШлюз;
	НовыйИсходящийПакет.Комментарий = "Создан автоматически в " + Формат(ТекущаяДата, "ДЛФ=DT");
	НовыйИсходящийПакет.Записать(РежимЗаписиДокумента.Запись);

	РегистрыСведений.СостоянияДокументовВФайловомШлюзе.ДобавитьЗапись(ТекущаяДатаСеанса(),
		НоваяТехническаяОперация.Ссылка, Перечисления.СтатусыДокументовФайловыйШлюз.ВыгруженоФайловыйШлюз, НовыйИсходящийПакет.Ссылка);
	
	Если ЗначениеЗаполнено(ДокументОснование) Тогда
		РегистрыСведений.ДокументыВыгруженныеВЛуч.ДобавитьДокумент(ДокументОснование,
			ТекущаяДата, НомерТехническойОперации, "", ПараметрыСеанса.ТекущийПользователь);
	КонецЕсли;
	
	ТекстСообщения = ТекстСообщенияXML(Ложь, ТекстСообщения, Номер, ДокументОснование, НоваяТехническаяОперация.Ссылка, "", "");
	
	ЗаписьXML.ЗаписатьБезОбработки(ТекстСообщения);
	ЗаписьXML.Закрыть();
	
	ПереместитьФайл(ИмяВременногоФайла, ПолноеИмяФайлаXML);
	
	Если ЭтоТранзит Тогда
		ПолноеИмяФайлаWINF = ИмяКаталогДляФайла + "\" + "winf" + РасширениеXML;
		ИмяВременногоФайла = ПолучитьИмяВременногоФайла(РасширениеXML);
		ЗаписьXML = Новый ЗаписьXML;
		Попытка
			ЗаписьXML.ОткрытьФайл(ИмяВременногоФайла, "windows-1251");
		Исключение
			Ошибка.СообщениеВЖурнал = "Не удалось открыть файл " + ИмяФайлаXML + РасширениеXML;
			Ошибка.СообщениеПользователю = Ошибка.СообщениеВЖурнал;
			Возврат Ошибка;
		КонецПопытки;
		ТекстСообщенияWINF = ТекстСообщенияXML(Истина, "", "",
			ДокументОснование, НоваяТехническаяОперация.Ссылка, ИмяКаталогДляФайла, ИмяФайлаXML);
		ЗаписьXML.ЗаписатьБезОбработки(ТекстСообщенияWINF);
		ЗаписьXML.Закрыть();
		ПереместитьФайл(ИмяВременногоФайла, ПолноеИмяФайлаWINF);
	КонецЕсли;
	
	Возврат Неопределено;
КонецФункции

