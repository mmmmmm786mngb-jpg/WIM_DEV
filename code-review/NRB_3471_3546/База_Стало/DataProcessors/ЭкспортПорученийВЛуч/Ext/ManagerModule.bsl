
Процедура ОбработатьВходящиеПакетыФайловогоШлюза() Экспорт
	
	Если НЕ ПолучитьФункциональнуюОпцию("ИспользоватьФайловыйШлюзДляОтправкиПоручений") Тогда
		Возврат;
	КонецЕсли;
	
	ВремяНачалаОбработатьВходящиеПакетыФайловогоШлюза = ОценкаПроизводительности.НачатьЗамерВремени();
	
	ОбработатьОтправленныеПакеты();
	
	ОбработатьПакетыСОшибками();
	
	ОбработатьВыпискиЗадерживающиесяСОтправкой();
	
	ОбработатьВходящиеПакеты();
	
	ОбработатьРаскрытияСписковВладельцев();
	
	ОценкаПроизводительности.ЗакончитьЗамерВремени("ЭкспортПорученийВЛуч_ОбработатьВходящиеПакетыФайловогоШлюза",
													ВремяНачалаОбработатьВходящиеПакетыФайловогоШлюза);
	
КонецПроцедуры

//////////////////////////////////////////////////////////////////////////

Процедура ОбработатьОтправленныеПакеты()
	// Отправленные пакеты
	ВнешнийИсточникФайловыйШлюзКаталогОтправленных = ПланыВидовХарактеристик.ВнешниеИсточники.ФайловыйШлюзКаталогОтправленных;
	ПутьДляЗагрузки = ВнешниеДанные.ПолучитьПараметрыВнешнегоИсточника(ВнешнийИсточникФайловыйШлюзКаталогОтправленных).Папка;
	Если ЗначениеЗаполнено(ПутьДляЗагрузки) Тогда
		
		Запрос = Новый Запрос;
		Запрос.УстановитьПараметр("Статус", Перечисления.СтатусыДокументовФайловыйШлюз.ВыгруженоФайловыйШлюз);
		Запрос.Текст = "ВЫБРАТЬ
		|	СостоянияДокументовВФайловомШлюзеСрезПоследних.Документ,
		|	СостоянияДокументовВФайловомШлюзеСрезПоследних.Пакет,
		|	СостоянияДокументовВФайловомШлюзеСрезПоследних.Пакет.ОтносительныйПуть КАК ОтносительныйПуть
		|ИЗ
		|	РегистрСведений.СостоянияДокументовВФайловомШлюзе.СрезПоследних КАК СостоянияДокументовВФайловомШлюзеСрезПоследних
		|ГДЕ
		|	СостоянияДокументовВФайловомШлюзеСрезПоследних.Статус = &Статус";
		
		Выборка = Запрос.Выполнить().Выбрать();
		Пока Выборка.Следующий() Цикл
			Каталог = Новый Файл(ПутьДляЗагрузки + "\" + Выборка.ОтносительныйПуть);
			Если Каталог.Существует() И Каталог.ЭтоКаталог() Тогда
				ПакетОбъект = Выборка.Пакет.ПолучитьОбъект();
				ПакетОбъект.Статус = Перечисления.СтатусыДокументовФайловыйШлюз.ВыгруженоВебКабинет;
				ПакетОбъект.Записать();
				
				РегистрыСведений.СостоянияДокументовВФайловомШлюзе.ДобавитьЗапись(ТекущаяДатаСеанса(),
					Выборка.Документ, Перечисления.СтатусыДокументовФайловыйШлюз.ВыгруженоВебКабинет, Выборка.Пакет);
				
			КонецЕсли;
		КонецЦикла;
		
	КонецЕсли;
КонецПроцедуры
 
Процедура ОбработатьПакетыСОшибками()
	// Пакеты с ошибками
	ВнешнийИсточникФайловыйШлюзКаталогОшибок = ПланыВидовХарактеристик.ВнешниеИсточники.ФайловыйШлюзКаталогОшибок;
	ПутьДляЗагрузки = ВнешниеДанные.ПолучитьПараметрыВнешнегоИсточника(ВнешнийИсточникФайловыйШлюзКаталогОшибок).Папка;
	Если ЗначениеЗаполнено(ПутьДляЗагрузки) Тогда
		
		Запрос = Новый Запрос;
		Запрос.УстановитьПараметр("Статус", Перечисления.СтатусыДокументовФайловыйШлюз.ВыгруженоФайловыйШлюз);
		Запрос.Текст = "ВЫБРАТЬ
		               |	СостоянияДокументовВФайловомШлюзеСрезПоследних.Документ КАК Документ,
		               |	СостоянияДокументовВФайловомШлюзеСрезПоследних.Пакет КАК Пакет,
		               |	СостоянияДокументовВФайловомШлюзеСрезПоследних.Пакет.ОтносительныйПуть КАК ОтносительныйПуть
		               |ИЗ
		               |	РегистрСведений.СостоянияДокументовВФайловомШлюзе.СрезПоследних(, 1 = 1) КАК СостоянияДокументовВФайловомШлюзеСрезПоследних
		               |ГДЕ
		               |	СостоянияДокументовВФайловомШлюзеСрезПоследних.Статус = &Статус";
		
		Выборка = Запрос.Выполнить().Выбрать();
		Пока Выборка.Следующий() Цикл
			Каталог = Новый Файл(ПутьДляЗагрузки + "\" + Выборка.ОтносительныйПуть);
			Если Каталог.Существует() И Каталог.ЭтоКаталог() Тогда
				ОбработатьОдинПакетСОшибками(Выборка, ПутьДляЗагрузки);
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
КонецПроцедуры

Процедура ОбработатьОдинПакетСОшибками(Выборка, ПутьДляЗагрузки)
	ПакетОбъект = Выборка.Пакет.ПолучитьОбъект();
	ПакетОбъект.Статус = Перечисления.СтатусыДокументовФайловыйШлюз.ОшибкаФайловыйШлюз;
	ПакетОбъект.Записать();
	
	ДатаОшибки = Дата(1, 1, 1);
	ОписаниеОшибки = "";
	
	СтруктураФайла = Новый Структура;
	Попытка
		ФайлОшибки = Новый Файл(ПутьДляЗагрузки + "\" + Выборка.ОтносительныйПуть + "\" + "error.xml");
		Если ФайлОшибки.Существует() Тогда
			ПрочитатьФайлСОписаниемОшибки(ФайлОшибки, СтруктураФайла);
		КонецЕсли;
		СтруктураФайла.Свойство("time", ДатаОшибки);
		СтруктураФайла.Свойство("description", ОписаниеОшибки);
	Исключение
		
	КонецПопытки;
	
	ПериодЗаписи = ?(ЗначениеЗаполнено(ДатаОшибки), ДатаОшибки, ТекущаяДатаСеанса());
	РегистрыСведений.СостоянияДокументовВФайловомШлюзе.ДобавитьЗапись(ПериодЗаписи, Выборка.Документ,
			Перечисления.СтатусыДокументовФайловыйШлюз.ОшибкаФайловыйШлюз, Выборка.Пакет, ОписаниеОшибки);
			
	ДокументОснование = Выборка.Документ.ДокументОснование;
	Если ТипЗнч(ДокументОснование) = Тип("ДокументСсылка.Выписка") Тогда
		Документы.ТехническаяОперация.ОтправитьУведомлениеОбОшибкеДоставкиВыписки(Выборка.Документ, ОписаниеОшибки, Выборка.Пакет);
	КонецЕсли;
КонецПроцедуры

Процедура ОбработатьВыпискиЗадерживающиесяСОтправкой()
	КомментарийОЗадержкеОтправки  = "Уведомление отправлено о задержке пакета создано";
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	СостоянияДокументовВФайловомШлюзеСрезПоследних.Документ КАК Документ
	|ИЗ
	|	РегистрСведений.СостоянияДокументовВФайловомШлюзе.СрезПоследних(, Документ.ДокументОснование ССЫЛКА Документ.Выписка) КАК СостоянияДокументовВФайловомШлюзеСрезПоследних
	|ГДЕ
	|	СостоянияДокументовВФайловомШлюзеСрезПоследних.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыДокументовФайловыйШлюз.ВыгруженоФайловыйШлюз)
	|	И СостоянияДокументовВФайловомШлюзеСрезПоследних.Комментарий <> &КомментарийОЗадержкеОтправки
	|	И СостоянияДокументовВФайловомШлюзеСрезПоследних.Период МЕЖДУ &ЧасНазад И &ДеньНазад";
	ТекущаяДата = ТекущаяДатаСеанса();
	Запрос.УстановитьПараметр("ЧасНазад", ТекущаяДата - ОбщегоНазначенияПовтИсп.СекундВЧасе());
	Запрос.УстановитьПараметр("ДеньНазад", ТекущаяДата - ОбщегоНазначенияПовтИсп.СекундВСутках());
	Запрос.УстановитьПараметр("КомментарийОЗадержкеОтправки", КомментарийОЗадержкеОтправки);
	РезультатЗапроса = Запрос.Выполнить();
	Если Не РезультатЗапроса.Пустой() Тогда
		Выборка = РезультатЗапроса.Выбрать();
		ОписаниеОшибки = "Не происходит отправка пакета из шлюза. Возможно шлюз не работает";
		Пока Выборка.Следующий() Цикл
			Документы.ТехническаяОперация.ОтправитьУведомлениеОбОшибкеДоставкиВыписки(Выборка.Документ, ОписаниеОшибки, Выборка.Пакет);
			РегистрыСведений.СостоянияДокументовВФайловомШлюзе.ДобавитьЗапись(ТекущаяДата, Выборка.Документ,
						Перечисления.СтатусыДокументовФайловыйШлюз.ВыгруженоФайловыйШлюз, Выборка.Пакет, КомментарийОЗадержкеОтправки);
		КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры

Процедура ПрочитатьФайлСОписаниемОшибки(ФайлОшибки, СтруктураФайла)
	ЧтениеXML = Новый ЧтениеXML;
	ЧтениеXML.ОткрытьФайл(ФайлОшибки.ПолноеИмя);
	Пока ЧтениеXML.Прочитать() Цикл
		Пока ЧтениеXML.Прочитать() Цикл
			Если ЧтениеXML.ТипУзла = ТипУзлаXML.НачалоЭлемента Тогда
				ИмяУзла = ЧтениеXML.Имя;
			Иначе
				Если ЧтениеXML.ТипУзла = ТипУзлаXML.Текст И ИмяУзла <> "" Тогда
					СтруктураФайла.Вставить(ИмяУзла, ЧтениеXML.Значение);
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;
КонецПроцедуры

