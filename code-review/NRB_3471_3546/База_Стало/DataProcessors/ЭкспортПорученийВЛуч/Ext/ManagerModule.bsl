					ВходящийПакетОбъект.КодОперации				= ТипОтчета;
					ВходящийПакетОбъект.НомерВходящегоДокумента	= НомерОтчета;
					ВходящийПакетОбъект.ДатаВходящегоДокумента	= ДатаОтчета;
					ВходящийПакетОбъект.Обработан				= Истина;
					Если ЗначениеЗаполнено(ПутьАрхиваНаТекущуюДатуПоСистеме) Тогда
						ПутьАрхиваВОбщихКаталогах = ОбщийКаталогПеремещаемогоФайлаВАрхив(ПутьАрхиваНаТекущуюДатуПоСистеме, "Z");
						ВходящийПакетОбъект.ПутьАрхив = ПутьАрхиваВОбщихКаталогах + "\" + Каталог.Имя;
					КонецЕсли;
					ВходящийПакетОбъект.СодержимоеФайла.Загрузить(ДанныеФайлов.ВсеФайлы);
					ВходящийПакетОбъект.Записать();
					ВходящийПакетОбъект.Записать(РежимЗаписиДокумента.Проведение);
					
				Иначе
					СтатусПоручения = Справочники.ВидыИнвентарныхПоручений.СтатусПорученияПоФормеОтчета(ФормаОтчета, ТипОтчета);
					ТехническаяОперация = Документы.ТехническаяОперация.НайтиДокумент(
						Новый Структура("РегистрационныйНомер, КодОперации", РегистрационныйНомер, ТипОтчета));
					Если ЗначениеЗаполнено(ТехническаяОперация) Тогда
						НеобработанныйВходящийПакет = Документы.ВходящийПакетИзФайловогоШлюза.НайтиДокумент(
							Новый Структура("НомерВходящегоДокумента, ДатаВходящегоДокумента, Обработан", НомерОтчета, ДатаОтчета, Ложь));
						Если ЗначениеЗаполнено(НеобработанныйВходящийПакет) Тогда
							НовыйВходящийПакет = НеобработанныйВходящийПакет.ПолучитьОбъект();
						Иначе	
							НовыйВходящийПакет = Документы.ВходящийПакетИзФайловогоШлюза.СоздатьДокумент();
							НовыйВходящийПакет.Дата = ТекущаяДатаСеанса();
							НовыйВходящийПакет.Комментарий = "Создан автоматически в " + Формат(ТекущаяДатаСеанса(), "ДЛФ=DT");
							НовыйВходящийПакет.Обработан = Ложь;
							НовыйВходящийПакет.КодОперации = ТипОтчета;
							НовыйВходящийПакет.НомерВходящегоДокумента = НомерОтчета;
							НовыйВходящийПакет.ДатаВходящегоДокумента = ДатаОтчета;
							
							ВходящийПакетПоТекущемуОтчету = Документы.ВходящийПакетИзФайловогоШлюза.НайтиДокумент(
								Новый Структура("НомерВходящегоДокумента, ДатаВходящегоДокумента", НомерОтчета, ДатаОтчета));
							НовыйВходящийПакет.ПовторныйОтчет = ЗначениеЗаполнено(ВходящийПакетПоТекущемуОтчету);
						КонецЕсли;
						
						Если НовыйВходящийПакет.ПовторныйОтчет Тогда
							НовыйВходящийПакет.Обработан = Истина;
						КонецЕсли;
						
						НовыйВходящийПакет.ДокументОснование = ТехническаяОперация;
						НовыйВходящийПакет.ОтносительныйПуть = Каталог.Имя;
						НовыйВходящийПакет.ПолныйПуть = Файл.Путь;
						
						Если ЗначениеЗаполнено(ПутьАрхиваНаТекущуюДатуПоСистеме) Тогда
							НовыйВходящийПакет.ПутьАрхив = ПутьАрхиваВОбщихКаталогах + "\" + Каталог.Имя;
						КонецЕсли;
						
						Если ТипЗнч(ДанныеФайлов.КоличествоИсполненноеВНРД) = Тип("Число") Тогда
							ИсполненноеКоличествоЦБ = ДанныеФайлов.КоличествоИсполненноеВНРД;
						Иначе
							ИсполненноеКоличествоЦБ = 0;
							ЗаписьЖурналаРегистрации(ИмяСобытияЖР_ЗагрузкаОтчетовПоПоручению, УровеньЖурналаРегистрации.Ошибка,
								Метаданные.Обработки.ЭкспортПорученийВЛуч, НовыйВходящийПакет.Ссылка,
								"КоличествоИсполненноеВНРД не удалось привести к числу");
						КонецЕсли;
						НовыйВходящийПакет.СодержимоеФайла.Загрузить(ДанныеФайлов.ВсеФайлы);
						
						СтатусПоручения = СкорректированныйСтатусПоручения(ТехническаяОперация, СтатусПоручения,
							?(НовыйВходящийПакет.ПовторныйОтчет, 0, ИсполненноеКоличествоЦБ));
						НовыйВходящийПакет.Статус = СтатусПоручения;
						
						Попытка
							НовыйВходящийПакет.Записать();
						Исключение
							ПомещатьВАрхив = Ложь;
							Продолжить;
						КонецПопытки;
						
						Попытка
							НовыйВходящийПакет.Записать(РежимЗаписиДокумента.Проведение);
						Исключение
							Продолжить;
						КонецПопытки;
						
						Если НовыйВходящийПакет.Статус = Перечисления.СтатусыДокументовФайловыйШлюз.НеИсполнено
