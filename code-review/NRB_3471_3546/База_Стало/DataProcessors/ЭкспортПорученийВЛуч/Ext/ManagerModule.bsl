// Читает DBF-файлы из указанного каталога в таблицу значений.
//
// Параметры:
//  КаталогФайлов	 - Строка
// 
// Возвращаемое значение:
//   ТаблицаЗначений
//
Функция ВсеФайлыDBF(КаталогФайлов)
	
	Данные = Новый ТаблицаЗначений;
	Данные.Колонки.Добавить("ИмяФайла");
	Данные.Колонки.Добавить("НомерСтрокиФайла");
	Данные.Колонки.Добавить("Элемент");
	Данные.Колонки.Добавить("Тип");
	Данные.Колонки.Добавить("Длина");
	Данные.Колонки.Добавить("Значение");
	
	МассивФайлов = НайтиФайлы(КаталогФайлов, "*.dbf", Истина);
	Для каждого Файл Из МассивФайлов Цикл
		Если СтрДлина(Файл.ИмяБезРасширения) > 8 Тогда
			ПолноеИмяФайла = Файл.Путь + Лев(Файл.ИмяБезРасширения, 8) + Файл.Расширение;
			ПереместитьФайл(Файл.ПолноеИмя, ПолноеИмяФайла);
		Иначе
			ПолноеИмяФайла = Файл.ПолноеИмя;
		КонецЕсли;
		
		База_XBase = Новый XBase;
		База_XBase.ОткрытьФайл(ПолноеИмяФайла, , Истина);
		База_XBase.Кодировка = КодировкаXBase.OEM;
		
		Если База_XBase.Открыта() Тогда
			
			Для НомерСтроки = 1 По База_XBase.КоличествоЗаписей() Цикл
				База_XBase.Перейти(НомерСтроки);
				Для каждого Поле Из База_XBase.Поля Цикл
					НоваяСтрока = Данные.Добавить();
					НоваяСтрока.ИмяФайла = Файл.Имя;
					НоваяСтрока.НомерСтрокиФайла = НомерСтроки;
					НоваяСтрока.Элемент = Поле.Имя;
					НоваяСтрока.Тип = Поле.Тип;
					НоваяСтрока.Длина = Поле.Длина;
					ЗначениеПоля = База_XBase[Поле.Имя];
					Если Поле.Тип = "S" Тогда
						НоваяСтрока.Значение = СтроковыеФункцииКлиентСервер.ИзменитьКодировкуСтроки(
							ЗначениеПоля, КодировкаТекста.OEM);
					Иначе
						НоваяСтрока.Значение = ЗначениеПоля;
					КонецЕсли;
				КонецЦикла;
			КонецЦикла;
			База_XBase.ЗакрытьФайл();
		КонецЕсли;
	КонецЦикла;
	Возврат Данные;
	
КонецФункции

Функция ДатаВремя(Дата, ВремяСтрокой)
	
	Результат = Дата;
	ОбщегоНазначения.СкопироватьВремя(Результат, СтроковыеФункцииКлиентСерверПереопределяемый.ВремяИзСтроки(ВремяСтрокой));
	Возврат Результат;
	
КонецФункции

Функция КоличествоИсполненияПоТехОперации(ТехническаяОперация)
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ЕСТЬNULL(СУММА(ЗапросКоличества.КоличествоИсполнения), 0) КАК КоличествоИсполнения
	|ИЗ
	|	(ВЫБРАТЬ
	|		СостоянияДокументовВФайловомШлюзе.КоличествоИсполнения КАК КоличествоИсполнения
	|	ИЗ
	|		РегистрСведений.СостоянияДокументовВФайловомШлюзе КАК СостоянияДокументовВФайловомШлюзе
	|	ГДЕ
	|		СостоянияДокументовВФайловомШлюзе.Документ = &ТехническаяОперация) КАК ЗапросКоличества";
	Запрос.УстановитьПараметр("ТехническаяОперация", ТехническаяОперация);
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.КоличествоИсполнения;
	Иначе
		Возврат 0;
	КонецЕсли;
	
КонецФункции

// Ищет первую строку таблицы ВсеФайлы, содержащую количество, и возвращает его.
//
// Параметры:
//  ВсеФайлы	- ТаблицаЗначений:
//    * ИмяФайла	- Строка
//    * Элемент		- Строка
//    * Тип			- Строка
//    * Значение	- Строка, Число
//  ИмяФайла	 - Строка	 - Имя файла, в записях которого нужно найти данные по количеству
// 
// Возвращаемое значение:
//  Число - количество, исполненное в НРД. 0, если искомых строк не найдено.
//
Функция КоличествоИсполненноеВНРД_DBF(ВсеФайлы, ИмяФайла)
	
	Отбор = Новый Структура("ИмяФайла, Элемент", ИмяФайла, "SEQ_AMO");
	НайденныеСтроки = ВсеФайлы.НайтиСтроки(Отбор);
	Количество = 0;
	Если НайденныеСтроки.Количество() > 0 Тогда
		Если НайденныеСтроки[0].Тип = "S" Тогда
			Данные = СтрЗаменить(НайденныеСтроки[0].Значение, " ", "");
			Если Данные = "" Тогда
				Данные = "0";
			КонецЕсли;
			Количество = СтроковыеФункцииКлиентСервер.ЧислоИзСтроки(Данные);
		ИначеЕсли НайденныеСтроки[0].Тип = "N" Тогда
			Количество = НайденныеСтроки[0].Значение;
		КонецЕсли;
	КонецЕсли;
	Возврат Количество;
	
КонецФункции

Функция СкорректированныйСтатусПоручения(ТехническаяОперация, СтатусПоручения, КоличествоИсполнения)
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ИСТИНА
	|ИЗ
	|	Документ.ТехническаяОперация КАК ТехническаяОперация
	|ГДЕ
	|	ТехническаяОперация.Ссылка = &ТехническаяОперация
	|	И ТехническаяОперация.ДокументОснование ССЫЛКА Документ.НеттоПоручение
	|	И ТехническаяОперация.ДокументОснование <> ЗНАЧЕНИЕ(Документ.НеттоПоручение.ПустаяСсылка)
	|	И &ДатаВвода <> ДАТАВРЕМЯ(1, 1, 1)
	|	И ТехническаяОперация.ДокументОснование.Дата >= &ДатаВвода
	|	И ТехническаяОперация.ДокументОснование.Количество > &ИтогоКоличествоИсполнения
	|	И &СтатусПоручения = &Исполнено
	|";
	Запрос.УстановитьПараметр("ТехническаяОперация", ТехническаяОперация);
	Запрос.УстановитьПараметр("ДатаВвода", Константы.ДатаВводаЧастичногоИсполненияИнвентарныхПоручений.Получить());
	ИтогоКоличествоИсполнения = КоличествоИсполненияПоТехОперации(ТехническаяОперация) + КоличествоИсполнения;
	Запрос.УстановитьПараметр("ИтогоКоличествоИсполнения", ИтогоКоличествоИсполнения);
	Запрос.УстановитьПараметр("СтатусПоручения", СтатусПоручения);
	Запрос.УстановитьПараметр("Исполнено", Перечисления.СтатусыДокументовФайловыйШлюз.Исполнено);
	Результат = Запрос.Выполнить();
	Если Результат.Пустой() Тогда
		Возврат СтатусПоручения;
	Иначе
		Возврат Перечисления.СтатусыДокументовФайловыйШлюз.ИсполненоЧастично;
	КонецЕсли;
	
КонецФункции

Функция ОбщийКаталогПеремещаемогоФайлаВАрхив(КаталогАрхива, ВидОтчета = "")
		
	Если Не ЗначениеЗаполнено(ВидОтчета) Тогда
		
		//1. каталоги даты  (Год\Месяц\День)
		ТекущаяДата 	= ТекущаяДатаСеанса();
		
		ТекущийГод 		= Формат(Год(ТекущаяДата),		"ЧГ=0");
		ТекущийМесяц 	= Формат(Месяц(ТекущаяДата),	"ЧЦ=2; ЧВН=; ЧГ=0");
		ТекущийДень 	= Формат(День(ТекущаяДата),		"ЧЦ=2; ЧВН=; ЧГ=0");
		
		ТекущийКаталогПоДате = ТекущийГод + "\" + ТекущийМесяц + "\" + ТекущийДень;
		ПроверитьНаличиеКаталоговВСтруктуре(КаталогАрхива, ТекущийКаталогПоДате);
		ТекущийКаталогАрхиваНаДату = КаталогАрхива + "\" + ТекущийКаталогПоДате; 
		
		//2. Система = Депо
		ТекущийКаталогПоСистеме = "Депо";
		ПроверитьНаличиеКаталоговВСтруктуре(ТекущийКаталогАрхиваНаДату, ТекущийКаталогПоСистеме);
		ТекущийКаталогАрхиваНаДатуПоСистеме = ТекущийКаталогАрхиваНаДату + "\" + ТекущийКаталогПоСистеме;
		
		Возврат ТекущийКаталогАрхиваНаДатуПоСистеме;		
				
	Иначе
		
		//3. Вид отчета 		
		ТекущийКаталогПоВидуОтчета = ВидОтчета;
		ПроверитьНаличиеКаталоговВСтруктуре(КаталогАрхива, ТекущийКаталогПоВидуОтчета);
		ТекущийКаталогАрхиваНаДатуПоСистемеПоВидуОтчета = КаталогАрхива + "\" + ТекущийКаталогПоВидуОтчета;
		
		Возврат ТекущийКаталогАрхиваНаДатуПоСистемеПоВидуОтчета;		
			
	КонецЕсли;	
	
КонецФункции

Процедура ПроверитьНаличиеКаталоговВСтруктуре(ИмяКорневогоКаталога, ИмяТекущегоКаталога)
	
	ТекущийКаталогНайден = Ложь;
	
	ФайлыКаталога = НайтиФайлы(ИмяКорневогоКаталога, ИмяТекущегоКаталога);
	
	Для Каждого НайденныйФайл Из ФайлыКаталога Цикл
		Если НайденныйФайл.ЭтоКаталог() Тогда
			ТекущийКаталогНайден = Истина;
			Прервать;
		КонецЕсли;		
	КонецЦикла;
	
	Если ТекущийКаталогНайден Тогда
	Иначе
		СоздатьКаталог(ИмяКорневогоКаталога + "\" + ИмяТекущегоКаталога);
	КонецЕсли;
	
КонецПроцедуры

Функция ЗначениеЭлементаИзДанныхФайлов(ВсеФайлы, Элемент, ИмяФайла = Неопределено, НомерСтрокиФайла = Неопределено) Экспорт
	
	Значение = Неопределено;
	
	Отбор = Новый Структура("Элемент", Элемент);
	Если ЗначениеЗаполнено(ИмяФайла) Тогда
		Отбор.Вставить("ИмяФайла", ИмяФайла);
	КонецЕсли;
	Если ЗначениеЗаполнено(НомерСтрокиФайла) Тогда
		Отбор.Вставить("НомерСтрокиФайла", НомерСтрокиФайла);
	КонецЕсли;
	
	НайденныеСтроки = ВсеФайлы.НайтиСтроки(Отбор);
	Если НайденныеСтроки.Количество() > 0 Тогда
		Значение = НайденныеСтроки[0].Значение;
		Значение = ?(ТипЗнч(Значение) = Тип("Строка"), СокрЛП(Значение), Значение);
	КонецЕсли;
	
	Возврат Значение;
	
КонецФункции

Функция БлокировкаЦБПоОтчетуСуществует(НомерОтчета, ДатаОтчета, ТехническаяОперация)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ИСТИНА КАК ДокументБлокировкиЦБСуществует
	|ИЗ
	|	Документ.ВходящийПакетИзФайловогоШлюза КАК ВходящийПакетИзФайловогоШлюза
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.БлокировкаЦБвВышестоящемДепозитарии КАК БлокировкаЦБвВышестоящемДепозитарии
	|		ПО ВходящийПакетИзФайловогоШлюза.Ссылка = БлокировкаЦБвВышестоящемДепозитарии.ДокументОснование
	|			И (НЕ ВходящийПакетИзФайловогоШлюза.ПометкаУдаления)
	|ГДЕ
	|	ВходящийПакетИзФайловогоШлюза.ДокументОснование = &ДокументОснование
	|	И ВходящийПакетИзФайловогоШлюза.НомерВходящегоДокумента = &НомерВходящегоДокумента
	|	И ВходящийПакетИзФайловогоШлюза.ДатаВходящегоДокумента = &ДатаВходящегоДокумента";
	
	Запрос.УстановитьПараметр("НомерВходящегоДокумента", НомерОтчета);
	Запрос.УстановитьПараметр("ДатаВходящегоДокумента", ДатаОтчета);
	Запрос.УстановитьПараметр("ДокументОснование", ТехническаяОперация);
	РезультатЗапроса = Запрос.Выполнить();
	
	Возврат Не РезультатЗапроса.Пустой();
	
КонецФункции

Функция ИсходноеПоручениеТехническойОперации(ТехническаяОперация)
	
	Поручение = Документы.Поручение.ПустаяСсылка();
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	ВЫБОР
	|		КОГДА ТехническаяОперация.ДокументОснование ССЫЛКА Документ.Поручение
	|			ТОГДА ТехническаяОперация.ДокументОснование
	|		КОГДА ТехническаяОперация.ДокументОснование ССЫЛКА Документ.НеттоПоручение
	|			ТОГДА НеттоПоручениеПоручения.Поручение
	|	КОНЕЦ КАК Поручение
	|ИЗ
	|	Документ.ТехническаяОперация КАК ТехническаяОперация
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.НеттоПоручение.Поручения КАК НеттоПоручениеПоручения
	|		ПО ТехническаяОперация.ДокументОснование = НеттоПоручениеПоручения.Ссылка
	|			И (НеттоПоручениеПоручения.Поручение.ВидОперацииД = &СнятиеСДепонирования)
	|ГДЕ
	|	ТехническаяОперация.Ссылка = &ТехническаяОперация";
	
	Запрос.УстановитьПараметр("ТехническаяОперация", ТехническаяОперация);
	Запрос.УстановитьПараметр("СнятиеСДепонирования", Справочники.ВидыОпераций.СнятиеСДепонирования);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда 
		Поручение = Выборка.Поручение;
	КонецЕсли;
	
	Возврат Поручение;
	
КонецФункции

Процедура ОбработатьБлокировкуЦБ(ВходящийПакет, ДатаПереходаНаНовыйМеханизмБлокировокЦБ, ДанныеФайлов) Экспорт
	
	ТехническаяОперация = ВходящийПакет.ДокументОснование;
	НомерОтчета = ВходящийПакет.НомерВходящегоДокумента;
	ДатаОтчета = ВходящийПакет.ДатаВходящегоДокумента;
	
	ЭтоОтчетПоОперацииСнятияЦБсДепонирования = ДанныеФайлов.ТипОтчета = "36" Или ДанныеФайлов.ТипОтчета = "36/2";
	
	Если Не ЭтоОтчетПоОперацииСнятияЦБсДепонирования Тогда
		Возврат;
	КонецЕсли;
	
	Поручение = ИсходноеПоручениеТехническойОперации(ТехническаяОперация);
		
	Если Не ЗначениеЗаполнено(Поручение) Тогда
		ТекстОшибки = "Не удалось найти исходное поручение по документу: " + Строка(ТехническаяОперация);
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстОшибки);
		ЗаписьЖурналаРегистрации("Загрузка отчетов по поручению (Z)", УровеньЖурналаРегистрации.Ошибка,
				Метаданные.Обработки.ЭкспортПорученийВЛуч, ВходящийПакет.Ссылка, ТекстОшибки);
		Возврат;
	КонецЕсли;
	
	РеквизитыПоручения = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Поручение,
		"Дата, ДатаИсполненияПоручения, ЦБ, СчетДепо, МХКонтрагент, МХДепонента, СчетДепоМХ, РазделСчетаДепоМХ");
		
	Если РеквизитыПоручения.Дата < ДатаПереходаНаНовыйМеханизмБлокировокЦБ
		Или БлокировкаЦБПоОтчетуСуществует(НомерОтчета, ДатаОтчета, ТехническаяОперация) Тогда
		Возврат;
	КонецЕсли;
	
	КодБлокировочногоРаздела = "27000000000000000";
	ЭтоБлокированиеЦБ = ДанныеФайлов.ФормаОтчета = "MS020" И ДанныеФайлов.РазделМХЗачисления = КодБлокировочногоРаздела;
	ЭтоРазблокированиеЦБ = ДанныеФайлов.ФормаОтчета = "MS020" И ДанныеФайлов.РазделМХСписания = КодБлокировочногоРаздела
		Или ДанныеФайлов.ФормаОтчета = "MS036" И ДанныеФайлов.РазделМХБлокировка = КодБлокировочногоРаздела;
	Если ЭтоБлокированиеЦБ Тогда
		
		ВидОперацииБлокировки = Перечисления.ВидыОперацийЦБ.Блокирование;
		
	ИначеЕсли ЭтоРазблокированиеЦБ Тогда
		
		ВидОперацииБлокировки = Перечисления.ВидыОперацийЦБ.Разблокирование;
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ВидОперацииБлокировки) И ЗначениеЗаполнено(ДанныеФайлов.БлокировкаКоличествоЦБ) Тогда
		СформироватьДокументБлокировкиЦБ(ВходящийПакет, ВидОперацииБлокировки, РеквизитыПоручения,
			ДанныеФайлов.БлокировкаКоличествоЦБ);
	КонецЕсли;
	
КонецПроцедуры

Процедура СформироватьДокументБлокировкиЦБ(ВходящийПакет, ВидОперацииБлокировки, РеквизитыПоручения, КоличествоЦБ)
	
	БлокировочныйРазделСчета = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(РеквизитыПоручения.СчетДепоМХ,
		"БлокировочныйРазделСчета");
	
	БлокировкаЦБОбъект = Документы.БлокировкаЦБвВышестоящемДепозитарии.СоздатьДокумент();
	БлокировкаЦБОбъект.Дата = ВходящийПакет.ДатаВходящегоДокумента;
	БлокировкаЦБОбъект.ДокументОснование = ВходящийПакет.Ссылка;
	БлокировкаЦБОбъект.ВидОперации = ВидОперацииБлокировки;
	БлокировкаЦБОбъект.ЦеннаяБумага = РеквизитыПоручения.ЦБ;
	БлокировкаЦБОбъект.СчетДепо = РеквизитыПоручения.СчетДепо;
	БлокировкаЦБОбъект.МестоХранения = РеквизитыПоручения.МХДепонента;
	БлокировкаЦБОбъект.СчетДепоМХ = РеквизитыПоручения.СчетДепоМХ;
	БлокировкаЦБОбъект.РазделСчетаДепоМХ = РеквизитыПоручения.РазделСчетаДепоМХ;
	БлокировкаЦБОбъект.БлокировочныйРазделСчетаДепоМХ = БлокировочныйРазделСчета;
	БлокировкаЦБОбъект.Количество = КоличествоЦБ;
	БлокировкаЦБОбъект.ДополнительныеСвойства.Вставить("МХКонтрагент", РеквизитыПоручения.МХКонтрагент);
	БлокировкаЦБОбъект.Записать(РежимЗаписиДокумента.Проведение);
	
КонецПроцедуры

Функция ПоследнийЗаполненныйСтатусТехническойОперации(ТехническаяОперация)
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	СостоянияДокументовВФайловомШлюзеСрезПоследних.Статус КАК Статус
	|ИЗ
	|	РегистрСведений.СостоянияДокументовВФайловомШлюзе.СрезПоследних(&ТекущаяДатаСеанса, Документ = &ТехническаяОперация) КАК СостоянияДокументовВФайловомШлюзеСрезПоследних
	|ГДЕ
	|	СостоянияДокументовВФайловомШлюзеСрезПоследних.Статус <> ЗНАЧЕНИЕ(Перечисление.СтатусыДокументовФайловыйШлюз.ПустаяСсылка)";
	Запрос.УстановитьПараметр("ТехническаяОперация", ТехническаяОперация);
	Запрос.УстановитьПараметр("ТекущаяДатаСеанса", ТекущаяДатаСеанса());
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Статус;
	Иначе
		Возврат Неопределено;
	КонецЕсли;
КонецФункции

Функция ТребуетсяСоздатьПоручениеНаОтмену(ВсеФайлы)
	
	Отбор = Новый Структура("Элемент", "ABORT_CAUS");
	НайденныеСтроки = ВсеФайлы.НайтиСтроки(Отбор);
	Если НайденныеСтроки.Количество() > 0 И Лев(НайденныеСтроки[0].Значение, 32) = "Истек срок исполнения поручения." Тогда
		Возврат Истина;
	Иначе
		Возврат Ложь;
	КонецЕсли;

	
КонецФункции

Процедура СоздатьОтменуПоручения(Поручение, НомерОтчета, ДатаОтчета)
	
	ПоручениеОтмены = Документы.Поручение.СоздатьДокумент();
	ПоручениеОтмены.ВидОперацииД = Справочники.ВидыОпераций.ОтменаПоручения;
	ПоручениеОтмены.ОтменяемоеПоручение = Поручение;
	ПоручениеОтмены.ВидИнициатора = 0;
	ПоручениеОтмены.КодОтчетаНРД = НомерОтчета;
	ПоручениеОтмены.Инициатор = ОбщегоНазначенияПовтИсп.ЗначениеКонстанты("ОрганизацияПоУмолчанию");
	ПоручениеОтмены.КодОтмены = Справочники.КодыОтменыПоручений.НайтиПоКоду("14");
	ПоручениеОтмены.ПричинаОтмены = ПоручениеОтмены.КодОтмены.Наименование;
	ПоручениеОтмены.Дата = ДатаОтчета;
	ПоручениеОтмены.ДатаИсполненияПоручения = ДатаОтчета + 60;
	ПоручениеОтмены.Записать(РежимЗаписиДокумента.Проведение);
	
КонецПроцедуры

Функция РезультатЗаполненияПоручения(Знач Поручение, РегистрационныйНомер, ДатаИсполнения, ДатаИсполненияВМестеРасчетов, КодОтчета, Комментарий)
	
	Документ = Поручение.ПолучитьОбъект();
	Если ТипЗнч(Поручение) = Тип("ДокументСсылка.Поручение") Тогда
		Документ.ДатаИсполненияПоручения = ДатаИсполнения;
		ВидОперацииД = Документ.ВидОперацииД;
		Если ЗначениеЗаполнено(ВидОперацииД) И ТипЗнч(ВидОперацииД) = Тип("СправочникСсылка.ВидыОпераций") И ВидОперацииД.ДвижениеПоЦБ Тогда
			Документ.ДатаИсполненияПорученияВДепозитарииМХ = ДатаИсполнения;
			Документ.ДатаИсполненияПорученияВМестеРасчетов = ДатаИсполненияВМестеРасчетов;
		КонецЕсли;
		Документ.КодОтчетаНРД = КодОтчета;
	ИначеЕсли ТипЗнч(Поручение) = Тип("ДокументСсылка.РаскрытиеСпискаВладельцев") Тогда
		Документ.ДатаИсполнения = ДатаИсполнения;
		Документ.REPORT_ID = КодОтчета;
	Иначе
		// Поручение в вышестоящий депозитарий
		Если ПустаяСтрока(Документ.РегистрационныйНомер) Тогда
			Документ.РегистрационныйНомер = РегистрационныйНомер;
		КонецЕсли;
		Документ.ДатаИсполнения = ДатаИсполнения;
		Документ.КодОтчетаВышестоящегоДепозитария = КодОтчета;
		Документ.ДополнительныеСвойства.Вставить("Комментарий", Комментарий);
	КонецЕсли;
	Документ.Комментарий = Документ.Комментарий + ?(ЗначениеЗаполнено(Документ.Комментарий), " | ", "") + Комментарий;
	Попытка
		Документ.Записать(РежимЗаписиДокумента.Проведение);
		Возврат "";
	Исключение
		Возврат "Не удалось провести " + Документ + " " + Символы.ПС + КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
	КонецПопытки;
	
КонецФункции

Функция РезультатЗаполненияДанныхДепонента(Поручение, КодЗагрузкиДепонентаНДЦ, НаименованиеДепонентаВНРД)
	Депонент = Справочники.Контрагенты.ПустаяСсылка();
	
	Если ТипЗнч(Поручение) = Тип("ДокументСсылка.Поручение")
		И ЗначениеЗаполнено(Поручение.ДокументОснование)
		И ТипЗнч(Поручение.ДокументОснование) = Тип("ДокументСсылка.Поручение")
		И Поручение.ДокументОснование.ВидОперацииД = Справочники.ВидыОпераций.ОткрытиеРазделаСчетаДепо
		И ЗначениеЗаполнено(Поручение.ДокументОснование.Депонент)
		И ТипЗнч(Поручение.ДокументОснование.Депонент) = Тип("СправочникСсылка.Контрагенты") Тогда

		Депонент = Поручение.ДокументОснование.Депонент;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Депонент) И ЗначениеЗаполнено(КодЗагрузкиДепонентаНДЦ)
		И ЗначениеЗаполнено(НаименованиеДепонентаВНРД) Тогда
		
		НДЦ = Константы.КлассификаторЗагрузкиНДЦ.Получить();
		Если НДЦ.Пустая() Тогда
			Возврат "Не заполнена константа ""Классификатор загрузки НДЦ""!";
		КонецЕсли;
				
		Если Депонент.Субброкер Тогда
			
			Субклиент = Поручение.ДокументОснование.Субклиент;
			Если Не ЗначениеЗаполнено(Субклиент) Тогда
				Возврат "В поручении № " + СокрЛП(Поручение.ДокументОснование.Номер) + " не заполнен Субклиент";
			КонецЕсли;

			СубклиентОбъект = Субклиент.ПолучитьОбъект();
			СубклиентОбъект.НаименованиеБенефициара = НаименованиеДепонентаВНРД;
			СубклиентОбъект.КодНРД = КодЗагрузкиДепонентаНДЦ;
			
			НачатьТранзакцию();
			Попытка
				СубклиентОбъект.Записать();
				ЗафиксироватьТранзакцию();
			Исключение
				ОтменитьТранзакцию();
				Возврат "Не удалось записать Субклиента " + СубклиентОбъект + " " + Символы.ПС
				+ КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
			КонецПопытки;
			
		Иначе
			
			ДепонентОбъект = Депонент.ПолучитьОбъект();
			ДепонентОбъект.НаименованиеБенефициараВНРД = НаименованиеДепонентаВНРД;
			НачатьТранзакцию();
			Попытка
				ДепонентОбъект.Записать();
				ЗафиксироватьТранзакцию();
			Исключение
				ОтменитьТранзакцию();
				Возврат "Не удалось записать депонента " + ДепонентОбъект + " " + Символы.ПС
				+ КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
			КонецПопытки;
			
			КодЗагрузки = Справочники.КодыЗагрузки.НайтиПоВладельцуИБирже(Депонент, НДЦ);
			Если ЗначениеЗаполнено(КодЗагрузки) Тогда
				КодЗагрузкиОбъект = КодЗагрузки.ПолучитьОбъект();
			Иначе
				КодЗагрузкиОбъект = Справочники.КодыЗагрузки.СоздатьЭлемент();
				КодЗагрузкиОбъект.Владелец	= Депонент;
				КодЗагрузкиОбъект.Биржа		= НДЦ;
				КодЗагрузкиОбъект.ДополнительныеСвойства.Вставить("КомментарийДляИсторииДанных", "ЭкспортПорученийВДКУ");
			КонецЕсли;		
			КодЗагрузкиОбъект.Код = КодЗагрузкиДепонентаНДЦ;
			
			НачатьТранзакцию();	
			Попытка
				КодЗагрузкиОбъект.Записать();
				ЗафиксироватьТранзакцию();
			Исключение
				ОтменитьТранзакцию();
				Возврат "Не удалось записать код загрузки " + КодЗагрузкиОбъект + " " + Символы.ПС
				+ КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
			КонецПопытки;
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат "";
КонецФункции

Функция ВыборкаТехническаяОперацияПоНомеруИДате(Номер, Дата)
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Номер", Номер);
	Запрос.УстановитьПараметр("Дата", Дата);
	Запрос.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
	|	ТехническаяОперация.Ссылка КАК Документ,
	|	ТехническаяОперация.ДокументОснование КАК ДокументОснование
	|ИЗ
	|	Документ.ТехническаяОперация КАК ТехническаяОперация
	|ГДЕ
	|	ТехническаяОперация.Проведен
	|	И ТехническаяОперация.Номер = &Номер
	|	И НАЧАЛОПЕРИОДА(ТехническаяОперация.Дата, ДЕНЬ) = НАЧАЛОПЕРИОДА(&Дата, ДЕНЬ)";
	Выборка = Запрос.Выполнить().Выбрать();
	Возврат Выборка;
КонецФункции

Процедура ПроверитьИЗаписатьОшибкуЗагрузкиПоРСВ(ДокументОснование, ОписаниеОшибки)
	ЭтоОшибкаПоРСВ = ЗначениеЗаполнено(ОписаниеОшибки)
		И ТипЗнч(ДокументОснование) = Тип("ДокументСсылка.РаскрытиеСпискаВладельцев")
		И ЗначениеЗаполнено(ДокументОснование);
		
	Если Не ЭтоОшибкаПоРСВ Тогда
		Возврат;
	КонецЕсли;
	
	ДокументРаскрытияОбъект = ДокументОснование.ПолучитьОбъект();
	ДокументРаскрытияОбъект.Статус = Перечисления.СтатусыРаскрытияСписковВладельцев.Ошибка;
	Если СтрНайти(ДокументРаскрытияОбъект.Комментарий, ОписаниеОшибки) = 0 Тогда
		ДокументРаскрытияОбъект.Комментарий = ДокументРаскрытияОбъект.Комментарий
			+ ?(ЗначениеЗаполнено(ДокументРаскрытияОбъект.Комментарий), Символы.ПС, "") + ОписаниеОшибки;
	КонецЕсли;
	ДокументРаскрытияОбъект.Записать();
КонецПроцедуры

Процедура ОбработатьMeetingInstructionStatus(ЧтениеXML, ПутьАрхив)
	
	СодержимоеФайла = СодержимоеФайлаПоMeetingInstructionStatus(ЧтениеXML);
	
	НомерДокумента = СодержимоеФайла["AppHdr.Rltd.BizMsgIdr"];
	ДатаДокументаСтрока = СодержимоеФайла["AppHdr.Rltd.CreDt"];
	ОписаниеОшибки_GblInstrSts = СодержимоеФайла["Document.MtgInstrSts.InstrTpSts.InstrSts.GblInstrSts.RjctnSts.AddtlInf"];
	ОписаниеОшибки_DtldInstrSts = СодержимоеФайла["Document.MtgInstrSts.InstrTpSts.InstrSts.DtldInstrSts.InstrSts.RjctnSts.AddtlInf"];
	ОписаниеОшибки = "" + ОписаниеОшибки_GblInstrSts + ?(ЗначениеЗаполнено(ОписаниеОшибки_GblInstrSts)
		И ЗначениеЗаполнено(ОписаниеОшибки_DtldInstrSts), Символы.ПС, "") + ОписаниеОшибки_DtldInstrSts;
	
	Если ЗначениеЗаполнено(ОписаниеОшибки) И ЗначениеЗаполнено(НомерДокумента) И ЗначениеЗаполнено(ДатаДокументаСтрока) Тогда
		ДатаДокумента = СтроковыеФункцииКлиентСерверПереопределяемый.ДатаВремяИзСтроки(ДатаДокументаСтрока);
		ДатаДокумента = ДатаДокумента + СмещениеСтандартногоВремени(ЧасовойПояс());
		Выборка = ВыборкаТехническаяОперацияПоНомеруИДате(НомерДокумента, ДатаДокумента);
		Если Выборка.Следующий() Тогда	// По входящему пакету из файлового шлюза сопоставлен документ ""Техническая операция"
			ВходящийПакет = Документы.ВходящийПакетИзФайловогоШлюза.СоздатьДокумент();
			ВходящийПакет.ДокументОснование = Выборка.Документ;
			ВходящийПакет.Дата = ТекущаяДатаСеанса();
			Для Каждого Элемент Из СодержимоеФайла Цикл
				ПолныйПутьТега = СтрЗаменить(Элемент.Ключ, "_", ".");
				НоваяСтрока = ВходящийПакет.СодержимоеФайла.Добавить();
				НоваяСтрока.Элемент = ПолныйПутьТега;
				НоваяСтрока.Значение = Элемент.Значение;
			КонецЦикла;
			ВходящийПакет.СодержимоеФайла.Сортировать("Элемент");
			ВходящийПакет.ПутьАрхив = ПутьАрхив;
			ВходящийПакет.Записать();
			ПроверитьИЗаписатьОшибкуЗагрузкиПоРСВ(Выборка.ДокументОснование, ОписаниеОшибки);
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

Функция СодержимоеФайлаПоMeetingInstructionStatus(ЧтениеXML)
	ИмяУзла = "";
	ПолноеИмяУзла = "";
	СодержимоеФайла = Новый Соответствие;
	Пока ЧтениеXML.Прочитать() Цикл
		Если ЧтениеXML.ТипУзла = ТипУзлаXML.НачалоЭлемента Тогда
			ИмяУзла = ЧтениеXML.Имя;
			ПолноеИмяУзла = ПолноеИмяУзла + ?(ЗначениеЗаполнено(ПолноеИмяУзла), ".", "") + ИмяУзла;
		ИначеЕсли ЧтениеXML.ТипУзла = ТипУзлаXML.КонецЭлемента Тогда
			ПозицияНачалаУзлаВПолномПути = СтрНайти(ПолноеИмяУзла, "." + ЧтениеXML.Имя, НаправлениеПоиска.СКонца);
			ПолноеИмяУзла = Лев(ПолноеИмяУзла, ПозицияНачалаУзлаВПолномПути - 1);
		ИначеЕсли ЧтениеXML.ТипУзла = ТипУзлаXML.Текст И ИмяУзла <> "" Тогда
			СодержимоеФайла.Вставить(ПолноеИмяУзла, ЧтениеXML.Значение);
		Иначе
			Продолжить;
		КонецЕсли;
	КонецЦикла;
	Возврат СодержимоеФайла;
КонецФункции

Функция ТекстСообщенияXML(ЭтоТранзит, ТекстСообщенияВходящий, Номер,
	ДокументОснование, НоваяТехническаяОперация, ИмяКаталогДляФайла, ИмяФайлаXML)
	
	Если ЭтоТранзит Тогда
		ТекстСообщения = Документы.РаскрытиеСпискаВладельцев.ТекстСообщенияТранзитаWINF(ДокументОснование,
			НоваяТехническаяОперация, ИмяКаталогДляФайла, ИмяФайлаXML);
	Иначе
		Если ЗначениеЗаполнено(ДокументОснование) И СтрНайти(ТекстСообщенияВходящий, СокрЛП(ДокументОснование.Номер)) > 0 Тогда
			ТекстСообщения = СтрЗаменить(ТекстСообщенияВходящий, СокрЛП(ДокументОснование.Номер), НоваяТехническаяОперация.Номер);
		ИначеЕсли СтрНайти(ТекстСообщенияВходящий, СокрЛП(Номер)) > 0 Тогда
			ТекстСообщения = СтрЗаменить(ТекстСообщенияВходящий, Номер, НоваяТехническаяОперация.Номер);
		Иначе
			ТекстСообщения = ТекстСообщенияВходящий;
		КонецЕсли;
	КонецЕсли;
	
	Возврат ТекстСообщения;
	
КонецФункции
