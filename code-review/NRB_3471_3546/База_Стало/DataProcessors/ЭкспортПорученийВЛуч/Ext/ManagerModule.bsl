	ИменаУзлов.Вставить("РазделМХЗачисления", СтрШаблон(ШаблонРазделМХЗачисления, ИмяОсновногоУзла));
	ИменаУзлов.Вставить("РазделМХСписания", СтрШаблон(ШаблонРазделМХСписания, ИмяОсновногоУзла));
	ИменаУзлов.Вставить("РазделМХБлокировка", СтрШаблон(ШаблонРазделМХБлокировка, ИмяОсновногоУзла, ФормаОтчета));
	ИменаУзлов.Вставить("ДатаИсполненияВМестеРасчетов", СтрШаблон(ШаблонДатаИсполненияВМестеРасчетов, ИмяОсновногоУзла));
	ИменаУзлов.Вставить("СообщениеОтНРД", СтрШаблон(ШаблонСообщениеОтНРД, ИмяОсновногоУзла));
	ИменаУзлов.Вставить("КоличествоВНРД1", СтрШаблон(ШаблонКоличествоВНРД1, ИмяОсновногоУзла));
	ИменаУзлов.Вставить("КоличествоВНРД2", СтрШаблон(ШаблонКоличествоВНРД2, ИмяОсновногоУзла, ФормаОтчета));
	ИменаУзлов.Вставить("КоличествоВНРД", "");
	ИменаУзлов.Вставить("КоличествоИсполненноеВНРД", "");
	ИменаУзлов.Вставить("ПричинаОтменыПоУмолчанию", СтрШаблон(ШаблонПричинаОтменыПоУмолчанию, ИмяОсновногоУзла, ФормаОтчета));
	ИменаУзлов.Вставить("ПричинаОтмены024", СтрШаблон(ШаблонПричинаОтмены024, ИмяОсновногоУзла));
	ИменаУзлов.Вставить("ПричинаОтмены034", СтрШаблон(ШаблонПричинаОтмены034, ИмяОсновногоУзла));
	ИменаУзлов.Вставить("ПричинаОтмены", "");
	ИменаУзлов.Вставить("ПроводкиПоОперациям", СтрШаблон(ШаблонПроводкиПоОперациям, ИмяОсновногоУзла));
	ИменаУзлов.Вставить("КодыЦБвНРД", СтрШаблон(ШаблонКодыЦБвНРД, ИмяОсновногоУзла));
	ИменаУзлов.Вставить("КодЦБвНРД", СтрШаблон(ШаблонКодЦБвНРД, ИмяОсновногоУзла));
	ИменаУзлов.Вставить("БлокировкаКоличествоЦБ", "");
	ИменаУзлов.Вставить("ПричинаПриостановкиПоУмолчанию", СтрШаблон(ШаблонПричинаПриостановкиПоУмолчанию, ИмяОсновногоУзла, ФормаОтчета));
	ИменаУзлов.Вставить("ПричинаПриостановки", СтрШаблон(ШаблонПричинаПриостановки, ИмяОсновногоУзла));
	Возврат ИменаУзлов;
КонецФункции

Функция ДанныеФайловОтчетаПоПоручениюXML(КаталогФайлов)
	ДанныеФайлов = НовыеДанныеФайлов();
	
	МассивФайлов = НайтиФайлы(КаталогФайлов, "*.xml", Истина);
	ДанныеФайлов.НайденоФайлов = МассивФайлов.Количество();
	Если ДанныеФайлов.НайденоФайлов = 0 Тогда
		Возврат ДанныеФайлов;
	КонецЕсли;
	
	Чтение = Новый ЧтениеXML;
	Чтение.ОткрытьФайл(МассивФайлов[0].ПолноеИмя);
	ПрочитанныйОбъект = ФабрикаXDTO.ПрочитатьXML(Чтение);
	Чтение.Закрыть();
	
	ИменаУзлов = ИменаУзловXML(ПрочитанныйОбъект);
	ИдентификаторКодаОтчета = ЗначениеУзлаПоПолномуПути(ПрочитанныйОбъект, ИменаУзлов.ИдентификаторКодаОтчета);
	ФормаОтчета = ЗначениеУзлаПоПолномуПути(ПрочитанныйОбъект, ИменаУзлов.ФормаОтчета);
	ДанныеФайлов.ФормаОтчета = ФормаОтчета;
	ДанныеФайлов.ИдентификаторКодаОтчета = ИдентификаторКодаОтчета;
	
	Если Не ЗначениеЗаполнено(ИменаУзлов.ИмяОсновногоУзла) Тогда
		ДанныеФайлов.ОбрабатыватьФайл = Ложь;
		Возврат ДанныеФайлов;
	КонецЕсли;
	
	SplmtryData = SplmtryData(ПрочитанныйОбъект, ИменаУзлов, ФормаОтчета);
	
	ИмяУзлаТипОтчета = ПолноеИмяУзлаСправаОтSplmtryData(ИменаУзлов.ТипОтчета);
	ИмяУзлаДатаИсполненияВДепозитарииМХ = ПолноеИмяУзлаСправаОтSplmtryData(ИменаУзлов.ДатаИсполненияВДепозитарииМХ);
	ИмяУзлаРегистрационныйНомер = ПолноеИмяУзлаСправаОтSplmtryData(ИменаУзлов.РегистрационныйНомер);
	ИмяУзлаДатаРегистрации = ПолноеИмяУзлаСправаОтSplmtryData(ИменаУзлов.ДатаРегистрации);
	ИмяУзлаНомерПоручения = ПолноеИмяУзлаСправаОтSplmtryData(ИменаУзлов.НомерПоручения);
	ИмяУзлаДатаПоручения = ПолноеИмяУзлаСправаОтSplmtryData(ИменаУзлов.ДатаПоручения);
	ИмяУзлаКодКонтрагентаНРД = ПолноеИмяУзлаСправаОтSplmtryData(ИменаУзлов.КодКонтрагентаНРД);
	ИмяУзлаНаименованиеКонтрагентаНРД = ПолноеИмяУзлаСправаОтSplmtryData(ИменаУзлов.НаименованиеКонтрагентаНРД);
	
	ДанныеФайлов.ТипОтчета = ЗначениеУзлаПоПолномуПути(SplmtryData.ОбщиеДанные, ИмяУзлаТипОтчета);
	ДанныеФайлов.НомерОтчета = ЗначениеУзлаПоПолномуПути(ПрочитанныйОбъект, ИменаУзлов.НомерОтчета);
	ДатаОтчетаСтрока = ЗначениеУзлаПоПолномуПути(ПрочитанныйОбъект, ИменаУзлов.ДатаОтчета);
	ДатаОтчета = СтроковыеФункцииКлиентСерверПереопределяемый.ДатаВремяИзСтроки(ДатаОтчетаСтрока);
	ДанныеФайлов.ДатаОтчета = ДатаОтчета + СмещениеСтандартногоВремени(ЧасовойПояс());
	ДатаИсполненияВДепозитарииМХСтрока = ЗначениеУзлаПоПолномуПути(SplmtryData.ОбщиеДанные, ИмяУзлаДатаИсполненияВДепозитарииМХ);
	ДанныеФайлов.ДатаИсполненияВДепозитарииМХ =
		СтроковыеФункцииКлиентСерверПереопределяемый.ДатаВремяИзСтроки(ДатаИсполненияВДепозитарииМХСтрока);
	ДанныеФайлов.ИдентификаторОтчета = ДанныеФайлов.НомерОтчета;
	ДанныеФайлов.РегистрационныйНомер = ЗначениеУзлаПоПолномуПути(SplmtryData.ОбщиеДанные, ИмяУзлаРегистрационныйНомер);
	ДатаРегистрацииСтрока = ЗначениеУзлаПоПолномуПути(SplmtryData.ОбщиеДанные, ИмяУзлаДатаРегистрации);
	ДанныеФайлов.ДатаРегистрации = СтроковыеФункцииКлиентСерверПереопределяемый.ДатаВремяИзСтроки(ДатаРегистрацииСтрока);
	ДанныеФайлов.НомерПоручения = ЗначениеУзлаПоПолномуПути(SplmtryData.ОбщиеДанные, ИмяУзлаНомерПоручения);
	ДатаПорученияСтрока = ЗначениеУзлаПоПолномуПути(SplmtryData.ОбщиеДанные, ИмяУзлаДатаПоручения);
	ДанныеФайлов.ДатаПоручения = СтроковыеФункцииКлиентСерверПереопределяемый.ДатаВремяИзСтроки(ДатаПорученияСтрока);
	ДанныеФайлов.КодКонтрагентаНРД = ЗначениеУзлаПоПолномуПути(SplmtryData.ОбщиеДанные, ИмяУзлаКодКонтрагентаНРД);
	ДанныеФайлов.НаименованиеКонтрагентаНРД = ЗначениеУзлаПоПолномуПути(SplmtryData.ОбщиеДанные, ИмяУзлаНаименованиеКонтрагентаНРД);
	
	Если ФормаОтчета = "MS101" Тогда
		ДанныеФайлов.ДанныеПоВсемЦБ = ДанныеПоВсемЦБ_XML(ПрочитанныйОбъект, ИменаУзлов);
	КонецЕсли;
	
	MS036 = "MS036";
	Если ФормаОтчета = "MS035" Или ФормаОтчета = MS036 Тогда
		ДанныеФайлов.КоличествоИсполненноеВНРД = КоличествоВНРД_XML(ПрочитанныйОбъект, ИменаУзлов, ФормаОтчета);
		ИменаУзлов.КоличествоИсполненноеВНРД = ИменаУзлов.КоличествоВНРД;
	КонецЕсли;
	
	Если ФормаОтчета = "MS020" Тогда
		ДанныеФайлов.РазделМХЗачисления = НайденныйИдентификаторРаздела(ПрочитанныйОбъект, ИменаУзлов.РазделМХЗачисления);
		ДанныеФайлов.РазделМХСписания = НайденныйИдентификаторРаздела(ПрочитанныйОбъект, ИменаУзлов.РазделМХСписания);
	КонецЕсли;
	
	Если ФормаОтчета = "MS035" Тогда
		ДанныеПоКодамЦБ = МассивОбъектовXDTO(ЗначениеУзлаПоПолномуПути(ПрочитанныйОбъект, ИменаУзлов.КодыЦБвНРД));
		ДанныеФайлов.КодЦБвНРД = КодВНРД(ДанныеПоКодамЦБ);
	КонецЕсли;
	
	Если ФормаОтчета = MS036 Тогда
		ИмяУзлаРазделМХБлокировка = ПолноеИмяУзлаСправаОтSplmtryData(ИменаУзлов.РазделМХБлокировка);
		ДанныеФайлов.РазделМХБлокировка = ЗначениеУзлаПоПолномуПути(SplmtryData.Расширение, ИмяУзлаРазделМХБлокировка);
		ДанныеФайлов.РазделМХСписания = НайденныйИдентификаторРаздела(ПрочитанныйОбъект, ИменаУзлов.РазделМХСписания);
		ДатаИсполненияВМестеРасчетовСтрока = ЗначениеУзлаПоПолномуПути(ПрочитанныйОбъект, ИменаУзлов.ДатаИсполненияВМестеРасчетов);
		ДанныеФайлов.ДатаИсполненияВМестеРасчетов =
			СтроковыеФункцииКлиентСерверПереопределяемый.ДатаВремяИзСтроки(ДатаИсполненияВМестеРасчетовСтрока);
	КонецЕсли;
	
	ЗаполнитьБлокировкаКоличествоЦБ =
		ФормаОтчета = "MS010" Или ФормаОтчета = "MS020" Или ФормаОтчета = MS036;
	Если ЗаполнитьБлокировкаКоличествоЦБ Тогда
		ДанныеФайлов.БлокировкаКоличествоЦБ = КоличествоВНРД_XML(ПрочитанныйОбъект, ИменаУзлов, ФормаОтчета);
		ИменаУзлов.БлокировкаКоличествоЦБ = ИменаУзлов.КоличествоВНРД;
	КонецЕсли;
	
	Если ФормаОтчета = "GS001" Тогда
		ПричинаОтмены = ПричинаОтменыXML(ПрочитанныйОбъект, ИдентификаторКодаОтчета, ИменаУзлов, ФормаОтчета);
		ДанныеФайлов.ТребуетсяСоздатьПоручениеНаОтмену = ТребуетсяСоздатьПоручениеНаОтменуXML(ПричинаОтмены);
		ДанныеФайлов.ПричинаОтмены = ПричинаОтмены;
	КонецЕсли;
	
	Если ФормаОтчета = "GS036" Тогда
		ДанныеФайлов.СообщениеОтНРД = ПервоеЗначениеУзлаПоПолномуПутиСоСписками(ПрочитанныйОбъект, ИменаУзлов.СообщениеОтНРД);
	КонецЕсли;
	
	Если ФормаОтчета = "GS101" Тогда
		ДанныеФайлов.ПричинаПриостановки = ПричинаОтказаПоИмениУзла(ПрочитанныйОбъект, ИменаУзлов, ФормаОтчета,
			"ПричинаПриостановки", "ПричинаПриостановкиПоУмолчанию");
	КонецЕсли;
	
	ЗаполнитьТаблицуВсеФайлыПоФайлуXML(ДанныеФайлов, ИменаУзлов, МассивФайлов[0].Имя);
	
	Возврат ДанныеФайлов;
КонецФункции

Функция ЗначениеУзлаПоПолномуПути(ПрочитанныйОбъект, ПолныйПутьУзла)
	Попытка
		Возврат Вычислить("ПрочитанныйОбъект." + ПолныйПутьУзла);
	Исключение
		Возврат Неопределено;
	КонецПопытки;
КонецФункции

Функция ПервоеЗначениеУзлаПоПолномуПутиСоСписками(ПрочитанныйОбъект, ПолноеИмяУзла)
	ИменаУзлов = СтрРазделить(ПолноеИмяУзла, ".");
	Значение = ПрочитанныйОбъект;
	Для Каждого ТекущееИмяУзла Из ИменаУзлов Цикл
		Значение = ЗначениеУзлаПоПолномуПути(Значение, ТекущееИмяУзла);
		Если Значение = Неопределено Тогда
			Прервать;
		КонецЕсли;
		Если ТипЗнч(Значение) = Тип("СписокXDTO") Тогда
			Значение = Значение[0];
		КонецЕсли;
	КонецЦикла;
	Возврат Значение;
КонецФункции

Функция МассивОбъектовXDTO(XDTO)
	МассивОбъектов = Новый Массив;
	Если ТипЗнч(XDTO) = Тип("СписокXDTO") Тогда
		Для Каждого ЭлементСписка Из XDTO Цикл
			МассивОбъектов.Добавить(ЭлементСписка);
		КонецЦикла;
	Иначе
		МассивОбъектов.Добавить(XDTO);
	КонецЕсли;
	Возврат МассивОбъектов;
КонецФункции

Функция SplmtryData(ПрочитанныйОбъект, ИменаУзлов, ФормаОтчета)
	SplmtryData = Новый Структура("ОбщиеДанные, Расширение");
	УзелSplmtryData = ПрочитанныйОбъект.Document[ИменаУзлов.ИмяОсновногоУзла].SplmtryData;
	Массив = МассивОбъектовXDTO(УзелSplmtryData);
	Для Каждого Элемент Из Массив Цикл
		Если ЗначениеУзлаПоПолномуПути(Элемент, "Envlp.XtnsnDt.TxPrcrDtls") <> Неопределено Тогда
			SplmtryData.ОбщиеДанные = Элемент;
			Прервать;
		КонецЕсли;
	КонецЦикла;
	Для Каждого Элемент Из Массив Цикл
		ИмяУзлаРасширение = СтрШаблон("Envlp.XtnsnDt.Xtnsn%1", ФормаОтчета);
		Если ЗначениеУзлаПоПолномуПути(Элемент, ИмяУзлаРасширение) <> Неопределено Тогда
			SplmtryData.Расширение = Элемент;
			Прервать;
		КонецЕсли;
	КонецЦикла;
	Возврат SplmtryData;
КонецФункции

Функция ПолноеИмяУзлаСправаОтSplmtryData(ПолныйПутьУзла)
	Результат = "";
	МассивИменУзлов = СтрРазделить(ПолныйПутьУзла, ".");
	ИндексSplmtryData = МассивИменУзлов.Найти("SplmtryData");
	Если ИндексSplmtryData <> Неопределено Тогда
		МассивИменУзловСправаОтSplmtryData = Новый Массив;
		Для Индекс = ИндексSplmtryData + 1 По МассивИменУзлов.ВГраница() Цикл
			МассивИменУзловСправаОтSplmtryData.Добавить(МассивИменУзлов[Индекс]);
		КонецЦикла;
		Результат = СтрСоединить(МассивИменУзловСправаОтSplmtryData, ".");
	КонецЕсли;
	Возврат Результат;
КонецФункции

Процедура ЗаполнитьТаблицуВсеФайлыПоФайлуXML(ДанныеФайлов, ИменаУзлов, ИмяФайла)
	ВсеФайлы = Новый ТаблицаЗначений;
	ВсеФайлы.Колонки.Добавить("Элемент");
	ВсеФайлы.Колонки.Добавить("Значение");
	ВсеФайлы.Колонки.Добавить("ИмяФайла");
	Для Каждого Элемент Из ДанныеФайлов Цикл
		Если Не ИменаУзлов.Свойство(Элемент.Ключ) Или Не ЗначениеЗаполнено(Элемент.Значение) Тогда
			Продолжить;
		КонецЕсли;
		НоваяСтрока = ВсеФайлы.Добавить();
		НоваяСтрока.Элемент = ИменаУзлов[Элемент.Ключ];
		НоваяСтрока.Значение = Элемент.Значение;
		НоваяСтрока.ИмяФайла = ИмяФайла;
	КонецЦикла;
	Если ЗначениеЗаполнено(ДанныеФайлов.ДанныеПоВсемЦБ) Тогда
		ЗаполнитьТаблицуВсеФайлыДаннымиПоВсемЦБ(ВсеФайлы, ДанныеФайлов.ДанныеПоВсемЦБ, ИмяФайла);
	КонецЕсли;
	ВсеФайлы.Свернуть("Элемент, Значение, ИмяФайла");
	ВсеФайлы.Сортировать("Элемент");
	ДанныеФайлов.ВсеФайлы = ВсеФайлы;
КонецПроцедуры

Процедура ЗаполнитьТаблицуВсеФайлыДаннымиПоВсемЦБ(ВсеФайлы, ДанныеПоВсемЦБ, ИмяФайла)
	ШаблонКодВНРД = "Document.MS101.SctiesSttlmTxDtls.AcctSctiesSttlmTxDtls.SctnSctiesSttlmTxDtls[%1].FinInstrmId.OthrId.Id";
	ШаблонКодРаздела = "Document.MS101.SctiesSttlmTxDtls.AcctSctiesSttlmTxDtls.SctnSctiesSttlmTxDtls[%1].Sctn.Id";
	ШаблонКоличество = "Document.MS101.SctiesSttlmTxDtls.AcctSctiesSttlmTxDtls.SctnSctiesSttlmTxDtls[%1].SttldQty.Qty.Unit";
	ШаблонНаправлениеДвижения = "Document.MS101.SctiesSttlmTxDtls.AcctSctiesSttlmTxDtls.SctnSctiesSttlmTxDtls[%1].SctiesMvmntTp";
	КоличествоДанныхПоВсемЦБ = ДанныеПоВсемЦБ.Количество();
	Для Индекс = 0 По КоличествоДанныхПоВсемЦБ - 1 Цикл
		ДанныеПоЦБ = ДанныеПоВсемЦБ[Индекс];
		ИндексСтрокой = Формат(Индекс , "ЧН=0; ЧГ=");
		ИменаУзловДанныеПоВсемЦБ = Новый Структура;
		ИменаУзловДанныеПоВсемЦБ.Вставить("КодВНРД", СтрШаблон(ШаблонКодВНРД, ИндексСтрокой));
		ИменаУзловДанныеПоВсемЦБ.Вставить("КодРаздела", СтрШаблон(ШаблонКодРаздела, ИндексСтрокой));
		ИменаУзловДанныеПоВсемЦБ.Вставить("Количество", СтрШаблон(ШаблонКоличество, ИндексСтрокой));
		ИменаУзловДанныеПоВсемЦБ.Вставить("НаправлениеДвижения", СтрШаблон(ШаблонНаправлениеДвижения, ИндексСтрокой));
		Для Каждого Элемент Из ДанныеПоЦБ Цикл
			НоваяСтрока = ВсеФайлы.Добавить();
			НоваяСтрока.Элемент = ИменаУзловДанныеПоВсемЦБ[Элемент.Ключ];
			НоваяСтрока.Значение = ДанныеПоЦБ[Элемент.Ключ];
			НоваяСтрока.ИмяФайла = ИмяФайла;
		КонецЦикла;
	КонецЦикла;
КонецПроцедуры

