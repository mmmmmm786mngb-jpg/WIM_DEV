								РегистрыСведений.СостоянияДокументовВФайловомШлюзе.ДобавитьЗапись(ТекущаяДатаСеанса(), ТехническаяОперация,
									ПоследнийЗаполненныйСтатус, НовыйВходящийПакет.Ссылка, СообщениеОтНРД);
							КонецЕсли;
						КонецЕсли;
						
					Иначе
						
						Запрос = Новый Запрос;
						Запрос.Текст =
						"ВЫБРАТЬ ПЕРВЫЕ 1
						|	ТехническаяОперация.Ссылка КАК Ссылка
						|ИЗ
						|	Документ.ТехническаяОперация КАК ТехническаяОперация
						|ГДЕ
						|	ТехническаяОперация.Проведен
						|	И ТехническаяОперация.Номер = &Номер
						|	И НАЧАЛОПЕРИОДА(ТехническаяОперация.Дата, ДЕНЬ) = НАЧАЛОПЕРИОДА(&Дата, ДЕНЬ)";
						Запрос.УстановитьПараметр("Номер", НомерПоручения);
						Запрос.УстановитьПараметр("Дата", ДатаПоручения);
						Если Не Запрос.Выполнить().Пустой() Тогда
							ПомещатьВАрхив = Ложь;
							Продолжить;
						КонецЕсли;
						
						ТехническаяОперацияТранзит = Документы.ТехническаяОперация.СоздатьДокумент();
						ТехническаяОперацияТранзит.Номер = Формат(ИдентификаторОтчета, "ЧГ=0");
						ТехническаяОперацияТранзит.Дата = ТекущаяДатаСеанса();
						ТехническаяОперацияТранзит.РегистрационныйНомер = РегистрационныйНомер;
						ТехническаяОперацияТранзит.РегистрационнаяДата = ДатаРегистрации;
						ТехническаяОперацияТранзит.НомерДокументаОснования = НомерПоручения;
						ТехническаяОперацияТранзит.ДатаДокументаОснования = ДатаПоручения;
						ТехническаяОперацияТранзит.КодОтчетаНРД = НомерОтчета;
						ТехническаяОперацияТранзит.ДатаИсполнения = ДатаОтчета;
						ТехническаяОперацияТранзит.ТипОперации = ФормаОтчета;
						ТехническаяОперацияТранзит.КодОперации = ТипОтчета;
						ТехническаяОперацияТранзит.ПорядковыйНомерВнутриДня = 1;
						ТехническаяОперацияТранзит.Записать(РежимЗаписиДокумента.Проведение);
						
						ВходящийПакетТранзит = Документы.ВходящийПакетИзФайловогоШлюза.СоздатьДокумент();
						ВходящийПакетТранзит.Дата = ТекущаяДатаСеанса();
						ВходящийПакетТранзит.Комментарий = "Создан автоматически в " + Формат(ТекущаяДатаСеанса(), "ДЛФ=DT");  
						ВходящийПакетТранзит.ДокументОснование = ТехническаяОперацияТранзит.Ссылка;
						ВходящийПакетТранзит.ОтносительныйПуть = Каталог.Имя;
						ВходящийПакетТранзит.ПолныйПуть = Файл.Путь;
						ВходящийПакетТранзит.Статус = Перечисления.СтатусыДокументовФайловыйШлюз.Исполнено;
						
						Если ЗначениеЗаполнено(ПутьАрхиваНаТекущуюДатуПоСистеме) Тогда
							ВходящийПакетТранзит.ПутьАрхив = ПутьАрхиваВОбщихКаталогах + "\" + Каталог.Имя;
						КонецЕсли;
						
						ВходящийПакетТранзит.СодержимоеФайла.Загрузить(ДанныеФайлов.ВсеФайлы);
						ВходящийПакетТранзит.Записать();
						ВходящийПакетТранзит.Записать(РежимЗаписиДокумента.Проведение);
						
					КонецЕсли;
					
				КонецЕсли;
				
			КонецЦикла;
			
			Если ЗначениеЗаполнено(ПутьАрхиваВОбщихКаталогах) И ПомещатьВАрхив Тогда
				
				СтарыйПутьКаталога = Каталог.ПолноеИмя;
				РаботаСФайлами.ПереместитьКаталог(СтарыйПутьКаталога, ПутьАрхиваВОбщихКаталогах + "\" + Каталог.Имя);
				ЗаписьЖурналаРегистрации("Архивация файлов входящих пакетов (Z)", УровеньЖурналаРегистрации.Информация,
							Метаданные.Обработки.ЭкспортПорученийВЛуч,, 
							"Каталог " + Каталог.Имя + " перемещен: " + СтарыйПутьКаталога + " => " + ПутьАрхиваВОбщихКаталогах + "\" + Каталог.Имя);
				
			КонецЕсли;
			
		КонецЦикла;
		
		Перенумеровать(ДокументыКПеренумерации);
		
	КонецЕсли;
КонецПроцедуры

Функция ДанныеФайловОтчетаПоПоручению(Файл)
	ИмяПромежуточногоФайла = ПолучитьИмяВременногоФайла("zip");
	ДвоичныеДанные = Новый ДвоичныеДанные(Файл.ПолноеИмя);
	ДвоичныеДанные.Записать(ИмяПромежуточногоФайла);
	
	ВременныйКаталог = СтрЗаменить(ИмяПромежуточногоФайла, ".zip", "");
	ЧтениеАрхива = Новый ЧтениеZipФайла(ИмяПромежуточногоФайла);
	ЧтениеАрхива.ИзвлечьВсе(ВременныйКаталог);
	
	ОбрабатыватьДепозитарнуюОтчетностьXML =
		РегистрыСведений.ПараметрыГлобальные.ЗначениеПараметра("1123.ОбрабатыватьДепозитарнуюОтчетностьВxml", Ложь);
		
	// NOTE: Временный функционал - отчеты видов 40 и 41 пока что всегда обрабатывать в формате dbf
	Если ОбрабатыватьДепозитарнуюОтчетностьXML Тогда
		ФайлыВидаОтчета40 = НайтиФайлы(ВременныйКаталог, "is40?.rpt", Истина);
		ФайлыВидаОтчета41 = НайтиФайлы(ВременныйКаталог, "is41k.rpt", Истина);
		ЭтоОтчетВида40Или41 = ЗначениеЗаполнено(ФайлыВидаОтчета40) Или ЗначениеЗаполнено(ФайлыВидаОтчета41);
		ОбрабатыватьДепозитарнуюОтчетностьXML = Не ЭтоОтчетВида40Или41;
	КонецЕсли;
	
	Если ОбрабатыватьДепозитарнуюОтчетностьXML Тогда
		ДанныеФайлов = ДанныеФайловОтчетаПоПоручениюXML(ВременныйКаталог);
		Если ДанныеФайлов.НайденоФайлов = 0 И ДанныеФайлов.ОбрабатыватьФайл Тогда
			ОбрабатыватьДепозитарнуюОтчетностьXML = Ложь;
		КонецЕсли;
	КонецЕсли;
	
	Если Не ОбрабатыватьДепозитарнуюОтчетностьXML Тогда
		ДанныеФайлов = ДанныеФайловОтчетаПоПоручениюDBF(ВременныйКаталог);
	КонецЕсли;
	
	УдалитьФайлы(ВременныйКаталог);
	УдалитьФайлы(ИмяПромежуточногоФайла);
	
	Возврат ДанныеФайлов;
КонецФункции

Функция НовыеДанныеФайлов()
	ДанныеФайлов = Новый Структура("ВсеФайлы, ТипОтчета, ФормаОтчета, НомерОтчета, ДатаОтчета, ДатаИсполненияВДепозитарииМХ,
		|ИдентификаторОтчета, РегистрационныйНомер, ДатаРегистрации, НомерПоручения, ДатаПоручения,
		|КодКонтрагентаНРД, НаименованиеКонтрагентаНРД, ДатаИсполненияВМестеРасчетов, ДанныеПоВсемЦБ,
		|РазделМХЗачисления, РазделМХСписания, РазделМХБлокировка, БлокировкаКоличествоЦБ, КоличествоИсполненноеВНРД, ТребуетсяСоздатьПоручениеНаОтмену,
		|ПричинаОтмены, КодЦБвНРД, СообщениеОтНРД, ПричинаПриостановки, ИдентификаторКодаОтчета, ОбрабатыватьФайл, НайденоФайлов");
	ДанныеФайлов.ОбрабатыватьФайл = Истина;
	ДанныеФайлов.КоличествоИсполненноеВНРД = 0;
	Возврат ДанныеФайлов;
КонецФункции

Функция ДанныеФайловОтчетаПоПоручениюDBF(ВременныйКаталог)
	ВсеФайлы = ВсеФайлыDBF(ВременныйКаталог);
	ИменаФайлов = Новый Массив;
	ОбщегоНазначения.ЗаполнитьМассивУникальнымиЗначениями(ИменаФайлов, ВсеФайлы.ВыгрузитьКолонку("ИмяФайла"));
	ДанныеФайлов = НовыеДанныеФайлов();
	ДанныеФайлов.ВсеФайлы = ВсеФайлы;
	ДанныеФайлов.НайденоФайлов = ИменаФайлов.Количество();
	
	reporth = "reporth.dbf";
	ДанныеФайлов.ТипОтчета = ЗначениеЭлементаИзДанныхФайлов(ВсеФайлы, "ORD_TYPE_I", reporth);
	ДанныеФайлов.ФормаОтчета = ЗначениеЭлементаИзДанныхФайлов(ВсеФайлы, "OUT_FORM", reporth);
	ДанныеФайлов.НомерОтчета = ЗначениеЭлементаИзДанныхФайлов(ВсеФайлы, "REG_NO", reporth);
	ДанныеФайлов.ДатаОтчета = ДатаВремя(ЗначениеЭлементаИзДанныхФайлов(ВсеФайлы, "REG_DATE", reporth),
		ЗначениеЭлементаИзДанныхФайлов(ВсеФайлы, "TREG_DATE", reporth));
	ДанныеФайлов.ДатаИсполненияВДепозитарииМХ = ЗначениеЭлементаИзДанныхФайлов(ВсеФайлы, "OPERDAY", reporth);
	ДанныеФайлов.ИдентификаторОтчета = ЗначениеЭлементаИзДанныхФайлов(ВсеФайлы, "REPORT_ID", reporth);
	ДанныеФайлов.РегистрационныйНомер = ЗначениеЭлементаИзДанныхФайлов(ВсеФайлы, "IN_REG_NO", reporth);
	ДанныеФайлов.ДатаРегистрации = ДатаВремя(ЗначениеЭлементаИзДанныхФайлов(ВсеФайлы, "IN_REG_DAT", reporth),
		ЗначениеЭлементаИзДанныхФайлов(ВсеФайлы, "TIN_REG_DA", reporth));
	ДанныеФайлов.НомерПоручения = ЗначениеЭлементаИзДанныхФайлов(ВсеФайлы, "REPL_TO_NO", reporth);
	ДанныеФайлов.ДатаПоручения = ЗначениеЭлементаИзДанныхФайлов(ВсеФайлы, "REPL_TO_DA", reporth);
	ДанныеФайлов.КодКонтрагентаНРД = ЗначениеЭлементаИзДанныхФайлов(ВсеФайлы, "PERSON_COD", reporth);
	ДанныеФайлов.НаименованиеКонтрагентаНРД = ЗначениеЭлементаИзДанныхФайлов(ВсеФайлы, "PERSON_NAM", reporth);
	
	hbltrans = "hbltrans.dbf";
	ДанныеФайлов.ДатаИсполненияВМестеРасчетов = ЗначениеЭлементаИзДанныхФайлов(ВсеФайлы, "OPER_DATE", hbltrans);
	ДанныеФайлов.РазделМХБлокировка = ЗначениеЭлементаИзДанныхФайлов(ВсеФайлы, "TLORO_SEC", hbltrans);
	
	ДанныеФайлов.ДанныеПоВсемЦБ = ДанныеПоВсемЦБ_DBF(ВсеФайлы);
	
	tranblsc = "tranblsc.dbf";
	ДанныеФайлов.КодЦБвНРД = ЗначениеЭлементаИзДанныхФайлов(ВсеФайлы, "SECURITY_C", tranblsc);
	ДанныеФайлов.КоличествоИсполненноеВНРД = КоличествоИсполненноеВНРД_DBF(ВсеФайлы, tranblsc);
	
	htrans = "htrans.dbf";
	ДанныеФайлов.РазделМХЗачисления = ЗначениеЭлементаИзДанныхФайлов(ВсеФайлы, "TSEC_CODE", htrans);
	ДанныеФайлов.РазделМХСписания = ЗначениеЭлементаИзДанныхФайлов(ВсеФайлы, "FSEC_CODE", htrans);
	
	ДанныеФайлов.БлокировкаКоличествоЦБ = БлокировкаКоличествоЦБ_DBF(ВсеФайлы, "transs.dbf");
	Если Не ЗначениеЗаполнено(ДанныеФайлов.БлокировкаКоличествоЦБ) Тогда
		ДанныеФайлов.БлокировкаКоличествоЦБ = БлокировкаКоличествоЦБ_DBF(ВсеФайлы, tranblsc);
	КонецЕсли;
	
	ДанныеФайлов.ТребуетсяСоздатьПоручениеНаОтмену = ТребуетсяСоздатьПоручениеНаОтмену(ВсеФайлы);
	ДанныеФайлов.ПричинаОтмены = ЗначениеЭлементаИзДанныхФайлов(ВсеФайлы, "ABORT_CAUS", "abort.dbf");
	ДанныеФайлов.СообщениеОтНРД = ЗначениеЭлементаИзДанныхФайлов(ВсеФайлы, "MESSAGE", "messages.dbf");
	
	Возврат ДанныеФайлов;
КонецФункции

Функция БлокировкаКоличествоЦБ_DBF(ВсеФайлы, ИмяФайла)
	БлокировкаКоличествоЦБ = ЗначениеЭлементаИзДанныхФайлов(ВсеФайлы, "SEQ_AMO", ИмяФайла);
	Если ЗначениеЗаполнено(БлокировкаКоличествоЦБ) Тогда
		БлокировкаКоличествоЦБ = СтрЗаменить(БлокировкаКоличествоЦБ, " ", "");
		БлокировкаКоличествоЦБ = СтрЗаменить(БлокировкаКоличествоЦБ, Символы.НПП, "");
		БлокировкаКоличествоЦБ = СтроковыеФункцииКлиентСервер.ЧислоИзСтроки(БлокировкаКоличествоЦБ);
	Иначе
		БлокировкаКоличествоЦБ = 0;
	КонецЕсли;
	Возврат БлокировкаКоличествоЦБ;
КонецФункции

Функция ДанныеПоВсемЦБ_DBF(ВсеФайлы)
	anysecur = "anysecur.dbf";
	КоличествоСтрок = КоличествоСтрокВТаблицеВсеФайлы(ВсеФайлы, anysecur);
	ДанныеПоВсемЦБ = Новый Массив;
	Для НомерСтрокиФайла = 1 По КоличествоСтрок Цикл
		ДанныеПоЦБ = Новый Структура("КодВНРД, КодРаздела, Количество");
		ДанныеПоЦБ.КодВНРД = ЗначениеЭлементаИзДанныхФайлов(ВсеФайлы, "SECURITY_C", anysecur, НомерСтрокиФайла);
		ДанныеПоЦБ.КодРаздела = ЗначениеЭлементаИзДанныхФайлов(ВсеФайлы, "SECTION_CO", anysecur, НомерСтрокиФайла);
		ДанныеПоЦБ.Количество = ЗначениеЭлементаИзДанныхФайлов(ВсеФайлы, "SEQ_AMO", anysecur, НомерСтрокиФайла);
		ДанныеПоВсемЦБ.Добавить(ДанныеПоЦБ);
	КонецЦикла;
	Возврат ДанныеПоВсемЦБ;
КонецФункции

Функция КоличествоСтрокВТаблицеВсеФайлы(ВсеФайлы, ИмяФайла)
	КоличествоСтрок = 0;
	Отбор = Новый Структура("ИмяФайла", ИмяФайла);
	НайденныеСтроки = ВсеФайлы.НайтиСтроки(Отбор);
	Для Каждого СтрокаТаблицы Из НайденныеСтроки Цикл
		ТекущийНомерСтроки = СтроковыеФункцииКлиентСервер.ЧислоИзСтроки(СтрокаТаблицы.НомерСтрокиФайла);
		Если ТекущийНомерСтроки > КоличествоСтрок Тогда
			КоличествоСтрок = ТекущийНомерСтроки;
		КонецЕсли;
	КонецЦикла;
	Возврат КоличествоСтрок;
КонецФункции

