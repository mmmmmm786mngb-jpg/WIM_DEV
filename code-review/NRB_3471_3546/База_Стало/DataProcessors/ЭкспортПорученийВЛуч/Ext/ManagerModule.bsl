Процедура ОбработатьВходящиеПакеты()
	//Входящие пакеты
	ВнешнийИсточникФайловыйШлюзКаталогВходящие = ПланыВидовХарактеристик.ВнешниеИсточники.ФайловыйШлюзКаталогВходящие;
	ПутьДляЗагрузки = ВнешниеДанные.ПолучитьПараметрыВнешнегоИсточника(ВнешнийИсточникФайловыйШлюзКаталогВходящие).Папка;
	
	ВнешнийИсточникФайловыйШлюзКаталоАрхив = ПланыВидовХарактеристик.ВнешниеИсточники.ФайловыйШлюзКаталогАрхив;
	ПутьАрхив = ВнешниеДанные.ПолучитьПараметрыВнешнегоИсточника(ВнешнийИсточникФайловыйШлюзКаталоАрхив).Папка;
	
	ДокументыКПеренумерации = Новый Массив;
	
	Если ЗначениеЗаполнено(ПутьАрхив) Тогда
		// каталог архива на текущую дату
		ПутьАрхиваНаТекущуюДатуПоСистеме = ОбщийКаталогПеремещаемогоФайлаВАрхив(ПутьАрхив);
		Файл = Новый Файл(ПутьАрхиваНаТекущуюДатуПоСистеме);
		Если Не Файл.Существует() Тогда
			СоздатьКаталог(ПутьАрхиваНаТекущуюДатуПоСистеме);
		КонецЕсли;
	Иначе
		ПутьАрхиваНаТекущуюДатуПоСистеме = "";
	КонецЕсли;
	
	
	
	Если ЗначениеЗаполнено(ПутьДляЗагрузки) Тогда
		МассивКаталоговZ = НайтиФайлы(ПутьДляЗагрузки, "Z???????*");
		// Уведомления о принятии(непринятии) поручений/распоряжений (К)
		МассивКаталоговK = НайтиФайлы(ПутьДляЗагрузки, "K???????*"); 
		Для Каждого Каталог Из МассивКаталоговK Цикл
			МассивФайлов = НайтиФайлы(Каталог.ПолноеИмя, "*.xml");
			Для Каждого Файл Из МассивФайлов Цикл
				
				СквознойИдентификаторВызова = Новый УникальныйИдентификатор;
				
				СтруктураФайла = Новый Структура();
				
				СтатусПакета = Перечисления.СтатусыДокументовФайловыйШлюз.ПринятоКИсполнению;
				
				ЧтениеXML = Новый ЧтениеXML;
				ЧтениеXML.ОткрытьФайл(Файл.ПолноеИмя);   
				
				// проверка формата файла обмена
				Если Не ЧтениеXML.Прочитать() Тогда
					
					ЗаписьЖурналаРегистрации("Загрузка уведомлений о принятии(непринятии) поручений/распоряжений", 
					УровеньЖурналаРегистрации.Предупреждение,,, 
					"Ошибка при чтении файла: " + Файл.ПолноеИмя);
					
					Продолжить;
				КонецЕсли;
				
				Если ЧтениеXML.ЛокальноеИмя = "information" Тогда	// депозитарная система не смогла идентифицировать
																	// полученный документ как поручение/инструкцию
					ТекстОшибкиИсходный = "";
					ТекстОшибкиПолный = "";
					
					Пока ЧтениеXML.Прочитать() Цикл
						Если Не ЧтениеXML.ТипУзла = ТипУзлаXML.НачалоЭлемента Тогда
							Продолжить;
						КонецЕсли;
						Если ЧтениеXML.ЛокальноеИмя = "line" Тогда
							Если ЧтениеXML.ЗначениеАтрибута("severity") = "ERROR" Тогда
								ЧтениеXML.Прочитать();
								Если ТекстОшибкиИсходный = "" Тогда
									ТекстОшибкиИсходный = ЧтениеXML.Значение;	  
								КонецЕсли; 
								
								ТекстОшибкиПолный = ТекстОшибкиПолный + " " + ЧтениеXML.Значение;
							КонецЕсли;
						КонецЕсли;
					КонецЦикла;
					
					Если ТекстОшибкиИсходный <> "" Тогда
						ТекстОшибки = ТекстОшибкиИсходный;
						Поз = СтрНайти(ТекстОшибки, " ");
						Пока Поз > 0 Цикл
							ТекстОшибки = Сред(ТекстОшибки, Поз + 1);					
							Поз = СтрНайти(ТекстОшибки, " ");
						КонецЦикла; 
						ИмяФайла = Лев(ТекстОшибки, СтрДлина(ТекстОшибки) - 1);
					КонецЕсли; 	
					
					ИмяФайла = СтрЗаменить(ВРЕГ(ИмяФайла), ".XML", "");
					
					Запрос = Новый Запрос;
					Запрос.УстановитьПараметр("Имяфайла", ИмяФайла);
					Запрос.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
					|	ИсходящийПакетВФайловыйШлюз.ДокументОснование КАК ТехническаяОперация
					|ИЗ
					|	Документ.ИсходящийПакетВФайловыйШлюз КАК ИсходящийПакетВФайловыйШлюз
					|ГДЕ
					|	НЕ ИсходящийПакетВФайловыйШлюз.ПометкаУдаления И ОтносительныйПуть = &Имяфайла";
					
					Выборка = Запрос.Выполнить().Выбрать();
					Если Выборка.Следующий() Тогда	// По входящему пакету из файлового шлюза сопоставлен документ ""Техническая операция"
						ПараметрыПоиска = Новый Структура("ПолныйПуть, ДокументОснование, Обработан",
															Файл.Путь, Выборка.ТехническаяОперация, Ложь);
						ВходящийПакет = Документы.ВходящийПакетИзФайловогоШлюза.НайтиДокумент(ПараметрыПоиска);
						Если НЕ ЗначениеЗаполнено(ВходящийПакет) Тогда
							НовыйВходящийПакет = Документы.ВходящийПакетИзФайловогоШлюза.СоздатьДокумент();
							НовыйВходящийПакет.Дата = ТекущаяДатаСеанса();
							НовыйВходящийПакет.ДокументОснование = Выборка.ТехническаяОперация;
							НовыйВходящийПакет.Комментарий = "Создан автоматически в " + Формат(ТекущаяДатаСеанса(), "ДЛФ=DT");  
						Иначе
							НовыйВходящийПакет = ВходящийПакет.ПолучитьОбъект();
							НовыйВходящийПакет.СодержимоеФайла.Очистить();
						КонецЕсли; 
						НовыйВходящийПакет.ОтносительныйПуть = ИмяФайла;
						НовыйВходящийПакет.ПолныйПуть = Файл.Путь;
						НовыйВходящийПакет.Статус = Перечисления.СтатусыДокументовФайловыйШлюз.ОшибкаФайловыйШлюз;
						
						Если ЗначениеЗаполнено(ПутьАрхиваНаТекущуюДатуПоСистеме) Тогда
							
							ПутьАрхиваВОбщихКаталогах = ОбщийКаталогПеремещаемогоФайлаВАрхив(ПутьАрхиваНаТекущуюДатуПоСистеме, "K");
							НовыйВходящийПакет.ПутьАрхив = ПутьАрхиваВОбщихКаталогах + "\" + Каталог.Имя;
						КонецЕсли; 
						
						НовыйВходящийПакет.Записать();
						
						РегистрыСведений.СостоянияДокументовВФайловомШлюзе.ДобавитьЗапись(ТекущаяДатаСеанса(), Выборка.ТехническаяОперация, 
								Перечисления.СтатусыДокументовФайловыйШлюз.ОшибкаФайловыйШлюз, НовыйВходящийПакет.Ссылка, ТекстОшибкиПолный);
						
						НовыйВходящийПакет.Записать(РежимЗаписиДокумента.Проведение);
					КонецЕсли;
					
				ИначеЕсли ЧтениеXML.ЛокальноеИмя = "Batch" Тогда
					ИмяУзла = "";
					
					Пока ЧтениеXML.Прочитать() Цикл
						
						Если ЧтениеXML.ТипУзла = ТипУзлаXML.НачалоЭлемента Тогда
							ИмяУзла = ЧтениеXML.Имя;
						ИначеЕсли ЧтениеXML.ТипУзла = ТипУзлаXML.Текст И ИмяУзла <> "" Тогда	
							СтруктураФайла.Вставить(ИмяУзла, ЧтениеXML.Значение);				
						КонецЕсли;
						
					КонецЦикла;
					
					КодОшибки = "";
					ОписаниеОшибки = "";
					
					Если СтруктураФайла.Свойство("abort_code") Тогда
						КодОшибки = СтруктураФайла.abort_code;
					КонецЕсли; 
					Если СтруктураФайла.Свойство("abort_cause") Тогда
						ОписаниеОшибки = СтруктураФайла.abort_cause;
					КонецЕсли; 
					
					Если КодОшибки <> "" Тогда
						СтатусПакета = Перечисления.СтатусыДокументовФайловыйШлюз.НеПринятоКИсполнению;
					КонецЕсли; 
					
					Если СтруктураФайла.contragent_doc_id <> "" И СтруктураФайла.create_date <> "" Тогда
						
						contragent_doc_id = СтруктураФайла.contragent_doc_id;
						Если КодОшибки = "" Тогда
							reg_no      = СтруктураФайла.reg_no;
							ДеньРегистрации = Дата(Лев(СтруктураФайла.reg_date, 4), Сред(СтруктураФайла.reg_date, 6, 2), Сред(СтруктураФайла.reg_date, 9, 2));
							ДатаВремяРегистрации = ДатаВремя(ДеньРегистрации, Сред(СтруктураФайла.reg_date, 12));
							reg_date    = XMLЗначение(Тип("Дата"), СтруктураФайла.reg_date);
						Иначе
							reg_no      = "";
							reg_date    = "";
						КонецЕсли; 
						
						create_date = XMLЗначение(Тип("Дата"), СтруктураФайла.create_date);
						
						Выборка = ВыборкаТехническаяОперацияПоНомеруИДате(contragent_doc_id, create_date);
						Если Выборка.Следующий() Тогда
							ТехническаяОперация = Выборка.Документ;
						Иначе
							ТехническаяОперация = Документы.ТехническаяОперация.ПустаяСсылка();
						КонецЕсли; 
						Если ЗначениеЗаполнено(ТехническаяОперация) Тогда
							// По входящему пакету из файлового шлюза сопоставлен документ ""Техническая операция"
							
							Если КодОшибки = "" Тогда
								ОбъектТО = ТехническаяОперация.ПолучитьОбъект();
								ОбъектТО.РегистрационныйНомер = reg_no;
								ОбъектТО.РегистрационнаяДата = reg_date;
								ОбъектТО.КодОтчетаНРД = reg_no;
								ОбъектТО.ДатаИсполнения = ДатаВремяРегистрации;
								ОбъектТО.Записать();
							КонецЕсли;
							
							Если ЗначениеЗаполнено(ТехническаяОперация.ДокументОснование) Тогда
								РеквизитыПоручения = РегистрыСведений.ДокументыВыгруженныеВЛуч.РеквизитыВыгрузки(
									ТехническаяОперация.ДокументОснование);
								РегистрыСведений.ДокументыВыгруженныеВЛуч.ДобавитьДокумент(
									ТехническаяОперация.ДокументОснование, РеквизитыПоручения.ДатаВыгрузки,
									РеквизитыПоручения.ИсходящийНомер, reg_no, ПараметрыСеанса.ТекущийПользователь);
							КонецЕсли; 
							
							ВходящийПакет = Документы.ВходящийПакетИзФайловогоШлюза.НайтиДокумент(
								Новый Структура("ПолныйПуть, Обработан", Файл.Путь, Ложь));
							Если НЕ ЗначениеЗаполнено(ВходящийПакет) Тогда
								НовыйВходящийПакет = Документы.ВходящийПакетИзФайловогоШлюза.СоздатьДокумент();
								НовыйВходящийПакет.Дата = ТекущаяДатаСеанса();
								НовыйВходящийПакет.Комментарий = "Создан автоматически в " + Формат(ТекущаяДатаСеанса(), "ДЛФ=DT");  
							Иначе
								НовыйВходящийПакет = ВходящийПакет.ПолучитьОбъект();
								НовыйВходящийПакет.СодержимоеФайла.Очистить();
							КонецЕсли; 
							НовыйВходящийПакет.ДокументОснование = ТехническаяОперация.Ссылка;
							НовыйВходящийПакет.ОтносительныйПуть = Каталог.Имя;
							НовыйВходящийПакет.ПолныйПуть = Файл.Путь;
							НовыйВходящийПакет.Статус = СтатусПакета;
							
							Если ЗначениеЗаполнено(ПутьАрхиваНаТекущуюДатуПоСистеме) Тогда
								ПутьАрхиваВОбщихКаталогах = ОбщийКаталогПеремещаемогоФайлаВАрхив(ПутьАрхиваНаТекущуюДатуПоСистеме, "K");
								НовыйВходящийПакет.ПутьАрхив = ПутьАрхиваВОбщихКаталогах + "\" + Каталог.Имя;								
							КонецЕсли; 
							
							Для каждого КлючИЗначение Из СтруктураФайла Цикл
								НовСтр = НовыйВходящийПакет.СодержимоеФайла.Добавить();
								НовСтр.Элемент = КлючИЗначение.Ключ;
								НовСтр.Значение = КлючИЗначение.Значение;
							КонецЦикла; 
							
							НовыйВходящийПакет.Обработан = Истина;
							
							НовыйВходящийПакет.Записать();
							
							ПериодЗаписи = ТекущаяДатаСеанса();
							РегистрыСведений.СостоянияДокументовВФайловомШлюзе.ДобавитьЗапись(ПериодЗаписи,
								ТехническаяОперация.Ссылка, СтатусПакета, НовыйВходящийПакет.Ссылка,
								?(КодОшибки = "", "", "Код причины отказа: " + КодОшибки + ". Причина отказа: "
									+ ОписаниеОшибки));
									
							НовыйВходящийПакет.Записать(РежимЗаписиДокумента.Проведение);
							
							ПроверитьИЗаписатьОшибкуЗагрузкиПоРСВ(Выборка.ДокументОснование, ОписаниеОшибки);
						КонецЕсли;
					КонецЕсли;
				ИначеЕсли ЧтениеXML.ЛокальноеИмя = "MeetingInstructionStatus" Тогда
					ПутьАрхив = "";
					Если ЗначениеЗаполнено(ПутьАрхиваНаТекущуюДатуПоСистеме) Тогда
						ПутьАрхиваВОбщихКаталогах = ОбщийКаталогПеремещаемогоФайлаВАрхив(ПутьАрхиваНаТекущуюДатуПоСистеме, "K");
						ПутьАрхив = ПутьАрхиваВОбщихКаталогах + "\" + Каталог.Имя;
					КонецЕсли;
					ОбработатьMeetingInstructionStatus(ЧтениеXML, ПутьАрхив);
				КонецЕсли;
				
				ЧтениеXML.Закрыть();
			КонецЦикла;
			
			Если ЗначениеЗаполнено(ПутьАрхиваВОбщихКаталогах) Тогда
				СтарыйПутьКаталога = Каталог.ПолноеИмя;
				РаботаСФайлами.ПереместитьКаталог(СтарыйПутьКаталога, ПутьАрхиваВОбщихКаталогах + "\" + Каталог.Имя);
				ЗаписьЖурналаРегистрации("Архивация файлов входящих пакетов (К)", УровеньЖурналаРегистрации.Информация,
							Метаданные.Обработки.ЭкспортПорученийВЛуч,, 
							"Каталог " + Каталог.Имя + " перемещен: " + СтарыйПутьКаталога + " => " + ПутьАрхиваВОбщихКаталогах + "\" + Каталог.Имя);
				
			КонецЕсли;
			
		КонецЦикла;
		
		ДатаПереходаНаНовыйМеханизмБлокировокЦБ =
			РегистрыСведений.ПараметрыГлобальные.ЗначениеПараметра("5577.ДатаПереходаНаНовыйМеханизмБлокировокЦБ");
		
		// Отчет по поручению (Z)
		РазрешенныеКодыОпераций = РазрешенныеКодыОперацийДляЭкспорта();
		ИмяСобытияЖР_ЗагрузкаОтчетовПоПоручению = "Загрузка отчетов по поручению (Z)";
		
		Если ЗначениеЗаполнено(ПутьАрхиваНаТекущуюДатуПоСистеме) Тогда
			ПутьАрхиваВОбщихКаталогах = ОбщийКаталогПеремещаемогоФайлаВАрхив(ПутьАрхиваНаТекущуюДатуПоСистеме, "Z");
		КонецЕсли;
		
		Для Каждого Каталог Из МассивКаталоговZ Цикл
			МассивФайлов = НайтиФайлы(Каталог.ПолноеИмя, "*.zip", Истина);
			
			ПомещатьВАрхив = Истина;
			
			Для Каждого Файл Из МассивФайлов Цикл
				ДанныеФайлов = ДанныеФайловОтчетаПоПоручению(Файл);
				ТипОтчета = ДанныеФайлов.ТипОтчета;
				
				Если Не ДанныеФайлов.ОбрабатыватьФайл Тогда
					ТекстОшибки = "Не удалось обработать файл с идентификатором кода отчета: " + ДанныеФайлов.ИдентификаторКодаОтчета;
					ЗаписьЖурналаРегистрации(ИмяСобытияЖР_ЗагрузкаОтчетовПоПоручению, УровеньЖурналаРегистрации.Информация,
						Метаданные.Обработки.ЭкспортПорученийВЛуч, , ТекстОшибки);
					Продолжить;
				КонецЕсли;
				
				Если РазрешенныеКодыОпераций.Найти(ТипОтчета) = Неопределено Тогда
					ЗаписьЖурналаРегистрации(ИмяСобытияЖР_ЗагрузкаОтчетовПоПоручению, УровеньЖурналаРегистрации.Информация,
						Метаданные.Обработки.ЭкспортПорученийВЛуч, ,
						"Тип отчета каталога " + Каталог.ПолноеИмя + " не включен в список разрешенных кодов операций: " + ТипОтчета);
					Продолжить;
				КонецЕсли;
				
				ФормаОтчета = ДанныеФайлов.ФормаОтчета;
				НомерОтчета = ДанныеФайлов.НомерОтчета;
				ДатаОтчета = ДанныеФайлов.ДатаОтчета;
				ДатаИсполненияВДепозитарииМХ = ДанныеФайлов.ДатаИсполненияВДепозитарииМХ;
				ИдентификаторОтчета = ДанныеФайлов.ИдентификаторОтчета;
				РегистрационныйНомер = ДанныеФайлов.РегистрационныйНомер;
				ДатаРегистрации = ДанныеФайлов.ДатаРегистрации;
				НомерПоручения = ДанныеФайлов.НомерПоручения;
				ДатаПоручения = ДанныеФайлов.ДатаПоручения;
				КодКонтрагентаНРД = ДанныеФайлов.КодКонтрагентаНРД;
				НаименованиеКонтрагентаНРД = ДанныеФайлов.НаименованиеКонтрагентаНРД;
				
				ДатаИсполненияВМестеРасчетов = ДанныеФайлов.ДатаИсполненияВМестеРасчетов;
				Если Не ЗначениеЗаполнено(ДатаИсполненияВМестеРасчетов) Тогда
					ДатаИсполненияВМестеРасчетов = НачалоДня(ДатаОтчета);
				КонецЕсли;
				
				Если ТипОтчета = "10/50" ИЛИ ТипОтчета = "10/CA" ИЛИ ТипОтчета = "10/CA2" Тогда
					Запрос = Новый Запрос;
					Запрос.Текст = "ВЫБРАТЬ
					|	Поручение.Ссылка
					|ИЗ
					|	Документ.Поручение КАК Поручение
					|ГДЕ
					|	НАЧАЛОПЕРИОДА(Поручение.ДатаИсполненияПоручения, ДЕНЬ) = НАЧАЛОПЕРИОДА(&ДатаИсполненияПоручения, ДЕНЬ)
					|	И Поручение.КодОтчетаНРД = &КодОтчетаНРД
					|	И Поручение.ВидОперацииД = &Погашение";
					
					Запрос.УстановитьПараметр("ДатаИсполненияПоручения", ДатаОтчета);
					Запрос.УстановитьПараметр("КодОтчетаНРД", НомерОтчета);
					Запрос.УстановитьПараметр("Погашение", Справочники.ВидыОпераций.Погашение);
					
					Результат = Запрос.Выполнить();
					
					Если Результат.Пустой() Тогда
						
						НовоеПоручение = Документы.Поручение.СоздатьДокумент();
						НовоеПоручение.Дата = ДатаОтчета;
						НовоеПоручение.ДатаИсполненияПоручения = НовоеПоручение.Дата + 1;
						НовоеПоручение.ДатаИсполненияПорученияВДепозитарииМХ = НовоеПоручение.ДатаИсполненияПоручения;
						НовоеПоручение.ДатаИсполненияПорученияВМестеРасчетов = НовоеПоручение.ДатаИсполненияПоручения;
						НовоеПоручение.КодОтчетаНРД = НомерОтчета;
						НовоеПоручение.ВидОперацииД = Справочники.ВидыОпераций.Погашение;
						НовоеПоручение.Инициатор = Константы.МестоХраненияПоУмолчанию.Получить(); 
						НовоеПоручение.Автор = ПараметрыСеанса.ТекущийПользователь;
						
						ОстаткиСовпадают = Истина;
						ТекстОшибки = "";
						
						Если ЗначениеЗаполнено(ДанныеФайлов.ДанныеПоВсемЦБ) Тогда
							Для Каждого ДанныеПоЦБ Из ДанныеФайлов.ДанныеПоВсемЦБ Цикл
								
								ЦБ = Справочники.ЦенныеБумаги.ЦеннаяБумагаПоКодуЗагрузкиНДЦ(ДанныеПоЦБ.КодВНРД, ДатаОтчета);
								Если ЦБ.Пустая() Тогда
									Продолжить;
								КонецЕсли;
								
								РазделСчетаДепоМХ = Справочники.РазделыСчетаДепоМХ.НайтиПоКоду(ДанныеПоЦБ.КодРаздела);
								СчетДепоМХ = РазделСчетаДепоМХ.Владелец;
								
								ОстаткиЦБ = ОстаткиПоЦБ(КонецДня(ДатаОтчета), ЦБ, СчетДепоМХ, РазделСчетаДепоМХ);
								
								Если ОстаткиЦБ.Количество() > 0 Тогда
									Для каждого СтрокаОстаток Из ОстаткиЦБ Цикл
										
										НовСтрока = НовоеПоручение.ЦенныеБумагиСписываемые.Добавить();
										НовСтрока.ЦеннаяБумага = ЦБ;
										
										НовСтрока.РазделСчетаДепоМХ = РазделСчетаДепоМХ;
										НовСтрока.СчетДепоМХ = СчетДепоМХ;
										НовСтрока.СчетДепо = СтрокаОстаток.СчетДепо;
										НовСтрока.РазделСчетаДепо = СтрокаОстаток.РазделСчетаДепо;
										НовСтрока.Количество = СтрокаОстаток.Количество;
										
									КонецЦикла; 
									
									КоличествоЦБ = ОстаткиЦБ.Итог("Количество");
								Иначе
									НовСтрока = НовоеПоручение.ЦенныеБумагиСписываемые.Добавить();
									НовСтрока.ЦеннаяБумага = ЦБ;
									
									НовСтрока.РазделСчетаДепоМХ = РазделСчетаДепоМХ;
									НовСтрока.СчетДепоМХ = СчетДепоМХ;
									НовСтрока.Количество = -ДанныеПоЦБ.Количество;
									
									КоличествоЦБ = 0;
								КонецЕсли;
								
								Если КоличествоЦБ <> -Число(ДанныеПоЦБ.Количество) Тогда
									ОстаткиСовпадают = Ложь;
									ТекстОшибки = ТекстОшибки + Символы.ПС + "ЦБ """ + ДанныеПоЦБ.КодВНРД + """ на счете """ + РазделСчетаДепоМХ.Код;
								КонецЕсли;
							КонецЦикла;
							
						КонецЕсли;
						
						Если НовоеПоручение.ЦенныеБумагиСписываемые.Количество() > 0 Тогда
							НовоеПоручение.ЦБ = НовоеПоручение.ЦенныеБумагиСписываемые[0].ЦеннаяБумага;
						КонецЕсли;
						
						НовоеПоручение.КоличествоЦБ = НовоеПоручение.ЦенныеБумагиСписываемые.Итог("Количество");
						
						Если ОстаткиСовпадают Тогда
							НовоеПоручение.Записать(РежимЗаписиДокумента.Проведение);
						Иначе
							НовоеПоручение.Записать(РежимЗаписиДокумента.Запись);
							
							ЗаписьЖурналаРегистрации("Загрузка отчета о погашении ЦБ",
							УровеньЖурналаРегистрации.Предупреждение,
							Метаданные.Документы.Поручение,
							НовоеПоручение.Ссылка,
							"Не совпадает количество ЦБ по отчету НРД : " + ТекстОшибки);
						КонецЕсли;
						
					КонецЕсли;
					
				ИначеЕсли ТипОтчета = "14" Тогда
					
					ТехническаяОперация = Документы.ТехническаяОперация.НайтиДокумент(
					Новый Структура("РегистрационныйНомер, КодОперации", РегистрационныйНомер, ТипОтчета));
					Если ЗначениеЗаполнено(ТехническаяОперация) Тогда
						ТехническаяОперацияОбъект = ТехническаяОперация.ПолучитьОбъект();
					Иначе
						ТехническаяОперацияОбъект = Документы.ТехническаяОперация.СоздатьДокумент();
					КонецЕсли;
					ТехническаяОперацияОбъект.Номер						= Формат(ИдентификаторОтчета, "ЧГ=0");
					ТехническаяОперацияОбъект.Дата						= ТекущаяДатаСеанса();
					ТехническаяОперацияОбъект.РегистрационныйНомер		= РегистрационныйНомер;
					ТехническаяОперацияОбъект.РегистрационнаяДата		= ДатаРегистрации;
					ТехническаяОперацияОбъект.НомерДокументаОснования	= НомерПоручения;
					ТехническаяОперацияОбъект.ДатаДокументаОснования	= ДатаПоручения;
					ТехническаяОперацияОбъект.КодОтчетаНРД				= НомерОтчета;
					ТехническаяОперацияОбъект.ДатаИсполнения			= ДатаОтчета;
					ТехническаяОперацияОбъект.ТипОперации				= ФормаОтчета;
					ТехническаяОперацияОбъект.КодОперации				= ТипОтчета;
					ТехническаяОперацияОбъект.ПорядковыйНомерВнутриДня	= 1;
					ТехническаяОперацияОбъект.Записать(РежимЗаписиДокумента.Проведение);
					
					ВходящийПакет = Документы.ВходящийПакетИзФайловогоШлюза.НайтиДокумент(
					Новый Структура("НомерВходящегоДокумента, ДатаВходящегоДокумента", НомерОтчета, ДатаОтчета));
					Если ЗначениеЗаполнено(ВходящийПакет) Тогда
						ВходящийПакетОбъект = ВходящийПакет.ПолучитьОбъект();
					Иначе
						ВходящийПакетОбъект = Документы.ВходящийПакетИзФайловогоШлюза.СоздатьДокумент();
					КонецЕсли;
					ВходящийПакетОбъект.Дата						= ТекущаяДатаСеанса();
					ВходящийПакетОбъект.Комментарий				= "Создан автоматически в " + Формат(ТекущаяДатаСеанса(), "ДЛФ=DT");
					ВходящийПакетОбъект.ДокументОснование		= ТехническаяОперацияОбъект.Ссылка;
					ВходящийПакетОбъект.ОтносительныйПуть		= Каталог.Имя;
					ВходящийПакетОбъект.ПолныйПуть				= Файл.Путь;
