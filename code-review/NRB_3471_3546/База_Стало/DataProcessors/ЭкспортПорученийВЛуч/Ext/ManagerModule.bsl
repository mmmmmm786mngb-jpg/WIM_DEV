Функция КоличествоВНРД_XML(ПрочитанныйОбъект, ИменаУзлов, ФормаОтчета)
	КоличествоВНРД = ЗначениеУзлаПоПолномуПути(ПрочитанныйОбъект, ИменаУзлов.КоличествоВНРД1);
	Если КоличествоВНРД = "-00.00" Тогда
		ИмяУзлаКоличествоВНРД2 = ПолноеИмяУзлаСправаОтSplmtryData(ИменаУзлов.КоличествоВНРД2);
		SplmtryData = SplmtryData(ПрочитанныйОбъект, ИменаУзлов, ФормаОтчета);
		КоличествоВНРД = ЗначениеУзлаПоПолномуПути(SplmtryData.Расширение, ИмяУзлаКоличествоВНРД2);
		ИменаУзлов.КоличествоВНРД = ИменаУзлов.КоличествоВНРД2;
	Иначе
		ИменаУзлов.КоличествоВНРД = ИменаУзлов.КоличествоВНРД1;
	КонецЕсли;
	Возврат СтроковыеФункцииКлиентСервер.ЧислоИзСтроки(КоличествоВНРД);
КонецФункции

Функция ТребуетсяСоздатьПоручениеНаОтменуXML(ПричинаОтмены)
	Если Лев(ПричинаОтмены, 32) = "Истек срок исполнения поручения." Тогда
		Возврат Истина;
	Иначе
		Возврат Ложь;
	КонецЕсли;
КонецФункции

Функция ПричинаОтменыXML(ПрочитанныйОбъект, ИдентификаторКодаОтчета, ИменаУзлов, ФормаОтчета)
	Если НРег(ИдентификаторКодаОтчета) = "sese.024.001.10" Тогда
		ИменаУзлов.ПричинаОтмены = ИменаУзлов.ПричинаОтмены024;
	КонецЕсли;
	Если НРег(ИдентификаторКодаОтчета) = "seev.034.001.11" Тогда
		ИменаУзлов.ПричинаОтмены = ИменаУзлов.ПричинаОтмены034;
	КонецЕсли;
	ПричинаОтмены = ПричинаОтказаПоИмениУзла(ПрочитанныйОбъект, ИменаУзлов, ФормаОтчета, "ПричинаОтмены", "ПричинаОтменыПоУмолчанию");
	Возврат ПричинаОтмены;
КонецФункции

Функция ПричинаОтказаПоИмениУзла(ПрочитанныйОбъект, ИменаУзлов, ФормаОтчета, ОсновнаяПричинаОтказа, ПричинаОтказаПоУмолчанию)
	ПричинаОтказа = ПервоеЗначениеУзлаПоПолномуПутиСоСписками(ПрочитанныйОбъект, ИменаУзлов[ОсновнаяПричинаОтказа]);
	Если ПричинаОтказа = Неопределено Или ТипЗнч(ПричинаОтказа) = Тип("ОбъектXDTO") Тогда
		ИмяУзлаПричинаПоУмолчанию = ПолноеИмяУзлаСправаОтSplmtryData(ИменаУзлов[ПричинаОтказаПоУмолчанию]);
		SplmtryData = SplmtryData(ПрочитанныйОбъект, ИменаУзлов, ФормаОтчета);
		ПричинаОтказа = ПервоеЗначениеУзлаПоПолномуПутиСоСписками(SplmtryData.Расширение, ИмяУзлаПричинаПоУмолчанию);
		ИменаУзлов[ОсновнаяПричинаОтказа] = ИменаУзлов[ПричинаОтказаПоУмолчанию];
	КонецЕсли;
	Возврат ПричинаОтказа;
КонецФункции

Функция НайденныйИдентификаторРаздела(ПрочитанныйОбъект, ИмяУзлаРазделаМХ)
	ИдентификаторРазделаПолный = ЗначениеУзлаПоПолномуПути(ПрочитанныйОбъект, ИмяУзлаРазделаМХ);
	ПоследняяПозиция = СтрНайти(ИдентификаторРазделаПолный, "/", НаправлениеПоиска.СКонца);
	ИдентификаторРаздела = Сред(ИдентификаторРазделаПолный, ПоследняяПозиция + 1);
	Возврат ИдентификаторРаздела;
КонецФункции

Функция ДанныеПоВсемЦБ_XML(ПрочитанныйОбъект, ИменаУзлов)
	ДанныеПоВсемЦБ = Новый Массив;
	ПроводкиПоОперациям = ЗначениеУзлаПоПолномуПути(ПрочитанныйОбъект, ИменаУзлов.ПроводкиПоОперациям);
	ПроводкиПоОперациям = МассивОбъектовXDTO(ПроводкиПоОперациям);
	Для Каждого ПроводкаПоОперации Из ПроводкиПоОперациям Цикл
		ПроводкиПоСчетамДепо = МассивОбъектовXDTO(ПроводкаПоОперации.AcctSctiesSttlmTxDtls);
		Для Каждого ПроводкаПоСчетуДепо Из ПроводкиПоСчетамДепо Цикл
			ПроводкиПоРазделамСчетаДепо = МассивОбъектовXDTO(ПроводкаПоСчетуДепо.SctnSctiesSttlmTxDtls);
			Для Каждого ПроводкаПоРазделуСчетаДепо Из ПроводкиПоРазделамСчетаДепо Цикл
				ДанныеПоЦБ = Новый Структура("КодВНРД, КодРаздела, Количество");
				ДанныеПоКодамЦБ = МассивОбъектовXDTO(ПроводкаПоРазделуСчетаДепо.FinInstrmId.OthrId);
				ДанныеПоЦБ.КодВНРД = КодВНРД(ДанныеПоКодамЦБ);
				ДанныеПоЦБ.КодРаздела = ПроводкаПоРазделуСчетаДепо.Sctn.Id;
				НаправлениеДвижения = ПроводкаПоРазделуСчетаДепо.SctiesMvmntTp;
				Знак = ?(НаправлениеДвижения = "DELI", "-", "");
				ДанныеПоЦБ.Количество = Знак + ПроводкаПоРазделуСчетаДепо.SttldQty.Qty.Unit;
				ДанныеПоВсемЦБ.Добавить(ДанныеПоЦБ);
			КонецЦикла;
		КонецЦикла;
	КонецЦикла;
	Возврат ДанныеПоВсемЦБ;
КонецФункции

Функция КодВНРД(ДанныеПоКодамЦБ)
	КодВНРД = "";
	Для Каждого ДанныеПоКодуЦБ Из ДанныеПоКодамЦБ Цикл
		Если ДанныеПоКодуЦБ.Tp.Prtry = "NSDR" Тогда
			КодВНРД = ДанныеПоКодуЦБ.Id;
			Прервать;
		КонецЕсли;
	КонецЦикла;
	Возврат КодВНРД;
КонецФункции

