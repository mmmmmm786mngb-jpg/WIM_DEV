Функция ВыгрузитьПоСхеме(Поручение) Экспорт
	Ошибка = Новый Структура("СообщениеПользователю,СообщениеВЖурнал,Данные");
	
	МакетОтображения = Поручение.ВидПоручения.НастройкиОтображения.Получить();
	Если МакетОтображения = Неопределено Тогда
		Ошибка.СообщениеВЖурнал = "Не найден шаблон для выгрузки поручения.";
		Ошибка.Данные = Поручение;
		Ошибка.СообщениеПользователю = Строка(Поручение.Ссылка) + ": " + Ошибка.СообщениеВЖурнал;// + " " + ВнешнийИсточникФайловыйШлюзКаталогКОтправке;
		Возврат Ошибка;
	КонецЕсли; 
	
	СквознойИдентификаторВызова = Строка(Новый УникальныйИдентификатор);
	
	ВебСервисПространствоИмен = "http://www.vtbcapital-broker.com/depo/FunctionalElectronicDocuments";
	
	DocumentsRequestType = ФабрикаXDTO.Тип(ВебСервисПространствоИмен, "SendFunctionalElectronicDocumentsRequestType");
	DocumentMessageType  = ФабрикаXDTO.Тип(ВебСервисПространствоИмен, "FunctionalElectronicDocumentMessageType");
	
	DocumentsRequest  = ФабрикаXDTO.Создать(DocumentsRequestType);
	DocumentMessage   = ФабрикаXDTO.Создать(DocumentMessageType);

	//чтение макета
	ТаблицаРеквизитов = Новый ТаблицаЗначений;
	ТаблицаРеквизитов.Колонки.Добавить("ИмяБлока");
	ТаблицаРеквизитов.Колонки.Добавить("ИмяПоля");
	ТаблицаРеквизитов.Колонки.Добавить("ИмяТаблицы");
	ТаблицаРеквизитов.Колонки.Добавить("ИмяСтрокиТаблицы");
	ТаблицаРеквизитов.Колонки.Добавить("ИмяРеквизита");
	ТаблицаРеквизитов.Колонки.Добавить("ФорматнаяСтрока");
	ТаблицаРеквизитов.Колонки.Добавить("ЭтоТаблица");
	ТаблицаРеквизитов.Колонки.Добавить("Обязательное");
	
	НомераКолонок = Новый Соответствие;
	НомераКолонок.Вставить("Значение", 5);
	НомераКолонок.Вставить("Блок", 1);
	НомераКолонок.Вставить("ПолеБлока", 4);
	НомераКолонок.Вставить("Таблица", 2);
	НомераКолонок.Вставить("ПолеТаблицы", 3);
	НомераКолонок.Вставить("Обязательное", 11);
	
	Для НомерСтроки = 2 По МакетОтображения.ВысотаТаблицы Цикл
		ИмяБлока = МакетОтображения.Область("R" + НомерСтроки + "C" + НомераКолонок["Блок"]).Текст;
		ИмяПоля = МакетОтображения.Область("R" + НомерСтроки + "C" + НомераКолонок["ПолеБлока"]).Текст;
		ИмяТаблицы = МакетОтображения.Область("R" + НомерСтроки + "C" + НомераКолонок["Таблица"]).Текст;
		ИмяСтрокиТаблицы = МакетОтображения.Область("R" + НомерСтроки + "C" + НомераКолонок["ПолеТаблицы"]).Текст;
		ИмяРеквизита = МакетОтображения.Область("R" + НомерСтроки + "C" + НомераКолонок["Значение"]).Текст;
		ФорматнаяСтрока = МакетОтображения.Область("R" + НомерСтроки + "C" + НомераКолонок["Значение"]).Формат;
		Обязательное = МакетОтображения.Область("R" + НомерСтроки + "C" + НомераКолонок["Обязательное"]).Текст;
		
		НовСтрока = ТаблицаРеквизитов.Добавить();
		НовСтрока.ИмяБлока = ИмяБлока;
		НовСтрока.ИмяПоля = ИмяПоля;
		НовСтрока.ИмяТаблицы = ИмяТаблицы;
		НовСтрока.ИмяСтрокиТаблицы = ИмяСтрокиТаблицы;
		НовСтрока.ИмяРеквизита = ИмяРеквизита;
		НовСтрока.ФорматнаяСтрока = ФорматнаяСтрока;
		НовСтрока.ЭтоТаблица = ЗначениеЗаполнено(ИмяСтрокиТаблицы);
		НовСтрока.Обязательное = ВРЕГ(Обязательное) = "ДА";

	КонецЦикла;	
	
	СКД = Поручение.ВидПоручения.СхемаКомпоновкиДанных.Получить();
	Если СКД = Неопределено Тогда
		СКД = Справочники.ВидыИнвентарныхПоручений.ПолучитьМакет("РеквизитыПоручения");
	КонецЕсли; 
	
	Для каждого НаборДанных Из СКД.НаборыДанных Цикл
		
		Если Найти(НаборДанных.Имя, "ТЧ_") > 0 Тогда
			ТекстОшибки = ЗаполнитьТаблицуБлока(Поручение, СКД, DocumentMessage, ТаблицаРеквизитов, НаборДанных.Имя);
		Иначе
			ТекстОшибки = ЗаполнитьБлок(Поручение, СКД, DocumentMessage, ТаблицаРеквизитов, НаборДанных.Имя);
		КонецЕсли;	
		
		Если ТекстОшибки <> "" Тогда
			Ошибка.СообщениеВЖурнал = ТекстОшибки;
			Ошибка.Данные = Поручение;
			Ошибка.СообщениеПользователю = Строка(Поручение.Ссылка) + ": " + ТекстОшибки;// + " " + ВнешнийИсточникФайловыйШлюзКаталогКОтправке;
			Возврат Ошибка;	
		КонецЕсли; 
	КонецЦикла; 
	
	//СтруктураВозврата = Новый Структура("ТекстДокумента, Ошибка");
	
	СоответствиеРеквизитовОбъекта = ОбщегоНазначения.ПолучитьСоответствиеРеквизитовОбъектаПоУмолчанию("Обработка.ЭкспортПорученийВЛуч", "Номера версий", , Поручение.Дата);
	НомераВерсий = СоответствиеРеквизитовОбъекта["НомераВерсий"];
	
	Если НомераВерсий <> Неопределено Тогда
		НайденныеСтроки = НомераВерсий.НайтиСтроки(Новый Структура("КодОперации", Поручение.ВидПоручения.Код));
		Если НайденныеСтроки.Количество() = 1 Тогда
			НомерВерсии = СокрЛП(НайденныеСтроки[0].НомерВерсии);
		Иначе
			Ошибка.СообщениеВЖурнал = "Не удалось определить номер версии для кода операции " + Поручение.ВидПоручения.Код;
			Ошибка.Данные = Поручение;
			Ошибка.СообщениеПользователю = Ошибка.СообщениеВЖурнал;// + " " + ВнешнийИсточникФайловыйШлюзКаталогКОтправке;
			Возврат Ошибка;
			//СтруктураВозврата.Ошибка = "Не удалось определить номер версии для кода операции " + Поручение.ВидПоручения.Код;
			//СтруктураВозврата.ТекстДокумента = "";
			//Возврат;
		КонецЕсли;
	Иначе
		Ошибка.СообщениеВЖурнал = "Не найдены номера версий для эскпорта поручений в Луч";
		Ошибка.Данные = Поручение;
		Ошибка.СообщениеПользователю = Ошибка.СообщениеВЖурнал;// + " " + ВнешнийИсточникФайловыйШлюзКаталогКОтправке;
		Возврат Ошибка;
		//СтруктураВозврата.Ошибка = "Не найдены номера версий для эскпорта поручений в Луч";
		//СтруктураВозврата.ТекстДокумента = "";
		//Возврат;
	КонецЕсли; 
	
	//Ошибка = Новый Структура("СообщениеПользователю,СообщениеВЖурнал,Данные");
	
	Запись = Новый ЗаписьXML;
	Запись.УстановитьСтроку("Windows-1251");
	Запись.ЗаписатьОбъявлениеXML();
	
	Запись.ЗаписатьНачалоЭлемента("Batch");
	ЗаписатьЭлементXML(Запись, "Documents_amount", "1");
	
	Запись.ЗаписатьНачалоЭлемента("Document");
	Запись.ЗаписатьАтрибут("DOC_ID"		, "1");
	Запись.ЗаписатьАтрибут("version"	, НомерВерсии);
	
	ВсеИменаБлоков = Новый Массив;
	ИмяБлокаORDER_HEADER = "ORDER_HEADER";
	МассивФорматов = Новый Структура;
	Для каждого СтрокаРеквизит Из ТаблицаРеквизитов Цикл
		Если СтрокаРеквизит.ФорматнаяСтрока <> "" Тогда
			МассивФорматов.Вставить(СтрокаРеквизит.ИмяПоля, СтрокаРеквизит.ФорматнаяСтрока);
		КонецЕсли; 
		
		Если ЗначениеЗаполнено(СтрокаРеквизит.ИмяБлока)
			И ВсеИменаБлоков.Найти(СтрокаРеквизит.ИмяБлока) = Неопределено Тогда
			ВсеИменаБлоков.Добавить(СтрокаРеквизит.ИмяБлока);
		КонецЕсли;
		
	КонецЦикла; 
	
	ЗаписатьБлокXML(Запись, DocumentMessage.Order_Header, ИмяБлокаORDER_HEADER, МассивФорматов);
	
	OrderType = Строка(Поручение.ВидПоручения.ФорматПоручения);
	ЗаписатьБлокXML(Запись, DocumentMessage[OrderType], OrderType, МассивФорматов);
	
	Для Каждого ИмяБлока Из ВсеИменаБлоков Цикл
		Если ИмяБлока = ИмяБлокаORDER_HEADER Или ИмяБлока = OrderType Тогда
			Продолжить;
		КонецЕсли;
		
		ЗаписатьБлокXML(Запись, DocumentMessage[ИмяБлока], ИмяБлока, МассивФорматов);
	КонецЦикла;
	
	Запись.ЗаписатьКонецЭлемента(); //Document
	Запись.ЗаписатьКонецЭлемента(); //Batch
	
	ТекстДокумента = Запись.Закрыть();
	
	РегистрыСведений.СообщенияОбменаСоСмежнымиСистемами.ДобавитьЗапись(СквознойИдентификаторВызова, "FunctionalElectronicDocuments", "SendFunctionalElectronicDocuments", "Исходящее", ТекстДокумента);
	
	//ИсходящийНомер = "D"+СокрЛП(Сред(Поручение.Номер, 2));
	ИсходящийНомер = ФорматИсходящегоНомера(СокрЛП(Поручение.Номер), ?(Поручение.Метаданные() = Метаданные.Документы.НеттоПоручение, "N", "D"));
	Ошибка = Обработки.ЭкспортПорученийВЛуч.СформироватьИсходящийПакетВФайловыйШлюз(ИсходящийНомер, Поручение.Дата, Строка(Поручение.ВидПоручения.ФорматПоручения), Поручение.ВидПоручения.Код, Поручение, ТекстДокумента);
	
	Если ЗначениеЗаполнено(Ошибка) Тогда
		Возврат Ошибка;
	КонецЕсли;

КонецФункции
 
Функция ЗаполнитьБлок(Поручение, СКД, DocumentMessage, ТаблицаРеквизитов, ИмяНабораДанных)
	
	ТаблицаБлоков = ТаблицаРеквизитов.Скопировать(, "ИмяБлока");
	ТаблицаБлоков.Свернуть("ИмяБлока");
	
	НаборДанных = СКД.НаборыДанных[ИмяНабораДанных];
	
	Запрос = Новый Запрос(НаборДанных.Запрос);
	Запрос.УстановитьПараметр("Сделка", Поручение);
	Запрос.УстановитьПараметр("Дата", ТекущаяДата());
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
		Для каждого СтрокаБлок Из ТаблицаБлоков Цикл
			ИмяБлока = СтрокаБлок.ИмяБлока;
			
			СвойствоБлок = DocumentMessage.Свойства().Получить(ИмяБлока);
			Если СвойствоБлок = Неопределено Тогда
				Продолжить;
			КонецЕсли;	
			
			ТекущийБлок = ФабрикаXDTO.Создать(СвойствоБлок.Тип);	
			
			МассивРеквизитов = ТаблицаРеквизитов.НайтиСтроки(Новый Структура("ИмяБлока, ЭтоТаблица", ИмяБлока, Ложь));
			Для каждого СтрокаРеквизит Из МассивРеквизитов Цикл
				ИмяРеквизита = СтрокаРеквизит.ИмяРеквизита;
				
				Если ИмяРеквизита = "" Тогда
					Продолжить;
				КонецЕсли;
				
				Если Найти(ИмяРеквизита, "[") > 0 И Найти(ИмяРеквизита, "]") > 0 Тогда
					ТекстВыражения = СтрЗаменить(ИмяРеквизита, "[", "Выборка[""");
					ТекстВыражения = СтрЗаменить(ТекстВыражения, "]", """]");
					Попытка
						Значение = Вычислить(ТекстВыражения);
					Исключение
						Значение = "";
						//Сообщить("Ошибка при вычислении поля """ + ИмяРеквизита + """ для заполнения реквизита """ + СтрокаРеквизит.ИмяПоля + """");
						Возврат "Ошибка при вычислении поля """ + ИмяРеквизита + """ для заполнения реквизита """ + СтрокаРеквизит.ИмяПоля + """";
					КонецПопытки;
					
					Если ЗначениеЗаполнено(Значение) Тогда
						ТекущийБлок[СтрокаРеквизит.ИмяПоля] = Значение;
					Иначе 
						Если СтрокаРеквизит.Обязательное Тогда
							Возврат "Не заполнено обязательное поле """ + СтрокаРеквизит.ИмяПоля + """. Выгрузка отменена.";
						КонецЕсли; 
					КонецЕсли;
				Иначе
					ТекущийБлок[СтрокаРеквизит.ИмяПоля] = ИмяРеквизита;
				КонецЕсли;
				
			КонецЦикла; 
			
			DocumentMessage[СтрокаБлок.ИмяБлока] = ТекущийБлок;
			
		КонецЦикла; 
		
	КонецЕсли; 
	
	Возврат "";
КонецФункции
 
Функция ЗаполнитьТаблицуБлока(Поручение, СКД, DocumentMessage, ТаблицаРеквизитов, ИмяНабораДанных)
	ТаблицаБлоков = ТаблицаРеквизитов.Скопировать(, "ИмяБлока");
	ТаблицаБлоков.Свернуть("ИмяБлока");
	
	НаборДанных = СКД.НаборыДанных[ИмяНабораДанных];
	
	ПапкиНабораДанных = Новый массив;
	Для каждого Поле Из НаборДанных.Поля Цикл
		Если ТипЗнч(Поле) = Тип("ПапкаПолейНабораДанныхСхемыКомпоновкиДанных") Тогда
			ПапкиНабораДанных.Добавить(Поле.Заголовок);
		КонецЕсли; 
	КонецЦикла;
	
	Запрос = Новый Запрос(НаборДанных.Запрос);
	Запрос.УстановитьПараметр("Сделка", Поручение);
	Запрос.УстановитьПараметр("Дата", ТекущаяДата());
	Запрос.УстановитьПараметр("ЭтоНеторговоеПоручениеСоСпискомЦБ", Документы.Поручение.ЭтоНеторговоеПоручениеСоСпискомЦБ(Поручение));
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		СтрокаДобавлена = Ложь;
		
		Для каждого СтрокаБлок Из ТаблицаБлоков Цикл
			ИмяБлока = СтрокаБлок.ИмяБлока;
			
			СвойствоБлок = DocumentMessage.Свойства().Получить(ИмяБлока);
			Если СвойствоБлок = Неопределено Тогда
				Продолжить;
			КонецЕсли;	
			
			Если DocumentMessage[ИмяБлока] = Неопределено Тогда
				ТекущийБлок = ФабрикаXDTO.Создать(СвойствоБлок.Тип);	
			Иначе
				ТекущийБлок = DocumentMessage[ИмяБлока];	
			КонецЕсли; 
			
			МассивРеквизитов = ТаблицаРеквизитов.НайтиСтроки(Новый Структура("ИмяБлока, ЭтоТаблица", ИмяБлока, Истина));
			Для каждого СтрокаРеквизит Из МассивРеквизитов Цикл
				ИмяРеквизита = СтрокаРеквизит.ИмяРеквизита;
				
				Если ИмяРеквизита = "" Тогда
					Продолжить;
				КонецЕсли;
				
				Если ПапкиНабораДанных.Найти(СтрокаРеквизит.ИмяТаблицы) = Неопределено Тогда
					Продолжить;
				КонецЕсли; 
				
				ИмяПоля = ИмяРеквизита;
				ИмяПоля = СтрЗаменить(ИмяПоля, "[", "");
				ИмяПоля = СтрЗаменить(ИмяПоля, "]", "");
				
				//ПолеНабораДанных = НаборДанных.Поля.Найти(ИмяПоля);
				//Если ПолеНабораДанных = Неопределено Тогда
				//	//Сообщить("Не найдено поле компоновки данных """ + ИмяРеквизита + """ для заполнения реквизита """ + СтрокаРеквизит.ИмяПоля + """");					
				//	Продолжить;
				//КонецЕсли; 
				
				ИмяТаблицы = СтрокаРеквизит.ИмяТаблицы;
				СвойствоТаблица = ТекущийБлок.Свойства().Получить(ИмяТаблицы);
				Если СвойствоТаблица = Неопределено Тогда
					Продолжить;
				КонецЕсли;
				
				Если ТекущийБлок[ИмяТаблицы] = Неопределено Тогда
					ТекущаяТаблица = ФабрикаXDTO.Создать(СвойствоТаблица.Тип);	
				Иначе
					ТекущаяТаблица = ТекущийБлок[ИмяТаблицы];	
				КонецЕсли;	
				
				ИмяСтрокиТаблицы = СтрокаРеквизит.ИмяСтрокиТаблицы; 
				СвойствоСтрокаТаблицы = ТекущаяТаблица.Свойства().Получить(ИмяСтрокиТаблицы);
				Если СвойствоСтрокаТаблицы = Неопределено Тогда
					Продолжить;
				КонецЕсли; 
				
				Если НЕ СтрокаДобавлена Тогда
					ТекущаяСтрокаТаблицы = ФабрикаXDTO.Создать(СвойствоСтрокаТаблицы.Тип);	
				Иначе
					КоличествоСтрок = ТекущаяТаблица[ИмяСтрокиТаблицы].Количество();
					ТекущаяСтрокаТаблицы = ТекущаяТаблица[ИмяСтрокиТаблицы][КоличествоСтрок - 1];
				КонецЕсли; 
				
				ИмяРеквизита = СтрЗаменить(ИмяРеквизита, ИмяНабораДанных + ".", "");
				
				Если Найти(ИмяРеквизита, "[") > 0 И Найти(ИмяРеквизита, "]") > 0 Тогда
					ТекстВыражения = СтрЗаменить(ИмяРеквизита, "[", "Выборка[""");
					ТекстВыражения = СтрЗаменить(ТекстВыражения, "]", """]");
					Попытка
						Значение = Вычислить(ТекстВыражения);
					Исключение
						Значение = "";
						//Сообщить("Ошибка при вычислении поля """ + ИмяРеквизита + """ для заполнения реквизита """ + СтрокаРеквизит.Заголовок + """");
						Возврат "Ошибка при вычислении поля """ + ИмяРеквизита + """ для заполнения реквизита """ + СтрокаРеквизит.Заголовок + """";
					КонецПопытки;
					
					Если ЗначениеЗаполнено(Значение) Тогда
						Если Найти(Значение, "[") > 0 Тогда
							ТекстВыражения = Значение;
							ТекстВыражения = СтрЗаменить(ТекстВыражения, "[", "Выборка.Поручение[");
							Попытка
								Значение = Вычислить(ТекстВыражения);
							Исключение
								Значение = "";
							КонецПопытки;
						КонецЕсли;
						
						Если ТипЗнч(Значение) = Тип("Строка") Тогда
							Значение = СтрЗаменить(Значение, """", "");
						КонецЕсли;
						
						ТекущаяСтрокаТаблицы[СтрокаРеквизит.ИмяПоля] = Значение;
					Иначе
						Если СтрокаРеквизит.Обязательное Тогда
							Возврат "Не заполнено обязательное поле таблицы """ + ИмяТаблицы + """: " + СтрокаРеквизит.ИмяПоля + """. Выгрузка отменена.";
						КонецЕсли;
					КонецЕсли; 
					
				Иначе
					ТекущаяСтрокаТаблицы[СтрокаРеквизит.ИмяПоля] = ИмяРеквизита;
				КонецЕсли;
				
				Если НЕ СтрокаДобавлена Тогда
					ТекущаяТаблица[ИмяСтрокиТаблицы].Добавить(ТекущаяСтрокаТаблицы);
				КонецЕсли; 
				
				ТекущийБлок[ИмяТаблицы] = ТекущаяТаблица;	
				
				СтрокаДобавлена = Истина;
			КонецЦикла; 
			
			DocumentMessage[СтрокаБлок.ИмяБлока] = ТекущийБлок;
			
		КонецЦикла; 
		
	КонецЦикла; 
	
	Возврат "";
КонецФункции

Процедура ЗаписатьБлокXML(Запись, Источник, Имя, МассивФорматов)
	Запись.ЗаписатьНачалоЭлемента(Имя);
	Для каждого Свойство Из Источник.Свойства() Цикл
		Если Источник[Свойство.Имя] = Неопределено Тогда
			Продолжить;
		КонецЕсли; 
		
		Если ТипЗнч(Источник[Свойство.Имя]) = Тип("ОбъектXDTO") Тогда
			ЗаписатьБлокXML(Запись, Источник[Свойство.Имя], Свойство.Имя, МассивФорматов);
			
		ИначеЕсли ТипЗнч(Источник[Свойство.Имя]) = Тип("СписокXDTO") Тогда
			
			Для каждого ЭлементСписка Из Источник[Свойство.Имя] Цикл
				Запись.ЗаписатьНачалоЭлемента(Свойство.Имя);
				Для каждого СвойствоСписка Из ЭлементСписка.Свойства() Цикл
					Если ЭлементСписка[СвойствоСписка.Имя] = Неопределено Тогда
						Продолжить;
					КонецЕсли; 
					
					ЗаписатьЭлементXML(Запись, СвойствоСписка.Имя,  ЭлементСписка[СвойствоСписка.Имя], МассивФорматов);
					
				КонецЦикла; 
				Запись.ЗаписатьКонецЭлемента();
			КонецЦикла; 
			
		Иначе
			Если Источник[Свойство.Имя] <> Неопределено Тогда
				ЗаписатьЭлементXML(Запись, Свойство.Имя, Источник[Свойство.Имя], МассивФорматов);
			КонецЕсли;
		КонецЕсли; 
	КонецЦикла;
	Запись.ЗаписатьКонецЭлемента(); //Имя
КонецПроцедуры

Процедура ЗаписатьЭлементXML(ЗаписьXML, Тег, Значение, МассивФорматов = Неопределено)
	ФорматнаяСтрока = "";
	Если МассивФорматов <> Неопределено Тогда
		Если МассивФорматов.Свойство(Тег) Тогда
			ФорматнаяСтрока = МассивФорматов[Тег];
		КонецЕсли;	
	КонецЕсли; 
	
	ЗаписьXML.ЗаписатьНачалоЭлемента(Строка(Тег));						// Начало элемента
	//ЗаписьXML.ЗаписатьТекст(СтрЗаменить(Строка(Значение), " ", ""));	// Значение элемента
	Если ФорматнаяСтрока = "" Тогда
		ЗаписьXML.ЗаписатьТекст(СокрЛП(Строка(Значение)));					// Значение элемента
	Иначе
		ЗаписьXML.ЗаписатьТекст(Формат(Значение, ФорматнаяСтрока));					// Значение элемента
	КонецЕсли; 
	
	ЗаписьXML.ЗаписатьКонецЭлемента();									// Конец элемента
КонецПроцедуры

Функция ФорматИсходящегоНомера(Знач Номер, Префикс = "D") Экспорт
	Поз = Найти("0123456789-", Лев(Номер, 1));
	Пока Поз = 0 Цикл
		Номер = Сред(Номер, 2);
		Поз = Найти("0123456789-", Лев(Номер, 1));
	КонецЦикла; 
		
	Возврат Префикс + Номер;
КонецФункции // ФорматИсходящегоНомера()

Функция НовыйДокументыКПеренумерации()
	
	ДокументыКПеренумерации = Новый ТаблицаЗначений;
	ДокументыКПеренумерации.Колонки.Добавить("Ссылка");
	ДокументыКПеренумерации.Колонки.Добавить("Тип", Новый ОписаниеТипов("Строка"));
	ДокументыКПеренумерации.Колонки.Добавить("Дата", Новый ОписаниеТипов("Дата",,, Новый КвалификаторыДаты(ЧастиДаты.Дата)));
	
	Возврат ДокументыКПеренумерации;
	
КонецФункции

Функция СозданныеДокументыПоТипам(СозданныеДокументы)
	
	ПодчиненныеДокументы = НовыйДокументыКПеренумерации();
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицуИзМассива(ПодчиненныеДокументы, СозданныеДокументы, "Ссылка");
	
	Для Каждого СозданныйДокумент из СозданныеДокументы Цикл
		
		Если ТипЗнч(СозданныйДокумент) = Тип("ДокументСсылка.НеттоПоручение") Тогда
			
			Для каждого ВходящийДокумент из СозданныйДокумент.Поручения Цикл
				ПодчиненныеДокументы.Добавить().Ссылка = ВходящийДокумент.Поручение;
				Подчиненные = КритерииОтбора.СтруктураПодчиненности.Найти(ВходящийДокумент.Поручение);
				ОбщегоНазначенияКлиентСервер.ДополнитьТаблицуИзМассива(ПодчиненныеДокументы, Подчиненные, "Ссылка");
			КонецЦикла;
			
		ИначеЕсли ТипЗнч(СозданныйДокумент) = Тип("ДокументСсылка.Поручение") Тогда
			Подчиненные = КритерииОтбора.СтруктураПодчиненности.Найти(СозданныйДокумент);
			ОбщегоНазначенияКлиентСервер.ДополнитьТаблицуИзМассива(ПодчиненныеДокументы, Подчиненные, "Ссылка");
		КонецЕсли;
				
	КонецЦикла;
	
	Для Каждого СтрокаТаблицы Из ПодчиненныеДокументы Цикл
	
		СтрокаТаблицы.Тип = СтрокаТаблицы.Ссылка.Метаданные().Имя;
		СтрокаТаблицы.Дата = СтрокаТаблицы.Ссылка.Дата;
	
	КонецЦикла;
	
	ПодчиненныеДокументы.Свернуть("Тип,Дата");
	
	//исключем ТехническуюОперацию из перенумерации
	Для Каждого СтрокаНаУдаление Из ПодчиненныеДокументы.НайтиСтроки(Новый Структура("Тип", "ТехническаяОперация")) Цикл
		ПодчиненныеДокументы.Удалить(СтрокаНаУдаление);	
	КонецЦикла;
	
	Возврат ПодчиненныеДокументы;

	
КонецФункции

Процедура ПеренумероватьДокументы(ДокументыПоТипам)
		
	Если Не ЗначениеЗаполнено(ДокументыПоТипам) Тогда
	
		Возврат;	
	
	КонецЕсли;
	
	ДатыДокументов = ДокументыПоТипам.Скопировать();
	ДатыДокументов.Свернуть("Дата");
	
	Перенумератор = Обработки.ПеренумерацияДокументов.Создать();
	
	Для каждого СтрокаТаблицыДат Из ДатыДокументов Цикл
	
		ДокументыЗаДату = ДокументыПоТипам.Скопировать(ДокументыПоТипам.НайтиСтроки(Новый Структура("Дата", СтрокаТаблицыДат.Дата)));
		
		Для каждого ВидДокументаЗаДату Из ДокументыЗаДату Цикл
		
			РегистрыСведений.РегистрацияДокументовКПеренумерации.ЗарегистрироватьДокументыКПеренумерации(ВидДокументаЗаДату.Тип, ВидДокументаЗаДату.Дата);	
						
		КонецЦикла; 
		
		Выборка = РегистрыСведений.РегистрацияДокументовКПеренумерации.Выбрать(СтрокаТаблицыДат.Дата, СтрокаТаблицыДат.Дата);
		
		Пока Выборка.Следующий() цикл
			
			СтруктураПоиска = Новый Структура("Тип,Дата", Выборка.ИмяДокумента, Выборка.Период);
			Если ЗначениеЗаполнено(ДокументыЗаДату.НайтиСтроки(СтруктураПоиска)) Тогда 
				
				Попытка
					Перенумератор.ПеренумероватьДокументы(Выборка, Истина);
				Исключение
				КонецПопытки;
				
			КонецЕсли;
		КонецЦикла;
		
	КонецЦикла; 

	
КонецПроцедуры

ПРоцедура Перенумеровать(СозданныеДокументы)

	ДокументыПоТипам = СозданныеДокументыПоТипам(СозданныеДокументы);
	
	ПеренумероватьДокументы(ДокументыПоТипам);
	
КонецПроцедуры

Функция РазрешенныеКодыОперацийДляЭкспорта()
	
	КодыОпераций_ = Новый Массив;
	
	Выборка = Справочники.ВидыИнвентарныхПоручений.Выбрать();
	Пока Выборка.Следующий() Цикл
		Если Не Выборка.ПометкаУдаления Тогда
			КодыОпераций_.Добавить(Выборка.Код);
		КонецЕсли;		
	КонецЦикла;
	
	//добавить статичные
	КодыОпераций_.Добавить("10/50");
	КодыОпераций_.Добавить("10/CA");
	КодыОпераций_.Добавить("10/CA2");
	КодыОпераций_.Добавить("14");
	
	КодыОпераций = Новый Массив;
	ОбщегоНазначения.ЗаполнитьМассивУникальнымиЗначениями(КодыОпераций, КодыОпераций_);
	
	Возврат КодыОпераций;
	
КонецФункции

Процедура ОбработатьРаскрытияСписковВладельцев()
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Выгружено", Перечисления.СтатусыРаскрытияСписковВладельцев.Выгружено);
	Запрос.УстановитьПараметр("Загружено", Перечисления.СтатусыДокументовФайловыйШлюз.ВыгруженоВебКабинет);
	Запрос.УстановитьПараметр("Ошибка", Перечисления.СтатусыДокументовФайловыйШлюз.ОшибкаФайловыйШлюз);
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ВыгрузкаРазделаРСВвВышестоящийДепозитарий.РаскрытиеСпискаВладельцев КАК Раскрытие,
	|	ВыгрузкаРазделаРСВвВышестоящийДепозитарий.Ссылка КАК Выгрузка,
	|	ТехническаяОперация.Ссылка КАК ТехническаяОперация,
	|	ТехническаяОперация.Дата КАК ДатаВыгрузки
	|ПОМЕСТИТЬ втВыгрузки
	|ИЗ
	|	Документ.ВыгрузкаРазделаРСВвВышестоящийДепозитарий КАК ВыгрузкаРазделаРСВвВышестоящийДепозитарий
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ТехническаяОперация КАК ТехническаяОперация
	|		ПО ВыгрузкаРазделаРСВвВышестоящийДепозитарий.Ссылка = ТехническаяОперация.ДокументОснование
	|ГДЕ
	|	ВыгрузкаРазделаРСВвВышестоящийДепозитарий.РаскрытиеСпискаВладельцев.Статус = &Выгружено
	|	И ВыгрузкаРазделаРСВвВышестоящийДепозитарий.ПометкаУдаления = ЛОЖЬ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВыгрузкаРазделаРСВвВышестоящийДепозитарий.Раскрытие КАК РаскрытиеСпискаВладельцев,
	|	СостоянияДокументовВФайловомШлюзеСрезПоследних.Статус КАК Статус,
	|	СостоянияДокументовВФайловомШлюзеСрезПоследних.Пакет КАК Пакет,
	|	СостоянияДокументовВФайловомШлюзеСрезПоследних.Пакет.ОтносительныйПуть КАК ПакетОтносительныйПуть,
	|	СостоянияДокументовВФайловомШлюзеСрезПоследних.Комментарий КАК Комментарий,
	|	ВЫБОР
	|		КОГДА СостоянияДокументовВФайловомШлюзеСрезПоследних.Статус = &Ошибка
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК Отменено,
	|	ВЫБОР
	|		КОГДА ЕСТЬNULL(СостоянияДокументовВФайловомШлюзеСрезПоследних.Статус, &Ошибка) = &Загружено
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК Принято
	|ИЗ
	|	втВыгрузки КАК ВыгрузкаРазделаРСВвВышестоящийДепозитарий
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СостоянияДокументовВФайловомШлюзе.СрезПоследних КАК СостоянияДокументовВФайловомШлюзеСрезПоследних
	|		ПО ВыгрузкаРазделаРСВвВышестоящийДепозитарий.ТехническаяОперация = СостоянияДокументовВФайловомШлюзеСрезПоследних.Документ
	|ГДЕ
	|	ВыгрузкаРазделаРСВвВышестоящийДепозитарий.ТехническаяОперация В
	|			(ВЫБРАТЬ ПЕРВЫЕ 1
	|				втВыгрузки.ТехническаяОперация
	|			ИЗ
	|				втВыгрузки КАК втВыгрузки
	|			ГДЕ
	|				втВыгрузки.Выгрузка = ВыгрузкаРазделаРСВвВышестоящийДепозитарий.Выгрузка
	|			УПОРЯДОЧИТЬ ПО
	|				втВыгрузки.ДатаВыгрузки УБЫВ)
	|ИТОГИ
	|	МАКСИМУМ(Отменено),
	|	МИНИМУМ(Принято)
	|ПО
	|	РаскрытиеСпискаВладельцев";
	Результат = Запрос.Выполнить();
	ВыборкаРаскрытий = Результат.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Пока ВыборкаРаскрытий.Следующий() Цикл
		Если ВыборкаРаскрытий.Отменено Или ВыборкаРаскрытий.Принято Тогда
			Попытка
				Раскрытие = ВыборкаРаскрытий.РаскрытиеСпискаВладельцев.ПолучитьОбъект();
				Раскрытие.Заблокировать();
				Если ВыборкаРаскрытий.Отменено Тогда
					Раскрытие.Статус = Перечисления.СтатусыРаскрытияСписковВладельцев.Отменено;
				ИначеЕсли ВыборкаРаскрытий.Принято Тогда
					Раскрытие.Статус = Перечисления.СтатусыРаскрытияСписковВладельцев.Принято;
				КонецЕсли;
				Раскрытие.Записать(РежимЗаписиДокумента.Проведение);
			Исключение
				ОписаниеОшибки = КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
				Ссылка = ВыборкаРаскрытий.РаскрытиеСпискаВладельцев;
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю(Строка(Ссылка)+" не обработано:"+Символы.ПС+ОписаниеОшибки);
				ЗаписьЖурналаРегистрации("Актуализация статусов РСВ", УровеньЖурналаРегистрации.Информация, Ссылка.Метаданные(), Ссылка, ОписаниеОшибки);
			КонецПопытки;
			Раскрытие = Неопределено;
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

