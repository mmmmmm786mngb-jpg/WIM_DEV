Процедура ДобавитьВыводКодаОснованияОперацииВВидеПоручения_10()
	
	ЗаписатьВидПоручения = Ложь;
	ВидПорученияОбъект = Справочники.ВидыИнвентарныхПоручений.П10.ПолучитьОбъект();
	
	СхемаКомпоновкиДанных = ВидПорученияОбъект.СхемаКомпоновкиДанных.Получить();
	Если ТипЗнч(СхемаКомпоновкиДанных) = Тип("СхемаКомпоновкиДанных") Тогда
		
		ИмяПоляКодОснованияОперации = "КодОснованияОперации";
		ИмяПоляКодОснованияОперацииНаименование = "КодОснованияОперацииНаименование";
		НаборДанныхПоручение = СхемаКомпоновкиДанных.НаборыДанных.Поручение;
		Если НаборДанныхПоручение.Поля.Найти(ИмяПоляКодОснованияОперации) = Неопределено Тогда
		
			ПолеКодОснованияОперации = НаборДанныхПоручение.Поля.Добавить(Тип("ПолеНабораДанныхСхемыКомпоновкиДанных"));
			ПолеКодОснованияОперации.Поле = ИмяПоляКодОснованияОперации;
			ПолеКодОснованияОперации.ПутьКДанным = ИмяПоляКодОснованияОперации;
			ПолеКодОснованияОперации.Заголовок = ИмяПоляКодОснованияОперации;
			
			ПолеКодОснованияОперацииНаименование = НаборДанныхПоручение.Поля.Добавить(Тип("ПолеНабораДанныхСхемыКомпоновкиДанных"));
			ПолеКодОснованияОперацииНаименование.Поле = ИмяПоляКодОснованияОперацииНаименование;
			ПолеКодОснованияОперацииНаименование.ПутьКДанным = ИмяПоляКодОснованияОперацииНаименование;
			ПолеКодОснованияОперацииНаименование.Заголовок = ИмяПоляКодОснованияОперацииНаименование;
			
			СтарыйТекст = "ПОМЕСТИТЬ втДокументыДляОбработки";
			НовыйТекст = "	,
						|	ДокументПоручение.ОснованиеОперацииДКУ.Код КАК КодОснованияОперации,
						|	ДокументПоручение.ОснованиеОперацииДКУ.Наименование КАК КодОснованияОперацииНаименование
						|ПОМЕСТИТЬ втДокументыДляОбработки";
			НаборДанныхПоручение.Запрос = СтрЗаменить(НаборДанныхПоручение.Запрос, СтарыйТекст, НовыйТекст);
			
			СтарыйТекст = "ИЗ
						|	Документ.НеттоПоручение КАК НеттоПоручения";
			НовыйТекст = "	,
						|	"""",
						|	""""
						|ИЗ
						|	Документ.НеттоПоручение КАК НеттоПоручения";
			НаборДанныхПоручение.Запрос = СтрЗаменить(НаборДанныхПоручение.Запрос, СтарыйТекст, НовыйТекст);
			
			СтарыйТекст = "ИЗ
						|	втДокументыДляОбработки КАК Документы";
			НовыйТекст = "	,
						|	Документы.КодОснованияОперации КАК КодОснованияОперации,
						|	Документы.КодОснованияОперацииНаименование КАК КодОснованияОперацииНаименование
						|ИЗ
						|	втДокументыДляОбработки КАК Документы";
			НаборДанныхПоручение.Запрос = СтрЗаменить(НаборДанныхПоручение.Запрос, СтарыйТекст, НовыйТекст);
			
			ВидПорученияОбъект.СхемаКомпоновкиДанных = Новый ХранилищеЗначения(СхемаКомпоновкиДанных);
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("СхемаКомпоновкиДанных обновлена для вида поручения 10");
			ЗаписатьВидПоручения = Истина;
		Иначе
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("СхемаКомпоновкиДанных не нужно обновлять для вида поручения 10");
		КонецЕсли;
		
	КонецЕсли;
	
	НастройкиОтображения = ВидПорученияОбъект.НастройкиОтображения.Получить();
	
	Если ТипЗнч(НастройкиОтображения) = Тип("ТабличныйДокумент") Тогда
		
		Если НастройкиОтображения.НайтиТекст("add_info", , , , Истина) = Неопределено Тогда
		
			МакетП10 = Справочники.ВидыИнвентарныхПоручений.ПолучитьМакет("П10");
			НоваяОбластьСтрока = МакетП10.Область("R2");
			СдвигаемаяОбластьСтрока = НастройкиОтображения.Область("R2");
			НастройкиОтображения.ВставитьОбласть(НоваяОбластьСтрока, СдвигаемаяОбластьСтрока, ТипСмещенияТабличногоДокумента.ПоГоризонтали);
			КолонкаНаФорме = "2";
			НастройкиОтображения.Область("R2C13").Текст = КолонкаНаФорме;
			
			ВидПорученияОбъект.НастройкиОтображения = Новый ХранилищеЗначения(НастройкиОтображения);
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("НастройкиОтображения обновлены для вида поручения 10");
			ЗаписатьВидПоручения = Истина;
		Иначе
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("НастройкиОтображения не нужно обновлять для вида поручения 10");
		КонецЕсли;
		
	КонецЕсли;
	
	Если ЗаписатьВидПоручения Тогда
		ВидПорученияОбъект.Записать();
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Вид поручения 10 записан");
	КонецЕсли;
	
КонецПроцедуры

