Процедура НастройкаПараметровЗагрузкиКотировокПоляAPICBonds(НастройкиCBonds)
	
	ЛитералСтрока				 = "Строка";
	ЛитералЧисло				 = "Число";
	
	// Реквизиты котировок Торговых площадок по-умолчанию
	Котировки_Поля = Новый ТаблицаЗначений;
	Котировки_Поля.Колонки.Добавить("ИдентификаторБиржи"		, ОбщегоНазначения.ОписаниеТипаЧисло(10, 0));
	Котировки_Поля.Колонки.Добавить("КолонкаКотировки"			, Новый ОписаниеТипов(ЛитералСтрока));
	Котировки_Поля.Колонки.Добавить("КолонкаКотировкиСиноним"	, Новый ОписаниеТипов(ЛитералСтрока));
	Котировки_Поля.Колонки.Добавить("Идентификатор"				, Новый ОписаниеТипов(ЛитералСтрока));
	Котировки_Поля.Колонки.Добавить("Наименование"				, Новый ОписаниеТипов(ЛитералСтрока));
	Котировки_Поля.Колонки.Добавить("Описание"					, Новый ОписаниеТипов(ЛитералСтрока));
	Котировки_Поля.Колонки.Добавить("Тип"						, Новый ОписаниеТипов(ЛитералСтрока));
	
	// BSLLS:DuplicateStringLiteral-off
	НовоеПоле = Котировки_Поля.Добавить();
	НовоеПоле.ИдентификаторБиржи		 = 0;
	НовоеПоле.КолонкаКотировки			 = "Bid";
	НовоеПоле.КолонкаКотировкиСиноним	 = "Лучшая котировка на покупку на конец торговой сессии [Bid]";
	НовоеПоле.Идентификатор				 = "buying_quote";
	НовоеПоле.Наименование				 = "buying_quote";
	НовоеПоле.Описание					 = "Котировка на покупку, закрытие (Bid)";
	НовоеПоле.Тип						 = ЛитералЧисло;
	НовоеПоле = Котировки_Поля.Добавить();
	НовоеПоле.ИдентификаторБиржи		 = 0;
