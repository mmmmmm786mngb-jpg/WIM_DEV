Процедура ЗаполнитьВалютуВРегистреНалоговаяБазаВыплатыДоходов()
	
	ВалютаРегламентированногоУчета = ОбщегоНазначенияПовтИсп.ЗначениеКонстанты("ВалютаРегламентированногоУчета");
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ПустаяВалюта", Справочники.Валюты.ПустаяСсылка());
	Запрос.Текст =
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	НалоговаяБазаВыплатыДоходов.Регистратор КАК Регистратор,
	|	НалоговаяБазаВыплатыДоходов.Регистратор.Дата КАК РегистраторДата
	|ИЗ
	|	РегистрНакопления.НалоговаяБазаВыплатыДоходов КАК НалоговаяБазаВыплатыДоходов
	|ГДЕ
	|	НалоговаяБазаВыплатыДоходов.Валюта = &ПустаяВалюта
	|	И НалоговаяБазаВыплатыДоходов.Регистратор ССЫЛКА Документ.НачисленныйНалог
	|
	|УПОРЯДОЧИТЬ ПО
	|	РегистраторДата";
	Результат = Запрос.Выполнить();
	Выборка = Результат.Выбрать();
	ВсегоДокументов = Выборка.Количество();
	ОткорректированоДокументов = 0;
	ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Начало корректировки РН НалоговаяБазаВыплатыДоходов :" + ТекущаяДатаСеанса());
	ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Регистраторов с пустой валютой = " + ВсегоДокументов);
	Пока Выборка.Следующий() Цикл
		ДокументНачисленныйНалог = Выборка.Регистратор;
		НаборЗаписей = РегистрыНакопления.НалоговаяБазаВыплатыДоходов.СоздатьНаборЗаписей();
		НаборЗаписей.Отбор.Регистратор.Установить(ДокументНачисленныйНалог);
		НаборЗаписей.Прочитать();
		Для Каждого Запись Из НаборЗаписей Цикл
			Запись.Валюта = ВалютаРегламентированногоУчета;
			Запись.СуммаДоходаВВалюте = Запись.СуммаДохода;
		КонецЦикла;
		НаборЗаписей.Записать();
		ОткорректированоДокументов = ОткорректированоДокументов + 1;
	КонецЦикла;
	ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Откорректировано регистраторов с пустой валютой = " + ОткорректированоДокументов);
	ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Окончание корректировки РН НалоговаяБазаВыплатыДоходов :" + ТекущаяДатаСеанса());
	
КонецПроцедуры

