Процедура ЗаполнитьКлассификаторВидовСчетовДЕПО()
	Набор = РегистрыСведений.КлассификаторДляОтчетовВидыСчетовДЕПО.СоздатьНаборЗаписей();
	Период = ДАТА(2024, 1, 1);
	Набор.Отбор.Период.Значение = Период;
	ТипыСчетовДепо = Перечисления.ТипыСчетовДепо;
	
	ДобавитьВКлассификаторВидовСчетовДепо(Набор, Период, ТипыСчетовДепо.Владельца, "OWNER");
	ДобавитьВКлассификаторВидовСчетовДепо(Набор, Период, ТипыСчетовДепо.ВладельцаТорговый, "OWNER");
	ДобавитьВКлассификаторВидовСчетовДепо(Набор, Период, ТипыСчетовДепо.НоминальногоДержателя, "NOMINEE");
	ДобавитьВКлассификаторВидовСчетовДепо(Набор, Период, ТипыСчетовДепо.НоминальногоДержателяТорговый, "NOMINEE");
	ДобавитьВКлассификаторВидовСчетовДепо(Набор, Период, ТипыСчетовДепо.ИностранногоНоминальногоДержателя, "FAUTNOMINEE");
	ДобавитьВКлассификаторВидовСчетовДепо(Набор, Период, ТипыСчетовДепо.ДоверительногоУправляющего, "TRUSTEE");
	ДобавитьВКлассификаторВидовСчетовДепо(Набор, Период, ТипыСчетовДепо.КазначейскийСчетЭмитента, "ISSUER");
	ДобавитьВКлассификаторВидовСчетовДепо(Набор, Период, ТипыСчетовДепо.ЭмиссионныйСчет, "EMISSION");
	ДобавитьВКлассификаторВидовСчетовДепо(Набор, Период, ТипыСчетовДепо.ИностранногоУполномоченногоДержателя, "FAUTHOLDER");
	ДобавитьВКлассификаторВидовСчетовДепо(Набор, Период, ТипыСчетовДепо.ИностранногоУполномоченногоДержателяТорговый, "FAUTHOLDER");
	ДобавитьВКлассификаторВидовСчетовДепо(Набор, Период, ТипыСчетовДепо.НеустановленныхЛиц, "NONE");
	ДобавитьВКлассификаторВидовСчетовДепо(Набор, Период, ТипыСчетовДепо.ИныеФедеральныеСчета, "OTHER");
	
	Набор.Записать();
	ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Добавлены записи в РС КлассификаторДляОтчетовВидыСчетовДЕПО ...");
