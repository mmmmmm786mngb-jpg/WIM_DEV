Процедура ЗаполнитьИсточникиКотировокНРД_CBonds()
	
	МакетPDF = Обработки.СервисыMarketDataAPI.ПолучитьМакет("list_of_trading_platforms");
	ТекстPDF = MarketData.ТекстPDF(Неопределено, МакетPDF);
