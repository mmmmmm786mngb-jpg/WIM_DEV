Процедура ДобавитьВНабор(Набор, AssetClass_Const, AssetSort_Const, SAC_Const, ТипЦБ, ВидЦБ, КодВидаЦББанкаРоссии)
	НоваяЗапись = Набор.Добавить();
	НоваяЗапись.AssetClass_Const = AssetClass_Const;
	НоваяЗапись.AssetSort_Const = AssetSort_Const;
	НоваяЗапись.SAC_Const = SAC_Const;
	НоваяЗапись.ТипЦБ = ТипЦБ;
	НоваяЗапись.ВидЦББанкаРоссии = Справочники.ВидыЦББанкаРоссии.НайтиПоКоду(КодВидаЦББанкаРоссии);
	Если ТипЗнч(ВидЦБ) = Тип("Структура") Тогда
		НоваяЗапись.ВидЦБ = ВидЦБ.ВидЦБ;
		НоваяЗапись.ПодвидОблигаций = ВидЦБ.ПодвидОблигаций;
	Иначе
		НоваяЗапись.ВидЦБ = ВидЦБ;
	КонецЕсли;
КонецПроцедуры

Процедура ЗаполнитьИзмерениеМетодикаРасчетаВРСРыночныеЦеныЦенныхБумаг()
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	РыночныеЦеныЦенныхБумаг.ЦеннаяБумага КАК ЦеннаяБумага
	|ИЗ
	|	РегистрСведений.РыночныеЦеныЦенныхБумаг КАК РыночныеЦеныЦенныхБумаг
	|ГДЕ
	|	РыночныеЦеныЦенныхБумаг.МетодикаРасчета = ЗНАЧЕНИЕ(Перечисление.МетодикиРасчетаРыночныхЦен.ПустаяСсылка)
	|
	|СГРУППИРОВАТЬ ПО
	|	РыночныеЦеныЦенныхБумаг.ЦеннаяБумага";
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		НаборЗаписей = РегистрыСведений.РыночныеЦеныЦенныхБумаг.СоздатьНаборЗаписей();
		НаборЗаписей.Отбор.ЦеннаяБумага.Установить(Выборка.ЦеннаяБумага);
		НаборЗаписей.Прочитать();
		Для Каждого Запись Из НаборЗаписей Цикл
			Если Не ЗначениеЗаполнено(Запись.МетодикаРасчета) Тогда
				Запись.МетодикаРасчета = Перечисления.МетодикиРасчетаРыночныхЦен.Для0409404;
			КонецЕсли;
		КонецЦикла;
		Замещать = Истина;
		НаборЗаписей.Записать(Замещать);
	КонецЦикла;
КонецПроцедуры

