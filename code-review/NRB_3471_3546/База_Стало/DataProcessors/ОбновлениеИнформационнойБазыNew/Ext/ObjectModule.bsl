	КонецЦикла;
	ЗаписатьИсточникиКотировок(ПлощадкиНРД, Справочники.ИсточникиКотировок.NSD);
	
	ПлощадкиCBonds = Новый Массив;
	ТипХранилище = Тип("ХранилищеЗначения");
	Настройки = Новый Структура;
	ИнициализацияНастроек = Обработки.ОбновлениеИнформационнойБазыNew.Создать();
	ИнициализацияНастроек.НастройкаПараметровЗагрузкиКотировокAPICBonds(Настройки, Ложь);
	Если Настройки.Свойство("ТЗ_ПрочиеТорговыеПлощадки") И ЗначениеЗаполнено(Настройки.ТЗ_ПрочиеТорговыеПлощадки) Тогда
		ТЗ_ПрочиеТорговыеПлощадки = XMLЗначение(ТипХранилище, Настройки.ТЗ_ПрочиеТорговыеПлощадки).Получить();
		Для Каждого ПрочаяТорговаяПлощадка Из ТЗ_ПрочиеТорговыеПлощадки Цикл
			ДобавитьПлощадкиCBonds(ПрочаяТорговаяПлощадка, ПлощадкиCBonds);
		КонецЦикла;
	КонецЕсли;
	ЗаписатьИсточникиКотировок(ПлощадкиCBonds, Справочники.ИсточникиКотировок.CBonds);
	
