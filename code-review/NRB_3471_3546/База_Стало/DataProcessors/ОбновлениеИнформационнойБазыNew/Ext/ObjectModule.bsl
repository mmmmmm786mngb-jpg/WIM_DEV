Процедура СоздатьНастройкуФиксированныхЗаписейЖурналаВходящих(РеквизитыНастройки)
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	НастройкиФиксированныхЗаписейЖурналаВходящихДокументов.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.НастройкиФиксированныхЗаписейЖурналаВходящихДокументов КАК НастройкиФиксированныхЗаписейЖурналаВходящихДокументов
	|ГДЕ 
	|	НастройкиФиксированныхЗаписейЖурналаВходящихДокументов.Наименование = &Наименование
	|	И НЕ НастройкиФиксированныхЗаписейЖурналаВходящихДокументов.ПометкаУдаления
	|";
	Запрос.УстановитьПараметр("Наименование", РеквизитыНастройки.Наименование);
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() Тогда
		НовыйЭлемент = Справочники.НастройкиФиксированныхЗаписейЖурналаВходящихДокументов.СоздатьЭлемент();
		ЗаполнитьЗначенияСвойств(НовыйЭлемент, РеквизитыНастройки);
		НовыйЭлемент.Записать();
		ТекстСообщения = "Создана настройка фиксированных записей ЖВ: " + РеквизитыНастройки.Наименование;
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
	Иначе
		ТекстСообщения = "Не создана настройка фиксированных записей ЖВ: " + РеквизитыНастройки.Наименование
						+ ", так как настройка с таким именем уже есть";
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
	КонецЕсли;
КонецПроцедуры

Процедура СоздатьОбновитьМетрики()
	
	НаименованиеДень = "День";
	СсылкаНаПериодДень = Справочники.ПериодыДляВычисленияМетрик.НайтиПоНаименованию(НаименованиеДень, Истина);
	Если ЗначениеЗаполнено(СсылкаНаПериодДень) Тогда
		ПериодДень = СсылкаНаПериодДень.ПолучитьОбъект();
	Иначе
		ПериодДень = Справочники.ПериодыДляВычисленияМетрик.СоздатьЭлемент();
	КонецЕсли;
	
	ПериодДень.Наименование = НаименованиеДень;
	ПериодДень.Обозначение = "24H";
	ПериодДень.Длительность = ОбщегоНазначенияПовтИсп.СекундВСутках();
	
	Попытка
		ПериодДень.Записать();
	Исключение
		Отказ = Истина;
		ИнформацияОбОшибке = ИнформацияОбОшибке();
		ОписаниеОшибки = ОбработкаОшибок.КраткоеПредставлениеОшибки(ИнформацияОбОшибке);
		ТекстОшибки = СтрШаблон("Не удалось записать период ""%1"" для вычисления метрик по причине: %2.",
			НаименованиеДень, ОписаниеОшибки);
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстОшибки);
		Возврат;
	КонецПопытки;
	
	МетрикиОбмена = Новый ТаблицаЗначений;
	МетрикиОбмена.Колонки.Добавить("Код");
	МетрикиОбмена.Колонки.Добавить("Наименование");
	МетрикиОбмена.Колонки.Добавить("Алгоритм");
	МетрикиОбмена.Колонки.Добавить("КлючеваяОперация");
	МетрикиОбмена.Колонки.Добавить("ПериодВычисления");
	
	НоваяСтрокаМетрик = МетрикиОбмена.Добавить();
	НоваяСтрокаМетрик.Код = "ExportOrders";
	НоваяСтрокаМетрик.Наименование = "ЭкспортПорученийВЛуч_ОбработкаВходящихПакетовФайловогоШлюза";
	НаименованиеКлючевойОперации = "Экспорт поручений в луч_ обработать входящие пакеты файлового шлюза";
	НоваяСтрокаМетрик.КлючеваяОперация = Справочники.КлючевыеОперации.НайтиПоНаименованию(НаименованиеКлючевойОперации, Истина);
	НоваяСтрокаМетрик.ПериодВычисления = ПериодДень.Ссылка;
	
	НоваяСтрокаМетрик = МетрикиОбмена.Добавить();
	НоваяСтрокаМетрик.Код = "KafkaUnloading";
	НоваяСтрокаМетрик.Наименование = "ВремяСПоследнегоУспешногоОбменаКафка_Выгрузка";
	НоваяСтрокаМетрик.Алгоритм = "ТаблицаЗначений = МетрикиАлгоритмыСервер.ВремяСПоследнегоУспешногоОбменаКафка_Выгрузка();";
	
	НоваяСтрокаМетрик = МетрикиОбмена.Добавить();
	НоваяСтрокаМетрик.Код = "KafkaLoading";
	НоваяСтрокаМетрик.Наименование = "ВремяСПоследнегоУспешногоОбменаКафка_Загрузка";
	НоваяСтрокаМетрик.Алгоритм = "ТаблицаЗначений = МетрикиАлгоритмыСервер.ВремяСПоследнегоУспешногоОбменаКафка_Загрузка();";
	
	ТипыВычисленияМетрик = Перечисления.ТипыВычисленияМетрик;
	Для Каждого МетрикаОбмена Из МетрикиОбмена Цикл
		
		СсылкаНаМетрику = Справочники.МетрикиPrometheus.НайтиПоКоду(МетрикаОбмена.Код);
		Если ЗначениеЗаполнено(СсылкаНаМетрику) Тогда
			Метрика = СсылкаНаМетрику.ПолучитьОбъект();
		Иначе
			Метрика = Справочники.МетрикиPrometheus.СоздатьЭлемент();
		КонецЕсли;
		
		Метрика.Код = МетрикаОбмена.Код;
		Метрика.Активность = Истина;
		Метрика.Наименование = МетрикаОбмена.Наименование;
		Метрика.МетодПолученияМетрики = Перечисления.МетодыПолученияМетрик.PullИзКэша;
		Метрика.ТипМетрики = Перечисления.ТипыМетрикPrometheus.Gauge;
		Метрика.ТипВычисленияМетрики = ?(ЗначениеЗаполнено(МетрикаОбмена.Алгоритм), ТипыВычисленияМетрик.Алгоритм,
			ТипыВычисленияМетрик.КлючеваяОперацияСредниеЗаПериод);
		Метрика.Алгоритм = МетрикаОбмена.Алгоритм;
		Метрика.КлючеваяОперация = МетрикаОбмена.КлючеваяОперация;
		Метрика.ПериодыВычисления.Очистить();
		Если ЗначениеЗаполнено(МетрикаОбмена.ПериодВычисления) Тогда
			НовыйПериод = Метрика.ПериодыВычисления.Добавить();
			НовыйПериод.ПериодВычисления = МетрикаОбмена.ПериодВычисления;
		КонецЕсли;
		
		Попытка
			Метрика.Записать();
		Исключение
			Отказ = Истина;
			ИнформацияОбОшибке = ИнформацияОбОшибке();
			ОписаниеОшибки = ОбработкаОшибок.КраткоеПредставлениеОшибки(ИнформацияОбОшибке);
			ТекстОшибки = СтрШаблон("Не удалось записать метрику ""%1"" по причине: %2.", Метрика.Наименование, ОписаниеОшибки);
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстОшибки);
			Возврат;
		КонецПопытки;
	КонецЦикла;
	
КонецПроцедуры

