	Запрос.УстановитьПараметр("Период", '20030529');
	Запрос.УстановитьПараметр("Наименования", ВалютыОтчета);
	РезультатЗапроса = Запрос.Выполнить();
	
	НаборЗаписей = РегистрыСведений.ВалютыОтчетаРегистрДепонентов.СоздатьНаборЗаписей();
	НаборЗаписей.Загрузить(РезультатЗапроса.Выгрузить());
	НаборЗаписей.Записать();

КонецПроцедуры

Процедура НастроитьВИ_Kafka(ПВХKafka, ИмяТопика)
	ПВХОбъект = ПВХKafka.ПолучитьОбъект();
	ПВХОбъект.Наименование = ИмяТопика;
	ПВХОбъект.Записать();
	
	ПараметрыНастройки = Новый Структура();
	ПараметрыНастройки.Вставить("Источник"			, ПВХKafka);
	ПараметрыНастройки.Вставить("ИмяНастройки"		, ИмяТопика);
	ПараметрыНастройки.Вставить("KafkaТопик"		, ИмяТопика);
	ПараметрыНастройки.Вставить("KafkaПользователь"	, "svc_Kafka_1C_NRB");
	СоздатьНастройкуОбменаKafka(ПараметрыНастройки); // настройка для прода
		
	ПараметрыНастройки.KafkaПользователь = "svc_Kafka_1C_NRB_UAT";
	ПараметрыНастройки.ИмяНастройки = "(UAT) " + ИмяТопика;
	ЭтоUAT = Истина;
	СоздатьНастройкуОбменаKafka(ПараметрыНастройки, , ЭтоUAT); // настройка для uat
	
	ЭтоТестоваяБаза = Привилегированный.ЭтоТестоваяБаза();
	Если ЭтоТестоваяБаза Тогда
		МенеджерЗаписи						= РегистрыСведений.ВнешниеИсточники.СоздатьМенеджерЗаписи();
		МенеджерЗаписи.ВнешнийИсточник		= ПараметрыНастройки.Источник;
		МенеджерЗаписи.КластерСерверов		= ПараметрыСеанса.ТекущийКластерСерверов;
		МенеджерЗаписи.ИнформационнаяБаза	= ПараметрыСеанса.ТекущаяИнформационнаяБаза;
		МенеджерЗаписи.Настройка			= Справочники.НастройкиОбменаДанными.НайтиПоНаименованию(ПараметрыНастройки.ИмяНастройки, Истина);
		МенеджерЗаписи.Записать();
	КонецЕсли;
КонецПроцедуры

Процедура СоздатьКодЗагрузкиМестаХранения(НаименованиеПолное, КодЗагрузки)
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	МестаХранения.Ссылка КАК МестоХранения,
	|	КодыЗагрузки.Ссылка КАК КодЗагрузки
	|ИЗ
	|	Справочник.МестаХранения КАК МестаХранения
	|	ЛЕВОЕ СОЕДИНЕНИЕ Справочник.КодыЗагрузки КАК КодыЗагрузки
	|		ПО МестаХранения.Ссылка = КодыЗагрузки.Владелец
	|			И КодыЗагрузки.Биржа = ЗНАЧЕНИЕ(Справочник.КлассификаторыЗагрузки.КодыМестХраненияИзПанда)
	|			И КодыЗагрузки.Код = &КодЗагрузки
	|			И НЕ КодыЗагрузки.ПометкаУдаления
	|ГДЕ
	|	НЕ МестаХранения.ЭтоГруппа
	|	И НЕ МестаХранения.ПометкаУдаления
	|	И ВЫРАЗИТЬ(МестаХранения.НаименованиеПолное КАК СТРОКА (500)) = &НаименованиеПолное";
	Запрос.УстановитьПараметр("НаименованиеПолное", НаименованиеПолное);
	Запрос.УстановитьПараметр("КодЗагрузки", КодЗагрузки);
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Количество() = 1 Тогда
		Выборка.Следующий();
		Если Не ЗначениеЗаполнено(Выборка.КодЗагрузки) Тогда
			НовыйЭлемент = Справочники.КодыЗагрузки.СоздатьЭлемент();
			НовыйЭлемент.Код = КодЗагрузки;
			НовыйЭлемент.Владелец = Выборка.МестоХранения;
			НовыйЭлемент.Биржа = Справочники.КлассификаторыЗагрузки.КодыМестХраненияИзПанда;
			НовыйЭлемент.Записать(); 			
			Текст = "Для места хранения с наименованием: " + НаименованиеПолное + " создан новый код загрузки: " + КодЗагрузки;
		Иначе
			Текст = "У места хранения с наименованием: " + НаименованиеПолное + " уже существует код загрузки: " + КодЗагрузки;
		КонецЕсли;
	Иначе
		Текст = "Не найдено место хранения с уникальным полным наименованием: " + НаименованиеПолное
				+ "! Не удалось создать код загрузки: " + КодЗагрузки;		
	КонецЕсли;
	ОбщегоНазначенияКлиентСервер.СообщитьПользователю(Текст);
КонецПроцедуры

Процедура ЗаполнитьСпособОтправкиОтчетовДляДепонентов()
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Контрагенты.Ссылка КАК Депонент,
		|	ВЫБОР
		|		КОГДА Контрагенты.ЮридическиеФизическиеЛица ССЫЛКА Справочник.ФизическиеЛица
		|			ТОГДА ЗНАЧЕНИЕ(Перечисление.СпособыОтправкиОтчетов.МП)
		|		КОГДА Контрагенты.ЮридическиеФизическиеЛица ССЫЛКА Справочник.ЮридическиеЛица
		|				И НЕ КодыЗагрузки.Ссылка ЕСТЬ NULL
		|			ТОГДА ЗНАЧЕНИЕ(Перечисление.СпособыОтправкиОтчетов.EmailКлиента)
		|		КОГДА Контрагенты.ЮридическиеФизическиеЛица ССЫЛКА Справочник.ЮридическиеЛица
		|				И КодыЗагрузки.Ссылка ЕСТЬ NULL
		|			ТОГДА ЗНАЧЕНИЕ(Перечисление.СпособыОтправкиОтчетов.EmailCustody)
		|		ИНАЧЕ ЗНАЧЕНИЕ(Перечисление.СпособыОтправкиОтчетов.ПустаяСсылка)
		|	КОНЕЦ КАК СпособОтправкиОтчетов,
		|	ПРЕДСТАВЛЕНИЕССЫЛКИ(Контрагенты.Ссылка) КАК ДепонентПредставление
		|ИЗ
		|	Справочник.Контрагенты КАК Контрагенты
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.КодыЗагрузки КАК КодыЗагрузки
		|		ПО Контрагенты.ЮридическиеФизическиеЛица = КодыЗагрузки.Владелец
		|			И (КодыЗагрузки.Биржа = &Биржа)
		|			И (НЕ КодыЗагрузки.ПометкаУдаления)
		|			И (ВЫБОР
		|				КОГДА КодыЗагрузки.ДатаОкончанияДействия = ДАТАВРЕМЯ(1, 1, 1)
		|					ТОГДА ИСТИНА
		|				КОГДА КодыЗагрузки.ДатаОкончанияДействия > НАЧАЛОПЕРИОДА(&ТекущаяДата, ДЕНЬ)
		|					ТОГДА ИСТИНА
		|				ИНАЧЕ ЛОЖЬ
		|			КОНЕЦ)
		|ГДЕ
		|	Контрагенты.Родитель = ЗНАЧЕНИЕ(Справочник.Контрагенты.Депоненты)
		|	И Контрагенты.СпособОтправкиОтчетов = ЗНАЧЕНИЕ(Перечисление.СпособыОтправкиОтчетов.ПустаяСсылка)";
	
	Запрос.УстановитьПараметр("Биржа", Справочники.КлассификаторыЗагрузки.Клиенты);
	Запрос.УстановитьПараметр("ТекущаяДата", ТекущаяДатаСеанса());
	
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		ДепонентОбъект = Выборка.Депонент.ПолучитьОбъект();
		ДепонентОбъект.СпособОтправкиОтчетов = Выборка.СпособОтправкиОтчетов;
		ДепонентОбъект.ОбменДанными.Загрузка = Истина;
		Попытка
			ДепонентОбъект.Записать();
		Исключение
			ТекстОшибки = СтрШаблон("Не удалось изменить ""Способ отправки отчетов"" для депонента %1", Выборка.ДепонентПредставление);
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстОшибки, Выборка.Депонент);
		КонецПопытки;
	КонецЦикла;
	
КонецПроцедуры

