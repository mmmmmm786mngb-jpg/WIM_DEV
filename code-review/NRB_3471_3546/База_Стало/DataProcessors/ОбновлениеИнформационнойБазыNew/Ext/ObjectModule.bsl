Процедура ЗаполнитьТипСообщенияВЖурналеKafka(ИмяРегистраСведенийСЖурналом)
	ВремяНачала = ТекущаяДатаСеанса();
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ЖурналВходящихСообщенийKafka.ВнешнийИсточник КАК ВнешнийИсточник,
	|	ЖурналВходящихСообщенийKafka.Идентификатор КАК Идентификатор
	|ИЗ
	|	РегистрСведений.ЖурналВходящихСообщенийKafka КАК ЖурналВходящихСообщенийKafka
	|ГДЕ
	|	ЖурналВходящихСообщенийKafka.ТипСообщения = """"";
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "ЖурналВходящихСообщенийKafka", ИмяРегистраСведенийСЖурналом);
	Выборка = Запрос.Выполнить().Выбрать();
	МенеджерЗаписи = РегистрыСведений[ИмяРегистраСведенийСЖурналом].СоздатьМенеджерЗаписи();
	ЗаписейКОбработке = Выборка.Количество();
	ЗаписейОбработано = 0;
	Пока Выборка.Следующий() Цикл
		МенеджерЗаписи.ВнешнийИсточник = Выборка.ВнешнийИсточник;
		МенеджерЗаписи.Идентификатор = Выборка.Идентификатор;
		МенеджерЗаписи.Прочитать();
		МенеджерЗаписи.ТипСообщения = Кафка.ТипСообщенияИзКлючаСообщения(МенеджерЗаписи.Ключ);
		МенеджерЗаписи.Записать(Истина);
		ЗаписейОбработано = ЗаписейОбработано + 1;
	КонецЦикла;
	ВремяКонца = ТекущаяДатаСеанса();
	ПродолжительностьВСекундах = ВремяКонца - ВремяНачала;
	Сообщение = "В регистре сведений " + ИмяРегистраСведенийСЖурналом + " обработано "
				+ Строка(ЗаписейОбработано) + " записей из " + Строка(ЗаписейКОбработке)
				+ " за " + Строка(ПродолжительностьВСекундах) + " секунд";
	ОбщегоНазначенияКлиентСервер.СообщитьПользователю(Сообщение);
КонецПроцедуры

