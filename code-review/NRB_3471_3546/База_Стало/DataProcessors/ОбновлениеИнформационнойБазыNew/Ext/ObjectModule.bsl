Процедура ДобавитьПлощадкиНРД(СтрокаPDF, ПлощадкиНРД)
	
	ВариантыПоиска = Новый Массив;
	СвойстваВариантов = "Начало, Длина";
	СтруктураВарианта = Новый Структура(СвойстваВариантов, 1, 49);
	ВариантыПоиска.Добавить(СтруктураВарианта);
	СтруктураВарианта = Новый Структура(СвойстваВариантов, 54, 53);
	ВариантыПоиска.Добавить(СтруктураВарианта);
	СтруктураВарианта = Новый Структура(СвойстваВариантов, 58, 99);
	ВариантыПоиска.Добавить(СтруктураВарианта);
	СтруктураВарианта = Новый Структура(СвойстваВариантов, 111, 99);
	ВариантыПоиска.Добавить(СтруктураВарианта);
	ДлинаКода = 4;
	Для Каждого ВариантПоиска Из ВариантыПоиска Цикл
		КодПлощадки = СокрЛП(Сред(СтрокаPDF, ВариантПоиска.Начало, ДлинаКода));
		ЭтоКодПлощадки = СтрДлина(КодПлощадки) = ДлинаКода И ОценкаПроизводительностиКлиентСервер.ТолькоЛатиницаВСтроке(КодПлощадки);
		Если ЭтоКодПлощадки Тогда
			Площадка = Новый Структура("id, shortname_rus, fullname_rus");
			Площадка.id = КодПлощадки;
			Площадка.shortname_rus = КодПлощадки;
			ПолноеНаименованиеПлощадки =
				СокрЛП(Сред(СтрокаPDF, ВариантПоиска.Начало + ДлинаКода, ВариантПоиска.Длина));
			Площадка.fullname_rus = ПолноеНаименованиеПлощадки;
			ПлощадкиНРД.Добавить(Площадка);
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

Функция НастройкаРегламентаРасчетРыночныхЦенЦенныхБумаг(РегламентРасчетРыночныхЦенЦенныхБумаг)
	
	Наименование = "Расчет рыночных цен ценных бумаг";
	
	Ключ = РегламентРасчетРыночныхЦенЦенныхБумаг.Имя;
	РегламентПредопределенное =
		РегламентныеЗадания.НайтиПредопределенное(РегламентРасчетРыночныхЦенЦенныхБумаг);
	Если РегламентПредопределенное.Ключ <> Ключ Тогда
		РегламентПредопределенное.Наименование = Наименование;
		РегламентПредопределенное.Ключ = Ключ;
		РегламентПредопределенное.Использование = Ложь;
		РегламентПредопределенное.Записать();
	КонецЕсли;
	
	ИнтервалыВТеченииДня = Новый Массив;
	ДобавитьИнтервал(ИнтервалыВТеченииДня, Дата(1, 1, 1, 12, 00, 0), Дата(1, 1, 1, 0, 0, 0), 0, 0);
	
	Успешно = НастройкаРегламентногоЗадания(РегламентРасчетРыночныхЦенЦенныхБумаг,
		ИнтервалыВТеченииДня, Наименование, Ключ);
	
	Если Не Успешно Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не могу создать\обновить регламент: " + Наименование);
	КонецЕсли;
	Возврат Успешно;
	
КонецФункции

