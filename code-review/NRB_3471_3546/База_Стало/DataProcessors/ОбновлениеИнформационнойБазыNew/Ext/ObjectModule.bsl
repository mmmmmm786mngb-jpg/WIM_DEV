Процедура НастройкаРегламентовЗагрузкиКотировокAPINSD(РегламентСервисыНРД)
	
	ИмяРегламентаЗагрузкаИтоговТорговЧерезNSDAPI = "ЗагрузкаИтоговТорговЧерезNSDAPI";
	
	ЗагрузкаИтоговТорговЧерезNSDAPI = РегламентныеЗадания.НайтиПредопределенное(РегламентСервисыНРД);
	Если ЗагрузкаИтоговТорговЧерезNSDAPI.Ключ <> ИмяРегламентаЗагрузкаИтоговТорговЧерезNSDAPI Тогда
		ЗагрузкаИтоговТорговЧерезNSDAPI.Наименование = "СервисыНРД " + "[" + ИмяРегламентаЗагрузкаИтоговТорговЧерезNSDAPI + "]"; 
		ЗагрузкаИтоговТорговЧерезNSDAPI.Ключ = ИмяРегламентаЗагрузкаИтоговТорговЧерезNSDAPI;
		ЗагрузкаИтоговТорговЧерезNSDAPI.Использование = Ложь;
		ЗагрузкаИтоговТорговЧерезNSDAPI.Записать();
	КонецЕсли;
	
	Наименование = "СервисыНРД " + "[" + ИмяРегламентаЗагрузкаИтоговТорговЧерезNSDAPI + "]";
	
	ПараметрыМетодаРЗ = Новый Массив;
	ПараметрыМетодаРЗ.Добавить(ИмяРегламентаЗагрузкаИтоговТорговЧерезNSDAPI);
	
	ИнтервалыВТеченииДня = Новый Массив;
	ДобавитьИнтервал(ИнтервалыВТеченииДня, Дата(1, 1, 1, 4, 00, 0), Дата(1, 1, 1, 0, 0, 0), 0, 0);
	ДобавитьИнтервал(ИнтервалыВТеченииДня, Дата(1, 1, 1, 22, 00, 0), Дата(1, 1, 1, 0, 0, 0), 0, 0);
	ПараметрыМетодаРЗ.Добавить(Перечисления.ПериодыДней.ПредыдущийРабочийДень);
	ДниНедели = СтрРазделить("2,3,4,5,6", ",");
	
	Успешно = НастройкаРегламентногоЗадания(РегламентСервисыНРД,
		ИнтервалыВТеченииДня, Наименование, ИмяРегламентаЗагрузкаИтоговТорговЧерезNSDAPI, ПараметрыМетодаРЗ, ДниНедели);
		
	Если Не Успешно Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не могу создать\обновить регламент " + ИмяРегламентаЗагрузкаИтоговТорговЧерезNSDAPI);
	Иначе // По-умолчанию задания включены
		Отбор = Новый Структура("Метаданные", РегламентСервисыНРД);
		Отбор.Вставить("Наименование", Наименование);
		Задания = РегламентныеЗадания.ПолучитьРегламентныеЗадания(Отбор);
		Задание = Задания[0];
		Задание.Использование = Истина;
		Задание.Записать();
	КонецЕсли;
	
КонецПроцедуры

