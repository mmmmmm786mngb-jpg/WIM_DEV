	НастройкаОбменаДаннымиСсылка = НастройкаОбменаОбъект.Ссылка;
	
	Если UAT Тогда
		ДобавитьНастройкуДляБазыUAT(ПВХ.Ссылка, НастройкаОбменаДаннымиСсылка);
	ИначеЕсли ITTest Тогда
