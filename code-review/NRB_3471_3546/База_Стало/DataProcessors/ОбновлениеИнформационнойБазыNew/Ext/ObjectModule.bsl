	НаборЗаписей = РегистрыСведений.УслугиДепозитарияВыгруженные.СоздатьНаборЗаписей();
	Пока УслугиДепозитария.Следующий() Цикл
		НоваяЗапись = НаборЗаписей.Добавить();
		НоваяЗапись.Документ = УслугиДепозитария.Регистратор;
	КонецЦикла;
	НаборЗаписей.Записать();
КонецПроцедуры

Процедура ЗаполнитьКодДоходаВРегистреНалоговаяБазаВыплатыДоходов()
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ПустойКодДохода", Справочники.ДоходыНДФЛ.ПустаяСсылка());
	Запрос.Текст =
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	НалоговаяБазаВыплатыДоходов.Регистратор КАК Регистратор,
	|	НалоговаяБазаВыплатыДоходов.Регистратор.Дата КАК РегистраторДата
	|ИЗ
	|	РегистрНакопления.НалоговаяБазаВыплатыДоходов КАК НалоговаяБазаВыплатыДоходов
	|ГДЕ
	|	НалоговаяБазаВыплатыДоходов.КодДохода = &ПустойКодДохода
	|	И НалоговаяБазаВыплатыДоходов.Регистратор ССЫЛКА Документ.НачисленныйНалог
	|
	|УПОРЯДОЧИТЬ ПО
	|	РегистраторДата";
	Результат = Запрос.Выполнить();
	Выборка = Результат.Выбрать();
	ВсегоДокументов = Выборка.Количество();
	ОткорректированоДокументов = 0;
	ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Начало корректировки РН НалоговаяБазаВыплатыДоходов :" + ТекущаяДатаСеанса());
	ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Регистраторов с пустым кодом дохода = " + ВсегоДокументов);
	Пока Выборка.Следующий() Цикл
		ДокументНачисленныйНалог = Выборка.Регистратор;
		НаборЗаписей = РегистрыНакопления.НалоговаяБазаВыплатыДоходов.СоздатьНаборЗаписей();
		НаборЗаписей.Отбор.Регистратор.Значение = ДокументНачисленныйНалог;
		НаборЗаписей.Прочитать();
		Для Каждого Запись Из НаборЗаписей Цикл
			Запись.КодДохода = Документы.НачисленныйНалог.КодДоходаПоВидуОперации(ДокументНачисленныйНалог.Основание.ВидОперацииД);
		КонецЦикла;
		НаборЗаписей.Записать();
		ОткорректированоДокументов = ОткорректированоДокументов + 1;
	КонецЦикла;
	ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Откорректировано регистраторов с пустым кодом дохода = " + ОткорректированоДокументов);
	ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Окончание корректировки РН НалоговаяБазаВыплатыДоходов :" + ТекущаяДатаСеанса());
	
