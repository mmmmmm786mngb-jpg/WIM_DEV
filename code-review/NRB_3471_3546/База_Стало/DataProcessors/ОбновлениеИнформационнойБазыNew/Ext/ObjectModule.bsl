	ИзменитьНаименованиеВидаЦББанкаРоссии("ENC1", "Документарные закладные (кроме обездвиженных документарных закладных)");
	ИзменитьНаименованиеВидаЦББанкаРоссии("ISU", "Ипотечные сертификаты участия");
	
	ДобавитьНовыйЭлементВСправочникВидыЦББанкаРоссии("SHS9", "Акции банков-нерезидентов (привилегированные)", 
		Перечисления.КатегорииЦенныхБумагДляРеестраКвалифицированныхИнвесторов.АкцииИОблигацииИностранныхЭмитентов);
	ДобавитьНовыйЭлементВСправочникВидыЦББанкаРоссии("SHS10", "Акции прочих нерезидентов (привилегированные)",
		Перечисления.КатегорииЦенныхБумагДляРеестраКвалифицированныхИнвесторов.АкцииИОблигацииИностранныхЭмитентов);
КонецПроцедуры

Процедура ИзменитьНаименованиеВидаЦББанкаРоссии(Код, НовоеНаименование)
	СсылкаНаЭлемент = Справочники.ВидыЦББанкаРоссии.НайтиПоКоду(Код);
	ЭлементОбъект = СсылкаНаЭлемент.ПолучитьОбъект();
	ЭлементОбъект.Наименование = НовоеНаименование;
	ЭлементОбъект.Записать();
	ТекстСообщения = "Наименование вида ЦБ Банка России с кодом " + Код + " изменено на " + НовоеНаименование;
	ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
КонецПроцедуры

Процедура ДобавитьНовыйЭлементВСправочникВидыЦББанкаРоссии(Код, Наименование, ВидИнструмента, ИностраннаяЦБ = Ложь)
	Ссылка = Справочники.ВидыЦББанкаРоссии.НайтиПоКоду(Код);
	Если Не ЗначениеЗаполнено(Ссылка) Тогда
		ЭлементОбъект = Справочники.ВидыЦББанкаРоссии.СоздатьЭлемент();
		ЭлементОбъект.Код = Код;
		ЭлементОбъект.Наименование = Наименование;
		ЭлементОбъект.ВидИнструмента = ВидИнструмента;
		ЭлементОбъект.ИностраннаяЦБ = ИностраннаяЦБ;
		ЭлементОбъект.Записать();
		ТекстСообщения = "Добавлен элемент справочника ВидыЦББанкаРоссии с кодом " + Код + " и наименованием " + Наименование;
	Иначе
		ТекстСообщения = "Уже существует элемент справочника ВидыЦББанкаРоссии с кодом " + Код;
	КонецЕсли;
	ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
КонецПроцедуры

Процедура ВнестиИзмененияВ_РС_КлассификаторДляОтчетовВидыСчетовДЕПОПоЗадаче2910()
	ТипыСчетовДепо = Перечисления.ТипыСчетовДепо;
	СоздатьЗаписьРС_КлассификаторДляОтчетовВидыСчетовДЕПО(ТипыСчетовДепо.ВладельцаТранзитный, Дата(2024, 1, 1), "TRANSITOWNER");
	СоздатьЗаписьРС_КлассификаторДляОтчетовВидыСчетовДЕПО(ТипыСчетовДепо.НеустановленныхЛиц, Дата(2026, 1, 1), "NONOWNER");
КонецПроцедуры

Процедура СоздатьЗаписьРС_КлассификаторДляОтчетовВидыСчетовДЕПО(ТипСчета1С, Период, ВидСчетаДляОтчета)
	Набор = РегистрыСведений.КлассификаторДляОтчетовВидыСчетовДЕПО.СоздатьНаборЗаписей();
	Набор.Отбор.ТипСчета1С.Установить(ТипСчета1С);
	Набор.Отбор.Период.Установить(Период);
	НоваяЗапись = Набор.Добавить();
	НоваяЗапись.Период = Период;
	НоваяЗапись.ТипСчета1С = ТипСчета1С;
	НоваяЗапись.ВидСчетаДляОтчета = ВидСчетаДляОтчета;
	Набор.Записать();
	ТекстСообщения = "Создана запись в РС КлассификаторДляОтчетовВидыСчетовДЕПО. ТипСчета1С = " + Строка(ТипСчета1С)
						+ " Период = " + Формат(Период, "ДФ=""дд.ММ.гггг""") + " ВидСчетаДляОтчета = " + ВидСчетаДляОтчета;
	ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
КонецПроцедуры

