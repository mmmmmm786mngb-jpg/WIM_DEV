Процедура НастроитьРегламентноеЗаданиеВыгрузкаОбращаемостиЦБВBackQort(Регламент)
	
	ИнтервалыВТеченииДня = Новый Массив;
	ДобавитьИнтервал(ИнтервалыВТеченииДня, Дата(1, 1, 1, 1, 30, 0), Дата(1, 1, 1, 0, 0, 0), 0, 0);
	ДниНедели = СтрРазделить("1,2,3,4,5,6,7", ",");
	
	Успешно = НастройкаРегламентногоЗадания(Регламент, ИнтервалыВТеченииДня, , , , ДниНедели);
	Если Не Успешно Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не могу создать\обновить регламент " + Регламент);
	КонецЕсли;
	
