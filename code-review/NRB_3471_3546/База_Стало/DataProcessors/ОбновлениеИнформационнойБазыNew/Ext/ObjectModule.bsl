Процедура ДобавитьВнешнийИсточникНРБСервисStoredProcSQL()
	
	ПВХ = ПланыВидовХарактеристик.ВнешниеИсточники.НРБСервисStoredProcSQL;
	
	ПВХОбъект = ПВХ.ПолучитьОбъект();
	ПВХОбъект.ТипВнешнегоИсточника = Перечисления.ТипыВнешнихИсточников.БазаДанныхSQL;
	ПВХОбъект.Записать();
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ПВХ", ПВХ);
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ВнешниеИсточники.ВнешнийИсточник КАК ВнешнийИсточник
	|ИЗ
	|	РегистрСведений.ВнешниеИсточники КАК ВнешниеИсточники
	|ГДЕ
	|	ВнешниеИсточники.ВнешнийИсточник = &ПВХ";
	
	Результат = Запрос.Выполнить();
	Если Не Результат.Пустой() Тогда
		ТекстСообщения = "Уже существует настройка для внешнего источника 'Сервис хранимых процедур НРБ', установка настроек отменена";
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
		Возврат;
	КонецЕсли;
	
	СерверSQL = "SMSK01DB004U";
	БазаSQL = "START";
	ШаблонПодключенияКБДSQL = "driver={SQL Server Native Client 11.0}; server=%SERVER%; Database=%DBNAME%;Trusted_Connection=yes;";
	
	Запись = РегистрыСведений.ВнешниеИсточники.СоздатьМенеджерЗаписи();
	Запись.ВнешнийИсточник = ПВХ;
	Запись.КластерСерверов = ПараметрыСеанса.ТекущийКластерСерверов;
	Запись.ИнформационнаяБаза = ПараметрыСеанса.ТекущаяИнформационнаяБаза;
	Запись.Сервер = СерверSQL;
	Запись.БазаДанных = БазаSQL;
	Запись.ШаблонПодключенияКБДSQL = ШаблонПодключенияКБДSQL;
	Запись.Записать();
	
	ДобавитьНастройкуДляБазыUAT(ПВХ, Неопределено, СерверSQL, БазаSQL, ШаблонПодключенияКБДSQL);
	ДобавитьНастройкуДляРабочихБаз(ПВХ, Неопределено, СерверSQL, БазаSQL, ШаблонПодключенияКБДSQL);
	
	ТекстСообщения = "Добавлена запись в РС Внешние источники 'Сервис хранимых процедур НРБ'.
		|НЕОБХОДИМО ВРУЧНУЮ УСТАНОВИТЬ параметры подключения к БД!";
	ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
	
КонецПроцедуры

