	ОбщегоНазначения.УстановитьОтборСКД(КомпоновщикСхемы.Настройки, "Поручение.ВидОперацииД.ВыплатаДоходаВДенежнойФорме",
		ВидСравненияКомпоновкиДанных.Равно, Истина);
	ОбщегоНазначения.УстановитьОтборСКД(КомпоновщикСхемы.Настройки, "Поручение.ЦБ.ISIN",
		ВидСравненияКомпоновкиДанных.Равно, "KYG3033X1135");
	СписокНомеровДепозитарногоДоговора = Новый СписокЗначений;
	СписокНомеровДепозитарногоДоговора.Добавить("1003666");
	СписокНомеровДепозитарногоДоговора.Добавить("1003667");
