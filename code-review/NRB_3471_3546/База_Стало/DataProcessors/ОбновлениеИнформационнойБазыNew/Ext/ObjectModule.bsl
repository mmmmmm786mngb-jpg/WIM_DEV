Процедура СоздатьВнешнийИсточникПапка(ПВХ, КаталогФайлов_PROD, КаталогФайлов_UAT)
	
	ОбъектПВХ = ПВХ.ПолучитьОбъект();
	ОбъектПВХ.ТипВнешнегоИсточника = Перечисления.ТипыВнешнихИсточников.Папка;
	ОбъектПВХ.Записать();
	
	Запись = РегистрыСведений.ВнешниеИсточники.СоздатьМенеджерЗаписи();
	Запись.ВнешнийИсточник = ПВХ;
	Запись.КластерСерверов = ПараметрыСеанса.ТекущийКластерСерверов;
	Запись.ИнформационнаяБаза = ПараметрыСеанса.ТекущаяИнформационнаяБаза;
	Запись.Сервер = КаталогФайлов_UAT;
	Запись.Записать();
	
	ЭтоТестоваяБаза = Привилегированный.ЭтоТестоваяБаза();
	Если ЭтоТестоваяБаза Тогда
		ДобавитьНастройкуДляТекущейБазы(ПВХ, , КаталогФайлов_UAT);
	Иначе
		ДобавитьНастройкуДляБазыITTest(ПВХ, , КаталогФайлов_UAT);
		ДобавитьНастройкуДляРабочихБаз(ПВХ, , КаталогФайлов_PROD);
	КонецЕсли;
	
	ТекстСообщения = СтрШаблон("Настроен внешний источник ""%1"".", ОбъектПВХ.Наименование);
	ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
	
КонецПроцедуры

