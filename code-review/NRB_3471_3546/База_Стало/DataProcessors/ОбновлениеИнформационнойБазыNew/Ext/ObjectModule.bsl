Процедура ИзменитьФормуСообщенияДляНовогоИЗамены(КодВидаКД, Этап, ФормаСообщенияНовоеЗначение)
	ВидКД = Справочники.ВидыКорпоративныхДействий.НайтиПоКоду(КодВидаКД);
	ИзменитьФормуСообщения(ВидКД, Этап, Справочники.ТипыУведомления.NEWM(), ФормаСообщенияНовоеЗначение);
	ИзменитьФормуСообщения(ВидКД, Этап, Справочники.ТипыУведомления.REPL(), ФормаСообщенияНовоеЗначение);
