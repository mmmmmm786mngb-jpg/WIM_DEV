	Макет = Справочники.Валюты.ПолучитьМакет("КлассификаторВалют");
	ОбластьКоды = Макет.Область("КодЧисловой");

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ИсключаемыеВалюты", Константы.ВалютаРегламентированногоУчета.Получить());
	Запрос.УстановитьПараметр("ТекущаяДата", НачалоДня(ТекущаяДатаСеанса()));
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Валюты.Код КАК Код,
	|	Валюты.Ссылка КАК Валюта
	|ИЗ
	|	Справочник.Валюты КАК Валюты
	|ГДЕ
	|	НЕ Валюты.ПометкаУдаления
	|	И НЕ Валюты.Ссылка В (&ИсключаемыеВалюты)";
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		
		НайденнаяОбласть = Макет.НайтиТекст(Выборка.Код, , ОбластьКоды);
		Если НайденнаяОбласть = Неопределено Или НайденнаяОбласть.Верх = 2 Тогда
			Продолжить;
		КонецЕсли;
		
		ОбластьЗагрузка = Макет.Области.ЗагружаетсяИзИнтернета;
		ОбластьРедкаяВалюта = Макет.Области.РедкаяВалюта;
		
		ВалютаОбъект = Выборка.Валюта.ПолучитьОбъект();
		ВалютаОбъект.ЗагружаетсяИзИнтернета = Макет.Область(НайденнаяОбласть.Верх, ОбластьЗагрузка.Лево,
			НайденнаяОбласть.Низ, ОбластьЗагрузка.Право).Текст;
		ВалютаОбъект.РедкаяВалюта = Макет.Область(НайденнаяОбласть.Верх, ОбластьРедкаяВалюта.Лево,
			НайденнаяОбласть.Низ, ОбластьРедкаяВалюта.Право).Текст;
		
		Попытка
			ВалютаОбъект.Записать();
		Исключение
			ТекстСообщения = СтрШаблон("Не удалось изменить валюту %1", ВалютаОбъект.НаименованиеПолное);
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
		КонецПопытки;
		
	КонецЦикла;
	
КонецПроцедуры

