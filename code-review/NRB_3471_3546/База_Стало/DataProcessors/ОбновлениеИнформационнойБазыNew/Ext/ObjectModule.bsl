Функция НастройкаРегламентногоЗадания(МетаданныеРегЗадания, ИнтервалыВТеченииДня, // BSLLS:NumberOfOptionalParams-off
	НаименованиеРегЗадания = Неопределено,
	КлючРегЗадания = Неопределено,
	МассивПараметровРегЗадания = Неопределено,
	ДниНедели = Неопределено,
	Использование = Истина)
	
	РегЗадание = НайтиИлиСоздатьРегламентноеЗадание(МетаданныеРегЗадания, НаименованиеРегЗадания, КлючРегЗадания);
	
	Если НаименованиеРегЗадания = Неопределено Тогда
		Если ЗначениеЗаполнено(МетаданныеРегЗадания.Наименование) Тогда
			НаименованиеРегЗадания = МетаданныеРегЗадания.Наименование;
		ИначеЕсли ЗначениеЗаполнено(МетаданныеРегЗадания.Синоним) Тогда
			НаименованиеРегЗадания = МетаданныеРегЗадания.Синоним;
		Иначе
			НаименованиеРегЗадания = МетаданныеРегЗадания.Имя;
		КонецЕсли;
	КонецЕсли;
	Если КлючРегЗадания = Неопределено Тогда
		КлючРегЗадания = МетаданныеРегЗадания.Имя;
	КонецЕсли;
	
	РегЗадание.Наименование = НаименованиеРегЗадания;
	РегЗадание.Ключ = КлючРегЗадания;
	РегЗадание.Параметры.Очистить();
	Если МассивПараметровРегЗадания <> Неопределено Тогда
		Для каждого ПараметрРЗ Из МассивПараметровРегЗадания Цикл
			РегЗадание.Параметры.Добавить(ПараметрРЗ);
		КонецЦикла;
	КонецЕсли;
	
	ПользовательРобот = ОбщегоНазначенияПовтИсп.ЗначениеКонстанты("ПользовательРобот");
	Если ЗначениеЗаполнено(ПользовательРобот) Тогда
		РегЗадание.ИмяПользователя = ОбщегоНазначенияПовтИсп.ЗначениеКонстанты("ПользовательРобот").Код;
	Иначе
		РегЗадание.ИмяПользователя = "ROBOTsvc";
	КонецЕсли;
	
	РегЗадание.КоличествоПовторовПриАварийномЗавершении = МетаданныеРегЗадания.КоличествоПовторовПриАварийномЗавершении;
	РегЗадание.ИнтервалПовтораПриАварийномЗавершении = МетаданныеРегЗадания.ИнтервалПовтораПриАварийномЗавершении;
	
	РегЗадание.Расписание = НовоеРасписаниеРегламентногоЗадания(ИнтервалыВТеченииДня, ДниНедели);
	РегЗадание.Использование = Использование;
	Попытка
		РегЗадание.Записать();
		ТекстСообщения = "Выполнена настройка регламентного задания """ + НаименованиеРегЗадания + """";
		Успешно = Истина;
	Исключение
		ТекстСообщения = "Не удалось создать/изменить регламентное задание """ + НаименованиеРегЗадания + """";
		Успешно = Ложь;
	КонецПопытки;
	ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
	
	Если Ложь Тогда // Отключение проверки на существование вызова процедуры \ функции
		НастройкаРегламентногоЗадания(Неопределено, Неопределено);
	КонецЕсли;
	
	Возврат Успешно;
КонецФункции

Функция НайтиИлиСоздатьРегламентноеЗадание(МетаданныеРегЗадания, НаименованиеРегЗадания = Неопределено, КлючРегЗадания = Неопределено)
	Отбор = Новый Структура("Метаданные", МетаданныеРегЗадания);
	Если КлючРегЗадания <> Неопределено Тогда
		Отбор.Вставить("Ключ", КлючРегЗадания);
	КонецЕсли;
	Если НаименованиеРегЗадания <> Неопределено Тогда
		Отбор.Вставить("Наименование", НаименованиеРегЗадания);
	КонецЕсли;
	
	РегЗадания = РегламентныеЗадания.ПолучитьРегламентныеЗадания(Отбор);
	Если РегЗадания.Количество() = 0 Тогда
		РегЗадание = РегламентныеЗадания.СоздатьРегламентноеЗадание(МетаданныеРегЗадания);
	Иначе
		РегЗадание = РегЗадания[0];
	КонецЕсли;
	
	Возврат РегЗадание;
КонецФункции

Функция НовоеРасписаниеРегламентногоЗадания(ИнтервалыВТеченииДня, ДниНедели = Неопределено)
	Расписание = Новый РасписаниеРегламентногоЗадания;
	Если Не ДниНедели = Неопределено Тогда
		Расписание.ДниНедели = ДниНедели;
	КонецЕсли;
	Расписание.ПериодПовтораДней = 1;
	ДетальныеРасписанияДня = Новый Массив;
	Для Каждого Интервал Из ИнтервалыВТеченииДня Цикл
		РасписаниеДт = Новый РасписаниеРегламентногоЗадания;
		ЗаполнитьЗначенияСвойств(РасписаниеДт, Интервал);
		ДетальныеРасписанияДня.Добавить(РасписаниеДт);
	КонецЦикла;
	Расписание.ДетальныеРасписанияДня = ДетальныеРасписанияДня;
	
	Возврат Расписание;
КонецФункции

// Процедура - Добавить\обновить таблицу печати дополнительных движений документа
//
// Параметры:
//  ТаблицаДвижений	 - ТаблицаЗначений - Таблица связи между документом,
//  	независимым регистром сведений и реквизитом в регистре ссылающемся на документ
//     * ИмяДокумента - Строка - Имя документа в конфигураторе
//     * ИмяРегистраСведений - Строка - Имя регистра сведений в конфигураторе
//     * ИмяРеквизитаРегистра - Строка - Имя реквизита регистра сведений в конфигураторе
//
Процедура ДобавитьОбновитьТаблицуПечатиДополнительныхДвиженийДокумента(ТаблицаДвижений)
	
	ИмяНастройки = "ТаблицаПечатиДополнительныхДвиженийДокумента";
	
	ТаблицаПечатиДополнительныхДвиженийДокумента = УниверсальныеМеханизмы.ВосстановитьНастройку(ИмяНастройки, Истина);
	Если (ТаблицаПечатиДополнительныхДвиженийДокумента = Неопределено)
		Или ТаблицаПечатиДополнительныхДвиженийДокумента.Количество() = 0 Тогда
			ТаблицаПечатиДополнительныхДвиженийДокумента = ТаблицаДвижений;
	Иначе
		ОбщегоНазначения.ЗагрузитьВТаблицуЗначений(ТаблицаДвижений, ТаблицаПечатиДополнительныхДвиженийДокумента);
		ТаблицаПечатиДополнительныхДвиженийДокумента.Свернуть("ИмяДокумента, ИмяРегистраСведений, ИмяРеквизитаРегистра");
	КонецЕсли;
	
	УниверсальныеМеханизмы.СохранитьНастройку(ИмяНастройки, ТаблицаПечатиДополнительныхДвиженийДокумента, Истина);
	ТекстСообщения = "Создана \ перезаписана таблица печати дополнительных движений документа в РС СохраненныеНастройки: ";
	ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения + ИмяНастройки);
	
КонецПроцедуры

Процедура ДобавитьПрефиксыВРегистр(МассивВидовОпераций, ТипДокумента, Префикс, ПрефиксСлужебный)
	ДатаЗаписей = Дата(1980,1,1);
	
	Для Сч = 1 по МассивВидовОпераций.Количество() Цикл
		ВидОперацииД = МассивВидовОпераций[Сч-1];
		
		НаборЗаписей = РегистрыСведений.ПрефиксыНомеровДокументов.СоздатьНаборЗаписей();
		НаборЗаписей.Отбор.ТипДокумента.Установить(ТипДокумента);
		НаборЗаписей.Отбор.ВидОперации.Установить(ВидОперацииД);
		НаборЗаписей.Отбор.Период.Установить(ДатаЗаписей);
		НаборЗаписей.Прочитать();
		
		Если НаборЗаписей.Количество() = 0 Тогда
			НоваяЗапись = НаборЗаписей.Добавить();
			НоваяЗапись.Период = ДатаЗаписей;
			НоваяЗапись.ТипДокумента = ТипДокумента;
			НоваяЗапись.ВидОперации = ВидОперацииД;
			НоваяЗапись.Префикс = Префикс;
			НоваяЗапись.ПрефиксСлужебный = ПрефиксСлужебный;
			НаборЗаписей.Записать();
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

Процедура НастроитьВнешнийИсточникДляОтправкиПочтовыхСообщений(ПВХ, НаименованиеНастройки, АдресПолучателя, АдресПолучателяКопии = "")
	ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Настройка внешнего источника для отправки почты """ +  Строка(ПВХ) + """");
		
	ОбъектПВХ = ПВХ.ПолучитьОбъект();
	ОбъектПВХ.ТипВнешнегоИсточника = Перечисления.ТипыВнешнихИсточников.НастройкаОбменаДанными;
	ОбъектПВХ.Записать();
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	НастройкиОбменаДанными.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.НастройкиОбменаДанными КАК НастройкиОбменаДанными
	|ГДЕ
	|	НастройкиОбменаДанными.Наименование = &НаименованиеНастройки
	|	И НЕ НастройкиОбменаДанными.ПометкаУдаления";
	Запрос.УстановитьПараметр("НаименованиеНастройки", НаименованиеНастройки);
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() Тогда
		НастройкаОбменаОбъект = Справочники.НастройкиОбменаДанными.СоздатьЭлемент();
		НастройкаОбменаОбъект.Наименование = НаименованиеНастройки;
		НастройкаОбменаОбъект.СпособОбмена = Перечисления.СпособыОбменаДанными.ОбменЧерезПочту;
		НастройкаОбменаОбъект.ИспользоватьУчетнуюЗаписьСообщенийВнешнегоИсточника = Истина;
		НастройкаОбменаОбъект.ВнешнийИсточникПриемаОтправкиСообщений = ПланыВидовХарактеристик.ВнешниеИсточники.РоботРассылки;
		НастройкаОбменаОбъект.АдресПолучателя = АдресПолучателя;
		НастройкаОбменаОбъект.АдресПолучателяКопии = АдресПолучателяКопии;
		НастройкаОбменаОбъект.Записать();
		НастройкаОбменаДаннымиСсылка = НастройкаОбменаОбъект.Ссылка;
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Создана новая настройка обмена данными """ + НаименованиеНастройки + """");
	Иначе
		Выборка = РезультатЗапроса.Выбрать();
		Выборка.Следующий();
		НастройкаОбменаДаннымиСсылка = Выборка.Ссылка;
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Найдена готовая настройка обмена данными """ + НаименованиеНастройки + """");
	КонецЕсли;
	
	МенеджерЗаписи = РегистрыСведений.ВнешниеИсточники.СоздатьМенеджерЗаписи();
	МенеджерЗаписи.ВнешнийИсточник		= ПВХ;
	МенеджерЗаписи.КластерСерверов		= ПараметрыСеанса.ТекущийКластерСерверов;
	МенеджерЗаписи.ИнформационнаяБаза	= ПараметрыСеанса.ТекущаяИнформационнаяБаза;
	МенеджерЗаписи.Настройка			= НастройкаОбменаДаннымиСсылка;
	МенеджерЗаписи.Записать();
	
	ДобавитьНастройкуДляРабочихБаз(ПВХ, НастройкаОбменаДаннымиСсылка);
	ДобавитьНастройкуДляБазыUAT(ПВХ, НастройкаОбменаДаннымиСсылка);
	ДобавитьНастройкуДляТекущейБазы(ПВХ, НастройкаОбменаДаннымиСсылка);
	ТекстСообщения = "Добавлена запись в РС ""Внешние источники"" для настройки источника """ + Строка(ПВХ) + """";
	ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
КонецПроцедуры

Процедура ДобавитьИнтервал(ИнтервалыВТеченииДня, ВремяНачала, ВремяКонца, ПериодПовтораВТечениеДня, ПаузаПовтора)
	НовыйИнтервал = Новый Структура;
	
	НовыйИнтервал.Вставить("ВремяНачала", ВремяНачала);
	НовыйИнтервал.Вставить("ВремяКонца", ВремяКонца);
	НовыйИнтервал.Вставить("ПериодПовтораВТечениеДня", ПериодПовтораВТечениеДня);
	НовыйИнтервал.Вставить("ПаузаПовтора", ПаузаПовтора);
	
	ИнтервалыВТеченииДня.Добавить(НовыйИнтервал);
КонецПроцедуры

Процедура ЗаменитьКодЭлементаСправочника(ИмяСправочника, СтарыйКод, НовыйКод)
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Контрагенты.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.Контрагенты КАК Контрагенты
	|ГДЕ
	|	Контрагенты.Код = &СтарыйКод";
	Запрос.УстановитьПараметр("СтарыйКод", СтарыйКод);
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "Контрагенты", ИмяСправочника);
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() Тогда
		Текст = "В справочнике " + ИмяСправочника + " не найден элемент с кодом " + Строка(СтарыйКод)
				+ ", замена кода на " + Строка(НовыйКод) + " не произведена ...";
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(Текст);
	Иначе
		Выборка = РезультатЗапроса.Выбрать();
		Если Выборка.Количество() > 1 Тогда
			Текст = "В справочнике " + ИмяСправочника + " найдено больше одного элемента с кодом " + Строка(СтарыйКод)
				+ ", замена кода на " + Строка(НовыйКод) + " не произведена ...";
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(Текст);
		Иначе
			Выборка.Следующий();
			ЭлементОбъект = Выборка.Ссылка.ПолучитьОбъект();
			ЭлементОбъект.Код = НовыйКод;
			ЭлементОбъект.Записать();
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

Функция НовыйЭлементОбъект(ИмяСправочника, Наименование, Код = Неопределено)
	НовыйЭлементОбъект = Неопределено;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Контрагенты.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.Контрагенты КАК Контрагенты
	|ГДЕ
	|	Контрагенты.Наименование = &Наименование И Контрагенты.Код = &Код";
	Запрос.УстановитьПараметр("Наименование", Наименование);
	Если Код = Неопределено Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "И Контрагенты.Код = &Код", "");
	Иначе
		Запрос.УстановитьПараметр("Код", Код);
	КонецЕсли;
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() Тогда
		НовыйЭлементОбъект = Справочники[ИмяСправочника].СоздатьЭлемент();
		НовыйЭлементОбъект.Наименование = Наименование;
		НовыйЭлементОбъект.Код = Код;
	КонецЕсли;
	
	Возврат НовыйЭлементОбъект;
КонецФункции

Процедура ДобавитьВнешнийИсточникKafka(ПараметрыНастройки, ОбновлятьНастройкуОбмена = Ложь)
	
	ПВХ = ПараметрыНастройки.Источник.ПолучитьОбъект();
	ПВХ.Наименование = ПараметрыНастройки.ИмяНастройки;
	ПВХ.ТипВнешнегоИсточника = Перечисления.ТипыВнешнихИсточников.НастройкаОбменаДанными;
	ПВХ.Записать();
	
	НастройкаОбмена = Справочники.НастройкиОбменаДанными.НайтиПоНаименованию(ПараметрыНастройки.ИмяНастройки);
	Если ЗначениеЗаполнено(НастройкаОбмена) Тогда
		НастройкаОбменаОбъект = НастройкаОбмена.ПолучитьОбъект();
	Иначе
		НастройкаОбменаОбъект = Справочники.НастройкиОбменаДанными.СоздатьЭлемент();
	КонецЕсли;
	ЗаполнитьЗначенияСвойств(НастройкаОбменаОбъект, ПараметрыНастройки);
	НастройкаОбменаОбъект.Наименование = ПараметрыНастройки.ИмяНастройки;
	НастройкаОбменаОбъект.СпособОбмена = Перечисления.СпособыОбменаДанными.ОбменЧерезKafka;
	Если Не ЗначениеЗаполнено(НастройкаОбмена) Или ОбновлятьНастройкуОбмена Тогда
		НастройкаОбменаОбъект.Записать();
	КонецЕсли;
	
	НастройкаОбменаДаннымиСсылка = НастройкаОбменаОбъект.Ссылка;
	
	МенеджерЗаписи						= РегистрыСведений.ВнешниеИсточники.СоздатьМенеджерЗаписи();
	МенеджерЗаписи.ВнешнийИсточник		= ПВХ.Ссылка;
	МенеджерЗаписи.КластерСерверов		= ПараметрыСеанса.ТекущийКластерСерверов;
	МенеджерЗаписи.ИнформационнаяБаза	= ПараметрыСеанса.ТекущаяИнформационнаяБаза;
	МенеджерЗаписи.Настройка			= НастройкаОбменаДаннымиСсылка;
	МенеджерЗаписи.Записать();
	
	ДобавитьНастройкуДляБазыUAT(ПВХ.Ссылка, НастройкаОбменаДаннымиСсылка);
	ДобавитьНастройкуДляРабочихБаз(ПВХ.Ссылка, НастройкаОбменаДаннымиСсылка);
	
КонецПроцедуры

