		ИнформацияОбОшибке = ИнформацияОбОшибке();
		ОписаниеОшибки = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке);
		Возврат;
	КонецПопытки;
	
	ТарифныйПланСсылка = Справочники.ТарифныеПланы.НайтиПоКоду("000002");
	ТарифныйПлан = ТарифныйПланСсылка.ПолучитьОбъект();
	ТарифныйПлан.КодТарифаCRM = "PROFIT";
	Попытка
		ТарифныйПлан.Записать();
	Исключение
		Успешно = Ложь;
		ИнформацияОбОшибке = ИнформацияОбОшибке();
		ОписаниеОшибки = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке);
		Возврат;
	КонецПопытки;
	
КонецПроцедуры

Процедура ПеренестиДанныеПоЦБвТЧвНеисполненныхПоручениях()
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Поручение.Ссылка КАК Поручение,
	|	Поручение.Представление КАК Представление
	|ИЗ
	|	Документ.Поручение КАК Поручение
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.Поручение.ЦенныеБумагиСписываемые КАК ПоручениеЦенныеБумагиСписываемые
	|		ПО Поручение.Ссылка = ПоручениеЦенныеБумагиСписываемые.Ссылка
	|ГДЕ
	|	Поручение.ВидОперацииД В(&ВидыНеторговыхОперацийСоСпискомЦБ)
	|	И ПоручениеЦенныеБумагиСписываемые.ЦеннаяБумага ЕСТЬ NULL";
	
	Запрос.УстановитьПараметр("ВидыНеторговыхОперацийСоСпискомЦБ", Документы.Поручение.ВидыНеторговыхОперацийСоСпискомЦБ());
	
	ТекстСообщения = "";
	РезультатЗапроса = Запрос.Выполнить();
	ПорученияКОбработке = РезультатЗапроса.Выбрать();
	Пока ПорученияКОбработке.Следующий() Цикл
		ПоручениеОбъект = ПорученияКОбработке.Поручение.ПолучитьОбъект();
		НоваяСтрокаЦБ = ПоручениеОбъект.ЦенныеБумагиСписываемые.Добавить();
		НоваяСтрокаЦБ.ЦеннаяБумага = ПоручениеОбъект.ЦБ;
		НоваяСтрокаЦБ.Количество = ПоручениеОбъект.КоличествоЦБ;
		НоваяСтрокаЦБ.ИдентификаторЗагрузки = ПоручениеОбъект.ИдентификаторЗагрузки;
		ПоручениеОбъект.ОбменДанными.Загрузка = Истина;
		Попытка
			ПоручениеОбъект.Записать();
			ТекстСообщения = ТекстСообщения + ПорученияКОбработке.Представление + Символы.ПС;
		Исключение
			ИнформацияОбОшибке = ИнформацияОбОшибке();
			ПодробноеПредставлениеОшибки = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке);
			СписокОшибок.Добавить("Не удалось обработать " + ПорученияКОбработке.Представление + " по причине " + ПодробноеПредставлениеОшибки);
			Отказ = Истина;
		КонецПопытки;
	КонецЦикла;
	
	Если Не ПустаяСтрока(ТекстСообщения) Тогда
		ТекстСообщения = "В поручениях данные по ЦБ перенесены в табличную часть: " + Символы.ПС + ТекстСообщения;
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
	КонецЕсли;
	
КонецПроцедуры

Процедура ЗаменитьЗапросЦБвВидахИнвентарныхПоручений()
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ВидыИнвентарныхПоручений.Ссылка КАК ВидПоручения,
	|	ВидыИнвентарныхПоручений.Представление КАК ВидПорученияПредставление,
	|	ВидыИнвентарныхПоручений.СхемаКомпоновкиДанных КАК СхемаКомпоновкиДанных
	|ИЗ
	|	Справочник.ВидыИнвентарныхПоручений КАК ВидыИнвентарныхПоручений";
	
	РезультатЗапроса = Запрос.Выполнить();
	ВидыПорученийКОбработке = РезультатЗапроса.Выбрать();
	ТекстыЗапросовЦБ = ТекстыЗапросовЦБВидыИнвентарныхПоручений();
	ОбработанныеВидыПоручений = "";
	Пока ВидыПорученийКОбработке.Следующий() Цикл
		СКД = ВидыПорученийКОбработке.СхемаКомпоновкиДанных.Получить();
		Если СКД = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		НаборЦБ = СКД.НаборыДанных.Найти("ТЧ_ЦенныеБумаги");
		Если НаборЦБ = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		ЗапросУжеИзменен = СтрНайти(НаборЦБ.Запрос, "&ЭтоНеторговоеПоручениеСоСпискомЦБ") <> 0;
		Если ЗапросУжеИзменен Тогда
			Продолжить;
		КонецЕсли;
		
		Если СтрНайти(НаборЦБ.Запрос, ТекстыЗапросовЦБ.ТекстЗапросаЦБсСуммойСтарый) <> 0 Тогда
			НаборЦБ.Запрос = СтрЗаменить(НаборЦБ.Запрос,
			ТекстыЗапросовЦБ.ТекстЗапросаЦБсСуммойСтарый,
			ТекстыЗапросовЦБ.ТекстЗапросаЦБсСуммойНовый);
		ИначеЕсли СтрНайти(НаборЦБ.Запрос, ТекстыЗапросовЦБ.ТекстЗапросаЦББезСуммыСтарый) <> 0 Тогда
			НаборЦБ.Запрос = СтрЗаменить(НаборЦБ.Запрос,
			ТекстыЗапросовЦБ.ТекстЗапросаЦББезСуммыСтарый,
			ТекстыЗапросовЦБ.ТекстЗапросаЦББезСуммыНовый);
		Иначе
			ОписаниеОшибки = СтрШаблон("Не удалось заменить запрос по ЦБ в виде инвентарного поручения %1",
			ВидыПорученийКОбработке.ВидПорученияПредставление);
			СписокОшибок.Добавить(ОписаниеОшибки);
			Отказ = Истина;
			Продолжить;
		КонецЕсли;
		
		ПараметрЭтоПоручениеСоСпискомЦБ = СКД.Параметры.Добавить();
		ПараметрЭтоПоручениеСоСпискомЦБ.Имя = "ЭтоНеторговоеПоручениеСоСпискомЦБ";
		ПараметрЭтоПоручениеСоСпискомЦБ.Заголовок = "Это неторговое поручение со списком ЦБ";
		ПараметрЭтоПоручениеСоСпискомЦБ.Выражение = "Документы.Поручения.ЭтоНеторговоеПоручениеСоСпискомЦБ(&Сделка)";
		ПараметрЭтоПоручениеСоСпискомЦБ.ОграничениеИспользования = Истина;
		ПараметрЭтоПоручениеСоСпискомЦБ.ВключатьВДоступныеПоля = Истина;
		
		ВидПорученияОбъект = ВидыПорученийКОбработке.ВидПоручения.ПолучитьОбъект();
		ВидПорученияОбъект.СхемаКомпоновкиДанных = Новый ХранилищеЗначения(СКД);
		Попытка
			ВидПорученияОбъект.Записать();
			ОбработанныеВидыПоручений = ОбработанныеВидыПоручений + ВидыПорученийКОбработке.ВидПорученияПредставление + "; ";
		Исключение
			ИнформацияОбОшибке = ИнформацияОбОшибке();
			ПодробноеПредставлениеОшибки = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке);
			ОписаниеОшибки = "Не удалось обработать вид инвентарного поручения "
			+ ВидыПорученийКОбработке.ВидПорученияПредставление + " по причине " + ПодробноеПредставлениеОшибки;
			СписокОшибок.Добавить(ОписаниеОшибки);
			Отказ = Истина;
		КонецПопытки;
	КонецЦикла;
	
	Если ЗначениеЗаполнено(ОбработанныеВидыПоручений) Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Изменены запросы по ЦБ в видах инвентарных поручений: " + ОбработанныеВидыПоручений);
	КонецЕсли;
	
КонецПроцедуры

