Процедура НастройкаРегламентовЗагрузкиКотировокAPIRuData(РегламентСервисыИнтерфакса)
	
	ИмяРегламентаЗагрузитьКурсыВалютИнтерфакс = "ЗагрузитьКурсыВалютИнтерфакс";
	ИмяРегламентаЗагрузитьКотировкиСПБИнтерфакс = "ЗагрузитьКотировкиСПБИнтерфакс";
	
	ИменаДействий = Новый Массив;
	ИменаДействий.Добавить(ИмяРегламентаЗагрузитьКурсыВалютИнтерфакс);
	ИменаДействий.Добавить(ИмяРегламентаЗагрузитьКотировкиСПБИнтерфакс);
	ИменаДействий.Добавить("ЗагрузитьКотировкиПрочихТорговыхПлощадокИнтерфакс");
	
	КурсыВалютИнтерфакс = РегламентныеЗадания.НайтиПредопределенное(РегламентСервисыИнтерфакса);
	Если КурсыВалютИнтерфакс.Ключ <> ИменаДействий[0] Тогда
		КурсыВалютИнтерфакс.Наименование = "СервисыИнтерфакс " + "[" + ИмяРегламентаЗагрузитьКурсыВалютИнтерфакс + "]"; 
		КурсыВалютИнтерфакс.Ключ = ИменаДействий[0];
		КурсыВалютИнтерфакс.Использование = Ложь;
		КурсыВалютИнтерфакс.Записать();
	КонецЕсли;
	
	Для Каждого Действие Из ИменаДействий Цикл
		
		Наименование = "СервисыИнтерфакс " + "[" + Действие + "]";
		
		ПараметрыМетодаРЗ = Новый Массив;
		ПараметрыМетодаРЗ.Добавить(Действие);
		
		ИнтервалыВТеченииДня = Новый Массив;
		Если Действие = ИмяРегламентаЗагрузитьКурсыВалютИнтерфакс Тогда
			ДобавитьИнтервал(ИнтервалыВТеченииДня, Дата(1, 1, 1, 8, 00, 0), Дата(1, 1, 1, 0, 0, 0), 0, 0);
			ПараметрыМетодаРЗ.Добавить(Перечисления.ПериодыДней.ТекущийДень);
		ИначеЕсли Действие = ИмяРегламентаЗагрузитьКотировкиСПБИнтерфакс Тогда
			ДобавитьИнтервал(ИнтервалыВТеченииДня, Дата(1, 1, 1, 8, 05, 0), Дата(1, 1, 1, 0, 0, 0), 0, 0);
			ПараметрыМетодаРЗ.Добавить(Перечисления.ПериодыДней.ПустаяСсылка());
		Иначе
			ДобавитьИнтервал(ИнтервалыВТеченииДня, Дата(1, 1, 1, 8, 15, 0), Дата(1, 1, 1, 0, 0, 0), 0, 0);
			ПараметрыМетодаРЗ.Добавить(Перечисления.ПериодыДней.ПустаяСсылка());
		КонецЕсли;
		ДниНедели = СтрРазделить("1,2,3,4,5,6,7", ",");
		
		Успешно = НастройкаРегламентногоЗадания(РегламентСервисыИнтерфакса,
			ИнтервалыВТеченииДня, Наименование, Действие, ПараметрыМетодаРЗ, ДниНедели);
			
		Если Не Успешно Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не могу создать\обновить регламент " + Действие);
		Иначе // По-умолчанию задания отключены
			Отбор = Новый Структура("Метаданные", РегламентСервисыИнтерфакса);
			Отбор.Вставить("Наименование", Наименование);
			Задания = РегламентныеЗадания.ПолучитьРегламентныеЗадания(Отбор);
			Задание = Задания[0];
			Задание.Использование = Ложь;
			Задание.Записать();
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

Функция ЗаполнитьАвтораВРегистреСтатусыРСВ(ОписаниеОшибки)
	
	Успешно = Истина;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	РаскрытиеСпискаВладельцев.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.РаскрытиеСпискаВладельцев КАК РаскрытиеСпискаВладельцев
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СтатусыРаскрытияСписковВладельцев КАК СтатусыРаскрытияСписковВладельцев
	|		ПО РаскрытиеСпискаВладельцев.Ссылка = СтатусыРаскрытияСписковВладельцев.ДокументРаскрытия
	|ГДЕ
	|	РаскрытиеСпискаВладельцев.Дата >= &НачалоПериода
	|	И РаскрытиеСпискаВладельцев.ВидКорпоративногоДействия В(&ВидыКДДляРСВ)
	|	И РаскрытиеСпискаВладельцев.ТипЗагрузкиСписковРаскрытия <> ЗНАЧЕНИЕ(Перечисление.ТипЗагрузкиСписковРаскрытия.PARTAD)
	|	И РаскрытиеСпискаВладельцев.Статус = &СтатусВыгружено
	|	И НЕ РаскрытиеСпискаВладельцев.ПометкаУдаления
	|	И СтатусыРаскрытияСписковВладельцев.Статус = &СтатусВыгружено
	|	И СтатусыРаскрытияСписковВладельцев.Автор = ЗНАЧЕНИЕ(Справочник.Пользователи.ПустаяСсылка)";
	ВидыКДДляРСВ = Справочники.ВидыКорпоративныхДействий.ВидыКДРСВДляЖурналовВходящихИсходящих();
	Запрос.УстановитьПараметр("ВидыКДДляРСВ", ВидыКДДляРСВ);
	Запрос.УстановитьПараметр("НачалоПериода", Дата(2021, 10, 1));
	Запрос.УстановитьПараметр("СтатусВыгружено", Перечисления.СтатусыРаскрытияСписковВладельцев.Выгружено);
	ДокументыРСВ = Запрос.Выполнить().Выбрать();
	Пока ДокументыРСВ.Следующий() Цикл
		ЗаполнитьАвтораВРегистреСтатусыРСВДляДокумента(ДокументыРСВ.Ссылка, Успешно, ОписаниеОшибки);
	КонецЦикла;
	
	Возврат Успешно;
	
КонецФункции

Процедура ЗаполнитьАвтораВРегистреСтатусыРСВДляДокумента(Ссылка, Успешно, ОписаниеОшибки)
	
	НаборЗаписей = РегистрыСведений.СтатусыРаскрытияСписковВладельцев.СоздатьНаборЗаписей();
	НаборЗаписей.Отбор.ДокументРаскрытия.Установить(Ссылка);
	НаборЗаписей.Прочитать();
	Для Каждого Запись Из НаборЗаписей Цикл
		
		Если Запись.Статус = Перечисления.СтатусыРаскрытияСписковВладельцев.Выгружено
			И Не ЗначениеЗаполнено(Запись.Автор) Тогда
			
			Пользователь = ПользовательВыгрузившийДокумент(Ссылка);
			Если ЗначениеЗаполнено(Пользователь) Тогда
				Запись.Автор = Пользователь;
			КонецЕсли;
		КонецЕсли;
		
	КонецЦикла;
	
	Если НаборЗаписей.Модифицированность() Тогда
		Попытка
			НаборЗаписей.Записать(Истина);
		Исключение
			ИнформацияОбОшибке = ИнформацияОбОшибке();
			ТекстОшибки = ОбработкаОшибок.СообщениеОбОшибкеДляПользователя(ИнформацияОбОшибке);
			ТекстСообщения = СтрШаблон("Не удалось заполнить автора выгрузки для документа %1 по причине: %2", Ссылка, ТекстОшибки);
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
			ОписаниеОшибки = ОписаниеОшибки + ?(ЗначениеЗаполнено(ОписаниеОшибки), ", ", "") + ТекстСообщения;
			Успешно = Ложь;
		КонецПопытки;
	КонецЕсли;
	
КонецПроцедуры

Функция ПользовательВыгрузившийДокумент(Ссылка)
	
	Пользователь = Справочники.Пользователи.ПустаяСсылка();
	
	Условия = Новый Структура;
	Условия.Вставить("Поле", "Статус");
	Условия.Вставить("ЗначениеПослеИзменения", Перечисления.СтатусыРаскрытияСписковВладельцев.Выгружено);
	
	ЗначенияПолей = Новый Массив;
	ЗначенияПолей.Добавить(Условия);
	
	Отбор = Новый Структура;
	Отбор.Вставить("Данные", Ссылка);
	Отбор.Вставить("ЗначенияПолей", ЗначенияПолей);
	
	ИсторияДанных.ОбновитьИсторию(Ссылка);
	Версии = ИсторияДанных.ВыбратьВерсии(Отбор, "ИмяПользователя", , 1);
	Если Версии.Количество() > 0 Тогда
		Пользователь = Справочники.Пользователи.НайтиПоКоду(Версии[0].ИмяПользователя);
	КонецЕсли;
	
	Возврат Пользователь;
	
КонецФункции

