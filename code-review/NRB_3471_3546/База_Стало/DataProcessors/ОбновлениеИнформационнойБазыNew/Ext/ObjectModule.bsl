Функция НастройкаРегламентаФормированияСпискаИностранныхЦенныхБумагДляЗапросаКотировок(
	РегламентФормированиеСпискаИностранныхЦенныхБумагДляЗапросаКотировок)
	
	Наименование = "Формирование списка иностранных ценных бумаг для запроса котировок";
	
	Ключ = РегламентФормированиеСпискаИностранныхЦенныхБумагДляЗапросаКотировок.Имя;
	РегламентПредопределенное =
		РегламентныеЗадания.НайтиПредопределенное(РегламентФормированиеСпискаИностранныхЦенныхБумагДляЗапросаКотировок);
	Если РегламентПредопределенное.Ключ <> Ключ Тогда
		РегламентПредопределенное.Наименование = Наименование;
		РегламентПредопределенное.Ключ = Ключ;
		РегламентПредопределенное.Использование = Ложь;
		РегламентПредопределенное.Записать();
	КонецЕсли;
	
	ИнтервалыВТеченииДня = Новый Массив;
	ДобавитьИнтервал(ИнтервалыВТеченииДня, Дата(1, 1, 1, 01, 00, 0), Дата(1, 1, 1, 0, 0, 0), 0, 0);
	ПараметрыМетодаРЗ = Новый Массив;
	
	Успешно = НастройкаРегламентногоЗадания(РегламентФормированиеСпискаИностранныхЦенныхБумагДляЗапросаКотировок,
		ИнтервалыВТеченииДня, Наименование, Ключ, ПараметрыМетодаРЗ);
	
	Если Не Успешно Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не могу создать\обновить регламент: " + Наименование);
	Иначе // По-умолчанию задания включены
		Отбор = Новый Структура("Метаданные", РегламентФормированиеСпискаИностранныхЦенныхБумагДляЗапросаКотировок);
		Отбор.Вставить("Наименование", Наименование);
		Задания = РегламентныеЗадания.ПолучитьРегламентныеЗадания(Отбор);
		Задание = Задания[0];
		Задание.Использование = Истина;
		Задание.Записать();
	КонецЕсли;
	Возврат Успешно;
	
КонецФункции

