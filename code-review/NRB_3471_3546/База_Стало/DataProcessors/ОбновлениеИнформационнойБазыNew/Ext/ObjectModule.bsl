	|ГДЕ
	|	ВнешниеИсточники.КластерСерверов = ""SMSK01AP547""
	|	И ВнешниеИсточники.ИнформационнаяБаза = ""Custody""");
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		
		МенеджерЗаписи							= РегистрыСведений.ВнешниеИсточники.СоздатьМенеджерЗаписи();
		МенеджерЗаписи.КластерСерверов			= "SMSK02AP547";
		МенеджерЗаписи.ИнформационнаяБаза		= "Custody";
		ЗаполнитьЗначенияСвойств(МенеджерЗаписи, Выборка);
		МенеджерЗаписи.Записать();
		
		МенеджерЗаписи							= РегистрыСведений.ВнешниеИсточники.СоздатьМенеджерЗаписи();
		МенеджерЗаписи.КластерСерверов			= "SMSK01AP547;SMSK02AP547";
		МенеджерЗаписи.ИнформационнаяБаза		= "Custody";
		ЗаполнитьЗначенияСвойств(МенеджерЗаписи, Выборка);
		МенеджерЗаписи.Записать();

	КонецЦикла;

КонецПроцедуры

Процедура ЗаполнитьВТарифныхПланахКодCRM(Успешно, ОписаниеОшибки)
	
	ТарифныйПланСсылка = ОбщегоНазначенияПовтИсп.ЗначениеКонстанты("ОсновнойТарифныйПлан");
