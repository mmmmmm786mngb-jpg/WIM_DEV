	ЭтапУведомлениеОКД = Справочники.ЭтапыКД.НайтиПоКоду(КодЭтапаУведомлениеОКД);
	
	ИзменитьФормуСообщенияДляНовогоИЗамены("BPUT", ЭтапУведомлениеОКД, Перечисления.ФормыСообщенийКК.ОПроведенииКД_BPUT);
