Процедура СоздатьНастройкуОбменаDepoToBqTradabilityStatus1642()
	
	ПВХ = ПланыВидовХарактеристик.ВнешниеИсточники.KafkaDepoToBqTradabilityStatus1642;
	
	ПараметрыНастройки = Новый Структура;
	ПараметрыНастройки.Вставить("Источник", ПВХ);
	ИмяТопика = "Depo.ToBqTradabilityStatus.1642";
	ПараметрыНастройки.Вставить("KafkaТопик", ИмяТопика);
	ПараметрыНастройки.Вставить("ИмяНастройки", ИмяТопика);
	ПараметрыНастройки.Вставить("KafkaПользователь"	, "svc_Kafka_1C_NRB");
	СоздатьНастройкуОбменаKafka(ПараметрыНастройки); // настройка для прода
	
	ПараметрыНастройки.KafkaПользователь = "svc_Kafka_1C_NRB_UAT";
	ПараметрыНастройки.Вставить("ИмяНастройки", "(UAT) Depo.ToBqTradabilityStatus.1642");
	ЭтоITTest = Истина;
	СоздатьНастройкуОбменаKafka(ПараметрыНастройки, , , ЭтоITTest); // настройка для ITTest
	
	ПВХИсточник = ПланыВидовХарактеристик.ВнешниеИсточники.KafkaDepoToBqSecuritiesQuotes1642;
	УстановитьВНастройкеПарольКафкаПоОбразцу(ПВХ.Ссылка, ПВХИсточник);
	
КонецПроцедуры

Процедура УстановитьВНастройкеПарольКафкаПоОбразцу(ПВХПриемник, ПВХИсточник)
	НастройкаИсточник = ВнешниеДанные.ПолучитьПараметрыВнешнегоИсточника(ПВХИсточник).Настройка;
	НастройкаПриемник = ВнешниеДанные.ПолучитьПараметрыВнешнегоИсточника(ПВХПриемник).Настройка;
	
	Если ЗначениеЗаполнено(НастройкаИсточник) И ЗначениеЗаполнено(НастройкаПриемник) Тогда
		Если ЗначениеЗаполнено(НастройкаИсточник.KafkaПароль) И Не ЗначениеЗаполнено(НастройкаПриемник.KafkaПароль) Тогда
			НастройкаПриемникОбъект = НастройкаПриемник.ПолучитьОбъект();
			НастройкаПриемникОбъект.KafkaПароль = НастройкаИсточник.KafkaПароль;
			НастройкаПриемникОбъект.Записать();
			Текст = "Для настройки " + НастройкаПриемник.Наименование + " установлен пароль по образцу настройки " + НастройкаИсточник.Наименование;
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(Текст);
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

