Процедура УдалитьДанныеПоРабочемуСтолуСотрудника()
	
	СтрокаКодовНастроекПользователей = "00048,00050,00051,00049";
	КодыНастройкиПользователей = СтрРазделить(СтрокаКодовНастроекПользователей, ",");
	Для Каждого КодНастройки Из КодыНастройкиПользователей Цикл
		Настройка = ПланыВидовХарактеристик.НастройкиПользователей.НайтиПоКоду(КодНастройки);
		Если ЗначениеЗаполнено(Настройка) Тогда
			
			НаборЗаписей = РегистрыСведений.НастройкиПользователей.СоздатьНаборЗаписей();
			НаборЗаписей.Отбор.Настройка.Установить(Настройка);
			НачатьТранзакцию();
			
			Попытка
				НаборЗаписей.Записать();
				НастройкаОбъект = Настройка.ПолучитьОбъект();
				НастройкаОбъект.Удалить();
				ЗафиксироватьТранзакцию();
			Исключение
				ОтменитьТранзакцию();
				ТекстОшибки = "Ошибка при удалении настройки пользователя " + Строка(Настройка);
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстОшибки, Настройка);
			КонецПопытки;
			
		КонецЕсли;
	КонецЦикла;
	
	СтрокаКодовВнешнихИсточников = "ОРС0000001,ОРС0000002,ОРС0000003,ОРС";
	КодыВнешниеИсточники = СтрРазделить(СтрокаКодовВнешнихИсточников, ",");
	Для Каждого КодИсточника Из КодыВнешниеИсточники Цикл
		
		Источник = ПланыВидовХарактеристик.ВнешниеИсточники.НайтиПоКоду(КодИсточника);
		Если ЗначениеЗаполнено(Источник) Тогда
			ИсточникОбъект = Источник.ПолучитьОбъект();
			Попытка
				ИсточникОбъект.Удалить();
			Исключение
				ТекстОшибки = "Ошибка при удалении внешнего источника " + Строка(Настройка);
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстОшибки, Настройка);
			КонецПопытки;
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

