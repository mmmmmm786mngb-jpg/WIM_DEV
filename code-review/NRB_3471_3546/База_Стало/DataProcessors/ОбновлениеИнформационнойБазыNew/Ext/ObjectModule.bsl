Процедура ДобавитьВнешнийИсточникЗагрузкаИзВнешнейAPINSD()
	
	ПараметрыНастройки = Новый Структура();
	ПараметрыНастройки.Вставить("ИмяНастройки", "HTTP Сервис. API National settlement depository (NSD)");
	ПараметрыНастройки.Вставить("Источник", ПланыВидовХарактеристик.ВнешниеИсточники.ЗагрузкаИзВнешнейAPINSD);
	ПараметрыНастройки.Вставить("HTTPСервисАдресСервера", "nsddata.ru");
	ПараметрыНастройки.Вставить("HTTPСервисПользователь", "");
	ПараметрыНастройки.Вставить("HTTPСервисПароль", "");
	ПараметрыНастройки.Вставить("HTTPСервисТаймаут", 60);
	ПараметрыНастройки.Вставить("HTTPСервисЗащищенноеСоединение", Истина);
	ПараметрыНастройки.Вставить("HTTPСервисАдресРесурсаАутентификации", "");
	ПараметрыНастройки.Вставить("HTTPСервисАдресРесурса", "/api/get/eod");
	
	ПВХ = ПараметрыНастройки.Источник.ПолучитьОбъект();
	ПВХ.Наименование = ПараметрыНастройки.ИмяНастройки;
	ПВХ.ТипВнешнегоИсточника = Перечисления.ТипыВнешнихИсточников.НастройкаОбменаДанными;
	ПВХ.Записать();
	
	НастройкаОбмена = Справочники.НастройкиОбменаДанными.НайтиПоНаименованию(ПараметрыНастройки.ИмяНастройки);
	Если ЗначениеЗаполнено(НастройкаОбмена) Тогда
		НастройкаОбменаОбъект = НастройкаОбмена.ПолучитьОбъект();
		СуществующийПользователь = НастройкаОбменаОбъект.HTTPСервисПользователь;
		СуществующийПароль		 = НастройкаОбменаОбъект.HTTPСервисПароль;
	Иначе
		НастройкаОбменаОбъект = Справочники.НастройкиОбменаДанными.СоздатьЭлемент();
		СуществующийПользователь = "N\A";
		СуществующийПароль		 = "";
	КонецЕсли;
	ЗаполнитьЗначенияСвойств(НастройкаОбменаОбъект, ПараметрыНастройки);
	НастройкаОбменаОбъект.HTTPСервисПользователь = СуществующийПользователь;
	НастройкаОбменаОбъект.HTTPСервисПароль		 = СуществующийПароль;
	НастройкаОбменаОбъект.Наименование			 = ПараметрыНастройки.ИмяНастройки;
	НастройкаОбменаОбъект.СпособОбмена			 = Перечисления.СпособыОбменаДанными.ОбменЧерезHTTPСервис;
	НастройкаОбменаОбъект.Записать();
	
	НастройкаОбменаДаннымиСсылка = НастройкаОбменаОбъект.Ссылка;
	
	МенеджерЗаписи						= РегистрыСведений.ВнешниеИсточники.СоздатьМенеджерЗаписи();
	МенеджерЗаписи.ВнешнийИсточник		= ПВХ.Ссылка;
	МенеджерЗаписи.КластерСерверов		= ПараметрыСеанса.ТекущийКластерСерверов;
	МенеджерЗаписи.ИнформационнаяБаза	= ПараметрыСеанса.ТекущаяИнформационнаяБаза;
	МенеджерЗаписи.Настройка			= НастройкаОбменаДаннымиСсылка;
	МенеджерЗаписи.Записать();
	
	ДобавитьНастройкуДляБазыUAT(ПВХ.Ссылка, НастройкаОбменаДаннымиСсылка);
	ДобавитьНастройкуДляРабочихБаз(ПВХ.Ссылка, НастройкаОбменаДаннымиСсылка);
	
КонецПроцедуры

Процедура ОтформатироватьСтроковыеКодыИсточниковКотировок()
	
	ТипЧисло = Новый ОписаниеТипов("Число");
	ВыборкаСправочникаИсточникиКотировок = Справочники.ИсточникиКотировок.Выбрать();
	Пока ВыборкаСправочникаИсточникиКотировок.Следующий() Цикл
		КодЧислом = ТипЧисло.ПривестиЗначение(ВыборкаСправочникаИсточникиКотировок.Код);
		Если КодЧислом > 0 Тогда
			Источник = ВыборкаСправочникаИсточникиКотировок.ПолучитьОбъект();
			Источник.Код = Формат(КодЧислом, "ЧГ=0");
			Источник.ОбменДанными.Загрузка = Истина;
			Источник.Записать();
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

Процедура ДобавитьВнешнийИсточникЗагрузкаИзВнешнейAPICBonds()
	
	ПараметрыНастройки = Новый Структура();
	ПараметрыНастройки.Вставить("ИмяНастройки", "HTTP Сервис. API CBonds");
	ПараметрыНастройки.Вставить("Источник", ПланыВидовХарактеристик.ВнешниеИсточники.ЗагрузкаИзВнешнейAPICBonds);
	ПараметрыНастройки.Вставить("HTTPСервисАдресСервера"				, "ws2.cbonds.info");
	ПараметрыНастройки.Вставить("HTTPСервисПорт"						, 443);
	ПараметрыНастройки.Вставить("HTTPСервисПользователь"				, "");
	ПараметрыНастройки.Вставить("HTTPСервисПароль"						, "");
	ПараметрыНастройки.Вставить("HTTPСервисТаймаут"						, 300);
	ПараметрыНастройки.Вставить("HTTPСервисЗащищенноеСоединение"		, Истина);
	ПараметрыНастройки.Вставить("HTTPСервисАдресРесурсаАутентификации"	, "");
	ПараметрыНастройки.Вставить("HTTPСервисАдресРесурса"				, "/services/wsdl");
	
	ПВХ = ПараметрыНастройки.Источник.ПолучитьОбъект();
	ПВХ.Наименование = ПараметрыНастройки.ИмяНастройки;
	ПВХ.ТипВнешнегоИсточника = Перечисления.ТипыВнешнихИсточников.НастройкаОбменаДанными;
	ПВХ.Записать();
	
	НастройкаОбмена = Справочники.НастройкиОбменаДанными.НайтиПоНаименованию(ПараметрыНастройки.ИмяНастройки);
	Если ЗначениеЗаполнено(НастройкаОбмена) Тогда
		НастройкаОбменаОбъект = НастройкаОбмена.ПолучитьОбъект();
		СуществующийПользователь = НастройкаОбменаОбъект.HTTPСервисПользователь;
		СуществующийПароль		 = НастройкаОбменаОбъект.HTTPСервисПароль;
	Иначе
		НастройкаОбменаОбъект = Справочники.НастройкиОбменаДанными.СоздатьЭлемент();
		СуществующийПользователь = "";
		СуществующийПароль		 = "";
	КонецЕсли;
	ЗаполнитьЗначенияСвойств(НастройкаОбменаОбъект, ПараметрыНастройки);
	НастройкаОбменаОбъект.HTTPСервисПользователь = СуществующийПользователь;
	НастройкаОбменаОбъект.HTTPСервисПароль		 = СуществующийПароль;
	НастройкаОбменаОбъект.Наименование			 = ПараметрыНастройки.ИмяНастройки;
	НастройкаОбменаОбъект.СпособОбмена			 = Перечисления.СпособыОбменаДанными.ОбменЧерезHTTPСервис;
	НастройкаОбменаОбъект.Записать();
	
	НастройкаОбменаДаннымиСсылка = НастройкаОбменаОбъект.Ссылка;
	
	МенеджерЗаписи						= РегистрыСведений.ВнешниеИсточники.СоздатьМенеджерЗаписи();
	МенеджерЗаписи.ВнешнийИсточник		= ПВХ.Ссылка;
	МенеджерЗаписи.КластерСерверов		= ПараметрыСеанса.ТекущийКластерСерверов;
	МенеджерЗаписи.ИнформационнаяБаза	= ПараметрыСеанса.ТекущаяИнформационнаяБаза;
	МенеджерЗаписи.Настройка			= НастройкаОбменаДаннымиСсылка;
	МенеджерЗаписи.Записать();
	
	ДобавитьНастройкуДляБазыUAT(ПВХ.Ссылка, НастройкаОбменаДаннымиСсылка);
	ДобавитьНастройкуДляРабочихБаз(ПВХ.Ссылка, НастройкаОбменаДаннымиСсылка);
	
КонецПроцедуры

Процедура НастройкаРегламентовЗагрузкиКотировокAPICBonds(РегламентСервисыCBonds)
	
	ИмяРегламентаЗагрузитьИндикативныеКотировкиCBonds = "ЗагрузитьИндикативныеКотировкиCBonds";
	
	ИменаДействий = Новый Массив;
	ИменаДействий.Добавить(ИмяРегламентаЗагрузитьИндикативныеКотировкиCBonds);
	ИменаДействий.Добавить("ЗагрузитьБиржевыеКотировкиТорговыхПлощадокCBonds");
	
	ЗагрузкаИтоговТорговЧерезCBondsAPI = РегламентныеЗадания.НайтиПредопределенное(РегламентСервисыCBonds);
	Если ЗагрузкаИтоговТорговЧерезCBondsAPI.Ключ <> ИменаДействий[0] Тогда
		ЗагрузкаИтоговТорговЧерезCBondsAPI.Наименование = "СервисыCBonds " + "[" + ИмяРегламентаЗагрузитьИндикативныеКотировкиCBonds + "]"; 
		ЗагрузкаИтоговТорговЧерезCBondsAPI.Ключ = ИменаДействий[0];
		ЗагрузкаИтоговТорговЧерезCBondsAPI.Использование = Ложь;
		ЗагрузкаИтоговТорговЧерезCBondsAPI.Записать();
	КонецЕсли;
	
	Для Каждого Действие Из ИменаДействий Цикл
		
		Наименование = "СервисыCBonds " + "[" + Действие + "]";
		
		ПараметрыМетодаРЗ = Новый Массив;
		ПараметрыМетодаРЗ.Добавить(Действие);
		
		ИнтервалыВТеченииДня = Новый Массив;
		Если Действие = ИмяРегламентаЗагрузитьИндикативныеКотировкиCBonds Тогда
			ДобавитьИнтервал(ИнтервалыВТеченииДня, Дата(1, 1, 1, 8, 30, 0), Дата(1, 1, 1, 0, 0, 0), 0, 0);
			ДобавитьИнтервал(ИнтервалыВТеченииДня, Дата(1, 1, 1, 22, 30, 0), Дата(1, 1, 1, 0, 0, 0), 0, 0);
			ПараметрыМетодаРЗ.Добавить(Перечисления.ПериодыДней.ПредыдущийРабочийДень);
		Иначе
			ДобавитьИнтервал(ИнтервалыВТеченииДня, Дата(1, 1, 1, 8, 40, 0), Дата(1, 1, 1, 0, 0, 0), 0, 0);
			ДобавитьИнтервал(ИнтервалыВТеченииДня, Дата(1, 1, 1, 22, 40, 0), Дата(1, 1, 1, 0, 0, 0), 0, 0);
			ПараметрыМетодаРЗ.Добавить(Перечисления.ПериодыДней.ПредыдущийРабочийДень);
		КонецЕсли;
		ДниНедели = СтрРазделить("2,3,4,5,6", ",");
		
		Успешно = НастройкаРегламентногоЗадания(РегламентСервисыCBonds,
			ИнтервалыВТеченииДня, Наименование, Действие, ПараметрыМетодаРЗ, ДниНедели);
			
		Если Не Успешно Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не могу создать\обновить регламент " + Действие);
		Иначе // По-умолчанию задания включены
			Отбор = Новый Структура("Метаданные", РегламентСервисыCBonds);
			Отбор.Вставить("Наименование", Наименование);
			Задания = РегламентныеЗадания.ПолучитьРегламентныеЗадания(Отбор);
			Задание = Задания[0];
			Задание.Использование = Истина;
			Задание.Записать();
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

