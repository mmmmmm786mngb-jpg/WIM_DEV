Функция НастройкаРегламентаЗагрузкиКотировокММВБ(РегламентЗагрузкиКотировокММВБ)
	
	Действие = "ФайлММВБ";
	Наименование = "Загрузка котировок [" + Действие + "]";
	
	Ключ = РегламентЗагрузкиКотировокММВБ.Имя + Действие;
	РегламентЗагрузкиКотировокММВБПредопределенное = РегламентныеЗадания.НайтиПредопределенное(РегламентЗагрузкиКотировокММВБ);
	Если РегламентЗагрузкиКотировокММВБПредопределенное.Ключ <> Ключ Тогда
		РегламентЗагрузкиКотировокММВБПредопределенное.Наименование = Наименование;
		РегламентЗагрузкиКотировокММВБПредопределенное.Ключ = Ключ;
		РегламентЗагрузкиКотировокММВБПредопределенное.Использование = Ложь;
		РегламентЗагрузкиКотировокММВБПредопределенное.Записать();
	КонецЕсли;
	
	ИнтервалыВТеченииДня = Новый Массив;
	ДобавитьИнтервал(ИнтервалыВТеченииДня, Дата(1, 1, 1, 20, 00, 0), Дата(1, 1, 1, 0, 0, 0), 0, 0);
	ДобавитьИнтервал(ИнтервалыВТеченииДня, Дата(1, 1, 1, 02, 00, 0), Дата(1, 1, 1, 0, 0, 0), 0, 0);
	ПараметрыМетодаРЗ = Новый Массив;
	ПараметрыМетодаРЗ.Добавить(Действие);
	
	Успешно = НастройкаРегламентногоЗадания(РегламентЗагрузкиКотировокММВБ,
		ИнтервалыВТеченииДня, Наименование, Ключ, ПараметрыМетодаРЗ);
	
	Если Не Успешно Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не могу создать\обновить регламент: " + Наименование);
	Иначе // По-умолчанию задания отключены
		Отбор = Новый Структура("Метаданные", РегламентЗагрузкиКотировокММВБ);
		Отбор.Вставить("Наименование", Наименование);
		Задания = РегламентныеЗадания.ПолучитьРегламентныеЗадания(Отбор);
		Задание = Задания[0];
		Задание.Использование = Ложь;
		Задание.Записать();
	КонецЕсли;
	Возврат Успешно;
	
КонецФункции

