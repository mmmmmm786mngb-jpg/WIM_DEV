Функция ОбработкаОбновленияПоЗадаче(НомерЗадачи, ВыполнитьОбновлениеПоЗадаче)

	Если НЕ ВыполнитьОбновлениеПоЗадаче Тогда
	
		НоваяСтрока = СписокОбновления.Добавить();
		НоваяСтрока.НомерЗадачи = НомерЗадачи;
		
		Возврат Ложь
	Иначе
		Отказ = Ложь;
		СписокОшибок.Очистить();
		
		ЗадачаДляОбновления = СписокОбновления.Найти(НомерЗадачи, "НомерЗадачи");
		Если ЗадачаДляОбновления = Неопределено Тогда
			Возврат Ложь
		КонецЕсли;
		
		Возврат ЗадачаДляОбновления.ТребуетсяОбновление
	КонецЕсли;
	
КонецФункции

// Процедура создает запись о выполнении обработчика обновления в регистре сведений "Журнал регистрации выполнения
// обработчиков обновления".
// Параметры:
//	НомерЗадачи - Число - целое число до 5 знаков включительно
//	Успешно - булево - был ли обработчик выполнен успешно (без ошибок). Необязательный параметр, по умолчанию равен Не Отказ.
//	Комментарий - Строка - произвольная информация о выполнении обработчика, например, сообщения о произошедших 
//		ошибках. Необязательный параметр.
//	ДатаВыполнения - Дата - Дата и время завершения выполнения обработчика. Необязательный параметр, по умолчанию 
//		текущая дата сеанса.
//	СообщитьОбОкончании - Булево - требуется ли выдать пользователю сообщение о завершении выполнения обработчика.
//		Необязательный параметр, по умолчанию Истина.
Процедура ЛогироватьВыполнениеОбработчика(НомерЗадачи, Успешно = Неопределено, Комментарий = Неопределено,
	ДатаВыполнения = Неопределено, СообщитьОбОкончании = Истина)
	
	Если Комментарий = Неопределено Тогда
		Комментарий = "";
		Для Каждого Сообщение Из СписокОшибок Цикл
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(Сообщение.Значение);
			Комментарий = Комментарий + Сообщение.Значение + Символы.ПС;
		КонецЦикла;
	КонецЕсли;
	
	Запись = РегистрыСведений.ЖурналРегистрацииВыполненияОбработчиковОбновления.СоздатьМенеджерЗаписи();
	Запись.НомерЗадачи = НомерЗадачи;
	Запись.УИД = Новый УникальныйИдентификатор;
	Если ДатаВыполнения = Неопределено Тогда
		ДатаВыполнения = ТекущаяДатаСеанса();
	КонецЕсли;
	Запись.ДатаВыполнения = ДатаВыполнения;
	Если Успешно = Неопределено Тогда
		Успешно = Не Отказ;
	КонецЕсли;
	Запись.Успешно = Успешно;
	Запись.Комментарий = Комментарий;
	Запись.Выполнил = ПараметрыСеанса.ТекущийПользователь;
	Запись.Записать();
	НомерСтрокой = Формат(НомерЗадачи, "ЧН=0; ЧГ=");
	Если СообщитьОбОкончании Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Обновление по задаче " + НомерСтрокой + ?(Успешно, " завершено.", " не выполнено!"));
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

