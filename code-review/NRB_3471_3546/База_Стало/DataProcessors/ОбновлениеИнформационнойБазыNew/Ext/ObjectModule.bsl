Процедура ИзменитьФормуСообщения(ВидКД, Этап, ТипУведомления, ФормаСообщенияНовоеЗначение)
	Набор = РегистрыСведений.ФормыСообщенийКабинетаКлиентаВТБКБ.СоздатьНаборЗаписей();
	Набор.Отбор.ВидКД.Установить(ВидКД);
	Набор.Отбор.Этап.Установить(Этап);
	Набор.Отбор.ТипУведомления.Установить(ТипУведомления);
	Набор.Прочитать();
	Для каждого Запись Из Набор Цикл
		Запись.ФормаСообщения = ФормаСообщенияНовоеЗначение;
	КонецЦикла;
	Набор.Записать();
	Текст = "Форма сообщения обновлена на этапе ""Уведомление о КД"" для вида КД "
				+ Строка(ВидКД) + ", тип уведомления " + Строка(ТипУведомления);
	ОбщегоНазначенияКлиентСервер.СообщитьПользователю(Текст);
КонецПроцедуры

Процедура СоздатьЭтапыКДиЗаполнитьФормыСообщенийДля791()
	
	КодЭтапаКДИзвещение = "ME011";
	КодЭтапаКДОтмена = "ME021";
	
	ЭтапКДИзвещение = Справочники.ЭтапыКД.НайтиПоКоду(КодЭтапаКДИзвещение);
	Если Не ЗначениеЗаполнено(ЭтапКДИзвещение) Тогда
		ЭтапКДИзвещениеОбъект = Справочники.ЭтапыКД.СоздатьЭлемент();
		ЭтапКДИзвещениеОбъект.Код = КодЭтапаКДИзвещение;
		ЭтапКДИзвещениеОбъект.Наименование = "Извещение о собрании владельцев ЦБ (SRDII)";
		ЭтапКДИзвещениеОбъект.ФормироватьУведомление = Истина;
		ЭтапКДИзвещениеОбъект.Записать();
		ЭтапКДИзвещение = ЭтапКДИзвещениеОбъект.Ссылка;
	КонецЕсли;
	
	ЭтапКДОтмена = Справочники.ЭтапыКД.НайтиПоКоду(КодЭтапаКДОтмена);
	Если Не ЗначениеЗаполнено(ЭтапКДОтмена) Тогда
		ЭтапКДОтменаОбъект = Справочники.ЭтапыКД.СоздатьЭлемент();
		ЭтапКДОтменаОбъект.Код = КодЭтапаКДОтмена;
		ЭтапКДОтменаОбъект.Наименование = "Отмена собрания владельцев ЦБ (SRDII)";
		ЭтапКДОтменаОбъект.ФормироватьУведомление = Истина;
		ЭтапКДОтменаОбъект.Записать();
		ЭтапКДОтмена = ЭтапКДОтменаОбъект.Ссылка;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ВидыКорпоративныхДействий.Ссылка КАК ВидКД
	|ИЗ
	|	Справочник.ВидыКорпоративныхДействий КАК ВидыКорпоративныхДействий
	|ГДЕ
	|	ВидыКорпоративныхДействий.Код В(&Код)";
	
	КодыВидовКД = Новый Массив;
	КодыВидовКД.Добавить("XMET");
	КодыВидовКД.Добавить("MEET");
	КодыВидовКД.Добавить("CONS");
	КодыВидовКД.Добавить("OMET");
	КодыВидовКД.Добавить("BMET");
	Запрос.УстановитьПараметр("Код", КодыВидовКД);
	
	ВыборкаВидыКД = Запрос.Выполнить().Выбрать();
	
	Пока ВыборкаВидыКД.Следующий() Цикл
		
		МенеджерЗаписи = РегистрыСведений.ФормыСообщенийКабинетаКлиентаВТБКБ.СоздатьМенеджерЗаписи();
		МенеджерЗаписи.ВидКД = ВыборкаВидыКД.ВидКД;
		МенеджерЗаписи.Этап = ЭтапКДИзвещение;
		МенеджерЗаписи.ФормаСообщения = Перечисления.ФормыСообщенийКК.ОПоступленииМатериаловКОбщемуСобраниюВладельцев;
		МенеджерЗаписи.Записать();
		
		МенеджерЗаписи = РегистрыСведений.ФормыСообщенийКабинетаКлиентаВТБКБ.СоздатьМенеджерЗаписи();
		МенеджерЗаписи.ВидКД = ВыборкаВидыКД.ВидКД;
		МенеджерЗаписи.Этап = ЭтапКДОтмена;
		МенеджерЗаписи.ФормаСообщения = Перечисления.ФормыСообщенийКК.ОбОтменеСобрания;
		МенеджерЗаписи.Записать();
		
	КонецЦикла;
	
КонецПроцедуры

Процедура ПерезагрузкаЦенныхБумагИнтерфакс(ТаблицаЦенныхБумагСISIN, Успешно)
	
	ISINs = ОбщегоНазначения.ВыгрузитьКолонку(ТаблицаЦенныхБумагСISIN, "ISIN", Истина, Истина);
	Если Не ЗначениеЗаполнено(ISINs) Тогда
		Возврат;
	КонецЕсли;
	
	ИмяПараметраФильтрСтатусов = "101.RuData_ФильтрСтатусовЦБ";
	ИмяПараметраОбновитьЭмитентыВсехЗагружаемыхЦенныхБумаг = "101.RuData_ОбновитьЭмитентыВсехЗагружаемыхЦБ";
	
	РегистрыСведений.ПараметрыГлобальные.УдалитьПараметр(ИмяПараметраФильтрСтатусов);
	РегистрыСведений.ПараметрыГлобальные.УдалитьПараметр(ИмяПараметраОбновитьЭмитентыВсехЗагружаемыхЦенныхБумаг);
	
	Статусы1 = "'Аннулирован','Готовится','Досрочно погашен','Не определено','Погашен',";
	Статусы2 = "'Прекращение','Приостановлен','Размещается','Размещен','Списан'";
	ДополнительныеСтатусыДляЗагрузки = Статусы1 + Статусы2;
	КомментарийПараметра = "Установлен обработкой ОбновлениеИнформационнойБазыNew " + ТекущаяДатаСеанса();
	ФильтрСтатусов = "'В обращении', 'Дефолт', " + СокрЛП(ДополнительныеСтатусыДляЗагрузки);
	РегистрыСведений.ПараметрыГлобальные.УстановитьЗначениеПараметра(ИмяПараметраФильтрСтатусов, ФильтрСтатусов,
		КомментарийПараметра);
	РегистрыСведений.ПараметрыГлобальные.УстановитьЗначениеПараметра(ИмяПараметраОбновитьЭмитентыВсехЗагружаемыхЦенныхБумаг, Истина,
		КомментарийПараметра);
	
	ВходныеПараметры = Новый Структура;
	ВходныеПараметры.Вставить("ISINs", ISINs);
	ВходныеПараметры.Вставить("ДатаВремяОбновленияДанных", Дата('00010101'));
	Успешно = RuDataAPI.СозданиеОбновлениеЦенныхБумагИЭмитентов(ВходныеПараметры);
	
	РегистрыСведений.ПараметрыГлобальные.УдалитьПараметр(ИмяПараметраФильтрСтатусов);
	РегистрыСведений.ПараметрыГлобальные.УдалитьПараметр(ИмяПараметраОбновитьЭмитентыВсехЗагружаемыхЦенныхБумаг);
	
КонецПроцедуры

Процедура ПоискИУдалениеДублейИнтерфакс(Успешно)
	
	ТаблицаЦенныхБумагСISIN = Новый ТаблицаЗначений;
	ТаблицаЦенныхБумагСISIN.Колонки.Добавить("ISIN");
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	КодыЗагрузки.Владелец КАК ЦеннаяБумагаКУдалению
	|ИЗ
	|	Справочник.КодыЗагрузки КАК КодыЗагрузки
	|ГДЕ
	|	КодыЗагрузки.Биржа = ЗНАЧЕНИЕ(Справочник.КлассификаторыЗагрузки.RuData)
	|	И КодыЗагрузки.Владелец ССЫЛКА Справочник.ЦенныеБумаги
	|	И НЕ КодыЗагрузки.Владелец.ПометкаУдаления
	|	И НЕ КодыЗагрузки.ПометкаУдаления
	|
	|СГРУППИРОВАТЬ ПО
	|	КодыЗагрузки.Владелец
	|
	|ИМЕЮЩИЕ
	|	КОЛИЧЕСТВО(КодыЗагрузки.Ссылка) > 1";
	РезультатЗапроса = Запрос.Выполнить();
	ЦенныеБумагаКУдалению = РезультатЗапроса.Выгрузить().ВыгрузитьКолонку("ЦеннаяБумагаКУдалению");
	Для Каждого ЦеннаяБумага Из ЦенныеБумагаКУдалению Цикл
		ЦеннаяБумагаОбъект = ЦеннаяБумага.ПолучитьОбъект();
		ЦеннаяБумагаОбъект.ОбменДанными.Загрузка = Истина;
		ЦеннаяБумагаОбъект.УстановитьПометкуУдаления(Истина, Истина);
		НовыйISIN = ТаблицаЦенныхБумагСISIN.Добавить();
		НовыйISIN.ISIN = ЦеннаяБумагаОбъект.ISIN;
	КонецЦикла;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	КодыЗагрузки.Владелец КАК ЮрЛицоКУдалению
	|ИЗ
	|	Справочник.КодыЗагрузки КАК КодыЗагрузки
	|ГДЕ
	|	КодыЗагрузки.Биржа = ЗНАЧЕНИЕ(Справочник.КлассификаторыЗагрузки.RuData)
	|	И КодыЗагрузки.Владелец ССЫЛКА Справочник.ЮридическиеЛица
	|	И НЕ КодыЗагрузки.Владелец.ПометкаУдаления
	|	И НЕ КодыЗагрузки.ПометкаУдаления
	|
	|СГРУППИРОВАТЬ ПО
	|	КодыЗагрузки.Владелец
	|
	|ИМЕЮЩИЕ
	|	КОЛИЧЕСТВО(КодыЗагрузки.Ссылка) > 1";
	РезультатЗапроса = Запрос.Выполнить();
	ЮридическиеФизическиеЛица = РезультатЗапроса.Выгрузить().ВыгрузитьКолонку("ЮрЛицоКУдалению");
	Для Каждого ЮрЛицо Из ЮридическиеФизическиеЛица Цикл
		ЮрЛицоОбъект = ЮрЛицо.ПолучитьОбъект();
		ЮрЛицоОбъект.УстановитьПометкуУдаления(Истина, Истина);
	КонецЦикла;
	
	Если Не ЗначениеЗаполнено(ЦенныеБумагаКУдалению) И Не ЗначениеЗаполнено(ЮридическиеФизическиеЛица) Тогда
		Возврат;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Контрагенты.Ссылка КАК Контрагент
	|ИЗ
	|	Справочник.Контрагенты КАК Контрагенты
	|ГДЕ
	|	Контрагенты.ЮридическиеФизическиеЛица В(&ЮридическиеФизическиеЛица)
	|	И НЕ Контрагенты.ПометкаУдаления
	|	И Контрагенты.Родитель = ЗНАЧЕНИЕ(Справочник.Контрагенты.Эмитенты)";
	Запрос.УстановитьПараметр("ЮридическиеФизическиеЛица", ЮридическиеФизическиеЛица);
	РезультатЗапроса = Запрос.Выполнить();
	Эмитенты = РезультатЗапроса.Выгрузить().ВыгрузитьКолонку("Контрагент");
	Для Каждого Эмитент Из Эмитенты Цикл
		ЭмитентОбъект = Эмитент.ПолучитьОбъект();
		ЭмитентОбъект.УстановитьПометкуУдаления(Истина, Истина);
	КонецЦикла;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ЦенныеБумаги.Ссылка КАК ЦеннаяБумагаЭмитента
	|ИЗ
	|	Справочник.ЦенныеБумаги КАК ЦенныеБумаги
	|ГДЕ
	|	НЕ ЦенныеБумаги.ПометкаУдаления
	|	И ЦенныеБумаги.Эмитент В(&Эмитенты)";
	Запрос.УстановитьПараметр("Эмитенты", Эмитенты);
	РезультатЗапроса = Запрос.Выполнить();
	ЦенныеБумагиЭмитентовДвойников = РезультатЗапроса.Выгрузить().ВыгрузитьКолонку("ЦеннаяБумагаЭмитента");
	Для Каждого ЦеннаяБумага Из ЦенныеБумагиЭмитентовДвойников Цикл
		НовыйISIN = ТаблицаЦенныхБумагСISIN.Добавить();
		НовыйISIN.ISIN = ЦеннаяБумага.ISIN;
	КонецЦикла;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ЦенныеБумаги.Ссылка КАК ЦеннаяБумагаСБазовымАктивом
	|ИЗ
	|	Справочник.ЦенныеБумаги КАК ЦенныеБумаги
	|ГДЕ
	|	НЕ ЦенныеБумаги.ПометкаУдаления
	|	И ЦенныеБумаги.БазовыйАктив В(&ЦенныеБумагиДляПоискаБазовыхАктивов)";
	ЦенныеБумагиДляПоискаБазовыхАктивов = Новый Массив;
	ОбщегоНазначенияКлиентСервер.ДополнитьМассив(ЦенныеБумагиДляПоискаБазовыхАктивов, ЦенныеБумагаКУдалению);
	ТолькоУникальные = Истина;
	ОбщегоНазначенияКлиентСервер.ДополнитьМассив(ЦенныеБумагиДляПоискаБазовыхАктивов, ЦенныеБумагиЭмитентовДвойников, ТолькоУникальные);
	Запрос.УстановитьПараметр("ЦенныеБумагиДляПоискаБазовыхАктивов", ЦенныеБумагиДляПоискаБазовыхАктивов);
	РезультатЗапроса = Запрос.Выполнить();
	ЦенныеБумагиСБазовымАктивом = РезультатЗапроса.Выгрузить().ВыгрузитьКолонку("ЦеннаяБумагаСБазовымАктивом");
	Для Каждого ЦеннаяБумага Из ЦенныеБумагиСБазовымАктивом Цикл
		НовыйISIN = ТаблицаЦенныхБумагСISIN.Добавить();
		НовыйISIN.ISIN = ЦеннаяБумага.ISIN;
	КонецЦикла;
	
	Если ЗначениеЗаполнено(ТаблицаЦенныхБумагСISIN) Тогда
		ПерезагрузкаЦенныхБумагИнтерфакс(ТаблицаЦенныхБумагСISIN, Успешно);
	КонецЕсли;
	
КонецПроцедуры

