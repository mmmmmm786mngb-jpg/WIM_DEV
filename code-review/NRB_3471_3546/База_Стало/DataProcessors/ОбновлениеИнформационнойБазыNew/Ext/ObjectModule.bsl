Процедура СоздатьОбновитьИсточникКотировок(Код, ПараметрыИсточника, Родитель = Неопределено)
	
	Источник = Справочники.ИсточникиКотировок.НайтиПоКоду(Код);
	Если Не ЗначениеЗаполнено(Источник) Тогда
		ИсточникОбъект = Справочники.ИсточникиКотировок.СоздатьЭлемент();
		ИсточникОбъект.Код = Код;
	Иначе
		ИсточникОбъект = Источник.ПолучитьОбъект();
	КонецЕсли;
	Если Не Родитель = Неопределено Тогда
		ИсточникОбъект.Родитель = Родитель;
	КонецЕсли;
	ЗаполнитьЗначенияСвойств(ИсточникОбъект, ПараметрыИсточника);
	ИсточникОбъект.ОбменДанными.Загрузка = Истина;
	ИсточникОбъект.Записать();
	
