Процедура ЗаполнитьСчетДепоМХвСправочникеСчетаДепо()
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	СчетаДепо.Ссылка КАК СчетДепо,
	|	СчетаДепо.Представление КАК СчетДепоПредставление,
	|	МАКСИМУМ(РазделыСчетаДепо.РазделСчетаДепоМХ.Владелец) КАК СчетДепоМХ
	|ИЗ
	|	Справочник.СчетаДепо КАК СчетаДепо
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.РазделыСчетаДепо КАК РазделыСчетаДепо
	|		ПО СчетаДепо.Ссылка = РазделыСчетаДепо.Владелец
	|			И (РазделыСчетаДепо.ДатаЗакрытияСчета = ДАТАВРЕМЯ(1, 1, 1))
	|
	|СГРУППИРОВАТЬ ПО
	|	СчетаДепо.Ссылка,
	|	СчетаДепо.Представление
	|
	|УПОРЯДОЧИТЬ ПО
	|	СчетДепо
	|АВТОУПОРЯДОЧИВАНИЕ";
	
	РезультатЗапроса = Запрос.Выполнить();
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	СчетаДепоБезЗаполнения = Новый Массив;
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		Если ЗначениеЗаполнено(ВыборкаДетальныеЗаписи.СчетДепоМХ) Тогда
			СчетДепоОбъект = ВыборкаДетальныеЗаписи.СчетДепо.ПолучитьОбъект();
			СчетДепоОбъект.СчетДепоМХ = ВыборкаДетальныеЗаписи.СчетДепоМХ;
			Попытка
				СчетДепоОбъект.Записать();
			Исключение
				ПодробноеПредставлениеОшибки = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
				ТекстОшибки = "Не удалось записать счет депо " + СчетДепоОбъект.Код + Символы.ПС + ПодробноеПредставлениеОшибки;
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстОшибки, ВыборкаДетальныеЗаписи.СчетДепо);
			КонецПопытки;
		Иначе
			ДанныеПоСчетуДепо = Новый Структура("СчетДепо,СчетДепоПредставление",
				ВыборкаДетальныеЗаписи.СчетДепо, ВыборкаДетальныеЗаписи.СчетДепоПредставление);
			СчетаДепоБезЗаполнения.Добавить(ДанныеПоСчетуДепо);
		КонецЕсли;
	КонецЦикла;
	
	Если ЗначениеЗаполнено(СчетаДепоБезЗаполнения) Тогда
		ТекстСообщения = "Не удалось автоматически заполнить реквизит СчетДепоМХ для "
			 + Строка(СчетаДепоБезЗаполнения.Количество()) + " счетов депо:";
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
		Для Каждого ДанныеПоСчетуДепо Из СчетаДепоБезЗаполнения Цикл
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ДанныеПоСчетуДепо.СчетДепоПредставление, ДанныеПоСчетуДепо.СчетДепо);
		КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры

Процедура ЗаполнитьРегистрПравилаГенерацииНомеровСчетовДепо()
	
	КодML = "ML9607021450";
	КодHL = "HL1212116838";
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	МАКСИМУМ(ВЫБОР
	|			КОГДА СчетаДепоМХ.Код = &КодML
	|				ТОГДА СчетаДепоМХ.Ссылка
	|		КОНЕЦ) КАК СчетML,
	|	МАКСИМУМ(ВЫБОР
	|			КОГДА СчетаДепоМХ.Код = &КодHL
	|				ТОГДА СчетаДепоМХ.Ссылка
	|		КОНЕЦ) КАК СчетHL
	|ИЗ
	|	Справочник.СчетаДепоМХ КАК СчетаДепоМХ
	|ГДЕ
	|	СчетаДепоМХ.Код В (&КодML, &КодHL)";
	
	Запрос.УстановитьПараметр("КодML", КодML);
	Запрос.УстановитьПараметр("КодHL", КодHL);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() И ЗначениеЗаполнено(Выборка.СчетML) И ЗначениеЗаполнено(Выборка.СчетHL) Тогда
		Период = '20240101';
		ТипыСчетовДепо = Перечисления.ТипыСчетовДепо;
		Постфикс = "NKC";
		СчетML = Выборка.СчетML;
		СчетHL = Выборка.СчетHL;
		
		Набор = РегистрыСведений.ПравилаГенерацииНомеровСчетовДепо.СоздатьНаборЗаписей();
		Набор.Отбор.Период.Установить(Период);
		ДобавитьВПравилаГенерацииНомеровСчетовДепо(Набор, Период, СчетML, ТипыСчетовДепо.Владельца);
		ДобавитьВПравилаГенерацииНомеровСчетовДепо(Набор, Период, СчетHL, ТипыСчетовДепо.ВладельцаТорговый, Постфикс);
		ДобавитьВПравилаГенерацииНомеровСчетовДепо(Набор, Период, СчетML, ТипыСчетовДепо.ДоверительногоУправляющего);
		ДобавитьВПравилаГенерацииНомеровСчетовДепо(Набор, Период, СчетHL, ТипыСчетовДепо.ДоверительногоУправляющегоТорговый, Постфикс);
		ДобавитьВПравилаГенерацииНомеровСчетовДепо(Набор, Период, СчетML, ТипыСчетовДепо.ИностранногоНоминальногоДержателя);
		ДобавитьВПравилаГенерацииНомеровСчетовДепо(Набор, Период, СчетHL, ТипыСчетовДепо.ИностранногоНоминальногоДержателяТорговый, Постфикс);
		ДобавитьВПравилаГенерацииНомеровСчетовДепо(Набор, Период, СчетML, ТипыСчетовДепо.ИностранногоУполномоченногоДержателя);
		ДобавитьВПравилаГенерацииНомеровСчетовДепо(Набор, Период, СчетHL, ТипыСчетовДепо.ИностранногоУполномоченногоДержателяТорговый, Постфикс);
		ДобавитьВПравилаГенерацииНомеровСчетовДепо(Набор, Период, СчетML, ТипыСчетовДепо.НоминальногоДержателя);
		ДобавитьВПравилаГенерацииНомеровСчетовДепо(Набор, Период, СчетHL, ТипыСчетовДепо.НоминальногоДержателяТорговый, Постфикс);
		Набор.Записать();
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Добавлены записи в РС ПравилаГенерацииНомеровСчетовДепо");
	Иначе
		ТекстСообщения = СтрШаблон("Не найдены счета депо МХ (%1, %2) для добавления в РС ПравилаГенерацииНомеровСчетовДепо", КодML, КодHL);
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
	КонецЕсли;
	
КонецПроцедуры

