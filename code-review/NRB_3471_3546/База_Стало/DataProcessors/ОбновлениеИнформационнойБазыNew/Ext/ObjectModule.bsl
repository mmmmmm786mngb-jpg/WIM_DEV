Процедура СоздатьЭлементСправочникаКонтрольПорученийСчетаТипаС()
	
	НазваниеКонтроля = "Контроль поручений по клиентам со счетами типа ""С""";
	НовыйКонтроль = Справочники.КонтрольПоручений.НайтиПоНаименованию(НазваниеКонтроля);
	Если ЗначениеЗаполнено(НовыйКонтроль) Тогда
		Возврат;
	КонецЕсли;
	НовыйКонтроль = Справочники.КонтрольПоручений.СоздатьЭлемент();
	НовыйКонтроль.Наименование = НазваниеКонтроля;
	НовыйКонтроль.Актуальность = Истина;
	НовыйКонтроль.СобытиеКонтроля = "ПриЗаписи";
	НовыйКонтроль.ШаблонСообщения =
		"В поручении № НомерПоручения депонент имеет счет депо типа ""С""";
	НоваяПеременная = НовыйКонтроль.СоответствияПеременныхШаблонаРеквизитам.Добавить();
	НоваяПеременная.ИмяПеременной = "НомерПоручения";
	НоваяПеременная.ПутьКРеквизиту = "Номер";
	
	КомпоновщикСхемы = Новый КомпоновщикНастроекКомпоновкиДанных;
	СхемаКомпоновки = Справочники.КонтрольПоручений.ПолучитьМакет("МакетОтбораПоручений");
	АдресВоВременномХранилище = ПоместитьВоВременноеХранилище(СхемаКомпоновки);
	ИсточникНастроек = Новый ИсточникДоступныхНастроекКомпоновкиДанных(АдресВоВременномХранилище);
	КомпоновщикСхемы.Инициализировать(ИсточникНастроек);
	КомпоновщикСхемы.ЗагрузитьНастройки(СхемаКомпоновки.НастройкиПоУмолчанию);
	ОбщегоНазначения.УстановитьОтборСКД(КомпоновщикСхемы.Настройки, "Поручение.Комментарий",
		ВидСравненияКомпоновкиДанных.Содержит, Неопределено);
	ОбщегоНазначения.УстановитьОтборСКД(КомпоновщикСхемы.Настройки, "ЕстьСчетТипаС",
		ВидСравненияКомпоновкиДанных.Равно, Истина);
	ОбщегоНазначения.УстановитьОтборСКД(КомпоновщикСхемы.Настройки, "Поручение.ВидОперацииД.КлассОпераций",
		ВидСравненияКомпоновкиДанных.Равно, Перечисления.КлассыОпераций.Инвентарные);
	ОбщегоНазначения.УстановитьОтборСКД(КомпоновщикСхемы.Настройки, "Поручение.ОснованиеОперацииДКУ",
		ВидСравненияКомпоновкиДанных.НеРавно, Справочники.КодыОснованияОперацийДКУ.TR01);
	НовыйКонтроль.НастройкиСКД = Новый ХранилищеЗначения(КомпоновщикСхемы.Настройки);
	НовыйКонтроль.Записать();
	
КонецПроцедуры

