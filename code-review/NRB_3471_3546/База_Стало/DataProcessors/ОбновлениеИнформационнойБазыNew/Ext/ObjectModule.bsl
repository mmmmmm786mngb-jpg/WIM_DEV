			ИначеЕсли КонтрольОбъект.УдалитьСобытиеКонтроля = "ПриПроведении" Тогда
				КонтрольОбъект.СобытиеКонтроля = Перечисления.СобытияКонтроляПоручений.ПриПроведении;
			ИначеЕсли КонтрольОбъект.УдалитьСобытиеКонтроля = "ПриЗаписи" Тогда
				КонтрольОбъект.СобытиеКонтроля = Перечисления.СобытияКонтроляПоручений.ПриЗаписи;
			Иначе
				ТекстСообщения = "Найдено непредусмотренное событие контроля: " + КонтрольОбъект.УдалитьСобытиеКонтроля;
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
			КонецЕсли;
			КонтрольОбъект.Записать();
			Обновлено = Обновлено + 1;
		КонецЦикла;
		Текст = "Обновлено записей справочника ""Контроль поручений"": " + Строка(Обновлено);
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(Текст);
		
		// Создаем необходимые внешние источники и настройки обмена
		НаименованиеНастройки = "Депозитарий и IT";
		АдресПолучателя = "custody@nrb.ru;BrokerAppSupport@nrb.ru";
		ВнешнийИсточник = ПланыВидовХарактеристик.ВнешниеИсточники.РассылкаУведомленийОСрабатыванииКонтроляПоручений;
		НастроитьВнешнийИсточникДляОтправкиПочтовыхСообщений(ВнешнийИсточник, НаименованиеНастройки, АдресПолучателя);
		
		ЛогироватьВыполнениеОбработчика(НомерЗадачи);
	КонецЕсли;
	
	НомерЗадачи = 3471;
	Если ОбработкаОбновленияПоЗадаче(НомерЗадачи, ВыполнитьОбновлениеПоЗадаче) Тогда
		СообщениеОНачалеВыполненияОбработчика(НомерЗадачи);
		
		РегламентныеЗаданияМетаданные = Метаданные.РегламентныеЗадания.ОтправкаПериодическихВыписокПоСчетуДЕПО;
		ИнтервалыВТеченииДня = Новый Массив;
		ДвенадцатьЧасовДня = 12;
		ДобавитьИнтервал(ИнтервалыВТеченииДня, Дата(1, 1, 1, ДвенадцатьЧасовДня, 0, 0), Дата(1, 1, 1, 0, 0, 0), 0, 0);
		НастройкаРегламентногоЗадания(РегламентныеЗаданияМетаданные, ИнтервалыВТеченииДня, , , , , Ложь);
		
		ЛогироватьВыполнениеОбработчика(НомерЗадачи);
	КонецЕсли;
	
	НомерЗадачи = 3546;
	Если ОбработкаОбновленияПоЗадаче(НомерЗадачи, ВыполнитьОбновлениеПоЗадаче) Тогда
		СообщениеОНачалеВыполненияОбработчика(НомерЗадачи);
		
		ВнешнийИсточник = ПланыВидовХарактеристик.ВнешниеИсточники.РассылкаУведомленийОбОшибкахДоставкиВыписокОСостоянииСчета;
		Настройки = НастройкиДляПисемДепозитариюIT();
		НастроитьВнешнийИсточникДляОтправкиПочтовыхСообщений(ВнешнийИсточник, Настройки.НаименованиеНастройкиДляПисем, Настройки.Email);
		ЛогироватьВыполнениеОбработчика(НомерЗадачи);
	КонецЕсли;
	
КонецПроцедуры
