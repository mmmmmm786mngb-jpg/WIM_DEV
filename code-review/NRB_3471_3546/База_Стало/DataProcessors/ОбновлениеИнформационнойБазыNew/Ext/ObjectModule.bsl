Процедура ОбновлениеПоЗадаче185()
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	КонтактнаяИнформация.Период КАК Период,
	|	КонтактнаяИнформация.Объект КАК Объект,
	|	КонтактнаяИнформация.Тип КАК Тип,
	|	КонтактнаяИнформация.Вид КАК Вид
	|ИЗ
	|	РегистрСведений.КонтактнаяИнформация КАК КонтактнаяИнформация
	|ГДЕ
	|	КонтактнаяИнформация.Тип = Значение(Перечисление.ТипыКонтактнойИнформации.Адрес)
	|	И КонтактнаяИнформация.Вид В (&ВидыАдреса)");
	ВидыАдреса = Новый Массив;
	ВидыКИ = Справочники.ВидыКонтактнойИнформации;
	ВидыАдреса.Добавить(ВидыКИ.АдресИнострОрганизацииУчред);
	ВидыАдреса.Добавить(ВидыКИ.АдресОрганизацииПочтовый);
	ВидыАдреса.Добавить(ВидыКИ.АдресЮрлицаПочтовый);
	ВидыАдреса.Добавить(ВидыКИ.ИнострАдресФизЛица);
	ВидыАдреса.Добавить(ВидыКИ.ИнформАдресКонтактногоЛица);
	ВидыАдреса.Добавить(ВидыКИ.ИнформАдресФизЛица);
	ВидыАдреса.Добавить(ВидыКИ.ФактАдресКонтрагента);
	ВидыАдреса.Добавить(ВидыКИ.ФактАдресОрганизацииEng);
	ВидыАдреса.Добавить(ВидыКИ.ФактАдресФизЛица);
	ВидыАдреса.Добавить(ВидыКИ.ФактАдресЮрЛица);
	ВидыАдреса.Добавить(ВидыКИ.ЮрАдресКонтрагента);
	ВидыАдреса.Добавить(ВидыКИ.ЮрАдресОрганизации);
	ВидыАдреса.Добавить(ВидыКИ.ЮрАдресОрганизацииEng);
	ВидыАдреса.Добавить(ВидыКИ.ЮрАдресФизЛица);
	ВидыАдреса.Добавить(ВидыКИ.ЮрАдресЮрЛица);
	Запрос.УстановитьПараметр("ВидыАдреса", ВидыАдреса);
	Выборка = Запрос.Выполнить().Выбрать();
	Набор = РегистрыСведений.КонтактнаяИнформация.СоздатьНаборЗаписей();
	Пока Выборка.Следующий() Цикл
		Набор.Отбор.Период.Установить(Выборка.Период);
		Набор.Отбор.Объект.Установить(Выборка.Объект);
		Набор.Отбор.Тип.Установить(Выборка.Тип);
		Набор.Отбор.Вид.Установить(Выборка.Вид);
		Набор.Прочитать();
		Для Каждого Запись Из Набор Цикл
			ЭтоСтрана = Справочники.КлассификаторСтранМира.КодАльфа2ПоНазваниюСтраны(Запись.Поле1);
			Запись.ЭтоРоссийскийАдрес = ?(ЭтоСтрана = "" Или ЭтоСтрана = "RU", Истина, Ложь);
		КонецЦикла;
		Набор.Записать();
	КонецЦикла;
КонецПроцедуры

