// Процедура - Добавляет настройку Обмена с Кафкой в РС ВнешниеИсточники
// Процедура умеет создавать только одну настройку соединения с Кафкой 
// Можно указать только один из параметров UAT или ITTest равно Истина
//
// Параметры:
//  ПараметрыНастройки - Структура -  Структура с параметрами для создания настройки обмена
//  DMZ - Булево -  Определяет это DMZ среда или нет
//  UAT - Булево -  Определяет это UAT среда или нет
//  ITTest - Булево -  Определяет это ITTest среда или нет

Процедура СоздатьНастройкуОбменаKafka(ПараметрыНастройки, DMZ = Ложь, UAT = Ложь, ITTest = Ложь)
	
	Если UAT И ITTest Тогда
		ТекстСообщения = "Процедура СоздатьНастройкуОбменаKafka можно использовать только для создания одной настройки одновременно";
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
		Возврат;
	КонецЕсли;
	
	ПВХ = ПараметрыНастройки.Источник.ПолучитьОбъект();
	ПВХ.ТипВнешнегоИсточника = Перечисления.ТипыВнешнихИсточников.НастройкаОбменаДанными;
	ПВХ.Записать();
	
	НастройкаОбмена = Справочники.НастройкиОбменаДанными.НайтиПоНаименованию(ПараметрыНастройки.ИмяНастройки, Истина);
	
	ИмяНастройки = "Настройка обмена с Кафка Internal Prod";
	
	Если DMZ Тогда
		ИмяНастройки = СтрЗаменить(ИмяНастройки, "Internal", "DMZ");
	КонецЕсли;
	
	Если UAT Тогда
		ИмяНастройки = СтрЗаменить(ИмяНастройки, "Prod", "UAT");
	КонецЕсли;
	
	Если ITTest Тогда
		ИмяНастройки = СтрЗаменить(ИмяНастройки, "Prod", "ITTest");
	КонецЕсли;
	
	Если ЗначениеЗаполнено(НастройкаОбмена) Тогда
		НастройкаОбменаОбъект = НастройкаОбмена.ПолучитьОбъект();
	Иначе
		НастройкаОбменаОбъект = Справочники.НастройкиОбменаДанными.СоздатьЭлемент();
	КонецЕсли;
	
	СтруктураНастроекОбмена = ОбщегоНазначения.ПолучитьЗначенияРеквизитовШапкиОбъектаПоУмолчанию(
		"Справочник.НастройкиОбменаДанными", Новый Структура, ИмяНастройки);
	
	Если ЗначениеЗаполнено(СтруктураНастроекОбмена) Тогда
		ЗаполнитьЗначенияСвойств(НастройкаОбменаОбъект, СтруктураНастроекОбмена);
	КонецЕсли;
	ЗаполнитьЗначенияСвойств(НастройкаОбменаОбъект, ПараметрыНастройки);
	
	ТестоваяСреда = UAT Или ITTest;
	Если Не ЗначениеЗаполнено(НастройкаОбменаОбъект.KafkaСертификат) Тогда
		// BSLLS:UsingHardcodePath-off
		НастройкаОбменаОбъект.KafkaСертификат = ?(ТестоваяСреда, "D://library_kafka//ca//ca.cer", "D://KafkaClient//Certificates//ca.cer");
		// BSLLS:UsingHardcodePath-on
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(НастройкаОбменаОбъект.KafkaАдрес) Тогда
		ЗаполнитьАдресКафки(DMZ, ТестоваяСреда, НастройкаОбменаОбъект);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(НастройкаОбменаОбъект.KafkaПользователь)
		И Не ЗначениеЗаполнено(НастройкаОбменаОбъект.KafkaПодписчик) Тогда
		НастройкаОбменаОбъект.KafkaПодписчик = СтрШаблон("G.%1", НастройкаОбменаОбъект.KafkaПользователь);
	КонецЕсли;
	
	НастройкаОбменаОбъект.Наименование = ПараметрыНастройки.ИмяНастройки;
	НастройкаОбменаОбъект.СпособОбмена = Перечисления.СпособыОбменаДанными.ОбменЧерезKafka;
