Процедура ЗаполнитьЖИ_втРаскрытияСписковВладельцев(Запрос)
	Запрос.Текст =
	"ВЫБРАТЬ
	|	РаскрытиеСпискаВладельцев.Ссылка КАК Основание,
	|	РаскрытиеСпискаВладельцев.Дата КАК Период,
	|	""КД"" КАК ПрефиксНомера,
	|	ВЫБОР
	|		КОГДА РаскрытиеСпискаВладельцев.КДРеференс <> """"
	|		ТОГДА ""Распоряжение по сбору списка владельцев ЦБ. КД референс: "" + РаскрытиеСпискаВладельцев.КДРеференс
	|		ИНАЧЕ ""Распоряжение по сбору списка владельцев ЦБ""
	|	КОНЕЦ КАК НаименованиеДокументаИлиКомплекта,
	|	"""" КАК ДепонентКод,
	|	ЛОЖЬ КАК ЭтоУведомленияЧерезЛК,
	|	ЕСТЬNULL(СтатусыРаскрытияСписковВладельцевСрезПоследних.Период, ДАТАВРЕМЯ(1, 1, 1)) КАК ДатаНаправленияВрученияДокумента,
	|	РаскрытиеСпискаВладельцев.СчетДЕПО.Владелец КАК Адресат,
	|	""Инициатор"" КАК ИсточникАдресата,
	|	ЕСТЬNULL(СтатусыРаскрытияСписковВладельцевСрезПоследних.Автор, ЗНАЧЕНИЕ(Справочник.Пользователи.ПустаяСсылка)) КАК Исполнитель,
	|	"""" КАК Комментарий,
	|	"""" КАК Инициатор,
	|	РаскрытиеСпискаВладельцев.Ссылка КАК Поручение,
	|	РаскрытиеСпискаВладельцев.ЦеннаяБумага1 КАК ЦеннаяБумага
	|ПОМЕСТИТЬ втРаскрытияСписковВладельцев
	|ИЗ
	|	Документ.РаскрытиеСпискаВладельцев КАК РаскрытиеСпискаВладельцев
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СтатусыРаскрытияСписковВладельцев.СрезПоследних(, Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыРаскрытияСписковВладельцев.Выгружено)) КАК СтатусыРаскрытияСписковВладельцевСрезПоследних
	|		ПО РаскрытиеСпискаВладельцев.Ссылка = СтатусыРаскрытияСписковВладельцевСрезПоследних.ДокументРаскрытия
	|ГДЕ
	|	РаскрытиеСпискаВладельцев.Дата МЕЖДУ &НачалоПериода И &КонецПериода
	|	И РаскрытиеСпискаВладельцев.ВидКорпоративногоДействия В(&ВидыКДДляРСВ)
	|	И РаскрытиеСпискаВладельцев.ТипЗагрузкиСписковРаскрытия <> ЗНАЧЕНИЕ(Перечисление.ТипЗагрузкиСписковРаскрытия.PARTAD)
	|	И РаскрытиеСпискаВладельцев.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыРаскрытияСписковВладельцев.Выгружено)
	|	И НЕ РаскрытиеСпискаВладельцев.ПометкаУдаления";
	ВидыКДДляРСВ = Справочники.ВидыКорпоративныхДействий.ВидыКДРСВДляЖурналовВходящихИсходящих();
	Запрос.УстановитьПараметр("ВидыКДДляРСВ", ВидыКДДляРСВ);
	Запрос.Выполнить();
КонецПроцедуры


Процедура ЗаполнитьЖО_втГлобальнаяОперацияКонвертация(Запрос)
	
	// Получить табличные части списаний и зачислений для конвертаций
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Списание.Ссылка					КАК Ссылка,
	|	Списание.РазделСчетаДепо		КАК РазделСчетаДепо,
	|	Списание.ЦеннаяБумага			КАК ЦеннаяБумага,
	|	""Конвертация / Списание""		КАК Комментарий,
	|	1								КАК ПорядокСтрок	// В начале идут списания
	|ПОМЕСТИТЬ втСписанияЗачисления
	|ИЗ
	|	Документ.ГлобальнаяОперация.Списание КАК Списание
	|
	|ГДЕ
	|	Списание.Ссылка.Дата МЕЖДУ &НачалоПериода И &КонецПериода
	|	И Списание.Ссылка.Проведен
	|	И Списание.Ссылка.ВидГлобальнойОперации = &ВидОперацииКонвертация
	|	И Списание.ЦеннаяБумага.НФИ = 0
	|	И Списание.Ссылка.СчетДепо.ВидСчетаДепо = &ВидСчетаДЕПО
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	Зачисление.Ссылка				КАК Ссылка,
	|	Зачисление.РазделСчетаДепо		КАК РазделСчетаДепо,
	|	Зачисление.ЦеннаяБумага			КАК ЦеннаяБумага,
	|	""Конвертация / Зачисление""	КАК Комментарий,
	|	2								КАК ПорядокСтрок	// Затем идут зачисления
	|ИЗ
	|	Документ.ГлобальнаяОперация.Зачисление КАК Зачисление
	|
	|ГДЕ
	|	Зачисление.Ссылка.Дата МЕЖДУ &НачалоПериода И &КонецПериода
	|	И Зачисление.Ссылка.Проведен
	|	И Зачисление.Ссылка.ВидГлобальнойОперации = &ВидОперацииКонвертация
	|	И Зачисление.ЦеннаяБумага.НФИ = 0
	|	И Зачисление.Ссылка.СчетДепо.ВидСчетаДепо = &ВидСчетаДЕПО
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Ссылка
	|";
	Запрос.Выполнить();
	
	// Посчитать количество строк на конвертацию: если строка только 1, то нумерация через дробь не нужна
	Запрос.Текст =
	"ВЫБРАТЬ
	|	СписанияЗачисления.Ссылка				КАК Ссылка,
	|	КОЛИЧЕСТВО(СписанияЗачисления.Ссылка)	КАК КоличествоСтрок
	|ПОМЕСТИТЬ втКоличествоСтрокСписанияЗачисления
	|ИЗ
	|	втСписанияЗачисления КАК СписанияЗачисления
	|
	|СГРУППИРОВАТЬ ПО
	|	СписанияЗачисления.Ссылка
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Ссылка
	|";
	Запрос.Выполнить();
	
	// ГлобальнаяОперация
	Запрос.Текст =
	"ВЫБРАТЬ
	|	СписанияЗачисления.Ссылка						КАК Операция,
	|	СписанияЗачисления.Ссылка.Дата					КАК Период,
	|	СписанияЗачисления.Ссылка.Номер					КАК НомерОперации,
	|	СписанияЗачисления.Ссылка.ВидГлобальнойОперации	КАК ВидОперации,
	|	СписанияЗачисления.Ссылка.СчетДепо				КАК СчетДепо,
	|	СписанияЗачисления.РазделСчетаДепо				КАК РазделСчетаДепо,
	|	СписанияЗачисления.ЦеннаяБумага					КАК ЦеннаяБумага,
	|	СписанияЗачисления.Ссылка.ДокументОснование		КАК Поручение,
	|	ЕСТЬNULL(РегистрацияВЭДО.Пользователь, СписанияЗачисления.Ссылка.Автор)	КАК Инициатор,
	|	СписанияЗачисления.Ссылка.Автор					КАК Исполнитель,
	|	СписанияЗачисления.Комментарий					КАК Комментарий,
	|	ВЫБОР
	|		КОГДА КоличествоСтрокСписанияЗачисления.КоличествоСтрок = 1
	|			ТОГДА 0		// если строка только 1, то нумерация через дробь не нужна
	|		ИНАЧЕ СписанияЗачисления.ПорядокСтрок
	|	КОНЕЦ											КАК ПорядокСтрок
	|ПОМЕСТИТЬ втГлобальнаяОперацияКонвертация
	|ИЗ
	|	втСписанияЗачисления КАК СписанияЗачисления
	|	ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.РегистрацияДокументовВЭДО КАК РегистрацияВЭДО
	|	ПО
	|		СписанияЗачисления.Ссылка = РегистрацияВЭДО.Документ.ОперацияЦБ
	|	ЛЕВОЕ СОЕДИНЕНИЕ втКоличествоСтрокСписанияЗачисления КАК КоличествоСтрокСписанияЗачисления
	|	ПО
	|		СписанияЗачисления.Ссылка = КоличествоСтрокСписанияЗачисления.Ссылка
	|";
	Запрос.Выполнить();
КонецПроцедуры

