	Выборка = Запрос.Выполнить().Выбрать();
	
	ПредДень = Дата("00010101");	// Предыдущее значение для генерации последовательности номеров
	НомерВнутриДня = 1;
	НомерСтрокиВнутриОперации = 1;
	Операция = Неопределено;
	Сообщение = Новый СообщениеПользователю();
	Если Выборка.Количество() = 0 Тогда
    	Сообщение.Текст = "Не обнаружены данные за " + ПредставлениеПериода(НачалоПериода, КонецПериода)
			+ " для заполнения регистра сведений ""Журнал операций""";
	Иначе
		Пока Выборка.Следующий() Цикл
			// Генерация номера внутри дня
			Если НачалоДня(ПредДень) = НачалоДня(Выборка.Период) Тогда	// день не изменился
				Если Операция <> Выборка.Операция Тогда 				// изменилась операция
					НомерВнутриДня = НомерВнутриДня + 1;				// продолжаем нумерацию
				КонецЕсли;
			Иначе // день сменился - начинаем новую нумерацию
				НомерВнутриДня = 1;
			КонецЕсли;
			
			// Генерация номера строки внутри операции
			Если Операция <> Выборка.Операция Тогда
				НомерСтрокиВнутриОперации = 1;
			Иначе
				НомерСтрокиВнутриОперации = НомерСтрокиВнутриОперации + 1;
			КонецЕсли;
			
			Операция = Выборка.Операция;
			ПредДень = Выборка.Период;
			
			// Формирование записи регистра
			НаборЗаписей = РегистрыСведений.ЖурналОпераций.СоздатьНаборЗаписей();
			НаборЗаписей.Отбор.Операция.Установить(Выборка.Операция);
			НаборЗаписей.Отбор.РазделСчетаДепо.Установить(Выборка.РазделСчетаДепо);
			НаборЗаписей.Отбор.СчетДЕПО.Установить(Выборка.СчетДЕПО);
			НаборЗаписей.Отбор.ЦеннаяБумага.Установить(Выборка.ЦеннаяБумага);
			НаборЗаписей.Отбор.Период.Установить(Выборка.Период); 
			
			НоваяЗапись = НаборЗаписей.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяЗапись, Выборка);
			НоваяЗапись.НомерОперации = Лев(Выборка.НомерОперации, 1) + Формат(Выборка.Период, "ДФ=ггММдд-")
				+ Формат(НомерВнутриДня, "ЧЦ=5;ЧВН=1;ЧГ=0")
				+ ?(Выборка.ПорядокСтрок <> 0, "/" + Формат(НомерСтрокиВнутриОперации, "ЧГ="), "");
			Если ЗначениеЗаполнено(Выборка.ОтменяемоеПоручениеНомер) Тогда
				НоваяЗапись.Комментарий = "Отмененное поручение №" + СокрЛП(Выборка.ОтменяемоеПоручениеНомер)
					+ " от " + Формат(Выборка.ОтменяемоеПоручениеДата, "ДЛФ=Д");
			Иначе
				Комментарий = СокрЛП(Выборка.Комментарий);
				Если Прав(Комментарий, 1) = "," Тогда
					НоваяЗапись.Комментарий = Лев(Комментарий, СтрДлина(Комментарий) - 1);
				КонецЕсли;
			КонецЕсли;
			
			Если Выборка.ВидОперации = Справочники.ВидыОпераций.ОткрытиеРазделаСчетаДепо
					И ТипЗнч(Выборка.СчетДЕПО) = Тип("СправочникСсылка.СчетаДепоМХ") Тогда
				НоваяЗапись.Комментарий			= "Счет депо – " + СокрЛП(Выборка.СчетДЕПО) + " Раздел счета депо МХ – " + СокрЛП(Выборка.РазделСчетаДепо.Код);
				НоваяЗапись.СчетДЕПО			= Неопределено;
				НоваяЗапись.удРазделСчетаДЕПО	= Неопределено;
			КонецЕсли;
			
			НаборЗаписей.Записать();
		КонецЦикла;
		Сообщение.Текст = "Заполнен регистр сведений ""Журнал операций"" за " + ПредставлениеПериода(НачалоПериода, КонецПериода);
	КонецЕсли;
	ЗаписьЖурналаРегистрации("Заполнение журналов ДЕПО", УровеньЖурналаРегистрации.Информация,,, Сообщение.Текст);
	Сообщение.Сообщить();
КонецПроцедуры

