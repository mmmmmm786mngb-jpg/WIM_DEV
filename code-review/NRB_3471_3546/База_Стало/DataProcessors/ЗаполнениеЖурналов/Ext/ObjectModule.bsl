Процедура ЗаполнитьЖИ_втВыписка(Запрос)
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Выписка.Ссылка КАК Основание,
	|	Выписка.Дата КАК Период,
	|	ВЫБОР
	|		КОГДА Выписка.ВидОтчета = ЗНАЧЕНИЕ(Перечисление.ВидыОтчетов.Уведомление)
	|			ТОГДА ""У""
	|		КОГДА Выписка.ВидОтчета = ЗНАЧЕНИЕ(Перечисление.ВидыОтчетов.Отчет)
	|			ТОГДА ""О""
	|		ИНАЧЕ ""В""
	|	КОНЕЦ КАК ПрефиксНомера,
	|	Выписка.ВидОтчета КАК НаименованиеДокументаИлиКомплекта,
	|	ВЫРАЗИТЬ(Выписка.ВладелецСчета КАК Справочник.Контрагенты) КАК Депонент,
	|	ВЫРАЗИТЬ(Выписка.ВладелецСчета КАК Справочник.Контрагенты).Код КАК ДепонентКод,
	|	ЛОЖЬ КАК ЭтоУведомленияЧерезЛК,
	|	Выписка.Дата КАК ДатаНаправленияВрученияДокумента,
	|	"""" КАК Адресат,
	|	""Депонент"" КАК ИсточникАдресата,
	|	ЕСТЬNULL(РегистрацияЭДО.Пользователь, Выписка.Автор) КАК Исполнитель,
	|	ВЫБОР
	|		КОГДА Выписка.ВидОтчета В (&ВидыОтчетаПоСчетуДЕПО)
	|			ТОГДА ""Документ выдан: "" + ВЫРАЗИТЬ(Выписка.ДокументОснование КАК Документ.Поручение).СпособОтправкиОтчета.Наименование
	|		КОГДА ВЫРАЗИТЬ(Выписка.ДокументОснование КАК Документ.Поручение).ВидОперацииД = &ИзменениеАнкетныхДанных
	|			ТОГДА ВЫРАЗИТЬ(Выписка.ДокументОснование КАК Документ.Поручение).Комментарий
	|		ИНАЧЕ """"
	|	КОНЕЦ КАК Комментарий,
	|	"""" КАК Инициатор,
	|	Выписка.ДокументОснование КАК Поручение,
	|	ВЫРАЗИТЬ(Выписка.ОперацияЦБ КАК Документ.ОперацииЦБ).ЦБ КАК ЦеннаяБумага
	|ПОМЕСТИТЬ втВыписка
	|ИЗ
	|	Документ.Выписка КАК Выписка
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.РегистрацияДокументовВЭДО КАК РегистрацияЭДО
	|		ПО (Выписка.Ссылка = (ВЫРАЗИТЬ(РегистрацияЭДО.Документ КАК Документ.Выписка)))
	|ГДЕ
	|	Выписка.Дата МЕЖДУ &НачалоПериода И &КонецПериода
	|	И Выписка.Проведен
	|";
	Запрос.Выполнить();
КонецПроцедуры

Процедура ЗаполнитьЖИ_втСводныйОтчетОСовершенныхОперациях(Запрос)
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Выписка.Ссылка КАК Основание,
	|	Выписка.Дата КАК Период,
	|	"""" КАК ПрефиксНомера,
	|	""Сводный отчет о совершенных операциях"" КАК НаименованиеДокументаИлиКомплекта,
	|	ВЫРАЗИТЬ(Выписка.ВладелецСчета КАК Справочник.Контрагенты) КАК Депонент,
	|	ВЫРАЗИТЬ(Выписка.ВладелецСчета КАК Справочник.Контрагенты).Код КАК ДепонентКод,
	|	ЛОЖЬ КАК ЭтоУведомленияЧерезЛК,
	|	Выписка.Дата КАК ДатаНаправленияВрученияДокумента,
	|	"""" КАК Адресат,
	|	""Депонент"" КАК ИсточникАдресата,
	|	ВЫБОР
	|		КОГДА Выписка.Изменил = ЗНАЧЕНИЕ(Справочник.Пользователи.ПустаяСсылка)
	|			ТОГДА Выписка.Автор
	|		ИНАЧЕ Выписка.Изменил
	|	КОНЕЦ КАК Исполнитель,
	|	"""" КАК Комментарий,
	|	НЕОПРЕДЕЛЕНО КАК Инициатор,
	|	НЕОПРЕДЕЛЕНО КАК Поручение,
	|	НЕОПРЕДЕЛЕНО КАК ЦеннаяБумага
	|ПОМЕСТИТЬ втСводныйОтчетОСовершенныхОперациях
	|ИЗ
	|	Документ.СводныйОтчетОСовершенныхОперациях КАК Выписка
	|ГДЕ
	|	Выписка.Дата МЕЖДУ &НачалоПериода И &КонецПериода
	|	И Выписка.Проведен";
	
	Запрос.Выполнить();
	
КонецПроцедуры

Процедура ЗаполнитьЖИ_втИсходящий(Запрос)
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Исходящий.Ссылка КАК Основание,
	|	Исходящий.Дата КАК Период,
	|	""П"" КАК ПрефиксНомера,
	|	Исходящий.НаименованиеДокументаИлиКомплекта КАК НаименованиеДокументаИлиКомплекта,
	|	Исходящий.Депонент КАК Депонент,
	|	Исходящий.Депонент.Код КАК ДепонентКод,
	|	ЛОЖЬ КАК ЭтоУведомленияЧерезЛК,
	|	Исходящий.Дата КАК ДатаНаправленияВрученияДокумента,
	|	Исходящий.Адресат КАК Адресат,
	|	""Адресат"" КАК ИсточникАдресата,
	|	Исходящий.Исполнитель КАК Исполнитель,
	|	Исходящий.Комментарий КАК Комментарий,
	|	"""" КАК Инициатор
	|ПОМЕСТИТЬ втИсходящий
	|ИЗ
	|	Документ.Исходящий КАК Исходящий
	|ГДЕ
	|	Исходящий.Дата МЕЖДУ &НачалоПериода И &КонецПериода
	|	И Исходящий.Проведен";
	Запрос.Выполнить();
КонецПроцедуры

Процедура ЗаполнитьЖИ_втЭтапыКДНЕУведомлениеКлиентов(Запрос)
	// Исходящие ДокументКД из РС ЭтапыКД на период записи и это не уведомления клиентов
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ЭтапыКД.ДокументКД КАК Основание,
	|	ЭтапыКД.Период КАК Период,
	|	""КД"" КАК ПрефиксНомера,
	|	ВЫБОР
	|		КОГДА ЭтапыКД.ДокументКД ССЫЛКА Документ.КорпоративноеДействие_Новый
	|				И ЭтапыКД.ЭтапКД.КомплектДокументов <> """"
	|			ТОГДА ЭтапыКД.ЭтапКД.КомплектДокументов + "". КД референс: "" + ЭтапыКД.ДокументКД.КДРеференс
	|		КОГДА ЭтапыКД.ДокументКД ССЫЛКА Документ.КорпоративноеДействие_Новый
	|				И ЭтапыКД.ЭтапКД.КомплектДокументов = """"
	|			ТОГДА ЭтапыКД.ЭтапКД.Наименование + "". КД референс: "" + ЭтапыКД.ДокументКД.КДРеференс
	|		КОГДА ЭтапыКД.ЭтапКД.КомплектДокументов <> """"
	|			ТОГДА ЭтапыКД.ЭтапКД.КомплектДокументов
	|		ИНАЧЕ ЭтапыКД.ЭтапКД.Наименование
	|	КОНЕЦ КАК НаименованиеДокументаИлиКомплекта,
	|	NULL КАК Депонент,
	|	"""" КАК ДепонентКод,
	|	ЛОЖЬ КАК ЭтоУведомленияЧерезЛК,
	|	ЭтапыКД.Период КАК ДатаНаправленияВрученияДокумента,
	|	"""" КАК Адресат,
	|	""Инициатор"" КАК ИсточникАдресата,
	|	ВЫБОР
	|		КОГДА ЭтапыКД.ДокументКД ССЫЛКА Документ.РаскрытиеСпискаВладельцев
	|			ТОГДА ЭтапыКД.ДокументКД.Автор
	|		ИНАЧЕ NULL
	|	КОНЕЦ КАК Исполнитель,
	|	ВЫБОР
	|		КОГДА ВЫРАЗИТЬ(ЭтапыКД.ДокументКД КАК Документ.Поручение).ВидОперацииД = &ИзменениеАнкетныхДанных
	|			ТОГДА ВЫРАЗИТЬ(ЭтапыКД.ДокументКД КАК Документ.Поручение).Комментарий
	|		ИНАЧЕ """"
	|	КОНЕЦ КАК Комментарий,
	|	ВЫБОР
	|		КОГДА ЭтапыКД.ДокументКД ССЫЛКА Документ.РаскрытиеСпискаВладельцев
	|			ТОГДА ЭтапыКД.ДокументКД.Инициатор
	|		ИНАЧЕ """"
	|	КОНЕЦ КАК Инициатор,
	|	ЭтапыКД.ДокументКД КАК Поручение
	|ПОМЕСТИТЬ втЭтапыКДНЕУведомлениеКлиентов
	|ИЗ
	|	РегистрСведений.ЭтапыКД КАК ЭтапыКД
	|ГДЕ
	|	ЭтапыКД.Период МЕЖДУ &НачалоПериода И &КонецПериода
	|	И ЭтапыКД.Исходящее
	|	И НЕ ЭтапыКД.ЭтапКД В (&ЭтапыУведомлениеКлиентов)
	|	И
	|	(
	|		ЭтапыКД.ДокументКД В (&СписокДопустимыхЗначенийРеквизитаДокументКД)
	|		ИЛИ ЭтапыКД.ДокументКД ССЫЛКА Документ.Поручение
	|		ИЛИ 
	|			(	(ЭтапыКД.ДокументКД ССЫЛКА Документ.КорпоративноеДействие_Новый
	|					ИЛИ ЭтапыКД.ДокументКД ССЫЛКА Документ.РаскрытиеСпискаВладельцев)
	|				И (ЭтапыКД.ДокументКД.ЦеннаяБумага1 = &ПустаяЦеннаяБумага
	|					ИЛИ	ЭтапыКД.ДокументКД.ЦеннаяБумага1.НФИ = 0)
	|			)
	|	)
	|";
	Запрос.Выполнить();
КонецПроцедуры

Процедура ЗаполнитьЖИ_втЭтапыКДУведомлениеКлиентов(Запрос)
	// Исходящие КД из РС ЭтапыКД на период записи и это уведомления клиентов
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ЭтапыКД.КД КАК Основание,
	|	ЭтапыКД.Период КАК Период,
	|	""КД"" КАК ПрефиксНомера,
	|	ВЫБОР
	|		КОГДА ЭтапыКД.КД ССЫЛКА Документ.УведомлениеКлиентам
	|				И ЭтапыКД.ЭтапКД.КомплектДокументов <> """"
	|			ТОГДА ЭтапыКД.ЭтапКД.КомплектДокументов + "". КД референс: "" + ЭтапыКД.КД.КДРеференс
	|		КОГДА ЭтапыКД.КД ССЫЛКА Документ.УведомлениеКлиентам
	|				И ЭтапыКД.ЭтапКД.КомплектДокументов = """"
	|			ТОГДА ЭтапыКД.ЭтапКД.Наименование + "". КД референс: "" + ЭтапыКД.КД.КДРеференс
	|		КОГДА ЭтапыКД.ЭтапКД.КомплектДокументов <> """"
	|			ТОГДА ЭтапыКД.ЭтапКД.КомплектДокументов
	|		ИНАЧЕ ЭтапыКД.ЭтапКД.Наименование
	|	КОНЕЦ КАК НаименованиеДокументаИлиКомплекта,
	|	Уведомления.Клиент КАК Депонент,
	|	Уведомления.Клиент.Код КАК ДепонентКод,
	|	ВЫБОР
	|		КОГДА НЕ Уведомления.Клиент ЕСТЬ NULL 
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК ЭтоУведомленияЧерезЛК,
	|	ЭтапыКД.Период КАК ДатаНаправленияВрученияДокумента,
	|	"""" КАК Адресат,
	|	""Депонент"" КАК ИсточникАдресата,
	|	&ПользовательРОБОТ КАК Исполнитель,
	|	"""" КАК Комментарий,
	|	"""" КАК Инициатор
	|ПОМЕСТИТЬ втЭтапыКДУведомлениеКлиентов
	|ИЗ
	|	РегистрСведений.ЭтапыКД КАК ЭтапыКД
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.УведомленияОтправленныеЧерезЛичныйКабинет КАК Уведомления
	|		ПО ЭтапыКД.КД = Уведомления.КД
	|			И (НАЧАЛОПЕРИОДА(ЭтапыКД.Период, ДЕНЬ) = Уведомления.Период)
	|ГДЕ
	|	ЭтапыКД.Период МЕЖДУ &НачалоПериода И &КонецПериода
	|	И ЭтапыКД.Исходящее
	|	И ЭтапыКД.ЭтапКД В (&ЭтапыУведомлениеКлиентов)
	|	И
	|	(
	|		ЭтапыКД.КД = НЕОПРЕДЕЛЕНО
	|		ИЛИ ЭтапыКД.КД = ЗНАЧЕНИЕ(Документ.КорпоративноеДействие_Новый.ПустаяСсылка)
	|		ИЛИ ЭтапыКД.КД = ЗНАЧЕНИЕ(Документ.РаскрытиеСпискаВладельцев.ПустаяСсылка)
	|		ИЛИ ЭтапыКД.КД.ЦеннаяБумага1 = &ПустаяЦеннаяБумага
	|		ИЛИ	ЭтапыКД.КД.ЦеннаяБумага1.НФИ = 0
	|	)
	|";
	Запрос.Выполнить();
КонецПроцедуры

Процедура ЗаполнитьЖИ_втУведомленияОПриемеЗаявлений(Запрос)
	// Уведомления из РС УведомленияОтправленныеЧерезЛичныйКабинет основывающиеся на Заявлениях на участие в оферте
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ДокКарточкаОферты.КорпоративноеДействие КАК Основание,
	|	Уведомления.Период КАК Период,
	|	""КД"" КАК ПрефиксНомера,
	|	""Уведомление клиентов. КД референс: "" + ЕСТЬNULL(ДокКорпоративноеДействие.КДРеференс, """") КАК НаименованиеДокументаИлиКомплекта,
	|	Уведомления.Клиент КАК Депонент,
	|	Уведомления.Клиент.Код КАК ДепонентКод,
	|	Истина КАК ЭтоУведомленияЧерезЛК,
	|	Уведомления.Период КАК ДатаНаправленияВрученияДокумента,
	|	"""" КАК Адресат,
	|	""Депонент"" КАК ИсточникАдресата,
	|	&ПользовательРОБОТ КАК Исполнитель,
	|	"""" КАК Комментарий,
	|	"""" КАК Инициатор
	|ПОМЕСТИТЬ втУведомленияОПриемеЗаявлений
	|ИЗ
	|	РегистрСведений.УведомленияОтправленныеЧерезЛичныйКабинет КАК Уведомления
	|	ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЗаявлениеНаУчастиеВОферте КАК ЗаявлениеНаУчастиеВОферте
	|		ПО Уведомления.КД = ЗаявлениеНаУчастиеВОферте.Ссылка
	|	ЛЕВОЕ СОЕДИНЕНИЕ Документ.КарточкаОферты КАК ДокКарточкаОферты
	|		ПО ЗаявлениеНаУчастиеВОферте.КарточкаОферты = ДокКарточкаОферты.Ссылка
	|	ЛЕВОЕ СОЕДИНЕНИЕ Документ.КорпоративноеДействие_Новый КАК ДокКорпоративноеДействие
	|		ПО ДокКарточкаОферты.КорпоративноеДействие = ДокКорпоративноеДействие.Ссылка
	|	ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ДоговорыКонтрагентов КАК ДоговорыКонтрагентов
	|		ПО 	ДоговорыКонтрагентов.Владелец = Уведомления.Клиент
	|			И ДоговорыКонтрагентов.ТипДоговора В (&ТипыДоговоровДепонента)
	|			И (ДоговорыКонтрагентов.ДатаОкончанияДействия = ДАТАВРЕМЯ(1, 1, 1)
	|				ИЛИ ДоговорыКонтрагентов.ДатаОкончанияДействия > Уведомления.Период)
	|			И НЕ ДоговорыКонтрагентов.ПометкаУдаления
	|ГДЕ
	|	Уведомления.Период МЕЖДУ &НачалоПериода И &КонецПериода
	|СГРУППИРОВАТЬ ПО
	|	Уведомления.КД,
	|	ДокКарточкаОферты.КорпоративноеДействие,
	|	""Уведомление клиентов. КД референс: "" + ЕСТЬNULL(ДокКорпоративноеДействие.КДРеференс, """"),
	|	Уведомления.Период,
	|	Уведомления.Клиент
	|ИМЕЮЩИЕ
	|	МАКСИМУМ(ВЫБОР
	|				КОГДА ДоговорыКонтрагентов.Ссылка ЕСТЬ NULL ТОГДА ЛОЖЬ ИНАЧЕ ИСТИНА
	|			 КОНЕЦ) = ИСТИНА
	|";
	Запрос.УстановитьПараметр("ТипыДоговоровДепонента", Справочники.Контрагенты.ТипыДоговоровДепонента());
	Запрос.Выполнить();
КонецПроцедуры

Процедура ЗаполнитьЖИ_втДокументыВыгруженныеВЛуч(Запрос)
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ЕСТЬNULL(НеттоПоручениеПоручения.Поручение, ДокументыВыгруженныеВЛуч.ДокументОснование) КАК Основание,
	|	ДокументыВыгруженныеВЛуч.ДатаВыгрузки КАК Период,
	|	""В"" КАК ПрефиксНомера,
	|	ВЫБОР
	|		КОГДА ДокументыВыгруженныеВЛуч.ИсходящийНомер <> """"
	|			ТОГДА ""Поручение "" + ДокументыВыгруженныеВЛуч.ИсходящийНомер
	|		ИНАЧЕ ""Поручение""
	|	КОНЕЦ КАК НаименованиеДокументаИлиКомплекта,
	|	ВЫБОР
	|		КОГДА ДокументыВыгруженныеВЛуч.ДокументОснование ССЫЛКА Документ.Поручение
	|			ТОГДА ВЫРАЗИТЬ(ДокументыВыгруженныеВЛуч.ДокументОснование.СчетДепо КАК Справочник.СчетаДепо).Владелец
	|		ИНАЧЕ """"
	|	КОНЕЦ КАК Депонент,
	|	ВЫБОР
	|		КОГДА ДокументыВыгруженныеВЛуч.ДокументОснование ССЫЛКА Документ.Поручение
	|			ТОГДА ВЫРАЗИТЬ(ДокументыВыгруженныеВЛуч.ДокументОснование.СчетДепо КАК Справочник.СчетаДепо).Владелец.Код
	|		ИНАЧЕ """"
	|	КОНЕЦ КАК ДепонентКод,
	|	ЛОЖЬ КАК ЭтоУведомленияЧерезЛК,
	|	ДокументыВыгруженныеВЛуч.ДатаВыгрузки КАК ДатаНаправленияВрученияДокумента,
	|	ВЫБОР
	|		КОГДА ДокументыВыгруженныеВЛуч.ДокументОснование ССЫЛКА Документ.Поручение
	|			ТОГДА ПРЕДСТАВЛЕНИЕ(ДокументыВыгруженныеВЛуч.ДокументОснование.МХДепонента)
	|		ИНАЧЕ ПРЕДСТАВЛЕНИЕ(ДокументыВыгруженныеВЛуч.ДокументОснование.МестоХранения)
	|	КОНЕЦ КАК Адресат,
	|	""Адресат"" КАК ИсточникАдресата,
	|	ДокументыВыгруженныеВЛуч.Исполнитель КАК Исполнитель,
	|	ВЫБОР
	|		КОГДА ДокументыВыгруженныеВЛуч.ДокументОснование ССЫЛКА Документ.Поручение
	|				И ДокументыВыгруженныеВЛуч.ДокументОснование.ВидОперацииД = &ИзменениеАнкетныхДанных
	|			ТОГДА ДокументыВыгруженныеВЛуч.ДокументОснование.Комментарий
	|		ИНАЧЕ """"
	|	КОНЕЦ КАК Комментарий,
	|	"""" КАК Инициатор,
	|	ЕСТЬNULL(НеттоПоручениеПоручения.Поручение, ДокументыВыгруженныеВЛуч.ДокументОснование) КАК Поручение
	|ПОМЕСТИТЬ втДокументыВыгруженныеВЛуч
	|ИЗ
	|	РегистрСведений.ДокументыВыгруженныеВЛуч КАК ДокументыВыгруженныеВЛуч
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.НеттоПоручение.Поручения КАК НеттоПоручениеПоручения
	|		ПО ДокументыВыгруженныеВЛуч.ДокументОснование = НеттоПоручениеПоручения.Ссылка
	|ГДЕ
	|	ДокументыВыгруженныеВЛуч.ДатаВыгрузки МЕЖДУ &НачалоПериода И &КонецПериода
	|	И ВЫБОР
	|			КОГДА ДокументыВыгруженныеВЛуч.ДокументОснование ССЫЛКА Документ.Поручение
	|				ТОГДА ВЫРАЗИТЬ(ДокументыВыгруженныеВЛуч.ДокументОснование КАК Документ.Поручение).НомерПорученияВБО + ДокументыВыгруженныеВЛуч.РегистрационныйНомер
	|			ИНАЧЕ ДокументыВыгруженныеВЛуч.РегистрационныйНомер
	|		КОНЕЦ <> """"";
	Запрос.Выполнить();
КонецПроцедуры

