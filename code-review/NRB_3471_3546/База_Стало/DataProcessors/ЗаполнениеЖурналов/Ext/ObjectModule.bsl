// Возвращает из НомерДокумента буквенный префикс, длиной не более МаксДлинаПрефикса
Функция БуквыПрефиксаНомера(НомерДокумента, МаксДлинаПрефикса = 2)
	Буквы = "АБВГДЕЁЖЗИЙКЛМНОПРСТУФХЦЧШЪЩЬЫЭЮЯабвгдеёжзийклмнопрстуфхцчшъщьыэюя";
	Префикс = "";
	Инд = 0;
	Пока Инд < СтрДлина(НомерДокумента) И Инд < МаксДлинаПрефикса Цикл
		ТекущийСимвол = Сред(НомерДокумента, Инд+1, 1);
		Если Найти(Буквы, ТекущийСимвол) > 0 Тогда
			Префикс = Префикс + ТекущийСимвол;
			Инд = Инд + 1;
		Иначе
			Прервать;
		КонецЕсли;
	КонецЦикла;
	Возврат Префикс;
КонецФункции

Функция СписокПустыхЗначенийРеквизитаДокументКД()
	ПустыеЗначенияДокументаКД = Новый Массив;
	ПустыеЗначенияДокументаКД.Добавить(Неопределено);
	ПустыеЗначенияДокументаКД.Добавить(Документы.Поручение.ПустаяСсылка());
	ПустыеЗначенияДокументаКД.Добавить(Документы.КорпоративноеДействие_Новый.ПустаяСсылка());
	ПустыеЗначенияДокументаКД.Добавить(Документы.РаскрытиеСпискаВладельцев.ПустаяСсылка());
	Возврат ПустыеЗначенияДокументаКД;
КонецФункции

