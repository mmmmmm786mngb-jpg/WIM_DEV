	Выборка = Запрос.Выполнить().Выбрать();
	
	ПредДень = Дата("00010101");	// Предыдущие значения для генерации последовательности номеров
	ПредОснование = "";
	НомерВнутриДня = 1;		// Начинается с 1 с началом нового дня
	НомерВнутриРСВ = 1;		// Начинается с 1 внутри списка владельцев РСВ, всегда равен 1 для других документов
	
	Если Выборка.Количество() = 0 Тогда
    	ТекстСообщения = "Не обнаружены данные за " + ПредставлениеПериода(НачалоПериода, КонецПериода)
			+ " для заполнения регистра сведений ""Журнал исходящих документов""";
	Иначе
		Пока Выборка.Следующий() Цикл
			Если Документы.Поручение.ЭтоПоручениеНФИ(Выборка.Поручение) Тогда
				Продолжить;
			КонецЕсли;
			
			// Генерация номера внутри дня
			Если НачалоДня(ПредДень) = НачалоДня(Выборка.Период) Тогда
				Если ПредОснование = Выборка.Основание Тогда	// Тот же документ в тот же день - обход списка владельцев РСВ
					НомерВнутриРСВ = НомерВнутриРСВ + 1;
				Иначе	// Документ сменился
					НомерВнутриДня = НомерВнутриДня + 1;
					НомерВнутриРСВ = 1;
				КонецЕсли;
			Иначе // день сменился - начинаем новую нумерацию
				НомерВнутриДня = 1;
				НомерВнутриРСВ = 1;
			КонецЕсли;
			ПредОснование	= Выборка.Основание;
			ПредДень		= Выборка.Период;
			
			// Формирование записи регистра
			НаборЗаписей = РегистрыСведений.ЖурналИсходящихДокументов.СоздатьНаборЗаписей();
			НаборЗаписей.Отбор.Основание.Установить(Выборка.Основание);
			НаборЗаписей.Отбор.Период.Установить(Выборка.Период);
			НаборЗаписей.Отбор.НомерСтрокиРСВ.Установить(НомерВнутриРСВ);
			
			НоваяЗапись = НаборЗаписей.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяЗапись, Выборка);
			НоваяЗапись.НомерДокумента = Выборка.ПрефиксНомера
				+ Формат(Выборка.Период, "ДФ=ггММдд-") + Формат(НомерВнутриДня, "ЧЦ=5;ЧВН=1;ЧГ=0");
				
			// Т.к. у всех уведомлений, отправленных через ЛК, номер документа один, добавим суффикс
			Если Выборка.ЭтоУведомленияЧерезЛК Тогда
				НоваяЗапись.НомерДокумента = НоваяЗапись.НомерДокумента + "/" + Формат(НомерВнутриРСВ, "ЧЦ=4;ЧВН=1;ЧГ=0");
			КонецЕсли;
			
			// Если нужно, перезапишем адресата.
			Если (Выборка.ИсточникАдресата = "Депонент") И ЗначениеЗаполнено(Выборка.Депонент) Тогда
				НаименованиеДепонента = ОбщегоНазначенияКлиентСервер.НаименованиеЮрФизЛицаКлиента(
					Выборка.Депонент, Выборка.Период, Ложь);
				ДокументыДепонента = ОбщегоНазначенияКлиентСервер.ДокументКлиента(Выборка.Депонент, Выборка.Период);
				НоваяЗапись.Адресат = НаименованиеДепонента + ". " + ДокументыДепонента;
				
			ИначеЕсли (Выборка.ИсточникАдресата = "Инициатор") И ЗначениеЗаполнено(Выборка.Инициатор) Тогда
				// Это поле Инициатор документа РаскрытиеСпискаВладельцев. Может быть контрагентом и местом хранения.
				Если ТипЗнч(Выборка.Инициатор) = Тип("СправочникСсылка.Контрагенты") Тогда
					НаименованиеДепонента = ОбщегоНазначенияКлиентСервер.НаименованиеЮрФизЛицаКлиента(
						Выборка.Инициатор, Выборка.Период, Ложь);
					ДокументыДепонента = ОбщегоНазначенияКлиентСервер.ДокументКлиента(Выборка.Инициатор, Выборка.Период);
					НоваяЗапись.Адресат = НаименованиеДепонента + ". " + ДокументыДепонента;
				Иначе
					НоваяЗапись.Адресат = Выборка.Инициатор.Наименование;
				КонецЕсли;
			КонецЕсли;
			НоваяЗапись.НомерСтрокиРСВ = НомерВнутриРСВ;
			НаборЗаписей.Записать();
		КонецЦикла;
    	ТекстСообщения = "Заполнен регистр сведений ""Журнал исходящих документов"" за "
			+ ПредставлениеПериода(НачалоПериода, КонецПериода);
	КонецЕсли;
	ЗаписьЖурналаРегистрации("Заполнение журналов ДЕПО", УровеньЖурналаРегистрации.Информация,,, ТекстСообщения);
	Сообщение = Новый СообщениеПользователю();
	Сообщение.Текст = ТекстСообщения;
	Сообщение.Сообщить();
КонецПроцедуры

Процедура ЗаполнитьЖурналОпераций(Знач НачалоПериода, Знач КонецПериода) Экспорт
