///////////////////////////////////////////////////////////////////////////////
// ИНТЕРФЕЙС МОДУЛЯ

Процедура ЗаполнитьЖурналВходящихДокументов(Знач НачалоПериода, Знач КонецПериода) Экспорт
	НачалоПериода = НачалоДня(НачалоПериода);
	КонецПериода = КонецДня(КонецПериода);
	
	РегистрыСведений.ЖурналВходящихДокументов.УдалитьЗаписиЗаПериод(НачалоПериода, КонецПериода);
	
	// Заполнить регистр данными за указанный период
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("НачалоПериода", НачалоПериода);
	Запрос.УстановитьПараметр("КонецПериода", КонецПериода);
	Запрос.УстановитьПараметр("КлассОперацийПоручений", Перечисления.КлассыОпераций.Инвентарные);
	Запрос.УстановитьПараметр("ПользовательРОБОТ", Константы.ПользовательРобот.Получить());
	Запрос.УстановитьПараметр("ПустойПользователь", Справочники.Пользователи.ПустаяСсылка());
	Запрос.УстановитьПараметр("ПустаяЦеннаяБумага", Справочники.ЦенныеБумаги.ПустаяСсылка());
	Запрос.УстановитьПараметр("СписокДопустимыхЗначенийРеквизитаДокументКД", СписокПустыхЗначенийРеквизитаДокументКД());
	
	ВидыОперацийПорученияНаДатуИсполнения = Новый Массив;
	ВидыОперацийПорученияНаДатуИсполнения.Добавить(Справочники.ВидыОпераций.Депонирование);
	ВидыОперацийПорученияНаДатуИсполнения.Добавить(Справочники.ВидыОпераций.СнятиеСДепонирования);
	ВидыОперацийПорученияНаДатуИсполнения.Добавить(Справочники.ВидыОпераций.Перемещение);
	Запрос.УстановитьПараметр("ВидыОперацийПорученияНаДатуИсполнения", ВидыОперацийПорученияНаДатуИсполнения);
	Запрос.УстановитьПараметр("КлассОперацийГлобальные", Перечисления.КлассыОпераций.Глобальные);
	Запрос.УстановитьПараметр("ОтменаПоручения", Справочники.ВидыОпераций.ОтменаПоручения);
	Запрос.УстановитьПараметр("МестоХраненияПоУмолчанию", Константы.МестоХраненияПоУмолчанию.Получить());
	
	ВидыКДДляРСВ = Справочники.ВидыКорпоративныхДействий.ВидыКДРСВДляЖурналовВходящихИсходящих();
	Запрос.УстановитьПараметр("ВидыКДДляРСВ", ВидыКДДляРСВ);
	
	ТипыСчетовДепоМХОтчетаНРД40 = Новый Массив;
	ТипыСчетовДепоМХОтчетаНРД40.Добавить(Перечисления.ТипыСчетовДепо.НоминальногоДержателя);
	ТипыСчетовДепоМХОтчетаНРД40.Добавить(Перечисления.ТипыСчетовДепо.НоминальногоДержателяТорговый);
	ТипыСчетовДепоМХОтчетаНРД40.Добавить(Перечисления.ТипыСчетовДепо.КлиринговыйСчетДЕПО_КСУ_GC_Bonds);
	ТипыСчетовДепоМХОтчетаНРД40.Добавить(Перечисления.ТипыСчетовДепо.КлиринговыйСчетДЕПО_КСУ_GC_Expanded);
	ТипыСчетовДепоМХОтчетаНРД40.Добавить(Перечисления.ТипыСчетовДепо.КлиринговыйСчетДЕПО_КСУ_GC_Shares);
	Запрос.УстановитьПараметр("ТипыСчетовДепоМХОтчетаНРД40", ТипыСчетовДепоМХОтчетаНРД40);
	
	// Получим депонентов из состава сводных поручений
	Запрос.Текст =
	"ВЫБРАТЬ
	|	СоставПоручения.Ссылка КАК Ссылка,
	|	МАКСИМУМ(СоставПоручения.Депонент) КАК Депонент
	|ПОМЕСТИТЬ втСоставПоручения
	|ИЗ
	|	Документ.иц_СводноеПоручение.СоставПоручения КАК СоставПоручения
	|ГДЕ
	|	СоставПоручения.Ссылка.Дата МЕЖДУ &НачалоПериода И &КонецПериода
	|	И СоставПоручения.Ссылка.Проведен
	|
	|СГРУППИРОВАТЬ ПО
	|	СоставПоручения.Ссылка
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	СоставПоручения.Ссылка
	|";
	Запрос.Выполнить();
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ОтветСубброкераНаРаскрытиеДанныеСубброкера.Ссылка КАК Ссылка,
	|	МАКСИМУМ(ОтветСубброкераНаРаскрытиеДанныеСубброкера.Клиент) КАК Клиент,
	|	МАКСИМУМ(ОтветСубброкераНаРаскрытиеДанныеСубброкера.ЦеннаяБумага) КАК ЦеннаяБумага
	|ПОМЕСТИТЬ втКлиентыОтветСубброкераНаРаскрытие
	|ИЗ
	|	Документ.ОтветСубброкераНаРаскрытие.ДанныеСубброкера КАК ОтветСубброкераНаРаскрытиеДанныеСубброкера
	|
	|СГРУППИРОВАТЬ ПО
	|	ОтветСубброкераНаРаскрытиеДанныеСубброкера.Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Поручение.Ссылка КАК Основание,
	|	Поручение.Дата КАК Период,
	|	Поручение.Номер КАК НомерОснования,
	|	ВЫБОР
	|		КОГДА ВЫРАЗИТЬ(Поручение.ВидОперацииД КАК Справочник.ВидыОпераций).КлассОпераций = &КлассОперацийГлобальные
	|				И ВЫРАЗИТЬ(Поручение.ВидОперацииД КАК Справочник.ВидыОпераций).ВыплатаДоходаВДенежнойФорме
	|			ТОГДА ""Извещение о выплате и перечислении денежных средств""
	|		ИНАЧЕ ""Поручение""
	|	КОНЕЦ КАК НаименованиеДокументаИлиКомплекта,
	|	ВЫБОР
	|		КОГДА ВЫРАЗИТЬ(Поручение.ВидОперацииД КАК Справочник.ВидыОпераций).КлассОпераций = &КлассОперацийГлобальные
	|				И ВЫРАЗИТЬ(Поручение.ВидОперацииД КАК Справочник.ВидыОпераций).ДвижениеПоЦБ
	|			ТОГДА Поручение.КодОтчетаНРД
	|		КОГДА ВЫРАЗИТЬ(Поручение.ВидОперацииД КАК Справочник.ВидыОпераций).ВыплатаДоходаВДенежнойФорме
	|			ТОГДА Поручение.НомерИПД
	|		ИНАЧЕ Поручение.Номер
	|	КОНЕЦ КАК ИсходящийНомер,
	|	ВЫБОР
	|		КОГДА ВЫРАЗИТЬ(Поручение.ВидОперацииД КАК Справочник.ВидыОпераций).ВыплатаДоходаВДенежнойФорме
	|			ТОГДА Поручение.ДатаПлатежногоПоручения
	|		ИНАЧЕ Поручение.Дата
	|	КОНЕЦ КАК ДатаОтправления,
	|	ВЫБОР
	|		КОГДА Поручение.ВидОперацииД = &ОтменаПоручения
	|				И Поручение.ОтменяемоеПоручение ССЫЛКА Документ.Поручение
	|			ТОГДА Поручение.ОтменяемоеПоручение.Депонент
	|		КОГДА Поручение.ВидОперацииД = ЗНАЧЕНИЕ(Справочник.ВидыОпераций.Перевод)
	|				И Поручение.ТипПеревода = ЗНАЧЕНИЕ(Перечисление.ТипыПереводов.Зачисление)
	|			ТОГДА Поручение.Контрагент
	|		КОГДА Поручение.ВидОперацииД = ЗНАЧЕНИЕ(Справочник.ВидыОпераций.Перевод)
	|				И Поручение.ТипПеревода = ЗНАЧЕНИЕ(Перечисление.ТипыПереводов.Списание)
	|			ТОГДА Поручение.Депонент
	|		ИНАЧЕ ЕСТЬNULL(ВЫРАЗИТЬ(Поручение.СчетДепо КАК Справочник.СчетаДепо).Владелец, Поручение.Депонент)
	|	КОНЕЦ КАК Депонент,
	|	ВЫБОР
	|		КОГДА Поручение.ВидОперацииД = &ОтменаПоручения
	|				И Поручение.ОтменяемоеПоручение ССЫЛКА Документ.Поручение
	|			ТОГДА Поручение.ОтменяемоеПоручение.ЦБ
	|		ИНАЧЕ Поручение.ЦБ
	|	КОНЕЦ КАК ЦеннаяБумага,
	|	ВЫБОР
	|		КОГДА ВЫРАЗИТЬ(Поручение.ВидОперацииД КАК Справочник.ВидыОпераций).КлассОпераций = &КлассОперацийГлобальные
	|				И ВЫРАЗИТЬ(Поручение.ВидОперацииД КАК Справочник.ВидыОпераций).ВыплатаДоходаВДенежнойФорме
	|			ТОГДА ПРЕДСТАВЛЕНИЕ(Поручение.ПлатежныйАгент)
	|		ИНАЧЕ ПРЕДСТАВЛЕНИЕ(Поручение.Инициатор)
	|	КОНЕЦ КАК ЛицоНаправившееДокумент,
	|	Поручение.Автор КАК Исполнитель,
	|	Поручение.СпособПриемаПоручений.Наименование + "" "" + ПОДСТРОКА(СТРОКА(Поручение.ДатаПриема), 1, 10) КАК Комментарий,
	|	ВЫБОР
	|		КОГДА Поручение.ВидОперацииД = &ОтменаПоручения
	|				И Поручение.ОтменяемоеПоручение ССЫЛКА Документ.Поручение
	|			ТОГДА Поручение.ОтменяемоеПоручение.Номер
	|		ИНАЧЕ """"
	|	КОНЕЦ КАК ОтменяемоеПоручениеНомер,
	|	ВЫБОР
	|		КОГДА Поручение.ВидОперацииД = &ОтменаПоручения
	|				И Поручение.ОтменяемоеПоручение ССЫЛКА Документ.Поручение
	|			ТОГДА Поручение.ОтменяемоеПоручение.Дата
	|		ИНАЧЕ ДАТАВРЕМЯ(1, 1, 1)
	|	КОНЕЦ КАК ОтменяемоеПоручениеДата
	|ИЗ
	|	Документ.Поручение КАК Поручение
	|ГДЕ
	|	Поручение.Дата МЕЖДУ &НачалоПериода И &КонецПериода
	|	И Поручение.Проведен
	|	И ВЫБОР
	|			КОГДА Поручение.ВидОперацииД = ЗНАЧЕНИЕ(Справочник.ВидыОпераций.ОткрытиеРазделаСчетаДепо)
	|					ИЛИ Поручение.ВидОперацииД = ЗНАЧЕНИЕ(Справочник.ВидыОпераций.ЗакрытиеРазделаСчетаДепо)
	|				ТОГДА ВЫБОР
	|						КОГДА Поручение.Депонент ССЫЛКА Справочник.Контрагенты
	|							ТОГДА ИСТИНА
	|						ИНАЧЕ ЛОЖЬ
	|					КОНЕЦ
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	Поручение.Ссылка,
	|	Поручение.ДатаИсполненияПоручения,
	|	""О"",
	|	""Отчет"",
	|	Поручение.КодОтчетаНРД,
	|	Поручение.ДатаИсполненияПоручения,
	|	Поручение.Депонент,
	|	Поручение.ЦБ,
	|	Поручение.МХДепонента.Наименование,
	|	ВЫБОР
	|		КОГДА Поручение.Изменил = &ПустойПользователь
	|			ТОГДА &ПользовательРОБОТ
	|		ИНАЧЕ Поручение.Изменил
	|	КОНЕЦ,
	|	Поручение.СпособПриемаПоручений.Наименование + "" "" + ПОДСТРОКА(СТРОКА(Поручение.ДатаПриема), 1, 10),
	|	"""",
	|	ДАТАВРЕМЯ(1, 1, 1)
	|ИЗ
	|	Документ.Поручение КАК Поручение
	|ГДЕ
	|	Поручение.ДатаИсполненияПоручения МЕЖДУ &НачалоПериода И &КонецПериода
	|	И Поручение.Проведен
	|	И ВЫРАЗИТЬ(Поручение.ВидОперацииД КАК Справочник.ВидыОпераций).КлассОпераций = &КлассОперацийПоручений
	|	И Поручение.ВидОперацииД В(&ВидыОперацийПорученияНаДатуИсполнения)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	СводноеПоручение.Ссылка,
	|	СводноеПоручение.Дата,
	|	СводноеПоручение.Номер,
	|	""Сводное поручение депо"",
	|	СводноеПоручение.Номер,
	|	СводноеПоручение.Дата,
	|	втСоставПоручения.Депонент,
	|	&ПустаяЦеннаяБумага,
	|	СводноеПоручение.Инициатор.Наименование,
	|	&ПользовательРОБОТ,
	|	"""",
	|	"""",
	|	ДАТАВРЕМЯ(1, 1, 1)
	|ИЗ
	|	Документ.иц_СводноеПоручение КАК СводноеПоручение
	|		ЛЕВОЕ СОЕДИНЕНИЕ втСоставПоручения КАК втСоставПоручения
	|		ПО СводноеПоручение.Ссылка = втСоставПоручения.Ссылка
	|ГДЕ
	|	СводноеПоручение.Дата МЕЖДУ &НачалоПериода И &КонецПериода
	|	И СводноеПоручение.Проведен
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	Входящий.Ссылка,
	|	Входящий.Дата,
	|	Входящий.Номер,
	|	Входящий.НаименованиеДокументаИлиКомплекта,
	|	Входящий.ИсходящийНомер,
	|	Входящий.ДатаОтправления,
	|	Входящий.Депонент,
	|	Входящий.ЦеннаяБумага,
	|	Входящий.ЛицоНаправившееДокумент,
	|	Входящий.Исполнитель,
	|	Входящий.Комментарий,
	|	"""",
	|	ДАТАВРЕМЯ(1, 1, 1)
	|ИЗ
	|	Документ.Входящий КАК Входящий
	|ГДЕ
	|	Входящий.Дата МЕЖДУ &НачалоПериода И &КонецПериода
	|	И Входящий.Проведен
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ЭтапыКД.ДокументКД,
	|	ЭтапыКД.Период,
	|	""КД"",
	|	ВЫБОР
	|		КОГДА ЭтапыКД.ЭтапКД.КомплектДокументов <> """"
	|			ТОГДА ЭтапыКД.ЭтапКД.КомплектДокументов + "". КД Референс "" + ЭтапыКД.КД.КДРеференс
	|		ИНАЧЕ ЭтапыКД.ЭтапКД.Наименование + "". КД Референс "" + ЭтапыКД.КД.КДРеференс
	|	КОНЕЦ,
	|	ЭтапыКД.НомерСообщения,
	|	ЭтапыКД.Период,
	|	NULL,
	|	ВЫБОР
	|		КОГДА ЭтапыКД.ДокументКД ССЫЛКА Документ.Поручение
	|			ТОГДА ЭтапыКД.ДокументКД.ЦБ
	|		КОГДА ЭтапыКД.ДокументКД ССЫЛКА Документ.КорпоративноеДействие_Новый
	|				ИЛИ ЭтапыКД.ДокументКД ССЫЛКА Документ.РаскрытиеСпискаВладельцев
	|			ТОГДА ЭтапыКД.ДокументКД.ЦеннаяБумага1
	|	КОНЕЦ,
	|	Константы.МестоХраненияПоУмолчанию.Наименование,
	|	&ПользовательРОБОТ,
	|	"""",
	|	"""",
	|	ДАТАВРЕМЯ(1, 1, 1)
	|ИЗ
	|	РегистрСведений.ЭтапыКД КАК ЭтапыКД,
	|	Константы КАК Константы
	|ГДЕ
	|	ЭтапыКД.Период МЕЖДУ &НачалоПериода И &КонецПериода
	|	И НЕ ЭтапыКД.Исходящее
	|	И ЭтапыКД.КодОтчета <> ""CA061""
	|	И (ЭтапыКД.ДокументКД В (&СписокДопустимыхЗначенийРеквизитаДокументКД)
	|			ИЛИ ЭтапыКД.ДокументКД ССЫЛКА Документ.Поручение
	|			ИЛИ (ЭтапыКД.ДокументКД ССЫЛКА Документ.КорпоративноеДействие_Новый
	|				ИЛИ ЭтапыКД.ДокументКД ССЫЛКА Документ.РаскрытиеСпискаВладельцев)
	|				И (ЭтапыКД.ДокументКД.ЦеннаяБумага1 = &ПустаяЦеннаяБумага
	|					ИЛИ ЭтапыКД.ДокументКД.ЦеннаяБумага1.НФИ = 0))
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	РаспоряжениеОператораСчетаДЕПО.Ссылка,
	|	РаспоряжениеОператораСчетаДЕПО.Дата,
	|	РаспоряжениеОператораСчетаДЕПО.Номер,
	|	""Распоряжение оператора счета депо на расчеты по сделке"",
	|	РаспоряжениеОператораСчетаДЕПО.ВходящийНомер,
	|	РаспоряжениеОператораСчетаДЕПО.Дата,
	|	РаспоряжениеОператораСчетаДЕПО.Депонент,
	|	РаспоряжениеОператораСчетаДЕПО.ЦеннаяБумага,
	|	РаспоряжениеОператораСчетаДЕПО.Оператор,
	|	РаспоряжениеОператораСчетаДЕПО.Автор,
	|	РаспоряжениеОператораСчетаДЕПО.ДопИнформация,
	|	"""",
	|	ДАТАВРЕМЯ(1, 1, 1)
	|ИЗ
	|	Документ.РаспоряжениеОператораСчетаДЕПО КАК РаспоряжениеОператораСчетаДЕПО
	|ГДЕ
	|	РаспоряжениеОператораСчетаДЕПО.Дата МЕЖДУ &НачалоПериода И &КонецПериода
	|	И РаспоряжениеОператораСчетаДЕПО.Проведен
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ОтветСубброкераНаРаскрытие.Ссылка,
	|	ОтветСубброкераНаРаскрытие.Дата,
	|	ОтветСубброкераНаРаскрытие.Номер,
	|	""Ответ субброкера на раскрытие"",
	|	ОтветСубброкераНаРаскрытие.НомерДокументаСубброкера,
	|	ОтветСубброкераНаРаскрытие.ДатаДокументаСубброкера,
	|	втКлиентыОтветСубброкераНаРаскрытие.Клиент,
	|	втКлиентыОтветСубброкераНаРаскрытие.ЦеннаяБумага,
	|	втКлиентыОтветСубброкераНаРаскрытие.Клиент.Наименование,
	|	&ПользовательРОБОТ,
	|	"""",
	|	"""",
	|	ДАТАВРЕМЯ(1, 1, 1)
	|ИЗ
	|	Документ.ОтветСубброкераНаРаскрытие КАК ОтветСубброкераНаРаскрытие
	|		ЛЕВОЕ СОЕДИНЕНИЕ втКлиентыОтветСубброкераНаРаскрытие КАК втКлиентыОтветСубброкераНаРаскрытие
	|		ПО ОтветСубброкераНаРаскрытие.Ссылка = втКлиентыОтветСубброкераНаРаскрытие.Ссылка
	|ГДЕ
	|	ОтветСубброкераНаРаскрытие.Дата МЕЖДУ &НачалоПериода И &КонецПериода
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	РаскрытиеСпискаВладельцев.Ссылка,
	|	РаскрытиеСпискаВладельцев.ВходящийДокументДата,
	|	""КД"",
	|	""Запрос на раскрытие списка владельцев. КД Референс "" + РаскрытиеСпискаВладельцев.КДРеференс,
	|	РаскрытиеСпискаВладельцев.ВходящийДокументНомер,
	|	РаскрытиеСпискаВладельцев.ВходящийДокументДата,
	|	NULL,
	|	РаскрытиеСпискаВладельцев.ЦеннаяБумага1,
	|	РаскрытиеСпискаВладельцев.СчетДЕПО.Владелец,
	|	РаскрытиеСпискаВладельцев.Автор,
	|	"""",
	|	"""",
	|	ДАТАВРЕМЯ(1, 1, 1)
	|ИЗ
	|	Документ.РаскрытиеСпискаВладельцев КАК РаскрытиеСпискаВладельцев
	|ГДЕ
	|	РаскрытиеСпискаВладельцев.ВходящийДокументДата МЕЖДУ &НачалоПериода И &КонецПериода
	|	И РаскрытиеСпискаВладельцев.ВидКорпоративногоДействия В(&ВидыКДДляРСВ)
	|	И РаскрытиеСпискаВладельцев.ТипЗагрузкиСписковРаскрытия <> ЗНАЧЕНИЕ(Перечисление.ТипЗагрузкиСписковРаскрытия.PARTAD)
	|	И НЕ РаскрытиеСпискаВладельцев.ПометкаУдаления
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	Настройки.Наименование,
	|	ДОБАВИТЬКДАТЕ(Календарь.Период, СЕКУНДА, РАЗНОСТЬДАТ(НАЧАЛОПЕРИОДА(Настройки.ДатаНачалаДействия, ДЕНЬ), Настройки.ДатаНачалаДействия, СЕКУНДА)),
	|	Настройки.ПрефиксНомераДокумента,
	|	Настройки.НаименованиеДокументаИлиКомплекта,
	|	Настройки.ПрефиксИсходящегоНомера + ""<ПериодВФорматеYYMMDDHHmm>"",
	|	ДОБАВИТЬКДАТЕ(Календарь.Период, СЕКУНДА, РАЗНОСТЬДАТ(НАЧАЛОПЕРИОДА(Настройки.ДатаНачалаДействия, ДЕНЬ), Настройки.ДатаНачалаДействия, СЕКУНДА)),
	|	Настройки.Депонент,
	|	NULL,
	|	Настройки.ЛицоНаправившееДокумент,
	|	Настройки.Исполнитель,
	|	Настройки.Комментарий,
	|	"""",
	|	ДАТАВРЕМЯ(1, 1, 1)
	|ИЗ
	|	Справочник.НастройкиФиксированныхЗаписейЖурналаВходящихДокументов КАК Настройки
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.Календарь КАК Календарь
	|		ПО (НЕ Календарь.Значение)
	|			И (Календарь.Период МЕЖДУ &НачалоПериода И &КонецПериода)
	|			И (НЕ Настройки.ПометкаУдаления)
	|			И (НАЧАЛОПЕРИОДА(Настройки.ДатаНачалаДействия, ДЕНЬ) <= Календарь.Период)
	|			И (ВЫБОР
	|				КОГДА Настройки.ДатаОкончанияДействия = ДАТАВРЕМЯ(1, 1, 1)
	|					ТОГДА ИСТИНА
	|				КОГДА Настройки.ДатаОкончанияДействия > Календарь.Период
	|					ТОГДА ИСТИНА
	|				ИНАЧЕ ЛОЖЬ
	|			КОНЕЦ)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ВходящийПакетИзФайловогоШлюза.Ссылка,
	|	ВходящийПакетИзФайловогоШлюза.Дата,
	|	""П"",
	|	""Отчет НКО АО НРД ("" + СОКРЛП(ВходящийПакетИзФайловогоШлюза.КодОперации) + "") "" + ЕСТЬNULL(СчетаДепоМХ.Код, """"),
	|	ВходящийПакетИзФайловогоШлюза.НомерВходящегоДокумента,
	|	ВходящийПакетИзФайловогоШлюза.ДатаВходящегоДокумента,
	|	NULL,
	|	NULL,
	|	""НКО АО НРД"",
	|	&ПользовательРОБОТ,
	|	"""",
	|	"""",
	|	ДАТАВРЕМЯ(1, 1, 1)
	|ИЗ
	|	Документ.ВходящийПакетИзФайловогоШлюза КАК ВходящийПакетИзФайловогоШлюза
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ВходящийПакетИзФайловогоШлюза.СодержимоеФайла КАК ВходящийПакетИзФайловогоШлюзаСодержимоеФайла
	|		ПО ВходящийПакетИзФайловогоШлюза.Ссылка = ВходящийПакетИзФайловогоШлюзаСодержимоеФайла.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.СчетаДепоМХ КАК СчетаДепоМХ
	|		ПО (ВходящийПакетИзФайловогоШлюзаСодержимоеФайла.Элемент = ""DEPO_ACC_C"")
	|			И (ВходящийПакетИзФайловогоШлюзаСодержимоеФайла.Значение = СчетаДепоМХ.Код)
	|			И (ВходящийПакетИзФайловогоШлюза.КодОперации = ""40"")
	|ГДЕ
	|	ВходящийПакетИзФайловогоШлюза.КодОперации В (""40"", ""41"", ""14"")
	|	И ВходящийПакетИзФайловогоШлюза.Дата МЕЖДУ &НачалоПериода И &КонецПериода
	|	И ВЫБОР
	|			КОГДА ВходящийПакетИзФайловогоШлюза.КодОперации = ""40""
	|				ТОГДА СчетаДепоМХ.Владелец = &МестоХраненияПоУмолчанию
	|						И СчетаДепоМХ.ТипСчета В (&ТипыСчетовДепоМХОтчетаНРД40)
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ
	|
	|СГРУППИРОВАТЬ ПО
	|	ВходящийПакетИзФайловогоШлюза.Ссылка,
	|	ВходящийПакетИзФайловогоШлюза.Дата,
	|	ВходящийПакетИзФайловогоШлюза.НомерВходящегоДокумента,
	|	ВходящийПакетИзФайловогоШлюза.ДатаВходящегоДокумента,
	|	СчетаДепоМХ.Код
	|
	|УПОРЯДОЧИТЬ ПО
	|	Период,
	|	Основание";
	Выборка = Запрос.Выполнить().Выбрать();
	
	ПредДень = Дата("00010101");	// Предыдущее значение для генерации последовательности номеров
	НомерВнутриДня = 1;
	
	Если Выборка.Количество() = 0 Тогда
		ТекстСообщения = "Не обнаружены данные за " + ПредставлениеПериода(НачалоПериода, КонецПериода)
			+ " для заполнения регистра сведений ""Журнал входящих документов""";
	Иначе
		Пока Выборка.Следующий() Цикл
			Если Документы.Поручение.ЭтоПоручениеНФИ(Выборка.Основание) Тогда
				Продолжить;
			КонецЕсли;
			
			// Генерация номера внутри дня
			Если НачалоДня(ПредДень) = НачалоДня(Выборка.Период) Тогда // день не изменился - продолжаем нумерацию
				НомерВнутриДня = НомерВнутриДня + 1;
			Иначе // день сменился - начинаем новую нумерацию
				НомерВнутриДня = 1;
			КонецЕсли;
			ПредДень = Выборка.Период;
			
			// Формирование записи регистра
			НаборЗаписей = РегистрыСведений.ЖурналВходящихДокументов.СоздатьНаборЗаписей();
			НаборЗаписей.Отбор.Основание.Установить(Выборка.Основание);
			НаборЗаписей.Отбор.Период.Установить(Выборка.Период);
			
			НоваяЗапись = НаборЗаписей.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяЗапись, Выборка);
			
			Если НоваяЗапись.ИсходящийНомер = "0" Тогда
				НоваяЗапись.ИсходящийНомер = "б/н";
			КонецЕсли;
			
			Если СтрНайти(НоваяЗапись.ИсходящийНомер, "<ПериодВФорматеYYMMDDHHmm>") <> 0 Тогда
				ДатаСтрокой = Формат(Выборка.Период, "ДФ=""yyMMddHHmm""");
				НоваяЗапись.ИсходящийНомер = СтрЗаменить(НоваяЗапись.ИсходящийНомер, "<ПериодВФорматеYYMMDDHHmm>", ДатаСтрокой);
			КонецЕсли;
				
			НоваяЗапись.НомерДокумента = БуквыПрефиксаНомера(Выборка.НомерОснования)
				+ Формат(Выборка.Период, "ДФ=ггММдд-") + Формат(НомерВнутриДня, "ЧЦ=5;ЧВН=1;ЧГ=0");
				
			Если ЗначениеЗаполнено(Выборка.ОтменяемоеПоручениеНомер) Тогда
				НоваяЗапись.Комментарий = "Отмена поручения № " + СокрЛП(Выборка.ОтменяемоеПоручениеНомер) + " от " + Формат(Выборка.ОтменяемоеПоручениеДата, "ДФ=dd.MM.yyyy");
			КонецЕсли;
			
			НаборЗаписей.Записать();
		КонецЦикла;
		ТекстСообщения = "Заполнен регистр сведений ""Журнал входящих документов"" за "
			+ ПредставлениеПериода(НачалоПериода, КонецПериода);
	КонецЕсли;
	ЗаписьЖурналаРегистрации("Заполнение журналов ДЕПО", УровеньЖурналаРегистрации.Информация,,, ТекстСообщения);
	Сообщение = Новый СообщениеПользователю();
	Сообщение.Текст = ТекстСообщения;
	Сообщение.Сообщить();
КонецПроцедуры

Процедура ЗаполнитьЖурналИсходящихДокументов(Знач НачалоПериода, Знач КонецПериода) Экспорт
	НачалоПериода = НачалоДня(НачалоПериода);
	КонецПериода = КонецДня(КонецПериода);
	
	РегистрыСведений.ЖурналИсходящихДокументов.УдалитьЗаписиЗаПериод(НачалоПериода, КонецПериода);
	
	ВидыОтчетаПоСчетуДЕПО = Новый Массив;
	ВидыОтчетаПоСчетуДЕПО.Добавить(Перечисления.ВидыОтчетов.ВыпискаОСостоянииСчетаДЕПО);
	ВидыОтчетаПоСчетуДЕПО.Добавить(Перечисления.ВидыОтчетов.ОтчетОбОперацияхПоСчетуДЕПО);
	ВидыОтчетаПоСчетуДЕПО.Добавить(Перечисления.ВидыОтчетов.СводныйОтчетОСовершеннойОперации);
	
	ЭтапыУведомлениеКлиентов = Новый Массив;
	ЭтапыУведомлениеКлиентов.Добавить(Справочники.ЭтапыКД.УведомлениеКлиентов);
		
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("НачалоПериода", НачалоПериода);
	Запрос.УстановитьПараметр("КонецПериода", КонецПериода);
	Запрос.УстановитьПараметр("ЭтапыУведомлениеКлиентов", ЭтапыУведомлениеКлиентов);
	Запрос.УстановитьПараметр("ПользовательРОБОТ", Константы.ПользовательРобот.Получить());
	Запрос.УстановитьПараметр("ВидыОтчетаПоСчетуДЕПО", ВидыОтчетаПоСчетуДЕПО);
	Запрос.УстановитьПараметр("СписокДопустимыхЗначенийРеквизитаДокументКД", СписокПустыхЗначенийРеквизитаДокументКД());
	Запрос.УстановитьПараметр("ИзменениеАнкетныхДанных", Справочники.ВидыОпераций.ВидОперацииИзменениеАнкетныхДанных());
	Запрос.УстановитьПараметр("ПустаяЦеннаяБумага", Справочники.ЦенныеБумаги.ПустаяСсылка());
	
	ЗаполнитьЖИ_втВыписка(Запрос);
	ЗаполнитьЖИ_втСводныйОтчетОСовершенныхОперациях(Запрос);
	ЗаполнитьЖИ_втИсходящий(Запрос);
	ЗаполнитьЖИ_втЭтапыКДНЕУведомлениеКлиентов(Запрос);
	ЗаполнитьЖИ_втЭтапыКДУведомлениеКлиентов(Запрос);
	ЗаполнитьЖИ_втУведомленияОПриемеЗаявлений(Запрос);
	ЗаполнитьЖИ_втДокументыВыгруженныеВЛуч(Запрос);
	ЗаполнитьЖИ_втЗапросыСубброкераНаРаскрытие(Запрос);
	ЗаполнитьЖИ_втВыгрузкиРазделовРСВ(Запрос);
	ЗаполнитьЖИ_втРаскрытияСписковВладельцев(Запрос);
	
	// Объединение таблиц документов
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Выписка.Основание КАК Основание,
	|	Выписка.Период КАК Период,
	|	Выписка.ПрефиксНомера КАК ПрефиксНомера,
	|	Выписка.Депонент КАК Депонент,
	|	Выписка.ДепонентКод КАК ДепонентКод,
	|	Выписка.НаименованиеДокументаИлиКомплекта КАК НаименованиеДокументаИлиКомплекта,
	|	Выписка.ЭтоУведомленияЧерезЛК КАК ЭтоУведомленияЧерезЛК,
	|	Выписка.ДатаНаправленияВрученияДокумента КАК ДатаНаправленияВрученияДокумента,
	|	Выписка.Адресат КАК Адресат,
	|	Выписка.ИсточникАдресата КАК ИсточникАдресата,
	|	Выписка.Исполнитель КАК Исполнитель,
	|	Выписка.Комментарий КАК Комментарий,
	|	Выписка.Инициатор КАК Инициатор,
	|	Выписка.Поручение КАК Поручение,
	|	Выписка.ЦеннаяБумага КАК ЦеннаяБумага
	|ИЗ
	|	втВыписка КАК Выписка
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	СводныйОтчетОСовершенныхОперациях.Основание,
	|	СводныйОтчетОСовершенныхОперациях.Период,
	|	СводныйОтчетОСовершенныхОперациях.ПрефиксНомера,
	|	СводныйОтчетОСовершенныхОперациях.Депонент,
	|	СводныйОтчетОСовершенныхОперациях.ДепонентКод,
	|	СводныйОтчетОСовершенныхОперациях.НаименованиеДокументаИлиКомплекта,
	|	СводныйОтчетОСовершенныхОперациях.ЭтоУведомленияЧерезЛК,
	|	СводныйОтчетОСовершенныхОперациях.ДатаНаправленияВрученияДокумента,
	|	СводныйОтчетОСовершенныхОперациях.Адресат,
	|	СводныйОтчетОСовершенныхОперациях.ИсточникАдресата,
	|	СводныйОтчетОСовершенныхОперациях.Исполнитель,
	|	СводныйОтчетОСовершенныхОперациях.Комментарий,
	|	СводныйОтчетОСовершенныхОперациях.Инициатор,
	|	СводныйОтчетОСовершенныхОперациях.Поручение,
	|	СводныйОтчетОСовершенныхОперациях.ЦеннаяБумага
	|ИЗ
	|	втСводныйОтчетОСовершенныхОперациях КАК СводныйОтчетОСовершенныхОперациях
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	Исходящий.Основание,
	|	Исходящий.Период,
	|	Исходящий.ПрефиксНомера,
	|	Исходящий.Депонент,
	|	Исходящий.ДепонентКод,
	|	Исходящий.НаименованиеДокументаИлиКомплекта,
	|	Исходящий.ЭтоУведомленияЧерезЛК,
	|	Исходящий.ДатаНаправленияВрученияДокумента,
	|	Исходящий.Адресат,
	|	Исходящий.ИсточникАдресата,
	|	Исходящий.Исполнитель,
	|	Исходящий.Комментарий,
	|	Исходящий.Инициатор,
	|	NULL,
	|	&ПустаяЦеннаяБумага
	|ИЗ
	|	втИсходящий КАК Исходящий
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ЭтапыКД.Основание,
	|	ЭтапыКД.Период,
	|	ЭтапыКД.ПрефиксНомера,
	|	ЭтапыКД.Депонент,
	|	ЭтапыКД.ДепонентКод,
