#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура ВыполнитьМетодОбъекта(ИмяМетода, ПараметрыМетода = "")
	
	Обработка = РеквизитФормыВЗначение("Объект");
	Выполнить("Обработка." + ИмяМетода + "(" + ПараметрыМетода + ")");
	ЗначениеВРеквизитФормы(Обработка, "Объект");
	
	ОбновитьСтатусыДокументов();
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьСтатусыДокументов()
	
	ДокументСоздан = 0;
	ДокументПроведен = 1;
	ДокументПомеченНаУдаление = 3;
	
	Услуги = Объект.УслугиПоПоручениям.Выгрузить(, "УслугиДепозитария").ВыгрузитьКолонку("УслугиДепозитария");
	УслугиПоФормамW8 = Объект.УслугиПоФормамW8.Выгрузить(, "УслугиДепозитария").ВыгрузитьКолонку("УслугиДепозитария");
	ОбщегоНазначенияКлиентСервер.ДополнитьМассив(Услуги, УслугиПоФормамW8);
	СтатусыУслуг = ОбщегоНазначения.ЗначенияРеквизитовОбъектов(Услуги, "Проведен, ПометкаУдаления");
	
	ТабличныеЧастиСУслугами = Новый Массив;
	ТабличныеЧастиСУслугами.Добавить("УслугиПоПоручениям");
	ТабличныеЧастиСУслугами.Добавить("УслугиПоФормамW8");
	
	Для Каждого ИмяТабличнойЧасти Из ТабличныеЧастиСУслугами Цикл
		Для Каждого Строка Из Объект[ИмяТабличнойЧасти] Цикл
			Строка.СтатусДокумента = ДокументСоздан;
			СтатусУслуги = СтатусыУслуг[Строка.УслугиДепозитария];
			Если ЗначениеЗаполнено(СтатусУслуги) Тогда
				Если СтатусУслуги.Проведен Тогда
					Строка.СтатусДокумента = ДокументПроведен;
				ИначеЕсли СтатусУслуги.ПометкаУдаления Тогда
					Строка.СтатусДокумента = ДокументПомеченНаУдаление;
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура УстановитьОдинаковыеОтметкиДляВсехСтрокДокумента(ТабЧасть, ТекущиеДанные)
	ТекОтметка = ТекущиеДанные.Отметка;
	ТекКонтрагент = ТекущиеДанные.Контрагент;
	ТекДоговор = ТекущиеДанные.Договор;
	ТекДокумент = ТекущиеДанные.УслугиДепозитария;
	Для Каждого СтрокаТЧ Из ТабЧасть Цикл
		Если ЗначениеЗаполнено(ТекДокумент) И СтрокаТЧ.УслугиДепозитария = ТекДокумент Тогда
			СтрокаТЧ.Отметка = ТекОтметка;
		КонецЕсли;
		Если Не ЗначениеЗаполнено(ТекДокумент) И ЭтоСтрокаБезДокументаИСТемЖеКонтрагентомИДоговором(СтрокаТЧ, ТекКонтрагент, ТекДоговор) Тогда
			СтрокаТЧ.Отметка = ТекОтметка;
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

&НаКлиенте
Функция ЭтоСтрокаБезДокументаИСТемЖеКонтрагентомИДоговором(СтрокаТЧ, ТекКонтрагент, ТекДоговор)
	Возврат Не ЗначениеЗаполнено(СтрокаТЧ.УслугиДепозитария) И СтрокаТЧ.Контрагент = ТекКонтрагент И СтрокаТЧ.Договор = ТекДоговор;
КонецФункции

&НаКлиенте
Процедура ПоказатьЗначениеПоля(ИмяТЧ, ВыбраннаяСтрока, ВыбранноеПоле, СписокРеквизитовКПоказуСтрокой)
	ИмяРеквизитаДляПоказа = Неопределено;
	ИменаРеквизитовКПоказу = СтрРазделить(СписокРеквизитовКПоказуСтрокой, ",");
	ИмяВыбранногоПоля = ВыбранноеПоле.Имя;
	Для Каждого ИмяРеквизита Из ИменаРеквизитовКПоказу Цикл
		Если СтрНайти(ИмяВыбранногоПоля, ИмяРеквизита) <> 0 Тогда
			ИмяРеквизитаДляПоказа = ИмяРеквизита;
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	Если ИмяРеквизитаДляПоказа <> Неопределено Тогда
		ТекСтрока = Объект[ИмяТЧ].НайтиПоИдентификатору(ВыбраннаяСтрока);
		Значение = ТекСтрока[ИмяРеквизитаДляПоказа];
		Если ЗначениеЗаполнено(Значение) Тогда
			ПоказатьЗначение(, Значение);
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

#КонецОбласти
