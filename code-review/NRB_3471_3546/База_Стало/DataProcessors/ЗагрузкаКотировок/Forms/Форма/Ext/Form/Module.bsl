
#Область ОписаниеПеременных

&НаСервере
Перем мТекущийОбъектНаСервере; 	// Реквизит формы "Объект", преобразованный в объект прикладного типа

#КонецОбласти

#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ОбщегоНазначения.ЛогироватьИспользованиеОбъекта(ТекущийОбъект());
	
	ИнициализироватьНаСервере();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура КаталогДанныхНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	НачалоВыбораКаталога();
	
КонецПроцедуры

&НаКлиенте
Процедура ДеньЗагрузкиПриИзменении(Элемент)
	
	ДеньЗагрузкиПриИзмененииНаСервере();
	
КонецПроцедуры

&НаКлиенте
Процедура ПериодЗагрузкиПриИзменении(Элемент)
	
	ПериодЗагрузкиПриИзмененииНаСервере();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура Прочитать(Команда)
	
	Прочитать = Истина;
	Загрузить = Ложь;
	ПрочитатьЗагрузитьНаКлиенте(Прочитать, Загрузить);
	
КонецПроцедуры

&НаКлиенте
Процедура Загрузить(Команда)
	
	Прочитать = Ложь;
	Загрузить = Истина;
	ПрочитатьЗагрузитьНаКлиенте(Прочитать, Загрузить);
	
КонецПроцедуры

&НаКлиенте
Процедура ПрочитатьЗагрузить(Команда)
	
	Прочитать = Истина;
	Загрузить = Истина;
	ПрочитатьЗагрузитьНаКлиенте(Прочитать, Загрузить);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура ПрочитатьЗагрузитьНаКлиенте(Прочитать, Загрузить)
	
	Отказ = Ложь;
	ТекстОтказа = "";
	НовыеРежимыТоргов = Новый Массив;
	
	Если Прочитать Тогда
		Лог = ПрочитатьММВБНаСервере(НовыеРежимыТоргов, Отказ, ТекстОтказа);
	КонецЕсли;
	Если Отказ Или ЗначениеЗаполнено(ТекстОтказа) Тогда
		ОчиститьТаблицуДанных();
		Лог.Показать("Результаты поиска\чтения файлов котировок");
	Иначе
		Если Загрузить Тогда
			Лог = ЗагрузитьММВБНаСервере(НовыеРежимыТоргов, Отказ, ТекстОтказа);
		КонецЕсли;
		Если Загрузить Или ЗначениеЗаполнено(НовыеРежимыТоргов) Тогда
			Лог.Показать("Результаты загрузки котировок");
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ДеньЗагрузкиПриИзмененииНаСервере()
	
	Объект.ПериодЗагрузки = Новый СтандартныйПериод(ДеньЗагрузки, ДеньЗагрузки);
	
	ОчиститьТаблицуДанных();
	
КонецПроцедуры

&НаСервере
Процедура ПериодЗагрузкиПриИзмененииНаСервере()
	
	Если НачалоДня(Объект.ПериодЗагрузки.ДатаНачала) = НачалоДня(Объект.ПериодЗагрузки.ДатаОкончания) Тогда
		ДеньЗагрузки = Объект.ПериодЗагрузки.ДатаНачала;
	Иначе
		ДеньЗагрузки = '00010101';
	КонецЕсли;
	
	ОчиститьТаблицуДанных();
	
КонецПроцедуры

&НаСервере
Процедура ОчиститьТаблицуДанных()
	
	ТекущийОбъект().ТаблицаДанных.Очистить();
	ЗначениеВРеквизитФормы(ТекущийОбъект().ТаблицаДанных, "ТаблицаДанных");
	
КонецПроцедуры

&НаСервере
Процедура ИнициализироватьНаСервере()
	
	ДеньЗагрузки = ОбщегоНазначения.ПредыдущийРабочийДень(ТекущаяДатаСеанса());
	Объект.ПериодЗагрузки = Новый СтандартныйПериод(ДеньЗагрузки, ДеньЗагрузки);
	
	ВнешнийИсточникХранилищеБиржевыхФайловММВБ = ПланыВидовХарактеристик.ВнешниеИсточники.ХранилищеБиржевыхФайловММВБ;
	КаталогДанных = ВнешниеДанные.ПолучитьПараметрыВнешнегоИсточника(ВнешнийИсточникХранилищеБиржевыхФайловММВБ).Папка;
	КаталогДанных = ОбщегоНазначенияКлиентСервер.ДобавитьКонечныйРазделительПути(КаталогДанных);
	Объект.КаталогДанных = РаботаСФайлами.ПолучитьАбсолютныйПуть(КаталогДанных);
	
	ИмяТаблицы	 = "ТаблицаДанных";
	Таблица		 = ТекущийОбъект().ТаблицаДанных;
	РазместитьТаблицуНаФорме(ИмяТаблицы, Таблица);
	
КонецПроцедуры

&НаСервере
Процедура РазместитьТаблицуНаФорме(ИмяТаблицы, Таблица)
	
	Реквизиты = Новый Массив;
	Реквизиты.Добавить(Новый РеквизитФормы(ИмяТаблицы, Новый ОписаниеТипов("ТаблицаЗначений")));
	Для Каждого Колонка Из Таблица.Колонки Цикл
		Реквизиты.Добавить(Новый РеквизитФормы(Колонка.Имя, Колонка.ТипЗначения, ИмяТаблицы));
	КонецЦикла;
	
	ИзменитьРеквизиты(Реквизиты);
	
	ТаблицаДанныхФормы = Элементы.Добавить(ИмяТаблицы, Тип("ТаблицаФормы"));
	ТаблицаДанныхФормы.ПутьКДанным = ИмяТаблицы;
	
	ТаблицаДанныхФормы.ИзменятьСоставСтрок = Ложь;
	ТаблицаДанныхФормы.ИзменятьПорядокСтрок = Ложь;
	ТаблицаДанныхФормы.ПоложениеКоманднойПанели = ПоложениеКоманднойПанелиЭлементаФормы.Верх;
	
	Для Каждого Колонка Из Таблица.Колонки Цикл
		РеквизитТаблицы = Элементы.Добавить("Колонка" + Колонка.Имя, Тип("ПолеФормы"), ТаблицаДанныхФормы);
		РеквизитТаблицы.Вид = ВидПоляФормы.ПолеНадписи;
		РеквизитТаблицы.ПутьКДанным = ИмяТаблицы + "." + Колонка.Имя;
		РеквизитТаблицы.Заголовок = Колонка.Имя;
	КонецЦикла;
	
	ЗначениеВРеквизитФормы(Таблица, ИмяТаблицы);
	
КонецПроцедуры

&НаСервере
Функция ТекущийОбъект()
	
	Если мТекущийОбъектНаСервере = Неопределено Тогда
		мТекущийОбъектНаСервере = РеквизитФормыВЗначение("Объект");
	КонецЕсли;
	
	Возврат мТекущийОбъектНаСервере;
	
КонецФункции

&НаСервере
Функция ПрочитатьММВБНаСервере(НовыеРежимыТоргов, Отказ, ТекстОтказа)
	
	Действие = "ФайлММВБ";
	
	ТабличныйДокумент = ТекущийОбъект().НовыйЛог(Действие);
	
	ТекущийОбъект().ЗагрузитьДанныеВТаблицу(Действие, Объект.ПериодЗагрузки, НовыеРежимыТоргов, Отказ, ТекстОтказа);
	
	ЗначениеВРеквизитФормы(ТекущийОбъект().ТаблицаДанных, "ТаблицаДанных");
	
	Если Отказ Или ЗначениеЗаполнено(ТекстОтказа) Тогда
		ОбластьОшибка = ТекущийОбъект().ОбластьМакета("Ошибка");
		ОбластьОшибка.Параметры.ОписаниеОшибки = ТекстОтказа;
		ТабличныйДокумент.Вывести(ОбластьОшибка);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(НовыеРежимыТоргов) Тогда
		ОбластьШапкаРежимыТоргов = ТекущийОбъект().ОбластьМакета("ШапкаРежимыТоргов");
		ТабличныйДокумент.Вывести(ОбластьШапкаРежимыТоргов);
		ОбластьСтрокаРежимТоргов = ТекущийОбъект().ОбластьМакета("СтрокаРежимТоргов");
		Для Каждого НовыйРежимТоргов Из НовыеРежимыТоргов Цикл
			ОбластьСтрокаРежимТоргов.Параметры.НовыйРежимТорговКод	 = НовыйРежимТоргов.Код;
			ОбластьСтрокаРежимТоргов.Параметры.НовыйРежимТоргов		 = НовыйРежимТоргов.Ссылка;
			ТабличныйДокумент.Вывести(ОбластьСтрокаРежимТоргов);
		КонецЦикла;
	КонецЕсли;
	
	Возврат ТабличныйДокумент;
	
КонецФункции

&НаСервере
Функция ЗагрузитьММВБНаСервере(НовыеРежимыТоргов, Отказ, ТекстОтказа)
	
	Действие = "ФайлММВБ";
	
	ТабличныйДокумент = ТекущийОбъект().НовыйЛог(Действие);
	
	ТекущийОбъект().ТаблицаДанных.Очистить();
	Для Каждого Строка Из ЭтотОбъект.ТаблицаДанных Цикл // BSLLS:RedundantAccessToObject-off
		
		СтрокаТаблицы = ТекущийОбъект().ТаблицаДанных.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаТаблицы, Строка);
		
	КонецЦикла;
	
	ТекущийОбъект().ЗагрузитьКотировкиИзТаблицы(Действие,
		Объект.ПериодЗагрузки, НовыеРежимыТоргов, Отказ, ТекстОтказа, ТабличныйДокумент);
	
	Возврат ТабличныйДокумент;
	
КонецФункции

&НаКлиенте
Процедура НачалоВыбораКаталога()
	
	Диалог = Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.ВыборКаталога);
	Диалог.Заголовок = НСтр("ru = 'Выберите каталог с файлами котировок'");
	Диалог.Каталог = Объект.КаталогДанных;
	Диалог.МножественныйВыбор = Ложь;
	Диалог.Показать(Новый ОписаниеОповещения("ВыбратьКаталогПриОкончанииВыбора", ЭтотОбъект));
	
КонецПроцедуры

&НаКлиенте
Процедура ВыбратьКаталогПриОкончанииВыбора(МассивКаталогов, ОбработчикЗавершения) Экспорт
	
	ПутьККаталогу =
	?(МассивКаталогов = Неопределено Или МассивКаталогов.Количество() = 0,
		"",
		МассивКаталогов[0]);
		
	Если ЗначениеЗаполнено(ПутьККаталогу) Тогда
		КаталогДанных = ОбщегоНазначенияКлиентСервер.ДобавитьКонечныйРазделительПути(ПутьККаталогу);
		КаталогДанных = РаботаСФайлами.ПолучитьАбсолютныйПуть(КаталогДанных);
	КонецЕсли;
	
	Если СтрНачинаетсяС(КаталогДанных, "\\") Тогда
		Объект.КаталогДанных = КаталогДанных;
	Иначе
		ПоказатьПредупреждение(, "Можно выбрать только сетевой каталог!");
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти
