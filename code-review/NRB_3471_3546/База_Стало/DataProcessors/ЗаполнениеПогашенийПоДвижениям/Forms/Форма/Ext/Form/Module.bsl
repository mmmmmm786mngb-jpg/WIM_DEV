
&НаКлиенте
Процедура ЗаполнитьПогашения(Команда)
	ЗаполнитьПогашенияНаСервере();
КонецПроцедуры

Процедура ЗаполнитьПогашенияНаСервере()

	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	ОстаткиЦБ.СчетДепо КАК СчетДепо,
	|	ОстаткиЦБ.СчетДепо.Владелец КАК Депонент,
	|	ОстаткиЦБ.РазделСчетаДепо КАК РазделСчетаДепо,
	|	ОстаткиЦБ.СчетДепоМХ КАК СчетДепоМестаХранения,
	|	ОстаткиЦБ.РазделСчетаДепоМХ КАК РазделСчетаДепоМестаХранения,
	|	ОстаткиЦБ.СтатусЦБ КАК СтатусЦБ,
	|	ОстаткиЦБ.Количество КАК Остаток,
	|	ОстаткиЦБ.Регистратор КАК Регистратор
	|ИЗ
	|	РегистрНакопления.ОстаткиЦБ КАК ОстаткиЦБ
	|ГДЕ
	|	ОстаткиЦБ.Регистратор ССЫЛКА Документ.ПогашениеЦБ
	|ИТОГИ ПО
	|	Регистратор");
	Результат = Запрос.Выполнить();
	Если Результат.Пустой() Тогда
		Возврат;
	КонецЕсли; 
	
	ВыборкаПоРегистратору = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Пока ВыборкаПоРегистратору.Следующий() Цикл
		
		ДокументОбъект = ВыборкаПоРегистратору.Регистратор.ПолучитьОбъект();
		ДокументОбъект.ЦенныеБумаги.Очистить();
		Выборка = ВыборкаПоРегистратору.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		Пока Выборка.Следующий() Цикл
		
			НоваяСтрока = ДокументОбъект.ЦенныеБумаги.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, Выборка);
			
		КонецЦикла;
		
		ДокументОбъект.Записать(РежимЗаписиДокумента.Запись);
		
		ПоручениеОбъект = ДокументОбъект.ДокументОснование.ПолучитьОбъект();
		ПоручениеОбъект.ЦенныеБумагиСписываемые.Очистить();
		Для каждого СтрокаТаблицы Из ДокументОбъект.ЦенныеБумаги Цикл
			
			НоваяСтрока = ПоручениеОбъект.ЦенныеБумагиСписываемые.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТаблицы);
			
			НоваяСтрока.СчетДепоМХ = СтрокаТаблицы.СчетДепоМестаХранения;
			НоваяСтрока.РазделСчетаДепоМХ = СтрокаТаблицы.РазделСчетаДепоМестаХранения;
			НоваяСтрока.Количество = СтрокаТаблицы.Остаток;
			
		КонецЦикла;
		
		ПоручениеОбъект.Записать(РежимЗаписиДокумента.Запись);
		
	КонецЦикла;
	
КонецПроцедуры

