////////////////////////////////////////////////////////////////////////
// СЛУЖЕБНЫЕ ПРОЦЕДУРЫ И ФУНКЦИИ

&НаСервереБезКонтекста
Функция ИмяКаталогаФайловОтветаНРД_API()
	
	Бэк = ВнешниеДанные.ОткрытьСоединениеСВнешнейБазой(ПланыВидовХарактеристик.ВнешниеИсточники.БэкОфис);
	НатройкаОбмена = Бэк.ВнешниеДанные.ПолучитьПараметрыВнешнегоИсточника(Бэк.ПланыВидовХарактеристик.ВнешниеИсточники.КаталогФайловОтветаНРД);
	Если Не ЗначениеЗаполнено(НатройкаОбмена.Папка) Тогда
		Возврат "";
	КонецЕсли;
	
	Возврат НатройкаОбмена.Папка;
	
КонецФункции

&НаСервереБезКонтекста
Функция ИДПлатежа()

	УИН = "";
	Бэк = ВнешниеДанные.ОткрытьСоединениеСВнешнейБазой(ПланыВидовХарактеристик.ВнешниеИсточники.БэкОфис);
		
	ЧислоПопыток = 9999;
	НомерПопытки = 0;
	Пока Истина Цикл
		
		УИН = СлучайныйНомер(8);
		
		Если КодВыпискиУникальный(Бэк, УИН) тогда
			Прервать;
		КонецЕсли;
		
		НомерПопытки = НомерПопытки + 1;
		Если НомерПопытки > ЧислоПопыток тогда
			ВызватьИсключение "Неудача при подборе нового кода файла К";
		КонецЕсли;
			        		
	КонецЦикла;
	
	Возврат УИН;
	
КонецФункции

&НаСервереБезКонтекста
Функция КодВыпискиУникальный(Бэк, Код)
	
	Запрос = Бэк.NewObject("Запрос");
	Запрос.Текст = 
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	0 КАК Поле1
	|ИЗ
	|	РегистрСведений.ОперацииПоВыплатеДохода КАК ОперацииПоВыплатеДохода
	|ГДЕ
	|	ОперацииПоВыплатеДохода.ИДПлатежа = &ИДПлатежа";
	
	Запрос.Установитьпараметр("ИДПлатежа", Код);
	РезультатЗапроса = Запрос.Выполнить();
	
	Возврат РезультатЗапроса.Пустой();
	
КонецФункции

&НаСервере
Процедура ФормированиеВыпискиНРДнаСервере(ПараметрыОперации)

	ОбработкаОбъект = РеквизитФормыВЗначение("Объект");
	ИмяФайла = ОбработкаОбъект.ИмяСформированногоФайлаВыписки(ПараметрыОперации);
	
	Если ЗначениеЗаполнено(ИмяФайла) Тогда
		ТекстСообщения = "Сформирован файл: " + ИмяФайла;
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура СформироватьКПакетНаСервере(ПараметрыПакета)
	
	ВнешнийИсточник = ПланыВидовХарактеристик.ВнешниеИсточники.ФайловыйШлюзКаталогВходящие;
	ПараметрыВнешнегоИсточника = ВнешниеДанные.ПолучитьПараметрыВнешнегоИсточника(ВнешнийИсточник);
	
	Если Не ЗначениеЗаполнено(ПараметрыВнешнегоИсточника) Тогда
		ТекстОшибки = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку("Не заполнены параметры внешнего источника %1", ВнешнийИсточник);
		ОбщегоНазначения.СообщитьОбОшибке(ТекстОшибки);
		Возврат;
	КонецЕсли;
	
	ОбработкаОбъект = РеквизитФормыВЗначение("Объект");
	ИмяФайла = ОбработкаОбъект.ИмяСформированногоФайлаKПакета(ПараметрыПакета);
	
	Если ЗначениеЗаполнено(ИмяФайла) Тогда
		ТекстСообщения = "Сформирован файл: " + ИмяФайла;
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура СформироватьZПакетНаСервере(ПараметрыПакета)
	
	ВнешнийИсточник = ПланыВидовХарактеристик.ВнешниеИсточники.ФайловыйШлюзКаталогВходящие;
	ПараметрыВнешнегоИсточника = ВнешниеДанные.ПолучитьПараметрыВнешнегоИсточника(ВнешнийИсточник);
	
	Если Не ЗначениеЗаполнено(ПараметрыВнешнегоИсточника) Тогда
		ТекстОшибки = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку("Не заполнены параметры внешнего источника %1", ВнешнийИсточник);
		ОбщегоНазначения.СообщитьОбОшибке(ТекстОшибки);
		Возврат;
	КонецЕсли;
		
	ОбработкаОбъект = РеквизитФормыВЗначение("Объект");	
	ИмяФайла = ОбработкаОбъект.ИмяСформированногоАрхиваZПакета(ПараметрыПакета);
	
	Если ЗначениеЗаполнено(ИмяФайла) Тогда
		ТекстСообщения = "Сформирован файл: " + ИмяФайла;
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Функция УстановитьНомерОтчетаНРД()
	
	НомерОтчетаНРД = КодДняМесяца(ДатаОтчетаНРД) + Лев(НомерИсполнения, 1) + Лев(НомерПорученияДепоНаИнвентОперацию, 4);
	
КонецФункции

&НаСервере
Функция НомерФайлаКПакетаУникальный(Код)
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	0 КАК Поле1
	               |ИЗ
	               |	Документ.ВходящийПакетИзФайловогоШлюза КАК ВходящийПакетИзФайловогоШлюза
	               |ГДЕ
	               |	ВходящийПакетИзФайловогоШлюза.ОтносительныйПуть = &ОтносительныйПуть
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	0 КАК Поле1
	               |ИЗ
	               |	Документ.ТехническаяОперация КАК ТехническаяОперация
	               |ГДЕ
	               |	ТехническаяОперация.РегистрационныйНомер = &РегистрационныйНомер";
	
	Запрос.УстановитьПараметр("ОтносительныйПуть", Лев(Код,8));
	Запрос.УстановитьПараметр("РегистрационныйНомер", Сред(Код,2));
	Результат = Запрос.ВыполнитьПакет();
	Возврат Результат[0].Пустой() и Результат[1].Пустой();
	
КонецФункции

&НаСервере
Функция СлучайныйНомерФайлаКПакета()
	
	Преф = "K" + КодДняМесяца();
	ЧислоПопыток = 9999;
	НомерПопытки = 0;
	Пока Истина Цикл
		
		Код = Преф + СлучайныйНомер(6);
		
		Если НомерФайлаКПакетаУникальный(Код) тогда
			Прервать;
		КонецЕсли;
		
		НомерПопытки = НомерПопытки + 1;
		Если НомерПопытки > ЧислоПопыток тогда
			ВызватьИсключение "Неудача при подборе нового кода файла К";
		КонецЕсли;
		
		Код = "";
			        		
	КонецЦикла;
	
	Возврат Код;
	
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция ПрефиксСделки_DNSD_CNSD(ЭтоПокупка)
	Возврат ?(ЭтоПокупка, "DNSD", "CNSD")
КонецФункции

// Возвращает день-месяц в виде строки из трех символов: ДДМ, где М - шестнадцатеричное число
//
// Параметры:
//  Д	 - Дата	 - если Неопределено, то берется текущая дата
// 
// Возвращаемое значение:
//  Строка - трехзначный код дня-месяца
//
&НаКлиентеНаСервереБезКонтекста
Функция КодДняМесяца(Д = Неопределено)
	
	Если Д = Неопределено Тогда
		Д = ТекущаяДата();
	КонецЕсли;
	Возврат Формат(День(Д), "ЧЦ=2; ЧВН=") + Сред("123456789ABC", Месяц(Д), 1);
	
КонецФункции

&НаКлиенте
Процедура ОткрытьПапкуНаПросмотр(Источник, имяПапки = "")
	
	Если ТипЗнч(Источник) = тип("Строка") Тогда
		КорневаяПапка = Источник;
	Иначе
		Настройик = ВнешниеДанные.ПолучитьПараметрыВнешнегоИсточника(Источник);
		КорневаяПапка = Настройик.Папка;
	КонецЕсли;
		
	Если ЗначениеЗаполнено(КорневаяПапка) тогда
		
		Если ЗначениеЗаполнено(имяПапки) тогда
			КорневаяПапка = КорневаяПапка + "/" + имяПапки;
		КонецЕсли;
		
		ЗапуститьПриложение(КорневаяПапка);
		
	КонецЕсли;
	
КонецПроцедуры

&наСервереБезКонтекста
Функция СлучайныйНомер(Длина)
	ГСЧ = Новый ГенераторСлучайныхЧисел();
	СлучайноеЧисло = ГСЧ.СлучайноеЧисло(pow(10, Длина - 1), pow(10, Длина) - 1);
	Возврат Лев(Формат(СлучайноеЧисло, "ЧГ="), Длина);
КонецФункции

&НаКлиенте
Процедура ДатаОтчетаНРДПриИзменении(Элемент)
	ДатаИсполненияВДепозитарииМХ = ДатаОтчетаНРД;
	ДатаИсполненияВМестеРасчетов = ДатаОтчетаНРД;
КонецПроцедуры

&НаСервере
Процедура ТехОперацияПриИзмененииНаСервере()
	
	НомерПоручения = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.ТехОперация, "НомерДокументаОснования");
	Номер = "0";
	Для Н = 1 По СтрДлина(НомерПоручения) Цикл
		Символ = Сред(НомерПоручения, Н, 1);
		Если Найти("0123456789", Символ) > 0 Тогда
			Номер = Номер + Символ;
		Иначе
			Прервать;
		КонецЕсли;
	КонецЦикла;
	НомерПорученияДепоНаИнвентОперацию = Формат(Число(Номер), "ЧЦ=4; ЧВН=; ЧГ=");
	
	НомерИсполнения = "1";
КонецПроцедуры

&НаКлиенте
Процедура ИДПлатежа1НачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	ИДПлатежа = ИДПлатежа();
КонецПроцедуры

&НаКлиенте
Процедура ПодтвердитьПереводДС(Команда)
	Отказ = Ложь;
	
	Если Не ЗначениеЗаполнено(Объект.ТехОперация) Тогда
		ТекстОшибки = "Не выбрана техническая операция";
		ОбщегоНазначения.СообщитьОбОшибке(ТекстОшибки, Отказ);
	КонецЕсли;
		
	Если Отказ Тогда
		Возврат;
	КонецЕсли;
		
	ФормированиеПодтвержлениеОперацииДС();
КонецПроцедуры

&НаСервере
Процедура ФормированиеПодтвержлениеОперацииДС()			
	ПараметрыОперации = Новый Структура("НомерБанковскогоСчета, НомерТранзитногоСчета, Сумма, Валюта",
		НомерБанковскогоСчета, НомерТранзитногоСчета, Сумма, Валюта);
	ПараметрыОперации.Вставить("ИмяФайла", ИмяФайла);
	ПараметрыОперации.Вставить("КаталогФайловОтветаНРД_API", КаталогФайловОтветаНРД_API);
	ПараметрыОперации.Вставить("ИДПлатежа", ИДПлатежа);
	ПараметрыОперации.Вставить("Дата", ДатаОперации);
	
	ОбработкаОбъект = РеквизитФормыВЗначение("Объект");	
	ИмяСформированногоФайла = ОбработкаОбъект.СформироватьПодтвержлениеОперацииДС(ПараметрыОперации);
	
	Если ЗначениеЗаполнено(ИмяСформированногоФайла) Тогда
		ТекстСообщения = "Сформирован файл: " + ИмяСформированногоФайла;
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
	КонецЕсли;
КонецПроцедуры

