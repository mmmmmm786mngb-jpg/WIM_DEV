////////////////////////////////////////////////////////////////////////
// ОБРАБОТЧИКИ КОМАНД

&НаКлиенте
Процедура СформироватьКПакет(Команда)
	
	Если Не ЗначениеЗаполнено(Объект.ТехОперация) Тогда
		ОбщегоНазначения.СообщитьОбОшибке("Не выбрана техническая операция!");
		Возврат;
	КонецЕсли;
	
	ПараметрыПакета = Новый Структура;
	ПараметрыПакета.Вставить("ИмяФайла", ИмяФайлаКПакета);
	ПараметрыПакета.Вставить("reg_no", РегНомерТехОперации);
	ПараметрыПакета.Вставить("reg_date", РегДатаТехОперации);
	
	СформироватьКПакетНаСервере(ПараметрыПакета);
	
КонецПроцедуры

&НаКлиенте
Процедура СформироватьZПакет(Команда)
	
	Если Не ЗначениеЗаполнено(Объект.ТехОперация) Тогда
		ОбщегоНазначения.СообщитьОбОшибке("Выберите техническую операцию!");
		Возврат;
	КонецЕсли;
	
	Если СтрДлина(ИмяКаталогаZПакета) <> 8 Или Лев(ИмяКаталогаZПакета, 1) <> "Z" Тогда
		ОбщегоНазначения.СообщитьОбОшибке("Имя каталога Z-пакета должно состоять из 8 символов в формате:"
			+ " ZDDMNNNN, где NNNN - номер поручения Депо на инвент.операцию");
		Возврат;
	КонецЕсли;
	
	Если СтрДлина(НомерОтчетаНРД) <> 8 Тогда
		ОбщегоНазначения.СообщитьОбОшибке("Номер отчета НРД должен состоять из 8 символов в формате:"
			+ " DDMYNNNN, где Y - номер исполнения, NNNN - номер поручения Депо на инвент.операцию");
		Возврат;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(ДатаОтчетаНРД) Или Не ЗначениеЗаполнено(ДатаИсполненияВДепозитарииМХ)
		Или Не ЗначениеЗаполнено(ДатаИсполненияВМестеРасчетов) Тогда
		ОбщегоНазначения.СообщитьОбОшибке("Заполните все даты.");
		Возврат;
	КонецЕсли;
	
	Если Количество = 0 И isReportFormGS036 = Ложь Тогда
		ОбщегоНазначения.СообщитьОбОшибке("Укажите количество.");
		Возврат;
	КонецЕсли;

	ПараметрыПакета = Новый Структура;
	ПараметрыПакета.Вставить("ИмяКаталога", ИмяКаталогаZПакета);
	ПараметрыПакета.Вставить("НомерОтчетаНРД", НомерОтчетаНРД);
	ПараметрыПакета.Вставить("ДатаОтчетаНРД", ДатаОтчетаНРД);
	ПараметрыПакета.Вставить("ДатаИсполненияВДепозитарииМХ", ДатаИсполненияВДепозитарииМХ);
	ПараметрыПакета.Вставить("ДатаИсполненияВМестеРасчетов", ДатаИсполненияВМестеРасчетов);
	ПараметрыПакета.Вставить("Количество", Количество);
	ПараметрыПакета.Вставить("ПричинаОтмены", ПричинаОтмены);
	ПараметрыПакета.Вставить("ВидБлокировки", ВидБлокировки);
	ПараметрыПакета.Вставить("GS036", isReportFormGS036);
	ПараметрыПакета.Вставить("TextMessageGS036", TextMessageGS036);
	
	СформироватьZПакетНаСервере(ПараметрыПакета);

КонецПроцедуры

&НаКлиенте
Процедура ФормированиеВыпискиНРД(Команда)

	Если Не ЗначениеЗаполнено(Объект.ТехОперация) Тогда
		ОбщегоНазначения.СообщитьОбОшибке("Не выбрана техническая операция!");
		Возврат;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(КаталогФайловОтветаНРД_API) Тогда
		ОбщегоНазначения.СообщитьОбОшибке("Не определен каталог файлов ответа НРД API");
		Возврат;
	КонецЕсли;
	
	ПараметрыОперации = Новый Структура;	
	ПараметрыОперации.Вставить("Дата", ДатаОперации);
	ПараметрыОперации.Вставить("Сумма", Сумма);
	ПараметрыОперации.Вставить("Валюта", Валюта);
	ПараметрыОперации.Вставить("ИмяФайла", ИмяФайла);
	ПараметрыОперации.Вставить("ИДПлатежа", ПрефиксСделки_DNSD_CNSD(НаправлениеСделки) + Формат(ИДПлатежа, "ЧГ"));
	ПараметрыОперации.Вставить("Покупка", НаправлениеСделки);
	ПараметрыОперации.Вставить("КаталогФайловОтветаНРД_API", КаталогФайловОтветаНРД_API);
	
	ФормированиеВыпискиНРДнаСервере(ПараметрыОперации);
	
КонецПроцедуры

