<?xml version="1.0" encoding="windows-1251"?>
<ReportNSD xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns="urn:nsd:std:iso:20022:tech:xsd:rprt.envl.001.01">
	<AppHdr xmlns="urn:iso:std:iso:20022:tech:xsd:head.001.001.01">
		<Fr>
			<OrgId>
				<!-- Соответствует Maker_name(Краткое наименование отправителя отчета) в файле DBF repotrh-->
				<Nm>НКО АО НРД</Nm>
				<Id>
					<OrgId>
						<Othr>
							<!-- Депозитарный код отправителя. Соответствует полю Maker_code (Код отправителя отчета) в файле DBF repotrh-->
							<Id>NDC000000000</Id>
							<Issr>NSDR</Issr>
						</Othr>
					</OrgId>
				</Id>
			</OrgId>
		</Fr>
		<To>
			<OrgId>
				<!--Соответствует полю Reciv_name (Краткое наименование получателя отчета) в файле DBF repotrh-->
				<Nm>ПУБЛИЧНОЕ АКЦИОНЕРНОЕ ОБЩЕСТВО ДНБ КОМПАНИЯ "ДЖИ"</Nm>
				<Id>
					<OrgId>
						<Othr>
							<!-- Депозитарный код получателя. Соответствует полю Reciv_code (Код получателя отчета) в файле DBF repotrh-->
							<Id>MS0189700000</Id>
							<Issr>NSDR</Issr>
						</Othr>
					</OrgId>
				</Id>
			</OrgId>
		</To>
		<!-- Уникальный идентификатор отчета. Соответствует полю Reg_no (Номер отчета) в файле DBF repotrh-->
		<BizMsgIdr>33644235</BizMsgIdr>
		<!-- Идентификатор кода отчета. В поле указывается значение "Тип сообщения ISO 20022 " или идентификатор отчета, присвоенный НРД-->
		<MsgDefIdr>seev.025.001.10</MsgDefIdr>
		<!-- Код печатной формы отчета. Соответствует полю Out_form (Форма) в файле DBF repotrh-->
		<BizSvc>MS036</BizSvc>
		<!-- Дата и время создания отчета, указывается время по UTC (без учета часового пояса).
Соответствует полям: - Reg_date (Дата составления отчета) и Treg_date (Время составления отчета) в файле DBF repotrh -->
		<CreDt>2022-05-01T10:57:00Z</CreDt>
	</AppHdr>
	<Document xmlns="urn:iso:std:iso:20022:tech:xsd:rprt.sese.025.001.10">
		<!--Подтверждение расчетной операции с ценными бумагами-->
		<SctiesSttlmTxConf>
			<!--Детали идентификации транзакции -->
			<TxIdDtls>
				<!--Соответствует полю Repl_to_no (Исх. № поручения) в файле DBF repotrh -->
				<AcctOwnrTxId>87957402</AcctOwnrTxId>
				<!-- Соответствует полю In_reg_no (Рег. № поручения ) в файле DBF repotrh-->
				<AcctSvcrTxId>10828150</AcctSvcrTxId>
				<!--Направление движения ЦБ. Снятие цб.-->
				<SctiesMvmntTp>DELI</SctiesMvmntTp>
				<!--Признак оплаты-->
				<Pmt>FREE</Pmt>
				<!--Референс КД-->
				<CorpActnEvtId>757575X5955</CorpActnEvtId>
			</TxIdDtls>
			<!-- Детали сделки -->
			<TradDtls>
				<TradDt>
					<!--Cоответствует полю Trad_dt (Дата сделки) в файле DBF hbltrans-->
					<Dt>
						<Dt>2022-05-08</Dt>
					</Dt>
				</TradDt>
				<SttlmDt>
					<!--Cоответствует полю Settl_date (Дата расчетов по поручению) в файле DBF hbltrans-->
					<Dt>
						<Dt>2022-05-08</Dt>
					</Dt>
				</SttlmDt>
				<!--Cоответствует полю Oper_date (Фактическая дата расчетов в реестре/депозитарии) в файле DBF hbltrans-->
				<FctvSttlmDt>
					<Dt>
						<Dt>2022-04-29</Dt>
					</Dt>
				</FctvSttlmDt>
			</TradDtls>
			<!--Определение финансового инструмента-->
			<FinInstrmId>
				<OthrId>
					<!-- Cоответствует полю Security_c (Депозитарный код ценной бумаги в кодировке НРД) в файле DBF tranblsc -->
					<Id>RU000A103513</Id>
					<!--Тип идентификатора-->
					<Tp>
						<!--Собственный код -->
						<Prtry>NSDR</Prtry>
					</Tp>
				</OthrId>
				<OthrId>
					<!--Cоответствует полю Sec_reg_nu (Регистрационный код код ценной бумаги) в файле DBF tranblsc-->
					<Id>t5a-108</Id>
					<!--Тип идентификатора-->
					<Tp>
						<!--Собственный код. -->
						<Prtry>OTHR</Prtry>
					</Tp>
				</OthrId>
				<!--Cоответствует полю Sec_shortn (Краткое наименование ценной бумаги) в файле DBF tranblsc-->
				<Desc>ак-НД108</Desc>
			</FinInstrmId>
			<!--Информация о счете и количестве-->
			<QtyAndAcctDtls>
				<!--Количество финансового инструмента, по которому проведены расчеты-->
				<SttldQty>
					<Qty>
						<!--Cоответствует полю Seq_amo (Количество ценных бумаг) в файле DBF tranblsc. В случае, если значение количества цб превышает 17 символов, указывается константа : "-00.00"  и  заполняется поле в расширении *Envlp/XtnsnDt/XtnsnMS036/FinInstrmId/RprtdSttlmQty-->
						<Unit>100</Unit>
					</Qty>
				</SttldQty>
				<!--Счет депо-->
				<SfkpgAcct>
					<!--Cоответствует полю Facc_code/KRZD/Fsec_code в файле DBF hbltrans-->
					<Id>MS1909270015/KRZD/83000000000000000</Id>
				</SfkpgAcct>
			</QtyAndAcctDtls>
			<!--Параметры расчетов-->
			<SttlmParams>
				<SctiesTxTp>
					<!--Тип операции с ценными бумагами-->
					<Cd>TRAD</Cd>
				</SctiesTxTp>
			</SttlmParams>
			<!--Поставщик-->
			<DlvrgSttlmPties>
				<!--Владелец счета депо списания-->
				<Pty1>
					<Id>
						<NmAndAdr>
							<!-- Cоответствует полю Fdepon_nam (Полное наименование владельца счета депо) в файле DBF hbltrans.-->
							<Nm>ПУБЛИЧНОЕ АКЦИОНЕРНОЕ ОБЩЕСТВО ДНБ КОМПАНИЯ "ДЖИ"</Nm>
						</NmAndAdr>
					</Id>
				</Pty1>
			</DlvrgSttlmPties>
			<!--Получатель-->
			<RcvgSttlmPties>
				<!--Кастодиан-->
				<Dpstry>
					<Id>
						<NmAndAdr>
							<!-- Cоответствует полю Reestr_nam (Наименование Регистратора/ Депозитария (места расчетов)) в файле DBF hbltrans.-->
							<Nm>АКЦИОНЕРНОЕ ОБЩЕСТВО "ЭЙЧБИСИ "РЕГИОНАЛЬНЫЙ ТРАНСПОРТНЫЙ ДЕЛЬТАКРЕДИТ"</Nm>
						</NmAndAdr>
					</Id>
				</Dpstry>
				<Pty1>
					<Id>
						<NmAndAdr>
							<!-- Cоответствует полю Fdepon_nam (Полное наименование владельца счета депо) в файле DBF hbltrans.-->
							<Nm>ПУБЛИЧНОЕ АКЦИОНЕРНОЕ ОБЩЕСТВО "АОЗТ ИНФОРМАТИКИ БАНК"</Nm>
