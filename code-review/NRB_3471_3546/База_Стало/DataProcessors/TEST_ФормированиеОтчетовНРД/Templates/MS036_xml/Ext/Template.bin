						<IdTp>
							<Prtry>
								<Id>CLID</Id>
								<Issr>NSDR</Issr>
							</Prtry>
						</IdTp>
						<Ctry>XX</Ctry>
						<!-- Cоответствует полю Sender_cod (Идентификатор получателя) в файле DBF hbltrans.-->
