								<Nm>Небанковская кредитная организация акционерное общество «Национальный расчетный депозитарий»</Nm>
							</RptSndr>
							<!--Получатель отчета-->
							<RptRcvr>
								<!--Полное наименование получателя отчета. -->
								<Nm>ПУБЛИЧНОЕ АКЦИОНЕРНОЕ ОБЩЕСТВО ДНБ КОМПАНИЯ "ДЖИ"</Nm>
								<!--Cоответствует полю Name_add (Доп. наименование к наименованию получателя отчета.) в файле DBF hbltrans-->
								<AddNm>Доп. наименование к наименованию получателя отчета</AddNm>
							</RptRcvr>
						</SvcInf>
						<TxPrcrDtls>
							<TxId>
								<!--Cоответствует полю Repl_to_no (Исх. № поручения.) в файле DBF repotrh-->
								<AcctOwnrTxId>87957402</AcctOwnrTxId>
								<!-- Соответствует полю In_reg_no (Рег. № поручения ) в файле DBF repotrh-->
								<AcctSvcrTxId>10825835</AcctSvcrTxId>
							</TxId>
							<!--Даты-->
							<TxDt>
								<!--Cоответствует полю Repl_to_da (Дата составления поручения) в файле DBF repotrh-->
								<InstrCreDt>
									<Dt>2022-01-26</Dt>
								</InstrCreDt>
								<!--Дата регистрации поручения-->
								<RegnDtTm>
									<Dt>2022-04-27T09:30:47Z</Dt>
								</RegnDtTm>
							</TxDt>
							<!--Инициатор поручения -->
							<Orgtr>
								<!--Cоответствует полю Person_nam (Полное наименование инициатора поручения) в файле DBF repotrh-->
								<Nm>ПУБЛИЧНОЕ АКЦИОНЕРНОЕ ОБЩЕСТВО ДНБ КОМПАНИЯ "ДЖИ"</Nm>
								<Id>
									<OrgId>
										<Othr>
											<!--Cоответствует полю Person_cod (Код инициатора поручения) в файле DBF repotrh-->
											<Id>MS0189700000</Id>
											<!--Организация, присвоившая код. Нет соответствий с DBF.-->
											<Issr>NSDR</Issr>
										</Othr>
									</OrgId>
								</Id>
							</Orgtr>
							<PrcrTxDtls>
								<!--Cоответствует полю Ord_type_i (Код операции, по которой формируется отчет) в файле DBF repotrh-->
								<PrcrTxCd>68/CAIR</PrcrTxCd>
								<!--Cоответствует полю Ord_type_n (Наименование операции, по которой формируется отчет) в файле DBF repotrh-->
								<PrcrTxNm>Участие в КД. BIDS/TEND</PrcrTxNm>
								<!--Cоответствует полям Reg_date и Treg_date  (Дата и время исполнения операции) в файле DBF repotrh-->
								<ExctnDtTm>
									<Dt>2022-05-02T09:30:47Z</Dt>
								</ExctnDtTm>
								<!--Cоответствует полю Opday_exe (Дата операционного дня исполнения операции) в файле DBF repotrh-->
								<OprExctnDt>
									<Dt>2022-05-02</Dt>
								</OprExctnDt>
							</PrcrTxDtls>
						</TxPrcrDtls>
						<CorpActnGnlInf>
							<EvtTp>
								<!--Код типа КД -->
								<Cd>TEND</Cd>
							</EvtTp>
						</CorpActnGnlInf>
						<!--Расширение для отчета MS036-->
						<XtnsnMS036>
							<!--Поставщик-->
							<DlvrgSttlmPties>
								<!--Cоответствует полю Name_add (Дополнение к наименованию анкеты счета списания) в файле DBF  hbltrans-->
								<AddNm>Дополнение к наименованию анкеты счета списания</AddNm>
								<!--Cоответствует полю Fsec_id (Идентификатор раздела (списание)) в файле DBF  hbltrans-->
								<SctnId>13052323</SctnId>
								<!--Cоответствует полю Fsec_name (Наименование раздела счета депо (списание)) в файле DBF  hbltrans-->
								<SctnTpNm>Блокировано для корпоративных действий</SctnTpNm>
							</DlvrgSttlmPties>
							<!--Сторона зачисление цб-->
							<RcvgSttlmPties>
								<!--Cоответствует полю Name_add_c (Дополнение к наименованию анкеты счета зачисления) в файле DBF  htrans-->
								<AddNm>Дополнение к наименованию анкеты счета зачисления</AddNm>
								<!--Cоответствует полю Tsec_id (Идентификатор раздела счета депо (зачисление)) в файле DBF  htrans-->
								<SctnId>11232145</SctnId>
								<!--Cоответствует полю Tsec_name (Наименование раздела счета депо (зачисление)) в файле DBF  htrans-->
								<SctnTpNm>Выкуплено</SctnTpNm>
								<Pty1>
									<SfkpgAcct>
										<!--Cоответствует полю Acc_type (Тип счёта получателя) в файле DBF  hbltrans-->
										<Tp>06</Tp>
										<!--Cоответствует полю Acc_type_n (Наименование типа счета получателя) в файле DBF  hbltrans-->
										<TpNm>Казначейский счет эмитента (лица, обязанного по ценным бумагам)</TpNm>
									</SfkpgAcct>
								</Pty1>
							</RcvgSttlmPties>
							<CntrctOrAnBsDcID>
								<!--Основание-->
								<BsDc>
									<!--Cоответствует полю Doc_name (Наименование вида договора / иного основания) в файле DBF trbldocs -->
									<BsDcNm>Выписка из утвержденного советом директоров (наблюдательным советом) общества отчета об итогах предъявления требований акционеров о выкупе акций</BsDcNm>
									<!-- Cоответствует полю Doc_num (Номер документа) в файле DBF trbldocs-->
									<BsDcNum>87957553</BsDcNum>
									<!---->
									<!-- Cоответствует полю Doc_date (Дата документа) в файле DBF trbldocs -->
									<BsDcDt>2022-02-22</BsDcDt>
								</BsDc>
							</CntrctOrAnBsDcID>
							<!--Дополнентельный документ-основание-->
							<CntrctOrAnBsDcID>
								<!--Основание-->
								<!--Cоответствует полю Partad_cod (Код вида договора/иного основания) в файле DBF  trbldocs-->
								<DcTpCd>OTHR</DcTpCd>
								<!--Cоответствует полю Ndc_code (Код типа документа НРД) в файле DBF trbldocs-->
								<DcTpCdNSD>Ndc_code</DcTpCdNSD>
								<BsDc>
									<!--Cоответствует полю Doc_name (Наименование вида договора / иного основания) в файле DBF trbldocs -->
									<BsDcNm>Выписка из утвержденного советом директоров (наблюдательным советом) общества отчета об итогах предъявления требований акционеров о выкупе акций</BsDcNm>
									<!-- Cоответствует полю Doc_num (Номер документа) в файле DBF trbldocs -->
									<BsDcNum>87957553</BsDcNum>
									<!---->
									<!-- Cоответствует полю Doc_date (Дата документа) в файле DBF trbldocs -->
									<BsDcDt>2022-02-22</BsDcDt>
								</BsDc>
							</CntrctOrAnBsDcID>
							<!--Предварительная блокировка раздела счета депо/-->
							<PrBlckSc>
								<!--Cоответствует полю Tloro_sec (Раздела счета депо) в файле DBF  hbltrans-->
								<ScTpPrBlck>83000000000000000</ScTpPrBlck>
								<!--Cоответствует полю tlsec_name  (Наименование типа раздела счета депо) в файле DBF  hbltrans-->
								<SctnTpNmPrBlck>Блокировано для корпоративных действий</SctnTpNmPrBlck>
								<!--Cоответствует полю Tsec_id (Идентификатор раздела счета депо) в файле DBF  hbltrans-->
								<SctnIdPrBlck>Tsec_id</SctnIdPrBlck>
							</PrBlckSc>
							<!--Дополнительная  информация-->
							<Addinf>
								<!--Cоответствует полю p_code (Код параметра) в файле DBF  addinfo-->
								<PrmtrCd>возможное значение p_code</PrmtrCd>
								<!--Cоответствует полю p_name (Наименование параметра) в файле DBF  addinfo-->
								<PrmtrNm>возможное значение p_name </PrmtrNm>
								<!--Cоответствует полю p_value (Значение параметра) в файле DBF  addinfo-->
								<PrmtrVl>возможное значение p_value</PrmtrVl>
							</Addinf>
							<!-- Идентификация Регистратора/Депозитария (места расчетов)-->
							<DpstryId>
								<!-- Cоответствует полю REESTR_COD (Код Регистратора/Депозитария (места расчетов)) в файле DBF  hbltrans-->
								<Cd>RSTINOL</Cd>
							</DpstryId>
							<!--Информация об Инструкции-->
							<InstrInfo>
