					</SfkpgAcct>
				</Pty1>
			</RcvgSttlmPties>
			<SplmtryData>
				<!--Расширение для sese.025.001.10: Подтверждение расчетной операции с ценными бумагами-->
				<Envlp xmlns="urn:nsd:std:iso:20022:tech:xsd:xtns.sese.025.001.10">
					<!--НРД: Корневой элемент для расширения-->
