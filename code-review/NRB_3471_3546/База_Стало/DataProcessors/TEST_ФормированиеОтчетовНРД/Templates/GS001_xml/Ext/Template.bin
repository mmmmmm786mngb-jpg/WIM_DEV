<?xml version="1.0" encoding="windows-1251"?>
<ReportNSD xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns="urn:nsd:std:iso:20022:tech:xsd:rprt.envl.001.01" >
	<AppHdr xmlns="urn:iso:std:iso:20022:tech:xsd:head.001.001.01">
		<Fr>
			<OrgId>
				<Nm>Краткое наименование отправителя отчета</Nm>
				<!-- Соответствует Maker_full_name (Наименование отправителя отчета) в файле DBF repotrh.-->
				<Id>
					<OrgId>
						<Othr>
							<Id>NDC000000000</Id>
							<Issr>NSDR</Issr>
							<!-- Депозитарный код отправителя. Соответствует полю Maker_code (Код отправителя отчета) в файле DBF repotrh.-->
						</Othr>
					</OrgId>
				</Id>
			</OrgId>
		</Fr>
		<To>
			<OrgId>
				<Nm>Краткое наименование получателя отчета</Nm>
				<!--Соответствует полю Reciv_full_name (Наименование получателя отчета) в файле DBF repotrh.-->
				<Id>
					<OrgId>
						<Othr>
							<Id>MC0000000000</Id>
							<Issr>NSDR</Issr>
							<!-- Депозитарный код получателя. Соответствует полю Reciv_code (Код получателя отчета) в файле DBF repotrh.-->
						</Othr>
					</OrgId>
				</Id>
			</OrgId>
		</To>
		<BizMsgIdr>99187531B</BizMsgIdr>
		<!-- Уникальный идентификатор отчета. Соответствует полю Reg_no (Номер отчета) в файле DBF repotrh.-->
		<MsgDefIdr>sese.024.001.10</MsgDefIdr>
		<!-- Идентификатор кода отчета. В поле указывается значение "Тип сообщения ISO 20022 " или идентификатор отчета, присвоенный НРД-->
		<BizSvc>GS001</BizSvc>
		<!-- Код печатной формы отчета. Соответствует полю Out_form (Форма) в файле DBF repotrh-->
		<CreDt>2020-10-12T10:57:00Z</CreDt>
		<!-- Дата и время создания отчета, указывается время по UTC (без учета часового пояса).
Соответствует полям: - Reg_date (Дата составления отчета) и Treg_date (Время составления отчета) в файле DBF repotrh -->
	</AppHdr>
	<Document xmlns="urn:iso:std:iso:20022:tech:xsd:rprt.sese.024.001.10">
		<SctiesSttlmTxStsAdvc>
			<TxId>
				<AcctOwnrTxId>56565656</AcctOwnrTxId>
				<!--Номер поручения по которому сформирован отказ присвоенный отправителем-->
			</TxId>
			<PrcgSts>
				<Rjctd>
					<Rsn>
						<Cd>
							<Prtry>
								<Id>DSEC</Id>
								<!--Код причины отказа №1-->
								<Issr>DEPCODEREGIS</Issr>
								<!--Деп код организации указавшей причину отказа, в случае отказа от НРД указывается константа NSDR-->
							</Prtry>
						</Cd>
						<AddtlRsnInf>Причина отказа №1</AddtlRsnInf>
						<!--Описание причины отказа указывается в этом поле если размер не превышает 210 символов, иначе поле не заполняется, а причина отказа 
указывается в блоке SplmtryData, в теге */SplmtryData/Envlp/XtnsnDt/XtnsnGS001/RjctdRsn/RsnInf-->
					</Rsn>
				</Rjctd>
			</PrcgSts>
			<SplmtryData>
				<!--Повторение блока SplmtryData содержащее данные о причине отказа №2-->
				<PlcAndNm>/Document/SctiesSttlmTxStsAdvc/PrcgSts/Rjctd/Rsn[2]</PlcAndNm>
				<!--Ссылка на второе повторение блока Rsn для связи с данными в SplmtryData-->
				<Envlp xmlns="urn:nsd:std:iso:20022:tech:xsd:xtns.sese.024.001.10">
					<XtnsnDt>
						<XtnsnGS001>
							<RjctdRsn>
								<RsnInf>Причина отказа размер которой больше 210 символов полностью указывается в этом поле</RsnInf>
								<RsnPty>
									<Nm>Акционерное общество "Регистратор"</Nm>
									<!--Полное наименование организации указавшей причину отказа-->
								</RsnPty>
							</RjctdRsn>
						</XtnsnGS001>
					</XtnsnDt>
				</Envlp>
			</SplmtryData>
			<SplmtryData>
				<Envlp xmlns="urn:nsd:std:iso:20022:tech:xsd:xtns.sese.024.001.10">
					<XtnsnDt>
						<XtnsnGS001>
							<AddtlInf>
								<RcmdAct>Рекомендуемые действия 1</RcmdAct>
								<RcmdAct>Рекомендуемые действия 2</RcmdAct>
								<RqrmtLaw>Первая ссылка на норму законодательства</RqrmtLaw>
								<RqrmtLaw>Вторая ссылка на норму законодательства</RqrmtLaw>
							</AddtlInf>
						</XtnsnGS001>
					</XtnsnDt>
				</Envlp>
			</SplmtryData>
			<SplmtryData>
				<!--Повторение блока SplmtryData содержащее данные "Report.dbf"-->
				<Envlp xmlns="urn:nsd:std:iso:20022:tech:xsd:xtns.sese.024.001.10">
					<XtnsnDt>
						<SvcInf>
							<Lang>RUS</Lang>
							<!--Версия печатной формы -->
							<PrntFrmVrsn>1</PrntFrmVrsn>
							<RptSndr>
								<Nm>Полное наименование отправителя отчета</Nm>
							</RptSndr>
							<RptRcvr>
								<Nm>Полное наименование получателя отчета</Nm>
							</RptRcvr>
						</SvcInf>
						<TxPrcrDtls>
							<TxId>
								<AcctOwnrTxId>56565656</AcctOwnrTxId>
								<!--Исх. № поручения, номер поручения присвоеный отправителем-->
								<AcctSvcrTxId>8804674</AcctSvcrTxId>
								<!--Рег. № поручения присвоеный НРД-->
							</TxId>
							<TxDt>
								<InstrCreDt>
									<Dt>2020-10-12</Dt>
									<!--Дата составления поручения-->
								</InstrCreDt>
								<RegnDtTm>
									<Dt>2020-10-12T09:30:47</Dt>
									<!--Дата регистрации поручения-->
								</RegnDtTm>
								<AccptdExctnDtTm>
									<Dt>2020-10-12T09:30:47</Dt>
									<!--Дата принятия поручения на исполнение-->
								</AccptdExctnDtTm>
							</TxDt>
							<Orgtr>
								<Nm>Полное наименование инициатора поручения</Nm>
								<Id>
									<OrgId>
										<Othr>
											<Id>MC0000055555</Id>
											<Issr>NSDR</Issr>
											<!--Депозитарный код инициатора-->
										</Othr>
									</OrgId>
								</Id>
							</Orgtr>
							<PrcrTxDtls>
								<PrcrTxCd>16</PrcrTxCd>
								<!--Код операции, по которой формируется отчет-->
								<PrcrTxNm>Наименование операции, по которой формируется отчет</PrcrTxNm>
								<ExctnDtTm>
									<Dt>2020-10-12T09:30:47</Dt>
									<!--Дата отказа-->
								</ExctnDtTm>
								<OprExctnDt>
									<Dt>2020-10-12</Dt>
									<!--Дата операционного дня отказа-->
								</OprExctnDt>
							</PrcrTxDtls>
						</TxPrcrDtls>
					</XtnsnDt>
				</Envlp>
			</SplmtryData>
		</SctiesSttlmTxStsAdvc>
	</Document>
</ReportNSD>
