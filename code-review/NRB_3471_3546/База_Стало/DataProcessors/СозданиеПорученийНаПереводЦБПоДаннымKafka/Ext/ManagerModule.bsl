
#Область ПрограммныйИнтерфейс

// Процедура исполняет поручения на перевод ЦБ за предыдущий день
//
Процедура ИсполнитьПорученияНаПереводЦБЗаПредыдущийДень() Экспорт
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	
	КонецПредыдущегоДня = НачалоДня(ТекущаяДатаСеанса()) - 1;
	Запрос.УстановитьПараметр("ВидИнициатораБрокер", 1);
	Запрос.УстановитьПараметр("КонецПредыдущегоДня", КонецПредыдущегоДня);
	Запрос.УстановитьПараметр("КонецПредыдущегоДняГраница", Новый Граница(КонецПредыдущегоДня));
	Запрос.УстановитьПараметр("НачалоПредыдущегоДня", НачалоДня(КонецПредыдущегоДня));
	
	Запрос.Текст = ТекстЗапросаДанныеПоПоручениям();
	
	НачатьТранзакцию();
	Попытка
		РезультатЗапроса = Запрос.Выполнить();
		
		Блокировка = Новый БлокировкаДанных;
		ЭлементБлокировки = Блокировка.Добавить("РегистрНакопления.ОстаткиЦБ");
		ЭлементБлокировки.Режим = РежимБлокировкиДанных.Исключительный;
		ЭлементБлокировки.ИсточникДанных = РезультатЗапроса;
		ЭлементБлокировки.ИспользоватьИзИсточникаДанных("СчетДепо", "СчетДепо");
		ЭлементБлокировки.ИспользоватьИзИсточникаДанных("РазделСчетаДепо", "РазделСчетаДепо");
		ЭлементБлокировки.ИспользоватьИзИсточникаДанных("ЦБ", "ЦБ");
		ЭлементБлокировки.ИспользоватьИзИсточникаДанных("СчетДепоМХ", "СчетДепоМХ");
		ЭлементБлокировки.ИспользоватьИзИсточникаДанных("РазделСчетаДепоМХ", "РазделСчетаДепоМХ");
		Блокировка.Заблокировать();
		
		Запрос.Текст = ТекстЗапросаОстаткиЦБ();
		Выборка = Запрос.Выполнить().Выбрать();
		
		Пока Выборка.Следующий() Цикл
			
			Если Выборка.КоличествоЦБ > Выборка.КоличествоОстаток Тогда
				ОтправитьУведомлениеОНедостаточномОстаткеДляПереводаЦБ(Выборка);
			Иначе
				ДатаИсполнения = НачалоДня(ТекущаяДатаСеанса()) - ОбщегоНазначенияПовтИсп.СекундВСутках();
				
				ОперацияЦБОбъект = Выборка.ОперацияЦБ.ПолучитьОбъект();
				ОперацияЦБОбъект.Дата = КонецДня(ДатаИсполнения);
				ОперацияЦБОбъект.ДатаИсполненияВДепозитарииМХ = ДатаИсполнения;
				ОперацияЦБОбъект.ДатаИсполненияВМестеРасчетов = ДатаИсполнения;
				ОперацияЦБОбъект.Записать(РежимЗаписиДокумента.Проведение);
			КонецЕсли;
			
		КонецЦикла;
		
		ЗафиксироватьТранзакцию();
	Исключение
		ОтменитьТранзакцию();
		ТекстОшибки = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстОшибки);
		ЗаписьЖурналаРегистрации("ИсполнениеПорученийНаПереводЦБ", УровеньЖурналаРегистрации.Ошибка, , , ТекстОшибки);
	КонецПопытки;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ТекстЗапросаДанныеПоПоручениям()
	
	Возврат
	"ВЫБРАТЬ
	|	ДокументПоручение.Ссылка КАК Поручение,
	|	ДокументПоручение.ТипПеревода КАК ТипПеревода,
	|	ДокументПоручение.СчетДепо КАК СчетДепо,
	|	ДокументПоручение.РазделСчетаДепо КАК РазделСчетаДепо,
	|	ДокументПоручение.ЦБ КАК ЦБ,
	|	ДокументПоручение.СчетДепоМХ КАК СчетДепоМХ,
	|	ДокументПоручение.РазделСчетаДепоМХ КАК РазделСчетаДепоМХ,
	|	ДокументПоручение.КоличествоЦБ КАК КоличествоЦБ
	|ПОМЕСТИТЬ Поручения
	|ИЗ
	|	Документ.Поручение КАК ДокументПоручение
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Константа.ОрганизацияПоУмолчанию КАК ОрганизацияПоУмолчанию
	|		ПО ДокументПоручение.Инициатор = ОрганизацияПоУмолчанию.Значение
	|ГДЕ
	|	ДокументПоручение.ВидОперацииД = ЗНАЧЕНИЕ(Справочник.ВидыОпераций.Перевод)
	|	И ДокументПоручение.ТипПеревода В (ЗНАЧЕНИЕ(Перечисление.ТипыПереводов.Списание), ЗНАЧЕНИЕ(Перечисление.ТипыПереводов.Зачисление))
	|	И ДокументПоручение.ВидИнициатора = &ВидИнициатораБрокер
	|	И ДокументПоручение.ПланируемаяДатаРасчетов МЕЖДУ &НачалоПредыдущегоДня И &КонецПредыдущегоДня
	|	И ДокументПоручение.СчетДепоМХ = ДокументПоручение.СчетДепоМХКонтрагента
	|	И ДокументПоручение.РазделСчетаДепоМХ = ДокументПоручение.РазделСчетаДепоМХКонтрагента
	|	И ДокументПоручение.НомерПорученияВБО ПОДОБНО ""OTC_%""
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СтатусыПорученийСрезПоследних.Поручение КАК Поручение,
	|	СтатусыПорученийСрезПоследних.СтатусПоручения КАК СтатусПоручения
	|ПОМЕСТИТЬ СтатусыПоручений
	|ИЗ
	|	РегистрСведений.СтатусыПоручений.СрезПоследних(
	|			&КонецПредыдущегоДняГраница,
	|			Поручение В
	|				(ВЫБРАТЬ
	|					Поручения.Поручение КАК Поручение
	|				ИЗ
	|					Поручения КАК Поручения)) КАК СтатусыПорученийСрезПоследних
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Поручения.Поручение КАК Поручение,
	|	Поручения.ТипПеревода КАК ТипПеревода
	|ПОМЕСТИТЬ ПорученияВСтатусеОбрабатывается
	|ИЗ
	|	Поручения КАК Поручения
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ СтатусыПоручений КАК СтатусыПоручений
	|		ПО (СтатусыПоручений.Поручение = Поручения.Поручение)
	|			И (СтатусыПоручений.СтатусПоручения = ЗНАЧЕНИЕ(Перечисление.СтатусыПоручений.Обрабатывается))
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ОперацииЦБ.Ссылка КАК ОперацияЦБ,
	|	МАКСИМУМ(ВЫБОР
	|			КОГДА ПорученияВСтатусеОбрабатывается.ТипПеревода = ЗНАЧЕНИЕ(Перечисление.ТипыПереводов.Списание)
	|				ТОГДА ПорученияВСтатусеОбрабатывается.Поручение
	|		КОНЕЦ) КАК ПоручениеСписание,
	|	МАКСИМУМ(ВЫБОР
	|			КОГДА ПорученияВСтатусеОбрабатывается.ТипПеревода = ЗНАЧЕНИЕ(Перечисление.ТипыПереводов.Зачисление)
	|				ТОГДА ПорученияВСтатусеОбрабатывается.Поручение
	|		КОНЕЦ) КАК ПоручениеЗачисление
	|ПОМЕСТИТЬ ОперацияИПоручения
	|ИЗ
	|	ПорученияВСтатусеОбрабатывается КАК ПорученияВСтатусеОбрабатывается
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ОперацииЦБ КАК ОперацииЦБ
	|		ПО (ВЫБОР
	|				КОГДА ПорученияВСтатусеОбрабатывается.Поручение = ОперацииЦБ.ДокументОснование
	|					ТОГДА ИСТИНА
	|				КОГДА ПорученияВСтатусеОбрабатывается.Поручение = ОперацииЦБ.ДокументОснованиеВстречный
	|					ТОГДА ИСТИНА
	|				ИНАЧЕ ЛОЖЬ
	|			КОНЕЦ)
	|
	|СГРУППИРОВАТЬ ПО
	|	ОперацииЦБ.Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ОперацияИПоручения.ОперацияЦБ КАК ОперацияЦБ,
	|	ОперацияИПоручения.ПоручениеСписание КАК ПоручениеСписание,
	|	ОперацияИПоручения.ПоручениеЗачисление КАК ПоручениеЗачисление,
	|	Поручения.КоличествоЦБ КАК КоличествоЦБ,
	|	Поручения.СчетДепо КАК СчетДепо,
	|	Поручения.РазделСчетаДепо КАК РазделСчетаДепо,
	|	Поручения.ЦБ КАК ЦБ,
	|	Поручения.СчетДепоМХ КАК СчетДепоМХ,
	|	Поручения.РазделСчетаДепоМХ КАК РазделСчетаДепоМХ
	|ПОМЕСТИТЬ ИтоговыеДанные
	|ИЗ
	|	ОперацияИПоручения КАК ОперацияИПоручения
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Поручения КАК Поручения
	|		ПО ОперацияИПоручения.ПоручениеСписание = Поручения.Поручение
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ИтоговыеДанные.СчетДепо КАК СчетДепо,
	|	ИтоговыеДанные.РазделСчетаДепо КАК РазделСчетаДепо,
	|	ИтоговыеДанные.ЦБ КАК ЦБ,
	|	ИтоговыеДанные.СчетДепоМХ КАК СчетДепоМХ,
	|	ИтоговыеДанные.РазделСчетаДепоМХ КАК РазделСчетаДепоМХ
	|ИЗ
	|	ИтоговыеДанные КАК ИтоговыеДанные";
	
КонецФункции

Функция ТекстЗапросаОстаткиЦБ()
	
	Возврат
	"ВЫБРАТЬ
	|	ОстаткиЦБОстатки.СчетДепо КАК СчетДепо,
	|	ОстаткиЦБОстатки.РазделСчетаДепо КАК РазделСчетаДепо,
	|	ОстаткиЦБОстатки.ЦБ КАК ЦБ,
	|	ОстаткиЦБОстатки.СчетДепоМХ КАК СчетДепоМХ,
	|	ОстаткиЦБОстатки.РазделСчетаДепоМХ КАК РазделСчетаДепоМХ,
	|	ОстаткиЦБОстатки.КоличествоОстаток КАК КоличествоОстаток
	|ПОМЕСТИТЬ ОстаткиЦБ
	|ИЗ
	|	РегистрНакопления.ОстаткиЦБ.Остатки(
	|			&КонецПредыдущегоДняГраница,
	|			(СчетДепо, РазделСчетаДепо, ЦБ, СчетДепоМХ, РазделСчетаДепоМХ) В
	|				(ВЫБРАТЬ
	|					ИтоговыеДанные.СчетДепо КАК СчетДепо,
	|					ИтоговыеДанные.РазделСчетаДепо КАК РазделСчетаДепо,
	|					ИтоговыеДанные.ЦБ КАК ЦБ,
	|					ИтоговыеДанные.СчетДепоМХ КАК СчетДепоМХ,
	|					ИтоговыеДанные.РазделСчетаДепоМХ КАК РазделСчетаДепоМХ
	|				ИЗ
	|					ИтоговыеДанные КАК ИтоговыеДанные)) КАК ОстаткиЦБОстатки
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ИтоговыеДанные.ОперацияЦБ КАК ОперацияЦБ,
	|	ИтоговыеДанные.КоличествоЦБ КАК КоличествоЦБ,
	|	ИтоговыеДанные.ЦБ.ISIN КАК ISIN,
	|	ИтоговыеДанные.ПоручениеСписание КАК ПоручениеСписание,
	|	ПРЕДСТАВЛЕНИЕССЫЛКИ(ИтоговыеДанные.СчетДепо) КАК СчетДепо,
	|	ЕСТЬNULL(ОстаткиЦБ.КоличествоОстаток, 0) КАК КоличествоОстаток
	|ИЗ
	|	ИтоговыеДанные КАК ИтоговыеДанные
	|		ЛЕВОЕ СОЕДИНЕНИЕ ОстаткиЦБ КАК ОстаткиЦБ
	|		ПО ИтоговыеДанные.СчетДепо = ОстаткиЦБ.СчетДепо
	|			И ИтоговыеДанные.РазделСчетаДепо = ОстаткиЦБ.РазделСчетаДепо
	|			И ИтоговыеДанные.ЦБ = ОстаткиЦБ.ЦБ
	|			И ИтоговыеДанные.СчетДепоМХ = ОстаткиЦБ.СчетДепоМХ
	|			И ИтоговыеДанные.РазделСчетаДепоМХ = ОстаткиЦБ.РазделСчетаДепоМХ";
	
КонецФункции

// Процедура отправляет уведомление о недостаточном остатке для перевода ЦБ
//
// Параметры:
//  ПараметрыСообщения - Строка - Параметры для текста сообщения
//
Процедура ОтправитьУведомлениеОНедостаточномОстаткеДляПереводаЦБ(ПараметрыСообщения)
	
	ПВХ = ПланыВидовХарактеристик.ВнешниеИсточники.РассылкаУведомленийОНедостаточномОстаткеДляПереводаЦБ;
	НастройкиОбмена = ВнешниеДанные.ПолучитьПараметрыВнешнегоИсточника(ПВХ).Настройка;
	Если НастройкиОбмена = Неопределено Тогда
		ОбщегоНазначения.СообщитьОбОшибке("Не удалось получить параметры внешнего источника """ + ПВХ + """");
		Возврат;
	КонецЕсли;
	
	ТемаПисьма = "Поручение на перевод ЦБ. ОТС. Недостаточно ЦБ";
	
	КоличествоЦБ 		= Формат(ПараметрыСообщения.КоличествоЦБ, "ЧГ=");
	СсылкаНаПоручение 	= ПолучитьНавигационнуюСсылку(ПараметрыСообщения.ПоручениеСписание);
	СчетДепо 			= СокрЛП(ПараметрыСообщения.СчетДепо);
	
	ТекстУведомления = ("Счет Депо: " + СчетДепо + Символы.ВК
		+ "ISIN: " + ПараметрыСообщения.ISIN + Символы.ВК
		+ "Количество ЦБ: " + КоличествоЦБ + Символы.ВК
		+ "Ссылка на поручение: " + СсылкаНаПоручение + ".");
	
	ПараметрыУведомления = Новый Соответствие;
	ПараметрыУведомления.Вставить("НастройкиОбмена",	НастройкиОбмена);
	ПараметрыУведомления.Вставить("Кодировка",			"UTF-8");
	ПараметрыУведомления.Вставить("ТемаПисьма",			ТемаПисьма);
	ПараметрыУведомления.Вставить("ТекстПисьма",		ТекстУведомления);
	ПараметрыУведомления.Вставить("ТипТекстаПисьма",	ТипТекстаПочтовогоСообщения.ПростойТекст);
	ПараметрыУведомления.Вставить("Важность",			ВажностьИнтернетПочтовогоСообщения.Обычная);
	
	РегистрыСведений.УведомленияКОтправке.ДобавитьУведомлениеКОтправке(ПараметрыУведомления);
	
КонецПроцедуры

#КонецОбласти