Перем ИдентификаторТипаДокумента Экспорт;
Перем ИспользуемыеВидыОпераций;
Перем НаименованиеОрганизации;

Процедура ЗаполнитьРезультат() Экспорт
	Перем Соединение, Команда, RS;
	
	Если ЭДО Тогда
		ВнешниеДанные.ADOConnect(Соединение, Команда, RS, ПланыВидовХарактеристик.ВнешниеИсточники.Документооборот);
		Номер = "Б/Н";
	КонецЕсли;
	
	Макет = ПолучитьМакет("Макет");
	ОбластьШапка					= Макет.ПолучитьОбласть("Шапка");
	ОбластьНаЕдиныйБрокерскийСчет	= Макет.ПолучитьОбласть("НаЕдиныйБрокерскийСчет");
	ОбластьНаСчетДепонента			= Макет.ПолучитьОбласть("НаСчетДепонента");
	ОбластьШапкаПоручения			= Макет.ПолучитьОбласть("ШапкаПоручения");
	ОбластьШапкаТаблицы				= Макет.ПолучитьОбласть("ШапкаТаблицы");
	ОбластьСтрокаТаблицы			= Макет.ПолучитьОбласть("СтрокаТаблицы");
	ОбластьПодвал					= Макет.ПолучитьОбласть("Подвал");
	Результат.Очистить();
	
	ОбластьШапка.Параметры.Период = Формат(Период, "ДФ=dd.MM.yyyy");
	ОбластьШапка.Параметры.Организация = НаименованиеОрганизации;
	Результат.Вывести(ОбластьШапка);
	
	ППНомерСчета = 1;
	ВыборкаСДС = ВыполнитьЗапрос().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "СпецДепозитарныйСчет");
	Пока ВыборкаСДС.Следующий() Цикл
		ВыборкаСчетВыплаты = ВыборкаСДС.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "СчетДляВыплатыДоходов");
		Пока ВыборкаСчетВыплаты.Следующий() Цикл
			Если ЗначениеЗаполнено(ВыборкаСчетВыплаты.СчетДляВыплатыДоходов) Тогда
				Область = ОбластьНаСчетДепонента;
				Область.Параметры.НомерСчетаВыплаты = ВыборкаСчетВыплаты.СчетДляВыплатыДоходов.НомерСчета;
				Область.Параметры.БанкВыплаты = ВыборкаСчетВыплаты.СчетДляВыплатыДоходов.Банк.Наименование;
			Иначе
				Область = ОбластьНаЕдиныйБрокерскийСчет;
			КонецЕсли;
			Область.Параметры.НомерСтрокиСчета = Строка(ППНомерСчета) + ".";
			Область.Параметры.НомерСпецДепозитарногоСчета = ВыборкаСДС.НомерСпецДепозитарногоСчета;
			Область.Параметры.Валюта = Справочники.Валюты.ПредставлениеВалюты(ВыборкаСДС.ВалютаСпецДепозитарногоСчета);
			Область.Параметры.СуммаПеревода = Формат(ВыборкаСчетВыплаты.СуммаБезНалога, "ЧДЦ=2; ЧРД=-; ЧРГ=' '");
			Результат.Вывести(Область);
		
			ВыборкаВидыОпераций = ВыборкаСчетВыплаты.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "ВидОперацииД");
			Пока ВыборкаВидыОпераций.Следующий() Цикл
				
				СтрокаВидаОпераций = ИспользуемыеВидыОпераций.Найти(ВыборкаВидыОпераций.ВидОперацииД, "ВидОперации");
				Если СтрокаВидаОпераций <> Неопределено Тогда
					ОбластьШапкаПоручения.Параметры.Заголовок = СтрокаВидаОпераций.ЗаголовокВШапкеПоручения;
				КонецЕсли;
				
				ВыборкаЦБ = ВыборкаВидыОпераций.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "ЦеннаяБумага");
				Пока ВыборкаЦБ.Следующий() Цикл
					Если ЗначениеЗаполнено(ВыборкаЦБ.НаименованиеЭмитента) Тогда
						ОбластьШапкаПоручения.Параметры.Эмитент = " " + ВыборкаЦБ.НаименованиеЭмитента;
					КонецЕсли;
					
					Если ЗначениеЗаполнено(ВыборкаЦБ.ISIN) Тогда
						ОбластьШапкаПоручения.Параметры.ISIN =  ", ISIN - " + ВыборкаЦБ.ISIN;
					КонецЕсли;
					
					Если ЗначениеЗаполнено(ВыборкаЦБ.НомерРегистрации) Тогда
						ОбластьШапкаПоручения.Параметры.РегНомер = ", " + ВыборкаЦБ.НомерРегистрации;
						Если ЗначениеЗаполнено(ВыборкаЦБ.ДатаГосРег) Тогда
							ОбластьШапкаПоручения.Параметры.ДатаРег = " от " + Формат(ВыборкаЦБ.ДатаГосРег, "ДФ=dd.MM.yyyy");
						КонецЕсли;
					КонецЕсли;
					Результат.Вывести(ОбластьШапкаПоручения);
					
					Если ВыборкаЦБ.ВидОперацииД = Справочники.ВидыОпераций.НачислениеДивидендов Тогда
						ОбластьШапкаТаблицы.Параметры.ЗаголовокКоличествоРезидент = "Резидент";
					Иначе 
						ОбластьШапкаТаблицы.Параметры.ЗаголовокКоличествоРезидент = "Количество";
					КонецЕсли;
					Результат.Вывести(ОбластьШапкаТаблицы);
					
					ППНомерСтрокиТаблицы = 1;
					ВыборкаДетЗаписи = ВыборкаЦБ.Выбрать();
					Пока ВыборкаДетЗаписи.Следующий() Цикл
						ОбластьСтрокаТаблицы.Параметры.Заполнить(ВыборкаДетЗаписи);
						ОбластьСтрокаТаблицы.Параметры.НомерСтроки = ППНомерСтрокиТаблицы;
						Если ВыборкаЦБ.ВидОперацииД = Справочники.ВидыОпераций.НачислениеДивидендов Тогда
							ОбластьСтрокаТаблицы.Параметры.КоличествоРез = ВыборкаДетЗаписи.Резидент;
						Иначе
							ОбластьСтрокаТаблицы.Параметры.КоличествоРез = ВыборкаДетЗаписи.Количество;
						КонецЕсли; 
						Результат.Вывести(ОбластьСтрокаТаблицы);
						ППНомерСтрокиТаблицы = ППНомерСтрокиТаблицы + 1;
					КонецЦикла;
				КонецЦикла;
			КонецЦикла;
			ППНомерСчета = ППНомерСчета + 1;
		КонецЦикла;
	КонецЦикла;
	ТекущийПользователь = ПараметрыСеанса.ТекущийПользователь.Наименование;
	ОбластьПодвал.Параметры.Пользователь = ТекущийПользователь;
	ОбластьПодвал.Параметры.Организация = НаименованиеОрганизации;
	Результат.Вывести(ОбластьПодвал);
	
	Если ЭДО Тогда
		ЗарегистрироватьДокументВЭДО(Номер, Результат, Период, Команда, RS);
	КонецЕсли;
	
КонецПроцедуры

Функция ВыполнитьЗапрос()
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ЦенныеБумаги.ЦеннаяБумага КАК ЦеннаяБумага,
	|	ЦенныеБумаги.ЦеннаяБумага.Эмитент.ЮридическиеФизическиеЛица.Наименование КАК НаименованиеЭмитента,
	|	ЦенныеБумаги.ЦеннаяБумага.ISIN КАК ISIN,
	|	ЦенныеБумаги.ЦеннаяБумага.НомерРегистрации КАК НомерРегистрации,
	|	ЦенныеБумаги.ЦеннаяБумага.ДатаГосРег КАК ДатаГосРег,
	|	ЦенныеБумаги.Ссылка.БанковскийСчет КАК СпецДепозитарныйСчет,
	|	ЦенныеБумаги.Ссылка.БанковскийСчет.НомерСчета КАК НомерСпецДепозитарногоСчета,
	|	ЦенныеБумаги.Ссылка.БанковскийСчет.ВалютаДенежныхСредств КАК ВалютаСпецДепозитарногоСчета,
	|	ВЫБОР
	|		КОГДА ЦенныеБумаги.БанковскийСчет.Владелец = ЦенныеБумаги.СчетДепо.Владелец 
	|			ТОГДА ЦенныеБумаги.БанковскийСчет
	|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.БанковскиеСчета.ПустаяСсылка)
	|	КОНЕЦ КАК СчетДляВыплатыДоходов,
	|	ЦенныеБумаги.Ссылка.ВидОперацииД КАК ВидОперацииД,
	|	ЦенныеБумаги.СчетДепо.Владелец.Код КАК Договор,
	|	ЦенныеБумаги.Резидент КАК Резидент,
	|	ЦенныеБумаги.СтавкаНалога,
	|	СУММА(ЦенныеБумаги.Количество) КАК Количество,
	|	СУММА(ЦенныеБумаги.Сумма) КАК Сумма,
	|	СУММА(ЦенныеБумаги.СуммаНалога) КАК СуммаНалога,
	|	СУММА(ЦенныеБумаги.Сумма - ЦенныеБумаги.СуммаНалога) КАК СуммаБезНалога
	|ИЗ
	|	Документ.Поручение.ЦенныеБумагиСписываемые КАК ЦенныеБумаги
	|ГДЕ
	|	ЦенныеБумаги.Ссылка.Дата МЕЖДУ &НачалоПериода И &КонецПериода
	|	И ЦенныеБумаги.Ссылка.ВидОперацииД В (&ВидыОпераций)
	|	И ЦенныеБумаги.Ссылка.Проведен
	|	И НЕ ЦенныеБумаги.Ссылка.ПометкаУдаления
	|
	|СГРУППИРОВАТЬ ПО
	|	ЦенныеБумаги.ЦеннаяБумага,
	|	ЦенныеБумаги.Ссылка.БанковскийСчет,
	|	ЦенныеБумаги.БанковскийСчет,
	|	ЦенныеБумаги.Ссылка.ВидОперацииД,
	|	ЦенныеБумаги.СчетДепо.Владелец,
	|	ЦенныеБумаги.Резидент,
	|	ЦенныеБумаги.СтавкаНалога
	|ИТОГИ
	|	СУММА(Количество),
	|	СУММА(Сумма),
	|	СУММА(СуммаНалога),
	|	СУММА(СуммаБезНалога)
	|ПО
	|	СпецДепозитарныйСчет,
	|	СчетДляВыплатыДоходов,
	|	ВидОперацииД,
	|	ЦеннаяБумага";
	Запрос.УстановитьПараметр("НачалоПериода",	НачалоДня(Период));
	Запрос.УстановитьПараметр("КонецПериода",	КонецДня(Период));
	Запрос.УстановитьПараметр("ВидыОпераций",	ИспользуемыеВидыОпераций.ВыгрузитьКолонку("ВидОперации"));
	Возврат Запрос.Выполнить();
КонецФункции

Функция ПолучитьНомерДокумента(ДатаФормированияОтчета, Команда, RS) Экспорт
	
	ТипыНаправленийПараметраADO	= ПараметрыСеанса.ТипыНаправленийПараметраADO;
	ТипыКомандADO = ПараметрыСеанса.ТипыКомандADO;

	ТаблицаПараметров = Новый ТаблицаЗначений();
	ТаблицаПараметров.Колонки.Добавить("ИмяПараметра");
	ТаблицаПараметров.Колонки.Добавить("ЗначениеПараметра");
	ТаблицаПараметров.Колонки.Добавить("НаправлениеПараметра");
	
	НовыйПараметр = ТаблицаПараметров.Добавить();
	НовыйПараметр.ИмяПараметра = "TypeId";
	НовыйПараметр.ЗначениеПараметра = ИдентификаторТипаДокумента;
	НовыйПараметр.НаправлениеПараметра = ТипыНаправленийПараметраADO.Входящий;
	
	НовыйПараметр = ТаблицаПараметров.Добавить();
	НовыйПараметр.ИмяПараметра = "DocumentDate";
	НовыйПараметр.ЗначениеПараметра = НачалоДня(ДатаФормированияОтчета) + 20*3600;
	НовыйПараметр.НаправлениеПараметра = ТипыНаправленийПараметраADO.Входящий;
	
	НовыйПараметр = ТаблицаПараметров.Добавить();
	НовыйПараметр.ИмяПараметра = "DateDoc";
	НовыйПараметр.ЗначениеПараметра = НачалоДня(ДатаФормированияОтчета) + 20*3600;;
	НовыйПараметр.НаправлениеПараметра = ТипыНаправленийПараметраADO.Входящий;
	
	НовыйПараметр = ТаблицаПараметров.Добавить();
	НовыйПараметр.ИмяПараметра = "Client";
	НовыйПараметр.ЗначениеПараметра = "";
	НовыйПараметр.НаправлениеПараметра = ТипыНаправленийПараметраADO.Входящий;
	
	НовыйПараметр = ТаблицаПараметров.Добавить();
	НовыйПараметр.ИмяПараметра = "Param1";
	НовыйПараметр.НаправлениеПараметра = ТипыНаправленийПараметраADO.Входящий;
	
	НовыйПараметр = ТаблицаПараметров.Добавить();
	НовыйПараметр.ИмяПараметра = "Param2";
	НовыйПараметр.НаправлениеПараметра = ТипыНаправленийПараметраADO.Входящий;
	
	НовыйПараметр = ТаблицаПараметров.Добавить();
	НовыйПараметр.ИмяПараметра = "Param3";
	НовыйПараметр.НаправлениеПараметра = ТипыНаправленийПараметраADO.Входящий;
	
	НовыйПараметр = ТаблицаПараметров.Добавить();
	НовыйПараметр.ИмяПараметра = "OpenPeriod";
	НовыйПараметр.ЗначениеПараметра = НачалоДня(ДатаФормированияОтчета);
	НовыйПараметр.НаправлениеПараметра = ТипыНаправленийПараметраADO.Входящий;
	
	НовыйПараметр = ТаблицаПараметров.Добавить();
	НовыйПараметр.ИмяПараметра = "ClosePeriod";
	НовыйПараметр.ЗначениеПараметра = КонецДня(ДатаФормированияОтчета);
	НовыйПараметр.НаправлениеПараметра = ТипыНаправленийПараметраADO.Входящий;
	
	НовыйПараметр = ТаблицаПараметров.Добавить();
	НовыйПараметр.ИмяПараметра = "Number";
	НовыйПараметр.ЗначениеПараметра = "";
	НовыйПараметр.НаправлениеПараметра = ТипыНаправленийПараметраADO.Исходящий;
	
	ВнешниеДанные.СформироватьПараметрыADO(Команда, ТаблицаПараметров);
	ВнешниеДанные.SQLЗапрос(Команда, RS, "SearchNumber", ТипыКомандADO.ХранимаяПроцедура);
	Номер = Команда.Parameters("Number").Value;
	
	Возврат Номер;
	
КонецФункции

Процедура ЗарегистрироватьДокументВЭДО(Номер, ТабДок, ДатаФормированияОтчета, Команда, RS) Экспорт
	
	ТипыНаправленийПараметраADO	= ПараметрыСеанса.ТипыНаправленийПараметраADO;
		
	ТаблицаПараметров = Новый ТаблицаЗначений();
	ТаблицаПараметров.Колонки.Добавить("ИмяПараметра");
	ТаблицаПараметров.Колонки.Добавить("ЗначениеПараметра");
	ТаблицаПараметров.Колонки.Добавить("НаправлениеПараметра");
	
	НовыйПараметр = ТаблицаПараметров.Добавить();
	НовыйПараметр.ИмяПараметра = "FileName";
	НовыйПараметр.ЗначениеПараметра = "Формирование СЗПо документам выплаты дохода погашения";
	НовыйПараметр.НаправлениеПараметра = ТипыНаправленийПараметраADO.Входящий;
	
	НовыйПараметр = ТаблицаПараметров.Добавить();
	НовыйПараметр.ИмяПараметра = "OpenPeriod";
	НовыйПараметр.ЗначениеПараметра = НачалоДня(ДатаФормированияОтчета);
	НовыйПараметр.НаправлениеПараметра = ТипыНаправленийПараметраADO.Входящий;
	
	НовыйПараметр = ТаблицаПараметров.Добавить();
	НовыйПараметр.ИмяПараметра = "ClosePeriod";
	НовыйПараметр.ЗначениеПараметра = КонецДня(ДатаФормированияОтчета);
	НовыйПараметр.НаправлениеПараметра = ТипыНаправленийПараметраADO.Входящий;
	
	НовыйПараметр = ТаблицаПараметров.Добавить();
	НовыйПараметр.ИмяПараметра = "DocumentDate";
	НовыйПараметр.ЗначениеПараметра = НачалоДня(ДатаФормированияОтчета) + 20*3600;;
	НовыйПараметр.НаправлениеПараметра = ТипыНаправленийПараметраADO.Входящий;
	
	НовыйПараметр = ТаблицаПараметров.Добавить();
	НовыйПараметр.ИмяПараметра = "ClientId";
	НовыйПараметр.ЗначениеПараметра = "";
	НовыйПараметр.НаправлениеПараметра = ТипыНаправленийПараметраADO.Входящий;
	
	НовыйПараметр = ТаблицаПараметров.Добавить();
	НовыйПараметр.ИмяПараметра = "ContractNumber";
	НовыйПараметр.ЗначениеПараметра = "";
	НовыйПараметр.НаправлениеПараметра = ТипыНаправленийПараметраADO.Входящий;
	
	НовыйПараметр = ТаблицаПараметров.Добавить();
	НовыйПараметр.ИмяПараметра = "ContractDate";
	НовыйПараметр.ЗначениеПараметра = null;
	НовыйПараметр.НаправлениеПараметра = ТипыНаправленийПараметраADO.Входящий;
	
	НовыйПараметр = ТаблицаПараметров.Добавить();
	НовыйПараметр.ИмяПараметра = "TypeId";
	НовыйПараметр.ЗначениеПараметра = ИдентификаторТипаДокумента;
	НовыйПараметр.НаправлениеПараметра = ТипыНаправленийПараметраADO.Входящий;
	
	НовыйПараметр = ТаблицаПараметров.Добавить();
	НовыйПараметр.ИмяПараметра = "Comment";
	НовыйПараметр.ЗначениеПараметра = "";
	НовыйПараметр.НаправлениеПараметра = ТипыНаправленийПараметраADO.Входящий;
	
	НовыйПараметр = ТаблицаПараметров.Добавить();
