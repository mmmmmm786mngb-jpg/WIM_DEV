// ПРОЦЕДУРЫ И ФУНКЦИИ ЗАГРУЗКИ PARTAD ИЗ ШЛЮЗА 


Процедура НайтиФайлыДляЗагрузкиЗаПериод(СоответствиеФайловДляЗагрузки, ПутьДляПоиска) Экспорт
	
	ПапкаСФайламиTEMP 	= РаботаСФайлами.СоздатьВременныйКаталог();
	
	НайденнныеКаталоги	= Новый Массив;
	ПолучитьКаталогиРаскрытияЗаПериодОбработки(ПутьДляПоиска, НайденнныеКаталоги);
	
	Для каждого ИмяКаталога из НайденнныеКаталоги Цикл
		НайденныеФайлы = НайтиФайлы(ИмяКаталога.ПолноеИмя, "*.zip", Истина);
		Для каждого ФайлZIP из НайденныеФайлы Цикл
			ОбнаруженНеобходимыйФайлReporth = Ложь;
			Попытка
				АрхивZIP	= Новый ЧтениеZipФайла(ФайлZIP.ПолноеИмя);
				АрхивZIP.ИзвлечьВсе(ПапкаСФайламиTEMP, РежимВосстановленияПутейФайловZIP.НеВосстанавливать);
				АрхивZIPЭлементы	= АрхивZIP.Элементы;
				Для сч = 0 По АрхивZIPЭлементы.Количество()-1 Цикл
					ИмяDBFФайла = АрхивZIPЭлементы.Получить(сч).Имя;
					Если ИмяDBFФайла = "reporth.dbf" Тогда
						ОбнаруженНеобходимыйФайлReporth = Истина;
						Прервать;
					КонецЕсли;
				КонецЦикла; 
				АрхивZIP.Закрыть();
				Если ОбнаруженНеобходимыйФайлReporth Тогда
					ТаблицыИКлючи = ОбработатьDBFФайлы(ПапкаСФайламиTEMP);
					reporth	= ТаблицыИКлючи.Получить("reporth");
					Если reporth.Количество() > 0 Тогда
						OrderType = СокрЛП(reporth[0].ORD_TYPE_I);
						REPORT_ID = Формат(reporth[0].REPORT_ID, "ЧГ=0");
						Если OrderType = "61" Тогда
							НоваяЗапись	= СоответствиеИдФайлам.Добавить();
							НоваяЗапись.REPORT_ID	= REPORT_ID;
							НоваяЗапись.ИмяАрхива	= ФайлZIP.ПолноеИмя;
							СоответствиеФайловДляЗагрузки.Вставить(ФайлZIP.Имя, ФайлZIP.Путь);
						КонецЕсли;
					КонецЕсли;
				КонецЕсли;
			Исключение
				ЗаписьЖурналаРегистрации("Загрузка 'Раскрытия списка владельцев'",
											УровеньЖурналаРегистрации.Ошибка,,, 
											ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
			КонецПопытки;
		КонецЦикла;
	КонецЦикла;

КонецПроцедуры

Процедура ПолучитьКаталогиРаскрытияЗаПериодОбработки(Путь, НайденнныеКаталоги)
	
	Сутки = ОбщегоНазначенияПовтИсп.СекундВСутках();
	
	ДатаАнализа = НачалоДня(ПериодНачало);
	Пока ДатаАнализа <= ПериодКонец Цикл
		МаскаКаталога = МаскаКаталогаСФайламиРаскрытияТекущегоДня(ДатаАнализа);
		НайденнныеКаталогиПоМаске = НайтиФайлы(Путь, МаскаКаталога, Истина);
		Для каждого НайденныйКаталог из НайденнныеКаталогиПоМаске Цикл
			Если НайденныйКаталог.ЭтоКаталог() Тогда
				НайденнныеКаталоги.Добавить(НайденныйКаталог);
			КонецЕсли;
		КонецЦикла;
		ДатаАнализа = ДатаАнализа + Сутки;
	КонецЦикла;

КонецПроцедуры

Функция МаскаКаталогаСФайламиРаскрытияТекущегоДня(ДатаАнализа)
	ПредставлениеДня = "" + День(ДатаАнализа) + ПредставлениеМесяца(Месяц(ДатаАнализа));
	Возврат "Z" + ПредставлениеДня + "*" + ".CRY";
КонецФункции

Функция ПредставлениеМесяца(НомерМесяца)
	Если НомерМесяца <= 9 Тогда 
		Возврат НомерМесяца;
	ИначеЕсли НомерМесяца = 10 Тогда
		Возврат "A";
	ИначеЕсли НомерМесяца = 11 Тогда
		Возврат "B";
	ИначеЕсли НомерМесяца = 12 Тогда
		Возврат "C";
	Иначе 
		Возврат "";
	КонецЕсли;
КонецФункции
 
Процедура ПеренестиФайлыРаскрытияВАрхив(КаталогЗагрузки, ПутьККаталогуОбработки) Экспорт 
	
	ПолныйПутьАрхива = ПутьККаталогуОбработки + "\Archive";
	ФайлАрхив = Новый Файл(ПолныйПутьАрхива); 
	Если НЕ ФайлАрхив.Существует()Тогда 
		СоздатьКаталог(ПолныйПутьАрхива);
	КонецЕсли;
	
	ПолныйПутьInbox = ПутьККаталогуОбработки + "\inbox"; 
	ИмяКаталогаZ = СтрЗаменить(КаталогЗагрузки, ПолныйПутьInbox + "\", "");
	ПозицияВАдресе = Найти(ИмяКаталогаZ, "\");
	Если ПозицияВАдресе > 0 Тогда 
		ИмяКаталогаZ = Лев(ИмяКаталогаZ, ПозицияВАдресе - 1);
	КонецЕсли;
	
	КаталогиВInbox = НайтиФайлы(ПолныйПутьInbox + "\" + ИмяКаталогаZ);
	
	Для каждого КаталогZ из КаталогиВInbox Цикл
		КаталогАрхива = ПолныйПутьАрхива + "\" + ИмяКаталогаZ;
		СоздатьКаталог(КаталогАрхива);
		КлонироватьСтруктуруКаталоговВНовойПапке(КаталогZ, КаталогАрхива);
		ПеренестиФайлыВСтруктуреКаталогов(КаталогZ, КаталогАрхива);
		Попытка
			УдалитьФайлы(КаталогZ.ПолноеИмя);  
		Исключение
			ЗаписьЖурналаРегистрации("Загрузка 'Раскрытия списка владельцев'",
			УровеньЖурналаРегистрации.Ошибка,,, 
			ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		КонецПопытки;  
	КонецЦикла;
	
КонецПроцедуры

Процедура ПеренестиФайлыВСтруктуреКаталогов(ИсходныйКаталог, ИмяНовогоКаталога)
	Файлы = НайтиФайлы(ИсходныйКаталог.ПолноеИмя, "*.*");
	Для Каждого Файл ИЗ Файлы Цикл
		Если Файл.ЭтоФайл() Тогда
			ПереместитьФайл(Файл.ПолноеИмя, ИмяНовогоКаталога + "\" + Файл.Имя);
		ИначеЕсли Файл.ЭтоКаталог() Тогда
			ПеренестиФайлыВСтруктуреКаталогов(Файл, ИмяНовогоКаталога + "\" + Файл.Имя)
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры
	
Процедура КлонироватьСтруктуруКаталоговВНовойПапке(ИсходныйКаталог, ИмяНовогоКаталога)
	Каталоги = НайтиФайлы(ИсходныйКаталог.ПолноеИмя, "*.*");
	Для Каждого Каталог ИЗ Каталоги Цикл
		Если Каталог.ЭтоКаталог() Тогда
			ИмяВложенногоКаталога = ИмяНовогоКаталога + "\" + Каталог.Имя;
			СоздатьКаталог(ИмяВложенногоКаталога);
			КлонироватьСтруктуруКаталоговВНовойПапке(Каталог, ИмяВложенногоКаталога);
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры
 
Процедура ЗарегистрироватьЭтапКД(ДокументСсылка)
	
	Этап 			= Справочники.ЭтапыКД.ЗапросСпискаВФорматеPARTAD;
	ТипУведомления 	= "NEWM";
		
	ТипУведомления = Справочники.ТипыУведомления.НайтиПоКоду(ТипУведомления);
	Если Этап.Пустая() Тогда
		ЗаписьЖурналаРегистрации("Загрузка 'Раскрытия списка владельцев'",
					УровеньЖурналаРегистрации.Ошибка,,ДокументСсылка,
					"Не найден тип уведомления " + ТипУведомления + ". Этап КД не выполнен");
		Возврат;
	КонецЕсли;
	
	ЗаписьЭтапаКД = РегистрыСведений.ЭтапыКД.СоздатьМенеджерЗаписи();
	ЗаписьЭтапаКД.КД 				= ДокументСсылка.КарточкаКД;
	ЗаписьЭтапаКД.ДокументКД 		= ДокументСсылка;
	ЗаписьЭтапаКД.Активность 		= Истина;
	ЗаписьЭтапаКД.Период 			= ДокументСсылка.Дата;
	ЗаписьЭтапаКД.ЭтапКД 			= Этап;
	ЗаписьЭтапаКД.КодОтчета 		= Этап.Код;
	ЗаписьЭтапаКД.НомерСообщения 	= СокрЛП(ДокументСсылка.Номер);
	ЗаписьЭтапаКД.ТипУведомления	= ТипУведомления;
	ЗаписьЭтапаКД.Исходящее			= Ложь;
	ЗаписьЭтапаКД.Записать();
	
КонецПроцедуры

ОбщегоНазначения.ЛогироватьИспользованиеОбъекта(ЭтотОбъект);
