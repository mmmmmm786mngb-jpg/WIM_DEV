//***********************************************************************************************

Функция ПолучитьТекстЗапросаSQL()
	Возврат
	"/****** Сценарий для команды SelectTopNRows среды SSMS  ******/
	|SELECT
	|  d.[doc_num]
	|  ,vr.[doc_id]
	|  ,vr.[maker_code]
	|  ,vr.[order_doc_id]
	|  ,vr.[order_reg_date_sgd]
	|  ,vr.[order_reg_no]
	|  ,vr.[order_reg_no_sgd]
	|  ,vr.[order_t_id]
	|  ,vr.[order_t_n]
	|  ,vr.[out_form]
	|  ,vr.[person_code]
	|  ,vr.[reciv_code]
	|  ,vr.[reference]
	|  ,vr.[report_id]
	|  ,vr.[sec_code]
	|  ,vr.[file_name]
	|  ,vr.[archived]
	|  ,vr.[move_hdd]
	|  ,vr.[file_body]
	|  ,vr.[file_body_arh]
	|  ,ol.[ADD_INFO]
	|FROM
	|	[NDC].[dbo].[v_reports]		as vr
	|
	|INNER JOIN
	|	[NDC].[dbo].[documents ]	AS d
	|ON
	|	vr.doc_id = d.doc_id
	|
	|LEFT JOIN
	|	[NDC].[dbo].[ol_advice]		AS ol
	|ON
	|	vr.doc_id = ol.doc_id
	|
	|WHERE
	|	vr.[order_t_id] = '61'
	|AND
	|	d.[doc_type] = 'OLADVICE'
	|AND
	|	d.[doc_date] BETWEEN {ts '"+Формат(ПериодНачало, "ДФ=yyyy-MM-dd")+" 00:00:00'} AND {ts '"+Формат(ПериодКонец, "ДФ=yyyy-MM-dd")+" 23:59:59'}";
КонецФункции

Процедура ЗаписатьЗначениеSQLВоВременныйФайл(doc_num, Значение, ИмяВременногоФайла, ADD_INFO = "")
	Stream = Неопределено;
	
	Stream = Новый COMОбъект("ADODB.Stream");
	Stream.Type = 1;
	Stream.Open();
	
	SaveOptionsEnum	= Новый Структура("adSaveCreateNotExist, adSaveCreateOverWrite",1 , 2);
	
	Stream.Write(Значение);
	Попытка	
		Stream.SaveToFile(ИмяВременногоФайла, SaveOptionsEnum.adSaveCreateOverWrite);
		НоваяЗапись	= СоответствиеИдФайлам.Добавить();
		НоваяЗапись.REPORT_ID	= СокрЛП(doc_num);
		НоваяЗапись.ИмяАрхива	= ИмяВременногоФайла;
		НоваяЗапись.Комментарий	= ADD_INFO;
	Исключение
		ОбщегоНазначения.СообщитьОбОшибке(ОписаниеОшибки());
	КонецПопытки;
КонецПроцедуры

Процедура ПолучитьФайлыИзЛуча(ПутьККаталогу) Экспорт
	//---
	Перем Соединение;
	Перем Команда;
	Перем RS;
	// Получим параметры источника данных
	Параметры = ВнешниеДанные.ПолучитьПараметрыВнешнегоИсточника(ПланыВидовХарактеристик.ВнешниеИсточники.КаталогФайловРаскрытияСпискаВладельцевPartad);
	Если Не ЗначениеЗаполнено(ПутьККаталогу) Тогда
		ПутьККаталогу	= Параметры.Папка;
	КонецЕсли; 	
	//---	
	ВнешниеДанные.ADOConnect(Соединение, Команда, RS, ПланыВидовХарактеристик.ВнешниеИсточники.Луч, 30, 30);
	//---
	ТекстSQLЗапроса = ПолучитьТекстЗапросаSQL();
	Параметры = ВнешниеДанные.ПолучитьПараметрыВнешнегоИсточника(ПланыВидовХарактеристик.ВнешниеИсточники.Луч);
	Команда.CommandText = СтрЗаменить(ТекстSQLЗапроса, "[NDC].", ?(ПустаяСтрока(Параметры.База), "", "["+СокрЛП(Параметры.База)+"]."));
	//---
	rs = Команда.Execute();
	//---
	Пока Не rs.Eof() Цикл
		ЗаписатьЗначениеSQLВоВременныйФайл(rs.Fields("doc_num").Value, rs.Fields("file_body").Value,
			ПутьККаталогу+"\"+rs.Fields("file_name").Value, rs.Fields("ADD_INFO").Value);
		rs.MoveNext();
	КонецЦикла;
	//---
	ВнешниеДанные.ADODisconnect(Соединение, Команда, RS);
КонецПроцедуры

Функция ПолучитьТекстЗапросаISO_SQL()
	Возврат
	"/****** Сценарий для команды SelectTopNRows среды SSMS  ******/
	|SELECT
	|  d.[doc_num]
	|  ,vr.[doc_id]
	|  ,vr.[maker_code]
	|  ,vr.[order_doc_id]
	|  ,vr.[order_reg_date_sgd]
	|  ,vr.[order_reg_no]
	|  ,vr.[order_reg_no_sgd]
	|  ,vr.[order_t_id]
	|  ,vr.[order_t_n]
	|  ,vr.[out_form]
	|  ,vr.[person_code]
	|  ,vr.[reciv_code]
	|  ,vr.[reference]
	|  ,vr.[report_id]
	|  ,vr.[sec_code]
	|  ,vr.[file_name]
	|  ,vr.[archived]
	|  ,vr.[move_hdd]
	|  ,vr.[file_body]
	|  ,vr.[file_body_arh]
	|FROM
	|	[NDC].[dbo].[v_reports]		as vr
	|INNER JOIN
	|	[NDC].[dbo].[documents ]	AS d
	|ON
	|	vr.doc_id = d.doc_id
	|WHERE
	|	vr.[order_t_id] = '67'
	|AND
	|	d.[doc_type] = 'REPORT'
	|AND
	|	vr.[out_form] = 'CA012'
	|AND
	|	d.[doc_date] BETWEEN {ts '"+Формат(ПериодНачало, "ДФ=yyyy-MM-dd")+" 00:00:00'} AND {ts '"+Формат(ПериодКонец, "ДФ=yyyy-MM-dd")+" 23:59:59'}";
КонецФункции

Процедура ПолучитьФайлыIsoИзЛуча(ПутьККаталогуISO) Экспорт
	//---
	Перем Соединение;
