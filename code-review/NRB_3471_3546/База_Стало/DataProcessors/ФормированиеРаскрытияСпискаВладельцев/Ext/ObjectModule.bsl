Функция ВернутьТип1СПоТипуDBF(ТипBF)
	// Содержит тип поля: "S"- строка, "N" - число, "D" - дата, "L" - булево, "F" - число, "M" - мемо поле (не поддерживается).
	Тип1С	= Неопределено;
	//---
	Если ТипBF = "S" Тогда
		Тип1С	= Новый ОписаниеТипов("Строка");
	ИначеЕсли ТипBF = "N" Тогда
		Тип1С	= Новый ОписаниеТипов("Число");
	ИначеЕсли ТипBF = "D" Тогда
		Тип1С	= Новый ОписаниеТипов("Дата");
	ИначеЕсли ТипBF = "L" Тогда
		Тип1С	= Новый ОписаниеТипов("Булево");
	ИначеЕсли ТипBF = "F" Тогда
		Тип1С	= Новый ОписаниеТипов("Число");
	КонецЕсли;
	
	Возврат Тип1С;
КонецФункции

Функция СоздатьТаблицуПоDBF(xBase, Имя)
	Таблица			= Новый ТаблицаЗначений;
	КоличествоПолей	= xBase.Поля.Количество();
	
	Для сч = 0 По КоличествоПолей-1 Цикл
		ТипКолонки	= ВернутьТип1СПоТипуDBF(xBase.Поля[сч].Тип);
		Если НЕ ТипКолонки = Неопределено Тогда
			Таблица.Колонки.Добавить(xBase.Поля[сч].Имя, ТипКолонки);
		Иначе
			ОбщегоНазначения.СообщитьОбОшибке("В таблице DBF '"+Имя+"' присутствуют поля 'MEMO' типа, которые не обрабатываются средствами 1С!");
		КонецЕсли;
	КонецЦикла;
	
	Возврат Таблица;
КонецФункции

Функция ОбработатьDBFФайлы(ПутьКВременномуКаталогу) Экспорт
	//---
	ФайлыДляОбработки	= НайтиФайлы(ПутьКВременномуКаталогу, "*.dbf");
	xBase				= Новый XBase;
	xBase.Кодировка		= КодировкаXBase.ANSI;
	ТаблицыИКлючи		= Новый Соответствие;
	//---
	Для Каждого ФайлИзМассива ИЗ ФайлыДляОбработки Цикл
		Если СтрДлина(ФайлИзМассива.ИмяБезРасширения) > 8 Тогда
			Продолжить;    // не прошли ограничение 8.3 для имени файла
		КонецЕсли;
		xBase.ОткрытьФайл(ФайлИзМассива.ПолноеИмя, , Истина);
		//---
		Таблица	= СоздатьТаблицуПоDBF(xBase, ФайлИзМассива.Имя);
		//---
		Если xBase.Первая() Тогда
			Пока Истина Цикл
				НоваяСтрока	= Таблица.Добавить();
				//---
				Для Каждого Колонка ИЗ Таблица.Колонки Цикл
					НоваяСтрока[Колонка.Имя]	= xBase[Колонка.Имя];
				КонецЦикла;				
				//---
				Если Не xBase.Следующая() Тогда
					Прервать;
				КонецЕсли;
				//---
			КонецЦикла;
		КонецЕсли;
		//---
		xBase.ЗакрытьФайл();
		//---
		ТаблицыИКлючи.Вставить(ФайлИзМассива.ИмяБезРасширения, Таблица);
		//---
	КонецЦикла;
	//---
	Возврат ТаблицыИКлючи;
КонецФункции

