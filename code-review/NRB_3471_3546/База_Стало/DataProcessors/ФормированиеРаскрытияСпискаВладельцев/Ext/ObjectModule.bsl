Функция СоздатьТаблицуДляЦБ()
	//----
	ТаблицаПоЦБ	= Новый ТаблицаЗначений;
	//----
	ТаблицаПоЦБ.Колонки.Добавить("FaceAmnt");
	ТаблицаПоЦБ.Колонки.Добавить("Unit");
	ТаблицаПоЦБ.Колонки.Добавить("BalTp");
	ТаблицаПоЦБ.Колонки.Добавить("Dt");
	ТаблицаПоЦБ.Колонки.Добавить("SfkpgPlc");
	//----
	Возврат ТаблицаПоЦБ;
КонецФункции

Функция ПолучитьДанныеИзФайла(ПолныйПутьФайла)
	ТекстXML	= Новый ТекстовыйДокумент;
	ТекстXML.Прочитать(ПолныйПутьФайла);
	XMLДанные	= ТекстXML.ПолучитьТекст();
	
	ТипXDTO		= ФабрикаXDTO.Пакеты.Получить("MeetingNotification_ISO20022BMET").КорневыеСвойства.Получить("MeetingNotification").Тип;
	
	XMLДанные	= СтрЗаменить(XMLДанные, "<MeetingNotification>", "<MeetingNotification xmlns=""MeetingNotification_ISO20022BMET"">");
	
	ЧтениеXML 	= Новый ЧтениеXML;
	ЧтениеXML.УстановитьСтроку(XMLДанные);
	
	Объект		= ФабрикаXDTO.ПрочитатьXML(ЧтениеXML, ТипXDTO);
	
	AppHdr		= Объект.AppHdr;
	Document	= Объект.Document;
	// Параметры документа раскрытия
	ПараметрыРаскрытия	= Новый Соответствие;
	// Параметры уведомления
	ПараметрыРаскрытия.Вставить("НомерВходящего"		, AppHdr.BizMsgIdr);
	ПараметрыРаскрытия.Вставить("ДатаВходящего"			, AppHdr.CreDt);
	ПараметрыРаскрытия.Вставить("РеференсКД"			, Document.MtgNtfctn.Mtg.MtgId);
	ПараметрыРаскрытия.Вставить("ТипСобрания"			, Document.MtgNtfctn.Mtg.TP);
	Если Не Document.MtgNtfctn.Mtg.Clssfctn = Неопределено Тогда
		Если Не Document.MtgNtfctn.Mtg.Clssfctn.Cd = Неопределено Тогда
			ПараметрыРаскрытия.Вставить("КлассСобрания"			, Document.MtgNtfctn.Mtg.Clssfctn.Cd);
		КонецЕсли;
	КонецЕсли;	
	ПараметрыРаскрытия.Вставить("ДатаПроведенияСобрания", Дата(1,1,1));
	ПараметрыРаскрытия.Вставить("ДатаОкончания"			, Дата(1,1,1));
	ПараметрыРаскрытия.Вставить("Комментарий"			, "");
	Если Не Document.MtgNtfctn.Vote = Неопределено Тогда
		Если Не Document.MtgNtfctn.Vote.VoteDdln = Неопределено Тогда
			Если Не Document.MtgNtfctn.Vote.VoteDdln.Dt = Неопределено Тогда
				ПараметрыРаскрытия.Вставить("ДатаОкончания"	, Document.MtgNtfctn.Vote.VoteDdln.Dt);
			КонецЕсли;
		КонецЕсли;
		ПараметрыРаскрытия.Вставить("Комментарий"	, Document.MtgNtfctn.Vote.AddtlVtngRqrmnts);
	КонецЕсли;
	// Даты проведения собрания
	ДатаПроведенияСобрания	= Новый Массив;
	Если не Document.MtgNtfctn.MtgDtls = Неопределено Тогда
		Для Каждого ЗаписьСхемыXDTO ИЗ Document.MtgNtfctn.MtgDtls Цикл
			Если НЕ ЗаписьСхемыXDTO.DtAndTm.Dt = Неопределено Тогда
				ДатаПроведенияСобрания	= ЗаписьСхемыXDTO.DtAndTm.Dt;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;	
	ПараметрыРаскрытия.Вставить("ДатаПроведенияСобрания", ДатаПроведенияСобрания);
	// Информация о ЦБ
	МассивИнформацииОЦБ		= Новый Массив;
	Если Не Document.MtgNtfctn.Scty = Неопределено Тогда
		Для Каждого ЗаписьСхемыXDTO ИЗ Document.MtgNtfctn.Scty Цикл
			ПараметрыЦБ	= Новый Соответствие;
			ПараметрыЦБ.Вставить("ISIN"		, ЗаписьСхемыXDTO.Id.Id.ISIN);
			ПараметрыЦБ.Вставить("Desc"		, ЗаписьСхемыXDTO.Id.Desc);
			ПараметрыЦБ.Вставить("КодНРД"	, Лев(ЗаписьСхемыXDTO.Id.Desc, Найти(ЗаписьСхемыXDTO.Id.Desc, "#")-1));
			// Выделяем номер гос регистрации
			ОстатокСтроки	= Сред(ЗаписьСхемыXDTO.Id.Desc, Найти(ЗаписьСхемыXDTO.Id.Desc, "#")+1);
			ОстатокСтроки	= Сред(ОстатокСтроки, Найти(ОстатокСтроки, "#")+1);
			ГосРегНомер		= Лев(ОстатокСтроки, Найти(ОстатокСтроки, "#")-1);
			// Установим номер гос. регистрации
			ПараметрыЦБ.Вставить("ГосРегНомер"	, ГосРегНомер);
			// Получим данные по ЦБ на счетах ДЕПО
			ПараметрыЦБНаСчетах	= Новый Соответствие;
			Если Не ЗаписьСхемыXDTO.Pos = Неопределено Тогда
				Для Каждого ЗаписьPOSСхемыXDTO ИЗ ЗаписьСхемыXDTO.Pos Цикл
					//---
					ТаблицаПоЦБ	= СоздатьТаблицуДляЦБ();
					//---
					ПараметрыЦБНаСчетах.Вставить("НомерСчетаДепо", ЗаписьPOSСхемыXDTO.AcctId);
					// Создадим структуру данных о количестве
					Для Каждого ЗаписьHldgBalСхемыXDTO ИЗ ЗаписьPOSСхемыXDTO.HldgBal Цикл
						НовСтр	= ТаблицаПоЦБ.Добавить();
						НовСтр.FaceAmnt	= ЗаписьHldgBalСхемыXDTO.Bal.FaceAmt;
						НовСтр.Unit		= ЗаписьHldgBalСхемыXDTO.Bal.Unit;
						НовСтр.BalTp	= ЗаписьHldgBalСхемыXDTO.BalTp;
						НовСтр.Dt		= ЗаписьHldgBalСхемыXDTO.Dt;
						НовСтр.SfkpgPlc	= ЗаписьHldgBalСхемыXDTO.SfkpgPlc;
					КонецЦикла;	
					ПараметрыЦБНаСчетах.Вставить("ДанныеПоСчету", ТаблицаПоЦБ);
				КонецЦикла;
			КонецЕсли;
			ПараметрыЦБ.Вставить("ПараметрыЦБНаСчетах", ПараметрыЦБНаСчетах);
			МассивИнформацииОЦБ.Добавить(ПараметрыЦБ);
		КонецЦикла;
	КонецЕсли;
	//---
	ПараметрыРаскрытия.Вставить("МассивИнформацииОЦБ", МассивИнформацииОЦБ);
	//---
	Если МассивИнформацииОЦБ.Количество()=0 Тогда
		Возврат Неопределено;
	Иначе
		Возврат ПараметрыРаскрытия;
	КонецЕсли;
КонецФункции

Процедура ОбработатьДанныеИЗФайлаISO(ДанныеФайла, ФайлZIP)
	//---
	Если ДанныеФайла = Неопределено Тогда
		Возврат;
	КонецЕсли;
	// Создание строки по раскрытию
	НоваяСтрока	= ДанныеРаскрытияСпискаВладельцев.Добавить();
	//---
	НоваяСтрока.Обрабатывать				= Истина;
	НоваяСтрока.Организация					= Константы.ОрганизацияПоУмолчанию.Получить();
	НоваяСтрока.Инициатор					= Константы.МестоХраненияПоУмолчанию.Получить();
	НоваяСтрока.ВходящийДокументДата		= ДанныеФайла.Получить("ДатаВходящего");
	НоваяСтрока.ВходящийДокументНомер		= ДанныеФайла.Получить("НомерВходящего");
	НоваяСтрока.КДРеференс					= ДанныеФайла.Получить("РеференсКД");
	НоваяСтрока.ДатаОкончанияПриема			= ДанныеФайла.Получить("ДатаОкончания");
	НоваяСтрока.Комментарий					= ДанныеФайла.Получить("Комментарий");
	//---
	Если Не ЗагрузитьISOИзФайла Тогда
		Если Не СоответствиеИдФайлам.Найти(ФайлZIP.ПолноеИмя, "ИмяАрхива") = Неопределено Тогда
			НоваяСтрока.REPORT_ID	= СоответствиеИдФайлам.Найти(ФайлZIP.ПолноеИмя, "ИмяАрхива").REPORT_ID;
		Иначе
			ВызватьИсключение "Не удалось определить 'REPORT_ID'!!! - по входящему №"+НоваяСтрока.ВходящийДокументНомер+" от: "+НоваяСтрока.ВходящийДокументДата;
		КонецЕсли;		
	Иначе
		НоваяСтрока.REPORT_ID	= НоваяСтрока.ВходящийДокументНомер;
	КонецЕсли;
	// Определим есть ли в 1С уже существующий документ
	НоваяСтрока.ДокументРаскрытия	= ПолучитьРаскрытиеСпискаВладельцев(НоваяСтрока.REPORT_ID);
	// Определим вид КД
	КодТипСобрания		= СокрЛП(ДанныеФайла.Получить("ТипСобрания"));
	ТипСобрания			= Справочники.РСВ_ТипСобрания.НайтиПоКоду(КодТипСобрания);
	Если Не ЗначениеЗаполнено(ТипСобрания) И ЗначениеЗаполнено(КодТипСобрания) Тогда
		ТипСобранияОбъект				= Справочники.РСВ_ТипСобрания.СоздатьЭлемент();
		ТипСобранияОбъект.Код			= КодТипСобрания;
		ТипСобранияОбъект.Наименование	= КодТипСобрания;
		ТипСобранияОбъект.Записать();
		//---
		ТипСобрания	= ТипСобранияОбъект.Ссылка;						
	КонецЕсли;
	НоваяСтрока.ТипСобрания	= ТипСобрания;
	//---
	КодКлассСобрания	= СокрЛП(ДанныеФайла.Получить("КлассСобрания"));
	Если Не КодКлассСобрания = Неопределено Тогда
		КлассСобрания		= Справочники.РСВ_КлассСобрания.НайтиПоКоду(КодКлассСобрания);
		Если Не ЗначениеЗаполнено(КлассСобрания) И ЗначениеЗаполнено(КодКлассСобрания) Тогда
			КлассСобранияОбъект					= Справочники.РСВ_КлассСобрания.СоздатьЭлемент();
			КлассСобранияОбъект.Код				= КодКлассСобрания;
			КлассСобранияОбъект.Наименование	= КодКлассСобрания;
			КлассСобранияОбъект.Записать();
			//---
			КлассСобрания	= КлассСобранияОбъект.Ссылка;						
		КонецЕсли;
		НоваяСтрока.КлассСобрания	= КлассСобрания;
	КонецЕсли;
	//----
	Если КодТипСобрания = "GMET" Тогда
		Если КодКлассСобрания = "AMET" ИЛИ КодКлассСобрания = Неопределено Тогда
			ВидКДКод	= "MEET";
		Иначе
			ВидКДКод	= "BMET";
		КонецЕсли;
	Иначе
		ВидКДКод	= "XMET";
	КонецЕсли;
	//---
	ВидКД		= Справочники.ВидыКорпоративныхДействий.НайтиПоКоду(ВидКДКод);
	Если Не ЗначениеЗаполнено(ВидКД) И ЗначениеЗаполнено(ВидКДКод) Тогда
		ВидКДОбъект				= Справочники.ВидыКорпоративныхДействий.СоздатьЭлемент();
		ВидКДОбъект.Код			= ВидКДКод;
		ВидКДОбъект.Наименование= ВидКДКод;
		ВидКДОбъект.Записать();
		//---
		ВидКД	= ВидКДОбъект.Ссылка;						
	КонецЕсли;
	НоваяСтрока.ВидКорпоративногоДействия	= ВидКД;
	// Обработаем даты проведения собраний
	НоваяСтрока.ДатаПроведенияСобрания	= ДанныеФайла.Получить("ДатаПроведенияСобрания");
	// Обработаем данные по ЦБ и заполним на основании их поля таблицы
	МассивИнформацииЦБ	= ДанныеФайла.Получить("МассивИнформацииОЦБ");
	//---
	Для Каждого ИнформацияЦБ ИЗ МассивИнформацииЦБ Цикл
		ЦеннаяБумага		= ПолучитьЦеннуюБумагуПоКодуНРД(СокрЛП(ИнформацияЦБ.Получить("КодНРД")));
		//---
		НомерСчетаДепо		= ИнформацияЦБ.Получить("ПараметрыЦБНаСчетах").Получить("НомерСчетаДепо");
		Если Не НомерСчетаДепо = Неопределено Тогда
			НайденныйСчетДЕПО		= Справочники.СчетаДепоМХ.НайтиПоКоду(СокрЛП(НомерСчетаДепо));
			Если Не ЗначениеЗаполнено(НайденныйСчетДЕПО) Тогда
				НоваяСтрока.СчетДЕПО	= СчетДЕПО_ПоУмолчанию;
			Иначе
				НоваяСтрока.СчетДЕПО	= НайденныйСчетДЕПО;
			КонецЕсли;
		КонецЕсли;
		//---
		ДанныеПоСчету		= ИнформацияЦБ.Получить("ПараметрыЦБНаСчетах").Получить("ДанныеПоСчету");
		Если Не ДанныеПоСчету = Неопределено Тогда
			Если ДанныеПоСчету.Количество()>0 Тогда
				КоличествоЦБ	= ДанныеПоСчету[0].Unit;
				ДатаФиксации	= ДанныеПоСчету[0].Dt;
			Иначе
				КоличествоЦБ	= 0;
				ДатаФиксации	= Дата(1,1,1);
			КонецЕсли;
		Иначе
			КоличествоЦБ	= 0;
			ДатаФиксации	= Дата(1,1,1);
		КонецЕсли;
		//---
		НоваяСтрока.ДатаФиксации	= ДатаФиксации;
		//---
		Если Не ЗначениеЗаполнено(НоваяСтрока.ЦеннаяБумага1) Тогда
			НоваяСтрока.Эмитент					= ЦеннаяБумага.Эмитент;
			НоваяСтрока.ЦеннаяБумага1			= ЦеннаяБумага;
			НоваяСтрока.ЦеннаяБумага1Остаток	= КоличествоЦБ;
		Иначе
			Если НоваяСтрока.ЦеннаяБумага1.Эмитент <> ЦеннаяБумага.Эмитент Тогда
				ВызватьИсключение "При формирова списка 'Раскрытие списка владельцев' - по входящему №"+НоваяСтрока.ВходящийДокументНомер+" от: "+НоваяСтрока.ВходящийДокументДата+" - определены ЦБ с разными 'Эмитентами'";
			КонецЕсли;
			НоваяСтрока.ЦеннаяБумага2			= ЦеннаяБумага;
			НоваяСтрока.ЦеннаяБумага2Остаток	= КоличествоЦБ;
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

Процедура ОбработатьISOФайл(ПутьККаталогуОбработки, ФайлZIP = Неопределено) Экспорт
	Если ЗагрузитьISOИзФайла Тогда
		ПолныйПутьФайла	= ПутьККаталогуОбработки;
	Иначе
		ПолныйПутьФайла	= ПутьККаталогуОбработки+"\repxml.xml";
	КонецЕсли;
	ДанныеФайла	= ПолучитьДанныеИзФайла(ПолныйПутьФайла);
	ОбработатьДанныеИЗФайлаISO(ДанныеФайла, ФайлZIP);
КонецПроцедуры

