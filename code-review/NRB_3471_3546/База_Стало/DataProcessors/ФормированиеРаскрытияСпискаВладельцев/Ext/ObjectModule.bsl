Процедура ОбработатьZIPФайлы(Удалять = Истина) Экспорт
	Если ТипЗагрузкиСписковРаскрытия = Перечисления.ТипЗагрузкиСписковРаскрытия.PARTAD Тогда
		ПутьККаталогуОбработки	= ПутьККаталогу;
	Иначе
		ПутьККаталогуОбработки	= ПутьККаталогуISO;
	КонецЕсли;
	// Инициируем переменную (булево) где будем отслеживать наличие ошибок во время загрузки
	ОперацияУспешна	= Истина;
	// Получим параметры источника данных
	Параметры = ВнешниеДанные.ПолучитьПараметрыВнешнегоИсточника(ПланыВидовХарактеристик.ВнешниеИсточники.КаталогФайловРаскрытияСпискаВладельцевPartad);
	Если Не ЗначениеЗаполнено(ПутьККаталогуОбработки) Тогда
		ПутьККаталогуОбработки	= Параметры.Папка;
	КонецЕсли; 	
	
	ФайлыZipДляОбработки		= НайтиФайлы(ПутьККаталогуОбработки, "*.zip");
	СписокФайловZIPДляОбработки = Новый Массив;
	
	Для Каждого ФайлZIP ИЗ ФайлыZipДляОбработки Цикл
		// Формируем список файлов для переноса в локальную папку временных фалов перед обработкой
		СписокФайловДляОбработки = Новый Массив;		
		СписокФайловДляОбработки.Добавить(ФайлZIP.Имя);
		
		СписокФайловZIPДляОбработки.Добавить(ФайлZIP.Имя);
		
		ОписаниеОшибки					= "";
		УдалятьКаталогФайловПриОшибке	= Ложь;
		
		ПапкаСФайлами					= РаботаСФайлами.СоздатьВременныйКаталог(ОписаниеОшибки);
		УдалятьКаталогФайловПриОшибке	= Истина;
		
		Если ПапкаСФайлами = Неопределено Тогда
			#Если Клиент Тогда
				Предупреждение(ОписаниеОшибки);
			#Иначе
				ЗаписьЖурналаРегистрации("Загрузка 'Раскрытия списка владельцев'", УровеньЖурналаРегистрации.Ошибка,
					, , ОписаниеОшибки);
			#КонецЕсли
			СоответствиеИдФайлам.Найти(ФайлZIP.ПолноеИмя, "ИмяАрхива").ОшибкаОбработки	= Истина; 
		 	Возврат;
		КонецЕсли; 
		
		ОперацияУспешна = РаботаСФайлами.УдалитьФайлыВУказаннойПапке(ПапкаСФайлами, СписокФайловДляОбработки, ОписаниеОшибки);
		
		Если Не ОперацияУспешна Тогда
			#Если Клиент Тогда
				Предупреждение(ОписаниеОшибки);
			#Иначе
				ЗаписьЖурналаРегистрации("Загрузка 'Раскрытия списка владельцев'", УровеньЖурналаРегистрации.Ошибка,
					, , ОписаниеОшибки);
			#КонецЕсли
			
			Если УдалятьКаталогФайловПриОшибке Тогда
				РаботаСФайлами.УдалитьКаталог(ПапкаСФайлами, ОписаниеОшибки);	
			КонецЕсли;	
			
			СоответствиеИдФайлам.Найти(ФайлZIP.ПолноеИмя, "ИмяАрхива").ОшибкаОбработки	= Истина; 
		 	Возврат;
		КонецЕсли; 
		
		ОперацияУспешна = РаботаСФайлами.СкопироватьФайлыВЛокальныйTEMP(ПутьККаталогуОбработки,
			СписокФайловДляОбработки, ПапкаСФайлами, ОписаниеОшибки);
		
		Если Не ОперацияУспешна Тогда
			#Если Клиент Тогда
				Предупреждение(ОписаниеОшибки);
			#Иначе
				ЗаписьЖурналаРегистрации("Загрузка 'Раскрытия списка владельцев'", УровеньЖурналаРегистрации.Ошибка,
					, , ОписаниеОшибки);
			#КонецЕсли
			
			Если УдалятьКаталогФайловПриОшибке Тогда
				РаботаСФайлами.УдалитьКаталог(ПапкаСФайлами, ОписаниеОшибки);	
			КонецЕсли;	
			
			СоответствиеИдФайлам.Найти(ФайлZIP.ПолноеИмя, "ИмяАрхива").ОшибкаОбработки	= Истина; 
		 	Возврат;
		КонецЕсли; 
		
		// Распаковываем скопированный архив и обрабатываем нужные файлы
		Попытка
			АрхивZIP	= Новый ЧтениеZipФайла(ПапкаСФайлами+"\"+ФайлZIP.Имя);
			АрхивZIP.ИзвлечьВсе(ПапкаСФайлами, РежимВосстановленияПутейФайловZIP.НеВосстанавливать);
			// Обходим список файлов архива и дополняем список файлов которые потом будем очищать
			АрхивZIPЭлементы	= АрхивZIP.Элементы;
			Для сч = 0 По АрхивZIPЭлементы.Количество()-1 Цикл
				СписокФайловДляОбработки.Добавить(АрхивZIPЭлементы.Получить(сч).Имя);
			КонецЦикла; 
			АрхивZIP.Закрыть();
		Исключение
			ОперацияУспешна = Ложь;
		КонецПопытки;
		
		Если Не ОперацияУспешна Тогда
			#Если Клиент Тогда
				Предупреждение(ОписаниеОшибки);
			#Иначе
				ЗаписьЖурналаРегистрации("Загрузка 'Раскрытия списка владельцев'", УровеньЖурналаРегистрации.Ошибка,
					, , ОписаниеОшибки);
			#КонецЕсли
			
			РаботаСФайлами.УдалитьФайлыВУказаннойПапке(ПапкаСФайлами, СписокФайловДляОбработки, ОписаниеОшибки);
			
			Если УдалятьКаталогФайловПриОшибке Тогда
				РаботаСФайлами.УдалитьКаталог(ПапкаСФайлами, ОписаниеОшибки);	
			КонецЕсли;	
			
			СоответствиеИдФайлам.Найти(ФайлZIP.ПолноеИмя, "ИмяАрхива").ОшибкаОбработки	= Истина; 
			Возврат;
		КонецЕсли; 
		
		Если ТипЗагрузкиСписковРаскрытия = Перечисления.ТипЗагрузкиСписковРаскрытия.PARTAD Тогда
			ТаблицыИКлючи = ОбработатьDBFФайлы(ПапкаСФайлами);
			Попытка
				ОбработатьДанныеИЗФайла(ТаблицыИКлючи, ФайлZIP);
			Исключение
				СоответствиеИдФайлам.Найти(ФайлZIP.ПолноеИмя, "ИмяАрхива").ОшибкаОбработки	= Истина; 
				ОперацияУспешна = Ложь;
			КонецПопытки;
		Иначе
			Попытка
				ОбработатьISOФайл(ПапкаСФайлами, ФайлZIP);
			Исключение
				СоответствиеИдФайлам.Найти(ФайлZIP.ПолноеИмя, "ИмяАрхива").ОшибкаОбработки	= Истина; 
				ОперацияУспешна = Ложь;
			КонецПопытки;
		КонецЕсли;
		
		// Загрузка закончена удалим файлы из временного каталога
		ОперацияУспешна = РаботаСФайлами.УдалитьФайлыВУказаннойПапке(ПапкаСФайлами, СписокФайловДляОбработки, ОписаниеОшибки);
		Если Удалять Тогда
			// Удалим архивы скаченные из ЛУЧа
			ОперацияУспешна = РаботаСФайлами.УдалитьФайлыВУказаннойПапке(ПутьККаталогуОбработки+"\",
				СписокФайловZIPДляОбработки, ОписаниеОшибки);
		КонецЕсли;
		
		Если УдалятьКаталогФайловПриОшибке Тогда
			ОперацияУспешна = РаботаСФайлами.УдалитьКаталог(ПапкаСФайлами, ОписаниеОшибки);	
		КонецЕсли;	
		
		Если Не ОперацияУспешна Тогда
			#Если Клиент Тогда
				Предупреждение(ОписаниеОшибки);
			#Иначе
				ЗаписьЖурналаРегистрации("Загрузка 'Раскрытия списка владельцев'", УровеньЖурналаРегистрации.Ошибка, , , ОписаниеОшибки);
			#КонецЕсли
			
			Если УдалятьКаталогФайловПриОшибке Тогда
				РаботаСФайлами.УдалитьКаталог(ПапкаСФайлами, ОписаниеОшибки);	
			КонецЕсли;	
			
			СоответствиеИдФайлам.Найти(ФайлZIP.ПолноеИмя, "ИмяАрхива").ОшибкаОбработки	= Истина; 
		 	Возврат;
		КонецЕсли; 
	КонецЦикла;	
КонецПроцедуры

