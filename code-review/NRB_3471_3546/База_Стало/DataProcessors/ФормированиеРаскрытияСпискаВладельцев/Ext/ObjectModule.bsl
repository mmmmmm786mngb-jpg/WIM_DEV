Процедура ОчиститьОбъектРаскрытиеСпискаВладельцев(Объект)
	//---
	МетаданныеОбъекта	= Объект.Метаданные();
	//---
	Для Каждого Реквизит ИЗ МетаданныеОбъекта.Реквизиты Цикл
		Объект[Реквизит.Имя] = "";
	КонецЦикла;
	//---
	Для Каждого ТабличнаяЧасть ИЗ МетаданныеОбъекта.ТабличныеЧасти Цикл
		Объект[ТабличнаяЧасть.Имя].Очистить();
	КонецЦикла;
КонецПроцедуры

Функция ПолучитьРаскрытиеСпискаВладельцев(REPORT_ID);
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	Ссылка
	|ИЗ
	|	Документ.РаскрытиеСпискаВладельцев КАК РаскрытиеСпискаВладельцев
	|ГДЕ
	|	НЕ ПометкаУдаления
	|	И REPORT_ID = &REPORT_ID
	|	И ТипЗагрузкиСписковРаскрытия = &ТипЗагрузкиСписковРаскрытия");

	Запрос.УстановитьПараметр("REPORT_ID"					, REPORT_ID);
	Запрос.УстановитьПараметр("ТипЗагрузкиСписковРаскрытия"	, ТипЗагрузкиСписковРаскрытия);
	
	Результат = Запрос.Выполнить().Выгрузить();	
	
	Если Результат.Количество()=0 Тогда
		Возврат Документы.РаскрытиеСпискаВладельцев.ПустаяСсылка();
	Иначе
		Возврат Результат[0].Ссылка;
	КонецЕсли;
КонецФункции

Функция ПолучитьЦеннуюБумагуПоКодуНРД(КодНРД)
	Запрос = Новый Запрос(
	"ВЫБРАТЬ ПЕРВЫЕ 1
    |	КодыЗагрузки.Владелец КАК ЦБ
    |ИЗ
    |	Справочник.КодыЗагрузки КАК КодыЗагрузки
    |ГДЕ
    |	НЕ	КодыЗагрузки.ПометкаУдаления
    |	И	КодыЗагрузки.Биржа = &НДЦ
    |	И	КодыЗагрузки.Код = &Код");
	
	Запрос.УстановитьПараметр("Код", КодНРД);
	Запрос.УстановитьПараметр("НДЦ", Справочники.КлассификаторыЗагрузки.НДЦ());
	
	Результат = Запрос.Выполнить().Выгрузить();

	Если Результат.Количество()=0 Тогда
		ВызватьИсключение "При загрузке 'Раскрытия списков владельцев' не удалось определить ценную бумагу по коду загрузки - "+КодНРД;
	Иначе
		Возврат Результат[0].ЦБ;
	КонецЕсли;	
КонецФункции

Функция ЗагрузитьВалютуИзКлассификатора(Код)
	Если Код = "" Тогда
		Возврат Справочники.Валюты.ПустаяСсылка();
	КонецЕсли;
	
	Макет = Справочники.Валюты.ПолучитьМакет("КлассификаторВалют");
	ТекущаяОбласть = Макет.НайтиТекст(Код);
	
	Если ТекущаяОбласть = Неопределено Тогда
		Возврат Справочники.Валюты.ПустаяСсылка();
	КонецЕсли; 
	
	ОбластьКодЧисловой         = Макет.Области.КодЧисловой;
	ОбластьНаименованиеКраткое = Макет.Области.НаименованиеКраткое;
	ОбластьНаименованиеПолное  = Макет.Области.НаименованиеПолное;
	
	КодЧисловой         = Макет.Область(ТекущаяОбласть.Верх, ОбластьКодЧисловой.        Лево, ТекущаяОбласть.Низ, ОбластьКодЧисловой.        Право).Текст;
	НаименованиеКраткое = Макет.Область(ТекущаяОбласть.Верх, ОбластьНаименованиеКраткое.Лево, ТекущаяОбласть.Низ, ОбластьНаименованиеКраткое.Право).Текст;
	НаименованиеПолное  = Макет.Область(ТекущаяОбласть.Верх, ОбластьНаименованиеПолное. Лево, ТекущаяОбласть.Низ, ОбластьНаименованиеПолное. Право).Текст;
	
	// Создание новой валюты.
	Элемент = Справочники.Валюты.СоздатьЭлемент();
	Элемент.Код                = КодЧисловой;
	Элемент.Наименование       = НаименованиеКраткое;
	Элемент.НаименованиеПолное = НаименованиеПолное;
	Элемент.Записать();
	Возврат Элемент.Ссылка;
КонецФункции

Функция ПолучитьБанковскийСчет(Организация, Валюта)
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	БанковскиеСчета.Ссылка
	|ИЗ
	|	Справочник.БанковскиеСчета КАК БанковскиеСчета
	|ГДЕ
	|	НЕ БанковскиеСчета.ПометкаУдаления
	|	И БанковскиеСчета.ВалютаДенежныхСредств = &ВалютаДенежныхСредств
	|	И БанковскиеСчета.ТипНазначения = &ТипНазначения
	|	И БанковскиеСчета.Владелец = &Организация
	|	И (БанковскиеСчета.ДатаЗакрытия > &ТекущаяДата
	|			ИЛИ БанковскиеСчета.ДатаЗакрытия = ДАТАВРЕМЯ(1, 1, 1))");

	Запрос.УстановитьПараметр("Организация"				, Организация);
	Запрос.УстановитьПараметр("ВалютаДенежныхСредств"	, Валюта);
	Запрос.УстановитьПараметр("ТипНазначения"			, ?(Валюта = Константы.ВалютаРегламентированногоУчета.Получить(), Перечисления.ТипыНазначенияБанковскихСчетов.Депозитарный, Перечисления.ТипыНазначенияБанковскихСчетов.ДепозитарныйТранзит));
	Запрос.УстановитьПараметр("ТекущаяДата"				, ТекущаяДата());
	
	Результат = Запрос.Выполнить().Выгрузить();
	
	Если Результат.Количество()>0 Тогда
		Возврат Результат[0].Ссылка;
	Иначе
		Возврат Справочники.БанковскиеСчета.ПустаяСсылка();
	КонецЕсли;
КонецФункции

Процедура ОбработатьДанныеИЗФайла(ТаблицыИКлючи, ФайлZIP)
	// Получим ссылки на таблицы
	reporth	= ТаблицыИКлючи.Получить("reporth");
	crprests= ТаблицыИКлючи.Получить("crprests");
	crpsecur= ТаблицыИКлючи.Получить("crpsecur");
	crpdetl	= ТаблицыИКлючи.Получить("crpdetl");
	loadreg	= ТаблицыИКлючи.Получить("loadreg");
	//----
	Если reporth = Неопределено ИЛИ crprests = Неопределено ИЛИ crpsecur = Неопределено ИЛИ crpdetl = Неопределено ИЛИ loadreg = Неопределено Тогда
		Возврат;
	КонецЕсли;
	//----
	Если Не reporth = Неопределено Тогда
		//---
		ДатаУведомления			= reporth[0].REG_DATE;
		ВремяУведомления		= СокрЛП(reporth[0].TREG_DATE);
		// Если дата уведомления не входит в период, то пропускаем
		Если Дата(Формат(ДатаУведомления, "ДФ=yyyyMMdd"))<НачалоДня(ПериодНачало) Тогда
			Возврат;
		КонецЕсли;
		// Создание строки по раскрытию
		НоваяСтрока	= ДанныеРаскрытияСпискаВладельцев.Добавить();
		//---
		НоваяСтрока.Обрабатывать			= Истина;
		//---
		НоваяСтрока.Организация				= Константы.ОрганизацияПоУмолчанию.Получить();
		НоваяСтрока.Инициатор				= Константы.МестоХраненияПоУмолчанию.Получить();
		НоваяСтрока.ВходящийДокументДата	= Дата(Формат(ДатаУведомления, "ДФ=yyyyMMdd")+СтрЗаменить(ВремяУведомления, ":", ""));
		НоваяСтрока.ВходящийДокументНомер	= СокрЛП(reporth[0].REG_NO);
		//---
		СтрокаТЧСоответствиеИдФайлам = СоответствиеИдФайлам.Найти(ФайлZIP.ПолноеИмя, "ИмяАрхива");
		Если НЕ СтрокаТЧСоответствиеИдФайлам = Неопределено Тогда
			НоваяСтрока.REPORT_ID	= СтрокаТЧСоответствиеИдФайлам.REPORT_ID;
			НоваяСтрока.Комментарий	= СтрокаТЧСоответствиеИдФайлам.Комментарий;
		Иначе
			ВызватьИсключение "Не удалось определить 'REPORT_ID' по входящему №"
				+ НоваяСтрока.ВходящийДокументНомер + " от: " + НоваяСтрока.ВходящийДокументДата;
		КонецЕсли;		
		
		НоваяСтрока.ДатаПоступленияЗапроса = reporth[0].REG_DATE;
		// Определим есть ли в 1С уже существующий документ
		НоваяСтрока.ДокументРаскрытия	= ПолучитьРаскрытиеСпискаВладельцев(НоваяСтрока.REPORT_ID);
		//---
		Если Не crprests = Неопределено Тогда 
			Если crprests.Количество()>0 Тогда
				НайденныйСчетДЕПО		= Справочники.СчетаДепоМХ.НайтиПоКоду(СокрЛП(crprests[0].DEPO_ACC_C));
				Если Не ЗначениеЗаполнено(НайденныйСчетДЕПО) Тогда
					НоваяСтрока.СчетДЕПО	= СчетДЕПО_ПоУмолчанию;
				Иначе
					НоваяСтрока.СчетДЕПО	= НайденныйСчетДЕПО;
				КонецЕсли;
			КонецЕсли;
			Для Каждого Строка ИЗ crprests Цикл
				Если Не ЗначениеЗаполнено(НоваяСтрока.ЦеннаяБумага1) Тогда
					НоваяСтрока.ЦеннаяБумага1			= ПолучитьЦеннуюБумагуПоКодуНРД(СокрЛП(Строка.SECURITY_C));
					НоваяСтрока.ЦеннаяБумага1Остаток	= Строка.REST;
				Иначе
					НоваяСтрока.ЦеннаяБумага2			= ПолучитьЦеннуюБумагуПоКодуНРД(СокрЛП(Строка.SECURITY_C));
					НоваяСтрока.ЦеннаяБумага2Остаток	= Строка.REST;
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
		//---
		НоваяСтрока.Эмитент	= НоваяСтрока.ЦеннаяБумага1.Эмитент;
		Если ЗначениеЗаполнено(НоваяСтрока.ЦеннаяБумага1) И ЗначениеЗаполнено(НоваяСтрока.ЦеннаяБумага2) Тогда
			Если НоваяСтрока.ЦеннаяБумага1.Эмитент <> НоваяСтрока.ЦеннаяБумага2.Эмитент Тогда
				ВызватьИсключение "При формирова списка 'Раскрытие списка владельцев' - по входящему №"+НоваяСтрока.ВходящийДокументНомер+" от: "+НоваяСтрока.ВходящийДокументДата+" - определены ЦБ с разными 'Эмитентами'";
			КонецЕсли;
		КонецЕсли;		
        //---
		Если Не crpdetl = Неопределено Тогда
			Если crpdetl.Количество()>0 Тогда
				Для Каждого Строка ИЗ crpdetl Цикл
					ВидСвязанногоКдКод	= СокрЛП(Строка.CA_TYP_LN);
					ВидСвязанногоКдИмя	= СокрЛП(Строка.CA_NAM_LN);
					//---
					ВидСвязанногоКД		= Справочники.ВидыКорпоративныхДействий.НайтиПоКоду(ВидСвязанногоКдКод);
					Если Не ЗначениеЗаполнено(ВидСвязанногоКД) И ЗначениеЗаполнено(ВидСвязанногоКдКод) Тогда
						ВидСвязанногоКДОбъект				= Справочники.ВидыКорпоративныхДействий.СоздатьЭлемент();
						ВидСвязанногоКДОбъект.Код			= ВидСвязанногоКдКод;
						ВидСвязанногоКДОбъект.Наименование	= ВидСвязанногоКдИмя;
						ВидСвязанногоКДОбъект.Записать();
						//---
						ВидСвязанногоКД	= ВидСвязанногоКДОбъект.Ссылка;						
					КонецЕсли;
					//---
					СвязанныйРеференсКД	= СокрЛП(Строка.CA_REF_LN);
					Если ЗначениеЗаполнено(ВидСвязанногоКдКод) И ЗначениеЗаполнено(СвязанныйРеференсКД) Тогда
						Если Не ЗначениеЗаполнено(НоваяСтрока.СвязанныйРеференсКД1) Тогда
							НоваяСтрока.СвязанныйВидКД1		= ВидСвязанногоКД;
							НоваяСтрока.СвязанныйРеференсКД1= СвязанныйРеференсКД;
						Иначе
							НоваяСтрока.СвязанныйВидКД2		= ВидСвязанногоКД;
							НоваяСтрока.СвязанныйРеференсКД2= СвязанныйРеференсКД;
						КонецЕсли;
					КонецЕсли;
				КонецЦикла;
			КонецЕсли;
		КонецЕсли;
		//---
		Если Не loadreg = Неопределено Тогда
			Если loadreg.Количество()>0 Тогда
				ВалютаРаскрытия	= СокрЛП(loadreg[0].CURRENCY_C);
				ВидКДКод		= СокрЛП(loadreg[0].C_T_CODE);
				ВидКДИмя		= СокрЛП(loadreg[0].C_T_NAME);
				ТипСпискаКод	= СокрЛП(loadreg[0].R_D_CODE);
				//---
				ВидКД		= Справочники.ВидыКорпоративныхДействий.НайтиПоКоду(ВидКДКод);
				Если Не ЗначениеЗаполнено(ВидКД) И ЗначениеЗаполнено(ВидКДКод) Тогда
					ВидКДОбъект				= Справочники.ВидыКорпоративныхДействий.СоздатьЭлемент();
					ВидКДОбъект.Код			= ВидКДКод;
					ВидКДОбъект.Наименование= ВидКДИмя;
					ВидКДОбъект.Записать();
					//---
					ВидКД	= ВидКДОбъект.Ссылка;						
				КонецЕсли;
				//---
				НоваяСтрока.ВидКорпоративногоДействия	= ВидКД;
				НоваяСтрока.КДРеференс					= СокрЛП(loadreg[0].REFERENCE);
				НоваяСтрока.ДатаФиксации				= loadreg[0].FIXING_DAT;
				НоваяСтрока.ДатаОкончанияПриема			= Дата(Формат(loadreg[0].FINISH_DAT, "ДФ=yyyyMMdd")+СтрЗаменить(loadreg[0].TFINISH_DA, ":", "")); 
				//---
				
				КодировкаNDC = Константы.КодировкаNDC.Получить();
				Если НЕ ЗначениеЗаполнено(КодировкаNDC) Тогда
					ВызватьИсключение "Константа Кодировка NDC не заполнена! Дальнейшая работа обработки невозможна.";
				КонецЕсли; 
				ОснованиеЗапросаПредварительно = СокрЛП(loadreg[0].BASE_ON);
				ОснованиеЗапроса = СтроковыеФункцииКлиентСервер.ИзменитьКодировкуСтроки(ОснованиеЗапросаПредварительно, КодировкаNDC);
				НоваяСтрока.ОснованиеЗапроса = ОснованиеЗапроса;
				
				Если ЗначениеЗаполнено(ВалютаРаскрытия) Тогда
					Валюта	= Справочники.Валюты.НайтиПоНаименованию(?(ВалютаРаскрытия="RUB", "SUR", ВалютаРаскрытия));
					Если Не ЗначениеЗаполнено(Валюта) Тогда
						Валюта	= ЗагрузитьВалютуИзКлассификатора(?(ВалютаРаскрытия="RUB", "SUR", ВалютаРаскрытия));
					КонецЕсли;
				Иначе
					Валюта	= НоваяСтрока.ЦеннаяБумага1.ВалютаНоминала;
				КонецЕсли;
				//---
				НоваяСтрока.БанковскийСчет	= ПолучитьБанковскийСчет(НоваяСтрока.Организация, Валюта);
				//---
				ТипСписка	= Справочники.РСВ_ТипСписка.НайтиПоКоду(ТипСпискаКод);
				Если Не ЗначениеЗаполнено(ТипСписка) И ЗначениеЗаполнено(ТипСпискаКод) Тогда
					ТипСпискаОбъект				= Справочники.РСВ_ТипСписка.СоздатьЭлемент();
					ТипСпискаОбъект.Код			= ВидКДКод;
					ТипСпискаОбъект.Записать();
					//---
					ТипСписка	= ТипСпискаОбъект.Ссылка;						
				КонецЕсли;
				НоваяСтрока.ТипСписка	= ТипСписка;
				//---
			КонецЕсли;
		КонецЕсли;
		//---
	КонецЕсли;	
КонецПроцедуры

//***********************************************************************************************
// Формирование документов
//***********************************************************************************************

Процедура СформироватьДокументы() Экспорт
	Для Каждого Строка ИЗ ДанныеРаскрытияСпискаВладельцев Цикл
		//---
		Если Не Строка.Обрабатывать Тогда
			Продолжить;
		КонецЕсли;
		//---
		Если ЗначениеЗаполнено(Строка.ДокументРаскрытия) Тогда
			РаскрытиеСписка	= Строка.ДокументРаскрытия.ПолучитьОбъект();
			ОчиститьОбъектРаскрытиеСпискаВладельцев(РаскрытиеСписка);
		Иначе
			РаскрытиеСписка	= Документы.РаскрытиеСпискаВладельцев.СоздатьДокумент();
		КонецЕсли;
		//---
		ЗаполнитьЗначенияСвойств(РаскрытиеСписка, Строка);
		//---
		РаскрытиеСписка.Дата						= ТекущаяДата();
		РаскрытиеСписка.Автор						= ПараметрыСеанса.ТекущийПользователь;
		РаскрытиеСписка.ТипЗагрузкиСписковРаскрытия	= ТипЗагрузкиСписковРаскрытия;
		РаскрытиеСписка.ВыгрузкаPARTADВCоответствииCоCтатьей8_6_1 = (Найти(РаскрытиеСписка.Комментарий, "8.6-1") > 0);
		//---
		Если ЗначениеЗаполнено(РаскрытиеСписка.СвязанныйРеференсКД1) Тогда
			РаскрытиеСписка.КарточкаКД 					= Документы.КорпоративноеДействие_Новый.КорпоративноеДействиеПоРеференсу(РаскрытиеСписка.СвязанныйРеференсКД1);
		КонецЕсли;
		ОписаниеОшибки	= "";
		НовыйДок		= РаскрытиеСписка.ЭтоНовый();
		РаскрытиеСписка.Записать();
		Если НовыйДок Тогда
			#Если Клиент Тогда
				Сообщить("Создан документ - " + РаскрытиеСписка.Ссылка);
			#Иначе
				ЗаписьЖурналаРегистрации("Загрузка 'Раскрытия списка владельцев'", УровеньЖурналаРегистрации.Информация, , , "Создан документ - " + РаскрытиеСписка.Ссылка);
			#КонецЕсли
		Иначе
			#Если Клиент Тогда
				Сообщить("Изменен документ - " + РаскрытиеСписка.Ссылка);
			#Иначе
				ЗаписьЖурналаРегистрации("Загрузка 'Раскрытия списка владельцев'", УровеньЖурналаРегистрации.Информация, , , "Изменен документ - " + РаскрытиеСписка.Ссылка);
			#КонецЕсли
		КонецЕсли;
		//---
		Строка.Обрабатывать	= Ложь;
		//---
		Строка.ДокументРаскрытия	= РаскрытиеСписка.Ссылка;
		
		Если ЗначениеЗаполнено(РаскрытиеСписка.КарточкаКД) Тогда
			ЗарегистрироватьЭтапКД(РаскрытиеСписка.Ссылка);
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

