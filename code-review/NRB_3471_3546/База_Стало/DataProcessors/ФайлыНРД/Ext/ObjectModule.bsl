// Возвращает полное имя первого найденного zip-файла в дереве каталогов, начиная с указанного каталога
Функция НайтиZIPФайл(Каталог)
	Файлы = НайтиФайлы(Каталог.ПолноеИмя, "*.*");
	Для Каждого Файл Из Файлы Цикл
		Если Файл.ЭтоФайл() И ВРЕГ(Файл.Расширение) = ВРЕГ(".zip") Тогда
			Возврат Файл.ПолноеИмя;
		КонецЕсли;
		
		Если Файл.ЭтоКаталог() Тогда
			ИмяФайла = НайтиZIPФайл(Файл);
			Если ЗначениеЗаполнено(ИмяФайла) Тогда
				Возврат ИмяФайла;
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	Возврат "";
КонецФункции

