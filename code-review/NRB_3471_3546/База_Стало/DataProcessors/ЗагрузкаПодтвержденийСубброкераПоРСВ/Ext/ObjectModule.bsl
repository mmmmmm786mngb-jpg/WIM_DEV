	|	ТЗ.АдресПочтовыйИндекс КАК АдресПочтовыйИндекс,
	|	ТЗ.АдресПочтовыйСтрана КАК АдресПочтовыйСтрана,
	|	ТЗ.ГражданствоФЛ КАК ГражданствоФЛ,
	|	ТЗ.ДатаРожденияФЛ КАК ДатаРожденияФЛ,
	|	ТЗ.ДоговорСубброкера КАК ДоговорСубброкера,
	|	ТЗ.ДокументВладельцаДатаВыдачи КАК ДокументВладельцаДатаВыдачи,
	|	ТЗ.ДокументВладельцаНомер КАК ДокументВладельцаНомер,
	|	ТЗ.ДокументВладельцаОрганВыдачи КАК ДокументВладельцаОрганВыдачи,
	|	ТЗ.ДокументВладельцаСерия КАК ДокументВладельцаСерия,
	|	ТЗ.ДокументВладельцаТип КАК ДокументВладельцаТип,
	|	ТЗ.КодЗагрузкиЦБ КАК КодЗагрузкиЦБ,
	|	ТЗ.КодКлиента КАК КодКлиента,
	|	ТЗ.КодСубброкера КАК КодСубброкера,
	|	ТЗ.КодСубклиента КАК КодСубклиента,
	|	ТЗ.Количество КАК Количество,
	|	ТЗ.НаличиеНалоговыхЛьгот КАК НаличиеНалоговыхЛьгот,
	|	ТЗ.НалоговаяСтавка КАК НалоговаяСтавка,
	|	ТЗ.НомерСчетаДепоКлиента КАК НомерСчетаДепоКлиента,
	|	ТЗ.ПолноеНаименованиеЛица КАК ПолноеНаименованиеЛица,
	|	ТЗ.ПолноеНаименованиеЮЛФЛСубклиента КАК ПолноеНаименованиеЮЛФЛСубклиента,
	|	ТЗ.ПризнакЮЛФЛ КАК ПризнакЮЛФЛ,
	|	ТЗ.РазделСчетаДепо КАК РазделСчетаДепо,
	|	ТЗ.СтатусНалогоплательщика КАК СтатусНалогоплательщика,
	|	ТЗ.Субброкер КАК Субброкер,
	|	ТЗ.СчетДепо КАК СчетДепо,
	|	ТЗ.ТипСчета КАК ТипСчета,
	|	&ЦеннаяБумага КАК ЦеннаяБумага,
	|	ВЫБОР
	|		КОГДА ВЫРАЗИТЬ(ТЗ.РазделСчетаДепо КАК Справочник.РазделыСчетаДепо).РазделСубклиента
	|			ТОГДА ВЫРАЗИТЬ(ТЗ.РазделСчетаДепо КАК Справочник.РазделыСчетаДепо).Субклиент
	|		ИНАЧЕ ТЗ.ПолноеНаименованиеЛица
	|	КОНЕЦ КАК Субклиент
	|ИЗ
	|	ТЗ КАК ТЗ");
	
	Запрос.УстановитьПараметр("ТЗ",	ЭтотОбъект.Подтверждения.Выгрузить());
	Запрос.УстановитьПараметр("ЦеннаяБумага",	ЭтотОбъект.ЦеннаяБумага);
	ТаблицаПодтверждений    = Запрос.Выполнить().Выгрузить();	
	ЭтотОбъект.Подтверждения.Загрузить(ТаблицаПодтверждений);
	
КонецПроцедуры

Процедура ДополнитьПодтвержденияСсылкамиНаОбъекты() Экспорт
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	ТЗ.НомерСчетаДепоКлиента КАК НомерСчетаДепоКлиента,
	|	ТЗ.КодСубброкера КАК КодСубброкера,
