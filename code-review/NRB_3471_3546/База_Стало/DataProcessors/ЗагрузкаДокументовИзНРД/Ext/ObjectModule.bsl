// Удаляет из строки комментария тип КД - подстроку "СтрокаПоиска: ХХХ", где ХХХ - произвольный код КД
Процедура УдалитьТипКД(СтрокаКомментария, СтрокаПоиска)
	ПозицияБлокаТипКД = Найти(СтрокаКомментария, СтрокаПоиска);
	Если ПозицияБлокаТипКД > 0 Тогда
		ПозицияХвоста = ПозицияБлокаТипКД + СтрДлина(СтрокаПоиска);
		СледующийПробел(СтрокаКомментария, ПозицияХвоста);
		СледующийНепробел(СтрокаКомментария, ПозицияХвоста);
		СледующийПробел(СтрокаКомментария, ПозицияХвоста);
		СледующийНепробел(СтрокаКомментария, ПозицияХвоста);
		
		СтрокаКомментария = СокрЛП(Лев(СтрокаКомментария, ПозицияБлокаТипКД-1)) + " "
		+ Сред(СтрокаКомментария, ПозицияХвоста);
	КонецЕсли;
КонецПроцедуры

Процедура СледующийПробел(Источник, Позиция)
	Символ = Сред(Источник, Позиция, 1);
	Пока Символ <> "" И Символ <> " " Цикл
		Позиция = Позиция + 1;
		Символ = Сред(Источник, Позиция, 1);
	КонецЦикла;
КонецПроцедуры

Процедура СледующийНепробел(Источник, Позиция)
	Символ = Сред(Источник, Позиция, 1);
	Пока Символ <> "" И Символ = " " Цикл
		Позиция = Позиция + 1;
		Символ = Сред(Источник, Позиция, 1);
	КонецЦикла;
КонецПроцедуры

Процедура Тест4490(ТестовыеФайлыХранилище) Экспорт
	
	ВремКаталог = РаботаСФайлами.СоздатьВременныйКаталог();
	ТестовыеФайлы = Новый Массив;
	
	Для Каждого ТестовыйФайлХранилище Из ТестовыеФайлыХранилище Цикл
		ФайлПроверка = Новый Файл(ТестовыйФайлХранилище.Имя);
		Файл = Новый Файл(ВремКаталог+ФайлПроверка.Имя);
		ДвоичныеДанные = ПолучитьИзВременногоХранилища(ТестовыйФайлХранилище.АдресХранилище);
		ДвоичныеДанные.Записать(Файл.ПолноеИмя);
		ТестовыеФайлы.Добавить(Файл);
	КонецЦикла;
	
	ЗаполнитьТаблицы(ТестовыеФайлы);
	
	РаботаСФайлами.УдалитьКаталог(ВремКаталог);
	
КонецПроцедуры

Функция ЭтоТаблицаТиповЦБ(ТаблицаDOM)
	
	Если Не ТаблицаDOM.ЕстьДочерниеУзлы() Тогда
		Возврат Ложь;
	КонецЕсли; 
	
	Ячейки = ТаблицаDOM.ПолучитьЭлементыПоИмени("TD");
	
	Если  Найти(Ячейки[0].ТекстовоеСодержимое, "Номер счета депо") > 0 Тогда
		Возврат Истина;
	Иначе
		Возврат Ложь;
	КонецЕсли;
	
КонецФункции

Функция ТипЦБ(ТаблицаДокумента)
	ТипЦБ = Перечисления.ТипыЦБ.Акция;
	Для Каждого Элемент Из ТаблицаДокумента.ДочерниеУзлы Цикл
		Если Элемент = Неопределено Или ВРег(Элемент.ИмяУзла) <> "TD" Тогда
			Продолжить;
		КонецЕсли; 
		
		Если ВРег(СокрЛП(Элемент.ТекстовоеСодержимое)) = "ИТОГО" Тогда
			Прервать;
		ИначеЕсли Найти(ВРег(Элемент.ТекстовоеСодержимое),"ОБЛИГАЦИИ") > 0 Тогда
			ТипЦБ = Перечисления.ТипыЦБ.Облигация;
			Прервать;
		ИначеЕсли Найти(ВРег(Элемент.ТекстовоеСодержимое),"ПАИ") > 0 Тогда
			ТипЦБ = Перечисления.ТипыЦБ.Пай;
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	Возврат ТипЦБ;
КонецФункции

