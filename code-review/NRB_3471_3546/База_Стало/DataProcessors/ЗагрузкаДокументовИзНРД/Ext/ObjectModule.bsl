Процедура ПодобратьДепонентовПоРаскрытию(Поручение, КоличествоЦБ, РазделСчетаДепо, СтавкаНалога, ДанныеПоБумагамДляРасчета)
	
	Поручение.СтавкаНалога = СтавкаНалога;
	
	Поручение.РазделСчетаДепоМХ = Справочники.РазделыСчетаДепоМХ.НайтиПоКоду(РазделСчетаДепо, , , СчетДепоМХ);
	Если Не ЗначениеЗаполнено(Поручение.РазделСчетаДепоМХ) Тогда
		Поручение.ОшибкаЗаполненияДепонентов = "Не найден раздел счета депо МХ с кодом "+РазделСчетаДепо;
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(Поручение.ОшибкаЗаполненияДепонентов);
		Возврат;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("КорпоративноеДействие", Поручение.КарточкаКД);
	Запрос.УстановитьПараметр("РазделСчетаДепоМХ", Поручение.РазделСчетаДепоМХ);
	Запрос.УстановитьПараметр("СтавкаНалога", Поручение.СтавкаНалога);
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	РаскрытиеСпискаВладельцев.Ссылка КАК Ссылка,
	|	РаскрытиеСпискаВладельцев.Представление КАК Представление,
	|	РаскрытиеСпискаВладельцев.ЦеннаяБумага1 КАК ЦеннаяБумага1
	|ИЗ
	|	Документ.КорпоративноеДействие_Новый КАК КорпоративноеДействие
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.КорпоративноеДействие_Новый КАК КорпоративноеДействиеWTRC
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.РаскрытиеСпискаВладельцев КАК РаскрытиеСпискаВладельцев
	|			ПО КорпоративноеДействиеWTRC.Ссылка = РаскрытиеСпискаВладельцев.КарточкаКД
	|				И (НЕ РаскрытиеСпискаВладельцев.ПометкаУдаления)
	|		ПО (ПОДСТРОКА(КорпоративноеДействиеWTRC.КДРеференсСвязанный, 1, 6) = ПОДСТРОКА(КорпоративноеДействие.КДРеференс, 1, 6))
	|			И КорпоративноеДействие.Ссылка <> КорпоративноеДействиеWTRC.Ссылка
	|			И (КорпоративноеДействиеWTRC.КДРеференсСвязанный <> """")
	|			И (КорпоративноеДействиеWTRC.ВидКД.Код = ""WTRC"")
	|			И (НЕ КорпоративноеДействиеWTRC.ПометкаУдаления)
	|ГДЕ
	|	КорпоративноеДействие.Ссылка = &КорпоративноеДействие
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ПоручениеЦенныеБумагиСписываемые.Ссылка КАК Ссылка,
	|	ПоручениеЦенныеБумагиСписываемые.Ссылка.СтавкаНалога КАК СтавкаНалога,
	|	ПоручениеЦенныеБумагиСписываемые.Ссылка.СтатусПоГлаве4 КАК СтатусПоГлаве4,
	|	ПоручениеЦенныеБумагиСписываемые.СчетДепо.Владелец КАК СчетДепоВладелец,
	|	ПоручениеЦенныеБумагиСписываемые.СчетДепо КАК СчетДепо,
	|	ПоручениеЦенныеБумагиСписываемые.РазделСчетаДепо КАК РазделСчетаДепо,
	|	ПоручениеЦенныеБумагиСписываемые.СчетДепоМХ КАК СчетДепоМХ,
	|	ПоручениеЦенныеБумагиСписываемые.РазделСчетаДепоМХ КАК РазделСчетаДепоМХ,
	|	ПоручениеЦенныеБумагиСписываемые.Количество КАК Количество,
	|	ПоручениеЦенныеБумагиСписываемые.Ссылка.СтатусПоГлаве4 КАК СтатусПоГлаве41
	|ИЗ
	|	Документ.Поручение.ЦенныеБумагиСписываемые КАК ПоручениеЦенныеБумагиСписываемые
	|ГДЕ
	|	ПоручениеЦенныеБумагиСписываемые.Ссылка.КарточкаКД = &КорпоративноеДействие
	|	И НЕ ПоручениеЦенныеБумагиСписываемые.Ссылка.ПометкаУдаления
	|	И ПоручениеЦенныеБумагиСписываемые.Ссылка.СтавкаНалога = &СтавкаНалога
	|	И ПоручениеЦенныеБумагиСписываемые.Ссылка.РазделСчетаДепоМХ = &РазделСчетаДепоМХ";
	Результаты = Запрос.ВыполнитьПакет();
	
	ВыборкаРаскрытий = Результаты[0].Выбрать();
	Если ВыборкаРаскрытий.Следующий() Тогда
		СуществующиеПоручения = Результаты[1].Выбрать();
		СуммарныеДанныеПоРСВ = ДанныеПоБумагамДляРасчета.СкопироватьКолонки();
		СуммарныеДанныеПоРСВ.Колонки.Добавить("СтатусПоГлаве4");
		ПоляГруппировки = "ЦеннаяБумага,Депонент,СчетДепо,СчетДепоМХ,РазделСчетаДепо,РазделСчетаДепоМХ";
		
		КоличестваПоСтатусам = КоличестваПоСтатусам(ВыборкаРаскрытий.Ссылка, Поручение.РазделСчетаДепоМХ, Поручение.СтавкаНалога);
		Для Каждого ВыборкаСтатусПоГлаве4 Из КоличестваПоСтатусам.Строки Цикл
					Если СуществующиеПоручения.НайтиСледующий(ВыборкаСтатусПоГлаве4.СтатусПоГлаве4, "СтатусПоГлаве4") // уже есть поручение с таким статусом по главе 4
						И Поручение.СтатусПоГлаве4 <> ВыборкаСтатусПоГлаве4.СтатусПоГлаве4 // но мы перезаполняем не его
						Или ВыборкаСтатусПоГлаве4.КоличествоЦБ <> КоличествоЦБ Тогда // поскольку статус по главе неизвестен, ориентируемся по количеству ЦБ
						Таблица = СуммарныеДанныеПоРСВ; // собираем все статусы на случай, если не найдём подходящего
						СуществующиеПоручения.Сбросить();
					Иначе
						Таблица = СуммарныеДанныеПоРСВ.СкопироватьКолонки();
						Поручение.СтатусПоГлаве4 = ВыборкаСтатусПоГлаве4.СтатусПоГлаве4;
					КонецЕсли;
					
					Для Каждого Выборка Из ВыборкаСтатусПоГлаве4.Строки Цикл
						Если Выборка.КоличествоЦБ = КоличествоЦБ Тогда // есть строка с нужным количеством (ИПД по поздно исполненной сделке)
							Таблица = СуммарныеДанныеПоРСВ.СкопироватьКолонки();
							Поручение.СтатусПоГлаве4 = ВыборкаСтатусПоГлаве4.СтатусПоГлаве4;
						КонецЕсли;
						Строка = Таблица.Добавить();
						Строка.ЦеннаяБумага = ВыборкаРаскрытий.ЦеннаяБумага1;
						Строка.Депонент = Выборка.Клиент;
						Строка.СчетДепо = Выборка.СчетДепо;
						Строка.СчетДепоМХ = СчетДепоМХ;
						Строка.РазделСчетаДепо = Выборка.РазделСчетаДепо;
						Строка.РазделСчетаДепоМХ = Поручение.РазделСчетаДепоМХ;
						Строка.СтатусПоГлаве4 = Выборка.СтатусПоГлаве4;
						Строка.Количество = Выборка.КоличествоЦБ;
						Если Выборка.КоличествоЦБ = КоличествоЦБ Тогда
							Прервать;
						КонецЕсли;
					КонецЦикла;
					
					Если Таблица <> СуммарныеДанныеПоРСВ Тогда // значит удалось подобрать статус по количеству
						Таблица.Свернуть(ПоляГруппировки, "Количество");
						ДанныеПоБумагамДляРасчета = Таблица;
						Возврат;
					КонецЕсли;
		КонецЦикла;
		Если ЗначениеЗаполнено(СуммарныеДанныеПоРСВ) Тогда
			Разница = СуммарныеДанныеПоРСВ.Итог("Количество") - КоличествоЦБ;
			Если Разница > 0 Тогда // Попробуем найти лишнее количество
				Для Каждого Строка Из СуммарныеДанныеПоРСВ Цикл
					Если Строка.Количество = Разница Тогда
						СуммарныеДанныеПоРСВ.Удалить(Строка);
						Прервать;
					КонецЕсли;
				КонецЦикла;
			КонецЕсли;
			Таблица = СуммарныеДанныеПоРСВ.Скопировать();
			Таблица.Свернуть("СтатусПоГлаве4");
			Если Таблица.Количество() > 1 Тогда
				Поручение.ОшибкаЗаполненияДепонентов = "Не удалось подобрать подходящий статус по главе 4 в "+ВыборкаРаскрытий.Представление;
			Иначе
				Поручение.СтатусПоГлаве4 = Таблица[0].СтатусПоГлаве4;
			КонецЕсли;
			СуммарныеДанныеПоРСВ.Свернуть(ПоляГруппировки, "Количество");
			ДанныеПоБумагамДляРасчета = СуммарныеДанныеПоРСВ;
		Иначе
			Поручение.ОшибкаЗаполненияДепонентов = "Не удалось найти подходящий субсчет и ставку в "+ВыборкаРаскрытий.Представление;
		КонецЕсли;
	Иначе	
		Поручение.ОшибкаЗаполненияДепонентов = "Не удалось найти раскрытие списка владельцев по указанному КД!";
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Поручение.ОшибкаЗаполненияДепонентов) Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(Поручение.ОшибкаЗаполненияДепонентов);
	КонецЕсли;
	
КонецПроцедуры

Функция КоличестваПоСтатусам(РСВ, РазделСчетаДепоМХ, НалоговаяСтавка)
	Результат = Новый ДеревоЗначений;
	Результат.Колонки.Добавить("СтатусПоГлаве4");
	Результат.Колонки.Добавить("КоличествоЦБ");
	Результат.Колонки.Добавить("Клиент");
	Результат.Колонки.Добавить("СчетДепо");
	Результат.Колонки.Добавить("РазделСчетаДепо");
	Если РСВ.СводноеРаскрытие.Количество() > 0 Тогда
		Строки = РСВ.СводноеРаскрытие.НайтиСтроки(Новый Структура("РазделСчетаДепоМХ,НалоговаяСтавка", РазделСчетаДепоМХ, НалоговаяСтавка));
		Для Каждого Строка Из Строки Цикл
			Если Не ЗначениеЗаполнено(Строка.СтатусПоГлаве4) Тогда
				Продолжить; // Пропускаем итоговую запись налоговой ставки
			ИначеЕсли Не ЗначениеЗаполнено(Строка.СчетДепоМХ) Тогда // Он заполнен только в детальных записях
				ИтогСтатуса = Результат.Строки.Добавить();
				ИтогСтатуса.СтатусПоГлаве4 = Строка.СтатусПоГлаве4;
				ИтогСтатуса.КоличествоЦБ = Строка.КоличествоЦБ;
			Иначе		
				ЗаполнитьЗначенияСвойств(ИтогСтатуса.Строки.Добавить(), Строка);
			КонецЕсли;
		КонецЦикла;
	Иначе
		Раскрытие = РСВ.ПолучитьОбъект();
		ДанныеРаскрытия = Раскрытие.ВыборкаДанныхЗаполненияСводногоРСВ();
		
		Разделы = ДанныеРаскрытия.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		Пока Разделы.Следующий() Цикл
			
			Если Разделы.РазделСчетаДепоМХ <> РазделСчетаДепоМХ Тогда
				Продолжить;
			КонецЕсли;
			
			Ставки = Разделы.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
			Пока Ставки.Следующий() Цикл
				
				Если Ставки.НалоговаяСтавка <> НалоговаяСтавка Тогда
					Продолжить;
				КонецЕсли;
				
				Статусы = Ставки.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
				Пока Статусы.Следующий() Цикл
					
					ИтогСтатуса = Результат.Строки.Добавить();
					ИтогСтатуса.СтатусПоГлаве4 = Статусы.СтатусПоГлаве4;
					ИтогСтатуса.КоличествоЦБ = Статусы.КоличествоЦБ;
					
					Детали = Статусы.Выбрать();
					Пока Детали.Следующий() Цикл
						ЗаполнитьЗначенияСвойств(ИтогСтатуса.Строки.Добавить(), Детали);
					КонецЦикла;
				КонецЦикла;
			КонецЦикла;
		КонецЦикла;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Процедура РаспределитьСуммыПоКолонкамТаблицы(КолонкиИСуммы, Таблица)
	МаксимальноеКоличество = 0; СтрокаМасимальногоКоличества = Неопределено;
	СуммарноеКоличество = Таблица.Итог("Количество");
	Для Каждого Строка Из Таблица Цикл
		Для Каждого Элемент Из КолонкиИСуммы Цикл
			Строка[Элемент.Ключ] = Элемент.Значение / СуммарноеКоличество * Строка.Количество;
			Если Строка.Количество > МаксимальноеКоличество Тогда
				МаксимальноеКоличество = Строка.Количество;
				СтрокаМасимальногоКоличества = Строка;
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;
	Для Каждого Элемент Из КолонкиИСуммы Цикл
		СтрокаМасимальногоКоличества[Элемент.Ключ] = СтрокаМасимальногоКоличества[Элемент.Ключ] + (Элемент.Значение - Таблица.Итог(Элемент.Ключ));
	КонецЦикла;
КонецПроцедуры

Процедура СкорректироватьСуммуКВыплатеПоИПД(Таблица)
	Расхождения = Новый Массив;
	ИтогоРасхождений = 0;
	Для Каждого Строка Из Таблица Цикл
		Расхождение = Строка.Сумма - Строка.СуммаНалога - Строка.СуммаНалогаВИностраннойЮрисдикции
			- Строка.СуммаКомиссий - Строка.ДополнительныеУдержания - Строка.СуммаКВыплатеПоИПД;
		ИтогоРасхождений = ИтогоРасхождений + Расхождение;
		Расхождения.Добавить(Расхождение);
	КонецЦикла;
	Если ИтогоРасхождений = 0 Тогда
		Для Инд = 0 По Расхождения.Количество() - 1 Цикл
			Таблица[Инд].СуммаКВыплатеПоИПД = Таблица[Инд].СуммаКВыплатеПоИПД + Расхождения[Инд];
		КонецЦикла;
	КонецЕсли;
КонецПроцедуры

Функция КодировкаТекстаHTML(ИмяФайлаHTML)

	ЧтениеHTML = Новый ЧтениеHTML;
	ЧтениеHTML.ОткрытьФайл(ИмяФайлаHTML);
	
	ПостроительDOM = Новый ПостроительDOM;
	ДокументHTML   = ПостроительDOM.Прочитать(ЧтениеHTML);
	
	ЧтениеHTML.Закрыть();

	Возврат ДокументHTML.КодировкаИсточника;
	
КонецФункции

Функция МаскиПоискаПоПериоду(ПрефиксФайлов)
	
	МаскиПоиска = Новый Массив;
	Сутки = ОбщегоНазначенияПовтИсп.СекундВСутках();
	ДатаДляМаски = НачалоПериода;
	Пока ДатаДляМаски <= КонецПериода Цикл
		НомерДня = Формат(ДатаДляМаски, "ДФ=dd");
		НомерМесяца = СтроковыеФункцииКлиентСервер.МесяцВШестнадцатеричнойСистеме(Месяц(ДатаДляМаски));
		МаскиПоиска.Добавить(ПрефиксФайлов + НомерДня + НомерМесяца + "????*");
		ДатаДляМаски = ДатаДляМаски + Сутки;
	КонецЦикла;
	Возврат МаскиПоиска;
	
КонецФункции

Функция КаталогАрхиваФайловНаТекущуюДату()
	
	ВнешнийИсточникФайловыйШлюзКаталогАрхив = ПланыВидовХарактеристик.ВнешниеИсточники.ФайловыйШлюзКаталогАрхив;
	ПутьАрхив = ВнешниеДанные.ПолучитьПараметрыВнешнегоИсточника(ВнешнийИсточникФайловыйШлюзКаталогАрхив).Папка;
	
	Если Не ЗначениеЗаполнено(ПутьАрхив) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	ТекущийКаталогАрхиваНаДату = ПутьАрхив + "\" + Формат(ТекущаяДатаСеанса(), "ДФ=yyyy\MM\dd") + "\Депо\I";
	Возврат ТекущийКаталогАрхиваНаДату;
	
КонецФункции

Процедура ОповеститьОНаличииОбособленныхСчетов(ДанныеПоБумагамДляРасчета, НомерИПД, Номер, Дата)
	
	Для Каждого СтрокаДанных Из ДанныеПоБумагамДляРасчета Цикл
		Если СтрокаДанных.ТипРазделаСчетаДЕПО = Перечисления.ТипыРазделовСчетовДЕПО.БлокированоОбособленный Тогда
			ТекстОбособленныйСчет = "ИПД № " + НомерИПД + ", Поручение " + СокрЛП(Номер) + " от "
			+ Дата + " указан раздел с типом Блокировано (обособл.), Счет депо: " + СокрЛП(СтрокаДанных.СчетДепо)
			+ ", Раздел счета депо: " + СокрЛП(СтрокаДанных.РазделСчетаДепо)
			+ ?(ЗначениеЗаполнено(СтрокаДанных.ISIN), ", ISIN: " + СтрокаДанных.ISIN, "Регистрационный номер ЦБ: "
			+ СтрокаДанных.НомерРегистрации);
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстОбособленныйСчет);
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

ОбщегоНазначения.ЛогироватьИспользованиеОбъекта(ЭтотОбъект);
