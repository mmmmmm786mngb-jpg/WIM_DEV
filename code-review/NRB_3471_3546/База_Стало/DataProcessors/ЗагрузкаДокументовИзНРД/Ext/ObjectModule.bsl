Процедура ИнициироватьПараметры() Экспорт
	
	ИспользоватьФайловыйШлюз = РегистрыСведений.ПараметрыГлобальные.ЗначениеПараметра("7056.ИспользоватьФайловыйШлюз", Ложь);
	
	Организация = ?(ЗначениеЗаполнено(Организация)	, Организация	, Константы.ОрганизацияПоУмолчанию.Получить());
	Валюта		= ?(ЗначениеЗаполнено(Валюта)		, Валюта		, Константы.ВалютаРегламентированногоУчета.Получить()); 
	Депозитарий	= ?(ЗначениеЗаполнено(Депозитарий)	, Депозитарий	, Константы.МестоХраненияПоУмолчанию.Получить());
	// Установим счет Депо МХ если не заполнен (HL1212112991)
	СчетДепоМХ	= ?(ЗначениеЗаполнено(СчетДепоМХ)	, СчетДепоМХ	, Справочники.СчетаДепоМХ.НайтиПоКоду("HL1212112991", Истина, , Депозитарий)); 
	ТранзитныйСчетПоУмолчанию	= ?(ЗначениеЗаполнено(ТранзитныйСчетПоУмолчанию)	, ТранзитныйСчетПоУмолчанию	, Константы.ТранзитныйСчетПоУмолчанию.Получить());
	
	НачалоПериода	= ?(ЗначениеЗаполнено(НачалоПериода), НачалоДня(НачалоПериода), НачалоДня(ТекущаяДата()));
	КонецПериода	= ?(ЗначениеЗаполнено(КонецПериода)	, КонецДня(КонецПериода), КонецДня(ТекущаяДата()));
	
	ОписаниеТиповДата	= Новый ОписаниеТипов("Дата", , , Новый КвалификаторыДаты(ЧастиДаты.ДатаВремя));
	ОписаниеТиповЧисло	= Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(32, 10));
	ОписаниеТиповСтрока = Новый ОписаниеТипов("Строка", , Новый КвалификаторыСтроки(255, ДопустимаяДлина.Переменная));
	
КонецПроцедуры

