Процедура ЗагрузитьДивидендыКупоныИзВнешнегоИсточника(ТестовыеФайлы = Неопределено)
	Перем Соединение;
	Перем Команда;
	Перем RS;
	Перем Файлы;
	Перем КодировкаТекстаHTML;
	
	ТипСтрока = Новый ОписаниеТипов("Строка");
	ТипДата   = Новый ОписаниеТипов("Дата");
	Файлы = Новый ТаблицаЗначений;
	Файлы.Колонки.Добавить("ИмяФайлаHTML",ТипСтрока);
	Файлы.Колонки.Добавить("Дата",ТипДата);
	Файлы.Колонки.Добавить("Номер",ТипСтрока);
	Файлы.Колонки.Добавить("ПутьККаталогу",ТипСтрока);
	
	УдалитьФайлыПослеЗагрузки = Ложь;
	
	Если ТестовыеФайлы = Неопределено Тогда
		Если ИспользоватьФайловыйШлюз Тогда
			ФайловыйШлюзКаталогВходящие = ПланыВидовХарактеристик.ВнешниеИсточники.ФайловыйШлюзКаталогВходящие;
			КаталогВнешнегоИсточника = ВнешниеДанные.ПолучитьПараметрыВнешнегоИсточника(ФайловыйШлюзКаталогВходящие).Папка;
			ПрефиксФайлов = "I";
			МаскиПоискаФайлов = МаскиПоискаПоПериоду(ПрефиксФайлов);
			Для Каждого МаскаПоиска Из МаскиПоискаФайлов Цикл
				НайденныеКаталоги = НайтиФайлы(КаталогВнешнегоИсточника, МаскаПоиска);
				Для Каждого Каталог Из НайденныеКаталоги Цикл
					НайденныеФайлы = НайтиФайлы(Каталог.ПолноеИмя, "I???????*.HTM");
					Для Каждого НайденныйФайл Из НайденныеФайлы Цикл
						ФайлыСтрока = Файлы.Добавить();
						ФайлыСтрока.ИмяФайлаHTML	= НайденныйФайл.ПолноеИмя;
						ФайлыСтрока.ПутьККаталогу	= Каталог.ПолноеИмя;
						ФайлыСтрока.Номер			= "#" + Каталог.Имя;
					КонецЦикла;
				КонецЦикла;
			КонецЦикла;
		Иначе
			ВнешниеДанные.ADOConnect(Соединение, Команда, RS, ПланыВидовХарактеристик.ВнешниеИсточники.Луч, 300, 300);
			
			Команда.CommandText = ПолучитьТекстЗапросаSQL(НачалоПериода, КонецПериода);
			rs					= Команда.Execute();
			КолонкиСозданы		= Ложь;
			
			Пока Не rs.Eof() Цикл	
				
				ИмяВременногоАрхива = ПолучитьИмяВременногоФайла("ZIP");
				
				ЗаписатьЗначениеSQLВоВременныйФайл(rs.Fields("File_body").Value, ИмяВременногоАрхива);
				// Создаем временный каталог
				ИмяВременнойПапки = ПолучитьИмяВременногоФайла("TMP");
				
				СоздатьКаталог(ИмяВременнойПапки);
				// Разархивация
				ЧтениеАрхива = Новый ЧтениеZipФайла(ИмяВременногоАрхива); 
				ЧтениеАрхива.ИзвлечьВсе(ИмяВременнойПапки);
				
				ФайлыСтрока = Файлы.Добавить();
				ФайлыСтрока.ИмяФайлаHTML = ИмяВременнойПапки + "\" + rs.Fields("File_name").Value;
				ФайлыСтрока.Дата			= rs.Fields("doc_date").Value;
				ФайлыСтрока.Номер			= СокрЛП(rs.Fields("doc_num").Value);
				
				УдалитьФайлы(ИмяВременногоАрхива);
				rs.MoveNext();
			КонецЦикла;
			ВнешниеДанные.ADODisconnect(Соединение, Команда, RS);
			УдалитьФайлыПослеЗагрузки = Истина;
		КонецЕсли;
	Иначе
		Если ПравоДоступа("Администрирование",Метаданные) = Истина Тогда
			ТекВремя = ТекущаяДата();
			ТестовыйНомер = Час(ТекВремя)*10000 + Минута(ТекВремя)*100;
			ДлинаНомераПоручения = Метаданные.Документы.Поручение.ДлинаНомера;
			Для Каждого ФайлHTML Из ТестовыеФайлы Цикл
				ТестовыйНомер = ТестовыйНомер + 1;
				ФайлыСтрока = Файлы.Добавить();
				ФайлыСтрока.ИмяФайлаHTML = ФайлHTML.ПолноеИмя;
				ФайлыСтрока.Дата		 = ТекВремя;
				ФайлыСтрока.Номер		 = "test-"+СтроковыеФункцииКлиентСервер.ДополнитьСтроку(Формат(ТестовыйНомер,"ЧГ=0"), ДлинаНомераПоручения);
			КонецЦикла;
		Иначе
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Текст = "Вам недоступен режим тестирования загрузки документов из НРД!";
			Сообщение.Сообщить();
			Возврат;
		КонецЕсли;
	КонецЕсли;
	
	Для Каждого ФайлыСтрока Из Файлы Цикл
		
		КодировкаТекстаHTML = КодировкаТекстаHTML(ФайлыСтрока.ИмяФайлаHTML);
		
		Текст = Новый ЧтениеТекста(ФайлыСтрока.ИмяФайлаHTML, ?(НЕ ЗначениеЗаполнено(КодировкаТекстаHTML), КодировкаТекста.Системная, КодировкаТекстаHTML));
				
		Обрабатываем	= Ложь;
		ИзвещениеПоИностраннойЦеннойБумаге = Ложь;
		СтрокаТекста	= Текст.ПрочитатьСтроку();
		Пока СтрокаТекста <> Неопределено Цикл
			
			Если Найти(СтрокаТекста, "Извещение НКО ЗАО НРД") > 0 ИЛИ
				Найти(СтрокаТекста, "Извещение НКО АО НРД") > 0 Тогда
				Обрабатываем = Истина;
				Прервать;
			ИначеЕсли Найти(СтрокаТекста, "Извещение о выплате и перечислении денежных средств") > 0 Тогда
				ИзвещениеПоИностраннойЦеннойБумаге = Истина;
				Обрабатываем = Истина;
				Прервать;
			КонецЕсли;
			СтрокаТекста = Текст.ПрочитатьСтроку();
		КонецЦикла;
		Текст.Закрыть();
		
		Если Не Обрабатываем Тогда
			Продолжить;
		КонецЕсли;
		
		НоваяСтрока = ДивидендыКупоны.Добавить();
		НоваяСтрока.Дата			= ФайлыСтрока.Дата;
		НоваяСтрока.Номер			= ФайлыСтрока.Номер;
		НоваяСтрока.Идентификатор	= Новый УникальныйИдентификатор;
		НоваяСтрока.ПутьККаталогу	= ФайлыСтрока.ПутьККаталогу;
		
		ТаблицаЗначений	= Новый ТаблицаЗначений();
		Если ИзвещениеПоИностраннойЦеннойБумаге Тогда
			ПолучитьТаблицуЗначенийДивидендовКупоновИзФайлаПоИностраннойЦБ(ФайлыСтрока.ИмяФайлаHTML, ТаблицаЗначений, НоваяСтрока);
		Иначе
			ПолучитьТаблицуЗначенийДивидендовКупоновИзФайла(ФайлыСтрока.ИмяФайлаHTML, ТаблицаЗначений, НоваяСтрока);
		КонецЕсли;
		НоваяСтрока.ИзвещениеПоИностраннойЦеннойБумаге = ИзвещениеПоИностраннойЦеннойБумаге;
		
		Если НоваяСтрока.ТипЦБ = Перечисления.ТипыЦБ.Акция
			Или НоваяСтрока.ТипЦБ = Перечисления.ТипыЦБ.Пай Тогда
			Если Не ЗначениеЗаполнено(НоваяСтрока.ВидОперации) Тогда 
				НоваяСтрока.ВидОперации = ?(НоваяСтрока.ТипЦБ = Перечисления.ТипыЦБ.Акция,
				Справочники.ВидыОпераций.НачислениеДивидендов,
				Справочники.ВидыОпераций.НачислениеДоходаПрочие);
			КонецЕсли;
			ЗаполнитьСтрокиПриложенияПоТаблице(ТаблицаЗначений, НоваяСтрока, "Дивиденды");
			НайденныеСтрокиАОИ = ДивидендыПриложение.НайтиСтроки(Новый Структура("ТипЦБ, ИдентификаторСтрокиВладельца", "АОИ", НоваяСтрока.Идентификатор));
			НайденныеСтрокиАПИ = ДивидендыПриложение.НайтиСтроки(Новый Структура("ТипЦБ, ИдентификаторСтрокиВладельца", "АПИ", НоваяСтрока.Идентификатор));
			Если НайденныеСтрокиАОИ.Количество() > 0 И НайденныеСтрокиАПИ.Количество() > 0 Тогда
				СтрокаПоВторойБумаге = ДивидендыКупоны.Добавить();
				ЗаполнитьЗначенияСвойств(СтрокаПоВторойБумаге, НоваяСтрока);
				СтрокаПоВторойБумаге.Идентификатор = Новый УникальныйИдентификатор;
				СтрокаПоВторойБумаге.ВидЦБ = Перечисления.ВидыАкций.Привилегированная;
				СуммаКВыплатеПоАПИ = 0; СуммаКВыплатеПоАОИ = 0;
				СуммаПоАПИ = 0; СуммаПоАОИ = 0;
				Для Каждого СтрокаАОИ Из НайденныеСтрокиАОИ Цикл
					СуммаПоАОИ = СуммаПоАОИ + СтрокаАОИ.Сумма;
					СуммаКВыплатеПоАОИ = СуммаКВыплатеПоАОИ + СтрокаАОИ.КВыплате;
				КонецЦикла;
				НоваяСтрока.ОбщаяСумма = СуммаПоАОИ;
				НоваяСтрока.СуммаКВыплате = СуммаКВыплатеПоАОИ;
				НоваяСтрока.ВидЦБ = Перечисления.ВидыАкций.Обыкновенная;
				Для Каждого СтрокаАПИ Из НайденныеСтрокиАПИ Цикл
					СтрокаАПИ.ИдентификаторСтрокиВладельца = СтрокаПоВторойБумаге.Идентификатор;
					СуммаПоАПИ = СуммаПоАПИ + СтрокаАПИ.Сумма;
					СуммаКВыплатеПоАПИ = СуммаКВыплатеПоАПИ + СтрокаАПИ.КВыплате;
				КонецЦикла;
				СтрокаПоВторойБумаге.КодЦБ = СтрокаПоВторойБумаге.КодЦБПрив;
				СтрокаПоВторойБумаге.НаименованиеЦБ = СтрокаПоВторойБумаге.НаименованиеЦБПрив;
				СтрокаПоВторойБумаге.ОбщаяСумма = СуммаПоАПИ;
				СтрокаПоВторойБумаге.СуммаКВыплате = СуммаКВыплатеПоАПИ;
				
				СписокЦБ = Новый СписокЗначений;
				СписокЦБ.Добавить(НоваяСтрока.КодЦБ);
				СписокЦБ.Добавить(СтрокаПоВторойБумаге.КодЦБ);
				
				НаименованиеЦБИзПервойСтроки = НоваяСтрока.НаименованиеЦБ;
				НаименованиеЦБИзВторойСтроки = СтрокаПоВторойБумаге.НаименованиеЦБ;

				Запрос = Новый Запрос(
				"ВЫБРАТЬ
				|	ЦенныеБумаги.Ссылка КАК ЦБ,
				|	ЦенныеБумаги.ISIN КАК КодЦБ,
				|	ЦенныеБумаги.Наименование КАК НаименованиеЦБ,
				|	ЦенныеБумаги.ВидЦБ КАК ВидЦБ
				|ИЗ
				|	Справочник.ЦенныеБумаги КАК ЦенныеБумаги
				|ГДЕ
				|	НЕ ЦенныеБумаги.ПометкаУдаления
				|	И ЦенныеБумаги.ISIN В(&СписокЦенныхБумаг)");
				Запрос.УстановитьПараметр("СписокЦенныхБумаг", СписокЦБ);
				ТЗРезультат = Запрос.Выполнить().Выгрузить();
				Если ТЗРезультат.Количество() Тогда
					Для Каждого СтрокаТЗ Из ТЗРезультат Цикл
						Если НоваяСтрока.ВидЦБ = СтрокаТЗ.ВидЦБ Тогда
							Если НоваяСтрока.КодЦБ <> СтрокаТЗ.КодЦБ Тогда
								НоваяСтрока.КодЦБ = СтрокаТЗ.КодЦБ;
								НоваяСтрока.НаименованиеЦБ = НаименованиеЦБИзВторойСтроки;
							КонецЕсли;
						ИначеЕсли СтрокаПоВторойБумаге.ВидЦБ = СтрокаТЗ.ВидЦБ Тогда
							Если СтрокаПоВторойБумаге.КодЦБ <> СтрокаТЗ.КодЦБ Тогда
								СтрокаПоВторойБумаге.КодЦБ = СтрокаТЗ.КодЦБ;
								СтрокаПоВторойБумаге.НаименованиеЦБ = НаименованиеЦБИзПервойСтроки;
							КонецЕсли;
						КонецЕсли;
					КонецЦикла;
				КонецЕсли;
			КонецЕсли;
			
		ИначеЕсли НоваяСтрока.ТипЦБ = Перечисления.ТипыЦБ.Облигация Тогда
			
			УстановитьВидОперацииВСтрокеДивидендовИКупоновПоДополнительнойИнформации(Новый Структура("ДополнительнаяИнформация", НоваяСтрока.ДополнительнаяИнформация), НоваяСтрока);	                                                                                                                               
						
			ЗаполнитьСтрокиПриложенияПоТаблице(ТаблицаЗначений, НоваяСтрока, "Купоны");
			
		КонецЕсли;
		
		Если Не ЗначениеЗаполнено(НоваяСтрока.ВидКД) Тогда 
			НоваяСтрока.ВидКД = НоваяСтрока.ВидОперации.ВидКД;
		КонецЕсли;
		
	КонецЦикла;
	
	Если УдалитьФайлыПослеЗагрузки Тогда
		Для Каждого ФайлыСтрока Из Файлы Цикл
			УдалитьФайлы(ФайлыСтрока.ИмяФайлаHTML);
		КонецЦикла;
		Если ЗначениеЗаполнено(ИмяВременнойПапки) Тогда
			УдалитьФайлы(ИмяВременнойПапки);
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

Процедура ЗаполнитьТаблицы(ТестовыеФайлы = Неопределено) Экспорт
	
	ИнициироватьПараметры();
	
	ОчиститьТаблицы();
	
	ЗагрузитьДивидендыКупоныИзВнешнегоИсточника(ТестовыеФайлы);
	
	ОчиститьТаблицыОтСтрокПоСобственнымПоручениям();
	
	РассчитатьПоляОбщейТаблицы();
	
	ДополнитьОбщуюТаблицуСсылкамиНаЭлементыБазы();
	
	ДополнитьТаблицыПриложенийСсылкамиНаЭлементыБазы();
	
	ДивидендыКупоны.Сортировать("Номер ВОЗР");
	
	Для Каждого СтрокаТаблицы Из ДивидендыКупоны Цикл
		Если СтрокаТаблицы.ТипЦБ = Перечисления.ТипыЦБ.Акция
			Или СтрокаТаблицы.ТипЦБ = Перечисления.ТипыЦБ.Пай Тогда
			НоваяСтрока = Дивиденды.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТаблицы);
		КонецЕсли;
	КонецЦикла;
	Купоны.Загрузить(ДивидендыКупоны.Выгрузить(
	ДивидендыКупоны.НайтиСтроки(Новый Структура("ТипЦБ", Перечисления.ТипыЦБ.Облигация))));
	
	Конвертации.Очистить();
	ЭтоЗагрузкаИзЛУЧ = (ТестовыеФайлы = Неопределено) И Не ИспользоватьФайловыйШлюз;
	Если ЭтоЗагрузкаИзЛУЧ Тогда
		ОбработатьКонвертации(Конвертации);
	КонецЕсли; 
	
КонецПроцедуры

Процедура РассчитатьПоляОбщейТаблицы()
	Для Каждого Строка Из ДивидендыКупоны Цикл
		Строка.НомерИПД = СокрЛП(ВыделитьНомерИПД(Строка.НомерИсходящегоДокумента));
		
		Если ЗначениеЗаполнено(Строка.КодЦБ) И ЗначениеЗаполнено(Строка.КодЦБПрив) И Строка.КодЦБ = Строка.КодЦБПрив Тогда
			Строка.ВыплатаНа1ЦБ = Строка.ВыплатаНа1ЦБПрив;
		КонецЕсли;
		
	КонецЦикла;
КонецПроцедуры

Процедура ОбработатьКонвертации(ТаблицаКонвертаций)
	Перем Соединение;
	Перем Команда;
	Перем RS;
	
	ТаблицаКонвертаций.Очистить();
	
	ВнешниеДанные.ADOConnect(Соединение, Команда, RS, ПланыВидовХарактеристик.ВнешниеИсточники.Луч, 300, 300);
	
	Команда.CommandText = ПолучитьТекстЗапросаSQLПоКонвертациям(НачалоПериода, КонецПериода);
	
	rs = Команда.Execute();
	
	ИдентификаторКлиента = Неопределено;
	Пока Не rs.Eof() Цикл
		
		НоваяСтрока = ТаблицаКонвертаций.Добавить();
		НоваяСтрока.Дата = rs.Fields("doc_date").Value;
		НоваяСтрока.Номер = СокрЛП(rs.Fields("doc_num").Value);
		
		ИмяВременногоФайла = ПолучитьИмяВременногоФайла("zip");
		
		ИмяВременнойПапки = ПолучитьИмяВременногоФайла("TMP");
		
		СоздатьКаталог(ИмяВременнойПапки);
		
		ЗаписатьЗначениеSQLВоВременныйФайл(rs.Fields("File_body").Value, ИмяВременногоФайла);
		
		ЧтениеАрхива = Новый ЧтениеZipФайла(ИмяВременногоФайла); 
		ЧтениеАрхива.ИзвлечьВсе(ИмяВременнойПапки);
		
		База = Новый XBase(ИмяВременнойПапки + "\anysecur.dbf",,Истина);
		База.Кодировка = КодировкаXBase.OEM;
		Если База.Открыта() Тогда
			База.Первая();
			НоваяСтрока.НомерРаздела = СокрЛП(База.SECTION_CO);
			
			Пока Истина Цикл
				
				КоличествоЦБ = Число(СокрЛП(СтрЗаменить(База.SEQ_AMO, " ", "")));
				КодЦБ = СокрЛП(База.SECURITY_C);
				Если КоличествоЦБ < 0 Тогда
					НоваяСтрока.КодИсходнойЦБ = КодЦБ;
					НоваяСтрока.КоличествоИсходнойЦБ = КоличествоЦБ;
				ИначеЕсли КоличествоЦБ > 0 Тогда
					НоваяСтрока.КодИтоговойЦБ = КодЦБ;
					НоваяСтрока.КоличествоИтоговойЦБ = КоличествоЦБ;
				КонецЕсли;
				
				Если Не База.Следующая() Тогда
					Прервать;
				КонецЕсли;
				
			КонецЦикла;
			
			База.ЗакрытьФайл();
			
			НоваяСтрока.НомерСчетаДепо = ПолучитьЗначениеПоляПервойЗаписиФайла(ИмяВременнойПапки + "\anyacc.dbf", "DEPO_ACC_C");
			НоваяСтрока.Основание = ПолучитьЗначениеПоляПервойЗаписиФайла(ИмяВременнойПапки + "\anypar.dbf", "BASE_ON");
			
			ИмяТекстовогоФайла = ИмяВременнойПапки + ПолучитьИмяВременногоФайла(".txt");
			ЗаписьТекста = Новый ЗаписьТекста(ИмяТекстовогоФайла, КодировкаТекста.OEM);
			ЗаписьТекста.ЗаписатьСтроку(НоваяСтрока.Основание);
			ЗаписьТекста.Закрыть();
			
			ЧтениеТекста = Новый ЧтениеТекста(ИмяТекстовогоФайла, "windows-1251");
			Текст = ЧтениеТекста.ПрочитатьСтроку();
			НоваяСтрока.Основание = Текст;
			ЧтениеТекста.Закрыть();
			
			НоваяСтрока.НомерОтчета = ПолучитьЗначениеПоляПервойЗаписиФайла(ИмяВременнойПапки + "\reporth.dbf", "REG_NO");
		КонецЕсли;
		
		УдалитьФайлы(ИмяВременнойПапки);
		
		rs.MoveNext();
		
	КонецЦикла;
	
	ВнешниеДанные.ADODisconnect(Соединение, Команда, RS);
	
	ЗаполнитьСсылкиВТаблицеКонвертации();
КонецПроцедуры

Функция ПолучитьЗначениеПоляПервойЗаписиФайла(ИмяФайла, ИмяПоля)
	
	База = Новый XBase(ИмяФайла, , Истина);
	База.Кодировка = КодировкаXBase.OEM;
	Если Не База.Открыта() Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	База.Первая();
	Результат = СокрЛП(База.ПолучитьЗначениеПоля(ИмяПоля));
	База.ЗакрытьФайл();
	Возврат Результат;
	
КонецФункции

Процедура ЗаполнитьСсылкиВТаблицеКонвертации()
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ТЗ.НомерСтроки КАК НомерСтроки,
	|	ТЗ.Отметка КАК Отметка,
	|	ТЗ.Номер КАК Номер,
	|	ТЗ.НомерСчетаДепо КАК НомерСчетаДепо,
	|	ТЗ.НомерОтчета КАК НомерОтчета,
	|	ТЗ.НомерРаздела КАК НомерРаздела,
	|	ТЗ.Основание КАК Основание,
	|	ТЗ.Дата КАК Дата,
	|	ТЗ.КодИсходнойЦБ КАК КодИсходнойЦБ,
	|	ТЗ.КоличествоИсходнойЦБ КАК КоличествоИсходнойЦБ,
	|	ТЗ.КоличествоИтоговойЦБ КАК КоличествоИтоговойЦБ,
	|	ТЗ.КодИтоговойЦБ КАК КодИтоговойЦБ
	|ПОМЕСТИТЬ вт
	|ИЗ
	|	&ТЗ КАК ТЗ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	КОЛИЧЕСТВО(ЦенныеБумаги.Ссылка) КАК Количество,
	|	ЦенныеБумаги.ISIN КАК ISIN
	|ПОМЕСТИТЬ втЦенныеБумаги
	|ИЗ
	|	Справочник.ЦенныеБумаги КАК ЦенныеБумаги
	|
	|СГРУППИРОВАТЬ ПО
	|	ЦенныеБумаги.ISIN
	|
	|ИМЕЮЩИЕ
	|	КОЛИЧЕСТВО(ЦенныеБумаги.Ссылка) = 1
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	вт.НомерСтроки КАК НомерСтроки,
	|	вт.Отметка КАК Отметка,
	|	вт.Номер КАК Номер,
	|	вт.НомерСчетаДепо КАК НомерСчетаДепо,
	|	вт.НомерОтчета КАК НомерОтчета,
	|	вт.НомерРаздела КАК НомерРаздела,
	|	вт.Основание КАК Основание,
	|	вт.Дата КАК Дата,
	|	вт.КодИсходнойЦБ КАК КодИсходнойЦБ,
	|	вт.КоличествоИсходнойЦБ КАК КоличествоИсходнойЦБ,
	|	вт.КоличествоИтоговойЦБ КАК КоличествоИтоговойЦБ,
	|	вт.КодИтоговойЦБ КАК КодИтоговойЦБ,
	|	КодыИсходныеЦБ.Владелец КАК ИсходнаяЦБ,
	|	КодыИтоговыеЦБ.Владелец КАК ИтоговаяЦБ,
	|	Конвертация.Ссылка КАК Конвертация
	|ИЗ
	|	вт КАК вт
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.КодыЗагрузки КАК КодыИсходныеЦБ
	|		ПО (КодыИсходныеЦБ.ПометкаУдаления = ЛОЖЬ)
	|			И (КодыИсходныеЦБ.Код = вт.КодИсходнойЦБ)
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.КодыЗагрузки КАК КодыИтоговыеЦБ
	|		ПО (КодыИтоговыеЦБ.ПометкаУдаления = ЛОЖЬ)
	|			И (КодыИтоговыеЦБ.Код = вт.КодИтоговойЦБ)
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.Поручение КАК Конвертация
	|		ПО вт.НомерОтчета = Конвертация.НомерОтчета
	|
	|УПОРЯДОЧИТЬ ПО
	|	НомерСтроки";
	Запрос.УстановитьПараметр("ТЗ", Конвертации);
	Результат = Запрос.Выполнить();
	тзРезультат = Результат.Выгрузить();
	Конвертации.Загрузить(тзРезультат);
КонецПроцедуры

