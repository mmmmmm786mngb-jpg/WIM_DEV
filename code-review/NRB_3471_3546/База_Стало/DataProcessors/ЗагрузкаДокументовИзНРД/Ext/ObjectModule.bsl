Функция ПолучитьТекстЗапросаSQL(НачалоПериода, КонецПериода)
	Возврат
	"select
	|	f.File_name,
	|	f.File_body,
	|	d.Doc_Date, 
	|	d.DOC_NUM 
	|from 
	|	documents d, 
	|	doc_status ds, 
	|	doc_keep_status dcs,
	|	doc_file df,
	|	files f 
	|where 
	|	d.doc_type = 'NPTI' 
	|	and d.keep_status = 'WORK' 
	|	and d.doc_status = ds.doc_status 
	|	and d.keep_status = dcs.keep_status  
	|	and df.DOC_ID = d.DOC_ID
	|	and f.FILE_ID = df.FILE_ID
	|   AND d.doc_date BETWEEN {ts '"+Формат(НачалоПериода, "ДФ=yyyy-MM-dd")+" 00:00:00'} AND {ts '"+Формат(КонецПериода, "ДФ=yyyy-MM-dd")+" 00:00:00'}";
КонецФункции

Функция ПолучитьТекстЗапросаSQLПоКонвертациям(НачалоПериода, КонецПериода)
	
	Возврат 
	"SELECT 
	|	r.report_id, 
	|	f.FILE_ID,
	|	f.File_body,
	|	r.order_doc_id, 
	|	r.out_form, 
	|	r.maker_code, 
	|	r.reciv_code, 
	|	r.person_code, 
	|	r.order_reg_no, 
	|	r.order_reg_no_sgd, 
	|	r.order_reg_date_sgd, 
	|	r.order_t_id, 
	|	r.order_t_n, 
	|	d.doc_id, 
	|	d.doc_date, 
	|	d.doc_num, 
	|	d.doc_status,
	|	(CASE WHEN r.order_doc_id IS NULL THEN 'Нет' ELSE 'Да' END) AS to_order, 
	|	ds.description AS status_name
	|FROM 
	|	documents AS d
	|	inner join reports AS r on r.doc_id = d.doc_id 
	|	inner join doc_status AS ds on ds.doc_status = d.doc_status
	|	left join doc_file df on d.DOC_ID=df.DOC_ID
	|	left join files f on df.FILE_ID=f.FILE_ID
	|WHERE 
	|	d.doc_type = 'REPORT' 
	|	and order_t_id = '10/51' 
	|	and out_form='MS101'
	|   AND d.doc_date BETWEEN {ts '"+Формат(НачалоПериода, "ДФ=yyyy-MM-dd")+" 00:00:00'} AND {ts '"+Формат(КонецПериода, "ДФ=yyyy-MM-dd")+" 00:00:00'}";
	
КонецФункции

Процедура ЗаписатьЗначениеSQLВоВременныйФайл(Значение, ИмяВременногоФайла)
	Stream = Неопределено;
	
	Stream = Новый COMОбъект("ADODB.Stream");
	Stream.Type = 1;
	Stream.Open();
	
	Stream.Write(Значение);
	
	Stream.SaveToFile(ИмяВременногоФайла);
КонецПроцедуры

