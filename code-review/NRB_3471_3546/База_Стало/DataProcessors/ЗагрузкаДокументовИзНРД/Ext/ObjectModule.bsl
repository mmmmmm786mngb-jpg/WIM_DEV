// СОЗДАНИЕ ДОКУМЕНТОВ В 1С НА ОСНОВЕ ЗАГРУЖЕННЫХ ДАННЫХ

Функция ДанныеПоОстаткамЦБ(Строка, РазделСчета, Депонент = Неопределено)
	Запрос	= Новый Запрос(
	"ВЫБРАТЬ
	|	ОстаткиЦБОстатки.СчетДепо.Владелец КАК Депонент,
	|	ОстаткиЦБОстатки.СчетДепо КАК СчетДепо,
	|	ОстаткиЦБОстатки.РазделСчетаДепо КАК РазделСчетаДепо,
	|	ОстаткиЦБОстатки.ЦБ КАК ЦеннаяБумага,
	|	ОстаткиЦБОстатки.СчетДепоМХ КАК СчетДепоМХ,
	|	ОстаткиЦБОстатки.РазделСчетаДепоМХ КАК РазделСчетаДепоМХ,
	|	ОстаткиЦБОстатки.КоличествоОстаток КАК Количество,
	|	ОстаткиЦБОстатки.ЦБ.ISIN КАК ISIN,
	|	ОстаткиЦБОстатки.ЦБ.НомерРегистрации КАК НомерРегистрации,
	|	ОстаткиЦБОстатки.РазделСчетаДепо.ТипРазделаСчетаДЕПО КАК ТипРазделаСчетаДЕПО
	|ИЗ
	|	РегистрНакопления.ОстаткиЦБ.Остатки(
	|			&МоментВремени,
	|			ЦБ = &ЦБ
	|				И СчетДепоМХ = &СчетДепоМХ
	|				И (РазделСчетаДепоМХ.Код = &КодРаздела
	|					ИЛИ &КодРаздела = """")
	|				И (СчетДепо.Владелец = &Депонент
	|					ИЛИ &Депонент = НЕОПРЕДЕЛЕНО)) КАК ОстаткиЦБОстатки");
	
	Если Строка.ФиксацияНаУтро = ИСТИНА Тогда
		СекундВЧасе = 60 * 60;
		ДатаФиксацииСУчетомВремени = НачалоДня(Строка.ДатаФиксацииСписка) + (СекундВЧасе * 7);
	Иначе
		ДатаФиксацииСУчетомВремени = КонецДня(Строка.ДатаФиксацииСписка);
	Конецесли;

	Запрос.УстановитьПараметр("МоментВремени"	, ДатаФиксацииСУчетомВремени);
	Запрос.УстановитьПараметр("ЦБ"				, Строка.ЦеннаяБумага);
	Запрос.УстановитьПараметр("СчетДепоМХ"		, СчетДепоМХ);
	Запрос.УстановитьПараметр("КодРаздела"		, РазделСчета);
	Запрос.УстановитьПараметр("Депонент"		, Депонент);
	
	Возврат Запрос.Выполнить().Выгрузить();
	
КонецФункции

Функция ВыделитьНомерИПД(НомерИсходящегоДокумента)
	
	ПозицияИзвещения = Найти(НомерИсходящегоДокумента, "ИПД/");
	Возврат Прав(НомерИсходящегоДокумента, СтрДлина(НомерИсходящегоДокумента) - ПозицияИзвещения + 1);
	
КонецФункции

// BSLLS:CognitiveComplexity-off
// BSLLS:CyclomaticComplexity-off
// BSLLS:DuplicateStringLiteral-off

Процедура СоздатьПоручения(МаскаТаблицы)
	
	Если ИспользоватьФайловыйШлюз Тогда
		КаталогАрхива = КаталогАрхиваФайловНаТекущуюДату();
		Если Не ОбщегоНазначенияКлиентСервер.ФайлСуществует(КаталогАрхива) Тогда
			СоздатьКаталог(КаталогАрхива);
		КонецЕсли;
		ПеремещатьВАрхив = ОбщегоНазначенияКлиентСервер.ФайлСуществует(КаталогАрхива);
	Иначе
		ПеремещатьВАрхив = Ложь;
	КонецЕсли;
	
	СпособПриемаПорученийЭлектронныйВид	= Справочники.СпособыПриемаПоручений.НайтиПоНаименованию("электронный вид");
	ДатаНачалаНачисленияНДФЛНаГособлигации = Константы.ДатаНачалаНачисленияНДФЛНаГособлигации.Получить();
	ВалютаРеглУчета = Константы.ВалютаРегламентированногоУчета.Получить();
	
	Для Каждого Строка Из ЭтотОбъект[МаскаТаблицы] Цикл
		ОшибкаФормированияДокумента	= Ложь;
		
		Если Не Строка.Отметка Тогда
			Продолжить;
		КонецЕсли;
		
		Поручение = ?(ЗначениеЗаполнено(Строка.Поручение), Строка.Поручение.ПолучитьОбъект(),
		Документы.Поручение.СоздатьДокумент());
		
		ДатаПоручения = НачалоДня(Строка.Дата) + 9 * 60 * 60;
		
		// Заполним документы по параметрам
		Поручение.Проведен					= Ложь;
		Поручение.Дата						= ДатаПоручения;
		Поручение.Инициатор					= Строка.Эмитент;
		Поручение.ПлатежныйАгент			= Депозитарий;
		Поручение.ПланируемаяДатаРасчетов	= ОбщегоНазначения.ДобавитьРабочийКалендарныйДень(ДатаПоручения, РегистрыСведений.ПараметрыГлобальные.ЗначениеПараметра("ПериодВыплатыДляИПДПоумолчанию",0));
		Поручение.СчетДепоМХДокумента		= СчетДепоМХ;
		Поручение.Автор						= ПараметрыСеанса.ТекущийПользователь;
		Поручение.Валюта					= Строка.ВалютаВыплаты;
		Поручение.ВидОперацииД				= Строка.ВидОперации;
		Поручение.ВыплатаНа1ЦБ				= Строка.ВыплатаНа1ЦБ;
		Поручение.ДатаПриема				= НачалоДня(Строка.Дата);
		Поручение.Контрагент				= Строка.Эмитент;
		Поручение.ЦБ						= Строка.ЦеннаяБумага;
		Поручение.СуммаСделки				= Строка.ОбщаяСумма;
		Поручение.НомерОтчета				= Строка.Номер;
		Поручение.СпособПриемаПоручений		= СпособПриемаПорученийЭлектронныйВид;
		Поручение.ДатаФиксации				= НачалоДня(Строка.ДатаФиксацииСписка);
		Поручение.БанковскийСчет			= Строка.БанковскийСчет;
		Поручение.ПериодНачисления			= ?(МаскаТаблицы = "Дивиденды", Строка.ДополнительнаяИнформация, "");
		Поручение.НомерПлатежногоПоручения	= Строка.НомерПлатежногоПоручения;
		Поручение.ДатаПлатежногоПоручения	= Строка.ДатаПлатежногоПоручения;
		Поручение.НомерИПД					= Строка.НомерИПД;
		Поручение.КарточкаКД				= Строка.КарточкаКД;
		Поручение.НеПроверятьНаличиеКарточкиКД = Строка.НеПроверятьНаличиеКарточкиКД;
		Поручение.ФиксацияНаУтро			= Строка.ФиксацияНаУтро;

		Если МаскаТаблицы = "Дивиденды" Тогда
			Поручение.КоэффициентД1 		= Строка.Д1;
			Поручение.КоэффициентД2 		= Строка.Д2;
		КонецЕсли;
		
		Поручение.Комментарий = СокрЛП(Строка.ДополнительнаяИнформация);
		
		Если Не Строка.ИзвещениеПоИностраннойЦеннойБумаге Тогда
			Если Строка.ТипЦБ = Перечисления.ТипыЦБ.Облигация Тогда
				УдалитьТипКД(Поручение.Комментарий, "Тип КД");
				Поручение.Комментарий = Поручение.Комментарий + " Размер выплаты на 1 ЦБ - " + Строка.ВыплатаНа1ЦБ + " руб.";
			ИначеЕсли Строка.ТипЦБ = Перечисления.ТипыЦБ.Акция Тогда
				ЦеннаяБумага = Строка.ЦеннаяБумага;
				Поручение.Комментарий = Поручение.Комментарий + " ISIN " + ЦеннаяБумага.ISIN
				+ " (размер выплаты на 1 ЦБ - " + Строка.ВыплатаНа1ЦБ + " руб.)";
			КонецЕсли;
		КонецЕсли;
		
		РеквизитыЦБ = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Поручение.ЦБ, "ВидЦБ, ВидЦББанкаРоссии");
		РасчетПоИностраннойЦБ = Справочники.ВидыЦББанкаРоссии.ЭтоВидИностраннойЦБ(РеквизитыЦБ.ВидЦББанкаРоссии);
		Поручение.СуммаИПД = Строка.СуммаКВыплате;
		Поручение.ОшибкаЗаполненияДепонентов = "";
		
		// Заполним ТЧ Поручения
		ПоручениеТЧ	= Поручение.ЦенныеБумагиСписываемые;
		// Почистим ТЧ перед заполненим
		ПоручениеТЧ.Очистить();
		
		Поручение.Записать(РежимЗаписиДокумента.Запись);
		
		Строка.Поручение = Поручение.Ссылка;
		
		// Заполним ТЧ
		СтрокиТабличнойЧасти	= ЭтотОбъект[МаскаТаблицы+"Приложение"].НайтиСтроки(Новый Структура("ИдентификаторСтрокиВладельца"
		, Строка.Идентификатор));
		ВремТаблица				= ЭтотОбъект[МаскаТаблицы+"Приложение"].Выгрузить(СтрокиТабличнойЧасти);
		
		НачислитьНДФЛНаИностранныеДивиденды = РасчетПоИностраннойЦБ
			И Справочники.ВидыОпераций.ЭтоВыплатаДоходаПоАкциямИлиИнымЦБ(Поручение.ВидОперацииД);
		Если НачислитьНДФЛНаИностранныеДивиденды Тогда
			НалогВИностраннойЮрисдикции = ВремТаблица.Итог("Налог");
			Поручение.СуммаИПД = Строка.ОбщаяСумма;
			Поручение.СуммаИПДНалогаВИностраннойЮрисдикции = НалогВИностраннойЮрисдикции;
			Поручение.СтавкаИПДНалогаВИностраннойЮрисдикции = ВремТаблица.Итог("СтавкаНалога");
		КонецЕсли;
		Поручение.КоличествоЦБ	= ВремТаблица.Итог("КоличествоЦБ");
		ДопУдержанияНа1ЦБ = 0;
		Если РасчетПоИностраннойЦБ Тогда
			СуммаДляРасчетаЦены = Поручение.СуммаИПД;
		Иначе
			СуммаДляРасчетаЦены = Поручение.СуммаСделки;
		КонецЕсли;
		Если Поручение.КоличествоЦБ <> 0 Тогда
			Поручение.ЦенаСделкиЦБ	= СуммаДляРасчетаЦены/Поручение.КоличествоЦБ;
			ДопУдержанияНа1ЦБ 		= Строка.ДопУдержания/Поручение.КоличествоЦБ;
			ЦенаНа1ЦБ				= СуммаДляРасчетаЦены/Поручение.КоличествоЦБ;
		КонецЕсли;
		
		СуммаУдержанногоНалога = 0; ВсегоНачислено = 0;
		Для Каждого СтрокаТЧ Из СтрокиТабличнойЧасти Цикл
			
			Если ЗначениеЗаполнено(СтрокаТЧ.Депонент) Тогда
				ДанныеПоБумагамДляРасчета = ДанныеПоОстаткамЦБ(Строка, СтрокаТЧ.РазделСчетаДепо, СтрокаТЧ.Депонент);
			Иначе
				ДанныеПоБумагамДляРасчета = ДанныеПоОстаткамЦБ(Строка, СтрокаТЧ.РазделСчетаДепо);
			КонецЕсли;
			
			Если WTRCСообщенияQI.ИспользоватьСхемуУведомленийWTRC_QI(Строка.ДатаПлатежногоПоручения) 
				И Справочники.ЦенныеБумаги.ЦБПодпадаетПодНалоговоеРегулированиеСША(Строка.ЦеннаяБумага) Тогда
				Если ЗначениеЗаполнено(Строка.КарточкаКД) Тогда
					Если ПустаяСтрока(СтрокаТЧ.РазделСчетаДепо) Тогда
						ОбщегоНазначенияКлиентСервер.СообщитьПользователю("В ИПД не указан раздел, предполагаем раздел 00000000000000000!");
						СтрокаТЧ.РазделСчетаДепо = "00000000000000000";
					КонецЕсли;
					ПодобратьДепонентовПоРаскрытию(Поручение, СтрокаТЧ.КоличествоЦБ, СтрокаТЧ.РазделСчетаДепо, СтрокаТЧ.СтавкаНалога, ДанныеПоБумагамДляРасчета);
				Иначе
					Поручение.ОшибкаЗаполненияДепонентов = "Не указано КД, поручение заполнено остатками ЦБ!";
				КонецЕсли;
				ЗаполнятьПриНесовпаденииКоличества = Истина;
			Иначе
				ЗаполнятьПриНесовпаденииКоличества = Ложь;
			КонецЕсли;
			
			ВсегоНачислено 				= ВсегоНачислено + СтрокаТЧ.Начислено;
			СуммаУдержанногоНалога 		= СуммаУдержанногоНалога + СтрокаТЧ.Налог;
			Если НачислитьНДФЛНаИностранныеДивиденды Тогда
				НДФЛУдержан = Ложь;
			Иначе
				НДФЛУдержан = ЗначениеЗаполнено(СтрокаТЧ.Налог);
			КонецЕсли;
			Если Поручение.ВидОперацииД = Справочники.ВидыОпераций.ПогашениеНКД И Поручение.Дата >= ДатаНачалаНачисленияНДФЛНаГособлигации Тогда
				НачислятьНалог = Не (НДФЛУдержан И РасчетПоИностраннойЦБ);
			Иначе 
				НачислятьНалог = Не НДФЛУдержан
					И (Поручение.Валюта = ВалютаРеглУчета И РеквизитыЦБ.ВидЦБ <> Перечисления.ВидыОблигаций.Государственная
						Или НачислитьНДФЛНаИностранныеДивиденды);
			КонецЕсли;
			
			Если ДанныеПоБумагамДляРасчета.Количество() > 0 И ЗаполнятьПриНесовпаденииКоличества 
				Или ДанныеПоБумагамДляРасчета.Итог("Количество") = СтрокаТЧ.КоличествоЦБ Тогда
				Для Каждого СтрокаДанных Из ДанныеПоБумагамДляРасчета Цикл
					НоваяСтрокаПоручения = ПоручениеТЧ.Добавить();
					ЗаполнитьЗначенияСвойств(НоваяСтрокаПоручения, СтрокаДанных);
					Если РасчетПоИностраннойЦБ Тогда
						НоваяСтрокаПоручения.СтавкаНалога = СтрокаТЧ.СтавкаНалога;
						НоваяСтрокаПоручения.Резидент	= ДанныеФизлиц.ЯвляетсяНалоговымРезидентом(Поручение.Дата, НоваяСтрокаПоручения.СчетДепо.Владелец);
					Иначе
						НоваяСтрокаПоручения.СуммаНалога = СтрокаТЧ.Налог;
						НоваяСтрокаПоручения.Сумма = ЦенаНа1ЦБ * НоваяСтрокаПоручения.Количество;
						НоваяСтрокаПоручения.ДополнительныеУдержания = ДопУдержанияНа1ЦБ * НоваяСтрокаПоручения.Количество;
					КонецЕсли;
					НоваяСтрокаПоручения.НДФЛУдержан = НДФЛУдержан;
					
				КонецЦикла;
				Если РасчетПоИностраннойЦБ Тогда
					КолонкиИСуммы = Новый Структура;
					КолонкиИСуммы.Вставить("Сумма",								 Строка.ОбщаяСумма);
					КолонкиИСуммы.Вставить("ДополнительныеУдержания",			 Строка.ДопУдержания);
					КолонкиИСуммы.Вставить("СуммаНалогаВИностраннойЮрисдикции",	 СтрокаТЧ.Налог);
					КолонкиИСуммы.Вставить("СуммаКомиссий",						 СтрокаТЧ.Комиссия);
					КолонкиИСуммы.Вставить("СуммаКВыплатеПоИПД",				 Строка.СуммаКВыплате);
					РаспределитьСуммыПоКолонкамТаблицы(КолонкиИСуммы, ПоручениеТЧ);
					СкорректироватьСуммуКВыплатеПоИПД(ПоручениеТЧ);
				КонецЕсли;
				Если НачислятьНалог Тогда
					Поручение.РассчитатьИЗаполнитьНалогиПоВыплатеДохода();
				КонецЕсли;
			ИначеЕсли ДанныеПоБумагамДляРасчета.Количество()>0 Тогда
				ОшибкаФормированияДокумента			= Истина;
				#Если Клиент Тогда
					СообщениеПользователю				= Новый СообщениеПользователю;
					СообщениеПользователю.КлючДанных	= Поручение.Ссылка;
					СообщениеПользователю.Текст			= "
					|Количество бумаг по остаткам в 'Депо' не совпадает с количеством бумаг во входящем поручении!
					|Требуется ручная корректировка документа (количество по документу: "+СтрокаТЧ.КоличествоЦБ+" - по базе: "+ДанныеПоБумагамДляРасчета.Итог("Количество")+"
					| - "+Поручение.Ссылка+" ("+Строка.НомерИсходящегоДокумента+")";
					СообщениеПользователю.Сообщить();
				#КонецЕсли
			Иначе
				ОшибкаФормированияДокумента				= Истина;
				#Если Клиент Тогда
					СообщениеПользователю				= Новый СообщениеПользователю;
					СообщениеПользователю.КлючДанных	= Поручение.Ссылка;
					СообщениеПользователю.Текст			= "
					|Остатки в 'Депо' по бумаге входящего поручения не обнаружены!
					|Требуется ручная корректировка документа:
					| - "+Поручение.Ссылка+" ("+Строка.НомерИсходящегоДокумента+")";
					СообщениеПользователю.Сообщить();
				#КонецЕсли
			КонецЕсли;
			Если ЗначениеЗаполнено(Строка.СуммаВыплаченнаяРанее) Тогда
				Поручение.Комментарий = Поручение.Комментарий + " -Выплачено ранее - " + Строка.СуммаВыплаченнаяРанее
				+ ?(Строка.ИзвещениеПоИностраннойЦеннойБумаге, " " + Строка.ВалютаВыплаты, "");
			КонецЕсли;
		КонецЦикла;
		Если ПоручениеТЧ.Количество() > 0 Тогда
			Поручение.ЗаполнитьБанковскиеСчета();
		КонецЕсли;
		Если ТипЗнч(Поручение.ВидОперацииД) = Тип("СправочникСсылка.ВидыОпераций")
			И Поручение.ВидОперацииД.ВыплатаДоходаВДенежнойФорме
			И Документы.НачисленныйНалог.ИспользоватьРасчетНДФЛПоПрогрессивнойШкале(Поручение.Дата) Тогда
			Документы.Поручение.ЗаполнитьПлановуюДатуРасчетов(Поручение.Ссылка, ПоручениеТЧ);
			Документы.Поручение.ЗаполнитьВалютуНалога(Поручение.Ссылка, ПоручениеТЧ);
		КонецЕсли;
		Если РасчетПоИностраннойЦБ Тогда
			Поручение.СуммаСделки = ПоручениеТЧ.Итог("СуммаКВыплатеПоИПД");
		КонецЕсли;
		Поручение.Записать(РежимЗаписиДокумента.Запись);
		
		ОповеститьОНаличииОбособленныхСчетов(ДанныеПоБумагамДляРасчета, Строка.НомерИПД, Поручение.Номер, Поручение.Дата);
		Если Поручение.КоличествоЦБ <> ПоручениеТЧ.Итог("Количество") Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(Строка(Поручение) + ": количество в поручении не соответствует количеству в ИПД!");
		ИначеЕсли Строка.ОбщаяСумма <> ПоручениеТЧ.Итог("Сумма") Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(Строка(Поручение) + ": общая сумма начисления не соответствует сумме в ИПД!");
		ИначеЕсли Строка.ДопУдержания <> ПоручениеТЧ.Итог("ДополнительныеУдержания") Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(Строка(Поручение) + ": сумма дополнительных удержаний не соответствует сумме в ИПД!");
		ИначеЕсли РасчетПоИностраннойЦБ И СуммаУдержанногоНалога <> ПоручениеТЧ.Итог("СуммаНалогаВИностраннойЮрисдикции") Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(Строка(Поручение) + ": сумма удержанного налога не соответствует сумме в ИПД!");
		ИначеЕсли РасчетПоИностраннойЦБ И Строка.СуммаКВыплате <> ПоручениеТЧ.Итог("СуммаКВыплатеПоИПД") Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(Строка(Поручение) + ": итоговая сумма к выплате не соответствует сумме в ИПД!");
		ИначеЕсли РасчетПоИностраннойЦБ И ПоручениеТЧ.Итог("Сумма") <> ПоручениеТЧ.Итог("СуммаКВыплатеПоИПД")
			+ ПоручениеТЧ.Итог("СуммаНалогаВИностраннойЮрисдикции")
			+ ПоручениеТЧ.Итог("СуммаКомиссий") + ПоручениеТЧ.Итог("ДополнительныеУдержания") Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(Строка(Поручение)+": сумма к выплате не соответствует сумме начисления за вычетом удержаний!");
		КонецЕсли;
		
		Если ПеремещатьВАрхив Тогда
			СтрокиДивидендыКупоны = ДивидендыКупоны.НайтиСтроки(Новый Структура("Идентификатор", Строка.Идентификатор));
			Если СтрокиДивидендыКупоны.Количество() > 0 Тогда
				ПутьККаталогу = СтрокиДивидендыКупоны[0].ПутьККаталогу;
				Если ЗначениеЗаполнено(ПутьККаталогу) Тогда
					ПозицияСлеша = СтрНайти(ПутьККаталогу, "\", НаправлениеПоиска.СКонца);
					НаименованиеКаталога = Сред(ПутьККаталогу, ПозицияСлеша + 1, СтрДлина(ПутьККаталогу) - ПозицияСлеша);
					РаботаСФайлами.ПереместитьКаталог(ПутьККаталогу, КаталогАрхива + "\" + НаименованиеКаталога);
					ЗаписьЖурналаРегистрации("Архивация файлов входящих пакетов (I)",
						УровеньЖурналаРегистрации.Информация,
						Метаданные.Обработки.ЗагрузкаДокументовИзНРД,
						,
						"Каталог " + НаименованиеКаталога + " перемещен: " + ПутьККаталогу + " => " + КаталогАрхива + "\" + НаименованиеКаталога);
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

// BSLLS:CognitiveComplexity-on
// BSLLS:CyclomaticComplexity-on
// BSLLS:DuplicateStringLiteral-on

Процедура СформироватьДокументы() Экспорт
	НачатьТранзакцию();
	СоздатьПоручения("Купоны");
	СоздатьПоручения("Дивиденды");
	ЗафиксироватьТранзакцию();
КонецПроцедуры

Процедура ЗаполнитьКонвертацию(Строка) Экспорт
	
	Если ЗначениеЗаполнено(Строка.Конвертация) Тогда
		Поручение = Строка.Конвертация.ПолучитьОбъект();
	Иначе
		Поручение = Документы.Поручение.СоздатьДокумент();
	КонецЕсли; 
	СпособПриемаПорученийЭлектронныйЫид	= Справочники.СпособыПриемаПоручений.НайтиПоНаименованию("электронный вид");
	
	ДатаПоручения = НачалоДня(Строка.Дата) + 9 * 60 * 60;
	
	Поручение.Проведен					= Ложь;
	Поручение.Дата						= ДатаПоручения;
	Поручение.Автор						= ПараметрыСеанса.ТекущийПользователь;
	Поручение.ВидОперацииД				= Справочники.ВидыОпераций.Конвертация;
	Поручение.ТипКонвертации 			= Перечисления.ТипыКонвертаций.Конвертация;
	Поручение.ДатаПриема				= НачалоДня(Строка.Дата);
	Поручение.Инициатор					= Депозитарий;
	Поручение.СпособПриемаПоручений		= СпособПриемаПорученийЭлектронныйЫид;
	Поручение.Комментарий				= Строка.Основание;
	Поручение.НомерОтчета				= Строка.НомерОтчета;
	ИсходноеКоличествоЦБ 				= - Строка.КоличествоИсходнойЦБ;
	Если ЗначениеЗаполнено(ИсходноеКоличествоЦБ) Тогда 
		КоэффициентКонвертации = Строка.КоличествоИтоговойЦБ / ИсходноеКоличествоЦБ;
	Иначе 
		КоэффициентКонвертации = 0;
	КонецЕсли;
	Поручение.КоэффициентКонвертации = КоэффициентКонвертации;
	
	// Заполним ТЧ Поручения
	Поручение.ЦенныеБумагиСписываемые.Очистить();
	НоваяСтрокаТЧ = Поручение.ЦенныеБумагиСписываемые.Добавить(); 
	НоваяСтрокаТЧ.ЦеннаяБумага = Строка.ИсходнаяЦБ;
	НоваяСтрокаТЧ.Количество = ИсходноеКоличествоЦБ;
	Поручение.ЦенныеБумагиЗачисляемые.Очистить();
	НоваяСтрокаТЧ = Поручение.ЦенныеБумагиЗачисляемые.Добавить(); 
	НоваяСтрокаТЧ.ЦеннаяБумага = Строка.ИтоговаяЦБ;
	НоваяСтрокаТЧ.Количество = Строка.КоличествоИтоговойЦБ;
	
	ПоручениеТЧ	= Поручение.Списание;
	ПоручениеТЧ.Очистить();	
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	ОстаткиЦБОстатки.СчетДепо.Владелец КАК Депонент,
	|	ОстаткиЦБОстатки.СчетДепо КАК СчетДепо,
	|	ОстаткиЦБОстатки.РазделСчетаДепо КАК РазделСчетаДепо,
	|	ОстаткиЦБОстатки.ЦБ КАК ЦеннаяБумага,
	|	ОстаткиЦБОстатки.СчетДепоМХ КАК СчетДепоМХ,
	|	ОстаткиЦБОстатки.РазделСчетаДепоМХ КАК РазделСчетаДепоМХ,
	|	ОстаткиЦБОстатки.КоличествоОстаток КАК Количество,
	|	ОстаткиЦБОстатки.СтатусЦБ КАК СтатусЦБ
	|ИЗ
	|	РегистрНакопления.ОстаткиЦБ.Остатки(
	|			&МоментВремени,
	|			ЦБ = &ЦБ
	|				И СчетДепоМХ = &СчетДепоМХ) КАК ОстаткиЦБОстатки
	|ГДЕ
	|	ОстаткиЦБОстатки.РазделСчетаДепоМХ.Наименование ПОДОБНО &РазделСчетаДепоМХ");
	
	Запрос.УстановитьПараметр("МоментВремени"		,ДатаПоручения);
	Запрос.УстановитьПараметр("ЦБ"					,Строка.ИсходнаяЦБ);
	Запрос.УстановитьПараметр("СчетДепоМХ"			,СчетДепоМХ);
	Запрос.УстановитьПараметр("РазделСчетаДепоМХ" 	,СокрЛП(Строка.НомерРаздела));
	
	ДанныеПоБумагамДляРасчета = Запрос.Выполнить().Выгрузить();
	
	Если ДанныеПоБумагамДляРасчета.Количество()>0 Тогда
		Если ДанныеПоБумагамДляРасчета.Итог("Количество") = ИсходноеКоличествоЦБ Тогда
			Для Каждого СтрокаДанных Из ДанныеПоБумагамДляРасчета Цикл
				НоваяСтрокаПоручения	= ПоручениеТЧ.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрокаПоручения, СтрокаДанных);
			КонецЦикла;
			Если ЗначениеЗаполнено(КоэффициентКонвертации) Тогда 
				Поручение.Зачисление.Очистить();
				Для Каждого СтрокаДанных Из ДанныеПоБумагамДляРасчета Цикл
					НоваяСтрокаПоручения	= Поручение.Зачисление.Добавить();
					ЗаполнитьЗначенияСвойств(НоваяСтрокаПоручения, СтрокаДанных);
					НоваяСтрокаПоручения.Количество = НоваяСтрокаПоручения.Количество * КоэффициентКонвертации;
					НоваяСтрокаПоручения.ЦеннаяБумага = Строка.ИтоговаяЦБ;
				КонецЦикла;
			КонецЕсли;
		Иначе
			ОшибкаФормированияДокумента			= Истина;
			#Если Клиент Тогда
				СообщениеПользователю				= Новый СообщениеПользователю;
				СообщениеПользователю.КлючДанных	= Поручение.Ссылка;
				СообщениеПользователю.Текст			= "
				|Количество бумаг по остаткам в 'Депо' не совпадает с количеством бумаг во входящем поручении!
				|Требуется ручная корректировка документа конвертации (количество по документу: "+ИсходноеКоличествоЦБ+" - по базе: "+ДанныеПоБумагамДляРасчета.Итог("Количество")+"
				| - "+Поручение.Ссылка+" ("+Строка.НомерОтчета+")";
				СообщениеПользователю.Сообщить();
			#КонецЕсли
		КонецЕсли;
	Иначе
		ОшибкаФормированияДокумента				= Истина;
		#Если Клиент Тогда
			СообщениеПользователю				= Новый СообщениеПользователю;
			СообщениеПользователю.КлючДанных	= Поручение.Ссылка;
			СообщениеПользователю.Текст			= "
			|Остатки в 'Депо' по бумаге входящего поручения не обнаружены!
			|Требуется ручная корректировка документа:
			| - "+Поручение.Ссылка+" ("+Строка.НомерОтчета+")";
			СообщениеПользователю.Сообщить();
		#КонецЕсли
	КонецЕсли;
	
	Поручение.Записать(РежимЗаписиДокумента.Запись);
	Строка.Конвертация = Поручение.Ссылка;
	
КонецПроцедуры

Процедура ЗагрузитьКонвертации() Экспорт
	Для Каждого СтрокаКонвертации Из Конвертации Цикл
		Если СтрокаКонвертации.Отметка = Ложь Тогда
			Продолжить;
		КонецЕсли; 
		ЗаполнитьКонвертацию(СтрокаКонвертации);
	КонецЦикла; 
КонецПроцедуры

// СОЗДАНИЕ ДОКУМЕНТОВ В 1С НА ОСНОВЕ ЗАГРУЖЕННЫХ ДАННЫХ
