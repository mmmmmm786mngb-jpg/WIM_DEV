// ФУНКЦИИ ПРЕОБРАЗОВАНИЯ ТИПОВ ПРИ ЧТЕНИИ HTM

Функция ПолучитьЧислоИзСтроки(ЧислоСтрокой)
	Если Не ЗначениеЗаполнено(ЧислоСтрокой) Тогда
		Возврат 0;
	КонецЕсли;
	
	Возврат Число(СтрЗаменить(СтрЗаменить(ЧислоСтрокой, ",", ""), ".", ","));
КонецФункции

Функция ПолучитьДатуПоСтрокеДДММГГ(ДатаСтрокой) Экспорт
	Цифры = "0123456789";
	
	СтрокаОбработки = СтрЗаменить(ДатаСтрокой, ".", "");
	ПоследовательностьДаты	= "";
	
	Для Счетчик = 1 По СтрДлина(СтрокаОбработки) Цикл
		ПроверяемыйСимвол = Сред(СтрокаОбработки, Счетчик, 1);
		Если Найти(Цифры, ПроверяемыйСимвол) > 0 Тогда
			ПоследовательностьДаты	= ПоследовательностьДаты + ПроверяемыйСимвол;
		ИначеЕсли Не ПустаяСтрока(ПоследовательностьДаты)  Тогда
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	Возврат Дата(Число(Прав(ПоследовательностьДаты,2))+2000, Сред(ПоследовательностьДаты,3,2), Лев(ПоследовательностьДаты,2));
	
КонецФункции

// ФУНКЦИИ ПРЕОБРАЗОВАНИЯ ТИПОВ ПРИ ЧТЕНИИ HTM
///////////////////////////////////////////////////////////////////////////////

///////////////////////////////////////////////////////////////////////////////
// ДИВИДЕНДЫ И КУПОНЫ ЗАГРУЗКА ДАННЫХ ИЗ HTM ФАЙЛОВ СЧИТАННЫХ ИЗ "ЛУЧ"

Функция ПроверитьТекущиеДанныеСтрокиДивидендыКорректны(ТекущиеДанные) Экспорт
	
	Если ТекущиеДанные = Неопределено Или ТекущиеДанные.Отметка = Ложь Тогда
		Возврат Истина;
	КонецЕсли; 
	
	Если Не ЗначениеЗаполнено(ТекущиеДанные.Эмитент) Тогда
		Сообщить("В строке № " + ТекущиеДанные.НомерСтроки + " не заполнен столбец Эмитент! Документ сформирован не будет!");
		Возврат Ложь;
	КонецЕсли; 
	
	Возврат Истина;
	
КонецФункции

Процедура ЗаполнитьСтрокиПриложенияПоТаблице(ТаблицаЗначений, СтрокаТаблицыДивидендыКупоны, ИмяТаблицы="")
	
	Для Каждого СтрокаТЗ Из ТаблицаЗначений Цикл
		НоваяСтрока = ЭтотОбъект[ИмяТаблицы+"Приложение"].Добавить();
		НоваяСтрока.ИдентификаторСтрокиВладельца = СтрокаТаблицыДивидендыКупоны.Идентификатор;
		
		Если СтрокаТаблицыДивидендыКупоны.ИзвещениеПоИностраннойЦеннойБумаге Тогда
			НоваяСтрока.РазделСчетаДепо = СтрокаТЗ.РазделСчетаДепо;
			НоваяСтрока.Комиссия = СтрокаТЗ.Комиссия;
		КонецЕсли;
		
		Для Каждого Колонка Из ТаблицаЗначений.Колонки Цикл
			ИмяСтолбца = РегистрыСведений.СоответствиеТаблицHTMLДивидендовКупонов.СтолбецДивидендовКупонов(НачалоПериода
			, Колонка.Заголовок);
			Если ИмяСтолбца <> Неопределено Тогда
				Если ТипЗнч(НоваяСтрока[ИмяСтолбца]) = Тип("Число") И ТипЗнч(СтрокаТЗ[Колонка.Имя]) <> Тип("Число") Тогда
					НоваяСтрока[ИмяСтолбца] = ПолучитьЧислоИзСтроки(СтрЗаменить(СтрокаТЗ[Колонка.Имя], " ", ""))
				Иначе
					НоваяСтрока[ИмяСтолбца] = СтрокаТЗ[Колонка.Имя];
				КонецЕсли;
			КонецЕсли; 
		КонецЦикла;
		
		Если ИмяТаблицы = "Дивиденды" Тогда
			НоваяСтрока.КоличествоАО = ?(НоваяСтрока.ТипЦБ = "АОИ", НоваяСтрока.КоличествоЦБ, 0);
			НоваяСтрока.КоличествоАП = ?(НоваяСтрока.ТипЦБ = "АПИ", НоваяСтрока.КоличествоЦБ, 0);
		КонецЕсли;				
		
		НоваяСтрока.Сумма = НоваяСтрока.КВыплате + НоваяСтрока.Налог;
	КонецЦикла;
	
КонецПроцедуры

Процедура ЗагрузитьЯчейкиСтрокиТаблицы(УзлыСтрокиТаблицы, СчетчикСтолбцов, ТаблицаЗначений, НоваяСтрока)
	
	Для Каждого Узел Из УзлыСтрокиТаблицы Цикл
		Если Узел = Неопределено Или ВРег(Узел.ИмяУзла) <> "TD" Тогда
			Продолжить;
		КонецЕсли; 
		
		Если ВРег(СокрЛП(Узел.ТекстовоеСодержимое)) = "ИТОГО" Тогда
			Прервать;
		КонецЕсли; 
		
		Если СчетчикСтолбцов = 0 Тогда
			НоваяСтрока = ТаблицаЗначений.Добавить();
		КонецЕсли; 
		
		Если СчетчикСтолбцов > ТаблицаЗначений.Колонки.Количество() - 1 Тогда
			ИмяСтолбца = "Столбец" + Формат(СчетчикСтолбцов + 1, "ЧГ=0");
			ЗаголовокСтолбца = СокрЛП(Узел.ТекстовоеСодержимое);			
			ТаблицаЗначений.Колонки.Добавить(ИмяСтолбца, ОписаниеТиповСтрока, ЗаголовокСтолбца, 12);
		КонецЕсли;
		
		НоваяСтрока[СчетчикСтолбцов] = СокрЛП(Узел.ТекстовоеСодержимое);
		СчетчикСтолбцов = СчетчикСтолбцов + 1;
	КонецЦикла; // по ячейкам
	
КонецПроцедуры

Процедура ПолучитьТаблицуЗначенийДивидендовКупоновИзФайла(ИмяФайлаHTML, Таблица, СтрокаТаблицы)
	
	ЧтениеHTML = Новый ЧтениеHTML;
	ЧтениеHTML.ОткрытьФайл(ИмяФайлаHTML, КодировкаТекстаHTML);
	
	ПостроительDOM = Новый ПостроительDOM;
	ДокументHTML   = ПостроительDOM.Прочитать(ЧтениеHTML);
	
	ЧтениеHTML.Закрыть();
	
	ТаблицыДокумента = ДокументHTML.ПолучитьЭлементыПоИмени("TABLE");
	ПоследняяТаблица = Неопределено;
	ПромежуточныйТипЦБ = Неопределено;

	// Обход всех таблиц документа, поиск значений - по подстроке
	Для Каждого ТаблицаДокумента Из ТаблицыДокумента Цикл
		ТаблицаЗначений = Новый ТаблицаЗначений;
		СчетчикСтолбцов = 0;
		СчетчикСтрок	= 0;
		
		Если ЭтоТаблицаВыплатаПоЦБ(ТаблицаДокумента) Тогда
			ПрочитатьИнформациюИзТаблицыВыплатаПоЦБ(ТаблицаДокумента, СтрокаТаблицы);
			СтрокаТаблицы.ВалютаВыплаты = Валюта;
		КонецЕсли; 
		
		Для Каждого ЭлементСтрока Из ТаблицаДокумента.ДочерниеУзлы Цикл
			СчетчикСтрок = СчетчикСтрок + 1;
			
			НоваяСтрока = Неопределено;
			СчетчикСтолбцов = 0;
			
			Если ПромежуточныйТипЦБ <> Неопределено Тогда
				Если  ЭтоТаблицаТиповЦБ(ТаблицаДокумента) Тогда
					СтрокаТаблицы.ТипЦБ = ТипЦБ(ТаблицаДокумента);
				КонецЕсли;
			КонецЕсли;

			ЗагрузитьЯчейкиСтрокиТаблицы(ЭлементСтрока.ДочерниеУзлы, СчетчикСтолбцов, ТаблицаЗначений, НоваяСтрока);
			
			Если НоваяСтрока = Неопределено Тогда
				Продолжить;
			КонецЕсли;
			
			ТекстСтолбца1 = ?(ТаблицаЗначений.Колонки.Количество() > 0, НоваяСтрока.Столбец1, "");
			ТекстСтолбца2 = ?(ТаблицаЗначений.Колонки.Количество() > 1, НоваяСтрока.Столбец2, "");
			ТекстСтолбца3 = ?(ТаблицаЗначений.Колонки.Количество() > 2, НоваяСтрока.Столбец3, "");
			ТекстСтолбца4 = ?(ТаблицаЗначений.Колонки.Количество() > 3, НоваяСтрока.Столбец4, "");
			
			//разбор текста
			СтруктураПроверяемыхЗначений = Новый Структура;
			СтруктураПроверяемыхЗначений.Вставить("ТекстСтолбца1", ТекстСтолбца1);
			СтруктураПроверяемыхЗначений.Вставить("ТекстСтолбца2", ТекстСтолбца2);
			СтруктураПроверяемыхЗначений.Вставить("ТекстСтолбца3", ТекстСтолбца3);
			СтруктураПроверяемыхЗначений.Вставить("ТекстСтолбца4", ТекстСтолбца4);
			СтруктураПроверяемыхЗначений.Вставить("НаименованиеЦБ", СтрокаТаблицы.НаименованиеЦБ);
			
			УстановитьРеквизитыСтрокиТаблицыЗначенийДивидендовКупоновПоРазборуТекста(СтруктураПроверяемыхЗначений, СтрокаТаблицы, ПромежуточныйТипЦБ);					
						
		КонецЦикла; // по строкам
		
		ПоследняяТаблица = ТаблицаДокумента;
		
	КонецЦикла; // по таблицам
	
	Если ПоследняяТаблица = Неопределено Тогда
		Возврат; // Последняя таблица документа содержит приложение к извещению
	КонецЕсли;	 
	
	// Получить приложение из последней таблицы
	ТаблицаЗначений = Новый ТаблицаЗначений;
	СчетчикСтолбцов = 0;
	СчетчикСтрок    = 0;
	// Первая строка ЭлементСтрока из ТаблицаДокумента.ДочерниеУзлы содержит заголовки столбцов.
	// Зная количество столбцов, необходимо получить элементы как ТаблицаДокумента.ПолучитьЭлементыПоИмени("td"),
	// из них пропустить КоличествоСтолбцов элементов, затем прочитать элементы как строки.
	// ВНИМАНИЕ!
	// Необходимо учитывать, что количество ячеек не равно КоличествоСтолбцов*КоличествоСтрок (когда атрибут ячейки colspan > 1).
	ЭлементыСтолбцов	= ПоследняяТаблица.ДочерниеУзлы[0].ПолучитьЭлементыПоИмени("TD");
	НоваяСтрока			= Неопределено;
	ЗагрузитьЯчейкиСтрокиТаблицы(ЭлементыСтолбцов, СчетчикСтолбцов, ТаблицаЗначений, НоваяСтрока);
	
	Если НоваяСтрока = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если Найти(ВРег(НоваяСтрока.Столбец1), "НОМЕР СЧЕТА ДЕПО") > 0 Тогда
		ТаблицаЗначений.Удалить(НоваяСтрока);
		
		СтрокиТаблицы		= Новый Массив;
		ВсеЯчейкиТаблицы	= ПоследняяТаблица.ПолучитьЭлементыПоИмени("TD");
		НомерЯчейки			= 0;
		Для Каждого УзелЯчейка Из ВсеЯчейкиТаблицы Цикл
			НомерЯчейки = НомерЯчейки + 1;
			Если НомерЯчейки <= СчетчикСтолбцов Тогда
				Продолжить;			
			КонецЕсли;
			
			ИндексСтолбца = (НомерЯчейки-1) % СчетчикСтолбцов;
			Если ИндексСтолбца = 0 Тогда
				ТекущаяСтрока = Новый Массив(СчетчикСтолбцов);
				СтрокиТаблицы.Добавить(ТекущаяСтрока);
			КонецЕсли;
			ТекущаяСтрока[ИндексСтолбца] = УзелЯчейка;
		КонецЦикла; 
		
		Для Каждого ЭлементСтрока Из СтрокиТаблицы Цикл
			СчетчикСтрок	= СчетчикСтрок + 1;
			СчетчикСтолбцов = 0;
			ЗагрузитьЯчейкиСтрокиТаблицы(ЭлементСтрока, СчетчикСтолбцов, ТаблицаЗначений, НоваяСтрока);
			
			Если НоваяСтрока = Неопределено Тогда
				Продолжить;
			КонецЕсли;
		КонецЦикла;
		
		Таблица = ТаблицаЗначений;
	КонецЕсли;
	
КонецПроцедуры

Процедура ПолучитьТаблицуЗначенийДивидендовКупоновИзФайлаПоИностраннойЦБ(ИмяФайлаHTML, Таблица, СтрокаТаблицы)
	
	ЧтениеHTML = Новый ЧтениеHTML;
	ЧтениеHTML.ОткрытьФайл(ИмяФайлаHTML);
	
	ПостроительDOM = Новый ПостроительDOM;
	ДокументHTML   = ПостроительDOM.Прочитать(ЧтениеHTML);
	
	ЧтениеHTML.Закрыть();
	
	ТаблицыДокумента = ДокументHTML.ПолучитьЭлементыПоИмени("TABLE");
	
	// Обход всех таблиц документа, поиск значений - по подстроке
	Для Каждого ТаблицаДокумента Из ТаблицыДокумента Цикл
		ТаблицаЗначений = Новый ТаблицаЗначений;
		СчетчикСтолбцов = 0;
		СчетчикСтрок	= 0;
		
		Если ЭтоТаблицаВыплатаПоИностраннойЦБ(ТаблицаДокумента) Тогда
			ПрочитатьИнформациюИзТаблицыВыплатаПоИностраннойЦБ(ТаблицаДокумента, СтрокаТаблицы, Таблица);
		КонецЕсли;
		
		Для Каждого ЭлементСтрока Из ТаблицаДокумента.ДочерниеУзлы Цикл
			СчетчикСтрок = СчетчикСтрок + 1;
			
			НоваяСтрока = Неопределено;
			СчетчикСтолбцов = 0;
			
			ЗагрузитьЯчейкиСтрокиТаблицы(ЭлементСтрока.ДочерниеУзлы, СчетчикСтолбцов, ТаблицаЗначений, НоваяСтрока);
			
			Если НоваяСтрока = Неопределено Тогда
				Продолжить;
			КонецЕсли;
			
			ТекстСтолбца1 = ?(ТаблицаЗначений.Колонки.Количество() > 0, НоваяСтрока.Столбец1, "");
			ТекстСтолбца2 = ?(ТаблицаЗначений.Колонки.Количество() > 1, НоваяСтрока.Столбец2, "");
			ТекстСтолбца3 = ?(ТаблицаЗначений.Колонки.Количество() > 2, НоваяСтрока.Столбец3, "");
			ТекстСтолбца4 = ?(ТаблицаЗначений.Колонки.Количество() > 3, НоваяСтрока.Столбец4, "");
			
			//разбор текста
			СтруктураПроверяемыхЗначений = Новый Структура;
			СтруктураПроверяемыхЗначений.Вставить("ТекстСтолбца1", ТекстСтолбца1);
			СтруктураПроверяемыхЗначений.Вставить("ТекстСтолбца2", ТекстСтолбца2);
			СтруктураПроверяемыхЗначений.Вставить("ТекстСтолбца3", ТекстСтолбца3);
			СтруктураПроверяемыхЗначений.Вставить("ТекстСтолбца4", ТекстСтолбца4);
			СтруктураПроверяемыхЗначений.Вставить("НаименованиеЦБ", СтрокаТаблицы.НаименованиеЦБ); 
			
			УстановитьРеквизитыСтрокиТаблицыЗначенийДивидендовКупоновПоИностраннойЦБ(СтруктураПроверяемыхЗначений, СтрокаТаблицы);							
			
			Если Найти(ВРег(ТекстСтолбца1), "ДОПОЛНИТЕЛЬНАЯ ИНФОРМАЦИЯ") Тогда
				ДополнительнаяИнформация = Сред(ТекстСтолбца1, 27);
			КонецЕсли;
			
		КонецЦикла; // по строкам
		
		Если СтрокаТаблицы.ДополнительнаяИнформация = "Выплата дивидендов" Тогда
			СтрокаТаблицы.ДополнительнаяИнформация = СтрокаТаблицы.ДополнительнаяИнформация
			+ ?(ЗначениеЗаполнено(СтрокаТаблицы.ВыплатаНа1ЦБ),
			" по " + СтрокаТаблицы.НаименованиеЦБ
			+ ", ISIN " + СтрокаТаблицы.КодЦБ
			+ " (доход на 1ЦБ - " + СтрокаТаблицы.ВыплатаНа1ЦБ
			+ "#ВалютаВыплаты#)" , ""); // Маркер заменяется на валюту позже
			
		ИначеЕсли СтрокаТаблицы.ТипЦБ = Перечисления.ТипыЦБ.Облигация Тогда
			
			СтруктураПроверяемыхЗначений = Новый Структура("ДополнительнаяИнформация", СтрокаТаблицы.ДополнительнаяИнформация); 			
			УстановитьДопИнформациюВСтрокеДивидендовИКупоновПоДополнительнойИнформации(СтруктураПроверяемыхЗначений, СтрокаТаблицы);
					
			СтрокаТаблицы.ДополнительнаяИнформация = СтрокаТаблицы.ДополнительнаяИнформация + 
			СтрокаТаблицы.НаименованиеЭмитента + " ISIN-"+  СтрокаТаблицы.КодЦБ
			+ ?(ЗначениеЗаполнено(СтрокаТаблицы.ВыплатаНа1ЦБ),
			" (размер выплаты на 1ЦБ- " + Формат(СтрокаТаблицы.ВыплатаНа1ЦБ, "ЧГ=") + " "
			+ СтрокаТаблицы.ВалютаВыплаты + ")" , "");
		КонецЕсли;
		
	КонецЦикла; // по таблицам
	
	СтрокаТаблицы.ДополнительнаяИнформация = СтрЗаменить(СтрокаТаблицы.ДополнительнаяИнформация, "#ВалютаВыплаты#", "") // Удаление неиспользованного маркера валюты 
	+ "; " + ДополнительнаяИнформация;
	
	СтрокаТаблицы.ОбщаяСумма = Таблица.Итог("Начислено");
	
КонецПроцедуры

Функция ЭтоТаблицаВыплатаПоЦБ(ТаблицаDOM)
	Если Не ТаблицаDOM.ЕстьДочерниеУзлы() Тогда
		Возврат Ложь;
	КонецЕсли; 
	
	Ячейки = ТаблицаDOM.ПолучитьЭлементыПоИмени("TD");
	
	Если  Найти(Ячейки[0].ТекстовоеСодержимое, "Код ц.б.") > 0 
		И Найти(Ячейки[1].ТекстовоеСодержимое, "Краткое наименование выпуска ц.б.") > 0 
		И Найти(Ячейки[2].ТекстовоеСодержимое, "Количество ц.б.") > 0
		И Найти(Ячейки[3].ТекстовоеСодержимое, "Размер выплаты") > 0 
		И (Найти(Ячейки[4].ТекстовоеСодержимое, "Сумма начисленной выплаты") > 0 Или Найти(Ячейки[4].ТекстовоеСодержимое, "Номинал") > 0) Тогда
		
		Возврат Истина;
	Иначе
		Возврат Ложь;
	КонецЕсли; 
КонецФункции

Процедура ПрочитатьИнформациюИзТаблицыВыплатаПоЦБ(Таблица, Данные)
	
	УзелСтроки = Таблица.ДочерниеУзлы[1];
	
	Ячейки = УзелСтроки.ПолучитьЭлементыПоИмени("TD");
	Данные.КодЦБ 			= СокрЛП(Ячейки[0].ТекстовоеСодержимое);
	Данные.НаименованиеЦБ 	= СокрЛП(Ячейки[1].ТекстовоеСодержимое);
	Если Ячейки.Количество() > 2 Тогда
		Данные.ВыплатаНа1ЦБ = СокрЛП(Ячейки[3].ТекстовоеСодержимое);
	КонецЕсли;
	
	Если Таблица.ДочерниеУзлы.Количество() > 3 Тогда
		УзелСтроки = Таблица.ДочерниеУзлы[2];
		Ячейки = УзелСтроки.ПолучитьЭлементыПоИмени("TD");
		Данные.КодЦБПрив 		  = СокрЛП(Ячейки[0].ТекстовоеСодержимое);
		Данные.НаименованиеЦБПрив = СокрЛП(Ячейки[1].ТекстовоеСодержимое);
		Данные.ВыплатаНа1ЦБПрив   = СокрЛП(Ячейки[3].ТекстовоеСодержимое);
	КонецЕсли;
	
КонецПроцедуры

Функция ЭтоТаблицаВыплатаПоИностраннойЦБ(ТаблицаDOM)
	
	Если Не ТаблицаDOM.ЕстьДочерниеУзлы() Тогда
		Возврат Ложь;
	КонецЕсли; 
	
	Ячейки = ТаблицаDOM.ПолучитьЭлементыПоИмени("TD");
	
	Если Ячейки.Количество() < 4 Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Если  Найти(Ячейки[0].ТекстовоеСодержимое, "ISIN") > 0 
		И Найти(Ячейки[1].ТекстовоеСодержимое, "Краткое наименование выпуска ц.б.") > 0 
		И Найти(Ячейки[2].ТекстовоеСодержимое, "Номер счета депо") > 0 Или Найти(Ячейки[2].ТекстовоеСодержимое, "Номинал ц.б.") > 0 
		И Найти(Ячейки[3].ТекстовоеСодержимое, "Номер счета депо") > 0 Тогда
		Возврат Истина;
	Иначе
		Возврат Ложь;
	КонецЕсли; 
	
КонецФункции

Процедура ПрочитатьИнформациюИзТаблицыВыплатаПоИностраннойЦБ(Таблица, Данные, ТаблицаПриложения)
	
	УзелСтроки = Таблица.ДочерниеУзлы[0];
	ЯчейкиЗаголовков = УзелСтроки.ПолучитьЭлементыПоИмени("TD");
	СтруктураСодержимого = Новый Соответствие;
	СтруктураСодержимого.Вставить("КодЦБ", 0);
	СтруктураСодержимого.Вставить("НаименованиеЦБ", 1);
	Индекс = 0;
	ТипЦБ = ?(ЗначениеЗаполнено(Данные.ТипЦБ), ?(Данные.ТипЦБ = Перечисления.ТипыЦБ.Акция, "АОИ", "Облигации"), "АОИ");
	Для Каждого Ячейка из ЯчейкиЗаголовков Цикл
		Если Найти(Ячейка.ТекстовоеСодержимое, "Номер счета депо") > 0 Тогда
			СтруктураСодержимого.Вставить("НомерСчетаДепо", Индекс);
		ИначеЕсли Найти(Ячейка.ТекстовоеСодержимое, "Раздел/субсчет депо") > 0 Тогда
			СтруктураСодержимого.Вставить("РазделСчетаДепо", Индекс);
		ИначеЕсли Найти(Ячейка.ТекстовоеСодержимое, "Кол-во ЦБ") > 0 Тогда
			СтруктураСодержимого.Вставить("КоличествоЦБ", Индекс);
		ИначеЕсли Найти(Ячейка.ТекстовоеСодержимое, "Размер выплаты на 1 ЦБ") > 0 Тогда
			СтруктураСодержимого.Вставить("ВыплатаНа1ЦБ", Индекс);
		ИначеЕсли Найти(Ячейка.ТекстовоеСодержимое, "Общая сумма начисленной выплаты") > 0 
			Или Найти(Ячейка.ТекстовоеСодержимое, "Общая сумма начисленного дохода") > 0 Тогда
			СтруктураСодержимого.Вставить("Начислено", Индекс);
		ИначеЕсли Найти(Ячейка.ТекстовоеСодержимое, "Всего к выплате") > 0 Тогда
			СтруктураСодержимого.Вставить("КВыплате", Индекс);
		ИначеЕсли Найти(Ячейка.ТекстовоеСодержимое, "Ставка налога") > 0 Тогда
			СтруктураСодержимого.Вставить("СтавкаНалога", Индекс);
		ИначеЕсли Найти(Ячейка.ТекстовоеСодержимое, "Сумма налога, удержанного налоговым агентом (в валюте платежа)") > 0 Тогда
			СтруктураСодержимого.Вставить("СуммаНалога", Индекс);
		ИначеЕсли Найти(Ячейка.ТекстовоеСодержимое, "Комиссия") > 0 Тогда
			СтруктураСодержимого.Вставить("Комиссия", Индекс);
		КонецЕсли;
		Индекс = Индекс + 1;
	КонецЦикла;
	
	УзелСтроки = Таблица.ДочерниеУзлы[1];
	Ячейки = УзелСтроки.ПолучитьЭлементыПоИмени("TD");
	Данные.КодЦБ 		  	= ТекстЯчейкиУзлаТаблицыВыплатыПоИностраннойЦБ(Ячейки, СтруктураСодержимого, "КодЦБ");
	Данные.НаименованиеЦБ 	= ТекстЯчейкиУзлаТаблицыВыплатыПоИностраннойЦБ(Ячейки, СтруктураСодержимого, "НаименованиеЦБ");
	Данные.ВыплатаНа1ЦБ   	= ПолучитьЧислоИзСтроки(СтрЗаменить(ТекстЯчейкиУзлаТаблицыВыплатыПоИностраннойЦБ(Ячейки, СтруктураСодержимого, "ВыплатаНа1ЦБ"), " ", ""));
	
	ТаблицаПриложения.Колонки.Добавить("НомерСчетаДепо", ОписаниеТиповСтрока, "Номер счета депо");
	ТаблицаПриложения.Колонки.Добавить("РазделСчетаДепо", ОписаниеТиповСтрока, "Раздел счета депо");
	ТаблицаПриложения.Колонки.Добавить("КоличествоЦБ", ОписаниеТиповЧисло, "Кол-во ЦБ");
	ТаблицаПриложения.Колонки.Добавить("Начислено", ОписаниеТиповЧисло, "Начислено");
	ТаблицаПриложения.Колонки.Добавить("КВыплате", ОписаниеТиповЧисло, "К выплате");
	ТаблицаПриложения.Колонки.Добавить("ТипЦБ", ОписаниеТиповСтрока, "Тип ц. б.");
	ТаблицаПриложения.Колонки.Добавить("Комиссия", ОписаниеТиповЧисло, "Комиссия");
	ТаблицаПриложения.Колонки.Добавить("Налог", ОписаниеТиповЧисло, "Налог");
	ТаблицаПриложения.Колонки.Добавить("СтавкаНалога", ОписаниеТиповЧисло, "Ставка налога");
	
	НоваяСтрокаТаблицыПриложений = ТаблицаПриложения.Добавить();
	НоваяСтрокаТаблицыПриложений.НомерСчетаДепо 	= ТекстЯчейкиУзлаТаблицыВыплатыПоИностраннойЦБ(Ячейки, СтруктураСодержимого, "НомерСчетаДепо");
	НоваяСтрокаТаблицыПриложений.РазделСчетаДепо 	= ТекстЯчейкиУзлаТаблицыВыплатыПоИностраннойЦБ(Ячейки, СтруктураСодержимого, "РазделСчетаДепо");
	НоваяСтрокаТаблицыПриложений.КоличествоЦБ 		= ПолучитьЧислоИзСтроки(СтрЗаменить(ТекстЯчейкиУзлаТаблицыВыплатыПоИностраннойЦБ(Ячейки, СтруктураСодержимого, "КоличествоЦБ"), " ", ""));
	НоваяСтрокаТаблицыПриложений.Начислено 			= ПолучитьЧислоИзСтроки(СтрЗаменить(ТекстЯчейкиУзлаТаблицыВыплатыПоИностраннойЦБ(Ячейки, СтруктураСодержимого, "Начислено"), " ", ""));
	НоваяСтрокаТаблицыПриложений.КВыплате 			= ПолучитьЧислоИзСтроки(СтрЗаменить(ТекстЯчейкиУзлаТаблицыВыплатыПоИностраннойЦБ(Ячейки, СтруктураСодержимого, "КВыплате"), " ", ""));
	НоваяСтрокаТаблицыПриложений.Комиссия 			= ПолучитьЧислоИзСтроки(СтрЗаменить(ТекстЯчейкиУзлаТаблицыВыплатыПоИностраннойЦБ(Ячейки, СтруктураСодержимого, "Комиссия"), " ", ""));
	НоваяСтрокаТаблицыПриложений.Налог 				= ПолучитьЧислоИзСтроки(СтрЗаменить(ТекстЯчейкиУзлаТаблицыВыплатыПоИностраннойЦБ(Ячейки, СтруктураСодержимого, "СуммаНалога"), " ", ""));
	НоваяСтрокаТаблицыПриложений.СтавкаНалога 		= ПолучитьЧислоИзСтроки(СтрЗаменить(ТекстЯчейкиУзлаТаблицыВыплатыПоИностраннойЦБ(Ячейки, СтруктураСодержимого, "СтавкаНалога"), " ", ""));
	НоваяСтрокаТаблицыПриложений.ТипЦБ 				= ТипЦБ; 
	
КонецПроцедуры

Функция ТекстЯчейкиУзлаТаблицыВыплатыПоИностраннойЦБ(Ячейки, СтруктураСодержимого, ИмяЯчейки)
	Попытка 
		Возврат СокрЛП(Ячейки[СтруктураСодержимого.Получить(ИмяЯчейки)].ТекстовоеСодержимое);
	Исключение
		Возврат "";
	КонецПопытки;
КонецФункции

Функция ПолучитьПериодДивидендов(ДополнительнаяИнформация)
	
	ПериодДивидендов = СокрЛП(ДополнительнаяИнформация);
	
	Суффикс = "См. приложение.";
	ПозицияСуффикса = Найти(ПериодДивидендов, Суффикс);
	Если ПозицияСуффикса > 0 И ПозицияСуффикса = СтрДлина(ПериодДивидендов) - СтрДлина(Суффикс) + 1 Тогда
		ПериодДивидендов = СтрЗаменить(ПериодДивидендов, Суффикс, "");
	КонецЕсли; 
	
	Возврат ПериодДивидендов;
	
КонецФункции

//процедуры для установки значений на основе разобранного текста
Процедура УстановитьРеквизитыСтрокиТаблицыЗначенийДивидендовКупоновПоРазборуТекста(СтруктураПроверяемыхЗначений, СтрокаТаблицы, ПромежуточныйТипЦБ)
	
	СтруктураПараметров = Новый Структура;
	СтруктураПараметров.Вставить("СтруктураПроверяемыхЗначений", СтруктураПроверяемыхЗначений);
	
	ЗаполнитьСвойстваСтрокиДивидендовКупоновПоРазборуТекстаИлиСоздатьОписание(СтруктураПараметров, , СтрокаТаблицы, ПромежуточныйТипЦБ);
	
КонецПроцедуры

Процедура ЗаполнитьСвойстваСтрокиДивидендовКупоновПоРазборуТекстаИлиСоздатьОписание(СтруктураПараметров, ДанныеРежимаЗагрузкиОписания = Неопределено, СтрокаТаблицы = Неопределено, ПромежуточныйТипЦБ = Неопределено) Экспорт
	
	ИмяБлока = "#1";
	СтруктураПроверяемыхЗначений = СтруктураПараметров.СтруктураПроверяемыхЗначений;	
	
	Если Не ПроверкаНаличияПроверяемыхЗначений(СтруктураПроверяемыхЗначений, ИмяБлока) Тогда
		Возврат;
	КонецЕсли;
	
	Если ПроверкаУсловияСРазборомТекста(ИмяБлока, "НомерИсходящегоДокумента", СтруктураПараметров, ДанныеРежимаЗагрузкиОписания) Тогда
		СтрокаТаблицы.НомерИсходящегоДокумента = СтруктураПроверяемыхЗначений.ТекстСтолбца1; 
		
	ИначеЕсли ПроверкаУсловияСРазборомТекста(ИмяБлока, "ДатаИПД", СтруктураПараметров, ДанныеРежимаЗагрузкиОписания) Тогда
		Если Не ЗначениеЗаполнено(СтрокаТаблицы.Дата) Тогда
			СтрокаТаблицы.Дата = СтроковыеФункцииКлиентСервер.СтрокаВДату(Сред(СокрЛП(СтруктураПроверяемыхЗначений.ТекстСтолбца1), 6, 10));
		КонецЕсли;
		
	ИначеЕсли ПроверкаУсловияСРазборомТекста(ИмяБлока, "НаименованиеЭмитента", СтруктураПараметров, ДанныеРежимаЗагрузкиОписания) Тогда
		СтрокаТаблицы.НаименованиеЭмитента = СтруктураПроверяемыхЗначений.ТекстСтолбца2;				
		
	ИначеЕсли ПроверкаУсловияСРазборомТекста(ИмяБлока, "ДатаФиксацииСписка", СтруктураПараметров, ДанныеРежимаЗагрузкиОписания, ИСТИНА) Тогда	
		Если ЗначениеЗаполнено(СтруктураПроверяемыхЗначений.ТекстСтолбца2) Тогда
			СтрокаТаблицы.ДатаФиксацииСписка = ПолучитьДатуПоСтрокеДДММГГ(СтруктураПроверяемыхЗначений.ТекстСтолбца2);	
		Иначе
			Если ДанныеРежимаЗагрузкиОписания = Неопределено Тогда
				СтрокаТаблицы.ДатаФиксацииСписка = ТекущаяДата();
				ТекстСообщения = "По исх.документу " + СтрокаТаблицы.НомерИсходящегоДокумента +" не заполнена дата фиксацими.Она заменена на сегодняшнюю дату. Проверьте корректность данных в файле передачи.";
				ОбщегоНазначения.СообщитьОбОшибке(ТекстСообщения);
				ЗаписьЖурналаРегистрации("Ошибка при загрузке документов из НРД", УровеньЖурналаРегистрации.Предупреждение,,, ТекстСообщения);
			КонецЕсли;
		КонецЕсли;
		
		Если ПроверкаУсловияСРазборомТекста(ИмяБлока, "ФиксацияНаУтро", СтруктураПараметров, ДанныеРежимаЗагрузкиОписания) Тогда		
			СтрокаТаблицы.ФиксацияНаУтро = ИСТИНА;
		КонецЕсли;
		
	ИначеЕсли ПроверкаУсловияСРазборомТекста(ИмяБлока, "НомерПлатежногоПоручения", СтруктураПараметров, ДанныеРежимаЗагрузкиОписания) Тогда		
		СтрокаТаблицы.НомерПлатежногоПоручения = СокрЛП(СтруктураПроверяемыхЗначений.ТекстСтолбца3);
		
	ИначеЕсли ПроверкаУсловияСРазборомТекста(ИмяБлока, "ДатаПлатежногоПоручения", СтруктураПараметров, ДанныеРежимаЗагрузкиОписания) Тогда	
		СтрокаТаблицы.ДатаПлатежногоПоручения = Дата(СтруктураПроверяемыхЗначений.ТекстСтолбца2+" 00:00:00");
		
	ИначеЕсли ПроверкаУсловияСРазборомТекста(ИмяБлока, "ЦенаАО", СтруктураПараметров, ДанныеРежимаЗагрузкиОписания) Тогда	
		СтрокаТаблицы.ЦенаАО = ПолучитьЧислоИзСтроки(СтруктураПроверяемыхЗначений.ТекстСтолбца3);	
		
	ИначеЕсли ПроверкаУсловияСРазборомТекста(ИмяБлока, "ЦенаАП", СтруктураПараметров, ДанныеРежимаЗагрузкиОписания) Тогда	
		СтрокаТаблицы.ЦенаАП = ПолучитьЧислоИзСтроки(СтруктураПроверяемыхЗначений.ТекстСтолбца2);
		
	ИначеЕсли ПроверкаУсловияСРазборомТекста(ИмяБлока, "ОбщаяСумма", СтруктураПараметров, ДанныеРежимаЗагрузкиОписания) Тогда	
		СтрокаТаблицы.ОбщаяСумма = ПолучитьЧислоИзСтроки(СтруктураПроверяемыхЗначений.ТекстСтолбца2);
		
	ИначеЕсли ПроверкаУсловияСРазборомТекста(ИмяБлока, "СуммаКВыплате", СтруктураПараметров, ДанныеРежимаЗагрузкиОписания) Тогда	
		СтрокаТаблицы.СуммаКВыплате = ПолучитьЧислоИзСтроки(СтруктураПроверяемыхЗначений.ТекстСтолбца2);	
		
	ИначеЕсли ПроверкаУсловияСРазборомТекста(ИмяБлока, "ДопУдержания", СтруктураПараметров, ДанныеРежимаЗагрузкиОписания) Тогда
		СтрокаТаблицы.ДопУдержания = ПолучитьЧислоИзСтроки(СтруктураПроверяемыхЗначений.ТекстСтолбца2);	
		
	ИначеЕсли ПроверкаУсловияСРазборомТекста(ИмяБлока, "СуммаВыплаченнаяРанее", СтруктураПараметров, ДанныеРежимаЗагрузкиОписания) Тогда
		СтрокаТаблицы.СуммаВыплаченнаяРанее = ПолучитьЧислоИзСтроки(СтруктураПроверяемыхЗначений.ТекстСтолбца2);
		
	ИначеЕсли ПроверкаУсловияСРазборомТекста(ИмяБлока, "Д1", СтруктураПараметров, ДанныеРежимаЗагрузкиОписания) Тогда
		СтрокаТаблицы.Д1 = ПолучитьЧислоИзСтроки(СтруктураПроверяемыхЗначений.ТекстСтолбца2);
	
	ИначеЕсли ПроверкаУсловияСРазборомТекста(ИмяБлока, "Д2", СтруктураПараметров, ДанныеРежимаЗагрузкиОписания) Тогда
		СтрокаТаблицы.Д2 = ПолучитьЧислоИзСтроки(СтруктураПроверяемыхЗначений.ТекстСтолбца2);

	ИначеЕсли ПроверкаУсловияСРазборомТекста(ИмяБлока, "Номинал", СтруктураПараметров, ДанныеРежимаЗагрузкиОписания) Тогда
		СтрокаТаблицы.Номинал = ПолучитьЧислоИзСтроки(СтруктураПроверяемыхЗначений.ТекстСтолбца2);
	
	ИначеЕсли ПроверкаУсловияСРазборомТекста(ИмяБлока, "НаименованиеЦБ", СтруктураПараметров, ДанныеРежимаЗагрузкиОписания) Тогда
		СтрокаТаблицы.НаименованиеЦБ = СтруктураПроверяемыхЗначений.ТекстСтолбца2;
				
	ИначеЕсли ПроверкаУсловияСРазборомТекста(ИмяБлока, "КодЦБ", СтруктураПараметров, ДанныеРежимаЗагрузкиОписания) Тогда
		СтрокаТаблицы.КодЦБ = СтруктураПроверяемыхЗначений.ТекстСтолбца2;		
		
	ИначеЕсли ПроверкаУсловияСРазборомТекста(ИмяБлока, "ДополнительнаяИнформация", СтруктураПараметров, ДанныеРежимаЗагрузкиОписания, Истина) Тогда
		
		Если ДанныеРежимаЗагрузкиОписания = Неопределено Тогда //т.к. в ином случае сюда попадает выполнение и дает ошибку, ибо СтрокаТаблицы = неопределено
			СтрокаТаблицы.ДополнительнаяИнформация = СтруктураПроверяемыхЗначений.ТекстСтолбца2;
			СтрокаТаблицы.ПериодДивидендов 		   = ПолучитьПериодДивидендов(СтруктураПроверяемыхЗначений.ТекстСтолбца2);
		КонецЕсли;
				
		Если ПроверкаУсловияСРазборомТекста(ИмяБлока, "ТипЦБ = Акция", СтруктураПараметров, ДанныеРежимаЗагрузкиОписания) Тогда
			СтрокаТаблицы.ТипЦБ = Перечисления.ТипыЦБ.Акция;
			
		ИначеЕсли ПроверкаУсловияСРазборомТекста(ИмяБлока, "ТипЦБ = Облигация", СтруктураПараметров, ДанныеРежимаЗагрузкиОписания) Тогда
		    СтрокаТаблицы.ТипЦБ = Перечисления.ТипыЦБ.Облигация;
			
		ИначеЕсли ПроверкаУсловияСРазборомТекста(ИмяБлока, "ТипЦБ = Облигация (по наименование ЦБ)", СтруктураПараметров, ДанныеРежимаЗагрузкиОписания) Тогда
			СтрокаТаблицы.ТипЦБ = Перечисления.ТипыЦБ.Облигация;	
			
		ИначеЕсли ПроверкаУсловияСРазборомТекста(ИмяБлока, "ТипЦБ = Пай", СтруктураПараметров, ДанныеРежимаЗагрузкиОписания) Тогда
			СтрокаТаблицы.ТипЦБ = Перечисления.ТипыЦБ.Пай;
			
		Иначе
		
			Если ДанныеРежимаЗагрузкиОписания = Неопределено Тогда			
				ПромежуточныйТипЦБ = Перечисления.ТипыЦБ.Акция;  // по умолчанию
			
			КонецЕсли;
					
		КонецЕсли;
		
	ИначеЕсли ПроверкаУсловияСРазборомТекста(ИмяБлока, "БИК", СтруктураПараметров, ДанныеРежимаЗагрузкиОписания) Тогда
		СтрокаТаблицы.БИК = СтруктураПроверяемыхЗначений.ТекстСтолбца3;
		
	ИначеЕсли ПроверкаУсловияСРазборомТекста(ИмяБлока, "НомерСчета", СтруктураПараметров, ДанныеРежимаЗагрузкиОписания) Тогда
		СтрокаТаблицы.НомерСчета = СтруктураПроверяемыхЗначений.ТекстСтолбца3;	
		
	КонецЕсли;
	
	Если ДанныеРежимаЗагрузкиОписания <> Неопределено И СтруктураПараметров.Свойство("ДанныеДляРекурсивногоОписания") Тогда
		ЗаполнитьСвойстваСтрокиДивидендовКупоновПоРазборуТекстаИлиСоздатьОписание(СтруктураПараметров, ДанныеРежимаЗагрузкиОписания, СтрокаТаблицы, ПромежуточныйТипЦБ);
	КонецЕсли;
	
КонецПроцедуры

Процедура УстановитьРеквизитыСтрокиТаблицыЗначенийДивидендовКупоновПоИностраннойЦБ(СтруктураПроверяемыхЗначений, СтрокаТаблицы)
	
	СтруктураПараметров = Новый Структура;
	СтруктураПараметров.Вставить("СтруктураПроверяемыхЗначений", СтруктураПроверяемыхЗначений);
	ЗаполнитьВидОперацииВСтрокеДивидендовКупоновСИностраннойЦБПоРазборуТекстаИлиСоздатьОписание(СтруктураПараметров, , СтрокаТаблицы);
	
КонецПроцедуры

Процедура ЗаполнитьВидОперацииВСтрокеДивидендовКупоновСИностраннойЦБПоРазборуТекстаИлиСоздатьОписание(СтруктураПараметров, ДанныеРежимаЗагрузкиОписания = Неопределено, СтрокаТаблицы = Неопределено) Экспорт
	
	ИмяБлока = "#3";
	СтруктураПроверяемыхЗначений = СтруктураПараметров.СтруктураПроверяемыхЗначений;
	
	Если Не ПроверкаНаличияПроверяемыхЗначений(СтруктураПроверяемыхЗначений, ИмяБлока) Тогда
		Возврат;
	КонецЕсли;
	
	Если ПроверкаУсловияСРазборомТекста(ИмяБлока, "НомерИсходящегоДокумента", СтруктураПараметров, ДанныеРежимаЗагрузкиОписания) Тогда
		СтрокаТаблицы.НомерИсходящегоДокумента = СтруктураПроверяемыхЗначений.ТекстСтолбца1; 
		
	ИначеЕсли ПроверкаУсловияСРазборомТекста(ИмяБлока, "ДатаИПД", СтруктураПараметров, ДанныеРежимаЗагрузкиОписания) Тогда
		Если Не ЗначениеЗаполнено(СтрокаТаблицы.Дата) Тогда
			СтрокаТаблицы.Дата = СтроковыеФункцииКлиентСервер.СтрокаВДату(Сред(СокрЛП(СтруктураПроверяемыхЗначений.ТекстСтолбца1), 6, 10));
		КонецЕсли;
		
	ИначеЕсли ПроверкаУсловияСРазборомТекста(ИмяБлока, "НаименованиеЭмитента", СтруктураПараметров, ДанныеРежимаЗагрузкиОписания) Тогда
		СтрокаТаблицы.НаименованиеЭмитента = СтруктураПроверяемыхЗначений.ТекстСтолбца2;
		
	ИначеЕсли ПроверкаУсловияСРазборомТекста(ИмяБлока, "ВыплатаВалюты и Доп.информация", СтруктураПараметров, ДанныеРежимаЗагрузкиОписания) Тогда
		НаименованиеВалюты = СокрЛП(СтруктураПроверяемыхЗначений.ТекстСтолбца2);
		Если НаименованиеВалюты = "RUR" Или НаименованиеВалюты = "RUB" Тогда
			НаименованиеВалюты = "SUR";
		КонецЕсли;
		СтрокаТаблицы.ВалютаВыплаты = Справочники.Валюты.НайтиПоНаименованию(НаименованиеВалюты);
		Если СтрокаТаблицы.ВалютаВыплаты.Пустая() Тогда
			СтрокаТаблицы.ВалютаВыплаты = Валюта;
		КонецЕсли;
		СтрокаТаблицы.ДополнительнаяИнформация = СтрЗаменить(СтрокаТаблицы.ДополнительнаяИнформация,
		"#ВалютаВыплаты#", " " + НаименованиеВалюты);	
		
	ИначеЕсли ПроверкаУсловияСРазборомТекста(ИмяБлока, "ДатаФиксацииСписка", СтруктураПараметров, ДанныеРежимаЗагрузкиОписания, Истина) Тогда	
		Если ЗначениеЗаполнено(СтруктураПроверяемыхЗначений.ТекстСтолбца2) Тогда
			СтрокаТаблицы.ДатаФиксацииСписка = ПолучитьДатуПоСтрокеДДММГГ(СтруктураПроверяемыхЗначений.ТекстСтолбца2);
		Иначе
			Если ДанныеРежимаЗагрузкиОписания = Неопределено Тогда
				СтрокаТаблицы.ДатаФиксацииСписка = ТекущаяДата();
				ТекстСообщения = "По исх.документу " + СтрокаТаблицы.НомерИсходящегоДокумента +" не заполнена дата фиксацими.Она заменена на сегодняшнюю дату. Проверьте корректность данных в файле передачи.";
				ОбщегоНазначения.СообщитьОбОшибке(ТекстСообщения);
				ЗаписьЖурналаРегистрации("Ошибка при загрузке документов из НРД", УровеньЖурналаРегистрации.Предупреждение,,, ТекстСообщения);
			КонецЕсли;
		КонецЕсли;
		
		Если ПроверкаУсловияСРазборомТекста(ИмяБлока, "ФиксацияНаУтро", СтруктураПараметров, ДанныеРежимаЗагрузкиОписания) Тогда		
			СтрокаТаблицы.ФиксацияНаУтро = ИСТИНА;
		КонецЕсли;

	ИначеЕсли ПроверкаУсловияСРазборомТекста(ИмяБлока, "НомерПлатежногоПоручения", СтруктураПараметров, ДанныеРежимаЗагрузкиОписания) Тогда		
		СтрокаТаблицы.НомерПлатежногоПоручения = СтруктураПроверяемыхЗначений.ТекстСтолбца2;
		
	ИначеЕсли ПроверкаУсловияСРазборомТекста(ИмяБлока, "ДатаПлатежногоПоручения", СтруктураПараметров, ДанныеРежимаЗагрузкиОписания) Тогда	
		СтрокаТаблицы.ДатаПлатежногоПоручения = Дата(СтруктураПроверяемыхЗначений.ТекстСтолбца2+" 00:00:00");
		
	ИначеЕсли ПроверкаУсловияСРазборомТекста(ИмяБлока, "ОбщаяСумма И СуммаКВыплате", СтруктураПараметров, ДанныеРежимаЗагрузкиОписания) Тогда 		
		СтрокаТаблицы.СуммаКВыплате = ПолучитьЧислоИзСтроки(СтруктураПроверяемыхЗначений.ТекстСтолбца2);
		СтрокаТаблицы.ОбщаяСумма = СтрокаТаблицы.СуммаКВыплате;		
		
	ИначеЕсли ПроверкаУсловияСРазборомТекста(ИмяБлока, "ДопУдержания", СтруктураПараметров, ДанныеРежимаЗагрузкиОписания) Тогда
		СтрокаТаблицы.ДопУдержания = ПолучитьЧислоИзСтроки(СтруктураПроверяемыхЗначений.ТекстСтолбца2);
		
	ИначеЕсли ПроверкаУсловияСРазборомТекста(ИмяБлока, "СуммаВыплаченнаяРанее", СтруктураПараметров, ДанныеРежимаЗагрузкиОписания) Тогда
		СтрокаТаблицы.СуммаВыплаченнаяРанее = ПолучитьЧислоИзСтроки(СтруктураПроверяемыхЗначений.ТекстСтолбца2);
		
	ИначеЕсли ПроверкаУсловияСРазборомТекста(ИмяБлока, "Д1", СтруктураПараметров, ДанныеРежимаЗагрузкиОписания) Тогда
		СтрокаТаблицы.Д1 = ПолучитьЧислоИзСтроки(СтруктураПроверяемыхЗначений.ТекстСтолбца2);
	
	ИначеЕсли ПроверкаУсловияСРазборомТекста(ИмяБлока, "Д2", СтруктураПараметров, ДанныеРежимаЗагрузкиОписания) Тогда
		СтрокаТаблицы.Д2 = ПолучитьЧислоИзСтроки(СтруктураПроверяемыхЗначений.ТекстСтолбца2);		
		
	ИначеЕсли ПроверкаУсловияСРазборомТекста(ИмяБлока, "НомерСчета", СтруктураПараметров, ДанныеРежимаЗагрузкиОписания) И НЕ ЗначениеЗаполнено(СтрокаТаблицы.НомерСчета)Тогда
		СтрокаТаблицы.НомерСчета = СтруктураПроверяемыхЗначений.ТекстСтолбца2;		

	ИначеЕсли ПроверкаУсловияСРазборомТекста(ИмяБлока, "ДополнительнаяИнформация и ПериодДивидендов", СтруктураПараметров, ДанныеРежимаЗагрузкиОписания, Истина) Тогда
		
		Если ДанныеРежимаЗагрузкиОписания = Неопределено Тогда //т.к. в ином случае сюда попадает выполнение и дает ошибку, ибо СтрокаТаблицы = неопределено
			СтрокаТаблицы.ДополнительнаяИнформация = СтруктураПроверяемыхЗначений.ТекстСтолбца2;
			СтрокаТаблицы.ПериодДивидендов 		   = ПолучитьПериодДивидендов(СтруктураПроверяемыхЗначений.ТекстСтолбца2);
		КонецЕсли;
				
		Если ПроверкаУсловияСРазборомТекста(ИмяБлока, "ТипЦБ = Акция И ДополнительнаяИнформация", СтруктураПараметров, ДанныеРежимаЗагрузкиОписания) Тогда
			СтрокаТаблицы.ТипЦБ = Перечисления.ТипыЦБ.Акция;
			СтрокаТаблицы.ДополнительнаяИнформация = "Выплата дивидендов";
		ИначеЕсли ПроверкаУсловияСРазборомТекста(ИмяБлока, "ВидКД = MCAL", СтруктураПараметров, ДанныеРежимаЗагрузкиОписания) Тогда
			СтрокаТаблицы.ТипЦБ = Перечисления.ТипыЦБ.Облигация;
			СтрокаТаблицы.ВидКД = Справочники.ВидыКорпоративныхДействий.MCAL();
			СтрокаТаблицы.ВидОперации = Справочники.ВидыОпераций.ПогашениеЦБПолное;	
		ИначеЕсли ПроверкаУсловияСРазборомТекста(ИмяБлока, "ТипЦБ = Облигация", СтруктураПараметров, ДанныеРежимаЗагрузкиОписания) Тогда
		    СтрокаТаблицы.ТипЦБ = Перечисления.ТипыЦБ.Облигация;
			
		ИначеЕсли ПроверкаУсловияСРазборомТекста(ИмяБлока, "ТипЦБ = Облигация (по наименованию ЦБ)", СтруктураПараметров, ДанныеРежимаЗагрузкиОписания) Тогда
			СтрокаТаблицы.ТипЦБ = Перечисления.ТипыЦБ.Облигация;
		ИначеЕсли ПроверкаУсловияСРазборомТекста(ИмяБлока, "ТипЦБ = Пай", СтруктураПараметров, ДанныеРежимаЗагрузкиОписания) Тогда
			СтрокаТаблицы.ТипЦБ = Перечисления.ТипыЦБ.Пай;
		ИначеЕсли ПроверкаУсловияСРазборомТекста(ИмяБлока, "ВидКД = CAPG", СтруктураПараметров, ДанныеРежимаЗагрузкиОписания) Тогда
			СтрокаТаблицы.ТипЦБ = Перечисления.ТипыЦБ.Акция;
			СтрокаТаблицы.ВидКД = Справочники.ВидыКорпоративныхДействий.CAPG();
			СтрокаТаблицы.ВидОперации = Справочники.ВидыОпераций.НачислениеДоходаПрочие;
			
		//если для основого режима есть ветка "иначе", то она обязательно должны быть переделана в ИначеЕсли ДанныеРежимаЗагрузкиОписания = Неопределено
		//для рабочего режима на результат это не повлияет, но инае пострадает режим описания
		ИначеЕсли ДанныеРежимаЗагрузкиОписания = Неопределено Тогда //т.к. в ином случае сюда попадает выполнение и дает ошибку, ибо СтрокаТаблицы = неопределено
			СтрокаТаблицы.ТипЦБ = Перечисления.ТипыЦБ.Акция;  // по умолчанию
			
		КонецЕсли;
		
	ИначеЕсли ПроверкаУсловияСРазборомТекста(ИмяБлока, "БИК", СтруктураПараметров, ДанныеРежимаЗагрузкиОписания) Тогда
		СтрокаТаблицы.БИК = СтруктураПроверяемыхЗначений.ТекстСтолбца3;
		
	ИначеЕсли ПроверкаУсловияСРазборомТекста(ИмяБлока, "НомерСчета: условие 2", СтруктураПараметров, ДанныеРежимаЗагрузкиОписания) Тогда
		СтрокаТаблицы.НомерСчета = СтруктураПроверяемыхЗначений.ТекстСтолбца3;
		
	КонецЕсли;

	Если ДанныеРежимаЗагрузкиОписания <> Неопределено И СтруктураПараметров.Свойство("ДанныеДляРекурсивногоОписания") Тогда
		ЗаполнитьВидОперацииВСтрокеДивидендовКупоновСИностраннойЦБПоРазборуТекстаИлиСоздатьОписание(СтруктураПараметров, ДанныеРежимаЗагрузкиОписания, СтрокаТаблицы);
	КонецЕсли;
	
КонецПроцедуры

Процедура УстановитьВидОперацииВСтрокеДивидендовИКупоновПоДополнительнойИнформации(СтруктураПроверяемыхЗначений, СтрокаТаблицы)
	
	СтруктураПараметров = Новый Структура;
	СтруктураПараметров.Вставить("СтруктураПроверяемыхЗначений", СтруктураПроверяемыхЗначений); 
	ЗаполнитьВидОперацииВСтрокеДивидендовКупоновПоРазборуТекстаИлиСоздатьОписание(СтруктураПараметров, , СтрокаТаблицы);
	
КонецПроцедуры

Процедура ЗаполнитьВидОперацииВСтрокеДивидендовКупоновПоРазборуТекстаИлиСоздатьОписание(СтруктураПараметров, ДанныеРежимаЗагрузкиОписания = Неопределено, СтрокаТаблицы = Неопределено) Экспорт
	
	ИмяБлока = "#2";
	СтруктураПроверяемыхЗначений = СтруктураПараметров.СтруктураПроверяемыхЗначений;
	
	Если Не ПроверкаНаличияПроверяемыхЗначений(СтруктураПроверяемыхЗначений, ИмяБлока) Тогда
		Возврат;
	КонецЕсли;	
	УсловияРазбораТекста = РегистрыСведений.НастройкиРазбораТекстовыхДанных.ПолучитьУсловияРазбораТекста(ЭтотОбъект.Метаданные().ПолноеИмя(), ИмяБлока);
	Если УсловияРазбораТекста.Количество() = 0 И НЕ ДанныеРежимаЗагрузкиОписания = Неопределено Тогда
		ДанныеЗаполненияБлока = ДанныеРежимаЗагрузкиОписания[ИмяБлока];
		Для Каждого Условие Из ДанныеЗаполненияБлока Цикл
			ПроверкаУсловияСРазборомТекста(ИмяБлока, Условие.Ключ, СтруктураПараметров, ДанныеРежимаЗагрузкиОписания);
		КонецЦикла;
	ИначеЕсли УсловияРазбораТекста.Количество() > 0 Тогда	
		Для Каждого УсловиеРазбораТекста Из УсловияРазбораТекста Цикл
			Результат = ПроверкаУсловияСРазборомТекста(ИмяБлока, УсловиеРазбораТекста.Условие, СтруктураПараметров, ДанныеРежимаЗагрузкиОписания);
			Если Результат Тогда
				ПолучитьВидОперации(СтрокаТаблицы, УсловиеРазбораТекста.Условие);
				Прервать;
			КонецЕсли;
		КонецЦикла;
		
		Если Не Результат Тогда
			СообщениеОбОшибке = "Не удалось определить вид операции по полю Дополнительная операция";
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Текст = СообщениеОбОшибке;
			Сообщение.Сообщить();
			ЗаписьЖурналаРегистрации("Загрузка документов из ФШ", УровеньЖурналаРегистрации.Ошибка, ЭтотОбъект.Метаданные(),, СообщениеОбОшибке);
		КонецЕсли;
	КонецЕСли;
	
	Если ДанныеРежимаЗагрузкиОписания <> Неопределено И СтруктураПараметров.Свойство("ДанныеДляРекурсивногоОписания") Тогда
		ЗаполнитьВидОперацииВСтрокеДивидендовКупоновПоРазборуТекстаИлиСоздатьОписание(СтруктураПараметров, ДанныеРежимаЗагрузкиОписания, СтрокаТаблицы);
	КонецЕсли;
	
КонецПроцедуры

Процедура ПолучитьВидОперации(Строка, Условие)
	ПозицияРавенства = СтрНайти(Условие, "=");
	ИмяРеквизита = СокрЛП(Лев(Условие, ПозицияРавенства - 1));
	ИмяЗначения = СокрЛП(Прав(Условие, СтрДлина(Условие) - ПозицияРавенства));
	Строка[ИмяРеквизита] = Справочники.ВидыОпераций[ИмяЗначения];
КонецПроцедуры

Процедура УстановитьДопИнформациюВСтрокеДивидендовИКупоновПоДополнительнойИнформации(СтруктураПроверяемыхЗначений, СтрокаТаблицы) 
	
	СтруктураПараметров = Новый Структура;
	СтруктураПараметров.Вставить("СтруктураПроверяемыхЗначений", СтруктураПроверяемыхЗначений);
	ЗаполнитьДопИнформациюВСтрокеДивидендовКупоновПоРазборуТекстаИлиСоздатьОписание(СтруктураПараметров, , СтрокаТаблицы);
	
КонецПроцедуры

Процедура ЗаполнитьДопИнформациюВСтрокеДивидендовКупоновПоРазборуТекстаИлиСоздатьОписание(СтруктураПараметров, ДанныеРежимаЗагрузкиОписания = Неопределено, СтрокаТаблицы = Неопределено) Экспорт
	
	ИмяБлока = "#4";
	СтруктураПроверяемыхЗначений = СтруктураПараметров.СтруктураПроверяемыхЗначений;
	
	Если Не ПроверкаНаличияПроверяемыхЗначений(СтруктураПроверяемыхЗначений, ИмяБлока) Тогда
		Возврат;
	КонецЕсли; 	
	
	Если ПроверкаУсловияСРазборомТекста(ИмяБлока, "ДопИнформация = Выплата КД по облигациям", СтруктураПараметров, ДанныеРежимаЗагрузкиОписания) Тогда
		СтрокаТаблицы.ДополнительнаяИнформация = "Выплата купонного дохода по облигациям ";
	ИначеЕсли ПроверкаУсловияСРазборомТекста(ИмяБлока, "ДопИнформация = Выплата части н.с. при частичном погашении облигаций ", СтруктураПараметров, ДанныеРежимаЗагрузкиОписания) Тогда
		СтрокаТаблицы.ДополнительнаяИнформация = "Выплата части номинальной стоимости при частичном погашении облигаций ";
	ИначеЕсли ПроверкаУсловияСРазборомТекста(ИмяБлока, "ДопИнформация = Выплата н.с. при погашении облигаций ", СтруктураПараметров, ДанныеРежимаЗагрузкиОписания) Тогда
		СтрокаТаблицы.ДополнительнаяИнформация = "Выплата номинальной стоимости при погашении облигаций ";		
	КонецЕсли;
	
	Если ДанныеРежимаЗагрузкиОписания <> Неопределено И СтруктураПараметров.Свойство("ДанныеДляРекурсивногоОписания") Тогда
		ЗаполнитьДопИнформациюВСтрокеДивидендовКупоновПоРазборуТекстаИлиСоздатьОписание(СтруктураПроверяемыхЗначений, ДанныеРежимаЗагрузкиОписания, СтрокаТаблицы);
	КонецЕсли;
	
КонецПроцедуры

// ДИВИДЕНДЫ И КУПОНЫ ЗАГРУЗКА ДАННЫХ ИЗ HTM ФАЙЛОВ СЧИТАННЫХ ИЗ "ЛУЧ"
///////////////////////////////////////////////////////////////////////////////

