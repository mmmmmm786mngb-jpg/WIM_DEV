	|			И (ВЫБОР
	|				КОГДА ДК.Номер = """"
	|						ИЛИ ПОДСТРОКА(ДК.Номер, 1, 1) = ""#""
	|					ТОГДА Поручение.НомерИПД = ДК.НомерИПД
	|				ИНАЧЕ Поручение.НомерОтчета = ДК.Номер
	|			КОНЕЦ)
	|			И (Поручение.СчетДепоМХДокумента = &СчетДепоМХ)";
	
	Запрос.УстановитьПараметр("ТекущаяДата"				, ТекущаяДатаСеанса());
	Запрос.УстановитьПараметр("ТЗ"						, ДивидендыКупоны);
	Запрос.УстановитьПараметр("Организация"				, Организация);
	Запрос.УстановитьПараметр("МестоХранения"			, Депозитарий);
	Запрос.УстановитьПараметр("КлассификаторЗагрузки"	, Константы.КлассификаторЗагрузкиНДЦ.Получить());
	Запрос.УстановитьПараметр("СчетДепоМХ"				, СчетДепоМХ);
	Запрос.Выполнить();
КонецПроцедуры

// BSLLS:QueryParseError-on

Процедура Подготовить_втСвязанныеДокументыКД(Запрос)
	Запрос.Текст =
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ДК.ДатаФиксацииСписка КАК ДатаФиксацииСписка,
	|	ДК.ЦеннаяБумага КАК ЦеннаяБумага,
	|	ДК.ВидКД КАК ВидКД,
	|	ДК.ВыплатаНа1ЦБ КАК ВыплатаНа1ЦБ
	|ПОМЕСТИТЬ втПоляПоискаКД
	|ИЗ
	|	втДивидендыКупоныСоСсылками КАК ДК
	|ГДЕ
	|	ДК.НомерИПД <> """"
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Поля.ДатаФиксацииСписка КАК ДатаФиксацииСписка,
	|	Поля.ЦеннаяБумага КАК ЦеннаяБумага,
	|	ВЫБОР
	|		КОГДА КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ЕСТЬNULL(КД2.Ссылка, КД.Ссылка)) = 1
	|			ТОГДА МАКСИМУМ(ЕСТЬNULL(КД2.Ссылка, КД.Ссылка))
	|	КОНЕЦ КАК КарточкаКД
	|ПОМЕСТИТЬ втСвязанныеДокументыКД
	|ИЗ
	|	втПоляПоискаКД КАК Поля
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.КорпоративноеДействие_Новый КАК КД
	|		ПО Поля.ДатаФиксацииСписка = КД.ДатаФиксации
	|			И Поля.ЦеннаяБумага = КД.ЦеннаяБумага1
	|			И Поля.ВидКД = КД.ВидКД
	|			И (НЕ КД.ПометкаУдаления)
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.КорпоративноеДействие_Новый КАК КД2
	|		ПО Поля.ДатаФиксацииСписка = КД2.ДатаФиксации
	|			И Поля.ЦеннаяБумага = КД2.ЦеннаяБумага1
	|			И Поля.ВидКД = КД2.ВидКД
	|			И Поля.ВыплатаНа1ЦБ = КД2.ВыплатаНа1ЦБ
	|			И (КД2.ВидКД В (&ВидыКДОпределяемыеПоВыплатеНаЦБ))
	|			И (НЕ КД2.ПометкаУдаления)
	|
	|СГРУППИРОВАТЬ ПО
	|	Поля.ДатаФиксацииСписка,
	|	Поля.ЦеннаяБумага";
	ВидыКДОпределяемыеПоВыплатеНаЦБ = Новый Массив();
	ВидыКДОпределяемыеПоВыплатеНаЦБ.Добавить(Справочники.ВидыКорпоративныхДействий.CAPG());
	ВидыКДОпределяемыеПоВыплатеНаЦБ.Добавить(Справочники.ВидыКорпоративныхДействий.MCAL());
	Запрос.УстановитьПараметр("ВидыКДОпределяемыеПоВыплатеНаЦБ", ВидыКДОпределяемыеПоВыплатеНаЦБ);
	Запрос.Выполнить();
КонецПроцедуры

Процедура ДополнитьОбщуюТаблицуСсылкамиНаЭлементыБазы()
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	Подготовить_втДивидендыКупоныСоСсылками(Запрос);
	Подготовить_втСвязанныеДокументыКД(Запрос);
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ДК.БИК КАК БИК,
	|	ДК.НомерСчета КАК НомерСчета,
	|	ДК.Д1 КАК Д1,
	|	ДК.Д2 КАК Д2,
	|	ДК.Дата КАК Дата,
	|	ДК.ДатаЗакрытияРеестра КАК ДатаЗакрытияРеестра,
	|	ДК.ДатаПлатежногоПоручения КАК ДатаПлатежногоПоручения,
	|	ДК.ДатаФиксацииСписка КАК ДатаФиксацииСписка,
	|	ДК.ДополнительнаяИнформация КАК ДополнительнаяИнформация,
	|	ДК.Идентификатор КАК Идентификатор,
	|	ДК.КодЦБ КАК КодЦБ,
	|	ДК.НаименованиеЦБ КАК НаименованиеЦБ,
	|	ДК.НаименованиеЭмитента КАК НаименованиеЭмитента,
	|	ДК.НачислениеАО КАК НачислениеАО,
	|	ДК.НачислениеАП КАК НачислениеАП,
	|	ДК.Номер КАК Номер,
	|	ДК.НомерИсходящегоДокумента КАК НомерИсходящегоДокумента,
	|	ДК.НомерПлатежногоПоручения КАК НомерПлатежногоПоручения,
	|	ДК.Номинал КАК Номинал,
	|	ДК.ОбщаяСумма КАК ОбщаяСумма,
	|	ДК.ПериодДивидендов КАК ПериодДивидендов,
	|	ДК.СуммаКВыплате КАК СуммаКВыплате,
	|	ДК.ТипЦБ КАК ТипЦБ,
	|	ДК.ЦенаАО КАК ЦенаАО,
	|	ДК.ЦенаАП КАК ЦенаАП,
	|	ДК.ВидОперации КАК ВидОперации,
	|	ДК.ВыплатаНа1ЦБ КАК ВыплатаНа1ЦБ,
	|	ДК.ВалютаВыплаты КАК ВалютаВыплаты,
	|	ДК.ДопУдержания КАК ДопУдержания,
	|	ДК.СуммаВыплаченнаяРанее КАК СуммаВыплаченнаяРанее,
	|	ДК.ИзвещениеПоИностраннойЦеннойБумаге КАК ИзвещениеПоИностраннойЦеннойБумаге,
	|	ДК.НомерИПД КАК НомерИПД,
	|	ДК.ВидКД КАК ВидКД,
	|	ДК.БанковскийСчет КАК БанковскийСчет,
	|	ДК.ЦеннаяБумага КАК ЦеннаяБумага,
	|	ДК.Эмитент КАК Эмитент,
	|	ДК.Поручение КАК Поручение,
	|	ЕСТЬNULL(СвязанныеДокументыКД.КарточкаКД, &ПустоеКД) КАК КарточкаКД,
	|	ДК.НеПроверятьНаличиеКарточкиКД КАК НеПроверятьНаличиеКарточкиКД,
	|	ДК.ПутьККаталогу КАК ПутьККаталогу,
	|	ДК.ФиксацияНаУтро КАК ФиксацияНаУтро
	|ИЗ
	|	втДивидендыКупоныСоСсылками КАК ДК
	|		ЛЕВОЕ СОЕДИНЕНИЕ втСвязанныеДокументыКД КАК СвязанныеДокументыКД
	|		ПО (СвязанныеДокументыКД.ДатаФиксацииСписка = ДК.ДатаФиксацииСписка)
	|			И (СвязанныеДокументыКД.ЦеннаяБумага = ДК.ЦеннаяБумага)";
	
	Запрос.УстановитьПараметр("ПустоеКД", Документы.КорпоративноеДействие_Новый.ПустаяСсылка());
	ДивидендыКупоны.Загрузить(Запрос.Выполнить().Выгрузить());

	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	БанковскиеСчета.Владелец КАК Владелец,
	|	БанковскиеСчета.Ссылка КАК Ссылка,
	|	БанковскиеСчета.ВалютаДенежныхСредств КАК Валюта,
	|	БанковскиеСчета.Банк.Код КАК БИК
	|ИЗ
	|	Справочник.БанковскиеСчета КАК БанковскиеСчета
	|ГДЕ
	|	БанковскиеСчета.ТипНазначения = &ДепозитарныйТранзит
	|	И БанковскиеСчета.Владелец = &Организация
	|
	|УПОРЯДОЧИТЬ ПО
	|	БанковскиеСчета.ДатаОткрытия УБЫВ");
	Запрос.УстановитьПараметр("ДепозитарныйТранзит", Перечисления.ТипыНазначенияБанковскихСчетов.ДепозитарныйТранзит);
	Запрос.УстановитьПараметр("Организация", Организация);
	ТранзитныеСчетаОрганизации = Запрос.Выполнить().Выгрузить();
	ВалютаРеглУчета = Константы.ВалютаРегламентированногоУчета.Получить();
	Для Каждого СтрокаТЧ из ДивидендыКупоны Цикл
		Если СтрокаТЧ.ВалютаВыплаты <> ВалютаРеглУчета И ЗначениеЗаполнено(СтрокаТЧ.БанковскийСчет) Тогда 
			НайденныеТранзитныеСчета = ТранзитныеСчетаОрганизации.НайтиСтроки(Новый Структура("БИК, Валюта", СтрокаТЧ.БанковскийСчет.Банк.Код, СтрокаТЧ.ВалютаВыплаты));
			Если НайденныеТранзитныеСчета.Количество() > 0 Тогда
				СтрокаТЧ.БанковскийСчет = НайденныеТранзитныеСчета[0].Ссылка;
			Иначе
				Если ЗначениеЗаполнено(ТранзитныйСчетПоУмолчанию) Тогда
					СтрокаТЧ.БанковскийСчет = ТранзитныйСчетПоУмолчанию;
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

