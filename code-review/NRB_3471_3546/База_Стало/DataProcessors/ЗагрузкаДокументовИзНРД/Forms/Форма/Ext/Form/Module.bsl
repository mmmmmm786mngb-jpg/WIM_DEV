// ВСПОМОГАТЕЛЬНЫЕ ПРОЦЕДУРЫ И ФУНКЦИИ

&НаСервере
Функция НайтиКодПоЦеннойБумаге(ЦеннаяБумага)
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ЦеннаяБумага", ЦеннаяБумага);
	
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	КодыЗагрузки.Код
	|ИЗ
	|	Справочник.КодыЗагрузки КАК КодыЗагрузки
	|ГДЕ
	|	КодыЗагрузки.ПометкаУдаления = ЛОЖЬ
	|	И КодыЗагрузки.Владелец = &ЦеннаяБумага
	|	И КодыЗагрузки.Биржа = &КлассификаторНДЦ";
	Запрос.УстановитьПараметр("КлассификаторНДЦ", Константы.КлассификаторЗагрузкиНДЦ.Получить());
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Код;
	Иначе	
		Возврат "";
	КонецЕсли;	 
КонецФункции

&НаКлиенте
Процедура Тест4490(Команда)
	
	ДиалогВыбораФайлов = Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.Открытие);
	ДиалогВыбораФайлов.МножественныйВыбор = Истина;
	ДиалогВыбораФайлов.Заголовок = "Тестируемые файлы";
	ДиалогВыбораФайлов.Фильтр = "Файлы XML|*.xml|HTML|*.html|HTM|*.htm";
	Если НЕ ДиалогВыбораФайлов.Выбрать() Тогда
		Возврат;
	КонецЕсли;
	ПереданныеФайлы = Новый Массив;
	Тест4490_ПередатьФайлыНаСервер(ДиалогВыбораФайлов.ВыбранныеФайлы, ПереданныеФайлы);
	Тест4490_ОбработатьФайлы(ПереданныеФайлы);
КонецПроцедуры

&НаКлиенте
Процедура Тест4490_ПередатьФайлыНаСервер(ИменаФайлов, ПереданныеФайлы)
	
	Если ТипЗнч(ПереданныеФайлы) <> Тип("Массив") Тогда
		ПереданныеФайлы = Новый Массив;
	КонецЕсли;
	Для Каждого ИмяФайла Из ИменаФайлов Цикл
		Файл = Новый Файл(ИмяФайла);
		ПереданныйФайл = Новый Структура("Имя, АдресХранилище");
		ПереданныйФайл.Имя = Файл.Имя;
		ПереданныйФайл.АдресХранилище = ПоместитьВоВременноеХранилище(Новый ДвоичныеДанные(Файл.ПолноеИмя), Новый УникальныйИдентификатор);
		ПереданныеФайлы.Добавить(ПереданныйФайл);
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура Тест4490_ОбработатьФайлы(ПереданныеФайлы)
	
	Тест4490_ОбработатьФайлыСервер(ПереданныеФайлы);
	
КонецПроцедуры

&НаСервере
Процедура Тест4490_ОбработатьФайлыСервер(ТестовыеФайлыХранилище)
	
	ОбработкаОбъект = РеквизитФормыВЗначение("Объект");
	ОбработкаОбъект.Тест4490(ТестовыеФайлыХранилище);
	ЗначениеВРеквизитФормы(ОбработкаОбъект, "Объект");
	
КонецПроцедуры
