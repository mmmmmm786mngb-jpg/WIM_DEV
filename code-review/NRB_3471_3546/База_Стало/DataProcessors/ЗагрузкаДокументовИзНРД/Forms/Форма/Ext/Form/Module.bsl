// ПРОЦЕДУРЫ И ФУНКЦИИ ЭЛЕМЕНТОВ УПРАВЛЕНИЯ ФОРМЫ

&НаКлиенте
Процедура АктивизироватьСтроки()
	ТекущиеДанныеДивиденды = Элементы.Дивиденды.ТекущиеДанные;
	Если Не ТекущиеДанныеДивиденды = Неопределено Тогда
		ИдентификаторСтрокиВладельца = ТекущиеДанныеДивиденды.Идентификатор;
	Иначе 
		ИдентификаторСтрокиВладельца = "идентификатор";
	КонецЕсли;
	ОтборСтрокПриложения = Новый ФиксированнаяСтруктура("ИдентификаторСтрокиВладельца", ИдентификаторСтрокиВладельца);
	Элементы.ДивидендыПриложение.ОтборСтрок = ОтборСтрокПриложения;
	
	ТекущиеДанныеКупоны = Элементы.Купоны.ТекущиеДанные;
	Если Не ТекущиеДанныеКупоны = Неопределено Тогда
		ИдентификаторСтрокиВладельца = ТекущиеДанныеКупоны.Идентификатор;
	Иначе 
		ИдентификаторСтрокиВладельца = "идентификатор";
	КонецЕсли;
	ОтборСтрокПриложения = Новый ФиксированнаяСтруктура("ИдентификаторСтрокиВладельца", ИдентификаторСтрокиВладельца);
	Элементы.КупоныПриложение.ОтборСтрок = ОтборСтрокПриложения;
КонецПроцедуры

&НаКлиенте
Процедура ДивидендыПриАктивизацииСтроки(Элемент)
	АктивизироватьСтроки();
КонецПроцедуры

&НаКлиенте
Процедура КупоныПриАктивизацииСтроки(Элемент)
	АктивизироватьСтроки();
КонецПроцедуры

&НаКлиенте
Процедура КупоныЦеннаяБумагаПриИзменении(Элемент)
	ТекДанные	= Элементы.Купоны.ТекущиеДанные;
	Если Не ТекДанные = Неопределено Тогда
		ТекДанные.КодЦБ	= НайтиКодПоЦеннойБумаге(ТекДанные.ЦеннаяБумага);
	КонецЕсли;
КонецПроцедуры


