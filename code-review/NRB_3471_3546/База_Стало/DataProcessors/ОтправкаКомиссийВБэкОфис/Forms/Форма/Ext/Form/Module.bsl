

&НаКлиенте
Процедура ВыборПериода(Команда)
	
	ПериодЗагрузки = Новый СтандартныйПериод;
	ПериодЗагрузки.ДатаНачала		= Объект.НачалоПериода;
	ПериодЗагрузки.ДатаОкончания	= Объект.КонецПериода;
	
	Диалог = Новый ДиалогРедактированияСтандартногоПериода();
	Диалог.Период = ПериодЗагрузки;
	Если Диалог.Редактировать() Тогда
		ПериодЗагрузки			= Диалог.Период;
		Объект.НачалоПериода	= ПериодЗагрузки.ДатаНачала;
		Объект.КонецПериода		= ПериодЗагрузки.ДатаОкончания;	
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура НачалоПериодаПриИзменении(Элемент)
	ПроверитьКорретностьЗаполненияПериода(Элемент.Имя);
КонецПроцедуры

&НаКлиенте
Процедура КонецПериодаПриИзменении(Элемент)
	ПроверитьКорретностьЗаполненияПериода(Элемент.Имя);
КонецПроцедуры

Процедура ПроверитьКорретностьЗаполненияПериода(ИмяПериода)
	
	Если ЗначениеЗаполнено(Объект.КонецПериода) И ЗначениеЗаполнено(Объект.КонецПериода) И Объект.НачалоПериода > Объект.КонецПериода Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Дата начала периода не может быть больше даты окончания!");
		Объект[ИмяПериода] = Дата(1,1,1);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура Сформировать(Команда)
	
	Если Не (ЗначениеЗаполнено(Объект.НачалоПериода) И ЗначениеЗаполнено(Объект.КонецПериода)) Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не заполнен период начисления!");
		Возврат;
	КонецЕсли;
	
	СформироватьНаСервере();
	УстановитьОтборСтрокПоРегистратору();
	
КонецПроцедуры

&НаСервере
Процедура СформироватьНаСервере()
	
	ОбработкаОбъект = РеквизитФормыВЗначение("Объект");
	ОбработкаОбъект.Сформировать();
	ЗначениеВРеквизитФормы(ОбработкаОбъект, "Объект");
	
КонецПроцедуры

&НаКлиенте
Процедура ОтправитьВБэкОфис(Команда)
	
	Если Объект.Комиссии.Количество() = 0 Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Отсутствуют данные для загрузки в Бэк-офис!");
		Возврат;
	КонецЕсли;
	
	ОтправитьВБэкОфисНаСервере();
	ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Данные успешно отправлены в Бэк-офис");
	СформироватьНаСервере();
	
КонецПроцедуры

&НаСервере
Процедура ОтправитьВБэкОфисНаСервере()
	
	ОбработкаОбъект = РеквизитФормыВЗначение("Объект");
	ОбработкаОбъект.ОтправитьВБэкОфис();
	
КонецПроцедуры

&НаКлиенте
Процедура ДокументыСКомиссиямиПриАктивизацииСтроки(Элемент)
	
	УстановитьОтборСтрокПоРегистратору();
	
КонецПроцедуры

&НаКлиенте
Процедура УстановитьОтборСтрокПоРегистратору()
	
	ТекущиеДанные = Элементы.ДокументыСКомиссиями.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Отбор = Новый Структура;
	Отбор.Вставить("Регистратор", ТекущиеДанные.Документ);
	Элементы.ДанныеПоКомиссиям.ОтборСтрок = Новый ФиксированнаяСтруктура(Отбор);
	
КонецПроцедуры

&НаКлиенте
Процедура ДокументыСКомиссиямиВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	ТекущиеДанные = Элементы.ДокументыСКомиссиями.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ТекущиеДанные.Документ) Тогда
		ПоказатьЗначение(, ТекущиеДанные.Документ);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ДанныеПоКомиссиямВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	ТекущиеДанные = Элементы.ДанныеПоКомиссиям.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ТекущиеДанные.Комиссия) Тогда
		ПоказатьЗначение(, ТекущиеДанные.Комиссия);
КонецЕсли;
	
КонецПроцедуры
