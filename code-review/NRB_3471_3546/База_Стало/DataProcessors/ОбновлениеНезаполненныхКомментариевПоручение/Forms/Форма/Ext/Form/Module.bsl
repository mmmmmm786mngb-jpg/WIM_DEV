
//#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура НастройкаПериода(Команда)
	
	ОписаниеОповещения = Новый ОписаниеОповещения("НастройкаПериодаЗавершение", ЭтаФорма);
	
	Диалог = Новый ДиалогРедактированияСтандартногоПериода;
	Диалог.Период.ДатаНачала = Объект.ПериодНачало;
	Диалог.Период.ДатаОкончания = Объект.ПериодКонец;
	Диалог.Показать(ОписаниеОповещения);
	
КонецПроцедуры

&НаКлиенте
Процедура ВыполнитьНажатие(Команда)
	
	ВыполнитьНажатиеНаСервере();
	
КонецПроцедуры


//#КонецОбласти

//#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура НастройкаПериодаЗавершение(Период, ДополнительныеПараметры) Экспорт
	
	Если Период <> Неопределено Тогда
		Объект.ПериодНачало = Период.ДатаНачала;
		Объект.ПериодКонец = Период.ДатаОкончания;
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура ВыполнитьНажатиеНаСервере()
	
	Выборка	= Документы.Поручение.Выбрать(Объект.ПериодНачало, Объект.ПериодКонец);
	Пока Выборка.Следующий() Цикл
		// Проверка модифицированности дока
		МодифицированДок	= Ложь;
		//---
	    ОбъектДок	=	Выборка.ПолучитьОбъект();
		// Обновим комментарий если надо
		Если Не ЗначениеЗаполнено(ОбъектДок.Комментарий) И ((ОбъектДок.ВидОперацииД = Справочники.ВидыОпераций.ОткрытиеСчетаДепо) ИЛИ  (ОбъектДок.ВидОперацииД = Справочники.ВидыОпераций.ОткрытиеРазделаСчетаДепо) ИЛИ (ОбъектДок.ВидОперацииД = Справочники.ВидыОпераций.НазначениеОператораСчетаДепо)) Тогда
			ПараметрыДоговора	= ПолучитьПараметрыДоговораПоПоручению(ОбъектДок.Инициатор, ОбъектДок.Дата);
			Если ПараметрыДоговора.Количество()>0 Тогда
				Если (ОбъектДок.ВидОперацииД = Справочники.ВидыОпераций.ОткрытиеСчетаДепо) ИЛИ  (ОбъектДок.ВидОперацииД = Справочники.ВидыОпераций.ОткрытиеРазделаСчетаДепо) Тогда
					ОбъектДок.Комментарий	= "Депозитарный договор №"+ПараметрыДоговора[0].Код+" от "+Формат(ПараметрыДоговора[0].ДатаНачалоДействия, "ДФ=dd.MM.yyyy");
					МодифицированДок		= Истина;
				ИначеЕсли (ОбъектДок.ВидОперацииД = Справочники.ВидыОпераций.НазначениеОператораСчетаДепо) Тогда
					ОбъектДок.Комментарий	= "Договор обслуживания на финансовых рынках №"+ПараметрыДоговора[0].Код+" от "+Формат(ПараметрыДоговора[0].ДатаНачалоДействия, "ДФ=dd.MM.yyyy");
					МодифицированДок		= Истина;
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;	
		//---
		Если МодифицированДок Тогда
			ОбъектДок.Записать(РежимЗаписиДокумента.Запись);
			#Если Клиент Тогда
				Сообщить("Модифицирован комментарий документа - "+ОбъектДок.Ссылка);
			#Иначе
				ЗаписьЖурналаРегистрации("Обновление комментариев 'Поручение'", УровеньЖурналаРегистрации.Информация, , , "Модифицирован комментарий документа - "+ОбъектДок.Ссылка);
			#КонецЕсли
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Функция ПолучитьПараметрыДоговораПоПоручению(Инициатор, Дата)
	Запрос = Новый Запрос(
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	Код,
	|	ДатаНачалоДействия,
	|	Ссылка
	|ИЗ
	|	Справочник.ДоговорыКонтрагентов
	|ГДЕ
	|	НЕ ПометкаУдаления
	|	И (ДатаНачалоДействия <= НАЧАЛОПЕРИОДА(&Дата, ДЕНЬ) ИЛИ ДатаНачалоДействия = ДАТАВРЕМЯ(1,1,1))
	|	И (ДатаОкончанияДействия >= НАЧАЛОПЕРИОДА(&Дата, ДЕНЬ) ИЛИ ДатаОкончанияДействия = ДАТАВРЕМЯ(1,1,1))
	|	И Владелец		= &Владелец
	|	И ТипДоговора	= ЗНАЧЕНИЕ(Перечисление.ТипыДоговоров.Депозитарный)");

	Запрос.УстановитьПараметр("Владелец", Инициатор);
	Запрос.УстановитьПараметр("Дата"	, Дата);
	
	Возврат Запрос.Выполнить().Выгрузить();
КонецФункции

//#КонецОбласти
