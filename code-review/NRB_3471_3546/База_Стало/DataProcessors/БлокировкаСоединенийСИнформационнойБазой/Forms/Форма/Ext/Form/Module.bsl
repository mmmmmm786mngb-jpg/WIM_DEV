
&НаСервере
Перем мТекущийОбъектНаСервере;

&НаСервере
Функция ТекущийОбъект()
	
	Если мТекущийОбъектНаСервере = Неопределено Тогда
		мТекущийОбъектНаСервере = РеквизитФормыВЗначение("Объект");
	КонецЕсли; 
	
	Возврат мТекущийОбъектНаСервере;
	
КонецФункции


////////////////////////////////////////////////////////////////////////////////
// ПРОЦЕДУРЫ - ОБРАБОТЧИКИ СОБЫТИЙ ФОРМЫ

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ТекущийОбъект().ПолучитьПараметрыБлокировки();
	
	Если Не ПравоДоступа("Администрирование", Метаданные) Тогда 
		ТолькоПросмотр = Истина;
		КоманднаяПанель.Доступность = Ложь;
		Элементы.ПараметрыАдминистрированияСервера.Доступность = Ложь;
		Элементы.ВыбратьПериод.Доступность = Ложь;
		Элементы.КодРазрешения.Видимость = Ложь;
	КонецЕсли;
	
	Если ОпределитьЭтаИнформационнаяБазаФайловая() Тогда 
		Элементы.ПараметрыАдминистрированияСервера.Видимость = Ложь;
	КонецЕсли;
	
КонецПроцедуры


////////////////////////////////////////////////////////////////////////////////
// ПРОЦЕДУРЫ - ОБРАБОТЧИКИ СОБЫТИЙ ЭЛЕМЕНТОВ ФОРМЫ

&НаКлиенте
Процедура Заблокировать(Команда)
	
	Если Объект.УстановитьБлокировкуСоединений Тогда
		
		Если Объект.НачалоБлокировки > Объект.ОкончаниеБлокировки Тогда 
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Дата окончания блокировки не можеть быть меньше даты начала блокировки. Блокировка не установлена...");
			Возврат;
		КонецЕсли;
		
		Если Не ПроверитьПараметрыАдминистрированияИБНаСервере() Тогда
			Возврат;
		КонецЕсли;
		
		Оповещение = Новый ОписаниеОповещения("ЗаблокироватьЗавершение", ЭтотОбъект);
		ТекстВопроса = 
			"После установки блокировки в информационной базе будет запущен 
			|режим завершения работы всех пользователей (включая Вас) 
			|на период действия блокировки.
			|Вы действительно хотите установить блокировку?";
		
		ПоказатьВопрос(Оповещение, ТекстВопроса, РежимДиалогаВопрос.ДаНетОтмена, 60, КодВозвратаДиалога.Нет, "Установка блокировки соединений с информационной базой");
		
	Иначе 
		ЗаблокироватьНаСервере();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаблокироватьЗавершение(РезультатВопроса, ДополнительныеПараметры) Экспорт 
	
	Если РезультатВопроса = КодВозвратаДиалога.Да Тогда 
		ЗаблокироватьНаСервере();
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция ПроверитьПараметрыАдминистрированияИБНаСервере()
	
	Возврат ТекущийОбъект().ПроверитьПараметрыАдминистрированияИБ();
	
КонецФункции

&НаСервере
Процедура ЗаблокироватьНаСервере()
	
	ТекущийОбъект().УстановитьБлокировку();
	
КонецПроцедуры

&НаКлиенте
Процедура ВыбратьПериод(Команда)
	
	Диалог = Новый ДиалогРедактированияСтандартногоПериода();
	Диалог.Период.ДатаНачала = Объект.НачалоБлокировки;
	Диалог.Период.ДатаОкончания = Объект.ОкончаниеБлокировки;
	
	Если Диалог.Редактировать() Тогда 
		Объект.НачалоБлокировки = Диалог.Период.ДатаНачала;
		Объект.ОкончаниеБлокировки = Диалог.Период.ДатаОкончания;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПараметрыАдминистрированияСервера(Элемент)
	
	ОткрытьФорму("Обработка.БлокировкаСоединенийСИнформационнойБазой.Форма.ПараметрыАдминистрированияСервера",, ЭтаФорма);
	
КонецПроцедуры
