
&НаКлиенте
Процедура Сформировать(Команда)
	
	Выгружать = Ложь;
	СформироватьНаСервере(Выгружать);
	
КонецПроцедуры

&НаКлиенте
Процедура СформироватьИВыгрузить(Команда)
	
	Выгружать = Истина;
	СформироватьНаСервере(Выгружать);
	
КонецПроцедуры

&НаСервере
Процедура СформироватьНаСервере(Выгружать)
	
	Объект1 = РеквизитФормыВЗначение("Объект");
	ТабличныйДокумент = Объект1.Сформировать(Выгружать);
	ТабДок.Очистить();
	ТабДок.Вывести(ТабличныйДокумент);
	
КонецПроцедуры

&НаКлиенте
Процедура КаталогВыгрузкиНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	// Переписать на ОписаниеОповещение ибо 8.2 о таком и не мечтала
	
	ВыборКаталога = Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.ВыборКаталога);
	ВыборКаталога.Заголовок = "Убедитесь что каталог доступен на сервере!";
	
	Если ВыборКаталога.Выбрать() Тогда 
		Объект.КаталогВыгрузки = ВыборКаталога.Каталог;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ПараметрыИсточника = ВнешниеДанные.ПолучитьПараметрыВнешнегоИсточника(ПланыВидовХарактеристик.ВнешниеИсточники.КаталогДанныхОКлиентахДляWEB);
	
	Если ПараметрыИсточника.Папка = "" Тогда 
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Во внешних настройках нет пути для выгрузки!");
	Иначе 
		Объект.КаталогВыгрузки = ПараметрыИсточника.Папка;
	КонецЕсли;	
	
КонецПроцедуры
