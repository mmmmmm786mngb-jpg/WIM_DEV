#Область ПрограммныйИнтерфейс

// Выполняет регистрацию клиента
// Параметры:
//	Выборка - ВыборкаДанных - предполагается что это выборка из РС ЖурналВходящихСообщенийKafka
//								и в ней есть поля Сообщение, Идентификатор, ВнешнийИсточник
Процедура ВыполнитьРегистрациюКлиента(Выборка) Экспорт
	Сообщение	= РаботаСJSON.РезультатЧтенияJSON(Выборка.Сообщение);
	Ошибка		= "";
	Регистрация	= Обработки.РегистрацияКлиентаЧерезKafka.Создать();
	Попытка
		Регистрация.ИнициализацияMessageInfo(Сообщение, Ошибка, "client");
	Исключение
		РегистрыСведений.ЖурналВходящихСообщенийKafka.ЗаписатьОшибку(Выборка.ВнешнийИсточник, Выборка.Идентификатор, СокрЛП(Ошибка));
		ВызватьИсключение;
	КонецПопытки;
	
	ТипОперации = НРег(Регистрация.MessageInfo[0].ActionType);
	Если ТипОперации = "ins" Или ТипОперации = "upd" Тогда
		Попытка
			Регистрация.ИнициализацияДанныхКлиентаJSON(Сообщение, Ошибка);
		Исключение
			РегистрыСведений.ЖурналВходящихСообщенийKafka.ЗаписатьОшибку(Выборка.ВнешнийИсточник, Выборка.Идентификатор, СокрЛП(Ошибка));
			ВызватьИсключение;
		КонецПопытки;
		ВыполнитьДобавлениеИзменениеКлиента(Регистрация, Сообщение, ТипОперации, Выборка, Ошибка);
	ИначеЕсли ТипОперации = "del" Тогда
		Ошибка = "Удаление данных не реализовано: " + ТипОперации;
		ЗаписьЖурналаРегистрации(Регистрация.ИмяСобытия,
			УровеньЖурналаРегистрации.Ошибка, , , Ошибка);
		РегистрыСведений.ЖурналВходящихСообщенийKafka.ЗаписатьОшибку(Выборка.ВнешнийИсточник, Выборка.Идентификатор, СокрЛП(Ошибка));
	Иначе
		Ошибка = "Не удалось определить тип операции по ActionType: " + ТипОперации;
		ЗаписьЖурналаРегистрации(Регистрация.ИмяСобытия,
			УровеньЖурналаРегистрации.Ошибка, , , Ошибка);
		РегистрыСведений.ЖурналВходящихСообщенийKafka.ЗаписатьОшибку(Выборка.ВнешнийИсточник, Выборка.Идентификатор, СокрЛП(Ошибка));
	КонецЕсли;
КонецПроцедуры

// Выполняет регистрацию договора
// Параметры:
//	Выборка - ВыборкаДанных - предполагается что это выборка из РС ЖурналВходящихСообщенийKafka
//								и в ней есть поля Сообщение, Идентификатор, ВнешнийИсточник
Процедура ВыполнитьРегистрациюДоговора(Выборка) Экспорт
	
	Сообщение	= РаботаСJSON.РезультатЧтенияJSON(Выборка.Сообщение);
	Ошибка		= "";
	Регистрация	= Обработки.РегистрацияКлиентаЧерезKafka.Создать();
	Попытка
		Регистрация.ИнициализацияMessageInfo(Сообщение, Ошибка, "contract");
	Исключение
		РегистрыСведений.ЖурналВходящихСообщенийKafka.ЗаписатьОшибку(Выборка.ВнешнийИсточник, Выборка.Идентификатор, СокрЛП(Ошибка));
		ВызватьИсключение;
	КонецПопытки;
	ТипОперации = НРег(Регистрация.MessageInfo[0].ActionType);
	Если ТипОперации = "ins" Тогда
		Попытка
			Регистрация.ИнициализацияДанныхДоговораJSON(Сообщение, Ошибка);
		Исключение
			РегистрыСведений.ЖурналВходящихСообщенийKafka.ЗаписатьОшибку(Выборка.ВнешнийИсточник, Выборка.Идентификатор, СокрЛП(Ошибка));
			ВызватьИсключение;
		КонецПопытки;
		Если НРег(Регистрация.Contract[0].ContractType) = "ds" Тогда
			НачатьТранзакцию();
			Попытка
				Результат = Регистрация.РезультатРегистрацииДоговораКлиента(Сообщение, Ошибка);
			Исключение
				ОписаниеОшибки = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
				Ошибка = Ошибка + Символы.ПС + ОписаниеОшибки;
			КонецПопытки;
			ТопикОтвета = ПланыВидовХарактеристик.ВнешниеИсточники.KafkaClientResponse;
			Если ПустаяСтрока(Ошибка) Тогда
				РегистрыСведений.ЖурналВходящихСообщенийKafka.ЗавершитьОбработку(Выборка.ВнешнийИсточник, Выборка.Идентификатор);
				Кафка.ОтправитьОтвет(ТопикОтвета, Результат);
				Попытка
					Регистрация.СформироватьПорученияИОперации();
					ЗафиксироватьТранзакцию();
				Исключение
					ОтменитьТранзакцию();
					ОписаниеОшибки = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
					РегистрыСведений.ЖурналВходящихСообщенийKafka.ЗаписатьОшибку(Выборка.ВнешнийИсточник, Выборка.Идентификатор, ОписаниеОшибки);
					ВызватьИсключение;
				КонецПопытки;
			Иначе
				ОтменитьТранзакцию();
				РегистрыСведений.ЖурналВходящихСообщенийKafka.ЗаписатьОшибку(Выборка.ВнешнийИсточник, Выборка.Идентификатор, СокрЛП(Ошибка));
				Если НЕ ТипЗнч(Результат) = Тип("Структура") Тогда
					Ответ = Новый Структура("ContractId,ContractType,SrcSystem,CrmClientId,ContractNumber,ObjectVersion");
					ЗаполнитьЗначенияСвойств(Ответ, Сообщение.Data);
					Ответ.Вставить("StatusCode", "REGERR");
					Результат = Новый Структура("MessageInfo,Data", Сообщение.MessageInfo, Ответ);
				КонецЕсли;
				Результат.Вставить("Ключ", "Contract");
				Результат.Вставить("Ссылка", Неопределено);
				Кафка.ОтправитьОтвет(ТопикОтвета, Результат);
				ОбменДаннымиКафка.ОбработатьОшибкуДанныхИзJSON(
					Регистрация.ИмяСобытия,
					Результат.MessageInfo,
					СокрЛП(Ошибка));
			КонецЕсли;
		Иначе
			РегистрыСведений.ЖурналВходящихСообщенийKafka.ЗавершитьОбработку(Выборка.ВнешнийИсточник, Выборка.Идентификатор);
		КонецЕсли;		
	ИначеЕсли ТипОперации = "upd" Или ТипОперации = "del" Тогда
		Ошибка = "Обновление данных не реализовано: " + ТипОперации;
		ЗаписьЖурналаРегистрации(Регистрация.ИмяСобытия,
			УровеньЖурналаРегистрации.Ошибка, , , Ошибка);
		РегистрыСведений.ЖурналВходящихСообщенийKafka.ЗаписатьОшибку(Выборка.ВнешнийИсточник, Выборка.Идентификатор, СокрЛП(Ошибка));
	Иначе
		Ошибка = "Не удалось определить тип операции по ActionType: " + ТипОперации;
		ЗаписьЖурналаРегистрации(Регистрация.ИмяСобытия,
			УровеньЖурналаРегистрации.Ошибка, , , Ошибка);
		РегистрыСведений.ЖурналВходящихСообщенийKafka.ЗаписатьОшибку(Выборка.ВнешнийИсточник, Выборка.Идентификатор, СокрЛП(Ошибка));
	КонецЕсли;

КонецПроцедуры

// Возвращает клиента по CrmClientId
// Параметры:
//	CrmClientId - Строка
// Возвращаемое значение:
//	СправочникСсылка.ФизическиеЛица - или СправочникСсылка.ЮридическиеЛица или неопределено если не удалось найти клиента
Функция КлиентПоCrmClientId(CrmClientId) Экспорт
	Клиент = Неопределено;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	КодыЗагрузки.Владелец КАК Клиент
	|ИЗ
	|	Справочник.КодыЗагрузки КАК КодыЗагрузки
	|ГДЕ
	|	КодыЗагрузки.Код = &CrmClientId
	|	И ВЫБОР
	|			КОГДА КодыЗагрузки.Владелец ССЫЛКА Справочник.ФизическиеЛица
	|				ТОГДА ИСТИНА
	|			КОГДА КодыЗагрузки.Владелец ССЫЛКА Справочник.ЮридическиеЛица
	|				ТОГДА ИСТИНА
	|			ИНАЧЕ ЛОЖЬ
	|		КОНЕЦ
	|	И КодыЗагрузки.Биржа = ЗНАЧЕНИЕ(Справочник.КлассификаторыЗагрузки.Клиенты)
	|	И НЕ КодыЗагрузки.ПометкаУдаления
	|	И ВЫБОР
	|			КОГДА КодыЗагрузки.ДатаОкончанияДействия = ДАТАВРЕМЯ(1, 1, 1)
	|				ТОГДА ИСТИНА
	|			КОГДА КодыЗагрузки.ДатаОкончанияДействия > &ТекущаяДата
	|				ТОГДА ИСТИНА
	|			ИНАЧЕ ЛОЖЬ
	|		КОНЕЦ";
	Запрос.УстановитьПараметр("CrmClientId", CrmClientId);
	Запрос.УстановитьПараметр("ТекущаяДата", НачалоДня(ТекущаяДатаСеанса()));
	РезультатЗапроса = Запрос.Выполнить();
	Если Не РезультатЗапроса.Пустой() Тогда
		Выборка = РезультатЗапроса.Выбрать();
		Выборка.Следующий();
		Клиент = Выборка.Клиент;
	КонецЕсли;
	
	Возврат Клиент;
КонецФункции

// Возвращает CrmClientId данного клиента используемый в интеграции
// Параметры:
//	Клиент - СправочникСсылка.ФизическиеЛица - или СправочникСсылка.ЮридическиеЛица
// Возвращаемое значение:
//	Строка
Функция CrmClientId(Клиент) Экспорт
	CrmClientId = Неопределено;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	КодыЗагрузкиКлиента.Код КАК CrmClientId
	|ИЗ
	|	Справочник.КодыЗагрузки КАК КодыЗагрузкиКлиента
	|ГДЕ
	|	КодыЗагрузкиКлиента.Владелец = &Клиент
	|	И НЕ КодыЗагрузкиКлиента.ПометкаУдаления
	|	И КодыЗагрузкиКлиента.Биржа = ЗНАЧЕНИЕ(Справочник.КлассификаторыЗагрузки.Клиенты)
	|	И ВЫБОР
	|			КОГДА КодыЗагрузкиКлиента.ДатаОкончанияДействия = ДАТАВРЕМЯ(1, 1, 1)
	|				ТОГДА ИСТИНА
	|			КОГДА КодыЗагрузкиКлиента.ДатаОкончанияДействия > &ТекущаяДата
	|				ТОГДА ИСТИНА
	|			ИНАЧЕ ЛОЖЬ
	|		КОНЕЦ";
	Запрос.УстановитьПараметр("Клиент", Клиент);
	Запрос.УстановитьПараметр("ТекущаяДата", НачалоДня(ТекущаяДатаСеанса()));
	РезультатЗапроса = Запрос.Выполнить();
	Если Не РезультатЗапроса.Пустой() Тогда
		Выборка = РезультатЗапроса.Выбрать();
		Выборка.Следующий();
		CrmClientId = Выборка.CrmClientId;
	КонецЕсли;
	
	Возврат CrmClientId;
КонецФункции

// Возвращает CrmContractNumber данного депонента используемый в интеграции
// Параметры:
//	Депонент - СправочникСсылка.Контрагенты
// Возвращаемое значение:
//	Строка
Функция CrmContractNumber(Депонент) Экспорт
	
	CrmContractNumber = Неопределено;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	КодыЗагрузкиКлиента.Код КАК CrmContractNumber
	|ИЗ
	|	Справочник.КодыЗагрузки КАК КодыЗагрузкиКлиента
	|ГДЕ
	|	КодыЗагрузкиКлиента.Владелец = &Депонент
	|	И НЕ КодыЗагрузкиКлиента.ПометкаУдаления
	|	И КодыЗагрузкиКлиента.Биржа = ЗНАЧЕНИЕ(Справочник.КлассификаторыЗагрузки.CrmContractNumber)
	|	И ВЫБОР
	|			КОГДА КодыЗагрузкиКлиента.ДатаОкончанияДействия = ДАТАВРЕМЯ(1, 1, 1)
	|				ТОГДА ИСТИНА
	|			КОГДА КодыЗагрузкиКлиента.ДатаОкончанияДействия > &ТекущаяДата
	|				ТОГДА ИСТИНА
	|			ИНАЧЕ ЛОЖЬ
	|		КОНЕЦ";
	
	Запрос.УстановитьПараметр("Депонент", Депонент);
	Запрос.УстановитьПараметр("ТекущаяДата", НачалоДня(ТекущаяДатаСеанса()));
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Если Не РезультатЗапроса.Пустой() Тогда
		Выборка = РезультатЗапроса.Выбрать();
		Выборка.Следующий();
		CrmContractNumber = СокрЛП(Выборка.CrmContractNumber);
	КонецЕсли;
	
	Возврат CrmContractNumber;
	
КонецФункции

#КонецОбласти


#Область СлужебныеПроцедурыИФункции

Процедура ВыполнитьДобавлениеИзменениеКлиента(Регистрация, Сообщение, ТипОперации, Выборка, Ошибка)
	НовоеЮрФизЛицо = Ложь;
	НачатьТранзакцию();
	Попытка
		Результат = Регистрация.РезультатРегистрацииКлиентаВДепозитарии(Сообщение, ТипОперации, НовоеЮрФизЛицо, Ошибка);
	Исключение
		ОписаниеОшибки = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		Ошибка = Ошибка + Символы.ПС + ОписаниеОшибки;
	КонецПопытки;
	
	Если ПустаяСтрока(Ошибка) И ТипОперации = "upd" И ЭтоДобавлениеПризнакаКвалИнвестор(Сообщение, Ошибка) Тогда
		Попытка
			Регистрация.ИнициализацияДанныхQualInfo(Сообщение, Ошибка);
			Регистрация.ЗарегистрироватьПризнакКвалИнвестор(Ошибка);
		Исключение
			ОписаниеОшибки = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
			Ошибка = Ошибка + Символы.ПС + ОписаниеОшибки;
		КонецПопытки;
	КонецЕсли;
	
	ТопикОтвета = ПланыВидовХарактеристик.ВнешниеИсточники.KafkaClientResponse;
	Если ПустаяСтрока(Ошибка) Тогда
		РегистрыСведений.ЖурналВходящихСообщенийKafka.ЗавершитьОбработку(Выборка.ВнешнийИсточник, Выборка.Идентификатор);
		Если НовоеЮрФизЛицо Тогда
			Кафка.ОтправитьОтвет(ТопикОтвета, Результат);
		КонецЕсли;
		// Отбработка завершения транзакции вне попытки была применена предыдущим разработчиком сознательно
		ЗафиксироватьТранзакцию();		// BSLLS:CommitTransactionOutsideTryCatch-off
	Иначе
		ОтменитьТранзакцию();			// BSLLS:WrongUseOfRollbackTransactionMethod-off
		РегистрыСведений.ЖурналВходящихСообщенийKafka.ЗаписатьОшибку(Выборка.ВнешнийИсточник, Выборка.Идентификатор, СокрЛП(Ошибка));
		Если НужноОтправитьОшибку(Ошибка) Тогда
			ПроверитьСоздатьСтруктуруРезультата(Результат, Регистрация, Сообщение);
			Результат.Вставить("Ключ", "client");
			Результат.Вставить("Ссылка", Неопределено);
			Если НовоеЮрФизЛицо Тогда
				Кафка.ОтправитьОтвет(ТопикОтвета, Результат);
			КонецЕсли;
			ОбменДаннымиКафка.ОбработатьОшибкуДанныхИзJSON(Регистрация.ИмяСобытия, Результат.MessageInfo, СокрЛП(Ошибка));
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

Процедура ПроверитьСоздатьСтруктуруРезультата(Результат, Регистрация, Сообщение)
	Если НЕ ТипЗнч(Результат) = Тип("Структура") Тогда
		СтруктураClientIds = Новый Структура("CrmClientId,DepoClientId");
		ЗаполнитьЗначенияСвойств(СтруктураClientIds, Регистрация.ClientIds[0]);
		СтруктураClientStatuses = Новый Структура("DepoClientStatus,DepoClientStatusDate", "REGERR", ТекущаяДатаСеанса());
		СтруктураClient = Новый Структура("ClientIds,ClientStatuses", СтруктураClientIds, СтруктураClientStatuses);
		Ответ = Новый Структура("Client", СтруктураClient);
		Результат = Новый Структура("MessageInfo,Data", Сообщение.MessageInfo, Ответ);
	КонецЕсли;
КонецПроцедуры

Функция ЭтоДобавлениеПризнакаКвалИнвестор(Сообщение, Ошибка)
	
	Попытка
		ДанныеКлиента = Сообщение.Data.Client;
		Возврат ДанныеКлиента.Свойство("QualInfo") И ДанныеКлиента.QualInfo.Свойство("QualSecCateg")
			И ДанныеКлиента.QualInfo.QualSecCateg <> Неопределено
			И ДанныеКлиента.QualInfo.QualInvestStatus <> Неопределено;
	Исключение
		Ошибка = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		ЗаписьЖурналаРегистрации("Обновление данных клиента", УровеньЖурналаРегистрации.Ошибка, , , Ошибка);
		Возврат Ложь;
	КонецПопытки;
	
КонецФункции

Функция НужноОтправитьОшибку(Ошибка)
	
	Возврат СтрНайти(Ошибка, "Не подключена услуга депозитарного обслуживания") = 0;

КонецФункции

#КонецОбласти