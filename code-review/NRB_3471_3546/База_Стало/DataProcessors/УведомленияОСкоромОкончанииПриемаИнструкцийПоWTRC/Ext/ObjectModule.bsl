
//////////////////////////////////////////////////////////////////////////////
// ИНТЕРФЕЙС ОБРАБОТКИ

Функция УведомлениеОтправлено() Экспорт
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	КОЛИЧЕСТВО(Уведомления.Депонент) КАК Количество
	|ИЗ
	|	РегистрСведений.УведомленияОСкоромОкончанииПриемаИнструкцийПоWTRC КАК Уведомления
	|ГДЕ
	|	Уведомления.Период = НАЧАЛОПЕРИОДА(&ДатаУведомления, ДЕНЬ)
	|");
	Запрос.УстановитьПараметр("ДатаУведомления", ДатаУведомления);
	Выборка = Запрос.Выполнить().Выбрать();
	Возврат Выборка.Следующий()	И Выборка.Количество > 0;
	
КонецФункции

Процедура СформироватьСписокДепонентов() Экспорт
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	НАЧАЛОПЕРИОДА(&ДатаУведомления, ДЕНЬ) КАК Период,
	|	ДепонентыWTRC.Депонент КАК Депонент,
	|	ДепонентыWTRC.Депонент.Код КАК КодДепонента
	|ИЗ
	|	БизнесПроцесс.ОбработкаWTRCСообщения.Депоненты КАК ДепонентыWTRC
	|ГДЕ
	|	НАЧАЛОПЕРИОДА(ДепонентыWTRC.Ссылка.ДатаОкончанияРаскрытия, ДЕНЬ) = НАЧАЛОПЕРИОДА(&ДатаОтбораБП, ДЕНЬ)
	|	И НЕ ДепонентыWTRC.Ссылка.ПометкаУдаления
	|	И НЕ (
	|			ВЫРАЗИТЬ(ДепонентыWTRC.Ссылка.ЦеннаяБумага1.Эмитент.ЮридическиеФизическиеЛица
	|				КАК Справочник.ЮридическиеЛица).Страна.Код = &КодСША
	|			И НЕ ДепонентыWTRC.Ссылка.ЦеннаяБумага1.ТипЦБ = &ДепозитарнаяРасписка)
	|
	|УПОРЯДОЧИТЬ ПО
	|	ДепонентыWTRC.Депонент.Код");
	ДатаОтбораБП = БизнесПроцессы.ОбработкаWTRCСообщения.ДатаСкорогоОкончанияПриемаИнструкцийНРД(ДатаУведомления);
	Запрос.УстановитьПараметр("ДатаОтбораБП",			ДатаОтбораБП);
	Запрос.УстановитьПараметр("ДатаУведомления",		ДатаУведомления);
	Запрос.УстановитьПараметр("КодСША",					"840");
	Запрос.УстановитьПараметр("ДепозитарнаяРасписка",	Перечисления.ТипыЦБ.ДепозитарнаяРасписка);
	Депоненты.Загрузить(Запрос.Выполнить().Выгрузить());
	
КонецПроцедуры

Процедура ОтправитьУведомление() Экспорт
	
	Если Депоненты.Количество() > 0 Тогда
		НастройкиОбмена = ВнешниеДанные.ПолучитьПараметрыВнешнегоИсточника(
			ПланыВидовХарактеристик.ВнешниеИсточники.РассылкаУведомленийОСкоромОкончанииПриемаИнструкцийПоWTRC).Настройка;
			
		НайденнаяСтрока = НастройкиОбмена.Параметры.Найти("Тема письма", "Наименование");
		Если НайденнаяСтрока = Неопределено Тогда
			ТемаПисьма = "<Без темы>";
		Иначе
			ТемаПисьма = НайденнаяСтрока.Значение;
		КонецЕсли;
		
		ДатаОтбораБП = БизнесПроцессы.ОбработкаWTRCСообщения.ДатаСкорогоОкончанияПриемаИнструкцийНРД(ДатаУведомления);
		ТекстУведомления = ТекстПисьма(ДатаУведомления, ДатаОтбораБП);

		ПараметрыУведомления = Новый Соответствие;
		ПараметрыУведомления.Вставить("НастройкиОбмена",	НастройкиОбмена);
		ПараметрыУведомления.Вставить("Кодировка",			"UTF-8");
		ПараметрыУведомления.Вставить("ТемаПисьма",			ТемаПисьма);
		ПараметрыУведомления.Вставить("ТекстПисьма",		ТекстУведомления);
		ПараметрыУведомления.Вставить("ТипТекстаПисьма",	ТипТекстаПочтовогоСообщения.HTML);
		ПараметрыУведомления.Вставить("Важность",			ВажностьИнтернетПочтовогоСообщения.Обычная);
		
		РегистрыСведений.УведомленияКОтправке.ДобавитьУведомлениеКотправке(ПараметрыУведомления);				
	Иначе
		ТекстУведомления = "";
	КонецЕсли;
	
КонецПроцедуры

Процедура ЗафиксироватьОтправленноеУведомлениеВРегистре() Экспорт
	
	Если Депоненты.Количество() = 0 Тогда
		Данные = Новый ТаблицаЗначений;
		Данные.Колонки.Добавить("Период");
		Данные.Колонки.Добавить("Депонент");
		
		НоваяСтрока = Данные.Добавить();
		НоваяСтрока.Период		= ДатаУведомления;
		НоваяСтрока.Депонент	= Справочники.Контрагенты.ПустаяСсылка();
	Иначе
		Данные = Депоненты.Выгрузить(, "Период,Депонент");
	КонецЕсли;
	
	Набор = РегистрыСведений.УведомленияОСкоромОкончанииПриемаИнструкцийПоWTRC.СоздатьНаборЗаписей();
	Набор.Отбор.Период.Установить(ДатаУведомления);
	Набор.Загрузить(Данные);
	Набор.Записать();
	
КонецПроцедуры

//////////////////////////////////////////////////////////////////////////////
// ВСПОМОГАТЕЛЬНЫЕ ПРОЦЕДУРЫ И ФУНКЦИИ

Функция ТекстПисьма(ДатаУведомления, ДатаОтбораБП)
	
	СтрокиТаблицы = "";
	Для Каждого Строка Из Депоненты Цикл
		ДанныеДепонента = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
		"<tr>
		|<td>%1</td>
		|</tr>
		|", СокрЛП(Строка.КодДепонента));
		СтрокиТаблицы = СтрокиТаблицы + ДанныеДепонента;
	КонецЦикла;
	
	Текст = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
		"<p>%1 заканчивается прием инструкций НРД по WTRC.</p>
		|<p>Депоненты, которые могут принять участие в КД WTRC по состоянию на %2:</p>
		|<table border=""1"" cellpadding=""5px"" cellspacing=""0"">
		|<tr>
		|<th>Код клиента</th>
		|</tr>
		|%3</table>
		|",
		Формат(ДатаОтбораБП, "ДЛФ=D"), Формат(ДатаУведомления, "ДЛФ=D"), СтрокиТаблицы);
	Возврат Текст;
	
КонецФункции

ОбщегоНазначения.ЛогироватьИспользованиеОбъекта(ЭтотОбъект);
