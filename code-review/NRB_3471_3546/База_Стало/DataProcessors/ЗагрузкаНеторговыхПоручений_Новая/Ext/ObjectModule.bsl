Процедура ЗаполнитьПоручение(Поручение, Данные)
	Если Не ЗначениеЗаполнено(Поручение.Дата) Тогда
		Поручение.Дата = ТекущаяДатаСеанса();
	КонецЕсли;

	Поручение.ПометкаУдаления = Ложь;
	Поручение.ИдентификаторЗагрузки = Данные.ИД_Брокера;
	Поручение.ИсточникЗагрузки = ИсточникЗагрузки;
	Поручение.KafkaMessageId = Данные.KafkaMessageId;
	Поручение.DepoMessageId = Данные.DepoMessageId;
	
	Если Данные.Состояние = "Исполнено" И ЗначениеЗаполнено(Данные.ДатаИсполнения) Тогда
		Поручение.ДатаИсполненияПоручения = Данные.ДатаИсполнения;
		Поручение.ДатаИсполненияПорученияВДепозитарииМХ = НачалоДня(Данные.ДатаИсполнения);
		Поручение.ДатаИсполненияПорученияВМестеРасчетов = НачалоДня(Данные.ДатаИсполнения);
	КонецЕсли;
	Поручение.ОснованиеОтмены	= Данные.ОснованиеОтказа;
	Поручение.Комментарий		= Данные.Комментарий;
	Поручение.ВидОперацииД		= Данные.ВидОперации;
	Поручение.Инициатор			= Данные.Инициатор;
	Поручение.СчетДепо			= Данные.РСДОтправитель.Владелец;
	Поручение.РазделСчетаДепо	= Данные.РСДОтправитель;
	Поручение.Депонент			= Поручение.СчетДепо.Владелец;
	
	Если Поручение.Инициатор = ОбщегоНазначенияПовтИсп.ОрганизацияПоУмолчанию() Тогда
		Поручение.ВидИнициатора = 1;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Данные.Референс) Тогда
		Поручение.Референс = Данные.Референс;
	Иначе
		Поручение.Референс = РеференсИзКомментария(Данные.Комментарий);
	КонецЕсли;
	
	Поручение.РазделСчетаДепоМХ = Данные.СчетРазделДЕПО;
	Поручение.СчетДепоМХ = Поручение.РазделСчетаДепоМХ.Владелец;
	
	Если Поручение.ВидОперацииД = Справочники.ВидыОпераций.Перевод Тогда
		Поручение.Контрагент					= Данные.ДПолучатель;
		Поручение.СчетДепоКонтрагента			= Данные.РCДПолучатель.Владелец;
		Поручение.РазделСчетаДепоКонтрагента	= Данные.РCДПолучатель;
		Поручение.РазделСчетаДепоМХКонтрагента	= Данные.РCДПолучатель.РазделСчетаДепоМХ;
		Поручение.СчетДепоМХКонтрагента			= Поручение.РазделСчетаДепоМХКонтрагента.Владелец;
		Поручение.ВидОперацииД = УточненныйВидПереводаПоСчетамДепоМХ(Поручение.СчетДепоМХ, Поручение.СчетДепоМХКонтрагента);
	Иначе
		Поручение.ДатаСделки				= Данные.DealDate;
		Поручение.ПланируемаяДатаРасчетов	= Данные.PayDate;
		Если ЗначениеЗаполнено(Данные.СчетДепоКонтрагента) Тогда
			Поручение.СчетДепоКонтрагента	= Данные.СчетДепоКонтрагента;
			Поручение.Контрагент			= Данные.СчетДепоКонтрагента.Владелец;
			Если ЗначениеЗаполнено(Данные.РазделСчетаДепоКонтрагента) Тогда
				Поручение.РазделСчетаДепоКонтрагента = Данные.РазделСчетаДепоКонтрагента;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	Поручение.МХКонтрагент = Данные.МХКонтрагент;
	Поручение.МХДепонента = Поручение.СчетДепоМХ.Владелец;
	Поручение.СпособПриемаПоручений = Справочники.СпособыПриемаПоручений.ЭлектронныйВид();
	Поручение.ЗагруженоИзВнешнегоИсточника = Истина;
	Если Не ЗначениеЗаполнено(Поручение.ДатаПриема) Тогда
		Поручение.ДатаПриема = ТекущаяДатаСеанса();
	КонецЕсли;
	
КонецПроцедуры

Функция УточненныйВидПереводаПоСчетамДепоМХ(СчетДепоМХ, СчетДепоМХКонтрагента)
	Если СчетДепоМХ = СчетДепоМХКонтрагента Тогда
		ВидОперацииД = Справочники.ВидыОпераций.ПереводМеждуРазделамиСчетаДепо;
	Иначе
		ВидОперацииД = Справочники.ВидыОпераций.Перемещение;
	КонецЕсли;
	
	Возврат ВидОперацииД;
КонецФункции 

Процедура ЗаписатьРезультатОбработкиВходящегоСообщения(DepoMessageId, ОписаниеОшибки = "")
	Идентификатор = DepoMessageId;
	ВнешнийИсточник = ПланыВидовХарактеристик.ВнешниеИсточники.KafkaPandaConsNti1634;
	ПроизошлаОшибкаОбработки = НЕ ПустаяСтрока(ОписаниеОшибки);
	Если ПроизошлаОшибкаОбработки Тогда
		РегистрыСведений.ЖурналВходящихСообщенийKafka.ЗаписатьОшибку(ВнешнийИсточник, Идентификатор, ОписаниеОшибки);
	Иначе
		РегистрыСведений.ЖурналВходящихСообщенийKafka.ЗавершитьОбработку(ВнешнийИсточник, Идентификатор);
	КонецЕсли;
КонецПроцедуры

Процедура ОповеститьОРазличающихсяРеквизитах(СводныеПорученияСРазличающимисяРеквизитами)
	РеквизитыДляПроверкиСтрокой = "ВидОперации, НомерПлатежа, Валюта, ИДФирмы, ИДКлиента, ИДКлиентаПолучателя, ИДКлиентаСубброкер,"
	+ "ИДКлиентаПолучателяСубброкер, СчетСписанияД, СчетЗачисленияД, Счет, СчетПриемник,"
	+ "UID, Биржа, Комментарий, ТипДеятельности, ID, CP, DepoCP, ID, CP, DepoCP, SubDepoCP, PayDate, DealDate";
	РеквизитыДляПроверки = СтрРазделить(РеквизитыДляПроверкиСтрокой, ", ", Ложь);
	ШаблонСообщения = "В строках с поручением с ИД брокера %1 различаются реквизиты %2";
	
	Пока СводныеПорученияСРазличающимисяРеквизитами.Следующий() Цикл
		ИменаРазличающихсяРеквизитов = "";
		Для Каждого Реквизит Из РеквизитыДляПроверки Цикл
			Если СводныеПорученияСРазличающимисяРеквизитами[Реквизит] > 1 Тогда
				ИменаРазличающихсяРеквизитов = ИменаРазличающихсяРеквизитов + Реквизит + "; ";
			КонецЕсли;
		КонецЦикла;
		
		ТекстСообщения = СтрШаблон(ШаблонСообщения, СводныеПорученияСРазличающимисяРеквизитами.ИД_Брокера, ИменаРазличающихсяРеквизитов);
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
		
		ПараметрыПоиска = Новый Структура("ИД_Брокера", СводныеПорученияСРазличающимисяРеквизитами.ИД_Брокера);
		СтрокиСНекорректнымиПоручениями = ДанныеДляПоручений.НайтиСтроки(ПараметрыПоиска);
		Для Каждого Строка Из СтрокиСНекорректнымиПоручениями Цикл
			Строка.Загружать = Ложь;
		КонецЦикла;
	КонецЦикла;
КонецПроцедуры

Процедура ОтправитьСтатусОбрабатываетсяВПанда(Поручение)
	СтатусПоручения = ОбработкаНеторговыхПорученийИзПандаВызовСервера.СтатусПоНаименованию("Обрабатывается");
	ОбработкаНеторговыхПорученийИзПандаВызовСервера.СоздатьСообщениеОбИзмененииСтатусаПорученияВПанда(Поручение, СтатусПоручения);
КонецПроцедуры

Процедура КонвертироватьДанныеПандаВДанные1С(ДанныеПанда)
	
	ДанныеДляПоручений.Очистить();
	Запрос = Новый Запрос;
	Запрос.Текст = ТекстЗапросаОбработкаДанныхПанда();
	Запрос.УстановитьПараметр("ДанныеПанда", ДанныеПанда);
	Запрос.УстановитьПараметр("ДлинаКодаСчетовДепо", Метаданные.Справочники.СчетаДепо.ДлинаКода);
	Запрос.УстановитьПараметр("ВидыОперацийЗачисление", ВидыОперацийЗачисление());
	Запрос.УстановитьПараметр("ВидыОперацийСписание", ВидыОперацийСписание());
	Запрос.УстановитьПараметр("ВидыОперацийПеревод", ВидыОперацийПеревод());
	Запрос.УстановитьПараметр("НачалоПериода", НачалоПериода);
	Запрос.УстановитьПараметр("КонецПериода", КонецПериода);
	РезультатЗапроса = Запрос.Выполнить();
	ДанныеДляПоручений.Загрузить(РезультатЗапроса.Выгрузить());
	ДозаполнитьДанныеПоручений();
	
КонецПроцедуры

Функция ВидыОперацийЗачисление()
	Результат = Новый Массив;
	Результат.Добавить("1");
	Результат.Добавить("2");
	Возврат Результат;
КонецФункции

Функция ВидыОперацийСписание()
	Результат = Новый Массив;
	Результат.Добавить("6");
	Результат.Добавить("7");
	Возврат Результат;
КонецФункции

Функция ВидыОперацийПеревод()
	Возврат "14";
КонецФункции

// BSLLS:MethodSize-off
// Функция возврашает тест запроса
// Возвращаемое значение:
//	Строка
Функция ТекстЗапросаОбработкаДанныхПанда()
	Возврат
	"ВЫБРАТЬ
	|	КодыЗагрузки.Владелец КАК МестоХранения,
	|	МАКСИМУМ(КодыЗагрузки.Код) КАК Наименование
	|ПОМЕСТИТЬ МестаХраненияПоНаименованиюПанда
	|ИЗ
	|	Справочник.КодыЗагрузки КАК КодыЗагрузки
	|ГДЕ
	|	КодыЗагрузки.Владелец ССЫЛКА Справочник.МестаХранения
	|	И КодыЗагрузки.Биржа = ЗНАЧЕНИЕ(Справочник.КлассификаторыЗагрузки.КодыМестХраненияИзПанда)
	|	И НЕ КодыЗагрузки.ПометкаУдаления
	|
	|СГРУППИРОВАТЬ ПО
	|	КодыЗагрузки.Владелец
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВЫБОР
	|		КОГДА ДанныеПанда.Operation В (&ВидыОперацийЗачисление)
	|			ТОГДА ЗНАЧЕНИЕ(Справочник.ВидыОпераций.Депонирование)
	|		КОГДА ДанныеПанда.Operation В (&ВидыОперацийСписание)
	|			ТОГДА ЗНАЧЕНИЕ(Справочник.ВидыОпераций.СнятиеСДепонирования)
	|		КОГДА ДанныеПанда.Operation В (&ВидыОперацийПеревод)
	|			ТОГДА ЗНАЧЕНИЕ(Справочник.ВидыОпераций.Перевод)
	|	КОНЕЦ КАК ВидОперации,
	|	ДанныеПанда.OperationText КАК OperationText,
	|	ДанныеПанда.Created КАК ДатаСоздания,
	|	ДанныеПанда.Id КАК НомерПоручения,
	|	ДанныеПанда.DocComment КАК Комментарий,
	|	ДанныеПанда.DealReference КАК Референс,
	|	ДанныеПанда.DeponentCode КАК КодДепонента,
	|	ДанныеПанда.DeponentName КАК НаименованиеДепонента,
	|	ДанныеПанда.DeponentSubAccount КАК БиржевойКодДепонента,
	|	ДанныеПанда.DeponentDepoAccount КАК КодСчетаДепоДепонента,
	|	ДанныеПанда.DeponentDepoAccountSection КАК КодРазделаСчетаДепоДепонента,
	|	ДанныеПанда.CounterpartyName КАК НаименованиеКонтрагента,
	|	ДанныеПанда.CounterpartyIdentifier КАК ИдентификаторКонтрагента,
	|	ДанныеПанда.CounterpartyDepoAccount КАК КодСчетаДепоКонтрагента,
	|	ДанныеПанда.CounterpartyDepoAccountSection КАК КодРазделаСчетаДепоКонтрагента,
	|	ДанныеПанда.CounterpartyClientName КАК НаименованиеКлиентаКонтрагента,
	|	ДанныеПанда.CounterpartyClientDepoAccount КАК КодСчетаДепоКлиентаКонтрагента,
	|	ДанныеПанда.Place КАК Place,
	|	ДанныеПанда.PlaceText КАК НаименованиеМестаРасчетов,
	|	ДанныеПанда.ISIN КАК ISIN,
	|	ДанныеПанда.SecRegNumber КАК SecRegNumber,
	|	ДанныеПанда.SecCode КАК SecCode,
	|	ДанныеПанда.Quantity КАК КоличествоЦБ,
	|	ДанныеПанда.ConsolidatedNumber КАК ExtID,
	|	ДанныеПанда.KafkaMessageId КАК KafkaMessageId,
	|	ДанныеПанда.DepoMessageId КАК DepoMessageId,
	|	ДанныеПанда.PayDate КАК PayDate,
	|	ДанныеПанда.DealDate КАК DealDate
	|ПОМЕСТИТЬ ДанныеПанда
	|ИЗ
	|	&ДанныеПанда КАК ДанныеПанда
	|ГДЕ
	|	ДанныеПанда.Operation В (&ВидыОперацийЗачисление, &ВидыОперацийСписание, &ВидыОперацийПеревод)
	|	И ДанныеПанда.Created МЕЖДУ &НачалоПериода И &КонецПериода
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ЦенныеБумаги.ISIN КАК ISIN,
	|	ЦенныеБумаги.НомерРегистрации КАК НомерРегистрации,
	|	ЦенныеБумаги.Ссылка КАК Ссылка,
	|	ЦенныеБумаги.ДатаПриемаНаОбслуживание КАК ДатаПриемаНаОбслуживание,
	|	ЦенныеБумаги.ДатаСнятияСОбслуживания КАК ДатаСнятияСОбслуживания,
	|	ДанныеПанда.ДатаСоздания КАК ДатаСозданияПоручения
	|ПОМЕСТИТЬ втЦенныеБумаги1СДепоСДублями
	|ИЗ
	|	ДанныеПанда КАК ДанныеПанда
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ЦенныеБумаги КАК ЦенныеБумаги
	|		ПО ДанныеПанда.ISIN = ЦенныеБумаги.ISIN
	|			И ДанныеПанда.SecRegNumber = ЦенныеБумаги.НомерРегистрации
	|			И (НЕ ЦенныеБумаги.ПометкаУдаления)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	// BSLLS:QueryParseError-off
	|ВЫБРАТЬ
	|	ВЫБОР
	|		КОГДА ЦенныеБумаги.ДатаПриемаНаОбслуживание <> ДАТАВРЕМЯ(1, 1, 1)
	|				И ЦенныеБумаги.ДатаСнятияСОбслуживания = ДАТАВРЕМЯ(1, 1, 1)
	|			ТОГДА 1
	|		ИНАЧЕ 0
	|	КОНЕЦ * 100 + ВЫБОР
	|		КОГДА ДЛИНАСТРОКИ(ЕСТЬNULL(КодыЗагрузки.Код, """")) > 0
	|			ТОГДА ВЫБОР
	|					КОГДА СТРНАЙТИ(ЕСТЬNULL(КодыЗагрузки.Код, """"), ""/"") = 0
	|						ТОГДА 2
	|					ИНАЧЕ 1
	|				КОНЕЦ
	|		ИНАЧЕ 0
	|	КОНЕЦ * 10 КАК Приоритет,
	|	ЦенныеБумаги.ISIN КАК ISIN,
	|	ЦенныеБумаги.НомерРегистрации КАК НомерРегистрации,
	|	ЦенныеБумаги.Ссылка КАК ЦеннаяБумага
	|ПОМЕСТИТЬ втЦенныеБумаги1СДепоСПриоритетом
	|ИЗ
	|	втЦенныеБумаги1СДепоСДублями КАК ЦенныеБумаги
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.КодыЗагрузки КАК КодыЗагрузки
	|		ПО ЦенныеБумаги.Ссылка = КодыЗагрузки.Владелец
	|			И (КодыЗагрузки.Биржа = ЗНАЧЕНИЕ(Справочник.КлассификаторыЗагрузки.NrdCode))
	|			И (НЕ КодыЗагрузки.ПометкаУдаления)
	|			И (ВЫБОР
	|				КОГДА КодыЗагрузки.ДатаОкончанияДействия = ДАТАВРЕМЯ(1, 1, 1)
	|					ТОГДА ИСТИНА
	|				ИНАЧЕ КодыЗагрузки.ДатаОкончанияДействия > ЦенныеБумаги.ДатаСозданияПоручения
	|			КОНЕЦ)
	|			И (КодыЗагрузки.ДатаНачалаДействия <= ЦенныеБумаги.ДатаСозданияПоручения)
	// BSLLS:QueryParseError-on
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	МАКСИМУМ(втЦенныеБумаги1СДепоСПриоритетом.Приоритет) КАК Приоритет,
	|	втЦенныеБумаги1СДепоСПриоритетом.ISIN КАК ISIN,
	|	втЦенныеБумаги1СДепоСПриоритетом.НомерРегистрации КАК НомерРегистрации
	|ПОМЕСТИТЬ втЦенныеБумаги1СДепоСМаксимальнымПриоритетом
	|ИЗ
	|	втЦенныеБумаги1СДепоСПриоритетом КАК втЦенныеБумаги1СДепоСПриоритетом
	|
	|СГРУППИРОВАТЬ ПО
	|	втЦенныеБумаги1СДепоСПриоритетом.ISIN,
	|	втЦенныеБумаги1СДепоСПриоритетом.НомерРегистрации
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЦенныеБумаги.ISIN КАК ISIN,
	|	ЦенныеБумаги.НомерРегистрации КАК НомерРегистрации,
	|	МАКСИМУМ(ЦенныеБумаги.ЦеннаяБумага) КАК ЦеннаяБумага
	|ПОМЕСТИТЬ втЦБпоISINиГосНомерам
	|ИЗ
	|	втЦенныеБумаги1СДепоСПриоритетом КАК ЦенныеБумаги
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ втЦенныеБумаги1СДепоСМаксимальнымПриоритетом КАК втЦенныеБумаги1СДепоСМаксимальнымПриоритетом
	|		ПО ЦенныеБумаги.Приоритет = втЦенныеБумаги1СДепоСМаксимальнымПриоритетом.Приоритет
	|			И ЦенныеБумаги.ISIN = втЦенныеБумаги1СДепоСМаксимальнымПриоритетом.ISIN
	|			И ЦенныеБумаги.НомерРегистрации = втЦенныеБумаги1СДепоСМаксимальнымПриоритетом.НомерРегистрации
	|
	|СГРУППИРОВАТЬ ПО
	|	ЦенныеБумаги.ISIN,
	|	ЦенныеБумаги.НомерРегистрации
	|
	|ИМЕЮЩИЕ
	|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ЦенныеБумаги.ЦеннаяБумага) = 1
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВЫБОР
	|		КОГДА ПорученияЦенныеБумаги.Ссылка ЕСТЬ NULL
	|				И НЕ РазделыСчетаДепоОтправителя.Ссылка ЕСТЬ NULL
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК Загружать,
	|	ДанныеПанда.ВидОперации КАК ВидОперации,
	|	ДанныеПанда.НомерПоручения КАК НомерПоручения,
	|	ДанныеПанда.ДатаСоздания КАК ДатаСоздания,
	|	ДанныеПанда.Комментарий КАК Комментарий,
	|	ДанныеПанда.Референс КАК Референс,
	|	ДанныеПанда.ExtID КАК ИД_Брокера,
	|	ДанныеПанда.KafkaMessageId КАК KafkaMessageId,
	|	ДанныеПанда.DepoMessageId КАК DepoMessageId,
	|	ДанныеПанда.КодДепонента КАК КодДО,
	|	ЕСТЬNULL(КодыДепонентовОтправителей.Владелец, КонтрагентОтправитель.Ссылка) КАК ДОтправитель,
	|	СчетаДепоОтправителя.Ссылка КАК СчетДепоДепонента,
	|	ДанныеПанда.КодРазделаСчетаДепоДепонента КАК РСДОтправительКод,
	|	РазделыСчетаДепоОтправителя.Ссылка КАК РСДОтправитель,
	|	РазделыСчетаДепоОтправителя.РазделСчетаДепоМХ КАК СчетРазделДЕПО,
	|	ВЫБОР
	|		КОГДА ДанныеПанда.ВидОперации = ЗНАЧЕНИЕ(Справочник.ВидыОпераций.Перевод)
	|			ТОГДА ЕСТЬNULL(КодыДепонентовОтправителей.Владелец, КонтрагентОтправитель.Ссылка)
	|	КОНЕЦ КАК ДПолучатель,
	|	ВЫБОР
	|		КОГДА ДанныеПанда.ВидОперации = ЗНАЧЕНИЕ(Справочник.ВидыОпераций.Перевод)
	|			ТОГДА ДанныеПанда.КодРазделаСчетаДепоКонтрагента
	|	КОНЕЦ КАК РCДПолучательКод,
	|	ВЫБОР
	|		КОГДА ДанныеПанда.ВидОперации = ЗНАЧЕНИЕ(Справочник.ВидыОпераций.Перевод)
	|			ТОГДА РазделыСчетаДепоДляПереводов.Ссылка
	|	КОНЕЦ КАК РCДПолучатель,
	|	ДанныеПанда.ИдентификаторКонтрагента КАК ID,
	|	ДанныеПанда.НаименованиеКонтрагента КАК CP,
	|	ДанныеПанда.КодСчетаДепоКонтрагента КАК DepoCP,
	|	СчетаДепоПолучателя.Ссылка КАК СчетДепоКонтрагента,
	|	ДанныеПанда.КодРазделаСчетаДепоКонтрагента КАК SubDepoCP,
	|	РазделыСчетаДепоПолучателя.Ссылка КАК РазделСчетаДепоКонтрагента,
	|	ДанныеПанда.НаименованиеКлиентаКонтрагента КАК ClientName,
	|	ДанныеПанда.КодСчетаДепоКлиентаКонтрагента КАК DepoCPClient,
	|	ДанныеПанда.ISIN КАК ISIN,
	|	ДанныеПанда.SecRegNumber КАК SecRegNumber,
	|	ДанныеПанда.SecCode КАК КодЦБ,
	|	втЦБпоISINиГосНомерам.ЦеннаяБумага КАК ЦеннаяБумага,
	|	ДанныеПанда.КоличествоЦБ КАК КоличествоЦБ,
	|	ДанныеПанда.PayDate КАК PayDate,
	|	ДанныеПанда.DealDate КАК DealDate,
	|	ДанныеПанда.Place КАК Place,
	|	ДанныеПанда.НаименованиеМестаРасчетов КАК НаименованиеМестаРасчетов,
	|	МестаХраненияПоНаименованиюПанда.МестоХранения КАК МХКонтрагент,
	|	ПорученияЦенныеБумаги.Ссылка КАК Поручение
	|ИЗ
	|	ДанныеПанда КАК ДанныеПанда
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.КодыЗагрузки КАК КодыДепонентовОтправителей
	|		ПО ДанныеПанда.КодДепонента = КодыДепонентовОтправителей.Код
	|			И (НЕ КодыДепонентовОтправителей.ПометкаУдаления)
	|			И (КодыДепонентовОтправителей.Владелец ССЫЛКА Справочник.Контрагенты)
	|			И (КодыДепонентовОтправителей.Биржа ССЫЛКА Справочник.Биржи)
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Контрагенты КАК КонтрагентОтправитель
	|		ПО ДанныеПанда.КодДепонента = КонтрагентОтправитель.Код
	|			И (ДанныеПанда.КодДепонента <> """")
	|			И (НЕ КонтрагентОтправитель.ПометкаУдаления)
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.СчетаДепо КАК СчетаДепоОтправителя
	|		ПО ДанныеПанда.КодСчетаДепоДепонента = СчетаДепоОтправителя.Код
	|			И (ЕСТЬNULL(КодыДепонентовОтправителей.Владелец, КонтрагентОтправитель.Ссылка) = СчетаДепоОтправителя.Владелец)
	|			И (НЕ СчетаДепоОтправителя.ПометкаУдаления)
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.РазделыСчетаДепо КАК РазделыСчетаДепоОтправителя
	|		ПО (РазделыСчетаДепоОтправителя.Владелец = СчетаДепоОтправителя.Ссылка)
	|			И (РазделыСчетаДепоОтправителя.Код = ДанныеПанда.КодРазделаСчетаДепоДепонента)
	|			И (НЕ РазделыСчетаДепоОтправителя.ПометкаУдаления)
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.РазделыСчетаДепо КАК РазделыСчетаДепоДляПереводов
	|		ПО (РазделыСчетаДепоДляПереводов.Владелец.Владелец = ЕСТЬNULL(КодыДепонентовОтправителей.Владелец, КонтрагентОтправитель.Ссылка))
	|			И (РазделыСчетаДепоДляПереводов.Код = ДанныеПанда.КодРазделаСчетаДепоКонтрагента)
	|			И (НЕ РазделыСчетаДепоДляПереводов.ПометкаУдаления)
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Контрагенты КАК Контрагенты
	|		ПО ДанныеПанда.ИдентификаторКонтрагента = Контрагенты.Код
	|			И (ДанныеПанда.ИдентификаторКонтрагента <> """")
	|			И (НЕ Контрагенты.ПометкаУдаления)
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.СчетаДепо КАК СчетаДепоПолучателя
	|		ПО (ПОДСТРОКА(ДанныеПанда.КодСчетаДепоКлиентаКонтрагента + ПОДСТРОКА(ДанныеПанда.КодСчетаДепоКонтрагента, 1, 4), 1, &ДлинаКодаСчетовДепо) = СчетаДепоПолучателя.Код)
	|			И (Контрагенты.Ссылка = СчетаДепоПолучателя.Владелец)
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.РазделыСчетаДепо КАК РазделыСчетаДепоПолучателя
	|		ПО (РазделыСчетаДепоПолучателя.Владелец = СчетаДепоПолучателя.Ссылка)
	|			И (РазделыСчетаДепоПолучателя.Код = ДанныеПанда.КодРазделаСчетаДепоКонтрагента)
	|			И (НЕ РазделыСчетаДепоПолучателя.ПометкаУдаления)
	|		ЛЕВОЕ СОЕДИНЕНИЕ втЦБпоISINиГосНомерам КАК втЦБпоISINиГосНомерам
	|		ПО ДанныеПанда.ISIN = втЦБпоISINиГосНомерам.ISIN
	|			И ДанныеПанда.SecRegNumber = втЦБпоISINиГосНомерам.НомерРегистрации
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.Поручение.ЦенныеБумагиСписываемые КАК ПорученияЦенныеБумаги
	|		ПО ДанныеПанда.НомерПоручения = ПорученияЦенныеБумаги.ИдентификаторЗагрузки
	|			И ДанныеПанда.ExtID = ПорученияЦенныеБумаги.Ссылка.ИдентификаторЗагрузки
	|			И (НЕ ПорученияЦенныеБумаги.Ссылка.ПометкаУдаления)
	|		ЛЕВОЕ СОЕДИНЕНИЕ МестаХраненияПоНаименованиюПанда КАК МестаХраненияПоНаименованиюПанда
	|		ПО ДанныеПанда.НаименованиеМестаРасчетов = МестаХраненияПоНаименованиюПанда.Наименование
	|
	|УПОРЯДОЧИТЬ ПО
	|	ДатаСоздания,
	|	ИД_Брокера,
	|	НомерПоручения";
КонецФункции
// BSLLS:MethodSize-on

#КонецОбласти

ОбщегоНазначения.ЛогироватьИспользованиеОбъекта(ЭтотОбъект);