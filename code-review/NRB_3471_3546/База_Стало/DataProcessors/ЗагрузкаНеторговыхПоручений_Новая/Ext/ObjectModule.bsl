#Область ОписаниеПеременных

Перем QUIK Экспорт;

#КонецОбласти


#Область ПрограммныйИнтерфейс

Процедура ИнициироватьСоединение(Параметры = Неопределено) Экспорт
	ВнешниеДанные.ИнициироватьСоединение(QUIK, "QUIK", Параметры);
КонецПроцедуры

Процедура ЗагрузитьНеторговыеПоручения() Экспорт
	
	Попытка
		НачатьТранзакцию();
		
		Если ФормироватьСводныеПоручения Тогда
			СформироватьСводныеПоручения();
		КонецЕсли;
		
		Для Каждого Строка Из ДанныеДляПоручений Цикл
			ЭтоСтрокаСводногоПоручения = ФормироватьСводныеПоручения И ЗначениеЗаполнено(Строка.ИД_Брокера);
			Если Не Строка.Загружать Или ЭтоСтрокаСводногоПоручения Тогда
				Продолжить;
			КонецЕсли;
			СформироватьПоручение(Строка);
		КонецЦикла;
		
		ЗафиксироватьТранзакцию();
	Исключение
		ОтменитьТранзакцию();
		ОбщегоНазначения.СообщитьОбОшибке("Не удалось загрузить 'Поручения клиентов':
											|
											|" + ОписаниеОшибки());
	КонецПопытки;
	
КонецПроцедуры

Процедура ПолучитьТаблицуПорученийЗаПериод(НачалоПериода, КонецПериода) Экспорт
	Если ИсточникЗагрузки = Перечисления.ИсточникиЗагрузки.QUIK Тогда
		Если QUIK = Неопределено Тогда
			ИнициироватьСоединение();
		КонецЕсли;
		НеторговыеПоручения = QUIK.НеторговыеПорученияЗаПериод(НачалоПериода, КонецПериода);
		КонвертироватьТаблицуADOвДанные1С(НеторговыеПоручения);
	ИначеЕсли ИсточникЗагрузки = Перечисления.ИсточникиЗагрузки.Панда Тогда
		НеторговыеПоручения = ОбработкаНеторговыхПорученийИзПандаВызовСервера.ДанныеНеторговыхПоручений(НачалоПериода, КонецПериода, Контрагент);
		КонвертироватьДанныеПандаВДанные1С(НеторговыеПоручения);
	Иначе
		Возврат;
	КонецЕсли;
КонецПроцедуры

Процедура СоздатьНедостающегоПоставщика(Данные) Экспорт
	КодДепонента = Данные.ID;
	ИмяДепонента = Данные.CP;
	Если Не ЗначениеЗаполнено(КодДепонента) Тогда
		Возврат;
	КонецЕсли;
	
	СпрДепонентов = Справочники.Контрагенты;
	СпрСчетовДепо = Справочники.СчетаДепо;
	СпрРазделовСчетовДепо = Справочники.РазделыСчетаДепо;
	
	// Если не заполнен счет Депо, то создадим его, но перед этим попробуем найти Депонента, если и его нет, то создадим и его
	Если Не ЗначениеЗаполнено(Данные.СчетДепоКонтрагента) Тогда
		РодительДляНовыхДепонентов	= СпрДепонентов.ГруппаКонтрагенты();
		Депонент					= СпрДепонентов.НайтиПоКоду(КодДепонента);
		
		Если Депонент = Неопределено ИЛИ Депонент = СпрДепонентов.ПустаяСсылка() Тогда
			НовыйДепонент	= СпрДепонентов.СоздатьЭлемент();
			
			НовыйДепонент.Код					= КодДепонента;
			НовыйДепонент.Наименование			= ИмяДепонента;
			НовыйДепонент.НаименованиеПолное	= ИмяДепонента;
			НовыйДепонент.ЮрФизЛицо				= Перечисления.ЮрФизЛицо.ЮрЛицо;
			НовыйДепонент.Родитель				= РодительДляНовыхДепонентов;
			НовыйДепонент.Контрагент			= Истина;
			
			НовыйДепонент.Записать();
			
			Депонент	= НовыйДепонент.Ссылка;
		КонецЕсли;
		
		НомерСчетаДепо = Данные.DepoCP;
		ЗаполненКодСчетаДепоКлиентаКонтрагента = ЗначениеЗаполнено(Данные.DepoCPClient);
		Если ЗаполненКодСчетаДепоКлиентаКонтрагента Тогда
			КодСчетаДепо = КодСчетаДепоПоКодуСчетаКлиентаКонтрагента(Данные.DepoCPClient, Данные.DepoCP);
			Данные.СчетДепоКонтрагента = Справочники.СчетаДепо.НайтиПоКоду(КодСчетаДепо, , , Депонент);
		Иначе
			Данные.СчетДепоКонтрагента = ПодобратьСчетДепо(Депонент, НомерСчетаДепо);
			КодСчетаДепо = Данные.DepoCP;
		КонецЕсли;
		
		Если Не ЗначениеЗаполнено(Данные.СчетДепоКонтрагента) Тогда
			НовыйСчетДепо	= СпрСчетовДепо.СоздатьЭлемент();
			
			НовыйСчетДепо.Владелец						= Депонент;
			НовыйСчетДепо.Код							= КодСчетаДепо;
			НовыйСчетДепо.Наименование					= НомерСчетаДепо;
			НовыйСчетДепо.СчетВМестеРасчетовНомерСчета	= НомерСчетаДепо;
			НовыйСчетДепо.ТипСчетаДепо					= Перечисления.ТипыСчетовДепо.НоминальногоДержателя;
			НовыйСчетДепо.ПризнакСчетаДепо				= Перечисления.ПризнакиСчетаДепо.СчетКонтрагента;
			НовыйСчетДепо.ВидСчетаДепо					= Перечисления.ВидыСчетовДепо.СчетДЕПО;
			
			НовыйСчетДепо.СчетВМестеРасчетовНомерСчетаКлиента = Данные.DepoCPClient;
			НовыйСчетДепо.СчетВМестеРасчетовНаименованиеКлиента = Данные.ClientName;
			
			НовыйСчетДепо.Записать();
			
			Данные.СчетДепоКонтрагента	= НовыйСчетДепо.Ссылка;
		КонецЕсли;
	КонецЕсли;
	
	// Если не заполнен Раздел счета Депо, то создадим его на основании счета Депо
	КодРазделаСчетаДепо = Данные.SubDepoCP;
	Если Не ЗначениеЗаполнено(КодРазделаСчетаДепо) Тогда
		Возврат;
	КонецЕсли;
	Данные.РазделСчетаДепоКонтрагента = СпрРазделовСчетовДепо.НайтиПоКоду(КодРазделаСчетаДепо, , , Данные.СчетДепоКонтрагента);
	
	Если Не ЗначениеЗаполнено(Данные.РазделСчетаДепоКонтрагента) Тогда
		НовыйРазделСчетаДепо	= СпрРазделовСчетовДепо.СоздатьЭлемент();
		НовыйРазделСчетаДепо.Владелец		= Данные.СчетДепоКонтрагента;
		НовыйРазделСчетаДепо.Код			= КодРазделаСчетаДепо;
		НовыйРазделСчетаДепо.Наименование	= КодРазделаСчетаДепо;
		НовыйразделСчетаДепо.Записать();
		
		Данные.РазделСчетаДепоКонтрагента	= НовыйРазделСчетаДепо.Ссылка;
	Иначе
		Если Данные.НаименованиеМестаРасчетов = "Депозитарий БКП" Тогда
			Данные.МХКонтрагент = МХКонтрагентаПоРазделу(Данные.РазделСчетаДепоКонтрагента);
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

Процедура ПроверитьПоставщикаВПоручениях() Экспорт
	Для Каждого Данные Из ДанныеДляПоручений Цикл
		Если Не Данные.Загружать ИЛИ Не ЭтоОперацияДепонирования(Данные.ВидОперации) Тогда
			Продолжить;
		КонецЕсли;	
		Если ЗначениеЗаполнено(Данные.DepoCP) И Не ЗначениеЗаполнено(Данные.СчетДепоКонтрагента) Тогда
			Данные.СчетДепоКонтрагента = Справочники.СчетаДепо.НайтиПоКоду(Данные.DepoCP);
		КонецЕсли;
		Если ЗначениеЗаполнено(Данные.СчетДепоКонтрагента) И ЗначениеЗаполнено(Данные.SubDepoCP)
				И Не ЗначениеЗаполнено(Данные.РазделСчетаДепоКонтрагента) Тогда
			Данные.РазделСчетаДепоКонтрагента = Справочники.РазделыСчетаДепо.НайтиПоКоду(Данные.SubDepoCP, , ,
				Данные.СчетДепоКонтрагента);
		КонецЕсли;	
		Если (ЗначениеЗаполнено(Данные.DepoCP) И Не ЗначениеЗаполнено(Данные.СчетДепоКонтрагента))
			ИЛИ (ЗначениеЗаполнено(Данные.SubDepoCP) И Не ЗначениеЗаполнено(Данные.РазделСчетаДепоКонтрагента)) Тогда
			СоздатьНедостающегоПоставщика(Данные);
		КонецЕсли;
	КонецЦикла;	
КонецПроцедуры

Функция ПодобратьСчетДепо(Депонент, НомерСчетаДепо) Экспорт
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	СчетаДепо.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.СчетаДепо КАК СчетаДепо
	|ГДЕ
	|	СчетаДепо.Владелец = &Депонент
	|	И СчетаДепо.Наименование = &НомерСчетаДепо
	|	И НЕ СчетаДепо.ПометкаУдаления";
	
	Запрос.УстановитьПараметр("Депонент", Депонент);
	Запрос.УстановитьПараметр("НомерСчетаДепо", НомерСчетаДепо);
	
	РезультатЗапроса = Запрос.Выполнить();
	Выборка = РезультатЗапроса.Выбрать();
	
	Если Выборка.Количество() = 1 Тогда
		Выборка.Следующий();
		Возврат Выборка.Ссылка;
	Иначе
		Возврат Справочники.СчетаДепо.НайтиПоКоду(НомерСчетаДепо, , , Депонент);
	КонецЕсли;
КонецФункции

Функция КодСчетаДепоПоКодуСчетаКлиентаКонтрагента(КодСчетаДепоКлиентаКонтрагента, КодСчетаДепо) Экспорт
	ДлинаКодаСчетовДепо = Метаданные.Справочники.СчетаДепо.ДлинаКода;
	Возврат Лев(КодСчетаДепоКлиентаКонтрагента + Лев(КодСчетаДепо, 4), ДлинаКодаСчетовДепо);
КонецФункции

Функция МХКонтрагентаПоРазделу(РазделСчетаДепоКонтрагента) Экспорт
	Если Не ЗначениеЗаполнено(РазделСчетаДепоКонтрагента) Тогда
		Возврат Неопределено;
	КонецЕсли;
	ПолучаемыеПоля = Новый Структура("МХКонтрагент", "РазделСчетаДепоМХ.Владелец.Владелец");
	РеквизитыРаздела = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(РазделСчетаДепоКонтрагента, ПолучаемыеПоля); 
	Возврат РеквизитыРаздела.МХКонтрагент;
КонецФункции

#КонецОбласти


#Область СлужебныеПроцедурыИФункции

Процедура СформироватьПоручение(Данные)
	
	Если Не ЗначениеЗаполнено(Данные.Поручение) Тогда
		Поручение = Документы.Поручение.СоздатьДокумент();
	Иначе
		Поручение = Данные.Поручение.ПолучитьОбъект();
	КонецЕсли;
	
	ЗаполнитьПоручение(Поручение, Данные);
	
	Поручение.ЦенныеБумагиСписываемые.Очистить();
	НоваяСтрокаЦБ = Поручение.ЦенныеБумагиСписываемые.Добавить();
	НоваяСтрокаЦБ.ЦеннаяБумага = Данные.ЦеннаяБумага;
	НоваяСтрокаЦБ.Количество = Данные.КоличествоЦБ;
	НоваяСтрокаЦБ.ИдентификаторЗагрузки = Данные.НомерПоручения;
	
	
	НачатьТранзакцию();
	Попытка
		Поручение.Записать(РежимЗаписиДокумента.Запись);
		ЗаписатьРезультатОбработкиВходящегоСообщения(Поручение.KafkaMessageId);
		Если ИсточникЗагрузки = Перечисления.ИсточникиЗагрузки.Панда Тогда
			ОтправитьСтатусОбрабатываетсяВПанда(Поручение.Ссылка);
		КонецЕсли;
		Данные.Поручение	= Поручение.Ссылка;
		Данные.Загружать	= Ложь;
		ЗафиксироватьТранзакцию();
	Исключение
		ОтменитьТранзакцию();
		ТекстСообщения = "Поручение №" + СокрЛП(Поручение.Номер) + " от " + Поручение.Дата + " не удалось записать "
						+ "по причине: " + ОписаниеОшибки();
		ОбщегоНазначения.СообщитьОбОшибке(ТекстСообщения);
	КонецПопытки;
	
КонецПроцедуры

Функция РеференсИзКомментария(Комментарий)
	
	Референс = "";
	ПозицияReference = Найти(Комментарий, "Референс:");
	Если ПозицияReference > 0 Тогда
	
		Референс = Прав(Комментарий, СтрДлина(Комментарий) -ПозицияReference - 9);
		
		ПозицияТочка = Найти(Референс, ".");
		
		Если ПозицияТочка > 0 Тогда
		
			Референс = СокрЛП(Лев(Референс, ПозицияТочка - 1));
		
		КонецЕсли;
	
	КонецЕсли;
	
	Возврат Референс;
	
КонецФункции

Процедура ДозаполнитьДанныеПоручений()
	ОрганизацияПоУмолчанию = ОбщегоНазначенияПовтИсп.ОрганизацияПоУмолчанию();
	МестоХраненияПоУмолчанию = ОбщегоНазначенияПовтИсп.ЗначениеКонстанты("МестоХраненияПоУмолчанию");
	
	Для Каждого Данные Из ДанныеДляПоручений Цикл
			Данные.Инициатор = Данные.ДОтправитель;
		Если Данные.НаименованиеМестаРасчетов = "Депозитарий БКП" Тогда
			РазделСчетаДепо = ?(ЗначениеЗаполнено(Данные.РCДПолучатель), Данные.РCДПолучатель, Данные.РазделСчетаДепоКонтрагента);
			Данные.МХКонтрагент = МХКонтрагентаПоРазделу(РазделСчетаДепо);
		КонецЕсли;
	КонецЦикла;
	
	ПустаяЦБ = Новый Структура("ЦеннаяБумага", Справочники.ЦенныеБумаги.ПустаяСсылка());
	СтрокиСНезаполненнойЦБ = ДанныеДляПоручений.НайтиСтроки(ПустаяЦБ);
	Для Каждого Строка Из СтрокиСНезаполненнойЦБ Цикл
		Если Строка.ВидОперации <> Справочники.ВидыОпераций.Депонирование Тогда
			Строка.ЦеннаяБумага = ПодобратьЦеннуюБумагуПоОстаткам(Строка);
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

Процедура КонвертироватьТаблицуADOвДанные1С(ТЗ)
	
	ДанныеДляПоручений.Очистить();
	Запрос = Новый Запрос(ТекстЗапросаПоПоручениям());
	Запрос.УстановитьПараметр("ТЗ", ТЗ);
	
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	ИндексЗапросаКонтрольРеквизитов = РезультатЗапроса.Количество() - 2;
	ИндексЗапросаСИтоговымиДанными = РезультатЗапроса.Количество() - 1;
	
	СводныеПорученияСРазличающимисяРеквизитами = РезультатЗапроса[ИндексЗапросаКонтрольРеквизитов].Выбрать();
	Если СводныеПорученияСРазличающимисяРеквизитами.Количество() > 0 Тогда
		ОповеститьОРазличающихсяРеквизитах(СводныеПорученияСРазличающимисяРеквизитами);
	КонецЕсли;
	
	ДанныеДляПоручений.Загрузить(РезультатЗапроса[ИндексЗапросаСИтоговымиДанными].Выгрузить());
	ДозаполнитьДанныеПоручений();
	
КонецПроцедуры

Функция ТекстЗапросаПоПоручениям()
	
	Возврат
	"ВЫБРАТЬ
	|	КодыЗагрузки.Владелец КАК МестоХранения,
	|	МАКСИМУМ(КодыЗагрузки.Код) КАК Наименование
	|ПОМЕСТИТЬ МестаХраненияПоНаименованиюПанда
	|ИЗ
	|	Справочник.КодыЗагрузки КАК КодыЗагрузки
	|ГДЕ
	|	КодыЗагрузки.Владелец ССЫЛКА Справочник.МестаХранения
	|	И КодыЗагрузки.Биржа = ЗНАЧЕНИЕ(Справочник.КлассификаторыЗагрузки.КодыМестХраненияИзПанда)
	|	И НЕ КодыЗагрузки.ПометкаУдаления
	|
	|СГРУППИРОВАТЬ ПО
	|	КодыЗагрузки.Владелец
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВЫБОР
	|		КОГДА ТЗ.ТипОперации = ""Депонирование""
	|			ТОГДА ЗНАЧЕНИЕ(Справочник.ВидыОпераций.Депонирование)
	|		КОГДА ТЗ.ТипОперации = ""СнятиеСДепонирования""
	|			ТОГДА ЗНАЧЕНИЕ(Справочник.ВидыОпераций.СнятиеСДепонирования)
	|		КОГДА ТЗ.ТипОперации = ""Перевод""
	|			ТОГДА ЗНАЧЕНИЕ(Справочник.ВидыОпераций.Перевод)
	|	КОНЕЦ КАК ВидОперации,
	|	ТЗ.НомерПоручения КАК НомерПоручения,
	|	ТЗ.НомерПлатежа КАК НомерПлатежа,
	|	ТЗ.CurrencyCode КАК CurrencyCode,
	|	ТЗ.ИДФирмы КАК ИДФирмы,
	|	ТЗ.ИДКлиента КАК ИДКлиента,
	|	ТЗ.ИДКлиентаПолучателя КАК ИДКлиентаПолучателя,
	|	ТЗ.ИДКлиентаСубброкер КАК ИДКлиентаСубброкер,
	|	ТЗ.ИДКлиентаПолучателяСубброкер КАК ИДКлиентаПолучателяСубброкер,
	|	ВЫБОР
	|		КОГДА ТЗ.Состояние = 0
	|			ТОГДА ""Активно""
	|		КОГДА ТЗ.Состояние = 1
	|			ТОГДА ""Исполнено""
	|		КОГДА ТЗ.Состояние = 2
	|			ТОГДА ""Снято""
	|		КОГДА ТЗ.Состояние = 3
	|			ТОГДА ""Срок действия истек""
	|		КОГДА ТЗ.Состояние = 4
	|			ТОГДА ""Запрос на отмену""
	|	КОНЕЦ КАК Состояние,
	|	ТЗ.ДатаИсполнения КАК ДатаИсполнения,
