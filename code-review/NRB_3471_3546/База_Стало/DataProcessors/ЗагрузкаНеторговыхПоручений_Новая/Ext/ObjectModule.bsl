	|		ПО ТД_ADO.ИДКлиентаПолучателяСубброкер = ДоговорыПолучателейСубброкер.Код
	|			И (ДоговорыПолучателейСубброкер.ПометкаУдаления = ЛОЖЬ)
	|			И (ДоговорыПолучателейСубброкер.Владелец ССЫЛКА Справочник.Контрагенты)
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.РазделыСчетаДепо КАК РазделыССД
	|		ПО (РазделыССД.Владелец.Владелец = ЕСТЬNULL(КодыДепонентовОтправителей.Владелец, ДоговорыОтправителейСубброкер.Владелец))
	|			И (РазделыССД.Код = ТД_ADO.СчетСписанияД)
	|			И (РазделыССД.ПометкаУдаления = ЛОЖЬ)
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.РазделыСчетаДепо КАК РазделыСЗД
	|		ПО (РазделыСЗД.Владелец.Владелец = ЕСТЬNULL(КодыДепонентовПолучателей.Владелец, ДоговорыПолучателейСубброкер.Владелец))
	|			И (РазделыСЗД.Код = ТД_ADO.СчетЗачисленияД)
	|			И (РазделыСЗД.ПометкаУдаления = ЛОЖЬ)
	|		ЛЕВОЕ СОЕДИНЕНИЕ ЦБПоКодамЗагрузки КАК ЦБПоКодамЗагрузки
	|		ПО ТД_ADO.SecCode = ЦБПоКодамЗагрузки.Код
	|		ЛЕВОЕ СОЕДИНЕНИЕ СчетаДепоКонтрагентов КАК СчетаДепоКонтрагентов
	|		ПО ТД_ADO.DepoCP = СчетаДепоКонтрагентов.DepoCP
	|			И ТД_ADO.ID = СчетаДепоКонтрагентов.ID
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.СчетаДепо КАК СчетаДепо
	|		ПО ТД_ADO.DepoCP = СчетаДепо.Код
	|			И (СчетаДепо.ПометкаУдаления = ЛОЖЬ)
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.РазделыСчетаДепо КАК РСчетаДепо
	|		ПО ТД_ADO.SubDepoCP = РСчетаДепо.Код
	|			И (РСчетаДепо.ПометкаУдаления = ЛОЖЬ)
	|			И (РСчетаДепо.Владелец = ЕСТЬNULL(СчетаДепоКонтрагентов.СчетДепо, СчетаДепо.Ссылка))
	|		ЛЕВОЕ СОЕДИНЕНИЕ МестаХраненияПоНаименованиюПанда КАК МестаХраненияПоНаименованиюПанда
	|		ПО ТД_ADO.НаименованиеМестаРасчетов = МестаХраненияПоНаименованиюПанда.Наименование
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.Поручение.ЦенныеБумагиСписываемые КАК ПорученияЦенныеБумаги
	|		ПО ТД_ADO.НомерПоручения = ПорученияЦенныеБумаги.ИдентификаторЗагрузки
	|			И ТД_ADO.ExtID = ПорученияЦенныеБумаги.Ссылка.ИдентификаторЗагрузки
	|			И (НЕ ПорученияЦенныеБумаги.Ссылка.ПометкаУдаления)
	|			И (ПорученияЦенныеБумаги.Ссылка.Дата МЕЖДУ НАЧАЛОПЕРИОДА(ТД_ADO.ДатаРегистрации, ДЕНЬ) И КОНЕЦПЕРИОДА(ДОБАВИТЬКДАТЕ(ТД_ADO.ДатаРегистрации, ДЕНЬ, 1), ДЕНЬ))
	|
	|УПОРЯДОЧИТЬ ПО
	|	ДатаРегистрации,
	|	ИД_Брокера,
	|	НомерПоручения";
	
КонецФункции

Функция ЭтоОперацияДепонирования(ВидОперации)
	Возврат (ВидОперации = Справочники.ВидыОпераций.Депонирование
			ИЛИ ВидОперации = Справочники.ВидыОпераций.СнятиеСДепонирования);
КонецФункции

Функция ПодобратьЦеннуюБумагуПоОстаткам(ДанныеПоручения)
	
	ДанныеЦБУказаны = ЗначениеЗаполнено(ДанныеПоручения.ISIN) И ЗначениеЗаполнено(ДанныеПоручения.SecRegNumber)
	Или ЗначениеЗаполнено(ДанныеПоручения.КодЦБ);
	
	Если Не ДанныеЦБУказаны Или Не ЗначениеЗаполнено(ДанныеПоручения.РСДОтправитель) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	КодыЦБ.Владелец КАК ЦеннаяБумага
	|ПОМЕСТИТЬ ЦБПоКодуЗагрузки
	|ИЗ
	|	Справочник.КодыЗагрузки КАК КодыЦБ
	|ГДЕ
	|	КодыЦБ.Код = &КодЗагрузки
	|	И НЕ КодыЦБ.ПометкаУдаления
	|	И КодыЦБ.Владелец ССЫЛКА Справочник.ЦенныеБумаги
	|	И (КодыЦБ.Биржа ССЫЛКА Справочник.Биржи
	|			ИЛИ КодыЦБ.Биржа ССЫЛКА Справочник.КлассификаторыЗагрузки)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ЦенныеБумаги.Ссылка
	|ИЗ
	|	Справочник.ЦенныеБумаги КАК ЦенныеБумаги
	|ГДЕ
	|	ЦенныеБумаги.ISIN = &ISIN
	|	И ЦенныеБумаги.НомерРегистрации = &НомерРегистрации
	|	И НЕ ЦенныеБумаги.ПометкаУдаления
	|	И &ISIN <> """"
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ОстаткиЦБ.ЦБ КАК ЦеннаяБумага
	|ИЗ
	|	РегистрНакопления.ОстаткиЦБ.Остатки(
	|			&Период,
	|			РазделСчетаДепо = &РазделСчетаДепо
	|				И ЦБ В
	|					(ВЫБРАТЬ
	|						ЦБПоКодуЗагрузки.ЦеннаяБумага
	|					ИЗ
	|						ЦБПоКодуЗагрузки КАК ЦБПоКодуЗагрузки)) КАК ОстаткиЦБ
	|ГДЕ
	|	ОстаткиЦБ.КоличествоОстаток > 0";
	
	Запрос.УстановитьПараметр("КодЗагрузки", ДанныеПоручения.КодЦБ);
	Запрос.УстановитьПараметр("ISIN", ДанныеПоручения.ISIN);
	Запрос.УстановитьПараметр("НомерРегистрации", ДанныеПоручения.SecRegNumber);
	Запрос.УстановитьПараметр("РазделСчетаДепо", ДанныеПоручения.РСДОтправитель);
	Запрос.УстановитьПараметр("Период", ДанныеПоручения.ДатаРегистрации);
	РезультатЗапроса = Запрос.Выполнить();
	Выборка = РезультатЗапроса.Выбрать();
	Если Выборка.Количество() = 1 Тогда
		Выборка.Следующий();
		Возврат Выборка.ЦеннаяБумага;
	Иначе
		Возврат Неопределено;
	КонецЕсли;
	
КонецФункции

Функция ЕстьРазличающиесяРеквизитыВПоручении(ДанныеПоручения, ИД_Брокера)
	ЕстьРазличающиесяРеквизитыВПоручении = Ложь;
	
	РеквизитыДляПроверкиСтрокой = "ВидОперации, НомерПлатежа, Валюта, КодДО, ДОтправитель, КодДП, ДПолучатель, Состояние,"
	+ "РСДОтправительКод, РСДОтправитель, РCДПолучательКод, РCДПолучатель, Счет, СчетРазделДЕПО, СчетПриемник,"
	+ "УидПользователя, Биржа, Комментарий, ТипДеятельности, ID, CP, DepoCP, СчетДепоКонтрагента, SubDepoCP,"
	+ "РазделСчетаДепоКонтрагента, PayDate, DealDate, Референс, МХКонтрагент, Инициатор";
	РеквизитыДляПроверки = СтрРазделить(РеквизитыДляПроверкиСтрокой, ", ", Ложь);
	
	ИменаРазличающихсяРеквизитов = "";
	Для Каждого Реквизит Из РеквизитыДляПроверки Цикл
		Если ДанныеПоручения[Реквизит] > 1 Тогда
			ИменаРазличающихсяРеквизитов = ИменаРазличающихсяРеквизитов + Реквизит + "; ";
			ЕстьРазличающиесяРеквизитыВПоручении = Истина;
		КонецЕсли;
	КонецЦикла;
	
	Если ЕстьРазличающиесяРеквизитыВПоручении Тогда
		ШаблонСообщения = "В строках с поручением с ИД брокера %1 различаются реквизиты %2. Невозможно создать сводное поручение по этим строкам";
		ТекстСообщения = СтрШаблон(ШаблонСообщения, ИД_Брокера, ИменаРазличающихсяРеквизитов);
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
	КонецЕсли;
	
	Возврат ЕстьРазличающиесяРеквизитыВПоручении;
КонецФункции

Процедура СформироватьСводныеПоручения()
	
	Запрос = ЗапросФормированияСводныхПоручений();
	ИдентификаторыБрокера = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Пока ИдентификаторыБрокера.Следующий() Цикл
		ПорученияКФормированию = ИдентификаторыБрокера.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		Пока ПорученияКФормированию.Следующий() Цикл
			Если ЕстьРазличающиесяРеквизитыВПоручении(ПорученияКФормированию, ИдентификаторыБрокера.ИД_Брокера) Тогда
				Продолжить;
			КонецЕсли;
			
			Если Не ЗначениеЗаполнено(ПорученияКФормированию.Поручение) Тогда
				Поручение = Документы.Поручение.СоздатьДокумент();
			Иначе
				Поручение = ПорученияКФормированию.Поручение.ПолучитьОбъект();
			КонецЕсли;
			
			ЗаполнитьИЗаписатьСводноеПоручение(Поручение, ПорученияКФормированию);
		КонецЦикла;
	КонецЦикла;
	
КонецПроцедуры

Процедура ЗаполнитьИЗаписатьСводноеПоручение(Поручение, ПорученияКФормированию)
	ДанныеПоручения = ПорученияКФормированию.Выбрать();
	ДанныеПоручения.Следующий();
	ЗаполнитьПоручение(Поручение, ДанныеПоручения);
	
	ДанныеПоручения.Сбросить();
	Поручение.ЦенныеБумагиСписываемые.Очистить();
	Пока ДанныеПоручения.Следующий() Цикл
		НоваяСтрокаЦБ = Поручение.ЦенныеБумагиСписываемые.Добавить();
		НоваяСтрокаЦБ.ЦеннаяБумага = ДанныеПоручения.ЦеннаяБумага;
		НоваяСтрокаЦБ.Количество = ДанныеПоручения.КоличествоЦБ;
		НоваяСтрокаЦБ.ИдентификаторЗагрузки = ДанныеПоручения.НомерПоручения;
	КонецЦикла;
	
	Попытка
		Поручение.Записать( РежимЗаписиДокумента.Запись);
		Если ИсточникЗагрузки = Перечисления.ИсточникиЗагрузки.Панда Тогда
			ОтправитьСтатусОбрабатываетсяВПанда(Поручение.Ссылка);
		КонецЕсли;
		ДанныеПоручения.Сбросить();
		Если Не ПустаяСтрока(Поручение.KafkaMessageId) Тогда
			ЗаписатьРезультатОбработкиВходящегоСообщения(Поручение.DepoMessageId);
		КонецЕсли;
		Пока ДанныеПоручения.Следующий() Цикл
			СтрокаПоИдентификатору = ДанныеДляПоручений.Найти(ДанныеПоручения.НомерПоручения, "НомерПоручения");
			СтрокаПоИдентификатору.Поручение = Поручение.Ссылка;
			СтрокаПоИдентификатору.Загружать = Ложь;
		КонецЦикла;
	Исключение
		ТекстСообщения = "Поручение №" + СокрЛП(Поручение.Номер) + " от " + Поручение.Дата + " не удалось записать ";
		ОбщегоНазначения.СообщитьОбОшибке(ТекстСообщения);
		ЗаписатьРезультатОбработкиВходящегоСообщения(ДанныеПоручения.KafkaMessageId, ТекстСообщения);
	КонецПопытки;
КонецПроцедуры

