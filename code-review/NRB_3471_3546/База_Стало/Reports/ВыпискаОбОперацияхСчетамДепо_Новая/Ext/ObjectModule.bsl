// BSLLS:CyclomaticComplexity-off

Функция ПолучитьПечатныеФормы() Экспорт
	
	// Создадим таблицу для хранения печатных форм
	ТаблицаПечатныхФорм	= Новый ТаблицаЗначений;
	ТаблицаПечатныхФорм.Колонки.Добавить("Клиент");
	ТаблицаПечатныхФорм.Колонки.Добавить("СчетДепо");
	ТаблицаПечатныхФорм.Колонки.Добавить("Основание");
	ТаблицаПечатныхФорм.Колонки.Добавить("ТабличныйДокумент");
	
	// Получим данные для отчета
	РезультатЗапроса = ВыборкаОперацийПоСчетамДепо();
	
	Если РезультатЗапроса.Пустой() Тогда
		стАктивныеОтборы = ПолучитьАктивныеОтборы();
		Если стАктивныеОтборы.Свойство("Клиенты") И ТипЗнч(стАктивныеОтборы.Клиенты) = Тип("СправочникСсылка.Контрагенты") Тогда
			// т.к. установлен отбор по клиенту, то получение и заполнение макета можно выполнить без учета результата запроса по остаткам и оборотам
			Клиент = стАктивныеОтборы.Клиенты;
			
			СписокСчетовДепо = Новый СписокЗначений;
			Если стАктивныеОтборы.Свойство("СчетаДепо") Тогда
				Если ТипЗнч(стАктивныеОтборы.СчетаДепо) = Тип("СписокЗначений") Тогда
					СписокСчетовДепо = стАктивныеОтборы.СчетаДепо;
				ИначеЕсли ТипЗнч(стАктивныеОтборы.СчетаДепо) = Тип("СправочникСсылка.СчетаДепо") Тогда
					СписокСчетовДепо.Добавить(стАктивныеОтборы.СчетаДепо);
				Иначе
					СписокСчетовДепо.Добавить(Справочники.СчетаДепо.ПустаяСсылка());
				КонецЕсли;
			Иначе
				СписокСчетовДепо.Добавить(Справочники.СчетаДепо.ПустаяСсылка());
			КонецЕсли;
			
			Для Каждого СчетДепоОтбора Из СписокСчетовДепо Цикл
				НовыйПечатныйДокумент					= ТаблицаПечатныхФорм.Добавить();
				НовыйПечатныйДокумент.Клиент			= Клиент;
				НовыйПечатныйДокумент.СчетДепо			= СчетДепоОтбора.Значение;
				НовыйПечатныйДокумент.Основание			= ВыпискаДокумент;
				НовыйПечатныйДокумент.ТабличныйДокумент	= ПолучитьПустойМакет(Клиент, СчетДепоОтбора.Значение);
			КонецЦикла;
		Иначе
			Возврат Неопределено;
		КонецЕсли;
	КонецЕсли;
	
	Если Выписка И ЗначениеЗаполнено(ВыпискаДокумент) Тогда
		Основание = ВыпискаДокумент;
	Иначе
		Основание = Документы.Выписка.ПустаяСсылка();
	КонецЕсли;
	
	ПоГруппировке	= ОбходРезультатаЗапроса.ПоГруппировкамСИерархией;
	ВыборкаКлиенты	= РезультатЗапроса.Выбрать(ПоГруппировке);
	Пока ВыборкаКлиенты.Следующий() Цикл
		
		Клиент = ВыборкаКлиенты.Клиент;
		
		// Очистим таблицу остатков под нового клиента
		ТаблицаЗначенийОстаткиНаКонец.Очистить();
		
		ИмяМакета = ПолучитьИмяМакета(Клиент, Основание.Дата);
		Макет = ПолучитьМакет(ИмяМакета);
		
		ВыборкаСчетаДепо = ВыборкаКлиенты.Выбрать(ПоГруппировке);
		Пока ВыборкаСчетаДепо.Следующий() Цикл
			
			ТабличныйДокумент = Новый ТабличныйДокумент;
			
			ТабличныйДокумент.РазмерСтраницы		= "A4";
			ТабличныйДокумент.ОриентацияСтраницы	= ОриентацияСтраницы.Ландшафт;
			ТабличныйДокумент.АвтоМасштаб			= Истина;
			ТабличныйДокумент.ТолькоПросмотр		= Истина;
			
			ПараметрыПереносаСтраницы = Новый Структура;
			
			СчетДепо = ВыборкаСчетаДепо.СчетДепо;
			ВидСчетаДепо = ВыборкаСчетаДепо.ВидСчетаДепо;
			
			ОпределяющаяДата = ?(ЗначениеЗаполнено(Основание.Дата), Основание.Дата, КонПериода);
			
			ИмяСекции = "Подвал";
			Подвал = Макет.ПолучитьОбласть(ИмяСекции);
			ФормированиеПечатныхФорм.УстановитьЗаголовкиСекцииМакета(Подвал.Параметры, ИмяМакета, ИмяСекции,
				мТекстыЗаголовков, ВидСчетаДепо);
			Подвал.Параметры.Заполнить(СформироватьПараметрыПодвалаМакета(Клиент, СчетДепо));
			
			ТекПользователь = ПараметрыСеанса.ТекущийПользователь;
			Если Не ЗначениеЗаполнено(ТекПользователь) Или Не РольДоступна("ПравоПодписанияОтчетов") Тогда // BSLLS:IsInRoleMethod-off
				Отбор = Новый Структура;
				Отбор.Вставить("ОтветственноеЛицо", Перечисления.ОтветственныеЛицаОрганизаций.ПодписантОтчетовПоУмолчанию);
				ОтветственноеЛицо = РегистрыСведений.ОтветственныеЛицаОрганизаций.ПолучитьПоследнее(ОпределяющаяДата, Отбор).ФизическоеЛицо;
			Иначе
				ОтветственноеЛицо = ТекПользователь.ФизЛицо;
			КонецЕсли;
			
			Если ТипЗнч(Клиент) = Тип("СправочникСсылка.Контрагенты") И ВыводитьФаксимилеВОтчетах И Не Документооборот Тогда
				ФормированиеПечатныхФорм.ПолучитьФаксимилье(ОтветственноеЛицо, Подвал.Рисунки.Faksimilie.Картинка);
			Иначе
				Подвал.Рисунки.Faksimilie.Картинка	= Новый Картинка;
			КонецЕсли;
			
			ИмяСекции = "Заголовок";
			Область = Макет.ПолучитьОбласть(ИмяСекции);
			Область.Параметры.Заполнить(СформироватьПараметрыЗаголовкаМакета(Клиент, СчетДепо));
			ФормированиеПечатныхФорм.УстановитьЗаголовкиСекцииМакета(Область.Параметры, ИмяМакета, ИмяСекции,
				мТекстыЗаголовков, ВидСчетаДепо);
			ТабличныйДокумент.Вывести(Область);
			
			ИмяСекции = "ШапкаОстатки";
			ШапкаОстатки = Макет.ПолучитьОбласть(ИмяСекции);
			ШапкаОстатки.Параметры.Заполнить(СформироватьПараметрыШапкиМакета(Клиент, НачПериода));
			ШапкаОстатки.Параметры.МоментДня = "начало операционного дня";
			ФормированиеПечатныхФорм.УстановитьЗаголовкиСекцииМакета(ШапкаОстатки.Параметры, ИмяМакета, ИмяСекции,
				мТекстыЗаголовков, ВидСчетаДепо);
			ТабличныйДокумент.Вывести(ШапкаОстатки);
			
			флВыведенаСтрокаОстатков = Ложь;
			СтрокаОстатки = Макет.ПолучитьОбласть("СтрокаОстатки");
			
			ВыборкаЦБ = ВыборкаСчетаДепо.Выбрать(ПоГруппировке);
			Пока ВыборкаЦБ.Следующий() Цикл
				ВыборкаРазделСчетаДепо = ВыборкаЦБ.Выбрать(ПоГруппировке);
				Пока ВыборкаРазделСчетаДепо.Следующий() Цикл
					ВыборкаРазделСчетаДепоМХ = ВыборкаРазделСчетаДепо.Выбрать(ПоГруппировке);
					Пока ВыборкаРазделСчетаДепоМХ.Следующий() Цикл
						ЗаполнитьСекциюСтрокаОстатки(СтрокаОстатки, ВыборкаРазделСчетаДепоМХ, Клиент.ОтчетыНаАнглийскомЯзыке, ПоГруппировке);
						ВывестиСекциюСтрокаОстаткиНаНачало(ТабличныйДокумент, СтрокаОстатки, флВыведенаСтрокаОстатков);
					КонецЦикла;
				КонецЦикла;
			КонецЦикла;
			
			Если Не флВыведенаСтрокаОстатков Тогда
				ТабличныйДокумент.Вывести(Макет.ПолучитьОбласть("ПустаяСтрокаОстатки"));
			КонецЕсли;
			
			ИмяСекции = "ШапкаОборот";
			ШапкаОборот = Макет.ПолучитьОбласть(ИмяСекции);
			ФормированиеПечатныхФорм.УстановитьЗаголовкиСекцииМакета(ШапкаОборот.Параметры, ИмяМакета, ИмяСекции, мТекстыЗаголовков, ВидСчетаДепо);
			ТабличныйДокумент.Вывести(ШапкаОборот);
			
			СтрокаОборот = Макет.ПолучитьОбласть("СтрокаОборот");
			ВывестиСекциюСтрокаОборот(ТабличныйДокумент, СтрокаОборот, Клиент.ОтчетыНаАнглийскомЯзыке, ВидСчетаДепо);
			
			ШапкаОстатки.Параметры.Заполнить(СформироватьПараметрыШапкиМакета(Клиент, КонПериода));
			ШапкаОстатки.Параметры.МоментДня = "конец операционного дня";
			
			ПараметрыПереносаСтраницы.Вставить("ШапкаОстатки", ШапкаОстатки);
			ПараметрыПереносаСтраницы.Вставить("Подвал", Подвал);
			
			ВывестиСекциюСтрокаОстаткиНаКонец(ТабличныйДокумент, СтрокаОстатки, Клиент.ОтчетыНаАнглийскомЯзыке, ПараметрыПереносаСтраницы);
			
			ТабличныйДокумент.Вывести(Подвал);
			
			ТабличныйДокумент.НижнийКолонтитул.Выводить = Истина;
			ТабличныйДокумент.НижнийКолонтитул.ТекстВЦентре = "[&НомерСтраницы] из [&СтраницВсего]";
			
			// Добавим Табличный документ в список сформированных
			НовыйПечатныйДокумент = ТаблицаПечатныхФорм.Добавить();
			НовыйПечатныйДокумент.Клиент			= Клиент;
			НовыйПечатныйДокумент.СчетДепо			= СчетДепо;
			НовыйПечатныйДокумент.Основание			= Основание;
			НовыйПечатныйДокумент.ТабличныйДокумент	= ТабличныйДокумент;
		КонецЦикла;
	КонецЦикла;
	
	Возврат ТаблицаПечатныхФорм;
	
КонецФункции

// BSLLS:CognitiveComplexity-on
// BSLLS:CyclomaticComplexity-on

Процедура ЗаполнитьСекциюСтрокаОстатки(СтрокаОстатки, ВыборкаМХ, ОтчетыНаАнглийскомЯзыке, ПоГруппировке)
	
	СтрокаОстатки.Параметры.КолОбр		= 0;
	СтрокаОстатки.Параметры.КолНеОбр	= 0;
	
	СтрокаОстатки.Параметры.ЦБ = ОбщегоНазначенияКлиентСервер.ПредставлениеЦБ(ВыборкаМХ.ЦБ, ОтчетыНаАнглийскомЯзыке);
	СтрокаОстатки.Параметры.ГосНомер = Строка(ВыборкаМХ.ЦБ.НомерРегистрации);
	Попытка
		СтрокаОстатки.Параметры.ISIN = Строка(ВыборкаМХ.ЦБ.ISIN);
	Исключение
	КонецПопытки;
	СтрокаОстатки.Параметры.МХ = ВыборкаМХ.РазделСчета.Владелец.Владелец.КодМестаХранения;
	ПредставлениеРСД = ОбщегоНазначенияКлиентСервер.ПредставлениеРазделаСчетаДепо(ВыборкаМХ.РазделСчетаДепо, ОтчетыНаАнглийскомЯзыке);
	СтрокаОстатки.Параметры.РС = ПредставлениеРСД;
	
	НоваяСтрокаОстКон = ТаблицаЗначенийОстаткиНаКонец.Добавить();
	ПредставлениеРСД = ОбщегоНазначенияКлиентСервер.ПредставлениеРазделаСчетаДепо(ВыборкаМХ.РазделСчетаДепо, ОтчетыНаАнглийскомЯзыке);
	НоваяСтрокаОстКон.РазделСчетаДепо = ПредставлениеРСД;
	НоваяСтрокаОстКон.ЦБ		= ВыборкаМХ.ЦБ;
	НоваяСтрокаОстКон.ГосНомер	= ВыборкаМХ.ЦБ.НомерРегистрации;
	НоваяСтрокаОстКон.МХ		= ВыборкаМХ.РазделСчета.Владелец.Владелец.КодМестаХранения;
	НоваяСтрокаОстКон.КолОбр	= 0;
	
	КолОбрОстНач		= 0;
	ВыборкаСтатусыЦБ	= ВыборкаМХ.Выбрать(ПоГруппировке);
	Пока ВыборкаСтатусыЦБ.Следующий() Цикл
		ВеткаСвободных		= (ВыборкаСтатусыЦБ.СтатусЦБ = Перечисления.СтатусыЦБ.Свободна);
		ВеткаОбремененных	= (ВыборкаСтатусыЦБ.СтатусЦБ = Перечисления.СтатусыЦБ.Обременена);
		ВеткаБлок			= (ВыборкаСтатусыЦБ.СтатусЦБ = Перечисления.СтатусыЦБ.Блокирована);
		ВеткаЗалог			= (ВыборкаСтатусыЦБ.СтатусЦБ = Перечисления.СтатусыЦБ.Заложена);
	
		ВыборкаСтрокОпераций = ВыборкаСтатусыЦБ.Выбрать();
		
		Если ВеткаСвободных Тогда
			СтрокаОстатки.Параметры.КолНеОбр = ВыборкаСтатусыЦБ.КоличествоНачальныйОстаток;
			НоваяСтрокаОстКон.КолНеОбр		 = ВыборкаСтатусыЦБ.КоличествоКонечныйОстаток;
			ЗаполнитьОборотПоСчетуДепо(ВыборкаСтрокОпераций);
		
		ИначеЕсли ВеткаОбремененных ИЛИ ВеткаБлок Тогда
			КолОбрОстНач				= КолОбрОстНач + ВыборкаСтатусыЦБ.КоличествоНачальныйОстаток;
			НоваяСтрокаОстКон.КолОбр	= НоваяСтрокаОстКон.КолОбр + ВыборкаСтатусыЦБ.КоличествоКонечныйОстаток;
			ЗаполнитьОборотПоСчетуДепо(ВыборкаСтрокОпераций);
		ИначеЕсли ВеткаЗалог Тогда
			КолОбрОстНач				= КолОбрОстНач + ВыборкаСтатусыЦБ.КоличествоНачальныйОстаток;
			НоваяСтрокаОстКон.КолОбр 	= НоваяСтрокаОстКон.КолОбр + ВыборкаСтатусыЦБ.КоличествоКонечныйОстаток;
			НоваяСтрокаОстКон.КолЗалог	= ВыборкаСтатусыЦБ.КоличествоКонечныйОстаток;
			ЗаполнитьОборотПоСчетуДепо(ВыборкаСтрокОпераций);
		КонецЕсли;
		
		СтрокаОстатки.Параметры.КолОбр = КолОбрОстНач;
		НоваяСтрокаОстКон.КолВПути = ВыборкаМХ.КонКоличествоВПути;
	КонецЦикла;
	
КонецПроцедуры

Процедура ВывестиСекциюСтрокаОстаткиНаНачало(ТабличныйДокумент, СтрокаОстатки, флВыведенаСтрокаОстатков)
	
	Если СтрокаОстатки.Параметры.КолОбр <> 0 ИЛИ СтрокаОстатки.Параметры.КолНеОбр <> 0 Тогда
		ТабличныйДокумент.Вывести(СтрокаОстатки);
		флВыведенаСтрокаОстатков = Истина;
	КонецЕсли;
	
КонецПроцедуры

Процедура ВывестиСекциюСтрокаОборот(ТабличныйДокумент, СтрокаОборот, ОтчетыНаАнглийскомЯзыке, ВидСчетаДепо)
	
	ТаблицаЗначенийОперации.Сортировать("ДатаВремя,НомерПроводки");
	Для Каждого ТекущаяСтрока Из ТаблицаЗначенийОперации Цикл 
		Если Не ЗначениеЗаполнено(ТекущаяСтрока.Регистратор) Тогда
			Продолжить;
		КонецЕсли;
		
		СтрокаОборот.Параметры.ДатаВремя = ТекущаяСтрока.ДатаВремя;
		ПредставлениеРСД = ОбщегоНазначенияКлиентСервер.ПредставлениеРазделаСчетаДепо(ТекущаяСтрока.РазделСчетаДепо, ОтчетыНаАнглийскомЯзыке);
		СтрокаОборот.Параметры.РС = ПредставлениеРСД;
		
		Если ТекущаяСтрока.ВидОперации = Справочники.ВидыОпераций.Депонирование Тогда
			Опер = "Зачисление";
			Если ОтчетыНаАнглийскомЯзыке Тогда
				Опер = Опер + " / Entry";
			КонецЕсли;
		ИначеЕсли ТекущаяСтрока.ВидОперации = Справочники.ВидыОпераций.СнятиеСДепонирования Тогда
			Опер = "Списание";
			Если ОтчетыНаАнглийскомЯзыке Тогда
				Опер = Опер + " / Withdrawal";
			КонецЕсли;
		Иначе
			Если ВидСчетаДепо = Перечисления.ВидыСчетовДепо.СчетНФИ И ЗначениеЗаполнено(ТекущаяСтрока.ВидОперации.НаименованиеОперацииИФИ) Тогда
				Опер = СокрЛП(ТекущаяСтрока.ВидОперации.НаименованиеОперацииИФИ); 
			Иначе
				Опер = СокрЛП(ТекущаяСтрока.ВидОперации.Наименование);
			КонецЕсли;
			Если ОтчетыНаАнглийскомЯзыке И ЗначениеЗаполнено(ТекущаяСтрока.ВидОперации.АнглийскоеНаименование) Тогда
				Опер = Опер + " / " + СокрЛП(ТекущаяСтрока.ВидОперации.АнглийскоеНаименование);
			КонецЕсли;
		КонецЕсли;
		
		СтрокаОборот.Параметры.НаименованиеОпер = Опер;
		СтрокаОборот.Параметры.ЦеннаяБумага		= ОбщегоНазначенияКлиентСервер.ПредставлениеЦБ(ТекущаяСтрока.ЦБ,
			ОтчетыНаАнглийскомЯзыке);
		СтрокаОборот.Параметры.РегНомер			= ТекущаяСтрока.ЦБ.НомерРегистрации;
		
		Попытка
			СтрокаОборот.Параметры.ISIN = ТекущаяСтрока.ЦБ.ISIN;
		Исключение
		КонецПопытки;
		
		СтрокаОборот.Параметры.КолЗач			= ТекущаяСтрока.Зачислено;
		СтрокаОборот.Параметры.КолСпис			= ТекущаяСтрока.Списано;
		
		Регистратор = ТекущаяСтрока.Регистратор;
		ДокументОснование = "";
		Если Метаданные.Документы.Найти(Регистратор.Метаданные().Имя).Реквизиты.Найти("ДокументОснование") <> Неопределено
			И ЗначениеЗаполнено(Регистратор.ДокументОснование) Тогда
			
			ДокументОснование = СокрЛП(Регистратор.ДокументОснование.Метаданные().Синоним);
			Если ОтчетыНаАнглийскомЯзыке Тогда
				ДокументОснование = ДокументОснование + "["
					+ ОбщегоНазначенияКлиентСервер.ПредставлениеДокумента(
						Регистратор.ДокументОснование, Истина) + "]";
			КонецЕсли;
					
			ДокументОснование = ДокументОснование + " № "
				+ СокрЛП(Регистратор.ДокументОснование.Номер)
				+ ?(ОтчетыНаАнглийскомЯзыке, " от[dated] ", " от ")
				+ Формат(Регистратор.ДокументОснование.Дата,"ДФ=dd.MM.yy");
		КонецЕсли;
		СтрокаОборот.Параметры.Основание = ДокументОснование;
		ТабличныйДокумент.Вывести(СтрокаОборот);
	КонецЦикла;
	
КонецПроцедуры

// BSLLS:CognitiveComplexity-off
// BSLLS:CyclomaticComplexity-off

Процедура ВывестиСекциюСтрокаОстаткиНаКонец(ТабличныйДокумент, СтрокаОстатки, ОтчетыНаАнглийскомЯзыке, ПараметрыПереносаСтраницы)
	
	ОбластиКПроверке = Новый Массив;
	ЕдинственнаяСтрока = Ложь;
	Если ТаблицаЗначенийОстаткиНаКонец.Количество() = 0 Тогда
		ОбластиКПроверке.Добавить(ПараметрыПереносаСтраницы.ШапкаОстатки);
		ОбластиКПроверке.Добавить(ПараметрыПереносаСтраницы.Подвал);
		ФормированиеПечатныхФорм.ВывестиГоризонтальныйРазделитель(ТабличныйДокумент, ОбластиКПроверке);
		ТабличныйДокумент.Вывести(ПараметрыПереносаСтраницы.ШапкаОстатки);
	ИначеЕсли ТаблицаЗначенийОстаткиНаКонец.Количество() = 1 Тогда
		ЕдинственнаяСтрока = Истина;
	Иначе
		ТабличныйДокумент.Вывести(ПараметрыПереносаСтраницы.ШапкаОстатки);
	КонецЕсли;
	
	НомерПоследнейСтроки = 0;
	НомерТекущейСтроки = 0;
	Для Каждого ТекущаяСтрока Из ТаблицаЗначенийОстаткиНаКонец Цикл
		НомерТекущейСтроки = НомерТекущейСтроки + 1;
		Если ТекущаяСтрока.КолНеОбр = Неопределено Тогда
			ТекущаяСтрока.КолНеОбр = 0;
		КонецЕсли;
		Если ТекущаяСтрока.КолЗалог = Неопределено Тогда
			ТекущаяСтрока.КолЗалог = 0;
		КонецЕсли;
		Если ТекущаяСтрока.КолОбр = Неопределено Тогда
			ТекущаяСтрока.КолОбр = 0;
		КонецЕсли;
		Если ТекущаяСтрока.КолВПути = Неопределено Тогда
			ТекущаяСтрока.КолВПути = 0;
		КонецЕсли;
		
		ЭтоСтрокаСИтогами = ТекущаяСтрока.КолНеОбр <> 0 Или ТекущаяСтрока.КолОбр <> 0;
		Если ЭтоСтрокаСИтогами Тогда
			НомерПоследнейСтроки = НомерТекущейСтроки;
		КонецЕсли;
	КонецЦикла;
	
	НомерТекущейСтроки = 0;
	Для Каждого ТекущаяСтрока Из ТаблицаЗначенийОстаткиНаКонец Цикл
		НомерТекущейСтроки = НомерТекущейСтроки + 1;
		ЭтоПоследняяСтрока = НомерТекущейСтроки = НомерПоследнейСтроки;
		
		ЭтоСтрокаСИтогами = ТекущаяСтрока.КолНеОбр <> 0 Или ТекущаяСтрока.КолОбр <> 0;
		
		Если ЭтоСтрокаСИтогами Тогда
			
			ПредставлениеРСД = ТекущаяСтрока.РазделСчетаДепо;
			СтрокаОстатки.Параметры.РС = ПредставлениеРСД;
			
			СтрокаОстатки.Параметры.ЦБ = ОбщегоНазначенияКлиентСервер.ПредставлениеЦБ(ТекущаяСтрока.ЦБ, ОтчетыНаАнглийскомЯзыке);
			Если МХПоУмолчанию Тогда
				СтрокаОстатки.Параметры.МХ = МХОтбор;
			Иначе
				СтрокаОстатки.Параметры.МХ = ТекущаяСтрока.МХ;
			КонецЕсли;
			СтрокаОстатки.Параметры.КолНеОбр	= ТекущаяСтрока.КолНеОбр;
			СтрокаОстатки.Параметры.КолОбр		= ТекущаяСтрока.КолОбр;
			
			СтрокаОстатки.Параметры.ГосНомер = ТекущаяСтрока.ГосНомер;
			Попытка
				СтрокаОстатки.Параметры.ISIN = ТекущаяСтрока.ЦБ.ISIN;
			Исключение
			КонецПопытки;
			
			Если ЭтоПоследняяСтрока Тогда
				Если ЕдинственнаяСтрока Тогда
					ОбластиКПроверке.Добавить(ПараметрыПереносаСтраницы.ШапкаОстатки);
				КонецЕсли;
				ОбластиКПроверке.Добавить(СтрокаОстатки);
				ОбластиКПроверке.Добавить(ПараметрыПереносаСтраницы.Подвал);
				ФормированиеПечатныхФорм.ВывестиГоризонтальныйРазделитель(ТабличныйДокумент, ОбластиКПроверке);
				Если ЕдинственнаяСтрока Тогда
					ТабличныйДокумент.Вывести(ПараметрыПереносаСтраницы.ШапкаОстатки);
				КонецЕсли;
			КонецЕсли;
			
			ТабличныйДокумент.Вывести(СтрокаОстатки);
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

// BSLLS:CognitiveComplexity-on
// BSLLS:CyclomaticComplexity-on

Функция ПолучитьПустойМакет(Контрагент, СчетДЕПО)
	
	Если Выписка И ЗначениеЗаполнено(ВыпискаДокумент) Тогда
		Основание = ВыпискаДокумент;
	Иначе
		Основание = Документы.Выписка.ПустаяСсылка();
	КонецЕсли;
	
	ИмяМакета	= ПолучитьИмяМакета(Контрагент, Основание.Дата);
	Макет		= ПолучитьМакет(ИмяМакета);
	ТабДок		= Новый ТабличныйДокумент;
	
	ИмяСекции = "Заголовок";	
	ОбластьЗаголовок = Макет.ПолучитьОбласть(ИмяСекции);
	ОбластьЗаголовок.Параметры.Заполнить(СформироватьПараметрыЗаголовкаМакета(Контрагент, СчетДЕПО));
	ФормированиеПечатныхФорм.УстановитьЗаголовкиСекцииМакета(ОбластьЗаголовок.Параметры, ИмяМакета, ИмяСекции,
		мТекстыЗаголовков, СчетДепо.ВидСчетаДепо);
	ТабДок.Вывести(ОбластьЗаголовок);
	
	ИмяСекции = "ШапкаОстатки";	
	ОбластьШапкаОстатки = Макет.ПолучитьОбласть(ИмяСекции);
	ОбластьШапкаОстатки.Параметры.Заполнить(СформироватьПараметрыШапкиМакета(Контрагент, НачПериода));
	ФормированиеПечатныхФорм.УстановитьЗаголовкиСекцииМакета(ОбластьШапкаОстатки.Параметры, ИмяМакета, ИмяСекции,
		мТекстыЗаголовков, СчетДепо.ВидСчетаДепо);
	ТабДок.Вывести(ОбластьШапкаОстатки);
	ТабДок.Вывести(Макет.ПолучитьОбласть("ПустаяСтрокаОстатки"));
	
	ИмяСекции = "ШапкаОборот";
	ШапкаОборот = Макет.ПолучитьОбласть(ИмяСекции);
	ФормированиеПечатныхФорм.УстановитьЗаголовкиСекцииМакета(ШапкаОборот.Параметры, ИмяМакета, ИмяСекции,
		мТекстыЗаголовков, СчетДепо.ВидСчетаДепо);
	ТабДок.Вывести(ШапкаОборот);
	
	ТабДок.Вывести(Макет.ПолучитьОбласть("ПустаяСтрокаОборот"));
	
	ТабДок.ВывестиГоризонтальныйРазделительСтраниц();
	
	ОбластьШапкаОстатки.Параметры.Заполнить(СформироватьПараметрыШапкиМакета(Контрагент, КонПериода));
	ТабДок.Вывести(ОбластьШапкаОстатки);
	ТабДок.Вывести(Макет.ПолучитьОбласть("ПустаяСтрокаОстатки"));

	ИмяСекции = "Подвал";
	ОбластьПодвал = Макет.ПолучитьОбласть(ИмяСекции);
	ФормированиеПечатныхФорм.УстановитьЗаголовкиСекцииМакета(ОбластьПодвал.Параметры, ИмяМакета, ИмяСекции,
		мТекстыЗаголовков, СчетДепо.ВидСчетаДепо);
	ОбластьПодвал.Параметры.Заполнить(СформироватьПараметрыПодвалаМакета(Контрагент, СчетДепо));
	
	// Получить факсимилье
	ОтветственноеЛицо = ПараметрыСеанса.ТекущийПользователь;
	
	Если ТипЗнч(Контрагент) = Тип("СправочникСсылка.Контрагенты") И ВыводитьФаксимилеВОтчетах И Не Документооборот Тогда
		ФормированиеПечатныхФорм.ПолучитьФаксимилье(ОтветственноеЛицо.ФизЛицо, ОбластьПодвал.Рисунки.Faksimilie.Картинка);
	Иначе
		ОбластьПодвал.Рисунки.Faksimilie.Картинка	= Новый Картинка;
	КонецЕсли;
	
	ТабДок.Вывести(ОбластьПодвал);
	
	ТабДок.РазмерСтраницы	  = "A4";
	ТабДок.ОриентацияСтраницы = ОриентацияСтраницы.Ландшафт;
	ТабДок.АвтоМасштаб		  = Истина;
	ТабДок.ТолькоПросмотр	  = Истина;

	Возврат ТабДок;
	
КонецФункции

Процедура ЗаполнитьОборотПоСчетуДепо(Данные);
	
	Пока Данные.Следующий() Цикл
		НоваяСтрокаОперация					= ТаблицаЗначенийОперации.Добавить();
		НоваяСтрокаОперация.ДатаВремя		= Данные.ДатаОперации;
		НоваяСтрокаОперация.НомерПроводки	= Данные.НомерПроводки;
		НоваяСтрокаОперация.ВидОперации		= Данные.ВидОперации;
		НоваяСтрокаОперация.ЦБ				= Данные.ЦБ;
		НоваяСтрокаОперация.ВидВыпускЦБ		= Строка(Данные.ЦБ.ТипЦБ) + " " + Строка(Данные.ЦБ.ВидЦБ) + ", " + Строка(Данные.ЦБ.Выпуск);
		НоваяСтрокаОперация.Зачислено		= Данные.КоличествоПриход;
		НоваяСтрокаОперация.Списано			= Данные.КоличествоРасход;
		НоваяСтрокаОперация.Основание		= Данные.Основание;
		НоваяСтрокаОперация.Регистратор		= Данные.Регистратор;
		НоваяСтрокаОперация.РазделСчета		= Данные.РазделСчета;
		НоваяСтрокаОперация.РазделСчетаДепо	= Данные.РазделСчетаДепо;
	КонецЦикла;
	
КонецПроцедуры

Функция СформироватьПараметрыЗаголовкаМакета(Контрагент, СчетДЕПО)

	стПараметры = Новый Структура;
	
	Период				= ?(ЗначениеЗаполнено(ВыпискаДокумент), ВыпискаДокумент.Дата, КонПериода);
	ПериодСтрокой		= Формат(Период, "ДФ=ddMMyyyy");
	Депозитарий			= Константы.ОрганизацияПоУмолчанию.Получить();
	ДанныеЛицензии		= ФормированиеПечатныхФорм.ДанныеЛицензииОрганизации(Константы.ОрганизацияПоУмолчанию.Получить());
	
	стПараметры.Вставить("Дата", "с " + Формат(НачПериода,"ДЛФ=DD") + " по " + Формат(КонПериода,"ДЛФ=DD"));
	стПараметры.Вставить("ТипОперации", "Формирование отчета по операциям за период по счету ДЕПО");
	стПараметры.Вставить("ИсходящийНомер", СокрЛП(ВыпискаДокумент.Номер));
	стПараметры.Вставить("Депозитарий", "ДЕПОЗИТАРИЙ"+ Символы.ПС + СокрЛП(Депозитарий.Наименование));
	стПараметры.Вставить("Лицензия", "Лицензия № " + СокрЛП(ДанныеЛицензии.НомерЛицензии));
	стПараметры.Вставить("ЛицензияДата", "выдана " + Формат(ДанныеЛицензии.ДатаЛицензии, "ДФ=dd.MM.yyyy") + " г. ФСФР России");
	стПараметры.Вставить("Custody", "");
	
	Если Контрагент.ОтчетыНаАнглийскомЯзыке Тогда
		стПараметры.Депозитарий = стПараметры.Депозитарий + Символы.ПС + стПараметры.Лицензия + Символы.ПС + стПараметры.ЛицензияДата;
		стПараметры.Custody = "CUSTODY" + Символы.ПС + СокрЛП(Депозитарий.АнглийскоеНаименование) + Символы.ПС + "License No. " + СокрЛП(ДанныеЛицензии.НомерЛицензии)
			+ Символы.ПС + "issued by FFMS of Russia on " + Формат(ДанныеЛицензии.ДатаЛицензии, "ДЛФ=D");
		
		Для сч = 1 По 12 Цикл
			стПараметры.Вставить("ор"+сч, Сред(стПараметры.ИсходящийНомер, сч, 1));
		КонецЦикла;
	КонецЕсли;
	
	стПараметры.Вставить("НомерВыписки", "Отчет № " + стПараметры.ИсходящийНомер + " об операциях по счету ДЕПО");
	Если Период < Дата(2016, 6, 14) Тогда
		стПараметры.НомерВыписки = "Выписка № " + стПараметры.ИсходящийНомер + " по операциям по счету ДЕПО";
	КонецЕсли;	
	
	стПараметры.Вставить("ИнициаторОперации", "");
	Если ЗначениеЗаполнено(ВыпискаДокумент) И ЗначениеЗаполнено(ВыпискаДокумент.ДокументОснование) Тогда
		стПараметры.ИнициаторОперации = ОбщегоНазначенияКлиентСервер.НаименованиеКлиента(ВыпискаДокумент.ДокументОснование.Инициатор, Контрагент.ОтчетыНаАнглийскомЯзыке);
	КонецЕсли;

	стПараметры.Вставить("НаименованиеДепонента", ОбщегоНазначенияКлиентСервер.НаименованиеЮрФизЛицаКлиента(Контрагент, Период, Контрагент.ОтчетыНаАнглийскомЯзыке));
	стПараметры.Вставить("ДокументыДепонента", ОбщегоНазначенияКлиентСервер.ДокументКлиента(Контрагент, Период));
	стПараметры.Вставить("НаименованиеСчетаДЕПО", ОбщегоНазначенияКлиентСервер.НаименованиеКлиента(Контрагент, Контрагент.ОтчетыНаАнглийскомЯзыке));
	стПараметры.Вставить("НомерСчетаДЕПО", ?(ЗначениеЗаполнено(СчетДЕПО), СокрЛП(СчетДЕПО.Код), ""));

	ФормированиеПечатныхФорм.СформироватьДатуДДММГГ(стПараметры, "", Период);
	ФормированиеПечатныхФорм.СформироватьДатуДДММГГ(стПараметры, "С", НачПериода);
	ФормированиеПечатныхФорм.СформироватьДатуДДММГГ(стПараметры, "По", КонПериода);
	
	Инфо = ФормированиеПечатныхФорм.ИнформацияОДепозитарии(Период, СчетДЕПО.ВидСчетаДепо)
		+ Символы.ПС + Символы.ПС + ФормированиеПечатныхФорм.ИнформацияОДепозитарииНаАнглийском(Период, СчетДЕПО.ВидСчетаДепо);
	стПараметры.Вставить("ИнформацияОДепозитарии", Инфо);
	
	стПараметры.Вставить("ТипОперации", ТипОперации(СчетДЕПО.ВидСчетаДепо, "Русский"));
	Если Контрагент.ОтчетыНаАнглийскомЯзыке Тогда
		стПараметры.Вставить("ТипОперацииНаАнглийском", ТипОперации(СчетДЕПО.ВидСчетаДепо, "Английский"));
	КонецЕсли;
	
	Если ЗначениеЗаполнено(СчетДЕПО) Тогда
		Если РегистрыСведений.КлиентыСУчетомНаСчетахТипаC.ЦБКлиентаУчитываютсяНаСчетеТипаС(Период, СчетДЕПО.Владелец) Тогда
			ТипСчетаДепо = "" + СчетДЕПО.ТипСчетаДепо + " типа С";
		Иначе
			ТипСчетаДепо = СчетДЕПО.ТипСчетаДепо;
		КонецЕсли;
		НаименованиеСчетаДЕПО =
			?(Контрагент.ОтчетыНаАнглийскомЯзыке,
				ПереводТекстаНаДругиеЯзыки.ДополнитьТекстПереводом(ТипСчетаДепо), СокрЛП(ТипСчетаДепо));
	Иначе
		НаименованиеСчетаДЕПО = "";
	КонецЕсли;
	стПараметры.Вставить("НаименованиеСчетаДЕПО", НаименованиеСчетаДЕПО);
	
	Возврат стПараметры;
	
КонецФункции

Функция ТипОперации(ВидСчетаДепо, Язык)
	
	Тип = "";
	Если Язык = "Русский" Тогда
		Тип = "Формирование выписки по операциям за период по счету ДЕПО";
	ИначеЕсли Язык = "Английский" Тогда
		Тип = "Generation of custody account transactions statement for a period";
	КонецЕсли;
	Возврат Тип;
	
КонецФункции

Функция СформироватьПараметрыШапкиМакета(Контрагент, Период)

	стПараметры = Новый Структура;
	стПараметры.Вставить("ДатаОстатков", Формат(Период, "ДЛФ=DD"));
	
	ФормированиеПечатныхФорм.СформироватьДатуДДММГГ(стПараметры, "На", Период);
	
	Возврат стПараметры;
	
КонецФункции

Функция СформироватьПараметрыПодвалаМакета(Контрагент, СчетДепо)
	
	стПараметры = Новый Структура;
	
	ТекПользователь = ПараметрыСеанса.ТекущийПользователь;
	Если НЕ ЗначениеЗаполнено(ТекПользователь) ИЛИ НЕ РольДоступна("ПравоПодписанияОтчетов") Тогда
		Отбор = Новый Структура;
		Отбор.Вставить("ОтветственноеЛицо",Перечисления.ОтветственныеЛицаОрганизаций.ПодписантОтчетовПоУмолчанию);
		ОтветственноеЛицо = РегистрыСведений.ОтветственныеЛицаОрганизаций.ПолучитьПоследнее(ВыпискаДокумент.Дата, Отбор).ФизическоеЛицо;
	Иначе
		ОтветственноеЛицо = ТекПользователь.ФизЛицо;
	КонецЕсли;
	
	стПараметры.Вставить("ФИО", ?(ОтветственноеЛицо = Неопределено, ПараметрыСеанса.ТекущийПользователь.ПолноеНаименование(), ОтветственноеЛицо.Наименование));
	
	Если Контрагент.ОтчетыНаАнглийскомЯзыке Тогда
		стПараметры.ФИО = стПараметры.ФИО + " / " + ОбщегоНазначенияКлиентСервер.Транслит(стПараметры.ФИО);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ВыпискаДокумент) Тогда
		стПараметры.Вставить("Поручение", "№ " + СокрЛП(ВыпискаДокумент.ДокументОснование.Номер) + " от "
			+ Формат(ВыпискаДокумент.ДокументОснование.Дата,"ДЛФ=D"));
		стПараметры.Поручение = "Поручение " + стПараметры.Поручение;
		стПараметры.Вставить("ДопИнформация", СокрЛП(ВыпискаДокумент.ДокументОснование.Комментарий));
		стПараметры.Вставить("РегНомерПоручения", СокрЛП(ВыпискаДокумент.ДокументОснование.ВходящийНомерПоручения));
		стПараметры.Вставить("Операция", "№ " + СокрЛП(ВыпискаДокумент.Номер) + " от "+Формат(ВыпискаДокумент.Дата,"ДЛФ=D"));
	КонецЕсли;
	
	Период = ?(ЗначениеЗаполнено(ВыпискаДокумент), ВыпискаДокумент.Дата, КонПериода);
	
	ФормированиеПечатныхФорм.СформироватьДатуВремяДДММГГЧЧММ(стПараметры, "", Период);
	
	Если СчетДепо.ВидСчетаДепо = Перечисления.ВидыСчетовДепо.СчетДЕПО Тогда
		стПараметры.Вставить("РеквизитыПриказа", РегистрыСведений.РеквизитыПриказовПриложенийКРДО.Реквизиты(Период));
	КонецЕсли;
	
	Возврат стПараметры;
	
КонецФункции

Функция ПолучитьАктивныеОтборы()
	
	стВозврата = Новый Структура();
	ЭлементыОтбора = КомпоновщикНастроек.Настройки.Отбор.Элементы;
	
	Для Каждого эл Из ЭлементыОтбора Цикл
		Если эл.Использование и ЗначениеЗаполнено(эл.ПравоеЗначение) Тогда
			стВозврата.Вставить(эл.ЛевоеЗначение, эл.ПравоеЗначение);
		КонецЕсли;
	КонецЦикла;
	
	Возврат стВозврата;
	
КонецФункции

Функция ПолучитьИмяМакета(Контрагент, ДатаОснования)
	
	ЗначениеПоУмолчанию = ДАТА(1, 1, 1);
	ДатаПереходаНаПечатнуюФорму2026 =
		РегистрыСведений.ПараметрыГлобальные.ЗначениеПараметра("3490.ДатаПереходаНаПечатныеФормыВыписок2026",
			ЗначениеПоУмолчанию);
	
	Если ДатаОснования >= ДатаПереходаНаПечатнуюФорму2026 Тогда
		ИмяМакета = "Макет2026";
	Иначе
		ИмяМакета = "Макет2017";
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Контрагент) И Контрагент.ОтчетыНаАнглийскомЯзыке Тогда
		ИмяМакета = ИмяМакета + "en";
	КонецЕсли;
	
	Возврат ИмяМакета;
	
КонецФункции

Процедура ПоместитьОтчетыВЭдо() Экспорт // BSLLS:Typo-off
	
	ТипДокумента = "DepoAccountOperations";
	
	ФормированиеОтчетовОСовершенныхОперациях = Обработки.ФормированиеОтчетовОСовершенныхОперациях.Создать();
	ФормированиеОтчетовОСовершенныхОперациях.ПоместитьОтчетыВKafka(ТипДокумента, ДокументыКЭДО, ВыводитьФаксимилеВОтчетах);
	
	Для Каждого СтрокаРезультата Из ДокументыКЭДО Цикл
		Если ЗначениеЗаполнено(СтрокаРезультата.ТекстОшибки) Тогда
			ШаблонОшибки = "Отчет [%1] по счету депо [%2] не отправлен в ЭДО по причине: %3";
			ТекстОшибки = СтрШаблон(ШаблонОшибки, ТипДокумента, СокрЛП(СтрокаРезультата.СчетДепо), СтрокаРезультата.ТекстОшибки);
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстОшибки);
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

