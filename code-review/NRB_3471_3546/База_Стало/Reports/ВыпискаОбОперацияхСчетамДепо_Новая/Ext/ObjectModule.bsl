Перем ТаблицаЗначенийОстаткиНаКонец, ТаблицаЗначенийОперации;
Перем мТекстыЗаголовков;

// ВЫБОРКА
Процедура ЗаполнитьПараметрыЗапросаПоОтборуСКД(Запрос)
	
	СравнениеКлиент		= "(СчетДепо.Владелец ВидСравнения (&Клиент)	ИЛИ &НеПроверятьКлиента)";
	СравнениеСчетДепо	= "(СчетДепо ВидСравнения (&СчетДепо)			ИЛИ &НеПроверятьСчетаДепо)";
	СравнениеЭмитент	= "(ЦБ.Эмитент ВидСравнения (&Эмитент)			ИЛИ &НеПроверятьЭмитента)";
	СравнениеЦБ			= "(ЦБ ВидСравнения (&ЦБ)						ИЛИ &НеПроверятьЦБ)";
	
	СписокКлиентов		= Новый СписокЗначений;
	СписокСчетовДепо	= Новый СписокЗначений;
	СписокЭмитентов		= Новый СписокЗначений;
	СписокЦБ			= Новый СписокЗначений;
	
	// заполним структуру параметров на основании данных отбора
	ЭлементыОтбора = ЭтотОбъект.КомпоновщикНастроек.Настройки.Отбор.Элементы;
	
	Если ЭлементыОтбора.Количество() = 0 Тогда
		НовыйЭлемент = ЭлементыОтбора.Вставить(0, Тип("ЭлементОтбораКомпоновкиДанных"));
		НовыйЭлемент.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("Клиенты");
		НовыйЭлемент.Использование = Ложь;
		
		НовыйЭлемент = ЭлементыОтбора.Вставить(1, Тип("ЭлементОтбораКомпоновкиДанных"));
		НовыйЭлемент.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("СчетаДепо");
		НовыйЭлемент.Использование = Ложь;
		
		НовыйЭлемент = ЭлементыОтбора.Вставить(2, Тип("ЭлементОтбораКомпоновкиДанных"));
		НовыйЭлемент.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("ЦенныеБумаги");
		НовыйЭлемент.Использование = Ложь;
		
		НовыйЭлемент = ЭлементыОтбора.Вставить(3, Тип("ЭлементОтбораКомпоновкиДанных"));
		НовыйЭлемент.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("Эмитенты");
		НовыйЭлемент.Использование = Ложь;
	КонецЕсли;
	
	Для Каждого эл Из ЭлементыОтбора Цикл
		ЛевоеЗначение = СокрЛП(эл.ЛевоеЗначение);
		Если эл.Использование Тогда
			// Определим маску вида сравнения для запроса
			Если	эл.ВидСравнения = ВидСравненияКомпоновкиДанных.Равно
				ИЛИ эл.ВидСравнения = ВидСравненияКомпоновкиДанных.ВИерархии
				ИЛИ эл.ВидСравнения = ВидСравненияКомпоновкиДанных.ВСписке
				ИЛИ эл.ВидСравнения = ВидСравненияКомпоновкиДанных.ВСпискеПоИерархии Тогда
				МаскаУсловия = "В";
			ИначеЕсли эл.ВидСравнения = ВидСравненияКомпоновкиДанных.НеРавно
				ИЛИ эл.ВидСравнения = ВидСравненияКомпоновкиДанных.НеВИерархии
				ИЛИ эл.ВидСравнения = ВидСравненияКомпоновкиДанных.НеВСписке
				ИЛИ эл.ВидСравнения = ВидСравненияКомпоновкиДанных.НеВСпискеПоИерархии Тогда
				МаскаУсловия = "НЕ В";
			ИначеЕсли эл.ВидСравнения = ВидСравненияКомпоновкиДанных.Заполнено Тогда
				МаскаУсловия = "НЕ ЕСТЬ NULL";
			ИначеЕсли эл.ВидСравнения = ВидСравненияКомпоновкиДанных.НеЗаполнено Тогда
				МаскаУсловия = "ЕСТЬ NULL";
			КонецЕсли;
			
			Если ЛевоеЗначение = "Клиенты" Тогда
				СравнениеКлиент = УсловиеСравнения(СравнениеКлиент, Запрос, МаскаУсловия, эл, "СчетДепо.Владелец",
					Справочники.Контрагенты.ПустаяСсылка(), "НеПроверятьКлиента", "Клиент");
			ИначеЕсли ЛевоеЗначение = "СчетаДепо" Тогда
				СравнениеСчетДепо = УсловиеСравнения(СравнениеСчетДепо, Запрос, МаскаУсловия, эл, "СчетДепо",
					Справочники.СчетаДепо.ПустаяСсылка(), "НеПроверятьСчетаДепо", "СчетДепо");
			ИначеЕсли ЛевоеЗначение = "ЦенныеБумаги" Тогда
				СравнениеЦБ = УсловиеСравнения(СравнениеЦБ, Запрос, МаскаУсловия, эл, "ЦБ",
					Справочники.ЦенныеБумаги.ПустаяСсылка(), "НеПроверятьЦБ", "ЦБ");
			ИначеЕсли ЛевоеЗначение = "Эмитенты" Тогда
				СравнениеЭмитент = УсловиеСравнения(СравнениеЭмитент, Запрос, МаскаУсловия, эл, "ЦБ.Эмитент",
					Справочники.Контрагенты.ПустаяСсылка(), "НеПроверятьЭмитента", "Эмитент");
			КонецЕсли;
		Иначе
			Если ЛевоеЗначение = "Клиенты" Тогда
				СравнениеКлиент	= СтрЗаменить(СравнениеКлиент, "ВидСравнения", "В");
				Запрос.УстановитьПараметр("Клиент",				СписокКлиентов);
				Запрос.УстановитьПараметр("НеПроверятьКлиента",	Истина);
			ИначеЕсли ЛевоеЗначение = "СчетаДепо" Тогда
				СравнениеСчетДепо	= СтрЗаменить(СравнениеСчетДепо, "ВидСравнения", "В");
				Запрос.УстановитьПараметр("СчетДепо",				СписокСчетовДепо);
				Запрос.УстановитьПараметр("НеПроверятьСчетаДепо",	Истина);
			ИначеЕсли ЛевоеЗначение = "ЦенныеБумаги" Тогда
				СравнениеЦБ	= СтрЗаменить(СравнениеЦБ, "ВидСравнения", "В");
				Запрос.УстановитьПараметр("ЦБ",				СписокЦБ);
				Запрос.УстановитьПараметр("НеПроверятьЦБ",	Истина);
			ИначеЕсли ЛевоеЗначение = "Эмитенты" Тогда
				СравнениеЭмитент	= СтрЗаменить(СравнениеЭмитент, "ВидСравнения", "В");
				Запрос.УстановитьПараметр("Эмитент",				СписокЭмитентов);
				Запрос.УстановитьПараметр("НеПроверятьЭмитента",	Истина);
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
	УсловияОтбора = СравнениеКлиент + Символы.ПС
		+ " И " + СравнениеСчетДепо + Символы.ПС
		+ " И " + СравнениеЦБ + Символы.ПС
		+ " И " + СравнениеЭмитент + Символы.ПС
		+ " И (СчетДепоМХ.Владелец = &МХ		ИЛИ &НеПроверятьМХ)";
	
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УСЛОВИЯОТБОРА", УсловияОтбора);
	
КонецПроцедуры

Функция УсловиеСравнения(ТекстСравнения, Запрос, МаскаУсловия, эл, ИмяПоля, ПустаяСсылка, НеПроверятьПоле, ИмяПараметра)
	
	Если МаскаУсловия = "НЕ ЕСТЬ NULL" Тогда
		ТекстСравнения	= "(НЕ %ИмяПоля ЕСТЬ NULL
			| ИЛИ НЕ %ИмяПоля = НЕОПРЕДЕЛЕНО
			| ИЛИ НЕ %ИмяПоля = &%ПустаяСсылка
			| ИЛИ &%НеПроверятьПоле)";
		ТекстСравнения = СтрЗаменить(ТекстСравнения, "%ИмяПоля", ИмяПоля);
		ТекстСравнения = СтрЗаменить(ТекстСравнения, "%ПустаяСсылка", ИмяПараметра + "ПустаяСсылка");
		Запрос.УстановитьПараметр(ИмяПараметра+"ПустаяСсылка", ПустаяСсылка);
		ТекстСравнения = СтрЗаменить(ТекстСравнения, "%НеПроверятьПоле", НеПроверятьПоле);
	ИначеЕсли  МаскаУсловия = "ЕСТЬ NULL" Тогда
		ТекстСравнения	= "(%ИмяПоля ЕСТЬ NULL
			| ИЛИ %ИмяПоля = НЕОПРЕДЕЛЕНО
			| ИЛИ %ИмяПоля = &%ПустаяСсылка
			| ИЛИ &%НеПроверятьПоле)";
		ТекстСравнения = СтрЗаменить(ТекстСравнения, "%ИмяПоля", ИмяПоля);
		ТекстСравнения = СтрЗаменить(ТекстСравнения, "%ПустаяСсылка", ИмяПараметра + "ПустаяСсылка");
		Запрос.УстановитьПараметр(ИмяПараметра+"ПустаяСсылка", ПустаяСсылка);
		ТекстСравнения = СтрЗаменить(ТекстСравнения, "%НеПроверятьПоле", НеПроверятьПоле);
	Иначе
		ТекстСравнения = СтрЗаменить(ТекстСравнения, "ВидСравнения", МаскаУсловия);
	КонецЕсли;
	Запрос.УстановитьПараметр(ИмяПараметра, эл.ПравоеЗначение);
	Запрос.УстановитьПараметр(НеПроверятьПоле, Ложь);
	Возврат ТекстСравнения;
	
КонецФункции

Функция ВыборкаОперацийПоСчетамДепо() Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("НачПериода", НачалоДня(НачПериода));
	Запрос.УстановитьПараметр("КонПериода", КонецДня(КонПериода));
	Запрос.УстановитьПараметр("КонПериодаГраница", Новый Граница(КонецДня(КонПериода), ВидГраницы.Включая));
	Запрос.УстановитьПараметр("МХ", ?(МХПоУмолчанию, Константы.МестоХраненияПоУмолчанию.Получить(), МХОтбор));
	Запрос.УстановитьПараметр("НеПроверятьМХ", МХОтбор.Пустая() И Не МХПоУмолчанию);
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ОстаткиИОборотыЦБ.СчетДепо.Владелец КАК Клиент,
	|	ОстаткиИОборотыЦБ.СчетДепо КАК СчетДепо,
	|	ОстаткиИОборотыЦБ.СчетДепо.ВидСчетаДепо КАК ВидСчетаДепо,
	|	ОстаткиИОборотыЦБ.ЦБ КАК ЦБ,
	|	ОстаткиИОборотыЦБ.РазделСчетаДепо КАК РазделСчетаДепо,
	|	ОстаткиИОборотыЦБ.РазделСчетаДепоМХ КАК РазделСчета,
	|	ОстаткиИОборотыЦБ.СтатусЦБ КАК СтатусЦБ,
	|	ОстаткиИОборотыЦБ.СчетДепоМХ.Владелец КАК МХ,
	|	ОстаткиИОборотыЦБ.Регистратор КАК Регистратор,
	|	ОстаткиИОборотыЦБ.Регистратор.Дата КАК ДатаОперации,
	|	ОстаткиИОборотыЦБ.Регистратор.Номер КАК НомерПроводки,
	|	ОстаткиИОборотыЦБ.Регистратор.Основание КАК Основание,
	|	ВЫБОР
	|		КОГДА ОстаткиИОборотыЦБ.Регистратор ССЫЛКА Документ.ОперацииЦБ
	|			ТОГДА ОстаткиИОборотыЦБ.Регистратор.ВидОперацииД
	|		КОГДА ОстаткиИОборотыЦБ.Регистратор ССЫЛКА Документ.ЦБВПути
	|			ТОГДА ОстаткиИОборотыЦБ.Регистратор.ВидОперацииД
	|		КОГДА ОстаткиИОборотыЦБ.Регистратор ССЫЛКА Документ.КонвертацияЦБ
	|			ТОГДА ЗНАЧЕНИЕ(Справочник.ВидыОпераций.Конвертация)
	|		КОГДА ОстаткиИОборотыЦБ.Регистратор ССЫЛКА Документ.ПогашениеЦБ
	|			ТОГДА ЗНАЧЕНИЕ(Справочник.ВидыОпераций.Погашение)
	|		КОГДА ОстаткиИОборотыЦБ.Регистратор ССЫЛКА Документ.ГлобальнаяОперация
	|			ТОГДА ОстаткиИОборотыЦБ.Регистратор.ВидГлобальнойОперации
	|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.ВидыОпераций.ПустаяСсылка)
	|	КОНЕЦ КАК ВидОперации,
	|	ЕСТЬNULL(ОстаткиИОборотыЦБ.КоличествоНачальныйОстаток, 0) КАК КоличествоНачальныйОстаток,
	|	ЕСТЬNULL(ОстаткиИОборотыЦБ.КоличествоКонечныйОстаток, 0) КАК КоличествоКонечныйОстаток,
	|	ЕСТЬNULL(ОстаткиИОборотыЦБ.КоличествоПриход, 0) КАК КоличествоПриход,
	|	ЕСТЬNULL(ОстаткиИОборотыЦБ.КоличествоРасход, 0) КАК КоличествоРасход,
	|	ЕСТЬNULL(НачЦБВПути.КоличествоОстаток, 0) КАК НачКоличествоВПути,
	|	ЕСТЬNULL(КонЦБВПути.КоличествоОстаток, 0) КАК КонКоличествоВПути
	|ИЗ
	|	РегистрНакопления.ОстаткиЦБ.ОстаткиИОбороты(&НачПериода, &КонПериода, Регистратор, ДвиженияИГраницыПериода, &УСЛОВИЯОТБОРА) КАК ОстаткиИОборотыЦБ
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ЦБВПути.Остатки(&НачПериода, &УСЛОВИЯОТБОРА) КАК НачЦБВПути
	|		ПО ОстаткиИОборотыЦБ.СчетДепоМХ.Владелец = НачЦБВПути.СчетДепоМХ.Владелец
	|			И ОстаткиИОборотыЦБ.ЦБ = НачЦБВПути.ЦБ
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ЦБВПути.Остатки(&КонПериодаГраница, &УСЛОВИЯОТБОРА) КАК КонЦБВПути
	|		ПО ОстаткиИОборотыЦБ.ЦБ = КонЦБВПути.ЦБ
	|			И ОстаткиИОборотыЦБ.СчетДепоМХ.Владелец = КонЦБВПути.СчетДепоМХ.Владелец
	|
	|УПОРЯДОЧИТЬ ПО
	|	ДатаОперации,
	|	НомерПроводки
	|ИТОГИ
	|	СУММА(КоличествоНачальныйОстаток),
	|	СУММА(КоличествоКонечныйОстаток),
	|	СУММА(КоличествоПриход),
	|	СУММА(КоличествоРасход),
	|	МАКСИМУМ(НачКоличествоВПути),
	|	МАКСИМУМ(КонКоличествоВПути)
	|ПО
	|	Клиент,
	|	СчетДепо,
	|	ЦБ,
	|	РазделСчетаДепо,
	|	РазделСчета,
	|	СтатусЦБ";
	ЗаполнитьПараметрыЗапросаПоОтборуСКД(Запрос);
	Результат = Запрос.Выполнить();
	Возврат Результат;
	
КонецФункции

Процедура СформироватьОтчет(Результат) Экспорт
	
	Результат.Очистить();
	ДокументыКЭДО.Очистить();
	
	ТаблицаОтчетов = ПолучитьПечатныеФормы();
	
	Если ТаблицаОтчетов = Неопределено Тогда
		ОбщегоНазначения.СообщитьОбОшибке("Данные для формирования отчета не обнаружены.");
		Возврат;
	КонецЕсли;
	
	Результат.РазмерСтраницы		= "A4";
	Результат.ОриентацияСтраницы	= ОриентацияСтраницы.Ландшафт;
	Результат.АвтоМасштаб			= Истина;
	
	// Обработаем полученные выписки, так же если стоит выгрузка в документооборот, то поместим выписки туда
	Для Каждого Строка Из ТаблицаОтчетов Цикл
		
		Если Справочники.Контрагенты.ОсобыеУсловия(Строка.Клиент) Тогда
			Если Не РегистрыСведений.ОтветственныеЛицаОрганизаций.ПользовательМожетРедактироватьОсобыеУсловия() Тогда
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Особые условия: " + Строка.Клиент
					+ ". Выполнение операции доступно Ответственному за особых клиентов");
				Продолжить;
			КонецЕсли;
		КонецЕсли;
		
		Результат.Вывести(Строка.ТабличныйДокумент);
		Результат.ВывестиГоризонтальныйРазделительСтраниц();
		// Помещаем отчет в Таблицу для ЭДО
		Если Документооборот Тогда
			
			// Проверим, что выписка еще не была выгружена в ЭДО
			Если ЗначениеЗаполнено(Строка.Основание)
				И Документы.СводныйОтчетОСовершенныхОперациях.БылОтправленВЭДО(Строка.Основание) Тогда
				Сообщение = Новый СообщениеПользователю();
				Сообщение.Текст = "Документ уже был помещен в ЭДО ранее: " + Строка.Основание;
				Сообщение.Сообщить();
				Продолжить;
			КонецЕсли;
			
			// Поместим таблицу для клиент серверной передачи
			АдресТаблицы  = ПоместитьВоВременноеХранилище(Строка.ТабличныйДокумент);
			
			НовыйДляЭДО	= ДокументыКЭДО.Добавить();
			
			НовыйДляЭДО.Клиент				= Строка.Клиент;
			НовыйДляЭДО.СчетДепо			= Строка.СчетДепо;
			НовыйДляЭДО.Документ			= Строка.Основание;
			НовыйДляЭДО.Основание			= Строка.Основание;
			НовыйДляЭДО.АдресТаблицы		= АдресТаблицы;
			НовыйДляЭДО.ActionType			= "INS";
		КонецЕсли;
	КонецЦикла;
	
	// Обработаем полученные выписки и поместим выписки в ЭДО если установлен соответствующий флаг
	Если Документооборот Тогда
		ПоместитьОтчетыВЭдо();
	КонецЕсли;
	
КонецПроцедуры

