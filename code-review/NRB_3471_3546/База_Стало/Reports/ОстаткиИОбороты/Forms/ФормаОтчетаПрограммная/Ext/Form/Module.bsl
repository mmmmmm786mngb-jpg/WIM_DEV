	ПолеГруппировки = Отчет.Группировка.Добавить();
	ПолеГруппировки.Использование = Истина;
	ПолеГруппировки.Поле = "ЦБ";
	ПолеГруппировки.Представление = "Ценная бумага";
	ПолеГруппировки.ТипГруппировки = 0;

	ПолеГруппировки = Отчет.Группировка.Добавить();
	ПолеГруппировки.Использование = Истина;
	ПолеГруппировки.Поле = "СчетДепоМХ";
	ПолеГруппировки.Представление = "Счет депо МХ";
	ПолеГруппировки.ТипГруппировки = 0;
	
	ПолеГруппировки = Отчет.Группировка.Добавить();
	ПолеГруппировки.Использование = Истина;
	ПолеГруппировки.Поле = "РазделСчетаДепоМХ";
	ПолеГруппировки.Представление = "Раздел счета депо МХ";
	ПолеГруппировки.ТипГруппировки = 0;
	
	ПолеГруппировки = Отчет.Группировка.Добавить();
	ПолеГруппировки.Использование = Истина;
	ПолеГруппировки.Поле = "СчетДепо";
	ПолеГруппировки.Представление = "Счет депо";
	ПолеГруппировки.ТипГруппировки = 0;
	
	ПолеГруппировки = Отчет.Группировка.Добавить();
	ПолеГруппировки.Использование = Истина;
	ПолеГруппировки.Поле = "РазделСчетаДепо";
