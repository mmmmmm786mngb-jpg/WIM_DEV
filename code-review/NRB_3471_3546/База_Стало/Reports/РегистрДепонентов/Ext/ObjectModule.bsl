// ВСПОМОГАТЕЛЬНЫЕ ФУНКЦИИ

Функция МассивПодстрок(Источник, Разделитель = ",")
	// Удаляем пробельные символы
	Стр = СтрЗаменить(Источник, " ", "");
	Стр = СтрЗаменить(Стр, Символы.ПС, "");
	Стр = СтрЗаменить(Стр, Символы.Таб, "");
	Возврат СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(Стр, Разделитель);	
КонецФункции

Функция СтрокаИзДаты(Дата) Экспорт
	Если ЗначениеЗаполнено(Дата) Тогда
		Возврат Формат(Дата, "ДФ=dd.MM.yyyy");
	Иначе
		Возврат "";
	КонецЕсли;
КонецФункции

Функция БанковскиеРеквизиты(НомерСчета, Банк, БанкНаименование, БанкКоррСчет, БанкБИК, БанкSWIFT)
	СтрокаРезультат = "Р/с " + СокрЛП(НомерСчета);
	
	Если ЗначениеЗаполнено(Банк) Тогда
		СтрокаРезультат = СтрокаРезультат + " в " + СокрЛП(БанкНаименование);
		
		Если ЗначениеЗаполнено(БанкКоррСчет) Тогда
			СтрокаРезультат = СтрокаРезультат + ", к/с " + СокрЛП(БанкКоррСчет);
		КонецЕсли;
		Если ЗначениеЗаполнено(БанкБИК) Тогда
			СтрокаРезультат = СтрокаРезультат + ", БИК " + СокрЛП(БанкБИК);
		КонецЕсли;
		Если ЗначениеЗаполнено(БанкSWIFT) Тогда
			СтрокаРезультат = СтрокаРезультат + ", SWIFT " + СокрЛП(БанкSWIFT);
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат СтрокаРезультат;
КонецФункции

Функция ПредставлениеГражданстваФизлица(ФизЛицо, Гражданство, Дата)
	СтрокаРезультат = "";
	
	Если ЗначениеЗаполнено(Гражданство) Тогда
		СтрокаРезультат = СокрЛП(Гражданство);
	Иначе
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "Для физ.лица " + СокрЛП(ФизЛицо) + " на " + Формат(Дата, "ДЛФ=Д")
			+ " не указано гражданство!";
		Сообщение.Сообщить();
	КонецЕсли;
	
	Возврат СтрокаРезультат;
КонецФункции

Функция ПредставлениеДокументаФизлица(ФизЛицо, Документ, Дата)
	СтрокаРезультат = "";
	
	// Документ физ.лица. Серия документа и номер подразделения не обязательны.
	Если ЗначениеЗаполнено(Документ.ДокументВид) Тогда
		СтрокаРезультат = ?(Документ.ДокументВид = Справочники.ДокументыУдостоверяющиеЛичность.ИМНС21, "Паспорт РФ",
			СокрЛП(Документ.ДокументВид))
		+ ?(ЗначениеЗаполнено(Документ.ДокументСерия), " серия " + Документ.ДокументСерия, "")
		+ " № " + Документ.ДокументНомер
		+ ", выдан " + Формат(Документ.ДокументДатаВыдачи, "ДФ='дд ММММ гггг';ДП='...'") + " г. " 
		+ Документ.ДокументКемВыдан
		+ ?(ЗначениеЗаполнено(Документ.ДокументКодПодразделения), ", № подр. " + Документ.ДокументКодПодразделения, "");
	Иначе
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "Для физ.лица " + СокрЛП(ФизЛицо) + " на " + Формат(Дата, "ДЛФ=Д")
			+ " не указан вид документа!";
		Сообщение.Сообщить();
	КонецЕсли;
	
	Возврат СтрокаРезультат;
КонецФункции

Функция ОГРН(ОГРН, ДатаГосРегистрации, Резидент)
	СтрокаРезультат = "";	
	Если ЗначениеЗаполнено(ОГРН) Тогда
		СтрокаРезультат = ?(Резидент, "ОГРН ", "") + СокрЛП(ОГРН);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ДатаГосРегистрации) Тогда
		СтрокаРезультат = ?(ЗначениеЗаполнено(СтрокаРезультат), СтрокаРезультат + " ", "")
			+ "Дата регистрации " + СтрокаИзДаты(ДатаГосРегистрации);
	КонецЕсли;
	
	Возврат СтрокаРезультат;
КонецФункции

