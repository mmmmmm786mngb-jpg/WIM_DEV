Перем мРубль, мСчетДляВыплатыДоходов, мРасчетныйБанк;
Перем КэшТаблицаВалют, КэшБрокерскиеСчета, КэшСчетаДляВыплатыДоходов, КэшРасчетныеКодыДляВыплатыДохода;

Процедура СформироватьОтчет(Таблица, СписокДепонентов) Экспорт
	ЗаполнитьТабличнуюЧастьДепоненты(СписокДепонентов);
	
	Макет = ПолучитьМакет("РегистрДепонентов");
	ОбластьШапка	= Макет.ПолучитьОбласть("Шапка");
	ОбластьСтрока	= Макет.ПолучитьОбласть("Строка");

	ОбластьШапка.Параметры.НазваниеОтчета = "Регистр депонентов за период с " + Формат(НачалоПериода, "ДЛФ=Д")
		+ " по " + Формат(КонецПериода, "ДЛФ=Д");
	РеквизитыОтчета = ЭтотОбъект.Метаданные().ТабличныеЧасти.Депоненты.Реквизиты;
	ВыбранныеПоля = МассивПодстрок("НомерДепонента,ДатаИзменения,КраткоеНаименование,
		|Наименование,Документ,Гражданство,ИНН,ЮридическийАдрес,ФактическийАдрес,
		|ДатаМестоРождения,Телефон,Email,Резидент,НомерДоговора,ДатаЗаключенияДоговора,ДатаРасторженияДоговора,
		|ПравоГолосаПоДоговоруДУ,ПредставительЮрлица,ДокументПредставителяЮрлица,Комментарий", ",");
	
	Для Каждого Реквизит Из РеквизитыОтчета Цикл
		Поле = ВыбранныеПоля.Найти(Реквизит.Имя);
		Если Поле <> Неопределено Тогда
			ОбластьШапка.Параметры[Реквизит.Имя] = Реквизит.Синоним;
		КонецЕсли;
	КонецЦикла;
	Таблица.Вывести(ОбластьШапка);
	
	Для Каждого Строка Из Депоненты Цикл
		ОбластьСтрока.Параметры.Заполнить(Строка);
		Таблица.Вывести(ОбластьСтрока);
	КонецЦикла;
КонецПроцедуры

Процедура ЗаполнитьТабличнуюЧастьДепоненты(СписокДепонентов)
	ТаблицыДанных		= ДепонентыСубклиентыКомментарии(СписокДепонентов);
	ВыборкаДепонентов	= ТаблицыДанных.ВыборкаДепонентов;
	КомментарииИзмененийАнкетныхДанных = ТаблицыДанных.КомментарииИзмененийАнкетныхДанных;
	
	Депоненты.Очистить();
	НомерСтроки = 1;
	
	ВыборкаДепонентов.Сбросить();
	Пока ВыборкаДепонентов.Следующий() Цикл
		ОтборПоДепоненту = Новый Структура("Депонент", ВыборкаДепонентов.Депонент);
		
		НоваяСтрока = Депоненты.Добавить();
		НоваяСтрока.НомерДепонента = НомерСтроки;
		НоваяСтрока.ДатаИзменения = ВыборкаДепонентов.ДатаСрезаПервойЗаписиДепонента;
		ЗаполнитьОсновныеРеквизитыДепонента(НоваяСтрока, ВыборкаДепонентов);
		ДобавитьСтрокиСубклиентов(ОтборПоДепоненту, ТаблицыДанных.ТаблицаСубклиентов,
			ВыборкаДепонентов.ДатаСрезаПервойЗаписиДепонента);
		ДобавитьСтрокиБанковскихСчетов(ВыборкаДепонентов.Депонент);
		ДобавитьСтрокиПредставителей(ВыборкаДепонентов.Депонент, ВыборкаДепонентов.ДатаСрезаПервойЗаписиДепонента);
		ДобавитьСтрокиДоверенныхЛиц(ВыборкаДепонентов.Депонент, ВыборкаДепонентов.ДатаСрезаПервойЗаписиДепонента);
		
		Комментарии = КомментарииИзмененийАнкетныхДанных.НайтиСтроки(ОтборПоДепоненту);
		Для Каждого Комментарий Из Комментарии Цикл
			НоваяСтрока = Депоненты.Добавить();
			НоваяСтрока.ДатаИзменения = Комментарий.Дата;
			НоваяСтрока.Комментарий = Комментарий.Комментарий;
			ЗаполнитьОсновныеРеквизитыДепонента(НоваяСтрока, ВыборкаДепонентов);
			ДобавитьСтрокиСубклиентов(ОтборПоДепоненту, ТаблицыДанных.ТаблицаСубклиентов, Комментарий.Дата);
			ДобавитьСтрокиБанковскихСчетов(ВыборкаДепонентов.Депонент);
			ДобавитьСтрокиПредставителей(ВыборкаДепонентов.Депонент, Комментарий.Дата);
			ДобавитьСтрокиДоверенныхЛиц(ВыборкаДепонентов.Депонент, Комментарий.Дата);
		КонецЦикла;
		НомерСтроки = НомерСтроки + 1;
	КонецЦикла;
КонецПроцедуры

Функция ДепонентыСубклиентыКомментарии(СписокДепонентов)
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("НачалоПериода",			НачалоПериода);
	Запрос.УстановитьПараметр("КонецПериода",			КонецПериода);
	Запрос.УстановитьПараметр("СписокДепонентов",		СписокДепонентов);
	Запрос.УстановитьПараметр("СписокДепонентовПуст",	НЕ ЗначениеЗаполнено(СписокДепонентов));
	Запрос.УстановитьПараметр("ТипСчетаДУ",				Перечисления.ТипыСчетовДепо.ДоверительногоУправляющего);
	Запрос.УстановитьПараметр("ПризнакСчетДепонента",	Перечисления.ПризнакиСчетаДепо.СчетДепонента);
	Запрос.УстановитьПараметр("ТипДоговораДепозитарный", Перечисления.ТипыДоговоров.Депозитарный);
	
	СформироватьВТДепоненты(Запрос);
	СформироватьВТСубклиенты(Запрос);
	
	ТаблицыДанных = Новый Структура;
	ТаблицыДанных.Вставить("ТаблицаСубклиентов",	ТаблицаСубклиентов(Запрос));
	ТаблицыДанных.Вставить("ВыборкаДепонентов",		ВыборкаДепонентов(Запрос));
	ТаблицыДанных.Вставить("КомментарииИзмененийАнкетныхДанных", КомментарииИзмененийАнкетныхДанных(Запрос));
	Возврат ТаблицыДанных;
КонецФункции

Процедура СформироватьВТДепоненты(Запрос)
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Контрагенты.Ссылка КАК Депонент,
	|	Контрагенты.ЮридическиеФизическиеЛица КАК ЮридическиеФизическиеЛица,
	|	Контрагенты.ЮрФизЛицо КАК ЮрФизЛицо,
	|	Договоры.Код КАК НомерДоговора,
	|	Договоры.ДатаНачалоДействия КАК ДатаЗаключенияДоговора,
	|	Договоры.ДатаОкончанияДействия КАК ДатаРасторженияДоговора,
	|	ВЫБОР
	|		КОГДА Договоры.ДатаНачалоДействия > &НачалоПериода
	|			ТОГДА Договоры.ДатаНачалоДействия
	|		ИНАЧЕ &НачалоПериода
	|	КОНЕЦ КАК ДатаСрезаПервойЗаписиДепонента,
	|	МАКСИМУМ(ВЫБОР
	|				КОГДА СчетаДепо.ТипСчетаДепо = &ТипСчетаДУ
	|					ТОГДА ИСТИНА
	|				ИНАЧЕ ЛОЖЬ
	|			КОНЕЦ) КАК ПравоГолосаПоДоговоруДУ
	|ПОМЕСТИТЬ втДепоненты
	|ИЗ
	|	Справочник.Контрагенты КАК Контрагенты
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.СчетаДепо КАК СчетаДепо
	|		ПО Контрагенты.Ссылка = СчетаДепо.Владелец
	|			И (СчетаДепо.ДатаОткрытияСчета <= &КонецПериода)
	|			И (СчетаДепо.ДатаЗакрытияСчета = ДАТАВРЕМЯ(1, 1, 1)
	|				ИЛИ СчетаДепо.ДатаЗакрытияСчета > &НачалоПериода)
	|			И (СчетаДепо.ПризнакСчетаДепо = &ПризнакСчетДепонента)
	|			И (НЕ СчетаДепо.ПометкаУдаления)
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ДоговорыКонтрагентов КАК Договоры
	|		ПО Контрагенты.Ссылка = Договоры.Владелец
	|			И (Договоры.ТипДоговора = &ТипДоговораДепозитарный)
	|			И (Договоры.ДатаНачалоДействия <= &КонецПериода)
	|			И (Договоры.ДатаОкончанияДействия = ДАТАВРЕМЯ(1, 1, 1)
	|				ИЛИ Договоры.ДатаОкончанияДействия > &НачалоПериода)
	|			И (НЕ Договоры.ПометкаУдаления)
	|ГДЕ
	|	(Контрагенты.Ссылка В ИЕРАРХИИ (&СписокДепонентов)
	|			ИЛИ &СписокДепонентовПуст)
	|
	|СГРУППИРОВАТЬ ПО
	|	Контрагенты.Ссылка,
	|	Контрагенты.ЮрФизЛицо,
	|	Договоры.Ссылка,
	|	Контрагенты.ЮридическиеФизическиеЛица,
	|	Договоры.Код,
	|	Договоры.ДатаНачалоДействия,
	|	Договоры.ДатаОкончанияДействия,
	|	ВЫБОР
	|		КОГДА Договоры.ДатаНачалоДействия > &НачалоПериода
	|			ТОГДА Договоры.ДатаНачалоДействия
	|		ИНАЧЕ &НачалоПериода
	|	КОНЕЦ
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Депонент,
	|	ЮридическиеФизическиеЛица,
	|	ДатаСрезаПервойЗаписиДепонента
	|";
	Запрос.Выполнить();
КонецПроцедуры

Процедура СформироватьВТСубклиенты(Запрос)
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Субклиенты.Объект КАК Объект,
	|	Субклиенты.Клиент КАК Клиент,
	|	МАКСИМУМ(Контрагенты.Ссылка) КАК КонтрагентСубклиента
	|ПОМЕСТИТЬ втСубклиенты
	|ИЗ
	|	РегистрСведений.Субклиенты КАК Субклиенты
	|	ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Контрагенты КАК Контрагенты
	|	ПО
	|		Субклиенты.Клиент = Контрагенты.ЮридическиеФизическиеЛица
	|
	|СГРУППИРОВАТЬ ПО
	|	Субклиенты.Объект,
	|	Субклиенты.Клиент
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Объект,
	|	Клиент
	|";
	Запрос.Выполнить();
КонецПроцедуры

Функция ТаблицаСубклиентов(Запрос)
	Запрос.Текст =
	"ВЫБРАТЬ
	|	втДепоненты.Депонент КАК Депонент,
	|	втСубклиенты.Клиент КАК Субклиент,
	|	втСубклиенты.Клиент.ИНН КАК ИНН,
	|	ВЫБОР
	|		КОГДА втСубклиенты.Клиент ССЫЛКА Справочник.ЮридическиеЛица
	|			ТОГДА НЕ втСубклиенты.Клиент.НеРезидент
	|		КОГДА втСубклиенты.Клиент ССЫЛКА Справочник.ФизическиеЛица
	|			ТОГДА НЕ ЕСТЬNULL(втСубклиенты.КонтрагентСубклиента.Резидент, ЛОЖЬ)
	|	КОНЕЦ КАК Резидент,
	|	ВЫБОР
	|		КОГДА втСубклиенты.Клиент ССЫЛКА Справочник.ЮридическиеЛица
	|			ТОГДА втСубклиенты.Клиент.ПолноеНаименование
	|		КОГДА втСубклиенты.Клиент ССЫЛКА Справочник.ФизическиеЛица
	|			ТОГДА втСубклиенты.Клиент.Наименование
	|	КОНЕЦ КАК Наименование,
	|	ВЫБОР
	|		КОГДА втСубклиенты.Клиент ССЫЛКА Справочник.ЮридическиеЛица
	|			ТОГДА втСубклиенты.Клиент.ОГРН
	|		ИНАЧЕ """"
	|	КОНЕЦ КАК ОГРН,
	|	ВЫБОР
	|		КОГДА втСубклиенты.Клиент ССЫЛКА Справочник.ЮридическиеЛица
	|			ТОГДА втСубклиенты.Клиент.ДатаГосРегистрации
	|		ИНАЧЕ """"
	|	КОНЕЦ КАК ДатаГосРегистрации,
	|	ВЫБОР
	|		КОГДА втСубклиенты.Клиент ССЫЛКА Справочник.ФизическиеЛица
	|			ТОГДА втСубклиенты.Клиент.ДатаРождения
	|		ИНАЧЕ """"
	|	КОНЕЦ КАК ДатаРождения,
	|	ВЫБОР
	|		КОГДА втСубклиенты.Клиент ССЫЛКА Справочник.ФизическиеЛица
	|			ТОГДА втСубклиенты.Клиент.МестоРождения
	|		ИНАЧЕ """"
	|	КОНЕЦ КАК МестоРождения
	|
	|ИЗ
	|	втДепоненты КАК втДепоненты
	|	ВНУТРЕННЕЕ СОЕДИНЕНИЕ втСубклиенты КАК втСубклиенты
	|	ПО
	|		втДепоненты.Депонент = втСубклиенты.Объект
	|";
	Субклиенты = Запрос.Выполнить().Выгрузить();
	Субклиенты.Индексы.Добавить("Депонент");
	Возврат Субклиенты;
КонецФункции

Функция ВыборкаДепонентов(Запрос)
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	втДепоненты.Депонент КАК Депонент,
	|	втДепоненты.НомерДоговора КАК НомерДоговора,
	|	втДепоненты.ДатаЗаключенияДоговора КАК ДатаЗаключенияДоговора,
	|	втДепоненты.ДатаРасторженияДоговора КАК ДатаРасторженияДоговора,
	|	втДепоненты.ПравоГолосаПоДоговоруДУ КАК ПравоГолосаПоДоговоруДУ,
	|	НЕ втДепоненты.Депонент.Резидент КАК Резидент,	// На самом деле поле Резидент спр. Контрагенты имеет смысл <Не резидент>
	|	втДепоненты.ЮридическиеФизическиеЛица КАК ЮридическиеФизическиеЛица,
	|	втДепоненты.ЮридическиеФизическиеЛица.ИНН КАК ИНН,
	|	ВЫБОР
	|		КОГДА втДепоненты.ЮридическиеФизическиеЛица ССЫЛКА Справочник.ЮридическиеЛица
	|			ТОГДА втДепоненты.ЮридическиеФизическиеЛица.ПолноеНаименование
	|		КОГДА втДепоненты.ЮридическиеФизическиеЛица ССЫЛКА Справочник.ФизическиеЛица
	|			ТОГДА втДепоненты.ЮридическиеФизическиеЛица.Наименование
	|	КОНЕЦ КАК Наименование,
	|	втДепоненты.ЮридическиеФизическиеЛица.Наименование КАК КраткоеНаименование,
	|	ВЫБОР
	|		КОГДА втДепоненты.ЮридическиеФизическиеЛица ССЫЛКА Справочник.ЮридическиеЛица
	|			ТОГДА втДепоненты.ЮридическиеФизическиеЛица.ОГРН
	|		ИНАЧЕ """"
	|	КОНЕЦ КАК ОГРН,
	|	ВЫБОР
	|		КОГДА втДепоненты.ЮридическиеФизическиеЛица ССЫЛКА Справочник.ЮридическиеЛица
	|			ТОГДА втДепоненты.ЮридическиеФизическиеЛица.ДатаГосРегистрации
	|		ИНАЧЕ """"
	|	КОНЕЦ КАК ДатаГосРегистрации,
	|	ВЫБОР
	|		КОГДА втДепоненты.ЮридическиеФизическиеЛица ССЫЛКА Справочник.ФизическиеЛица
	|			ТОГДА втДепоненты.ЮридическиеФизическиеЛица.ДатаРождения
	|		ИНАЧЕ """"
	|	КОНЕЦ КАК ДатаРождения,
	|	ВЫБОР
	|		КОГДА втДепоненты.ЮридическиеФизическиеЛица ССЫЛКА Справочник.ФизическиеЛица
	|			ТОГДА втДепоненты.ЮридическиеФизическиеЛица.МестоРождения
	|		ИНАЧЕ """"
	|	КОНЕЦ КАК МестоРождения,
	|	втДепоненты.ДатаСрезаПервойЗаписиДепонента КАК ДатаСрезаПервойЗаписиДепонента
	|
	|ИЗ
	|	втДепоненты КАК втДепоненты
	|
	|УПОРЯДОЧИТЬ ПО
	|	втДепоненты.Депонент.ЮрФизЛицо,
	|	втДепоненты.Депонент.Наименование";
	Возврат Запрос.Выполнить().Выбрать();
КонецФункции

Функция КомментарииИзмененийАнкетныхДанных(Запрос)
	Запрос.Текст =
	"ВЫБРАТЬ
	|	втДепоненты.Депонент КАК Депонент,
	|	Поручение.Комментарий КАК Комментарий,
	|	Поручение.ДатаИсполненияПоручения КАК ДатаИсполненияПоручения
	|ПОМЕСТИТЬ втКомментарии
	|ИЗ
	|	втДепоненты КАК втДепоненты
	|	ЛЕВОЕ СОЕДИНЕНИЕ Документ.Поручение КАК Поручение
	|	ПО
	|		ВЫРАЗИТЬ(Поручение.СчетДепо КАК Справочник.СчетаДепо).Владелец = втДепоненты.Депонент
	|		И Поручение.Проведен
	|		И НАЧАЛОПЕРИОДА(Поручение.ДатаИсполненияПоручения, ДЕНЬ) > втДепоненты.ДатаСрезаПервойЗаписиДепонента
	|		И Поручение.ДатаИсполненияПоручения <= КОНЕЦПЕРИОДА(&КонецПериода, ДЕНЬ)
	|		И ВЫРАЗИТЬ(Поручение.ВидОперацииД КАК Справочник.ВидыОпераций) = &ИзменениеАнкетныхДанных
	|		И (ВЫРАЗИТЬ(Поручение.Комментарий КАК СТРОКА(100))) <> """"
	|;
	|
	|//////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	втКомментарии.Депонент КАК Депонент,
	|	МАКСИМУМ(втКомментарии.ДатаИсполненияПоручения) КАК Дата
	|ПОМЕСТИТЬ втПоследнееИсполненноеПоручениеЗаДень
	|ИЗ
	|	втКомментарии КАК втКомментарии
	|СГРУППИРОВАТЬ ПО
	|	втКомментарии.Депонент,
	|	НАЧАЛОПЕРИОДА(втКомментарии.ДатаИсполненияПоручения, ДЕНЬ)
	|;
	|
	|//////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	втКомментарии.Депонент КАК Депонент,
	|	втКомментарии.Комментарий КАК Комментарий,
	|	втКомментарии.ДатаИсполненияПоручения КАК Дата
	|ИЗ
	|	втКомментарии КАК втКомментарии
	|	ВНУТРЕННЕЕ СОЕДИНЕНИЕ втПоследнееИсполненноеПоручениеЗаДень КАК втПоследнееИсполненноеПоручениеЗаДень
	|	ПО
	|		втКомментарии.Депонент = втПоследнееИсполненноеПоручениеЗаДень.Депонент
	|		И втКомментарии.ДатаИсполненияПоручения = втПоследнееИсполненноеПоручениеЗаДень.Дата
	|
	|УПОРЯДОЧИТЬ ПО
	|	втКомментарии.Депонент,
	|	втКомментарии.ДатаИсполненияПоручения
	|";
	Запрос.УстановитьПараметр("ИзменениеАнкетныхДанных", Справочники.ВидыОпераций.ВидОперацииИзменениеАнкетныхДанных());
	Запрос.УстановитьПараметр("КонецПериода", КонецПериода);
	Комментарии = Запрос.Выполнить().Выгрузить();
	Комментарии.Индексы.Добавить("Депонент");
	Возврат Комментарии;
КонецФункции

Процедура ЗаполнитьОсновныеРеквизитыДепонента(НоваяСтрока, ВыборкаДепонентов)
	ЗаполнитьЗначенияСвойств(НоваяСтрока, ВыборкаДепонентов, "Депонент,Резидент,НомерДоговора");
	НоваяСтрока.ДатаЗаключенияДоговора	= СтрокаИзДаты(ВыборкаДепонентов.ДатаЗаключенияДоговора);
	НоваяСтрока.ДатаРасторженияДоговора	= СтрокаИзДаты(ВыборкаДепонентов.ДатаРасторженияДоговора);
	НоваяСтрока.ПравоГолосаПоДоговоруДУ	= ?(ВыборкаДепонентов.ПравоГолосаПоДоговоруДУ, "Да", "");
	
	Если ЗначениеЗаполнено(ВыборкаДепонентов.ЮридическиеФизическиеЛица) Тогда
		ЗаполнитьЗначенияСвойств(НоваяСтрока, ВыборкаДепонентов, "ИНН,Наименование");
		КИ = КонтактнаяИнформация(ВыборкаДепонентов.ЮридическиеФизическиеЛица, НоваяСтрока.ДатаИзменения);
		ЗаполнитьЗначенияСвойств(НоваяСтрока, КИ, "ФактическийАдрес,ЮридическийАдрес,Email,Телефон");
		
		Если ТипЗнч(ВыборкаДепонентов.ЮридическиеФизическиеЛица) = Тип("СправочникСсылка.ЮридическиеЛица") Тогда
			НоваяСтрока.КраткоеНаименование = ВыборкаДепонентов.КраткоеНаименование;
			НоваяСтрока.Документ = ОГРН(ВыборкаДепонентов.ОГРН, ВыборкаДепонентов.ДатаГосРегистрации,
				ВыборкаДепонентов.Резидент);
			
		ИначеЕсли ТипЗнч(ВыборкаДепонентов.ЮридическиеФизическиеЛица) = Тип("СправочникСсылка.ФизическиеЛица") Тогда
			ОсновныеДанныеФизЛица = ОсновныеДанныеФизЛица(ВыборкаДепонентов.ЮридическиеФизическиеЛица, НоваяСтрока.ДатаИзменения);
			
			НоваяСтрока.КраткоеНаименование = ОбщегоНазначения.ПолучитьФамилиюИмяОтчество(
				ОсновныеДанныеФизЛица.Фамилия, ОсновныеДанныеФизЛица.Имя, ОсновныеДанныеФизЛица.Отчество);
			
			НоваяСтрока.Документ = ПредставлениеДокументаФизлица(ВыборкаДепонентов.Наименование, ОсновныеДанныеФизЛица,
				НоваяСтрока.ДатаИзменения);
			
			НоваяСтрока.Гражданство = ПредставлениеГражданстваФизлица(ВыборкаДепонентов.Наименование,
				ОсновныеДанныеФизЛица.Гражданство, НоваяСтрока.ДатаИзменения);
			
			НоваяСтрока.ДатаМестоРождения = СтрокаИзДаты(ВыборкаДепонентов.ДатаРождения);
			Если ЗначениеЗаполнено(ВыборкаДепонентов.МестоРождения) Тогда
				НоваяСтрока.ДатаМестоРождения = НоваяСтрока.ДатаМестоРождения + ", " + ВыборкаДепонентов.МестоРождения;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

Процедура ДобавитьСтрокиБанковскихСчетов(Депонент)
	
	БанковскиеСчета = БанковскиеСчетаДепонента(Депонент, КонецПериода);
	
	Если БанковскиеСчета.Количество() > 0 Тогда
		Запрос = Новый Запрос;
		Запрос.Текст =
		"ВЫБРАТЬ
		|	БанковскиеСчета.ПредставлениеВалюты КАК ПредставлениеВалюты,
		|	БанковскиеСчета.БанковскийСчет КАК БанковскийСчет,
		|	БанковскиеСчета.НомерСчета КАК НомерСчета,
		|	БанковскиеСчета.Банк КАК Банк,
		|	БанковскиеСчета.БанкНаименование КАК БанкНаименование,
		|	БанковскиеСчета.БанкКоррСчет КАК БанкКоррСчет,
		|	БанковскиеСчета.БанкБИК КАК БанкБИК,
		|	БанковскиеСчета.БанкSWIFT КАК БанкSWIFT,
		|	БанковскиеСчета.ВидБанковскогоСчета КАК ВидБанковскогоСчета,
		|	БанковскиеСчета.НомерСтроки КАК НомерСтроки,
		|	ВЫБОР
		|		КОГДА БанковскиеСчета.ВидБанковскогоСчета = 1
		|			ТОГДА &ЗаголовокГруппыБанковскиеСчета
		|		КОГДА БанковскиеСчета.ВидБанковскогоСчета = 2
		|			ТОГДА &ЗаголовокГруппыБрокерскиеСчета
		|		КОГДА БанковскиеСчета.ВидБанковскогоСчета = 3
		|			ТОГДА &ЗаголовокГруппыРасчетныеКоды
		|		ИНАЧЕ """"
		|	КОНЕЦ КАК ЗаголовокВидаБанковскогоСчета
		|ПОМЕСТИТЬ БанковскиеСчета
		|ИЗ
		|	&БанковскиеСчета КАК БанковскиеСчета
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	БанковскиеСчета.ПредставлениеВалюты КАК ПредставлениеВалюты,
		|	БанковскиеСчета.БанковскийСчет КАК БанковскийСчет,
		|	БанковскиеСчета.НомерСчета КАК НомерСчета,
		|	БанковскиеСчета.Банк КАК Банк,
		|	БанковскиеСчета.БанкНаименование КАК БанкНаименование,
		|	БанковскиеСчета.БанкКоррСчет КАК БанкКоррСчет,
		|	БанковскиеСчета.БанкБИК КАК БанкБИК,
		|	БанковскиеСчета.БанкSWIFT КАК БанкSWIFT,
		|	БанковскиеСчета.ЗаголовокВидаБанковскогоСчета КАК ЗаголовокВидаБанковскогоСчета
		|ИЗ
		|	БанковскиеСчета КАК БанковскиеСчета
		|
		|УПОРЯДОЧИТЬ ПО
		|	БанковскиеСчета.ВидБанковскогоСчета,
		|	БанковскиеСчета.НомерСтроки
		|ИТОГИ ПО
		|	ЗаголовокВидаБанковскогоСчета";
		
		Запрос.УстановитьПараметр("БанковскиеСчета", БанковскиеСчета);
		Запрос.УстановитьПараметр("ЗаголовокГруппыБанковскиеСчета", "БАНКОВСКИЕ СЧЕТА:");
		Запрос.УстановитьПараметр("ЗаголовокГруппыБрокерскиеСчета", "БРОКЕРСКИЕ СЧЕТА:");
		Запрос.УстановитьПараметр("ЗаголовокГруппыРасчетныеКоды", "РАСЧЕТНЫЕ КОДЫ:");
		ВыборкаВидБанковскогоСчета = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		Пока ВыборкаВидБанковскогоСчета.Следующий() Цикл
			Выборка = ВыборкаВидБанковскогоСчета.Выбрать();
			НоваяСтрока = Депоненты.Добавить();
			НоваяСтрока.КраткоеНаименование = ВыборкаВидБанковскогоСчета.ЗаголовокВидаБанковскогоСчета;
			Пока Выборка.Следующий() Цикл
				НоваяСтрока = Депоненты.Добавить();
				НоваяСтрока.Наименование = БанковскиеРеквизиты(Выборка.НомерСчета, Выборка.Банк, Выборка.БанкНаименование,
					Выборка.БанкКоррСчет, Выборка.БанкБИК, Выборка.БанкSWIFT);
				НоваяСтрока.Документ = Выборка.ПредставлениеВалюты;
			КонецЦикла;
		КонецЦикла;
	КонецЕсли;
КонецПроцедуры

Функция БанковскиеСчетаДепонента(Депонент, Дата)
	Результат = Новый ТаблицаЗначений;
	Результат.Колонки.Добавить("ПредставлениеВалюты", ОбщегоНазначения.ПолучитьОписаниеТиповСтроки(10));
	Результат.Колонки.Добавить("БанковскийСчет", Новый ОписаниеТипов("СправочникСсылка.БанковскиеСчета"));
	Результат.Колонки.Добавить("НомерСчета", ОбщегоНазначения.ПолучитьОписаниеТиповСтроки(20));
	Результат.Колонки.Добавить("Банк", Новый ОписаниеТипов("СправочникСсылка.Банки"));
	Результат.Колонки.Добавить("БанкНаименование", ОбщегоНазначения.ПолучитьОписаниеТиповСтроки(100));
	Результат.Колонки.Добавить("БанкКоррСчет", ОбщегоНазначения.ПолучитьОписаниеТиповСтроки(20));
	Результат.Колонки.Добавить("БанкБИК", ОбщегоНазначения.ПолучитьОписаниеТиповСтроки(20));
	Результат.Колонки.Добавить("БанкSWIFT", ОбщегоНазначения.ПолучитьОписаниеТиповСтроки(15));
	Результат.Колонки.Добавить("ВидБанковскогоСчета", Новый ОписаниеТипов("Число"));
	Результат.Колонки.Добавить("НомерСтроки", Новый ОписаниеТипов("Число"));
	
	ТаблицаВалют = ТаблицаВалют(Дата);
	СчетаДляВыплатыДоходов			= СчетаДляВыплатыДоходов(Дата);
	РасчетныеКодыДляВыплатыДохода	= РасчетныеКодыДляВыплатыДохода(Дата, мРубль);
	БрокерскиеСчета					= БрокерскиеСчета(Дата);
	
	Для Каждого ТекущаяВалюта Из ТаблицаВалют Цикл
		СтрокаРеквизитов = Неопределено;
		ВидБанковскогоСчета = Неопределено;
		Отбор = Новый Структура("Депонент, Валюта", Депонент, ТекущаяВалюта.Валюта);
		СтрокаРеквизитов = СтрокаРеквизитовБанковскогоСчета(Отбор, СчетаДляВыплатыДоходов);
		Если СтрокаРеквизитов <> Неопределено Тогда
			ВидБанковскогоСчета = 1;
		Иначе
			СтрокаРеквизитов = СтрокаРеквизитовБрокерскогоСчета(Отбор, Депонент, БрокерскиеСчета);
			ВидБанковскогоСчета = 2;
		КонецЕсли;
		
		ЗаполнитьСтрокуРеквизитовДаннымиПоРасчетномуКоду(РасчетныеКодыДляВыплатыДохода, СтрокаРеквизитов,
			ТекущаяВалюта, Депонент, ВидБанковскогоСчета);
		
		Если СтрокаРеквизитов <> Неопределено Тогда
			НоваяСтрока = Результат.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаРеквизитов);
			НоваяСтрока.ПредставлениеВалюты = ТекущаяВалюта.Представление;
			НоваяСтрока.ВидБанковскогоСчета = ВидБанковскогоСчета;
			НоваяСтрока.НомерСтроки = Результат.Количество();
		КонецЕсли;
	КонецЦикла;
	Возврат Результат;
КонецФункции

Функция СтрокаРеквизитовБанковскогоСчета(Отбор, СчетаДляВыплатыДоходов)
	
	СтрокаРеквизитов = Неопределено;
	СтрокиСчета = СчетаДляВыплатыДоходов.НайтиСтроки(Отбор);
	Если СтрокиСчета.Количество() > 0 Тогда
		СтрокаРеквизитов = СтрокиСчета[0];
	КонецЕсли;
	
	Возврат СтрокаРеквизитов;
	
КонецФункции

Функция СтрокаРеквизитовБрокерскогоСчета(Отбор, Депонент, БрокерскиеСчета)
	
	СтрокаРеквизитов = Неопределено;
	СтрокиБС = БрокерскиеСчета.БС.НайтиСтроки(Отбор);
	Если СтрокиБС.Количество() > 0 Тогда
		СтрокаРеквизитов = СтрокиБС[0];
	Иначе
		// Продолжим поиск в БС по пустому депоненту с правом для текущего депонента
		Права = БрокерскиеСчета.Права.Найти(Депонент, "Депонент");
		Если Права <> Неопределено Тогда
			ПравоИспользованияДС = Права.ПравоПредоставлено;
		Иначе
			ПравоИспользованияДС = Ложь;
		КонецЕсли;
		
		Отбор.Вставить("Депонент", Справочники.Контрагенты.ПустаяСсылка());
		Отбор.Вставить("ИспользованиеДС", ПравоИспользованияДС);
		СтрокиБС = БрокерскиеСчета.БС.НайтиСтроки(Отбор);
		Если СтрокиБС.Количество() > 0 Тогда
			СтрокаРеквизитов = СтрокиБС[0];
		КонецЕсли;
	КонецЕсли;
	
	Возврат СтрокаРеквизитов;
	
КонецФункции

Процедура ЗаполнитьСтрокуРеквизитовДаннымиПоРасчетномуКоду(РасчетныеКодыДляВыплатыДохода, СтрокаРеквизитов,
	ТекущаяВалюта, Депонент, ВидБанковскогоСчета)

	Если СтрокаРеквизитов = Неопределено И ТекущаяВалюта.Валюта = мРубль Тогда
		ТекущийРасчетныйКод = РасчетныеКодыДляВыплатыДохода.Найти(Депонент, "Депонент");
		Если ТекущийРасчетныйКод <> Неопределено Тогда
			СтрокаРеквизитов = ТекущийРасчетныйКод;
			ВидБанковскогоСчета = 3;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

Функция ТаблицаВалют(Дата)
	НайденнаяСтрока = КэшТаблицаВалют.Найти(Дата, "Дата");
	Если НайденнаяСтрока <> Неопределено Тогда
		Возврат НайденнаяСтрока.ТаблицаВалют;
	КонецЕсли;
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	ВалютыОтчета.Валюта КАК Валюта
	|ИЗ
	|	РегистрСведений.ВалютыОтчетаРегистрДепонентов.СрезПоследних(&Дата, ) КАК ВалютыОтчета
	|ГДЕ
	|	ВалютыОтчета.ФлагАктивности
	|
	|УПОРЯДОЧИТЬ ПО
	|	ВалютыОтчета.ПорядокВОтчете");
	Запрос.УстановитьПараметр("Дата", Дата);
	ТаблицаВалют = Запрос.Выполнить().Выгрузить();
	ТаблицаВалют.Колонки.Добавить("Представление");
	Для Каждого Строка Из ТаблицаВалют Цикл
		Строка.Представление = Справочники.Валюты.ПредставлениеВалюты(Строка.Валюта);
	КонецЦикла;
	ТаблицаВалют.Сортировать("Представление");
	
	НоваяСтрока = КэшТаблицаВалют.Добавить();
	НоваяСтрока.Дата = Дата;
	НоваяСтрока.ТаблицаВалют = ТаблицаВалют;
	
	Возврат ТаблицаВалют;
КонецФункции

Функция СчетаДляВыплатыДоходов(Дата)
	НайденнаяСтрока = КэшСчетаДляВыплатыДоходов.Найти(Дата, "Дата");
	Если НайденнаяСтрока <> Неопределено Тогда
		Возврат НайденнаяСтрока.СчетаДляВыплатыДоходов;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	СчетаСрезПоследних.Счет.Владелец КАК Депонент,
	|	СчетаСрезПоследних.Счет.ВалютаДенежныхСредств КАК Валюта,
	|	МАКСИМУМ(СчетаСрезПоследних.Счет) КАК БанковскийСчет
	|ПОМЕСТИТЬ втСчетаДляВыплатыДоходов
	|ИЗ
	|	РегистрСведений.СчетаДляВыплатыДоходов.СрезПоследних(
	|			&ДатаСреза,
	|			Счет.ВалютаДенежныхСредств В (&СписокВалют)
	|				И ФлагАктивности) КАК СчетаСрезПоследних
	|
	|СГРУППИРОВАТЬ ПО
	|	СчетаСрезПоследних.Счет.Владелец,
	|	СчетаСрезПоследних.Счет.ВалютаДенежныхСредств
	|;
	|
	|ВЫБРАТЬ
	|	Счета.Депонент КАК Депонент,
	|	Счета.Валюта КАК Валюта,
	|	Счета.БанковскийСчет КАК БанковскийСчет,
	|	Счета.БанковскийСчет.НомерСчета КАК НомерСчета,
	|	Счета.БанковскийСчет.Банк КАК Банк,
	|	Счета.БанковскийСчет.Банк.Наименование КАК БанкНаименование,
	|	Счета.БанковскийСчет.Банк.КоррСчет КАК БанкКоррСчет,
	|	Счета.БанковскийСчет.Банк.Код КАК БанкБИК,
	|	Счета.БанковскийСчет.Банк.SWIFT КАК БанкSWIFT
	|ИЗ
	|	втСчетаДляВыплатыДоходов КАК Счета
	|";
	Запрос.УстановитьПараметр("ДатаСреза", Дата);
	ТаблицаВалют = ТаблицаВалют(Дата);
	Запрос.УстановитьПараметр("СписокВалют", ТаблицаВалют.ВыгрузитьКолонку("Валюта"));
	ТаблицаСчетов = Запрос.Выполнить().Выгрузить();
	
	НоваяСтрока = КэшСчетаДляВыплатыДоходов.Добавить();
	НоваяСтрока.Дата = Дата;
	НоваяСтрока.СчетаДляВыплатыДоходов = ТаблицаСчетов;
	
	Возврат ТаблицаСчетов;
КонецФункции

Функция РасчетныеКодыДляВыплатыДохода(Дата, Валюта)
	Отбор = Новый Структура("Дата, Валюта", Дата, Валюта);
	Строки = КэшРасчетныеКодыДляВыплатыДохода.НайтиСтроки(Отбор);
	Если Строки.Количество() > 0 Тогда
		Возврат Строки[0].РасчетныеКодыДляВыплатыДохода;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	РасчетныеКоды.Клиент КАК Депонент,
	|	Счета.Ссылка КАК БанковскийСчет,
	|	Счета.НомерСчета КАК НомерСчета,
	|	Счета.Банк КАК Банк,
	|	Счета.Банк.Наименование + "" (РК ""+ РасчетныеКоды.РасчетныйКод.НомерСчета + "")"" КАК БанкНаименование,
	|	Счета.Банк.КоррСчет КАК БанкКоррСчет,
	|	Счета.Банк.Код КАК БанкБИК,
	|	Счета.Банк.SWIFT КАК БанкSWIFT
	|ИЗ
	|	РегистрСведений.РасчетныеКодыДляВыплатыДоходовКлиентам.СрезПоследних(&ДатаСреза, Валюта = &Валюта) КАК РасчетныеКоды
	|	ЛЕВОЕ СОЕДИНЕНИЕ Справочник.БанковскиеСчета КАК Счета
	|		ПО Счета.Ссылка = &СчетДляВыплатыДоходов
	|";
	Запрос.УстановитьПараметр("ДатаСреза",	Дата);
	Запрос.УстановитьПараметр("Валюта",		Валюта);
	Запрос.УстановитьПараметр("СчетДляВыплатыДоходов", мСчетДляВыплатыДоходов);
	ТаблицаКодов = Запрос.Выполнить().Выгрузить();
	
	НоваяСтрока = КэшРасчетныеКодыДляВыплатыДохода.Добавить();
	НоваяСтрока.Дата = Дата;
	НоваяСтрока.Валюта = Валюта;
	НоваяСтрока.РасчетныеКодыДляВыплатыДохода = ТаблицаКодов;
	
	Возврат ТаблицаКодов;
КонецФункции

Функция БрокерскиеСчета(Дата)
	НайденнаяСтрока = КэшБрокерскиеСчета.Найти(Дата, "Дата");
	Если НайденнаяСтрока <> Неопределено Тогда
		Возврат НайденнаяСтрока.БрокерскиеСчета;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Право.Клиент КАК Депонент,
	|	Право.Значение КАК ПравоПредоставлено
	|ПОМЕСТИТЬ втПравоИспользованияЦБКлиентов
	|ИЗ
	|	РегистрСведений.ПравоИспользованияЦБКлиентов.СрезПоследних(&ДатаСреза, ) КАК Право
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	БС.Клиент КАК Депонент,
	|	БС.Валюта КАК Валюта,
	|	БС.Счет КАК БанковскийСчет
	|ПОМЕСТИТЬ втБрокерскиеСчета
	|ИЗ
	|	РегистрСведений.БрокерскиеСчета.СрезПоследних(
	|			&ДатаСреза,
	|			Банк = &БанкНРД
	|				И ТипСчета = &ТипСпецБрокерский
	|				И Валюта В (&СписокВалют)) КАК БС
	|ГДЕ
	|	БС.ФлагАктивности
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Депонент
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Право.Депонент КАК Депонент,
	|	Право.ПравоПредоставлено КАК ПравоПредоставлено
	|ИЗ
	|	втПравоИспользованияЦБКлиентов КАК Право
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	БС.Депонент КАК Депонент,
	|	БС.Валюта КАК Валюта,
	|	БС.БанковскийСчет КАК БанковскийСчет,
	|	БС.БанковскийСчет.НомерСчета КАК НомерСчета,
	|	БС.БанковскийСчет.Банк КАК Банк,
	|	БС.БанковскийСчет.Банк.Наименование КАК БанкНаименование,
	|	БС.БанковскийСчет.Банк.КоррСчет КАК БанкКоррСчет,
	|	БС.БанковскийСчет.Банк.Код КАК БанкБИК,
	|	БС.БанковскийСчет.Банк.SWIFT КАК БанкSWIFT,
	|	ЕСТЬNULL(Права.ПравоПредоставлено, ЛОЖЬ) КАК ИспользованиеДС
	|ИЗ
	|	втБрокерскиеСчета КАК БС
	|		ЛЕВОЕ СОЕДИНЕНИЕ втПравоИспользованияЦБКлиентов КАК Права
	|		ПО БС.Депонент = Права.Депонент";
	
	Запрос.УстановитьПараметр("ДатаСреза",			Дата);
	Запрос.УстановитьПараметр("БанкНРД",			мРасчетныйБанк);
	Запрос.УстановитьПараметр("ТипСпецБрокерский",	Перечисления.ТипыНазначенияБанковскихСчетов.Брокерский);
	
	ТаблицаВалют = ТаблицаВалют(Дата);
	Запрос.УстановитьПараметр("СписокВалют",	ТаблицаВалют.ВыгрузитьКолонку("Валюта"));	
	Запрос.УстановитьПараметр("ПустойДепонент",	Справочники.Контрагенты.ПустаяСсылка());
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	
	Результат = Новый Структура;
	Результат.Вставить("Права",	РезультатЗапроса[2].Выгрузить());
	Результат.Вставить("БС",	РезультатЗапроса[3].Выгрузить());
	
	НоваяСтрока = КэшБрокерскиеСчета.Добавить();
	НоваяСтрока.Дата = Дата;
	НоваяСтрока.БрокерскиеСчета = Результат;
	
	Возврат Результат;
КонецФункции

Процедура ДобавитьСтрокиПредставителей(Депонент, ДатаИзменения)
	Представители = ПредставителиЮрЛиц(Депонент);
	Если Представители.Количество() > 0 Тогда
		НоваяСтрока = Депоненты.Добавить();
		НоваяСтрока.КраткоеНаименование = "Представители по Уставу:";
	КонецЕсли;
	
	ФорматДатыПериода = "ДФ=dd.MM.yyyy";
	Для Каждого Представитель Из Представители Цикл
		ОсновныеДанныеФизЛица = ОсновныеДанныеФизЛица(Представитель.ЮрФизЛицо, ДатаИзменения);		
		ФИОФизЛица = ОбщегоНазначения.ПолучитьФамилиюИмяОтчество(ОсновныеДанныеФизЛица.Фамилия,
			ОсновныеДанныеФизЛица.Имя, ОсновныеДанныеФизЛица.Отчество);
		ПериодДействияПредставителя = "";
		Если ЗначениеЗаполнено(Представитель.ДатаНачалаДействия) Тогда
			ПериодДействияПредставителя = "с " + Формат(Представитель.ДатаНачалаДействия, ФорматДатыПериода);
		КонецЕсли;
		Если ЗначениеЗаполнено(Представитель.ДатаОкончанияДействия) Тогда
			ПериодДействияПредставителя = ?(ЗначениеЗаполнено(ПериодДействияПредставителя), ПериодДействияПредставителя + " ", "")
				+ "по " + Формат(Представитель.ДатаОкончанияДействия, ФорматДатыПериода);
		КонецЕсли;
		НоваяСтрока = Депоненты.Добавить();
		НоваяСтрока.ПериодДействияПредставителя = ПериодДействияПредставителя;
		НоваяСтрока.ПредставительЮрлица = ФИОФизЛица;
		НоваяСтрока.ДокументПредставителяЮрлица = ПредставлениеДокументаФизлица(ФИОФизЛица, ОсновныеДанныеФизЛица,
			ДатаИзменения);
	КонецЦикла;
КонецПроцедуры

Процедура ДобавитьСтрокиДоверенныхЛиц(Депонент, ДатаИзменения)
	ДоверенныеЛица = ДоверенныеЛицаДепонента(Депонент);
	Если ДоверенныеЛица.Количество() > 0 Тогда
		НоваяСтрока = Депоненты.Добавить();
		НоваяСтрока.КраткоеНаименование = "Представители по Доверенности:";
	КонецЕсли;
	
	ФорматДаты = "ДФ=dd.MM.yyyy";
	Для Каждого ДоверенноеЛицо Из ДоверенныеЛица Цикл
		ОсновныеДанныеФизЛица = ОсновныеДанныеФизЛица(ДоверенноеЛицо.ФизЛицо, ДатаИзменения);
		ФИОФизЛица = ОбщегоНазначения.ПолучитьФамилиюИмяОтчество(ОсновныеДанныеФизЛица.Фамилия,
			ОсновныеДанныеФизЛица.Имя, ОсновныеДанныеФизЛица.Отчество);
		Контакты = КонтактнаяИнформация(ДоверенноеЛицо.ФизЛицо, ДатаИзменения);
		ПериодДействияПредставителя = "";
		Если ЗначениеЗаполнено(ДоверенноеЛицо.ДатаНачала) Тогда
			ПериодДействияПредставителя = "с " + Формат(ДоверенноеЛицо.ДатаНачала, ФорматДаты);
		КонецЕсли;
		Если ЗначениеЗаполнено(ДоверенноеЛицо.ДатаОкончания) Тогда
			ПериодДействияПредставителя = ?(ЗначениеЗаполнено(ПериодДействияПредставителя), ПериодДействияПредставителя + " ", "")
				+ "по " + Формат(ДоверенноеЛицо.ДатаОкончания, ФорматДаты);
		КонецЕсли;
		ПредставлениеДокумента = СтрШаблон("%1 № %2 от %3, период действия: %4", ДоверенноеЛицо.ВидДокументаПредставление,
			ДоверенноеЛицо.НомерДоверенности, Формат(ДоверенноеЛицо.ДатаНачала, ФорматДаты), ПериодДействияПредставителя);
		НоваяСтрока = Депоненты.Добавить();
		НоваяСтрока.Наименование = ФИОФизЛица;
		НоваяСтрока.Документ = ПредставлениеДокумента;
		НоваяСтрока.Телефон = Контакты.Телефон;
		НоваяСтрока.Email = Контакты.Email;
		НоваяСтрока.ДокументПредставителяЮрлица = ПредставлениеДокументаФизлица(ФИОФизЛица, ОсновныеДанныеФизЛица,
			ДатаИзменения);
	КонецЦикла;
КонецПроцедуры

Функция ПредставителиЮрЛиц(Депонент)
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Представители.ЮрФизЛицо КАК ЮрФизЛицо,
	|	Представители.ДатаНачалаДействия КАК ДатаНачалаДействия,
	|	Представители.ДатаОкончанияДействия КАК ДатаОкончанияДействия
	|ИЗ
	|	РегистрСведений.ПредставителиЮрЛица КАК Представители
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Контрагенты КАК Контрагенты
	|		ПО Представители.Клиент = Контрагенты.ЮридическиеФизическиеЛица
	|			И (Контрагенты.Ссылка = &Депонент)
	|ГДЕ
	|	ВЫБОР
	|			КОГДА Представители.ДатаНачалаДействия < &НачалоПериода
	|				ТОГДА ВЫБОР
	|						КОГДА Представители.ДатаОкончанияДействия > &НачалоПериода
	|							ТОГДА ИСТИНА
	|						КОГДА Представители.ДатаОкончанияДействия = ДАТАВРЕМЯ(1, 1, 1)
	|							ТОГДА ИСТИНА
	|						ИНАЧЕ ЛОЖЬ
	|					КОНЕЦ
	|			КОГДА Представители.ДатаНачалаДействия МЕЖДУ &НачалоПериода И &КонецПериода
	|				ТОГДА ИСТИНА
	|			ИНАЧЕ ЛОЖЬ
	|		КОНЕЦ
	|	И Представители.ЮрФизЛицо ССЫЛКА Справочник.ФизическиеЛица
	|
	|УПОРЯДОЧИТЬ ПО
	|	ДатаНачалаДействия";
	Запрос.УстановитьПараметр("Депонент", Депонент);
	Запрос.УстановитьПараметр("НачалоПериода", НачалоПериода);
	Запрос.УстановитьПараметр("КонецПериода", КонецПериода);
	Возврат Запрос.Выполнить().Выгрузить();
КонецФункции

Функция ДоверенныеЛицаДепонента(Депонент)
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ВЫРАЗИТЬ(ДоверенныеЛица.ДоверенноеЛицо КАК Справочник.ФизическиеЛица).Представление КАК НаименованиеПолное,
	|	ДоверенныеЛица.ВидДокумента.Представление КАК ВидДокументаПредставление,
	|	ДоверенныеЛица.ДатаНачала КАК ДатаНачала,
	|	ДоверенныеЛица.ДатаОкончания КАК ДатаОкончания,
	|	ДоверенныеЛица.НомерДоверенности КАК НомерДоверенности,
	|	ДоверенныеЛица.ДоверенноеЛицо КАК ФизЛицо
	|ИЗ
	|	РегистрСведений.ДоверенныеЛица КАК ДоверенныеЛица
	|ГДЕ
	|	ДоверенныеЛица.Депонент = &Депонент
	|	И ДоверенныеЛица.ДоверенноеЛицо ССЫЛКА Справочник.ФизическиеЛица
	|	И ВЫБОР
	|			КОГДА ДоверенныеЛица.ДатаНачала < &НачалоПериода
	|				ТОГДА ВЫБОР
	|						КОГДА ДоверенныеЛица.ДатаОкончания > &НачалоПериода
	|							ТОГДА ИСТИНА
	|						КОГДА ДоверенныеЛица.ДатаОкончания = ДАТАВРЕМЯ(1, 1, 1)
	|							ТОГДА ИСТИНА
	|						ИНАЧЕ ЛОЖЬ
	|					КОНЕЦ
	|			КОГДА ДоверенныеЛица.ДатаНачала МЕЖДУ &НачалоПериода И &КонецПериода
	|				ТОГДА ИСТИНА
	|			ИНАЧЕ ЛОЖЬ
	|		КОНЕЦ
	|
	|УПОРЯДОЧИТЬ ПО
	|	ДоверенныеЛица.Период";
	Запрос.УстановитьПараметр("Депонент", Депонент);
	Запрос.УстановитьПараметр("НачалоПериода", НачалоПериода);
	Запрос.УстановитьПараметр("КонецПериода", КонецПериода);
	Возврат Запрос.Выполнить().Выгрузить();
КонецФункции

Процедура ДобавитьСтрокиСубклиентов(ОтборПоДепоненту, ТаблицаСубклиентов, ДатаИзменения)
	СтрокиСубклиентов = ТаблицаСубклиентов.НайтиСтроки(ОтборПоДепоненту);
	Если СтрокиСубклиентов.Количество() > 0 Тогда
		НоваяСтрока = Депоненты.Добавить();
		НоваяСтрока.КраткоеНаименование = "СУБКЛИЕНТЫ:";
	КонецЕсли;
	
	Для Каждого СтрокаСубклиента Из СтрокиСубклиентов Цикл
		НоваяСтрока = Депоненты.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаСубклиента, "Депонент,Субклиент,Резидент,Наименование,ИНН");
		КИ = КонтактнаяИнформация(СтрокаСубклиента.Субклиент, ДатаИзменения);
		ЗаполнитьЗначенияСвойств(НоваяСтрока, КИ, "ФактическийАдрес,ЮридическийАдрес,Email,Телефон");
		
		Если ТипЗнч(СтрокаСубклиента.Субклиент) = Тип("СправочникСсылка.ЮридическиеЛица") Тогда
			НоваяСтрока.Документ = ОГРН(СтрокаСубклиента.ОГРН, СтрокаСубклиента.ДатаГосРегистрации,
				СтрокаСубклиента.Резидент);
			
		ИначеЕсли ТипЗнч(СтрокаСубклиента.Субклиент) = Тип("СправочникСсылка.ФизическиеЛица") Тогда
			ОсновныеДанныеФизЛица = ОсновныеДанныеФизЛица(СтрокаСубклиента.Субклиент, ДатаИзменения);
			
			НоваяСтрока.Документ = ПредставлениеДокументаФизлица(СтрокаСубклиента.Наименование, ОсновныеДанныеФизЛица,
				ДатаИзменения);
			
			НоваяСтрока.Гражданство = ПредставлениеГражданстваФизлица(СтрокаСубклиента.Наименование,
				ОсновныеДанныеФизЛица.Гражданство, ДатаИзменения);
			
			НоваяСтрока.ДатаМестоРождения = СтрокаИзДаты(СтрокаСубклиента.ДатаРождения);
			Если ЗначениеЗаполнено(СтрокаСубклиента.МестоРождения) Тогда
				НоваяСтрока.ДатаМестоРождения = НоваяСтрока.ДатаМестоРождения + ", " + СтрокаСубклиента.МестоРождения;
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

Функция КонтактнаяИнформация(ЮрФизЛицо, ДатаСреза)
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ФактическийАдрес.Представление КАК ФактическийАдрес
	|ИЗ
	|	РегистрСведений.КонтактнаяИнформация.СрезПоследних(&ДатаСреза,
	|		Объект = &ЮрФизЛицо
	|		И Тип = &Адрес
	|		И (Объект ССЫЛКА Справочник.ЮридическиеЛица И Вид = &ФактАдресЮрЛица
	|			ИЛИ Объект ССЫЛКА Справочник.ФизическиеЛица И Вид = &ФактАдресФизЛица)) КАК ФактическийАдрес
	|;
	|////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЮридическийАдрес.Представление КАК ЮридическийАдрес
	|ИЗ
	|	РегистрСведений.КонтактнаяИнформация.СрезПоследних(&ДатаСреза,
	|		Объект = &ЮрФизЛицо
	|		И Тип = &Адрес
	|		И (Объект ССЫЛКА Справочник.ЮридическиеЛица И Вид = &ЮрАдресЮрЛица
	|			ИЛИ Объект ССЫЛКА Справочник.ФизическиеЛица И Вид = &ЮрАдресФизЛица)) КАК ЮридическийАдрес
	|;
	|////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Email.Представление КАК Email
	|ИЗ
	|	РегистрСведений.КонтактнаяИнформация.СрезПоследних(&ДатаСреза,
	|		Объект = &ЮрФизЛицо
	|		И Тип = &АдресЭлектроннойПочты
	|		И (Объект ССЫЛКА Справочник.ЮридическиеЛица И Вид = &EmailЮрЛица
	|			ИЛИ Объект ССЫЛКА Справочник.ФизическиеЛица И Вид = &EmailФизЛица)) КАК Email
	|;
	|////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Телефон.Представление КАК Телефон
	|ИЗ
	|	РегистрСведений.КонтактнаяИнформация.СрезПоследних(&ДатаСреза,
	|		Объект = &ЮрФизЛицо
	|		И Тип = &Телефон
	|		И (Объект ССЫЛКА Справочник.ЮридическиеЛица И Вид = &ТелефонЮрЛица
	|			ИЛИ Объект ССЫЛКА Справочник.ФизическиеЛица И Вид = &ТелефонФизЛица)) КАК Телефон
	|";
	Запрос.УстановитьПараметр("ЮрФизЛицо",			ЮрФизЛицо);
	Запрос.УстановитьПараметр("ДатаСреза",			ДатаСреза);
	Запрос.УстановитьПараметр("Адрес",				Перечисления.ТипыКонтактнойИнформации.Адрес);
	Запрос.УстановитьПараметр("Телефон",			Перечисления.ТипыКонтактнойИнформации.Телефон);
	Запрос.УстановитьПараметр("АдресЭлектроннойПочты",	Перечисления.ТипыКонтактнойИнформации.АдресЭлектроннойПочты);
	Запрос.УстановитьПараметр("ФактАдресЮрЛица",	Справочники.ВидыКонтактнойИнформации.ФактАдресЮрЛица);
	Запрос.УстановитьПараметр("ФактАдресФизЛица",	Справочники.ВидыКонтактнойИнформации.ФактАдресФизЛица);
	Запрос.УстановитьПараметр("ЮрАдресЮрЛица",		Справочники.ВидыКонтактнойИнформации.ЮрАдресЮрЛица);
	Запрос.УстановитьПараметр("ЮрАдресФизЛица",		Справочники.ВидыКонтактнойИнформации.ЮрАдресФизЛица);
	Запрос.УстановитьПараметр("EmailЮрЛица",		Справочники.ВидыКонтактнойИнформации.EmailЮрЛица);
	Запрос.УстановитьПараметр("EmailФизЛица",		Справочники.ВидыКонтактнойИнформации.EmailФизЛица);
	Запрос.УстановитьПараметр("ТелефонЮрЛица",		Справочники.ВидыКонтактнойИнформации.ТелефонЮрЛица);
	Запрос.УстановитьПараметр("ТелефонФизЛица",		Справочники.ВидыКонтактнойИнформации.ТелефонФизЛица);
	
	Пакет = Запрос.ВыполнитьПакет();
	КИ = Новый Структура;
	
	Выборка = Пакет[0].Выбрать();
	КИ.Вставить("ФактическийАдрес", ?(Выборка.Следующий(), Выборка.ФактическийАдрес, ""));
	
	Выборка = Пакет[1].Выбрать();
	КИ.Вставить("ЮридическийАдрес", ?(Выборка.Следующий(), Выборка.ЮридическийАдрес, ""));
	
	Выборка = Пакет[2].Выбрать();
	КИ.Вставить("Email", ?(Выборка.Следующий(), Выборка.Email, ""));
	
	Выборка = Пакет[3].Выбрать();
	КИ.Вставить("Телефон", ?(Выборка.Следующий(), Выборка.Телефон, ""));
	
	Возврат КИ;
КонецФункции

Функция ОсновныеДанныеФизЛица(ФизЛицо, ДатаСреза)
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ЕСТЬNULL(ФИОФизЛиц.Фамилия, """") КАК Фамилия,
	|	ЕСТЬNULL(ФИОФизЛиц.Имя, """") КАК Имя,
	|	ЕСТЬNULL(ФИОФизЛиц.Отчество, """") КАК Отчество,
	|	ЕСТЬNULL(Паспорт.ДокументВид, &ПустойВидДокумента) КАК ДокументВид,
	|	ЕСТЬNULL(Паспорт.ДокументСерия, """") КАК ДокументСерия,
	|	ЕСТЬNULL(Паспорт.ДокументНомер, """") КАК ДокументНомер,
	|	ЕСТЬNULL(Паспорт.ДокументДатаВыдачи, ДАТАВРЕМЯ(1,1,1)) КАК ДокументДатаВыдачи,
	|	ЕСТЬNULL(Паспорт.ДокументКемВыдан, """") КАК ДокументКемВыдан,
	|	ЕСТЬNULL(Паспорт.ДокументКодПодразделения, """") КАК ДокументКодПодразделения,
	|	ЕСТЬNULL(Гражданство.Страна.Наименование, """") КАК Гражданство
	|
	|ИЗ
	|	Справочник.ФизическиеЛица КАК ФизическиеЛица
	|
	|	ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ФИОФизЛиц.СрезПоследних(&ДатаСреза, ФизЛицо = &ФизЛицо) КАК ФИОФизЛиц
	|	ПО ФизическиеЛица.Ссылка = ФИОФизЛиц.ФизЛицо 
	|
	|	ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ПаспортныеДанныеФизЛиц.СрезПоследних(&ДатаСреза, ФизЛицо = &ФизЛицо) КАК Паспорт
	|	ПО ФизическиеЛица.Ссылка = Паспорт.ФизЛицо 
	|
	|	ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ГражданствоФизЛиц.СрезПоследних(&ДатаСреза, ФизЛицо = &ФизЛицо) КАК Гражданство
	|	ПО ФизическиеЛица.Ссылка = Гражданство.ФизЛицо 
	|	
	|ГДЕ
	|	ФизическиеЛица.Ссылка = &ФизЛицо
	|";
	Запрос.УстановитьПараметр("ФизЛицо", ФизЛицо);
	Запрос.УстановитьПараметр("ДатаСреза", ДатаСреза);
	Запрос.УстановитьПараметр("ПустойВидДокумента", Справочники.ДокументыУдостоверяющиеЛичность.ПустаяСсылка());
	
	ДанныеФизЛица = Новый Структура(
		"Фамилия, Имя, Отчество,
		|ДокументВид, ДокументСерия, ДокументНомер, ДокументДатаВыдачи, ДокументКемВыдан, ДокументКодПодразделения,
		|Гражданство",
		"", "", "",
		Справочники.ДокументыУдостоверяющиеЛичность.ПустаяСсылка(), "", "", Дата(1,1,1), "", "",
		"");
	
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		ЗаполнитьЗначенияСвойств(ДанныеФизЛица, Выборка);
	КонецЕсли;
	
	Возврат ДанныеФизЛица;
КонецФункции

