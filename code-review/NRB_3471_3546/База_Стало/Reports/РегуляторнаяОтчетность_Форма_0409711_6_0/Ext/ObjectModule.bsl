#Область ПрограммныйИнтерфейс

// Процедура заполняет данными ТЧ ДанныеПодраздела_1_2, ДанныеПодраздела_1_2_1 и параметр ДанныеДляРасшифровки
// Параметры:
//	ДанныеДляРасшифровки - ТаблицаЗначений - возвращаемый параметр, в котором возвращается таблица значений
//
// BSLLS:MethodSize-off
Процедура ПолучитьДанные(ДанныеДляРасшифровки) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	// Важно, что реквизит Резидент в справочнике контрагентов, как это ни парадоксально, означает "Нерезидент по документам"
	// - живите теперь с этим, если не знали раньше
	// Условия типа 1 = 1 в нескольких местах запроса в виртуальных таблицах среза последних - это чтобы Sonar не ругался
	// на виртуальную таблицу без параметров
	"ВЫБРАТЬ
	|	ЮридическиеЛицаМеждународныеКомпанииСрезПоследних.МеждународнаяКомпания КАК МеждународнаяКомпания,
	|	ЮридическиеЛицаМеждународныеКомпанииСрезПоследних.ЮридическоеЛицо КАК ЮридическоеЛицо
	|ПОМЕСТИТЬ ЮридическиеЛицаМеждународныеКомпании
	|ИЗ
	|	РегистрСведений.ЮридическиеЛицаМеждународныеКомпании.СрезПоследних(&ПериодКонец, ) КАК ЮридическиеЛицаМеждународныеКомпанииСрезПоследних
	|ГДЕ
	|	ЮридическиеЛицаМеждународныеКомпанииСрезПоследних.МеждународнаяКомпания
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ОстаткиЦБОстатки.СчетДепо КАК СчетДепо,
	|	ОстаткиЦБОстатки.РазделСчетаДепо КАК РазделСчетаДепо,
	|	ОстаткиЦБОстатки.ЦБ КАК ЦБ,
	|	ОстаткиЦБОстатки.СчетДепоМХ КАК СчетДепоМХ,
	|	ОстаткиЦБОстатки.СтатусЦБ КАК СтатусЦБ,
	|	ОстаткиЦБОстатки.КоличествоОстаток КАК КоличествоОстаток
	|ПОМЕСТИТЬ ВТ_Остатки
	|ИЗ
	|	РегистрНакопления.ОстаткиЦБ.Остатки(
	|			&ПериодКонец,
	|			СчетДепо.ПризнакСчетаДепо = ЗНАЧЕНИЕ(Перечисление.ПризнакиСчетаДепо.СчетДепонента)
	|				И НЕ СчетДепо.ТипСчетаДепо В (&ИсключаемыеТипыСчетовДепо)) КАК ОстаткиЦБОстатки
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ОстаткиЦБОбороты.ЦБ КАК ЦБ,
	|	СУММА(ОстаткиЦБОбороты.КоличествоПриход) КАК КоличествоПриход,
	|	СУММА(ОстаткиЦБОбороты.КоличествоРасход) КАК КоличествоРасход,
	|	ОстаткиЦБОбороты.Регистратор КАК Регистратор
	|ПОМЕСТИТЬ ВТ_ОборотыВсеОперации
	|ИЗ
	|	РегистрНакопления.ОстаткиЦБ.Обороты(&ПериодНачало, &ПериодКонец, Регистратор, 1 = 1) КАК ОстаткиЦБОбороты
	|ГДЕ
	|	ВЫБОР
	|			КОГДА ОстаткиЦБОбороты.Регистратор ССЫЛКА Документ.КонвертацияЦБ
	|				ТОГДА ИСТИНА
	|			КОГДА ОстаткиЦБОбороты.Регистратор ССЫЛКА Документ.ГлобальнаяОперация
	|				ТОГДА ИСТИНА
	|			КОГДА ОстаткиЦБОбороты.Регистратор ССЫЛКА Документ.ПогашениеЦБ
	|				ТОГДА ИСТИНА
	|			КОГДА ОстаткиЦБОбороты.Регистратор ССЫЛКА Документ.ОперацииЦБ
	|				ТОГДА ИСТИНА
	|			ИНАЧЕ ЛОЖЬ
	|		КОНЕЦ
	|
	|СГРУППИРОВАТЬ ПО
	|	ОстаткиЦБОбороты.ЦБ,
	|	ОстаткиЦБОбороты.Регистратор
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_ОборотыВсеОперации.ЦБ КАК ЦБ,
	|	ВТ_ОборотыВсеОперации.КоличествоПриход КАК КоличествоПриход,
	|	ВТ_ОборотыВсеОперации.КоличествоРасход КАК КоличествоРасход,
	|	ВТ_ОборотыВсеОперации.Регистратор КАК Регистратор
	|ПОМЕСТИТЬ ВТ_Обороты
	|ИЗ
	|	ВТ_ОборотыВсеОперации КАК ВТ_ОборотыВсеОперации
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ОперацииЦБ КАК ОперацииЦБ
	|		ПО ВТ_ОборотыВсеОперации.Регистратор = ОперацииЦБ.Ссылка
	|ГДЕ
	|	ВЫБОР
	|			КОГДА ВТ_ОборотыВсеОперации.Регистратор ССЫЛКА Документ.ОперацииЦБ
	|					И НЕ ОперацииЦБ.ВидОперацииД В (&ДопустимыеВидыОпераций)
	|				ТОГДА ЛОЖЬ
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_Обороты.ЦБ КАК ЦБ,
	|	ВТ_Обороты.Регистратор КАК Регистратор,
	|	ВЫБОР
	|		КОГДА ВТ_Обороты.КоличествоПриход <> 0
	|				И (ВТ_Обороты.Регистратор ССЫЛКА Документ.КонвертацияЦБ
	|					ИЛИ ВТ_Обороты.Регистратор ССЫЛКА Документ.ГлобальнаяОперация
	|					ИЛИ ВТ_Обороты.Регистратор ССЫЛКА Документ.ОперацииЦБ
	|						И ОперацииЦБ.ВидОперацииД = ЗНАЧЕНИЕ(Справочник.ВидыОпераций.Депонирование))
	|			ТОГДА 1
	|		ИНАЧЕ 0
	|	КОНЕЦ КАК КолПриемЦБ,
	|	ВЫБОР
	|		КОГДА ВТ_Обороты.Регистратор ССЫЛКА Документ.КонвертацияЦБ
	|				ИЛИ ВТ_Обороты.Регистратор ССЫЛКА Документ.ГлобальнаяОперация
	|				ИЛИ ВТ_Обороты.Регистратор ССЫЛКА Документ.ОперацииЦБ
	|					И ОперацииЦБ.ВидОперацииД = ЗНАЧЕНИЕ(Справочник.ВидыОпераций.Депонирование)
	|			ТОГДА ВТ_Обороты.КоличествоПриход
	|		ИНАЧЕ 0
	|	КОНЕЦ КАК ОбПриемЦБ,
	|	ВЫБОР
	|		КОГДА ВТ_Обороты.КоличествоРасход <> 0
	|				И (ВТ_Обороты.Регистратор ССЫЛКА Документ.КонвертацияЦБ
	|					ИЛИ ВТ_Обороты.Регистратор ССЫЛКА Документ.ГлобальнаяОперация
	|					ИЛИ ВТ_Обороты.Регистратор ССЫЛКА Документ.ПогашениеЦБ
	|					ИЛИ ВТ_Обороты.Регистратор ССЫЛКА Документ.ОперацииЦБ
	|						И ОперацииЦБ.ВидОперацииД = ЗНАЧЕНИЕ(Справочник.ВидыОпераций.СнятиеСДепонирования))
	|			ТОГДА 1
	|		ИНАЧЕ 0
	|	КОНЕЦ КАК КолСнятиеЦБ,
	|	ВЫБОР
	|		КОГДА ВТ_Обороты.Регистратор ССЫЛКА Документ.КонвертацияЦБ
	|				ИЛИ ВТ_Обороты.Регистратор ССЫЛКА Документ.ГлобальнаяОперация
	|				ИЛИ ВТ_Обороты.Регистратор ССЫЛКА Документ.ПогашениеЦБ
	|				ИЛИ ВТ_Обороты.Регистратор ССЫЛКА Документ.ОперацииЦБ
	|					И ОперацииЦБ.ВидОперацииД = ЗНАЧЕНИЕ(Справочник.ВидыОпераций.СнятиеСДепонирования)
	|			ТОГДА ВТ_Обороты.КоличествоРасход
	|		ИНАЧЕ 0
	|	КОНЕЦ КАК ОбСнятиеЦБ,
	|	ВЫБОР
	|		КОГДА ВТ_Обороты.Регистратор ССЫЛКА Документ.ОперацииЦБ
	|				И ОперацииЦБ.ВидОперацииД = ЗНАЧЕНИЕ(Справочник.ВидыОпераций.Перевод)
	|				И ОперацииЦБ.Инициатор <> ОперацииЦБ.Получатель
	|			ТОГДА 1
	|		ИНАЧЕ 0
	|	КОНЕЦ КАК КолПереводЦБ,
	|	ВЫБОР
	|		КОГДА ВТ_Обороты.Регистратор ССЫЛКА Документ.ОперацииЦБ
	|				И ОперацииЦБ.ВидОперацииД = ЗНАЧЕНИЕ(Справочник.ВидыОпераций.Перевод)
	|				И ОперацииЦБ.Инициатор <> ОперацииЦБ.Получатель
	|			ТОГДА ВТ_Обороты.КоличествоПриход
	|		ИНАЧЕ 0
	|	КОНЕЦ КАК ОбПереводЦБ,
	|	ВЫБОР
	|		КОГДА ВТ_Обороты.Регистратор ССЫЛКА Документ.ГлобальнаяОперация
	|			ТОГДА ""ГлобальнаяОперация"" + ВЫРАЗИТЬ(ВТ_Обороты.Регистратор КАК Документ.ГлобальнаяОперация).Номер
	|		КОГДА ВТ_Обороты.Регистратор ССЫЛКА Документ.КонвертацияЦБ
	|			ТОГДА ""КонвертацияЦБ"" + ВЫРАЗИТЬ(ВТ_Обороты.Регистратор КАК Документ.КонвертацияЦБ).Номер
	|		КОГДА ВТ_Обороты.Регистратор ССЫЛКА Документ.ОперацииЦБ
	|			ТОГДА ""ОперацииЦБ"" + ВЫРАЗИТЬ(ВТ_Обороты.Регистратор КАК Документ.ОперацииЦБ).Номер
	|		КОГДА ВТ_Обороты.Регистратор ССЫЛКА Документ.ПогашениеЦБ
	|			ТОГДА ""ПогашениеЦБ"" + ВЫРАЗИТЬ(ВТ_Обороты.Регистратор КАК Документ.ПогашениеЦБ).Номер
	|	КОНЕЦ КАК СтрокаДляСортировки
	|ПОМЕСТИТЬ ВТ_ОборотыПоВидамОпераций
	|ИЗ
	|	ВТ_Обороты КАК ВТ_Обороты
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ОперацииЦБ КАК ОперацииЦБ
	|		ПО ВТ_Обороты.Регистратор = ОперацииЦБ.Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВсеЦБ.ЦБ КАК ЦБ
	|ПОМЕСТИТЬ ВТ_ЦБ
	|ИЗ
	|	(ВЫБРАТЬ
	|		ВТ_Обороты.ЦБ КАК ЦБ
	|	ИЗ
	|		ВТ_Обороты КАК ВТ_Обороты
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		ВТ_Остатки.ЦБ
	|	ИЗ
	|		ВТ_Остатки КАК ВТ_Остатки) КАК ВсеЦБ
	|
	|СГРУППИРОВАТЬ ПО
	|	ВсеЦБ.ЦБ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_Остатки.СчетДепо КАК СчетДепо
	|ПОМЕСТИТЬ ВТ_СчетаДепо
	|ИЗ
	|	ВТ_Остатки КАК ВТ_Остатки
	|
	|СГРУППИРОВАТЬ ПО
	|	ВТ_Остатки.СчетДепо
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_Остатки.СчетДепоМХ КАК СчетДепоМХ
	|ПОМЕСТИТЬ ВТ_СчетаДепоМХ
	|ИЗ
	|	ВТ_Остатки КАК ВТ_Остатки
	|
	|СГРУППИРОВАТЬ ПО
	|	ВТ_Остатки.СчетДепоМХ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_ЦБ.ЦБ КАК ЦБ,
	|	ВЫБОР
	|		КОГДА ВТ_ЦБ.ЦБ.ТипЦБ В (&ТипыДепозитарныхРасписок)
	|			ТОГДА ВТ_ЦБ.ЦБ.БазовыйАктив.Эмитент
	|		ИНАЧЕ ЦенныеБумаги.Эмитент
	|	КОНЕЦ КАК Эмитент
	|ПОМЕСТИТЬ ВТ_ЭмитентыЦБ
	|ИЗ
	|	ВТ_ЦБ КАК ВТ_ЦБ
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ЦенныеБумаги КАК ЦенныеБумаги
	|		ПО ВТ_ЦБ.ЦБ = ЦенныеБумаги.Ссылка
	|
	|СГРУППИРОВАТЬ ПО
	|	ВТ_ЦБ.ЦБ,
	|	ВЫБОР
	|		КОГДА ВТ_ЦБ.ЦБ.ТипЦБ В (&ТипыДепозитарныхРасписок)
	|			ТОГДА ВТ_ЦБ.ЦБ.БазовыйАктив.Эмитент
	|		ИНАЧЕ ЦенныеБумаги.Эмитент
	|	КОНЕЦ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_ЭмитентыЦБ.Эмитент КАК Эмитент
	|ПОМЕСТИТЬ ВТ_Эмитенты
	|ИЗ
	|	ВТ_ЭмитентыЦБ КАК ВТ_ЭмитентыЦБ
	|
	|СГРУППИРОВАТЬ ПО
	|	ВТ_ЭмитентыЦБ.Эмитент
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	КлиентыСУчетомНаСчетахТипаС.Клиент КАК Эмитент
	|ПОМЕСТИТЬ ВТ_ЭмитентыСУчетомНаСчетахТипаС
	|ИЗ
	|	РегистрСведений.КлиентыСУчетомНаСчетахТипаC.СрезПоследних(&ОтчетнаяДата, 1 = 1) КАК КлиентыСУчетомНаСчетахТипаС
	|ГДЕ
	|	КлиентыСУчетомНаСчетахТипаС.ФлагАктивности
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_Эмитенты.Эмитент КАК Эмитент,
	|	Контрагенты.Резидент КАК Нерезидент
	|ПОМЕСТИТЬ ВТ_РезидентствоЭмитентов
	|ИЗ
	|	ВТ_Эмитенты КАК ВТ_Эмитенты
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Контрагенты КАК Контрагенты
	|		ПО ВТ_Эмитенты.Эмитент = Контрагенты.Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_Эмитенты.Эмитент КАК Эмитент,
	|	МАКСИМУМ(КодыЗагрузки.Код) КАК LEI,
	|	КОЛИЧЕСТВО(*) КАК КоличествоLEI
	|ПОМЕСТИТЬ ВТ_КодыLEI
	|ИЗ
	|	ВТ_Эмитенты КАК ВТ_Эмитенты
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Контрагенты КАК Контрагенты
	|		ПО ВТ_Эмитенты.Эмитент = Контрагенты.Ссылка
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_РезидентствоЭмитентов КАК ВТ_РезидентствоЭмитентов
	|		ПО ВТ_Эмитенты.Эмитент = ВТ_РезидентствоЭмитентов.Эмитент
	|			И (ВТ_РезидентствоЭмитентов.Нерезидент)
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ЮридическиеЛица КАК ЮридическиеЛица
	|		ПО (Контрагенты.ЮридическиеФизическиеЛица = ЮридическиеЛица.Ссылка)
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.КодыЗагрузки КАК КодыЗагрузки
	|		ПО (ЮридическиеЛица.Ссылка = КодыЗагрузки.Владелец)
	|			И (КодыЗагрузки.Биржа = ЗНАЧЕНИЕ(Справочник.КлассификаторыЗагрузки.LEI_Code))
	|			И (НЕ КодыЗагрузки.ПометкаУдаления)
	|			И (КодыЗагрузки.ДатаОкончанияДействия = ДАТАВРЕМЯ(1, 1, 1)
	|				ИЛИ КодыЗагрузки.ДатаОкончанияДействия > &ПериодКонец)
	|
	|СГРУППИРОВАТЬ ПО
	|	ВТ_Эмитенты.Эмитент
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЮридическиеЛица.ИНН КАК ИНН
	|ПОМЕСТИТЬ ВТ_ИНН
	|ИЗ
	|	ВТ_Эмитенты КАК ВТ_Эмитенты
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Контрагенты КАК Контрагенты
	|		ПО ВТ_Эмитенты.Эмитент = Контрагенты.Ссылка
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ЮридическиеЛица КАК ЮридическиеЛица
	|		ПО (Контрагенты.ЮридическиеФизическиеЛица = ЮридическиеЛица.Ссылка)
	|			И ЮридическиеЛица.ИНН <> """"
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	МестаХранения.ИНН КАК ИНН
	|ИЗ
	|	ВТ_СчетаДепоМХ КАК ВТ_СчетаДепоМХ
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.СчетаДепоМХ КАК СчетаДепоМХ
	|			ПО ВТ_СчетаДепоМХ.СчетДепоМХ = СчетаДепоМХ.Ссылка
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.МестаХранения КАК МестаХранения
	|			ПО (СчетаДепоМХ.Владелец = МестаХранения.Ссылка)
	|				И МестаХранения.ИНН <> """"
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЮридическиеЛицаЦБРФСрезПоследних.Период КАК Период,
	|	ЮридическиеЛицаЦБРФСрезПоследних.ИНН КАК ИНН,
	|	ЮридическиеЛицаЦБРФСрезПоследних.ОГРН КАК ОГРН,
	|	ЮридическиеЛицаЦБРФСрезПоследних.Наименование КАК Наименование
	|ПОМЕСТИТЬ ВТ_ЮридическиеЛицаЦБРФ
	|ИЗ
	|	РегистрСведений.ЮридическиеЛицаЦБРФ.СрезПоследних(
