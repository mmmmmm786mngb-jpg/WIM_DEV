	ИндексСедьмогоЗапросаСКонца = ИндексШестогоЗапросаСКонца - 1;
	
	ОписаниеОшибок = "";
	ПроверитьДанныеМестХранения(РезультатПакета[ИндексЧетвертогоЗапросаСКонца].Выгрузить());
	ПроверитьДанныеЭмитентов(РезультатПакета[ИндексПятогоЗапросаСКонца].Выгрузить());
	ПроверитьДанныеСчетовДЕПО(РезультатПакета[ИндексШестогоЗапросаСКонца].Выгрузить());
	ПроверитьДанныеЦБ(РезультатПакета[ИндексСедьмогоЗапросаСКонца].Выгрузить());
	
	ДанныеПодраздела_1_2.Загрузить(РезультатПакета[ИндексТретьегоЗапросаСКонца].Выгрузить());
	РегуляторнаяОтчетность.ПронумероватьСтроки(ДанныеПодраздела_1_2);
	ДанныеПодраздела_1_2_1.Загрузить(РезультатПакета[ИндексВторогоЗапросаСКонца].Выгрузить());
	РегуляторнаяОтчетность.ПронумероватьСтроки(ДанныеПодраздела_1_2_1);
	ДанныеДляРасшифровки = РезультатПакета[ИндексПоследнегоЗапроса].Выгрузить();
	РегуляторнаяОтчетность.ПронумероватьСтроки(ДанныеДляРасшифровки);	
КонецПроцедуры
// BSLLS:MethodSize-on

// Процедура выгружает сформированный отчет (данные в табличных частях отчета) в XML-файл
Процедура ВыгрузитьВXML() Экспорт
	ИмяФормы = "0409711";
	ПространствоИмен = "urn:cbr-ru:rep0409711:v6.0.4.5";
	
	// Осторожно! Схема хранимая в конфигурации модифицирована по сравнению с оригинальной:
	//	в разделах "Ф0409711Данные711Подраздел1.2ЦБнаСчДепо" и "Ф0409711Данные711Подраздел1.2.1ДепОперЦБ"
	//	тип атрибутов Десят30.20Неотриц-лок заменен "Строка38-лок"
	// Это потребовалось, чтобы все числа можно было выгрузить в файл дополненными до 20 нулей после запятой (см. NRB-629)
	СхемаXSD = ПолучитьМакет("Ф711_Schema_XSD");
	Фабрика = РегуляторнаяОтчетность.ФабрикаИзСхемыXSD(СхемаXSD);
	Отчетность = Фабрика.Создать(Фабрика.Тип(ПространствоИмен, "Ф0409711"));
	
	УникИдОЭС = Новый УникальныйИдентификатор;
	Отчетность.УникИдОЭС = Строка(УникИдОЭС);	// Пример: "8b91f09d-da8b-11ed-811d-00155d1a3509";
	Отчетность.ВидОтчета = "КО";
	Отчетность.КодФормы = ИмяФормы;
	Отчетность.ОКУД = ИмяФормы;
	Отчетность.ВидОЭС = "Отчетность КО";
	Отчетность.Периодичность = "месячная";
	Отчетность.ДатаВремяФормирования = ТекущаяДатаСеанса();
	// BSLLS:Typo-off
	Отчетность.ОтчДата = ОтчетнаяДата;
	// BSLLS:Typo-on
	
	Отчетность.Составитель = СоставительОтчета(Фабрика, ПространствоИмен);
	
	Отчетность.Данные711 = Данные711(Фабрика, ПространствоИмен);
	
	РегуляторнаяОтчетность.ЗаписатьОтчетностьДляДельтыВXML(Фабрика, Отчетность, ИмяФормы, ПериодНачало, ПериодКонец);
КонецПроцедуры

#КонецОбласти


#Область СлужебныеПроцедурыИФункции

// Процедура осуществляет проверку данных эмитентов, упомянутых в отчете на соответествие схеме XSD.
// Например, проверяется ожидаемая длинна и состав символов ИНН и ОГРН ...
// Параметры:
//	ДанныеЭмитентов - ТаблицаЗначений
Процедура ПроверитьДанныеЭмитентов(ДанныеЭмитентов)
	ДлиныИНН = РегуляторнаяОтчетность.ДопустимыеДлиныИНН();
	ДлиныОГРН = РегуляторнаяОтчетность.ДопустимыеДлиныОГРН();
	
	Для каждого Данные Из ДанныеЭмитентов Цикл
		
		Если НЕ ЗначениеЗаполнено(Данные.ЮридическиеФизическиеЛица) Тогда
			ОписаниеОшибки = "Для эмитента " + Строка(Данные.Эмитент) + " не указано юридическое/физическое лицо";
			РегуляторнаяОтчетность.ДобавитьОписаниеОшибки(ОписаниеОшибок, ОписаниеОшибки);
		КонецЕсли;
		Принадлежность = "эмитента";
		РегуляторнаяОтчетность.ПроверитьЦифровуюСтроку(ОписаниеОшибок, "ИНН", Принадлежность, Данные.ИНН_Эм, Данные.Эмитент, ДлиныИНН);
		РегуляторнаяОтчетность.ПроверитьЦифровуюСтроку(ОписаниеОшибок, "ОГРН", Принадлежность, Данные.ОГРН_Эм, Данные.Эмитент, ДлиныОГРН);
		РегуляторнаяОтчетность.ПроверитьЦифровуюСтроку(ОписаниеОшибок, "Код страны", Принадлежность, Данные.КодСтрЭм, Данные.Эмитент, 3);
		Если Данные.ПризнакКодаЭмНерез = "LEI" И Данные.КоличествоLEI > 1 Тогда
			ОписаниеОшибки = "Для эмитента " + Строка(Данные.Эмитент) + " в справочнике кодов загрузки имеется более одного действующего кода LEI";
			РегуляторнаяОтчетность.ДобавитьОписаниеОшибки(ОписаниеОшибок, ОписаниеОшибки);
		КонецЕсли;
		Если Данные.НетСоотвествияИННДляЦБРФ Тогда
			ОписаниеОшибки = "Для ЮЛ [" + Строка(Данные.Эмитент) + "] не найдено соответствие в справочнике ИНН и ОРГН ЦБ РФ";
			РегуляторнаяОтчетность.ДобавитьОписаниеОшибки(ОписаниеОшибок, ОписаниеОшибки);
		КонецЕсли;
		Если Данные.ИНН_Эм = "0000000000" Тогда
			ОписаниеОшибки = "У эмитента " + Строка(Данные.Эмитент) + " отсутствует ИНН";
			РегуляторнаяОтчетность.ДобавитьОписаниеОшибки(ОписаниеОшибок, ОписаниеОшибки);
		КонецЕсли;
		Если Данные.ЭтоРезидентИлиНерезидентМК И Данные.ОГРН_Эм = "" Тогда
			ОписаниеОшибки = "У эмитента " + Строка(Данные.Эмитент) + " отсутствует ОГРН";
			РегуляторнаяОтчетность.ДобавитьОписаниеОшибки(ОписаниеОшибок, ОписаниеОшибки);
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

Процедура ПроверитьДанныеЦБ(ДанныеЦБ)
	Для каждого Данные Из ДанныеЦБ Цикл
		Если Не Данные.ЦББезНоминала Тогда
			Если Не ЗначениеЗаполнено(Данные.НомСтоимЦБ) Тогда
				ОписаниеОшибки = РегуляторнаяОтчетность.ОписаниеОшибкиЦБ(Данные.ЦБ, "не указан номинал", Данные.ISIN);
				РегуляторнаяОтчетность.ДобавитьОписаниеОшибки(ОписаниеОшибок, ОписаниеОшибки);
			КонецЕсли;
			Если Не ЗначениеЗаполнено(Данные.ВалютаНоминала) Тогда
				ОписаниеОшибки = РегуляторнаяОтчетность.ОписаниеОшибкиЦБ(Данные.ЦБ, "не указана валюта номинала", Данные.ISIN);
				РегуляторнаяОтчетность.ДобавитьОписаниеОшибки(ОписаниеОшибок, ОписаниеОшибки);
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

Процедура ПроверитьДанныеМестХранения(ДанныеМестХранения)
	Для каждого Данные Из ДанныеМестХранения Цикл
		Принадлежность = "места хранения";
		РегуляторнаяОтчетность.ПроверитьЦифровуюСтроку(ОписаниеОшибок, "ИНН", Принадлежность, Данные.ИНН_Орг, Данные.МестоХранения, 10);
		РегуляторнаяОтчетность.ПроверитьЦифровуюСтроку(ОписаниеОшибок, "ОГРН", Принадлежность, Данные.ОГРН_Орг, Данные.МестоХранения, 13);
		РегуляторнаяОтчетность.ПроверитьЦифровуюСтроку(ОписаниеОшибок, "Код страны", Принадлежность, Данные.КодСтр_Орг, Данные.МестоХранения, 3);
	КонецЦикла;
КонецПроцедуры

Процедура ПроверитьДанныеСчетовДЕПО(ДанныеСчетовДЕПО)
	Для каждого Данные Из ДанныеСчетовДЕПО Цикл
		Если Данные.КодСтрВладельца <> "643" И Данные.КодСекторЭк <> "S2" Тогда
			ОписаниеОшибки = "У владельца счета ДЕПО " + СокрЛП(Строка(Данные.СчетДепо)) + " (" + Строка(Данные.СчетДепо.Владелец) + ") "
								+ " код страны " + Строка(Данные.КодСтрВладельца) + ", а код сектора экономики при этом " + Строка(Данные.КодСекторЭк);
			РегуляторнаяОтчетность.ДобавитьОписаниеОшибки(ОписаниеОшибок, ОписаниеОшибки);
		КонецЕсли;
		Если Не ЗначениеЗаполнено(Данные.КодСекторЭк) Тогда
			ОписаниеОшибки = "У депонента [" + СокрЛП(Данные.СчетДепо.Владелец.Код) + "] [" + Строка(Данные.СчетДепо.Владелец) + "] "
								+ " не заполнен Тип депонента (Сектор экономики)";
			РегуляторнаяОтчетность.ДобавитьОписаниеОшибки(ОписаниеОшибок, ОписаниеОшибки);
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

Функция СоставительОтчета(Фабрика, ПространствоИмен)
	Составитель = Фабрика.Создать(Фабрика.Тип(ПространствоИмен, "Ф0409711Составитель"));
	
	Составитель.Руководитель = Фабрика.Создать(Фабрика.Тип(ПространствоИмен, "Ф0409711СоставительРуководитель"));
	РегуляторнаяОтчетность.ЗаполнитьИнформациюОбОтветственномЛице(Составитель.Руководитель, Организация,
								Перечисления.ОтветственныеЛицаОрганизаций.Руководитель, ОтчетнаяДата);
	
	Составитель.Исполнитель = Фабрика.Создать(Фабрика.Тип(ПространствоИмен, "Ф0409711СоставительИсполнитель"));
	РегуляторнаяОтчетность.ЗаполнитьИнформациюОбОтветственномЛице(Составитель.Исполнитель, Организация,
								Перечисления.ОтветственныеЛицаОрганизаций.Исполнитель, ОтчетнаяДата);
	
	РегуляторнаяОтчетность.ЗаполнитьИнформациюОбОрганизации(Составитель, Организация, ОтчетнаяДата);
	
	Возврат Составитель;
КонецФункции

Функция Данные711(Фабрика, ПространствоИмен)
	Данные711 = Фабрика.Создать(Фабрика.Тип(ПространствоИмен, "Ф0409711Данные711"));
	Данные711.Ид = "1";
	Данные711.ДатаОперДня = НачалоДня(ТекущаяДатаСеанса());
	
	Данные711.Подраздел1_2 = Подраздел1_2(Фабрика, ПространствоИмен);
	Данные711.Подраздел1_2_1 = Подраздел1_2_1(Фабрика, ПространствоИмен);
	
	Возврат Данные711;
КонецФункции

Функция Подраздел1_2(Фабрика, ПространствоИмен)
	Подраздел1_2 = Фабрика.Создать(Фабрика.Тип(ПространствоИмен, "Ф0409711Данные711Подраздел1.2"));
	
	// BSLLS:Typo-off
	СписокРеквизитовСЧислами20Знаков = "НомСтоимЦБ,КолЦБ,КЦБОбремВсего,КЦБОбремВЗалоге,КЦБОбремСчДепо,КЦБОбремКорпДейст"
										+ ",КЦБОбремЗапретОп,КЦБСчетЭскроуАг,КЦБОбремАрест";
	// BSLLS:Typo-on
	РеквизитыСЧислами6Знаков = СтрРазделить(СписокРеквизитовСЧислами20Знаков, ",");
	
	Для каждого СтрокаТЧ Из ДанныеПодраздела_1_2 Цикл
		
		// BSLLS:Typo-off
		СтрокаПодраздела = Фабрика.Создать(Фабрика.Тип(ПространствоИмен, "Ф0409711Данные711Подраздел1.2ЦБнаСчДепо"));
		// BSLLS:Typo-on
		
		ЗаполнитьОбщиеДляПодразделовРеквизиты(СтрокаПодраздела, СтрокаТЧ);
		
		// Осторожно! Схема хранимая в конфигурации модифицирована по сравнению с оригинальной:
		//	в разделах "Ф0409711Данные711Подраздел1.2ЦБнаСчДепо" и "Ф0409711Данные711Подраздел1.2.1ДепОперЦБ"
		//	тип атрибутов Десят30.20Неотриц-лок заменен "Строка30-лок"
		// Это потребовалось, чтобы все числа можно было выгрузить в файл дополненными до 6 нулей после запятой (см. NRB-279)
		ЗаполнитьРеквизитыВФормате6ЗнаковПослеЗапятой(СтрокаПодраздела, СтрокаТЧ, РеквизитыСЧислами6Знаков);
		
		РегуляторнаяОтчетность.ПрисвоитьНепустое(СтрокаПодраздела.КодВалК, СтрокаТЧ.КодВалК);
		РегуляторнаяОтчетность.ПрисвоитьНепустое(СтрокаПодраздела.ВидСчета, СтрокаТЧ.ВидСчета);
		РегуляторнаяОтчетность.ПрисвоитьНепустое(СтрокаПодраздела.КодСекторЭк, СтрокаТЧ.КодСекторЭк);
		РегуляторнаяОтчетность.ПрисвоитьНепустое(СтрокаПодраздела.КодСтрВладельца, СтрокаТЧ.КодСтрВладельца);
		РегуляторнаяОтчетность.ПрисвоитьНепустое(СтрокаПодраздела.ПризнакОргЮЛ, СтрокаТЧ.ПризнакОргЮЛ);
		РегуляторнаяОтчетность.ПрисвоитьНепустое(СтрокаПодраздела.НаимОрг, СтрокаТЧ.НаимОрг);
		РегуляторнаяОтчетность.ПрисвоитьНепустое(СтрокаПодраздела.ПризнакОрг, СтрокаТЧ.ПризнакОрг);
		РегуляторнаяОтчетность.ПрисвоитьНепустое(СтрокаПодраздела.ИНН_Орг, СтрокаТЧ.ИНН_Орг);
		РегуляторнаяОтчетность.ПрисвоитьНепустое(СтрокаПодраздела.ПризнакКодаОргНерез, СтрокаТЧ.ПризнакКодаОргНерез);
		РегуляторнаяОтчетность.ПрисвоитьНепустое(СтрокаПодраздела.TIN_Орг, СтрокаТЧ.TIN_Орг);
		РегуляторнаяОтчетность.ПрисвоитьНепустое(СтрокаПодраздела.ОГРН_Орг, СтрокаТЧ.ОГРН_Орг);
		РегуляторнаяОтчетность.ПрисвоитьНепустое(СтрокаПодраздела.КодСтр_Орг, СтрокаТЧ.КодСтр_Орг);
		
		Подраздел1_2.ЦБнаСчДепо.Добавить(СтрокаПодраздела);
	КонецЦикла;
	
	Возврат Подраздел1_2;
КонецФункции

Функция Подраздел1_2_1(Фабрика, ПространствоИмен)
	Подраздел1_2_1 = Фабрика.Создать(Фабрика.Тип(ПространствоИмен, "Ф0409711Данные711Подраздел1.2.1"));
	РеквизитыСЧислами = "КолПриемЦБ, КолСнятиеЦБ, КолПереводЦБ";
	СписокРеквизитовСЧислами20Знаков = "НомСтоимЦБ,ОбПриемЦБ,ОбСнятиеЦБ,ОбПереводЦБ";
	РеквизитыСЧислами6Знаков = СтрРазделить(СписокРеквизитовСЧислами20Знаков, ",");
	
	Для каждого СтрокаТЧ Из ДанныеПодраздела_1_2_1 Цикл
		СтрокаДепОперЦБ = Фабрика.Создать(Фабрика.Тип(ПространствоИмен, "Ф0409711Данные711Подраздел1.2.1ДепОперЦБ"));
		ЗаполнитьОбщиеДляПодразделовРеквизиты(СтрокаДепОперЦБ, СтрокаТЧ);
		ЗаполнитьЗначенияСвойств(СтрокаДепОперЦБ, СтрокаТЧ, РеквизитыСЧислами);
		
		// Осторожно! Схема хранимая в конфигурации модифицирована по сравнению с оригинальной:
		//	в разделах "Ф0409711Данные711Подраздел1.2ЦБнаСчДепо" и "Ф0409711Данные711Подраздел1.2.1ДепОперЦБ"
		//	тип атрибутов Десят30.20Неотриц-лок заменен "Строка30-лок"
		// Это потребовалось, чтобы все числа можно было выгрузить в файл дополненными до 6 нулей после запятой (см. NRB-279)
		ЗаполнитьРеквизитыВФормате6ЗнаковПослеЗапятой(СтрокаДепОперЦБ, СтрокаТЧ, РеквизитыСЧислами6Знаков);
		
		РегуляторнаяОтчетность.ПрисвоитьНепустое(СтрокаДепОперЦБ.КодВал, СтрокаТЧ.КодВал);
		Подраздел1_2_1.ДепОперЦБ.Добавить(СтрокаДепОперЦБ);
	КонецЦикла;
	
	Возврат Подраздел1_2_1;
КонецФункции

Процедура ЗаполнитьОбщиеДляПодразделовРеквизиты(СтруктураXDTO, СтрокаТЧ)
	СтруктураXDTO.НомСтр = Формат(СтрокаТЧ.НомСтр, "ЧГ=0");
	
	РегуляторнаяОтчетность.ПрисвоитьНепустое(СтруктураXDTO.ПризнакЭм, СтрокаТЧ.ПризнакЭм);
	РегуляторнаяОтчетность.ПрисвоитьНепустое(СтруктураXDTO.НаименованиеЭм, СтрокаТЧ.НаименованиеЭм);
	РегуляторнаяОтчетность.ПрисвоитьНепустое(СтруктураXDTO.ИНН_Эм, СтрокаТЧ.ИНН_Эм);
	РегуляторнаяОтчетность.ПрисвоитьНепустое(СтруктураXDTO.ПризнакКодаЭмНерез, СтрокаТЧ.ПризнакКодаЭмНерез);
	РегуляторнаяОтчетность.ПрисвоитьНепустое(СтруктураXDTO.TIN_Эм, СтрокаТЧ.TIN_Эм);
	РегуляторнаяОтчетность.ПрисвоитьНепустое(СтруктураXDTO.ОГРН_Эм, СтрокаТЧ.ОГРН_Эм);
	РегуляторнаяОтчетность.ПрисвоитьНепустое(СтруктураXDTO.КодСтрЭм, СтрокаТЧ.КодСтрЭм);
	РегуляторнаяОтчетность.ПрисвоитьНепустое(СтруктураXDTO.КодТипаЦБ, СтрокаТЧ.КодТипаЦБ);
	РегуляторнаяОтчетность.ПрисвоитьНепустое(СтруктураXDTO.НомРегЦБ, СтрокаТЧ.НомРегЦБ);
	РегуляторнаяОтчетность.ПрисвоитьНепустое(СтруктураXDTO.ISIN, СтрокаТЧ.ISIN);
	РегуляторнаяОтчетность.ПрисвоитьНепустое(СтруктураXDTO.CFI, СтрокаТЧ.CFI);
КонецПроцедуры

Процедура ЗаполнитьРеквизитыВФормате6ЗнаковПослеЗапятой(СтруктураXDTO, СтрокаТЧ, РеквизитыСЧислами6Знаков)
	ФорматЧисла = "ЧЦ=38; ЧДЦ=20; ЧРД=.; ЧН=; ЧГ=";
	Для Каждого ИмяРеквизита Из РеквизитыСЧислами6Знаков Цикл
		Если ИмяРеквизита <> "НомСтоимЦБ" Или ЗначениеЗаполнено(СтрокаТЧ.НомСтоимЦБ) Тогда
			СтруктураXDTO[ИмяРеквизита] = Формат(СтрокаТЧ[ИмяРеквизита], ФорматЧисла);
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

