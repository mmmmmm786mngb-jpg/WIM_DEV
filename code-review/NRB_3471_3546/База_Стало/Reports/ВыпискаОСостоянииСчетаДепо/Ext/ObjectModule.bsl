// ВСПОМОГАТЕЛЬНЫЕ ФУНКЦИИ

Функция ИмяМакета(ОтчетНаАнглийскомЯзыке, ДатаМакета)
	
	ЗначениеПоУмолчанию = ДАТА(1, 1, 1);
	ДатаПереходаНаПечатнуюФорму2026 =
		РегистрыСведений.ПараметрыГлобальные.ЗначениеПараметра("3490.ДатаПереходаНаПечатныеФормыВыписок2026",
			ЗначениеПоУмолчанию);
	
	Если ДатаМакета >= ДатаПереходаНаПечатнуюФорму2026 Тогда
		ИмяМакета = "Макет2026";
	Иначе
		ИмяМакета = "Макет2017";
	КонецЕсли;
	
	Если ОтчетНаАнглийскомЯзыке Тогда
		ИмяМакета = ИмяМакета + "en";
	КонецЕсли;
	
	Возврат ИмяМакета;
КонецФункции

Функция СформироватьЗапрос(ДатаВыписки, ПозицияВыпискиОперационныйДень, СчетДепо, Ошибка)
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	ОстаткиЦБ.РазделСчетаДепо КАК РазделСчетаДепо,
	|	ОстаткиЦБ.СчетДепоМХ КАК СчетДепоМХ,
	|	ОстаткиЦБ.СчетДепоМХ.Владелец.КодМестаХранения КАК СчетДепоМХНаименование,
	|	ОстаткиЦБ.РазделСчетаДепоМХ КАК РазделСчетаДепоМХ,
	|	ПРЕДСТАВЛЕНИЕ(ОстаткиЦБ.РазделСчетаДепоМХ) КАК РазделСчетаДепоМХПредставление,
	|	ОстаткиЦБ.СтатусЦБ КАК СтатусЦБ,
	|	ОстаткиЦБ.КоличествоОстаток КАК КоличествоОстаток,
	|	ВЫБОР
	|		КОГДА ОстаткиЦБ.СтатусЦБ = &Свободна
	|			ТОГДА ОстаткиЦБ.КоличествоОстаток
	|		ИНАЧЕ 0
	|	КОНЕЦ КАК СвободныйОстаток,
	|	ВЫБОР
	|		КОГДА ОстаткиЦБ.СтатусЦБ В (&СтатусыОбременена)
	|			ТОГДА ОстаткиЦБ.КоличествоОстаток
	|		ИНАЧЕ 0
	|	КОНЕЦ КАК ОбремененныйОстаток,
	|	ОстаткиЦБ.ЦБ КАК ЦБ,
	|	ОстаткиЦБ.ЦБ.ВалютаНоминала КАК ВалютаНоминала,
	|	ЕСТЬNULL(НоминалЦБ.Сумма, 0) КАК Номинал
	|ИЗ
	|	РегистрНакопления.ОстаткиЦБ.Остатки(
	|			&Дата,
	|			СчетДепо = &СчетДепо И &УсловияОтбора) КАК ОстаткиЦБ
	|	ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.НоминалЦБ.СрезПоследних(&Дата) КАК НоминалЦБ 
	|		ПО ОстаткиЦБ.ЦБ = НоминалЦБ.ЦеннаяБумага
	|УПОРЯДОЧИТЬ ПО
	|	РазделСчетаДепо,
	|	СчетДепоМХ,
	|	РазделСчетаДепоМХ,
	|	ЦБ
	|ИТОГИ ПО
	|	РазделСчетаДепо,
	|	СчетДепоМХ,
	|	РазделСчетаДепоМХ");
	
	СтатусыОбременена = Новый Массив;
	СтатусыОбременена.Добавить(Перечисления.СтатусыЦБ.Обременена);
	СтатусыОбременена.Добавить(Перечисления.СтатусыЦБ.Блокирована);
	СтатусыОбременена.Добавить(Перечисления.СтатусыЦБ.Заложена);
	
	Запрос.УстановитьПараметр("Дата",		КонецДня(ДатаВыписки) - ?(ПозицияВыпискиОперационныйДень = 1, 24 * 60 * 60, 0));
	Запрос.УстановитьПараметр("СчетДепо",	СчетДепо);
	Запрос.УстановитьПараметр("Свободна",	Перечисления.СтатусыЦБ.Свободна);
	Запрос.УстановитьПараметр("СтатусыОбременена",	СтатусыОбременена);
	ЗаполнитьПараметрыЗапросаПоОтборуСКД(Запрос, Ошибка);
	Если ЗначениеЗаполнено(Ошибка) Тогда
		Возврат Неопределено;
	Иначе
		Возврат Запрос.Выполнить();
	КонецЕсли;
	
КонецФункции

Процедура ЗаполнитьПараметрыЗапросаПоОтборуСКД(Запрос, Ошибка)
	
	СравнениеЭмитент	= "(ЦБ.Эмитент ВидСравнения (&Эмитент)	ИЛИ &НеПроверятьЭмитента)";
	СравнениеЦБ			= "(ЦБ ВидСравнения (&ЦБ)				ИЛИ &НеПроверятьЦБ)";
	
	СписокЭмитентов		= Новый СписокЗначений;
	СписокЦБ			= Новый СписокЗначений;
	
	ЭлементыОтбора = КомпоновщикНастроек.Настройки.Отбор.Элементы;
	Для Каждого ЭлементОтбора Из ЭлементыОтбора Цикл
		ЛевоеЗначение = СокрЛП(ЭлементОтбора.ЛевоеЗначение);
		Если ЭлементОтбора.Использование Тогда
			МаскаУсловия = МаскаУсловия(ЭлементОтбора.ВидСравнения);
			Если НЕ ЗначениеЗаполнено(МаскаУсловия) Тогда
				Ошибка = "Неверный вид сравнения в отборе.";
				Возврат;
			КонецЕсли;
			
			Если ЛевоеЗначение = "ЦенныеБумаги" Тогда
				СравнениеЦБ = УсловиеСравнения(СравнениеЦБ, Запрос, МаскаУсловия, ЭлементОтбора, "ЦБ",
					Справочники.ЦенныеБумаги.ПустаяСсылка(), "НеПроверятьЦБ", "ЦБ");
				
			ИначеЕсли ЛевоеЗначение = "Эмитенты" Тогда
				СравнениеЭмитент = УсловиеСравнения(СравнениеЭмитент, Запрос, МаскаУсловия, ЭлементОтбора, "ЦБ.Эмитент",
					Справочники.Контрагенты.ПустаяСсылка(), "НеПроверятьЭмитента", "Эмитент");
			КонецЕсли;
		Иначе
			Если ЛевоеЗначение = "ЦенныеБумаги" Тогда
				СравнениеЦБ	= СтрЗаменить(СравнениеЦБ, "ВидСравнения", "В");
				Запрос.УстановитьПараметр("ЦБ",				СписокЦБ);
				Запрос.УстановитьПараметр("НеПроверятьЦБ",	Истина);
			
			ИначеЕсли ЛевоеЗначение = "Эмитенты" Тогда
				СравнениеЭмитент = СтрЗаменить(СравнениеЭмитент, "ВидСравнения", "В");
				Запрос.УстановитьПараметр("Эмитент",				СписокЭмитентов);
				Запрос.УстановитьПараметр("НеПроверятьЭмитента",	Истина);
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
	УсловияОтбора = "" + СравнениеЦБ + Символы.ПС
					+ " И " + СравнениеЭмитент;
	
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловияОтбора", УсловияОтбора);
	
КонецПроцедуры

Функция МаскаУсловия(ВидСравнения)
	
	Если ВидСравнения = ВидСравненияКомпоновкиДанных.Равно
			ИЛИ ВидСравнения = ВидСравненияКомпоновкиДанных.ВИерархии
			ИЛИ ВидСравнения = ВидСравненияКомпоновкиДанных.ВСписке
			ИЛИ ВидСравнения = ВидСравненияКомпоновкиДанных.ВСпискеПоИерархии Тогда
		МаскаУсловия = "В ИЕРАРХИИ";
	ИначеЕсли ВидСравнения = ВидСравненияКомпоновкиДанных.НеРавно
			ИЛИ ВидСравнения = ВидСравненияКомпоновкиДанных.НеВИерархии
			ИЛИ ВидСравнения = ВидСравненияКомпоновкиДанных.НеВСписке
			ИЛИ ВидСравнения = ВидСравненияКомпоновкиДанных.НеВСпискеПоИерархии Тогда
		МаскаУсловия = "НЕ В ИЕРАРХИИ";
	ИначеЕсли ВидСравнения = ВидСравненияКомпоновкиДанных.Заполнено Тогда
		МаскаУсловия = "НЕ ЕСТЬ NULL";
	ИначеЕсли ВидСравнения = ВидСравненияКомпоновкиДанных.НеЗаполнено Тогда
		МаскаУсловия = "ЕСТЬ NULL";
	Иначе
		МаскаУсловия = "";
	КонецЕсли;
	Возврат МаскаУсловия;
	
КонецФункции

Функция УсловиеСравнения(ТекстСравнения, Запрос, МаскаУсловия, эл, ИмяПоля,	ПустаяСсылка, НеПроверятьПоле, ИмяПараметра)
	
	Если МаскаУсловия = "НЕ ЕСТЬ NULL" Тогда
		ТекстСравнения	= "(НЕ %ИмяПоля ЕСТЬ NULL
			| ИЛИ НЕ %ИмяПоля = НЕОПРЕДЕЛЕНО
			| ИЛИ НЕ %ИмяПоля = &%ПустаяСсылка
			| ИЛИ &%НеПроверятьПоле)";
		ТекстСравнения = СтрЗаменить(ТекстСравнения, "%ИмяПоля", ИмяПоля);
		ТекстСравнения = СтрЗаменить(ТекстСравнения, "%ПустаяСсылка", ИмяПараметра + "ПустаяСсылка");
		Запрос.УстановитьПараметр(ИмяПараметра + "ПустаяСсылка", ПустаяСсылка);
		ТекстСравнения = СтрЗаменить(ТекстСравнения, "%НеПроверятьПоле", НеПроверятьПоле);
	ИначеЕсли  МаскаУсловия = "ЕСТЬ NULL" Тогда
		ТекстСравнения	= "(%ИмяПоля ЕСТЬ NULL
			| ИЛИ %ИмяПоля = НЕОПРЕДЕЛЕНО
			| ИЛИ %ИмяПоля = &%ПустаяСсылка
			| ИЛИ &%НеПроверятьПоле)";
		ТекстСравнения = СтрЗаменить(ТекстСравнения, "%ИмяПоля", ИмяПоля);
		ТекстСравнения = СтрЗаменить(ТекстСравнения, "%ПустаяСсылка", ИмяПараметра + "ПустаяСсылка");
		Запрос.УстановитьПараметр(ИмяПараметра + "ПустаяСсылка", ПустаяСсылка);
		ТекстСравнения = СтрЗаменить(ТекстСравнения, "%НеПроверятьПоле", НеПроверятьПоле);
	Иначе
		ТекстСравнения = СтрЗаменить(ТекстСравнения, "ВидСравнения", МаскаУсловия);
	КонецЕсли;
	Запрос.УстановитьПараметр(ИмяПараметра,		эл.ПравоеЗначение);
	Запрос.УстановитьПараметр(НеПроверятьПоле,	Ложь);
	Возврат ТекстСравнения;
	
КонецФункции

Процедура ЗаполнитьПараметрыШапки(ПараметрыШапки, ИмяМакета, ИмяСекции, ДатаМакета, ОтчетНаАнглийскомЯзыке)
	
	ФормированиеПечатныхФорм.УстановитьЗаголовкиСекцииМакета(ПараметрыШапки, ИмяМакета, ИмяСекции,
		мТекстыЗаголовков, СчетДепо.ВидСчетаДепо);
	
	Если СтрНайти(ИмяМакета, "Макет2017") > 0 Тогда
		Инфо = ФормированиеПечатныхФорм.ИнформацияОДепозитарии(ДатаВыписки, СчетДепо.ВидСчетаДепо) + Символы.ПС
			+ Символы.ПС + ФормированиеПечатныхФорм.ИнформацияОДепозитарииНаАнглийском(ДатаВыписки, СчетДепо.ВидСчетаДепо);
		ПараметрыШапки.ИнформацияОДепозитарии = Инфо;
	КонецЕсли;
	
	ПараметрыШапки.ТипОперации = ТипОперации(СчетДепо.ВидСчетаДепо, "Русский");
	Если ОтчетНаАнглийскомЯзыке Тогда
		ПараметрыШапки.ТипОперацииНаАнглийском = ТипОперации(СчетДепо.ВидСчетаДепо, "Английский");
	КонецЕсли;
	
	Если ВидЗапроса = "Депонентов" Тогда
		Если ЗначениеЗаполнено(Выписка) И ЗначениеЗаполнено(Выписка.ДокументОснование) И (ЗначениеЗаполнено(Выписка.ДокументОснование.Инициатор)
			И (ТипЗнч(Выписка.ДокументОснование.Инициатор) = Тип("СправочникСсылка.Контрагенты")
			ИЛИ ТипЗнч(Выписка.ДокументОснование.Инициатор) = Тип("СправочникСсылка.Организации"))) Тогда
			ПараметрыШапки.ИнициаторОперации = ОбщегоНазначенияКлиентСервер.НаименованиеКлиента(Выписка.ДокументОснование.Инициатор, ОтчетНаАнглийскомЯзыке);
		Иначе
			ПараметрыШапки.ИнициаторОперации = ОбщегоНазначенияКлиентСервер.НаименованиеКлиента(СчетДепо.Владелец, ОтчетНаАнглийскомЯзыке);
		КонецЕсли;
	КонецЕсли;
	
	Если ПозицияВыпискиОперационныйДень = 1 Тогда
		ФормированиеПечатныхФорм.СформироватьДатуДДММГГ(ПараметрыШапки, "По", ДатаВыписки);
	Иначе
		ФормированиеПечатныхФорм.СформироватьДатуДДММГГ(ПараметрыШапки, "На", ДатаВыписки);
	КонецЕсли;
	
	Если ВидЗапроса = "Депонентов" Тогда
		ПараметрыШапки.ВидЗапроса = "Запрос от депонента";
	ИначеЕсли ВидЗапроса = "ВМХ" Тогда
		ПараметрыШапки.ВидЗапроса = "Запрос от вышестоящих мест хранения";
	ИначеЕсли ВидЗапроса = "ГОДЗ" Тогда
		ПараметрыШапки.ВидЗапроса = "Запрос от гос. или иных органов по законодательству";
	КонецЕсли;
	
	Если ОтчетНаАнглийскомЯзыке Тогда
		ВидЗапросаНаАнглийском = "";
		Если ВидЗапроса = "Депонентов" Тогда
			ВидЗапросаНаАнглийском = " / Inquiry from the depositor";
		ИначеЕсли ВидЗапроса = "ВМХ" Тогда
			ВидЗапросаНаАнглийском = " / Request from higher depositaries";
		ИначеЕсли ВидЗапроса = "ГОДЗ" Тогда
			ВидЗапросаНаАнглийском = " / Inquiry from public institutions under the law";
		КонецЕсли;
		ПараметрыШапки.ВидЗапроса = ПараметрыШапки.ВидЗапроса + ВидЗапросаНаАнглийском;
	КонецЕсли;
	ПараметрыШапки.НомерСчетаДЕПО = СокрЛП(СчетДепо.Код);
	
	ПараметрыШапки.НаименованиеДепонента = ОбщегоНазначенияКлиентСервер.НаименованиеЮрФизЛицаКлиента(
		СчетДепо.Владелец, ДатаМакета, ОтчетНаАнглийскомЯзыке);
	ПараметрыШапки.ДокументыДепонента = ОбщегоНазначенияКлиентСервер.ДокументКлиента(СчетДепо.Владелец,	ДатаМакета);
	
	Если ЗначениеЗаполнено(СчетДЕПО) Тогда
		Если РегистрыСведений.КлиентыСУчетомНаСчетахТипаC.ЦБКлиентаУчитываютсяНаСчетеТипаС(ДатаВыписки, СчетДепо.Владелец) Тогда
			ТипСчетаДепо = "" + СчетДЕПО.ТипСчетаДепо + " типа С";
		Иначе
			ТипСчетаДепо = СчетДЕПО.ТипСчетаДепо;
		КонецЕсли;
		ПараметрыШапки.НаименованиеСчетаДЕПО =
			?(ОтчетНаАнглийскомЯзыке,
				ПереводТекстаНаДругиеЯзыки.ДополнитьТекстПереводом(ТипСчетаДепо), СокрЛП(ТипСчетаДепо));
	Иначе
		ПараметрыШапки.НаименованиеСчетаДЕПО = "";
	КонецЕсли;
	
КонецПроцедуры

Функция ТипОперации(ВидСчетаДепо, Язык)
	
	Тип = "";
	Если Язык = "Русский" Тогда
		Тип = "Формирование выписки о состоянии счета депо";
	ИначеЕсли Язык = "Английский" Тогда
		Тип = "Generation of custody account status statement";
	КонецЕсли;
	Возврат Тип;
	
КонецФункции

Процедура ЗаполнитьПараметрыПодвала(ОбластьПодвала, ИмяМакета, ДатаМакета, ОтчетНаАнглийскомЯзыке, РегНомерПоручения, БезУполномоченного)
	
	ОтветственноеЛицо = ПараметрыСеанса.ТекущийПользователь;
	РисункиПодвала = ОбластьПодвала.Рисунки;
	ПараметрыПодвала = ОбластьПодвала.Параметры;
	
	Если БезУполномоченного Тогда
		РисункиПодвала.Faksimilie.Картинка	= Новый Картинка;
	Иначе
		// Получить факсимилье
		Если ВыводитьФаксимилеВОтчетах И Не Документооборот Тогда
			ФормированиеПечатныхФорм.ПолучитьФаксимилье(ОтветственноеЛицо.ФизЛицо, РисункиПодвала.Faksimilie.Картинка);
		Иначе
			РисункиПодвала.Faksimilie.Картинка	= Новый Картинка;
		КонецЕсли;
		
		ФИООтветственногоЛица = ?(ОтветственноеЛицо.ФизЛицо = Неопределено, ОтветственноеЛицо.ПолноеНаименование(),
			ОтветственноеЛицо.ФизЛицо);
		
		ПараметрыПодвала.ФИО = Строка(ФИООтветственногоЛица);
		
		Если ОтчетНаАнглийскомЯзыке Тогда
			ПараметрыПодвала.ФИО = ПараметрыПодвала.ФИО + " / "
				+ ОбщегоНазначенияКлиентСервер.Транслит(ФИООтветственногоЛица);
		КонецЕсли;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Выписка) И ЗначениеЗаполнено(Выписка.ДокументОснование) Тогда
		ПараметрыПодвала.Поручение = ОбщегоНазначенияКлиентСервер.ДокументОснованиеСтрокой(Выписка.ДокументОснование, ОтчетНаАнглийскомЯзыке);
		ПараметрыПодвала.ДопИнформация = СокрЛП(Выписка.ДокументОснование.Комментарий);
	КонецЕсли;
	
	ДатаОтчета = ?(ЗначениеЗаполнено(ДатаФормированияОтчетов), ДатаФормированияОтчетов, Выписка.Дата);
	ФормированиеПечатныхФорм.СформироватьДатуВремяДДММГГЧЧММ(ПараметрыПодвала, "", ДатаОтчета);
	
	ФормированиеПечатныхФорм.УстановитьЗаголовкиСекцииМакета(ПараметрыПодвала, ИмяМакета, "Подвал", мТекстыЗаголовков, СчетДепо.ВидСчетаДепо);
	
	Если СчетДепо.ВидСчетаДепо = Перечисления.ВидыСчетовДепо.СчетДЕПО Тогда
		ПараметрыПодвала.РеквизитыПриказа = РегистрыСведений.РеквизитыПриказовПриложенийКРДО.Реквизиты(ДатаМакета);
	КонецЕсли;
	
КонецПроцедуры

Процедура ПоместитьОтчетыВЭдо() Экспорт // BSLLS:Typo-off
	
	ТипДокумента = "DepoAccountState";
	
	ФормированиеОтчетовОСовершенныхОперациях = Обработки.ФормированиеОтчетовОСовершенныхОперациях.Создать();
	ФормированиеОтчетовОСовершенныхОперациях.ПоместитьОтчетыВKafka(ТипДокумента, ДокументыКЭДО, ВыводитьФаксимилеВОтчетах);
	
	Для Каждого СтрокаРезультата Из ДокументыКЭДО Цикл
		Если ЗначениеЗаполнено(СтрокаРезультата.ТекстОшибки) Тогда
			ШаблонОшибки = "Отчет [%1] по счету депо [%2] не отправлен в ЭДО по причине: %3";
			ТекстОшибки = СтрШаблон(ШаблонОшибки, ТипДокумента, СокрЛП(СтрокаРезультата.СчетДепо), СтрокаРезультата.ТекстОшибки);
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстОшибки);
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

Процедура ВыполнитьПеренумерациюВыписок(ДатаПеренумерации)
	
	ОбработкаПеренумерации = Обработки.ПеренумерацияДокументов.Создать();
	ВыборкаРег = РегистрыСведений.РегистрацияДокументовКПеренумерации.Выбрать(НачалоДня(ДатаПеренумерации), КонецДня(ДатаПеренумерации));
	Пока ВыборкаРег.Следующий() Цикл
		Если ВыборкаРег.ИмяДокумента = "Выписка" Тогда
			ОбработкаПеренумерации.ПеренумероватьДокументы(ВыборкаРег);
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

