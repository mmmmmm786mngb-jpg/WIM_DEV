Перем мТекстыЗаголовков;

///////////////////////////////////////////////////////////
// ИНТЕРФЕЙС

// BSLLS:CognitiveComplexity-off
// BSLLS:CyclomaticComplexity-off
// BSLLS:NestedStatements-off

// Формирует отчет "Выписка о состоянии счета депо"
// Параметры:
//	Отчет - ОтчетОбъект.ВыпискаОСостоянииСчетаДепо
//	БезУполномоченного - Булево
// Возвращаемое значение:
//	- ТабличныйДокумент
Функция СформироватьОтчет(Отчет, БезУполномоченного = Ложь) Экспорт
	Перем Соединение, Команда, RS;
	Перем ИсхНомер;
	
	ДатаМакета = ?(ЗначениеЗаполнено(Выписка), Выписка.Дата, ДатаВыписки);
	Отчет.Очистить();
	Документооборот	= Документооборот И ЗначениеЗаполнено(Выписка); // Для выгрузки в ЭДО требуется выписка
	
	Если Документооборот Тогда
		Если Документы.СводныйОтчетОСовершенныхОперациях.БылОтправленВЭДО(Выписка) Тогда
			Сообщение = Новый СообщениеПользователю();
			Сообщение.Текст = "Документ уже был помещен в ЭДО ранее: " + Выписка;
			Сообщение.Сообщить();
			Возврат Неопределено;
		КонецЕсли;
	КонецЕсли;
	
	Если Справочники.Контрагенты.ОсобыеУсловия(СчетДепо.Владелец) Тогда
		Если Не РегистрыСведений.ОтветственныеЛицаОрганизаций.ПользовательМожетРедактироватьОсобыеУсловия() Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Особые условия: " + СчетДепо.Владелец
			+ ". Выполнение операции доступно Ответственному за особых клиентов");
			Возврат Неопределено;
		КонецЕсли;
	КонецЕсли;
	
	ОтчетНаАнглийскомЯзыке = СчетДепо.Владелец.ОтчетыНаАнглийскомЯзыке;
	ИмяМакета	= ИмяМакета(ОтчетНаАнглийскомЯзыке, ДатаМакета);
	Макет		= ПолучитьМакет(ИмяМакета);
	
	Отчет.РазмерСтраницы 		= "A4";
	Отчет.ОриентацияСтраницы	= ОриентацияСтраницы.Портрет;
	Отчет.АвтоМасштаб			= Истина;
	
	// Подготовка подвала
	РегНомерПоручения = "";
	ДатаПоручения = "";
	Если ЗначениеЗаполнено(Выписка) И ЗначениеЗаполнено(Выписка.ДокументОснование) Тогда
		РегНомерПоручения = СокрЛП(Выписка.ДокументОснование.ВходящийНомерПоручения);
		ДатаПоручения = Выписка.ДокументОснование.Дата;
	КонецЕсли;
	
	ИмяСекции		= "Подвал";
	ОбластьПодвала	= Макет.ПолучитьОбласть(ИмяСекции);
	ФормированиеПечатныхФорм.УстановитьЗаголовкиСекцииМакета(ОбластьПодвала.Параметры, ИмяМакета, ИмяСекции,
		мТекстыЗаголовков, СчетДепо.ВидСчетаДепо);
	ЗаполнитьПараметрыПодвала(ОбластьПодвала, ИмяМакета, ДатаМакета, ОтчетНаАнглийскомЯзыке, РегНомерПоручения, БезУполномоченного);
	
	// Вывод шапки
	ИмяСекции	= "Шапка";
	Область		= Макет.ПолучитьОбласть(ИмяСекции);
	ЗаполнитьПараметрыШапки(Область.Параметры, ИмяМакета, ИмяСекции, ДатаМакета, ОтчетНаАнглийскомЯзыке);
	Отчет.Вывести(Область);
	
	// Вывод данных о разделе счета депо
	Ошибка = "";
	РезультатЗапроса = СформироватьЗапрос(ДатаВыписки, ПозицияВыпискиОперационныйДень, СчетДепо, Ошибка);
	Если ЗначениеЗаполнено(Ошибка) Тогда
		Сообщение = Новый СообщениеПользователю();
		Сообщение.Текст = Ошибка;
		Сообщение.Сообщить();
		Возврат Неопределено;
	КонецЕсли;
	
	ВыборкаРазделСчетаДепо = РезультатЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	// Если есть остатки по ЦБ, то выведем информацию о них, иначе выведем информацию о том, что остатки нулевые
	Если ВыборкаРазделСчетаДепо.Количество() > 0 Тогда
		
		ВыборкаРазделСчетаДепо_СчетчикСтрок = 0;
		Пока ВыборкаРазделСчетаДепо.Следующий() Цикл
			ВыборкаРазделСчетаДепо_СчетчикСтрок		 = ВыборкаРазделСчетаДепо_СчетчикСтрок + 1;
			ВыборкаРазделСчетаДепо_ПоследняяСтрока	 = ВыборкаРазделСчетаДепо_СчетчикСтрок = ВыборкаРазделСчетаДепо.Количество();
			
			ИмяСекции			= "РазделСчетаДЕПО";
			ОбластьРаздела		= Макет.ПолучитьОбласть(ИмяСекции);
			ПараметрыОбласти	= ОбластьРаздела.Параметры;
			ФормированиеПечатныхФорм.УстановитьЗаголовкиСекцииМакета(ПараметрыОбласти, ИмяМакета, ИмяСекции,
				мТекстыЗаголовков, СчетДепо.ВидСчетаДепо);
			РазделСчетаДепо = ВыборкаРазделСчетаДепо.РазделСчетаДепо;
			ПараметрыОбласти.НомерРазделаСчетаДЕПО = СокрЛП(РазделСчетаДепо.Код);
			БезНомера = Истина;
			ПредставлениеРаздела = ОбщегоНазначенияКлиентСервер.ПредставлениеРазделаСчетаДепо(РазделСчетаДепо, ОтчетНаАнглийскомЯзыке, БезНомера);
			ПараметрыОбласти.НаименованиеРазделаСчетаДЕПО = ПредставлениеРаздела;
			
			Отчет.Вывести(ОбластьРаздела);
			
			ОбластьТело			= Макет.ПолучитьОбласть("Тело");
			ПараметрыОбласти	= ОбластьТело.Параметры;
			ВыборкаСчетДепоМХ	= ВыборкаРазделСчетаДепо.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
			
			ВыборкаСчетДепоМХ_СчетчикСтрок = 0;
			Пока ВыборкаСчетДепоМХ.Следующий() Цикл
				ВыборкаСчетДепоМХ_СчетчикСтрок		 = ВыборкаСчетДепоМХ_СчетчикСтрок + 1;
				ВыборкаСчетДепоМХ_ПоследняяСтрока	 = ВыборкаСчетДепоМХ_СчетчикСтрок = ВыборкаСчетДепоМХ.Количество();
				
				ВыборкаРазделСчетаДепоМХ = ВыборкаСчетДепоМХ.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
				
				ВыборкаРазделСчетаДепоМХ_СчетчикСтрок = 0;
				Пока ВыборкаРазделСчетаДепоМХ.Следующий() Цикл
					ВыборкаРазделСчетаДепоМХ_СчетчикСтрок	 = ВыборкаРазделСчетаДепоМХ_СчетчикСтрок + 1;
					ВыборкаРазделСчетаДепоМХ_ПоследняяСтрока = ВыборкаРазделСчетаДепоМХ_СчетчикСтрок = ВыборкаРазделСчетаДепоМХ.Количество();
					
					ВыборкаЦБ = ВыборкаРазделСчетаДепоМХ.Выбрать();
					
					ВыборкаЦБ_СчетчикСтрок = 0;
					Пока ВыборкаЦБ.Следующий() Цикл
						ВыборкаЦБ_СчетчикСтрок		 = ВыборкаЦБ_СчетчикСтрок + 1;
						ВыборкаЦБ_ПоследняяСтрока	 = ВыборкаЦБ_СчетчикСтрок = ВыборкаЦБ.Количество();
						ЭтоПоследняяСтрока = ВыборкаРазделСчетаДепо_ПоследняяСтрока
							И ВыборкаСчетДепоМХ_ПоследняяСтрока
							И ВыборкаРазделСчетаДепоМХ_ПоследняяСтрока
							И ВыборкаЦБ_ПоследняяСтрока;
						
						ПараметрыОбласти.ЦеннаяБумага	= ОбщегоНазначенияКлиентСервер.ПредставлениеЦБ(ВыборкаЦБ.ЦБ,
							ОтчетНаАнглийскомЯзыке);
						ПараметрыОбласти.РегНомер		= СокрЛП(ВыборкаЦБ.ЦБ.НомерРегистрации);
						ПараметрыОбласти.ISIN = СокрЛП(ВыборкаЦБ.ЦБ.ISIN);
						
						ПараметрыОбласти.Номинал = ?(ВыборкаЦБ.Номинал <> 0,
							Формат(ВыборкаЦБ.Номинал, "ЧДЦ=4; ЧН=-----") + " "
							+ СтрЗаменить(СокрЛП(ВыборкаЦБ.ВалютаНоминала), "SUR", "RUR"), "-----");
						
						ПараметрыОбласти.МХ						= СокрЛП(ВыборкаЦБ.СчетДепоМХНаименование);
						ПараметрыОбласти.РазделМХ				= СокрЛП(ВыборкаЦБ.РазделСчетаДепоМХПредставление);
						ПараметрыОбласти.КоличествоОстаток		= ВыборкаЦБ.КоличествоОстаток;
						ПараметрыОбласти.СвободноеКоличество	= ВыборкаЦБ.СвободныйОстаток;
						
						ПараметрыОбласти.ОбремененноеКоличество = ВыборкаЦБ.ОбремененныйОстаток;
						
						// Проверка на "разрыв" страницы: если подвал не вмещается на страницу, то вывести его с последней строкой таблицы на след. лист
						Если ЭтоПоследняяСтрока Тогда
							// Подготовка массива областей макета, проверяемых на потенциальный "разрыв" страницы между ними
							// области "последняя строка" последней таблицы и "подвал" таблицы должны быть на одном листе
							СтрокаСПодвалом = Новый Массив;
							СтрокаСПодвалом.Добавить(ОбластьТело);
							СтрокаСПодвалом.Добавить(ОбластьПодвала);
							ФормированиеПечатныхФорм.ВывестиГоризонтальныйРазделитель(Отчет, СтрокаСПодвалом);
						КонецЕсли;
						
						Отчет.Вывести(ОбластьТело);
					КонецЦикла;
				КонецЦикла;
			КонецЦикла;
		КонецЦикла;
	
	Иначе	// Остатки нулевые
		ИмяСекции	= "РазделСчетаДЕПО";
		Область		= Макет.ПолучитьОбласть(ИмяСекции);
		ФормированиеПечатныхФорм.УстановитьЗаголовкиСекцииМакета(Область.Параметры, ИмяМакета, ИмяСекции,
			мТекстыЗаголовков, СчетДепо.ВидСчетаДепо);
		Отчет.Вывести(Область);
		Область = Макет.ПолучитьОбласть("Тело");
		Отчет.Вывести(Область);
	КонецЕсли;
	
	// Вывод подвала	
	Отчет.Вывести(ОбластьПодвала);
	
	Отчет.НижнийКолонтитул.Выводить = Истина;
	Отчет.НижнийКолонтитул.ТекстВЦентре = "[&НомерСтраницы] из [&СтраницВсего]";
	
	Если Документооборот Тогда
		ДокументыКЭДО.Очистить();
		
		// Поместим таблицу для клиент серверной передачи
		АдресТаблицы = ПоместитьВоВременноеХранилище(Отчет);
		
		НовыйДляЭДО = ДокументыКЭДО.Добавить();
		
		НовыйДляЭДО.Клиент				= СчетДепо.Владелец;
		НовыйДляЭДО.СчетДепо			= СчетДепо;
		НовыйДляЭДО.Документ			= Выписка;
		НовыйДляЭДО.Основание			= Выписка;
		НовыйДляЭДО.АдресТаблицы		= АдресТаблицы;
		НовыйДляЭДО.ActionType			= "INS";
		
		ПоместитьОтчетыВЭдо();
	КонецЕсли;
	
	Возврат Отчет;
КонецФункции

// Процедура заполняет реквизиты отчета основываясь на информации из документа Выписка
Процедура ЗаполнитьРеквизитыОтчетаПоВыписке() Экспорт
	Если ЗначениеЗаполнено(Выписка) Тогда
		СчетДепо = Выписка.СчетДепо;
		ДатаВыписки = Выписка.ДатаКонПериода;
		ПозицияВыпискиОперационныйДень = Выписка.ПозицияВыпискиОперационныйДень;
		
		ЭлементыОтбора = КомпоновщикНастроек.Настройки.Отбор.Элементы;
		ЭлементыОтбора.Очистить();
		
		НовыйЭлемент = ЭлементыОтбора.Вставить(0, Тип("ЭлементОтбораКомпоновкиДанных"));
		НовыйЭлемент.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("ЦенныеБумаги");
		Если ЗначениеЗаполнено(Выписка.ЦБВыписка) Тогда
			НовыйЭлемент.Использование = Истина;
			НовыйЭлемент.ПравоеЗначение = Выписка.ЦБВыписка;
		Иначе
			НовыйЭлемент.Использование = Ложь;
		КонецЕсли;
		
		НовыйЭлемент = ЭлементыОтбора.Вставить(1, Тип("ЭлементОтбораКомпоновкиДанных"));
		НовыйЭлемент.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("Эмитенты");
		Если ЗначениеЗаполнено(Выписка.ЭмитентВыписка) Тогда
			НовыйЭлемент.Использование = Истина;
			НовыйЭлемент.ПравоеЗначение = Выписка.ЭмитентВыписка;
		Иначе
			НовыйЭлемент.Использование = Ложь;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

// BSLLS:CognitiveComplexity-on
// BSLLS:CyclomaticComplexity-on
// BSLLS:NestedStatements-on
Процедура ПеренумероватьВыписки() Экспорт
	Если ЗначениеЗаполнено(ДатаФормированияОтчетов) И ЗначениеЗаполнено(Выписка) Тогда
		ДокОбъект = Выписка.ПолучитьОбъект();
		ДокОбъект.Дата = ДатаФормированияОтчетов;
		ДокОбъект.Записать();
		ВыполнитьПеренумерациюВыписок(ДатаВыписки);
		Если НачалоДня(ДатаВыписки) <> НачалоДня(ДатаФормированияОтчетов) Тогда
			ВыполнитьПеренумерациюВыписок(ДатаФормированияОтчетов);
		КонецЕсли;
		ДатаМакета = ?(ЗначениеЗаполнено(Выписка), Выписка.Дата, ДатаВыписки);
	КонецЕсли;	
КонецПроцедуры

