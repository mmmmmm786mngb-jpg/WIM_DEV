Перем ТаблицаЗначенийОпераций;

Функция ЗаголовокОтчета() Экспорт
	Возврат  "Количество и объемы проведеных депозитарных операций ";
КонецФункции

// Функция делает выборку депозитарных операций из регистра ОстаткиЦБ.
//
// Параметры
// БезПараметров
//
// Возвращаемое значение:
//   ТаблицаЗначений.Результат запроса.
//
Функция КоличествоОбъемОпераций() Экспорт

	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Котировки.ЦеннаяБумага,
	|	МАКСИМУМ(Котировки.Период) КАК Период
	|ПОМЕСТИТЬ ВремяКотировок
	|ИЗ
	|	РегистрСведений.Котировки КАК Котировки
	|ГДЕ
	|	Котировки.РежимТоргов.РежимТоргов = ЗНАЧЕНИЕ(Перечисление.РежимыТоргов.Рыночная)
	|	И Котировки.Период <= &КонДата
	|СГРУППИРОВАТЬ ПО
	|	Котировки.ЦеннаяБумага
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	КотировкиСрезПоследних.ЦеннаяБумага
	|ПОМЕСТИТЬ А1
	|ИЗ
	|	РегистрСведений.Котировки.СрезПоследних(&КонДата, ) КАК КотировкиСрезПоследних
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВремяКотировок КАК ВремяКотировок
	|		ПО КотировкиСрезПоследних.ЦеннаяБумага = ВремяКотировок.ЦеннаяБумага
	|			И КотировкиСрезПоследних.Период = ВремяКотировок.Период
	|ГДЕ
	|	(ПОДСТРОКА(КотировкиСрезПоследних.РежимТоргов.Код, 1, 2) = ""EQ""
	|	ИЛИ ПОДСТРОКА(КотировкиСрезПоследних.РежимТоргов.Код, 1, 2) = ""TQ"")
	|	И КотировкиСрезПоследних.РежимТоргов.Код <> ""EQCC""
	|	И КотировкиСрезПоследних.РежимТоргов.Код <> ""EQDP""
	|	И КотировкиСрезПоследних.РежимТоргов.Код <> ""EQUS""
	|	И КотировкиСрезПоследних.РежимТоргов.Код <> ""EQEU""
	|	И КотировкиСрезПоследних.РежимТоргов.Код <> ""EQQI""
	|	И (КотировкиСрезПоследних.КотировальныйЛист = ""1""
	|	ИЛИ КотировкиСрезПоследних.КотировальныйЛист = ""2"")
	|СГРУППИРОВАТЬ ПО
	|	КотировкиСрезПоследних.ЦеннаяБумага
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	КатегорияЦБ.ЦеннаяБумага,
	|	МАКСИМУМ(КатегорияЦБ.Период) КАК Период
	|ПОМЕСТИТЬ ВремяКатегорий
	|ИЗ
	|	РегистрСведений.КатегорияЦБ КАК КатегорияЦБ
	|ГДЕ
	|	КатегорияЦБ.Период <= &КонДата
	|
	|СГРУППИРОВАТЬ ПО
	|	КатегорияЦБ.ЦеннаяБумага
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ОстаткиЦБОбороты.ЦБ.Эмитент КАК ЦБЭмитент,
	|	ВЫБОР
	|		КОГДА ОстаткиЦБОбороты.ЦБ.НомерРегистрации <> """"
	|			ТОГДА ОстаткиЦБОбороты.ЦБ.НомерРегистрации
	|		ИНАЧЕ ОстаткиЦБОбороты.ЦБ.ISIN
	|	КОНЕЦ КАК ЦБ,
	|	ВЫБОР
	|		КОГДА А1.ЦеннаяБумага ЕСТЬ NULL 
	|			ТОГДА ""Прочие""
	|		ИНАЧЕ ""А1""
	|	КОНЕЦ КАК Категория,
	|	ВЫБОР
	|		КОГДА ОстаткиЦБОбороты.Регистратор ССЫЛКА Документ.КонвертацияЦБ
	|			ТОГДА ЗНАЧЕНИЕ(Справочник.ВидыОпераций.Конвертация)
	|		КОГДА ОстаткиЦБОбороты.Регистратор ССЫЛКА Документ.ПогашениеЦБ
	|			ТОГДА ЗНАЧЕНИЕ(Справочник.ВидыОпераций.Погашение)
	|		КОГДА ОстаткиЦБОбороты.Регистратор ССЫЛКА Документ.ГлобальнаяОперация
	|			ТОГДА ОстаткиЦБОбороты.Регистратор.ВидГлобальнойОперации
	|		ИНАЧЕ ОстаткиЦБОбороты.Регистратор.ВидОперацииД
	|	КОНЕЦ КАК РегистраторВидОперацииД,
	|	ВЫБОР
	|		КОГДА ОстаткиЦБОбороты.Регистратор.ВидОперацииД = &Депонирование
	|				ИЛИ ОстаткиЦБОбороты.Регистратор ССЫЛКА Документ.КонвертацияЦБ
	|					И ОстаткиЦБОбороты.КоличествоПриход > 0
	|			ТОГДА 1
	|		ИНАЧЕ 0
	|	КОНЕЦ КАК Депонирование,
	|	ВЫБОР
	|		КОГДА ОстаткиЦБОбороты.Регистратор.ВидОперацииД = &Снятие
	|		ИЛИ ОстаткиЦБОбороты.Регистратор ССЫЛКА Документ.КонвертацияЦБ
	|		И ОстаткиЦБОбороты.КоличествоРасход > 0
	|		ИЛИ ОстаткиЦБОбороты.Регистратор ССЫЛКА Документ.ПогашениеЦБ
	|		ИЛИ (ОстаткиЦБОбороты.Регистратор ССЫЛКА Документ.ГлобальнаяОперация
	|			И
	|				(ОстаткиЦБОбороты.Регистратор.ВидГлобальнойОперации = ЗНАЧЕНИЕ(Справочник.ВидыОпераций.Погашение)
	|				ИЛИ ОстаткиЦБОбороты.Регистратор.ВидГлобальнойОперации = ЗНАЧЕНИЕ(Справочник.ВидыОпераций.СписаниеАкцийПриЛиквидацииЭмитента)
	|				ИЛИ ОстаткиЦБОбороты.Регистратор.ВидГлобальнойОперации = ЗНАЧЕНИЕ(Справочник.ВидыОпераций.СписаниеОбесценившихсяЦенныхБумаг)
	|				)
	|			)
	|			ТОГДА 1
	|		ИНАЧЕ 0
	|	КОНЕЦ КАК Снятие,
	|	ВЫБОР
	|		КОГДА ОстаткиЦБОбороты.Регистратор.ВидОперацииД = &Перевод
	|			ТОГДА 1
	|		ИНАЧЕ 0
	|	КОНЕЦ КАК Перевод,
	|	ОстаткиЦБОбороты.КоличествоОборот КАК КоличествоОборот,
	|	ОстаткиЦБОбороты.КоличествоПриход КАК КоличествоПриход,
	|	ОстаткиЦБОбороты.КоличествоРасход КАК КоличествоРасход
	|ИЗ
	|	РегистрНакопления.ОстаткиЦБ.Обороты(&НачДата, &КонДата, Регистратор, ) КАК ОстаткиЦБОбороты
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.КатегорияЦБ КАК КатегорияЦБ
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВремяКатегорий КАК ВремяКатегорий
	|			ПО КатегорияЦБ.ЦеннаяБумага = ВремяКатегорий.ЦеннаяБумага
	|				И КатегорияЦБ.Период = ВремяКатегорий.Период
	|		ПО ОстаткиЦБОбороты.ЦБ = КатегорияЦБ.ЦеннаяБумага
	|		ЛЕВОЕ СОЕДИНЕНИЕ А1 КАК А1
	|		ПО ОстаткиЦБОбороты.ЦБ = А1.ЦеннаяБумага
	|ИТОГИ
	|	СУММА(Депонирование),
	|	СУММА(Снятие),
	|	СУММА(Перевод),
	|	СУММА(КоличествоОборот),
	|	СУММА(КоличествоПриход),
	|	СУММА(КоличествоРасход)
	|ПО
	|	ЦБЭмитент,
	|	ЦБ,
	|	Категория,
	|	РегистраторВидОперацииД";
	
	Запрос.УстановитьПараметр("Депонирование",Справочники.ВидыОпераций.Депонирование);
	Запрос.УстановитьПараметр("Снятие",Справочники.ВидыОпераций.СнятиеСДепонирования);
	Запрос.УстановитьПараметр("Перевод",Справочники.ВидыОпераций.Перевод);
	Запрос.УстановитьПараметр("НачДата",НачалоДня(НачПериода));
	Запрос.УстановитьПараметр("КонДата",КонецДня(КонПериода));
	
	Результат = Запрос.Выполнить();
		
    Возврат Результат;
	
КонецФункции // КоличествоОбъемОпераций()
 
Процедура СформироватьОтчет(ТабличныйДокумент) Экспорт
	
	ТаблицаЗначенийОпераций.Очистить();
	ТабличныйДокумент.Очистить();
	
	РезультатЗапроса = КоличествоОбъемОпераций();
	
	Если РезультатЗапроса.Пустой() Тогда
		
		Сообщить("Нет операций за выбранный период!");	
		
	Иначе

		Дерево = РезультатЗапроса.Выгрузить(ОбходРезультатаЗапроса.ПоГруппировкам);
		Для каждого ВеткаЭмитент Из Дерево.Строки Цикл
			Для каждого ВеткаЦБ Из ВеткаЭмитент.Строки Цикл
				
				ВеткаПериод	= ВеткаЦБ.Строки[0];
				Если ВеткаПериод <> Неопределено Тогда 
					
					Для каждого ВеткаКатегория Из ВеткаЦБ.Строки Цикл
						Для каждого ВеткаВидОперации Из ВеткаКатегория.Строки Цикл
							
							КоличествоПрием   = 0; 	ОбъемПрием		  = 0;
							КоличествоСнятие  = 0; 	ОбъемСнятие		  = 0;
							КоличествоПеревод = 0; 	Объемперевод	  = 0;

							//определение количества и объема.
							Если ВеткаВидОперации.РегистраторВидОперацииД = Справочники.ВидыОпераций.Депонирование Тогда
								КоличествоПрием   = ВеткаВидОперации.Депонирование;
								ОбъемПрием		  = ВеткаВидОперации.КоличествоПриход; 								
							ИначеЕсли ВеткаВидОперации.РегистраторВидОперацииД = Справочники.ВидыОпераций.Конвертация Тогда
								КоличествоПрием   = ВеткаВидОперации.Депонирование;
								ОбъемПрием		  = ВеткаВидОперации.КоличествоПриход; 								
								КоличествоСнятие  = ВеткаВидОперации.Снятие;
								ОбъемСнятие		  = ВеткаВидОперации.КоличествоРасход;
							Иначе 	
								Если ВеткаВидОперации.РегистраторВидОперацииД = Справочники.ВидыОпераций.СнятиеСДепонирования
									ИЛИ ВеткаВидОперации.РегистраторВидОперацииД = Справочники.ВидыОпераций.Погашение
									ИЛИ ВеткаВидОперации.РегистраторВидОперацииД = Справочники.ВидыОпераций.СписаниеАкцийПриЛиквидацииЭмитента
									ИЛИ ВеткаВидОперации.РегистраторВидОперацииД = Справочники.ВидыОпераций.СписаниеОбесценившихсяЦенныхБумаг
									Тогда
									КоличествоСнятие  = ВеткаВидОперации.Снятие;
									ОбъемСнятие		  = ВеткаВидОперации.КоличествоРасход;
								ИначеЕсли ВеткаВидОперации.РегистраторВидОперацииД = Справочники.ВидыОпераций.Перевод Тогда
									КоличествоПеревод = ВеткаВидОперации.Перевод;
									Объемперевод	  = ВеткаВидОперации.КоличествоРасход;
								КонецЕсли; 								
							КонецЕсли; 
							
							//заполнение ТаблицыЗначенийОпераций.							
							Если ВеткаВидОперации.ЦБ = Перечисления.ТипыЦБ.Вексель Тогда
								
								ЗаполнениеГруппыТЗ("Векселя", ВеткаВидОперации.ЦБЭмитент, 
									СокрЛП(ВеткаВидОперации.ЦБ), 
									КоличествоПрием, ОбъемПрием,
									КоличествоСнятие, ОбъемСнятие,
									КоличествоПеревод, Объемперевод);
								
							Иначе	
								
								Если ВеткаВидОперации.Категория = "Прочие" Тогда
									
									ЗаполнениеГруппыТЗ("ПрочиеЭмитенты",ВеткаВидОперации.ЦБЭмитент, 
									СокрЛП(ВеткаВидОперации.ЦБ), 
									КоличествоПрием, ОбъемПрием,
									КоличествоСнятие, ОбъемСнятие,
									КоличествоПеревод, Объемперевод); 
									
								Иначе	
									
									ЗаполнениеГруппыТЗ("Эмитенты, ценные бумаги которых включены в листинг",ВеткаВидОперации.ЦБЭмитент,СокрЛП(ВеткаВидОперации.ЦБ), 
									КоличествоПрием, ОбъемПрием,
									КоличествоСнятие, ОбъемСнятие,
									КоличествоПеревод, Объемперевод); 
									
								КонецЕсли; 
								
							КонецЕсли; 														
														
						КонецЦикла;	//веткаОперации				
					КонецЦикла;//Веткакатегории
					
				Иначе
					Сообщить("Не определена Категория ЦБ - " + Строка(ВеткаЦБ.ЦБ));
				КонецЕсли;
				
			КонецЦикла;//ВеткаЦБ			
		КонецЦикла;//ВеткаЭмитент
		
	КонецЕсли;
	
	//предварительная очитска табличного документа.	
	Макет = ПолучитьМакет("Макет");
	ОбластьШапка = Макет.ПолучитьОбласть("Шапка");
	ОбластьИтоги = Макет.ПолучитьОбласть("Итоги");
	ОбластьШапка.Параметры.ОписаниеПериода = Период;
	ТабличныйДокумент.Вывести(ОбластьШапка);
	
	ТаблицаЗначенийОпераций.Свернуть("ГруппаЦБ,Эмитент,НомерРег","КолПрием,ОбПрием,КолСнятие,ОбСнятие,КолПеревод,ОбПеревод");
	ТаблицаЗначенийОпераций.Сортировать("ГруппаЦБ Убыв,Эмитент");
	
	ОбластьСтрока			= Макет.ПолучитьОбласть("Строка");
	ОбластьГруппаЭмитентов 	= Макет.ПолучитьОбласть("ГруппаЭмитентов");
	НПП						= 1;
	
	Для каждого ТекущаяСтрока Из ТаблицаЗначенийОпераций Цикл
		
		Если НПП = 1 Тогда
		
			ОбластьГруппаЭмитентов.Параметры.НаименованиеГруппы = ТекущаяСтрока.ГруппаЦБ;
			ТабличныйДокумент.Вывести(ОбластьГруппаЭмитентов);
		    ГруппаЭмитента =  ТекущаяСтрока.ГруппаЦБ;
			
		КонецЕсли; 
		
		Если ТекущаяСтрока.ГруппаЦБ = ГруппаЭмитента Тогда
			
			ОбластьСтрока.Параметры.Заполнить(ТекущаяСтрока);
			ОбластьСтрока.Параметры.НПП 		= НПП; НПП = НПП + 1;
			ОбластьСтрока.Параметры.КолВсего	= ТекущаяСтрока.КолПрием + ТекущаяСтрока.КолСнятие + ТекущаяСтрока.КолПеревод;
			ОбластьСтрока.Параметры.ОбВсего		= ТекущаяСтрока.ОбПрием + ТекущаяСтрока.ОбСнятие + ТекущаяСтрока.ОбПеревод;
			ТабличныйДокумент.Вывести(ОбластьСтрока);
			
		Иначе	
			
			ГруппаЭмитента = ТекущаяСтрока.ГруппаЦБ;
			ОбластьГруппаЭмитентов.Параметры.НаименованиеГруппы = ТекущаяСтрока.ГруппаЦБ;
			ТабличныйДокумент.Вывести(ОбластьГруппаЭмитентов);
		   
			ОбластьСтрока.Параметры.Заполнить(ТекущаяСтрока);
			ОбластьСтрока.Параметры.НПП = НПП;
			ОбластьСтрока.Параметры.КолВсего	= ТекущаяСтрока.КолПрием + ТекущаяСтрока.КолСнятие + ТекущаяСтрока.КолПеревод;
			ОбластьСтрока.Параметры.ОбВсего		= ТекущаяСтрока.ОбПрием + ТекущаяСтрока.ОбСнятие + ТекущаяСтрока.ОбПеревод;
			ТабличныйДокумент.Вывести(ОбластьСтрока); 
						
		КонецЕсли; 	
				
	КонецЦикла; 
	
	ОбластьИтоги.Параметры.КолПрием		= ТаблицаЗначенийОпераций.Итог("КолПрием");		
	ОбластьИтоги.Параметры.ОбПрием		= ТаблицаЗначенийОпераций.Итог("ОбПрием");
	ОбластьИтоги.Параметры.КолСнятие	= ТаблицаЗначенийОпераций.Итог("КолСнятие");
	ОбластьИтоги.Параметры.ОбСнятие		= ТаблицаЗначенийОпераций.Итог("ОбСнятие");
	ОбластьИтоги.Параметры.КолПеревод	= ТаблицаЗначенийОпераций.Итог("КолПеревод");
	ОбластьИтоги.Параметры.ОбПеревод	= ТаблицаЗначенийОпераций.Итог("ОбПеревод");
	ОбластьИтоги.Параметры.КолВсего     = ОбластьИтоги.Параметры.КолПрием + ОбластьИтоги.Параметры.КолСнятие +  ОбластьИтоги.Параметры.КолПеревод;
	ОбластьИтоги.Параметры.ОбВсего		= ОбластьИтоги.Параметры.ОбПрием + ОбластьИтоги.Параметры.ОбСнятие  + ОбластьИтоги.Параметры.ОбПеревод;
	ТабличныйДокумент.Вывести(ОбластьИтоги);
	
	ТабличныйДокумент.ОтображатьСетку 		= Ложь;
	ТабличныйДокумент.ТолькоПросмотр 		= Истина;
	ТабличныйДокумент.ОтображатьЗаголовки 	= Ложь;
	
	
КонецПроцедуры
	
Процедура ЗаполнениеГруппыТЗ(Группа, Эмитент, НомерРег, КолПрием, ОбПрием, КолСнятие, ОбСнятие, КолПеревод, ОбПеревод)

	НоваяСтрока	= ТаблицаЗначенийОпераций.Добавить();
	НоваяСтрока.ГруппаЦБ	= Группа;                                                               
	НоваяСтрока.Эмитент		= Эмитент; 
