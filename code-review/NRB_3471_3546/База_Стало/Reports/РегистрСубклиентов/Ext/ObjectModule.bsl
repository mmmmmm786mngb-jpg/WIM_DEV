
// Формирует отчет в табличный документ из параметра
//
// Параметры:
//  Таблица - Табличный документ - табличный документ результата
//
Процедура СформироватьОтчет(Таблица) Экспорт
	
	Таблица.Очистить();
	Макет = ПолучитьМакет("РегистрСубклиентов");
	ОбластьШапка	= Макет.ПолучитьОбласть("Шапка");
	ОбластьСтрока	= Макет.ПолучитьОбласть("Строка");
	
	ОбластьШапка.Параметры.НазваниеОтчета = "Регистр субклиентов за период с " + Формат(НачалоПериода, "ДЛФ=Д")
		+ " по " + Формат(КонецПериода, "ДЛФ=Д");
	Таблица.Вывести(ОбластьШапка);
	
	ТекущийСубклиент = Неопределено;
	ПредыдущиеДанные = Неопределено;
	НомерСтроки = 0;
	ДанныеПоСубклиентам = ДанныеПоСубклиентам();
	Выборка = ДанныеПоСубклиентам[4].Выбрать();
	ДанныеДУСубклиентов = ДанныеПоСубклиентам[5].Выгрузить();
	ТекстКлиент = "";
	ТекстДоговор = "";
	Пока Выборка.Следующий() Цикл
		ДанныеЗаполнения = НовыеДанныеЗаполнения();
		ЗаполнитьЗначенияСвойств(ДанныеЗаполнения, Выборка);
		Если ТипЗнч(Выборка.Субклиент) = Тип("СправочникСсылка.ЮридическиеЛица") Тогда
			ДанныеЗаполнения.КраткоеНаименование = Выборка.КраткоеНаименование;
			ДанныеЗаполнения.Документ = ОГРН(Выборка.ОГРН, Выборка.ДатаГосРегистрации, Выборка.Резидент);
		ИначеЕсли ТипЗнч(Выборка.Субклиент) = Тип("СправочникСсылка.ФизическиеЛица") Тогда
			ДанныеЗаполнения.КраткоеНаименование = ОбщегоНазначения.ПолучитьФамилиюИмяОтчество(Выборка.Фамилия, Выборка.Имя, Выборка.Отчество);
			ДанныеЗаполнения.Документ = ПредставлениеДокументаФизлица(Выборка.Наименование, Выборка, Выборка.ДатаИзменения);
			ДанныеЗаполнения.Гражданство = ПредставлениеГражданстваФизлица(Выборка.Наименование, Выборка.Гражданство, Выборка.ДатаИзменения);
			ДанныеЗаполнения.ДатаМестоРождения = СтрокаИзДаты(Выборка.ДатаРождения);
			Если ЗначениеЗаполнено(Выборка.МестоРождения) Тогда
				ДанныеЗаполнения.ДатаМестоРождения = ДанныеЗаполнения.ДатаМестоРождения + ", " + Выборка.МестоРождения;
			КонецЕсли;
		КонецЕсли;
		Если ТекущийСубклиент <> Выборка.Субклиент Тогда
			НомерСтроки = НомерСтроки+1;
			ДанныеЗаполнения.НомерДепонента = НомерСтроки;
			ТекущийСубклиент = Выборка.Субклиент;
			Для Каждого ТекПоле Из ДанныеЗаполнения Цикл
				ОбластьСтрока.Области[ТекПоле.Ключ].ЦветФона = ЦветаСтиля.ЦветФонаПоля;
			КонецЦикла;
			
			ТекстКлиент = "";
			ТекстДоговор = "";
			Отбор = Новый Структура("Субклиент", Выборка.Субклиент);
			ДУПоТекущемуСубклиенту = ДанныеДУСубклиентов.НайтиСтроки(Отбор);
			Для Каждого Стр Из ДУПоТекущемуСубклиенту Цикл
				ТекстКлиент = ТекстКлиент + СокрЛП(Стр.ДУ) + ";" + Символы.ПС;
				ТекстДоговор = ТекстДоговор + СокрЛП(Стр.ДоговорДУ) + ";" + Символы.ПС;
			КонецЦикла;
			ТекстКлиент = Лев(ТекстКлиент, СтрДлина(ТекстКлиент)-2);
			ТекстДоговор = Лев(ТекстДоговор, СтрДлина(ТекстДоговор)-2);
		Иначе
			ДанныеЗаполнения.НомерДепонента = "";
			
			ПоляБезОтображенияИзменений = Новый Массив;
			ПоляБезОтображенияИзменений.Добавить("НомерДепонента");
			ПоляБезОтображенияИзменений.Добавить("ДатаИзменения");
			ПоляБезОтображенияИзменений.Добавить("Клиент");
			ПоляБезОтображенияИзменений.Добавить("Договор");
			
			Для Каждого ТекПоле Из ДанныеЗаполнения Цикл
				Если ПоляБезОтображенияИзменений.Найти(ТекПоле.Ключ) <> Неопределено Тогда
					Продолжить;
				КонецЕсли;
				ТекЦветФона = ?(ТекПоле.Значение <> ПредыдущиеДанные[ТекПоле.Ключ], ЦветаСтиля.ЦветНавигации, ЦветаСтиля.ЦветФонаПоля);
				ОбластьСтрока.Области[ТекПоле.Ключ].ЦветФона = ТекЦветФона;
			КонецЦикла;
		КонецЕсли;
		ДанныеЗаполнения.Клиент = ТекстКлиент;
		ДанныеЗаполнения.Договор = ТекстДоговор;
		ПредыдущиеДанные = ДанныеЗаполнения;
		ОбластьСтрока.Параметры.Заполнить(ДанныеЗаполнения);
		Таблица.Вывести(ОбластьСтрока);
	КонецЦикла; 
	
КонецПроцедуры

Функция ДанныеПоСубклиентам()
	
	Запрос = Новый Запрос;
	Запрос.Текст = ТекстЗапросаПоСубклиентам();
	Запрос.УстановитьПараметр("НачалоПериода",			НачалоПериода);
	Запрос.УстановитьПараметр("КонецПериода",			КонецПериода);
	Запрос.УстановитьПараметр("СписокДепонентов",		СписокДепонентов);
	Запрос.УстановитьПараметр("СписокДепонентовПуст",	Не ЗначениеЗаполнено(СписокДепонентов));
	Запрос.УстановитьПараметр("СписокСубклиентов",		СписокСубклиентов);
	Запрос.УстановитьПараметр("СписокСубклиентовПуст",	Не ЗначениеЗаполнено(СписокСубклиентов));
	Запрос.УстановитьПараметр("ТипСчетаДУ",				Перечисления.ТипыСчетовДепо.ДоверительногоУправляющего);
	Запрос.УстановитьПараметр("ПризнакСчетДепонента",	Перечисления.ПризнакиСчетаДепо.СчетДепонента);
	Запрос.УстановитьПараметр("ТипДоговораДепозитарный", Перечисления.ТипыДоговоров.Депозитарный);
	Запрос.УстановитьПараметр("Адрес",				Перечисления.ТипыКонтактнойИнформации.Адрес);
	Запрос.УстановитьПараметр("Телефон",			Перечисления.ТипыКонтактнойИнформации.Телефон);
	Запрос.УстановитьПараметр("АдресЭлектроннойПочты",	Перечисления.ТипыКонтактнойИнформации.АдресЭлектроннойПочты);
	Запрос.УстановитьПараметр("ФактАдресЮрЛица",	Справочники.ВидыКонтактнойИнформации.ФактАдресЮрЛица);
	Запрос.УстановитьПараметр("ФактАдресФизЛица",	Справочники.ВидыКонтактнойИнформации.ФактАдресФизЛица);
	Запрос.УстановитьПараметр("ЮрАдресЮрЛица",		Справочники.ВидыКонтактнойИнформации.ЮрАдресЮрЛица);
	Запрос.УстановитьПараметр("ЮрАдресФизЛица",		Справочники.ВидыКонтактнойИнформации.ЮрАдресФизЛица);
	Запрос.УстановитьПараметр("EmailЮрЛица",		Справочники.ВидыКонтактнойИнформации.EmailЮрЛица);
	Запрос.УстановитьПараметр("EmailФизЛица",		Справочники.ВидыКонтактнойИнформации.EmailФизЛица);
	Запрос.УстановитьПараметр("ТелефонЮрЛица",		Справочники.ВидыКонтактнойИнформации.ТелефонЮрЛица);
	Запрос.УстановитьПараметр("ТелефонФизЛица",		Справочники.ВидыКонтактнойИнформации.ТелефонФизЛица);
	Результаты = Запрос.ВыполнитьПакет();
	Возврат Результаты;
	
КонецФункции

////////////////////////////////////////////////////////////////////////////
// ВСПОМОГАТЕЛЬНЫЕ ФУНКЦИИ

Функция НовыеДанныеЗаполнения()
	
	Возврат Новый Структура("НомерДепонента, ДатаИзменения, КраткоеНаименование, Наименование, Документ,
	|Гражданство, ИНН, ЮридическийАдрес, ФактическийАдрес, ДатаМестоРождения, Телефон, Email, Резидент, Клиент, Договор");
	
КонецФункции

Функция ТекстЗапросаПоСубклиентам()
	
	Возврат
	"ВЫБРАТЬ
	|	Контрагенты.Ссылка КАК Депонент,
	|	МАКСИМУМ(Договоры.Ссылка) КАК Договор
	|ПОМЕСТИТЬ втДепоненты
	|ИЗ
	|	Справочник.Контрагенты КАК Контрагенты
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.СчетаДепо КАК СчетаДепо
	|		ПО Контрагенты.Ссылка = СчетаДепо.Владелец
	|			И (СчетаДепо.ДатаОткрытияСчета <= &КонецПериода)
	|			И (СчетаДепо.ДатаЗакрытияСчета = ДАТАВРЕМЯ(1, 1, 1)
	|				ИЛИ СчетаДепо.ДатаЗакрытияСчета > &НачалоПериода)
	|			И (СчетаДепо.ПризнакСчетаДепо = &ПризнакСчетДепонента)
	|			И (НЕ СчетаДепо.ПометкаУдаления)
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ДоговорыКонтрагентов КАК Договоры
	|		ПО Контрагенты.Ссылка = Договоры.Владелец
	|			И (Договоры.ТипДоговора = &ТипДоговораДепозитарный)
	|			И (Договоры.ДатаНачалоДействия <= &КонецПериода)
	|			И (Договоры.ДатаОкончанияДействия = ДАТАВРЕМЯ(1, 1, 1)
	|				ИЛИ Договоры.ДатаОкончанияДействия > &НачалоПериода)
	|			И (НЕ Договоры.ПометкаУдаления)
	|ГДЕ
	|	(Контрагенты.Ссылка В ИЕРАРХИИ (&СписокДепонентов)
	|			ИЛИ &СписокДепонентовПуст)
	|
	|СГРУППИРОВАТЬ ПО
	|	Контрагенты.Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Субклиенты.Клиент КАК Субклиент,
	|	МАКСИМУМ(Контрагенты.Ссылка) КАК КонтрагентСубклиента,
	|	Субклиенты.Объект КАК ДУ,
	|	втДепоненты.Договор КАК ДоговорДУ
	|ПОМЕСТИТЬ втСубклиенты
	|ИЗ
	|	втДепоненты КАК втДепоненты
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.Субклиенты КАК Субклиенты
	|			ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Контрагенты КАК Контрагенты
	|			ПО (Контрагенты.ЮридическиеФизическиеЛица = Субклиенты.Клиент)
	|		ПО втДепоненты.Депонент = Субклиенты.Объект
	|ГДЕ
	|	(Субклиенты.Клиент В (&СписокСубклиентов)
	|			ИЛИ &СписокСубклиентовПуст)
	|
	|СГРУППИРОВАТЬ ПО
	|	Субклиенты.Объект,
	|	Субклиенты.Клиент,
	|	втДепоненты.Договор
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	втСубклиенты.Субклиент КАК Субклиент,
	|	КонтактнаяИнформация.Период КАК ДатаАдресФакт,
	|	ДАТАВРЕМЯ(1, 1, 1) КАК ДатаАдресЮр,
	|	ДАТАВРЕМЯ(1, 1, 1) КАК ДатаЭлПочта,
	|	ДАТАВРЕМЯ(1, 1, 1) КАК ДатаТелефон,
	|	ДАТАВРЕМЯ(1, 1, 1) КАК ДатаФИО,
	|	ДАТАВРЕМЯ(1, 1, 1) КАК ДатаПаспортныеДанные,
	|	ДАТАВРЕМЯ(1, 1, 1) КАК ДатаГражданство,
	|	втСубклиенты.КонтрагентСубклиента КАК КонтрагентСубклиента
	|ПОМЕСТИТЬ втСубклиентыДатыИзменений
	|ИЗ
	|	втСубклиенты КАК втСубклиенты
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.КонтактнаяИнформация КАК КонтактнаяИнформация
	|		ПО втСубклиенты.Субклиент = КонтактнаяИнформация.Объект
	|			И (КонтактнаяИнформация.Тип = &Адрес)
	|			И (КонтактнаяИнформация.Объект ССЫЛКА Справочник.ЮридическиеЛица
	|					И КонтактнаяИнформация.Вид = &ФактАдресЮрЛица
	|				ИЛИ КонтактнаяИнформация.Объект ССЫЛКА Справочник.ФизическиеЛица
	|					И КонтактнаяИнформация.Вид = &ФактАдресФизЛица)
	|			И (КонтактнаяИнформация.Период <= &КонецПериода)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	втСубклиенты.Субклиент,
	|	ДАТАВРЕМЯ(1, 1, 1),
	|	КонтактнаяИнформация.Период,
	|	ДАТАВРЕМЯ(1, 1, 1),
	|	ДАТАВРЕМЯ(1, 1, 1),
	|	ДАТАВРЕМЯ(1, 1, 1),
	|	ДАТАВРЕМЯ(1, 1, 1),
	|	ДАТАВРЕМЯ(1, 1, 1),
	|	втСубклиенты.КонтрагентСубклиента
	|ИЗ
	|	втСубклиенты КАК втСубклиенты
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.КонтактнаяИнформация КАК КонтактнаяИнформация
	|		ПО втСубклиенты.Субклиент = КонтактнаяИнформация.Объект
	|			И (КонтактнаяИнформация.Тип = &Адрес)
	|			И (КонтактнаяИнформация.Объект ССЫЛКА Справочник.ЮридическиеЛица
	|					И КонтактнаяИнформация.Вид = &ЮрАдресЮрЛица
	|				ИЛИ КонтактнаяИнформация.Объект ССЫЛКА Справочник.ФизическиеЛица
	|					И КонтактнаяИнформация.Вид = &ЮрАдресФизЛица)
	|			И (КонтактнаяИнформация.Период <= &КонецПериода)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	втСубклиенты.Субклиент,
	|	ДАТАВРЕМЯ(1, 1, 1),
	|	ДАТАВРЕМЯ(1, 1, 1),
	|	КонтактнаяИнформация.Период,
	|	ДАТАВРЕМЯ(1, 1, 1),
	|	ДАТАВРЕМЯ(1, 1, 1),
	|	ДАТАВРЕМЯ(1, 1, 1),
	|	ДАТАВРЕМЯ(1, 1, 1),
	|	втСубклиенты.КонтрагентСубклиента
	|ИЗ
	|	втСубклиенты КАК втСубклиенты
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.КонтактнаяИнформация КАК КонтактнаяИнформация
	|		ПО втСубклиенты.Субклиент = КонтактнаяИнформация.Объект
	|			И (КонтактнаяИнформация.Тип = &АдресЭлектроннойПочты)
	|			И (КонтактнаяИнформация.Объект ССЫЛКА Справочник.ЮридическиеЛица
	|					И КонтактнаяИнформация.Вид = &EmailЮрЛица
	|				ИЛИ КонтактнаяИнформация.Объект ССЫЛКА Справочник.ФизическиеЛица
	|					И КонтактнаяИнформация.Вид = &EmailФизЛица)
	|			И (КонтактнаяИнформация.Период <= &КонецПериода)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	втСубклиенты.Субклиент,
	|	ДАТАВРЕМЯ(1, 1, 1),
	|	ДАТАВРЕМЯ(1, 1, 1),
	|	ДАТАВРЕМЯ(1, 1, 1),
	|	КонтактнаяИнформация.Период,
	|	ДАТАВРЕМЯ(1, 1, 1),
	|	ДАТАВРЕМЯ(1, 1, 1),
	|	ДАТАВРЕМЯ(1, 1, 1),
	|	втСубклиенты.КонтрагентСубклиента
	|ИЗ
	|	втСубклиенты КАК втСубклиенты
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.КонтактнаяИнформация КАК КонтактнаяИнформация
	|		ПО втСубклиенты.Субклиент = КонтактнаяИнформация.Объект
	|			И (КонтактнаяИнформация.Тип = &Телефон)
	|			И (КонтактнаяИнформация.Объект ССЫЛКА Справочник.ЮридическиеЛица
	|					И КонтактнаяИнформация.Вид = &ТелефонЮрЛица
	|				ИЛИ КонтактнаяИнформация.Объект ССЫЛКА Справочник.ФизическиеЛица
	|					И КонтактнаяИнформация.Вид = &ТелефонФизЛица)
	|			И (КонтактнаяИнформация.Период <= &КонецПериода)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	втСубклиенты.Субклиент,
	|	ДАТАВРЕМЯ(1, 1, 1),
	|	ДАТАВРЕМЯ(1, 1, 1),
	|	ДАТАВРЕМЯ(1, 1, 1),
	|	ДАТАВРЕМЯ(1, 1, 1),
	|	ФИОФизЛиц.Период,
	|	ДАТАВРЕМЯ(1, 1, 1),
	|	ДАТАВРЕМЯ(1, 1, 1),
	|	втСубклиенты.КонтрагентСубклиента
	|ИЗ
	|	втСубклиенты КАК втСубклиенты
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ФИОФизЛиц КАК ФИОФизЛиц
	|		ПО втСубклиенты.Субклиент = ФИОФизЛиц.ФизЛицо
