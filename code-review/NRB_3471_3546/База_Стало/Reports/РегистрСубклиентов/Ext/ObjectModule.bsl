	|	втСубклиенты.КонтрагентСубклиента КАК КонтрагентСубклиента,
	|	втСубклиенты.ДоговорДУ КАК ДоговорДУ
	|ИЗ
	|	втСубклиенты КАК втСубклиенты
	|
	|УПОРЯДОЧИТЬ ПО
	|	Субклиент,
	|	втСубклиенты.ДоговорДУ.Код,
	|	втСубклиенты.ДУ.Наименование";
	
КонецФункции

Функция СтрокаИзДаты(Дата)
	
	Если ЗначениеЗаполнено(Дата) Тогда
		Возврат Формат(Дата, "ДФ=dd.MM.yyyy");
	Иначе
		Возврат "";
	КонецЕсли;
	
КонецФункции

Функция ПредставлениеГражданстваФизлица(ФизЛицо, Гражданство, Дата)
	
	СтрокаРезультат = "";
	Если ЗначениеЗаполнено(Гражданство) Тогда
		СтрокаРезультат = СокрЛП(Гражданство);
	Иначе
		ТекстСообщения = "Для физ.лица " + СокрЛП(ФизЛицо) + " на " + Формат(Дата, "ДЛФ=Д") + " не указано гражданство!";
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
	КонецЕсли;
	Возврат СтрокаРезультат;
	
КонецФункции

Функция ПредставлениеДокументаФизлица(ФизЛицо, ДанныеДокумента, Дата)
	
	СтрокаРезультат = "";
	Если ЗначениеЗаполнено(ДанныеДокумента.ДокументВид) Тогда
		СтрокаРезультат = 
		?(ДанныеДокумента.ДокументВид = Справочники.ДокументыУдостоверяющиеЛичность.ИМНС21, "Паспорт РФ", СокрЛП(ДанныеДокумента.ДокументВид))
		+ ?(ЗначениеЗаполнено(ДанныеДокумента.ДокументСерия), " серия " + ДанныеДокумента.ДокументСерия, "")
		+ " № " + ДанныеДокумента.ДокументНомер
		+ ", выдан " + Формат(ДанныеДокумента.ДокументДатаВыдачи, "ДФ='дд ММММ гггг';ДП='...'") + " г. " 
		+ ДанныеДокумента.ДокументКемВыдан
		+ ?(ЗначениеЗаполнено(ДанныеДокумента.ДокументКодПодразделения), ", № подр. " + ДанныеДокумента.ДокументКодПодразделения, "");
	Иначе
		ТекстСообщения = "Для физ.лица " + СокрЛП(ФизЛицо) + " на " + Формат(Дата, "ДЛФ=Д") + " не указан вид документа!";
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
	КонецЕсли;
	
	Возврат СтрокаРезультат;
КонецФункции

Функция ОГРН(ОГРН, ДатаГосРегистрации, Резидент)
	
	СтрокаРезультат = "";	
	Если ЗначениеЗаполнено(ОГРН) Тогда
		СтрокаРезультат = ?(Резидент, "ОГРН ", "") + СокрЛП(ОГРН);
	КонецЕсли;
	Если ЗначениеЗаполнено(ДатаГосРегистрации) Тогда
		СтрокаРезультат = ?(ЗначениеЗаполнено(СтрокаРезультат), СтрокаРезультат + " ", "")
			+ "Дата регистрации " + СтрокаИзДаты(ДатаГосРегистрации);
	КонецЕсли;
	Возврат СтрокаРезультат;
	
КонецФункции

