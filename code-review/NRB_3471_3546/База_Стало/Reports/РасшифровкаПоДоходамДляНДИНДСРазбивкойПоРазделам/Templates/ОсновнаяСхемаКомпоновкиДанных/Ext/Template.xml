		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ
	Поручение.Ссылка КАК Поручение,
	ПоручениеЦенныеБумагиСписываемые.РазделСчетаДепо КАК РазделСчетаДепо,
	Поручение.Валюта КАК Валюта,
	ПоручениеЦенныеБумагиСписываемые.Сумма КАК Сумма,
	ПоручениеЦенныеБумагиСписываемые.СуммаНалога КАК СуммаНалога,
	ВЫБОР
		КОГДА Поручение.Валюта = &amp;ВалютаRUB
			ТОГДА ПоручениеЦенныеБумагиСписываемые.Сумма - ПоручениеЦенныеБумагиСписываемые.СуммаНалога
		ИНАЧЕ ПоручениеЦенныеБумагиСписываемые.Сумма
	КОНЕЦ КАК СуммаКВыплате,
	ПоручениеЦенныеБумагиСписываемые.СтавкаНалога КАК СтавкаНалога,
	ПоручениеЦенныеБумагиСписываемые.СтатьиНКРФСоглашения КАК СтатьиНКРФСоглашения,
	Поручение.ДатаФиксации КАК ДатаФиксации,
	Поручение.ДатаПлатежногоПоручения КАК ДатаПолученияНаСДС,
	Поручение.ДатаИсполненияПоручения КАК ДатаВыплатыКлиенту,
	Поручение.Комментарий КАК Комментарий
ИЗ
	Документ.Поручение.ЦенныеБумагиСписываемые КАК ПоручениеЦенныеБумагиСписываемые
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.Поручение КАК Поручение
		ПО ПоручениеЦенныеБумагиСписываемые.Ссылка = Поручение.Ссылка
			И (ПоручениеЦенныеБумагиСписываемые.СчетДепо.ТипСчетаДепо В (&amp;ТипыСчетовНоминальныхДержателей))
ГДЕ
	Поручение.Проведен
	И ПоручениеЦенныеБумагиСписываемые.Ссылка.ВидОперацииД В (&amp;НачислениеДивидендов, &amp;ПогашениеНКД, &amp;ПогашениеЦБЧастичное, &amp;ПогашениеЦБПолное)
	И НЕ ПоручениеЦенныеБумагиСписываемые.Ссылка.ДатаИсполненияПоручения = ДАТАВРЕМЯ(1, 1, 1)
{ГДЕ
	(Поручение.Ссылка = &amp;Поручение),
	(Поручение.Дата &gt;= &amp;ДатаНачала),
	(Поручение.Дата &lt;= &amp;ДатаОкончания)}</query>
	</dataSet>
