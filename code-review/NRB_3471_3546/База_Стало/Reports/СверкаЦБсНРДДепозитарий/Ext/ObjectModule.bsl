КонецФункции

Функция ТекстЗапросаОстаткиЗаблокированныхЦБ()
	ТекстЗапроса = 
	"ВЫБРАТЬ
	|	Остатки.ЦеннаяБумага КАК ЦБ,
	|	Остатки.СчетДепоМХ.Код КАК НомерСчетаДепо,
	|	Остатки.БлокировочныйРазделСчетаДепоМХ.Код КАК НомерРазделаСчетаДепо,
	|	ЕСТЬNULL(КодыЗагрузки.КодНРД, """") КАК КодНРД,
	|	ВЫБОР
	|		КОГДА Остатки.ЦеннаяБумага.Дробная И Остатки.ЦеннаяБумага.Числитель <> 0
	|			ТОГДА Остатки.КоличествоОстаток / Остатки.ЦеннаяБумага.Числитель * Остатки.ЦеннаяБумага.Знаменатель
	|		ИНАЧЕ Остатки.КоличествоОстаток
	|	КОНЕЦ КАК ОстатокДепо,
	|	Остатки.ЦеннаяБумага.НомерРегистрации КАК НомерРегистрации,
	|	Остатки.ЦеннаяБумага.ISIN КАК ISIN,
	|	Остатки.ЦеннаяБумага.Наименование КАК ЦеннаяБумагаНаименование,
	|	"""" КАК КодКлиента
	|ПОМЕСТИТЬ втОстаткиЗаблокированныхЦБ
	|ИЗ
	|	РегистрНакопления.ЗаблокированныеЦБвВышестоящемДепозитарии.Остатки(&ДатаСверкиНачалоСледующегоДня) КАК Остатки
	|	ЛЕВОЕ СОЕДИНЕНИЕ втКодыЗагрузки КАК КодыЗагрузки
	|	ПО
	|		Остатки.ЦеннаяБумага = КодыЗагрузки.ЦБ
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	Остатки.ЦеннаяБумага КАК ЦБ,
	|	Остатки.СчетДепоМХ.Код КАК НомерСчетаДепо,
	|	Остатки.РазделСчетаДепоМХ.Код КАК НомерРазделаСчетаДепо,
	|	ЕСТЬNULL(КодыЗагрузки.КодНРД, """") КАК КодНРД,
	|	ВЫБОР
	|		КОГДА Остатки.ЦеннаяБумага.Дробная И Остатки.ЦеннаяБумага.Числитель <> 0
	|			ТОГДА -Остатки.КоличествоОстаток / Остатки.ЦеннаяБумага.Числитель * Остатки.ЦеннаяБумага.Знаменатель
	|		ИНАЧЕ -Остатки.КоличествоОстаток
	|	КОНЕЦ КАК ОстатокДепо,
	|	Остатки.ЦеннаяБумага.НомерРегистрации КАК НомерРегистрации,
	|	Остатки.ЦеннаяБумага.ISIN КАК ISIN,
	|	Остатки.ЦеннаяБумага.Наименование КАК ЦеннаяБумагаНаименование,
	|	"""" КАК КодКлиента
	|ИЗ
	|	РегистрНакопления.ЗаблокированныеЦБвВышестоящемДепозитарии.Остатки(&ДатаСверкиНачалоСледующегоДня) КАК Остатки
	|	ЛЕВОЕ СОЕДИНЕНИЕ втКодыЗагрузки КАК КодыЗагрузки
	|	ПО
	|		Остатки.ЦеннаяБумага = КодыЗагрузки.ЦБ
	|";
	Возврат ТекстЗапроса;
КонецФункции

Функция ТекстЗапросаПроверкаНаДублированиеКодовЗагрузки()
	Возврат
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	втОстатки.ЦБ КАК ЦБ
	|ПОМЕСТИТЬ втРазличныеЦБ
	|ИЗ
	|	втОстатки КАК втОстатки
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	втРазличныеЦБ.ЦБ КАК ЦБ,
	|	втРазличныеЦБ.ЦБ.Наименование КАК Наименование,
	|	втРазличныеЦБ.ЦБ.НомерРегистрации КАК НомерРегистрации,
	|	КОЛИЧЕСТВО(втРазличныеЦБ.ЦБ) КАК КоличествоКодов
	|ИЗ
	|	втРазличныеЦБ КАК втРазличныеЦБ
	|		ЛЕВОЕ СОЕДИНЕНИЕ втКодыЗагрузки КАК втКодыЗагрузки
	|		ПО втРазличныеЦБ.ЦБ = втКодыЗагрузки.ЦБ
	|
	|СГРУППИРОВАТЬ ПО
	|	втРазличныеЦБ.ЦБ
	|
	|ИМЕЮЩИЕ
	|	КОЛИЧЕСТВО(втРазличныеЦБ.ЦБ) > 1
	|
	|УПОРЯДОЧИТЬ ПО
	|	Наименование,
	|	НомерРегистрации
	|";
КонецФункции

Функция ТекстЗапросаПроверкаНаСуществованиеКодовЗагрузки()
	Возврат
	"ВЫБРАТЬ
	|	втОстатки.ЦБ КАК ЦБ,
	|	втОстатки.ЦБ.Наименование КАК Наименование,
	|	втОстатки.ЦБ.НомерРегистрации КАК НомерРегистрации
	|ИЗ
	|	втОстатки КАК втОстатки
	|ГДЕ
	|	втОстатки.КодНРД = """"
	|
	|СГРУППИРОВАТЬ ПО
	|	втОстатки.ЦБ
	|
	|УПОРЯДОЧИТЬ ПО
	|	Наименование,
	|	НомерРегистрации";	
КонецФункции

Функция ДанныеЗапросаСверкиПоЦБ()
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("ТаблицаСверки",	ТаблицаСверки);
	Запрос.УстановитьПараметр("ДатаСверки",		КонецДня(ДатаСверки));
	Запрос.УстановитьПараметр("НДЦ",			Справочники.КлассификаторыЗагрузки.НДЦ());
	Запрос.УстановитьПараметр("ВыводитьТолькоРасхождения", ВыводитьТолькоРасхождения);
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ТаблицаСверки.НомерСчетаДепо КАК НомерСчетаДепо,
	|	ТаблицаСверки.НомерРазделаСчетаДепо КАК НомерРазделаСчетаДепо,
	|	ТаблицаСверки.КодНРД КАК КодНРД,
	|	ТаблицаСверки.ОстатокВнешнегоИсточника КАК ОстатокВнешнегоИсточника,
	|	ТаблицаСверки.ОстатокДепо КАК ОстатокДепо,
	|	ТаблицаСверки.ЦеннаяБумагаНаименование КАК ЦеннаяБумагаНаименование,
	|	ТаблицаСверки.НомерРегистрации КАК НомерРегистрации
	|ПОМЕСТИТЬ втДанные
	|ИЗ
	|	&ТаблицаСверки КАК ТаблицаСверки
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	НомерСчетаДепо,
	|	НомерРазделаСчетаДепо,
	|	НомерРегистрации,
	|	КодНРД
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	втДанные.НомерСчетаДепо КАК НомерСчетаДепо,
	|	втДанные.НомерРазделаСчетаДепо КАК НомерРазделаСчетаДепо,
	|	втДанные.КодНРД КАК КодНРД,
	|	МАКСИМУМ(втДанные.НомерРегистрации) КАК НомерРегистрации
	|ПОМЕСТИТЬ втКлючи
	|ИЗ
	|	втДанные КАК втДанные
	|
	|СГРУППИРОВАТЬ ПО
	|	втДанные.НомерСчетаДепо,
	|	втДанные.НомерРазделаСчетаДепо,
	|	втДанные.КодНРД
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	НомерСчетаДепо,
	|	НомерРазделаСчетаДепо,
	|	НомерРегистрации,
	|	КодНРД
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	втДанные.КодНРД КАК КодНРД,
	|	МАКСИМУМ(втДанные.ЦеннаяБумагаНаименование) КАК ЦеннаяБумагаНаименование
	|ПОМЕСТИТЬ втНаименованияПоКодуНРД
	|ИЗ
	|	втДанные КАК втДанные
	|
	|СГРУППИРОВАТЬ ПО
	|	втДанные.КодНРД
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	КодНРД
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	втДанные.НомерРегистрации КАК НомерРегистрации,
	|	МАКСИМУМ(втДанные.ЦеннаяБумагаНаименование) КАК ЦеннаяБумагаНаименование
	|ПОМЕСТИТЬ втНаименованияПоНомеруРегистрации
	|ИЗ
	|	втДанные КАК втДанные
	|
	|СГРУППИРОВАТЬ ПО
	|	втДанные.НомерРегистрации
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	НомерРегистрации
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	КодыЗагрузки.Владелец КАК ЦеннаяБумага,
	|	ПРЕДСТАВЛЕНИЕ(КодыЗагрузки.Владелец) КАК ЦеннаяБумагаНаименование,
	|	КодыЗагрузки.Владелец.НомерРегистрации КАК НомерРегистрации,
	|	МАКСИМУМ(КодыЗагрузки.Код) КАК КодНРД
	|ПОМЕСТИТЬ втКодыЗагрузки
	|ИЗ
	|	Справочник.КодыЗагрузки КАК КодыЗагрузки
	|ГДЕ
	|	(КодыЗагрузки.ДатаОкончанияДействия = ДАТАВРЕМЯ(1, 1, 1)
	|			ИЛИ КодыЗагрузки.ДатаОкончанияДействия > &ДатаСверки)
	|	И КодыЗагрузки.Биржа = &НДЦ
	|	И КодыЗагрузки.Владелец ССЫЛКА Справочник.ЦенныеБумаги
	|	И НЕ КодыЗагрузки.ПометкаУдаления
	|
	|СГРУППИРОВАТЬ ПО
	|	КодыЗагрузки.Владелец,
	|	КодыЗагрузки.Владелец.НомерРегистрации
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	КодНРД
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	втКлючи.НомерСчетаДепо КАК НомерСчетаДепо,
	|	втКлючи.НомерРазделаСчетаДепо КАК НомерРазделаСчетаДепо,
	|	втКлючи.КодНРД КАК КодНРД,
	|	"""" КАК НомерРегистрации,
	|	СУММА(втДанные.ОстатокВнешнегоИсточника) КАК ОстатокВнешнегоИсточника,
	|	СУММА(втДанные.ОстатокДепо) КАК ОстатокДепо,
	|	МАКСИМУМ(втНаименования.ЦеннаяБумагаНаименование) КАК ЦеннаяБумагаНаименование
	|ПОМЕСТИТЬ втОбъединенныеДанные
	|ИЗ
	|	втКлючи КАК втКлючи
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ втДанные КАК втДанные
	|		ПО втКлючи.НомерСчетаДепо = втДанные.НомерСчетаДепо
	|			И втКлючи.НомерРазделаСчетаДепо = втДанные.НомерРазделаСчетаДепо
	|			И втКлючи.КодНРД = втДанные.КодНРД
	|		ЛЕВОЕ СОЕДИНЕНИЕ втНаименованияПоКодуНРД КАК втНаименования
	|		ПО втКлючи.КодНРД = втНаименования.КодНРД
	|ГДЕ
	|	втКлючи.КодНРД <> """"
	|
	|СГРУППИРОВАТЬ ПО
	|	втКлючи.НомерСчетаДепо,
	|	втКлючи.НомерРазделаСчетаДепо,
	|	втКлючи.КодНРД
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	втКлючи.НомерСчетаДепо,
	|	втКлючи.НомерРазделаСчетаДепо,
	|	"""",
	|	втКлючи.НомерРегистрации,
	|	СУММА(втДанные.ОстатокВнешнегоИсточника),
	|	СУММА(втДанные.ОстатокДепо),
	|	МАКСИМУМ(втНаименования.ЦеннаяБумагаНаименование)
	|ИЗ
	|	втКлючи КАК втКлючи
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ втДанные КАК втДанные
	|		ПО втКлючи.НомерСчетаДепо = втДанные.НомерСчетаДепо
	|			И втКлючи.НомерРазделаСчетаДепо = втДанные.НомерРазделаСчетаДепо
	|			И втКлючи.НомерРегистрации = втДанные.НомерРегистрации
	|		ЛЕВОЕ СОЕДИНЕНИЕ втНаименованияПоНомеруРегистрации КАК втНаименования
	|		ПО втКлючи.НомерРегистрации = втНаименования.НомерРегистрации
	|ГДЕ
	|	втКлючи.НомерРегистрации <> """"
	|	И втКлючи.КодНРД = """"
	|
	|СГРУППИРОВАТЬ ПО
	|	втКлючи.НомерСчетаДепо,
	|	втКлючи.НомерРазделаСчетаДепо,
	|	втКлючи.НомерРегистрации
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	КодНРД
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Данные.НомерСчетаДепо КАК НомерСчетаДепо,
	|	Данные.НомерРазделаСчетаДепо КАК НомерРазделаСчетаДепо,
	|	Данные.КодНРД КАК КодНРД,
	|	Данные.ОстатокВнешнегоИсточника КАК ОстатокВнешнегоИсточника,
	|	Данные.ОстатокДепо КАК ОстатокДепо,
	|	Данные.ОстатокДепо - Данные.ОстатокВнешнегоИсточника КАК Расхождение,
	|	ЕСТЬNULL(КодыЗагрузки.ЦеннаяБумага, Данные.ЦеннаяБумагаНаименование) КАК ЦеннаяБумага,
	|	ЕСТЬNULL(КодыЗагрузки.НомерРегистрации, Данные.НомерРегистрации) КАК НомерРегистрации,
	|	ЕСТЬNULL(КодыЗагрузки.ЦеннаяБумагаНаименование, Данные.ЦеннаяБумагаНаименование) КАК ЦеннаяБумагаНаименование
	|ИЗ
	|	втОбъединенныеДанные КАК Данные
	|		ЛЕВОЕ СОЕДИНЕНИЕ втКодыЗагрузки КАК КодыЗагрузки
	|		ПО (КодыЗагрузки.КодНРД = Данные.КодНРД)
	|
	|ГДЕ
	|	(Данные.ОстатокДепо - Данные.ОстатокВнешнегоИсточника <> 0)
	|	ИЛИ НЕ &ВыводитьТолькоРасхождения
	|
	|УПОРЯДОЧИТЬ ПО
	|	НомерСчетаДепо,
	|	НомерРазделаСчетаДепо,
	|	КодНРД
	|
	|ИТОГИ
	|	СУММА(ОстатокВнешнегоИсточника),
	|	СУММА(ОстатокДепо),
	|	СУММА(Расхождение)
	|ПО
	|	НомерСчетаДепо,
	|	НомерРазделаСчетаДепо";
	Возврат Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
КонецФункции

Процедура ВывестиДанныеПоЦБ(Дерево, Результат)
	
	Результат.Очистить();	
	Макет = ПолучитьМакет("Макет");		
	ОбластьШапка = Макет.ПолучитьОбласть("Шапка");
	ОбластьШапкаМестаХранения = Макет.ПолучитьОбласть("ШапкаМестаХранения");
	ОбластьСтрокаЦБ = Макет.ПолучитьОбласть("СтрокаЦБ");
	ОбластьПодвал = Макет.ПолучитьОбласть("Подвал");
	
	// Шапка
	ОбластьШапка.Параметры.ДатаСверки  = "на конец дня: " + Формат(ДатаСверки, "ДЛФ=D");
	ОбластьШапка.Параметры.ИсточникВШапке = "НРД";
	ОбластьШапка.Параметры.ИсточникВТаблице = "НРД";
	Результат.Вывести(ОбластьШапка);
	
	Результат.НачатьАвтогруппировкуСтрок();
	
	Пока Дерево.Следующий() Цикл
		ВыборкаРазделов = Дерево.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		Пока ВыборкаРазделов.Следующий() Цикл
			ОбластьШапкаМестаХранения.Параметры.Заполнить(ВыборкаРазделов);
			ОбластьШапкаМестаХранения.Параметры.МестоХранения = 
				"Счет депо: " + ВыборкаРазделов.НомерСчетаДепо +
				"; раздел счета депо: " + ВыборкаРазделов.НомерРазделаСчетаДепо;
			Результат.Вывести(ОбластьШапкаМестаХранения, 1);
					
			ВыборкаЦБ = ВыборкаРазделов.Выбрать();			
			Пока ВыборкаЦБ.Следующий() Цикл				
				ОбластьСтрокаЦБ.Параметры.Заполнить(ВыборкаЦБ);
				Если ЗначениеЗаполнено(ВыборкаЦБ.ЦеннаяБумага) Тогда
					ОбластьСтрокаЦБ.Область("ЦеннаяБумага").Расшифровка = ВыборкаЦБ.ЦеннаяБумага;
				КонецЕсли;
				Если ВыборкаЦБ.Расхождение = 0 Тогда
					ЦветФонаРасхождения = WebЦвета.МятныйКрем;
				Иначе
					ЦветФонаРасхождения = WebЦвета.Розовый; // Выделяем ошибки цветом
				КонецЕсли;
				ОбластьСтрокаЦБ.Область("Расхождение").ЦветФона = ЦветФонаРасхождения;
				Результат.Вывести(ОбластьСтрокаЦБ, 2);
			КонецЦикла;
		КонецЦикла;
	КонецЦикла;
	
	Результат.ЗакончитьАвтогруппировкуСтрок();
	
	ОбластьПодвал.Параметры.ДатаВремяФормирования = "Время формирования отчета (1С): " + ТекущаяДатаСеанса();
	Результат.Вывести(ОбластьПодвал);
	
	Результат.ПоказатьУровеньГруппировокСтрок(0);
	Результат.ФиксацияСверху = 3;
	Результат.ПовторятьПриПечатиСтроки = Результат.Область("R3:R3");
КонецПроцедуры

Функция ДанныеЗапросаСверкиПоКлиентам()
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("ТаблицаСверки",	ТаблицаСверки);
	Запрос.УстановитьПараметр("ДатаСверки",		КонецДня(ДатаСверки));
	Запрос.УстановитьПараметр("НДЦ",			Справочники.КлассификаторыЗагрузки.НДЦ());
	Запрос.УстановитьПараметр("ВыводитьТолькоРасхождения", ВыводитьТолькоРасхождения);
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ТаблицаСверки.НомерСчетаДепо КАК НомерСчетаДепо,
	|	ТаблицаСверки.НомерРазделаСчетаДепо КАК НомерРазделаСчетаДепо,
	|	ТаблицаСверки.СчетДепоДепонента КАК СчетДепоДепонента,
	|	ТаблицаСверки.КодНРД КАК КодНРД,
	|	ТаблицаСверки.ОстатокВнешнегоИсточника КАК ОстатокВнешнегоИсточника,
	|	ТаблицаСверки.ОстатокДепо КАК ОстатокДепо,
	|	ТаблицаСверки.ЦеннаяБумагаНаименование КАК ЦеннаяБумагаНаименование,
	|	ТаблицаСверки.НомерРегистрации КАК НомерРегистрации,
	|	ТаблицаСверки.ISIN КАК ISIN,
	|	ТаблицаСверки.КодКлиента КАК КодКлиента,
	|	ТаблицаСверки.КодСубклиента КАК КодСубклиента
	|ПОМЕСТИТЬ втДанные
	|ИЗ
	|	&ТаблицаСверки КАК ТаблицаСверки
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	НомерСчетаДепо,
	|	НомерРазделаСчетаДепо,
	|	СчетДепоДепонента,
	|	НомерРегистрации,
	|	ISIN,
	|	КодНРД,
	|	КодКлиента,
	|	КодСубклиента
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	МАКСИМУМ(КодыЗагрузки.Владелец) КАК Ссылка,
	|	КодыЗагрузки.Код КАК Код
	|ПОМЕСТИТЬ Контрагенты
	|ИЗ
	|	Справочник.КодыЗагрузки КАК КодыЗагрузки
	|ГДЕ
	|	(КодыЗагрузки.Владелец ССЫЛКА Справочник.ФизическиеЛица
	|			ИЛИ КодыЗагрузки.Владелец ССЫЛКА Справочник.ЮридическиеЛица)
	|	И КодыЗагрузки.Биржа = ЗНАЧЕНИЕ(Справочник.КлассификаторыЗагрузки.Клиенты)
	|	И НЕ КодыЗагрузки.ПометкаУдаления
	|	И ВЫБОР
	|			КОГДА КодыЗагрузки.ДатаОкончанияДействия = ДАТАВРЕМЯ(1, 1, 1)
	|				ТОГДА ИСТИНА
	|			ИНАЧЕ КодыЗагрузки.ДатаОкончанияДействия > &ДатаСверки
	|		КОНЕЦ
	|
	|СГРУППИРОВАТЬ ПО
	|	КодыЗагрузки.Код
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ТЗ.НомерРегистрации КАК НомерРегистрации,
