	|ПОМЕСТИТЬ втЦБпоГосНомерам
	|ИЗ
	|	втДанные КАК ТЗ
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ЦенныеБумаги КАК ЦенныеБумаги
	|		ПО ТЗ.НомерРегистрации = ЦенныеБумаги.НомерРегистрации
	|			И (ТЗ.НомерРегистрации <> """")
	|			И (НЕ ЦенныеБумаги.ПометкаУдаления)
	|
	|СГРУППИРОВАТЬ ПО
	|	ТЗ.НомерРегистрации
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ТЗ.ISIN КАК ISIN,
	|	МАКСИМУМ(ЦенныеБумаги.Ссылка) КАК ЦеннаяБумага
	|ПОМЕСТИТЬ втЦБпоISIN
	|ИЗ
	|	втДанные КАК ТЗ
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ЦенныеБумаги КАК ЦенныеБумаги
	|		ПО ТЗ.ISIN = ЦенныеБумаги.ISIN
	|			И (ТЗ.ISIN <> """")
	|			И (НЕ ЦенныеБумаги.ПометкаУдаления)
	|
	|СГРУППИРОВАТЬ ПО
	|	ТЗ.ISIN
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ЦенныеБумаги.ISIN КАК ISIN,
	|	ЦенныеБумаги.НомерРегистрации КАК НомерРегистрации,
	|	ЦенныеБумаги.Ссылка КАК Ссылка,
	|	ЦенныеБумаги.ДатаПриемаНаОбслуживание КАК ДатаПриемаНаОбслуживание,
	|	ЦенныеБумаги.ДатаСнятияСОбслуживания КАК ДатаСнятияСОбслуживания
	|ПОМЕСТИТЬ втЦенныеБумаги1СДепоСДублями
	|ИЗ
	|	втДанные КАК ТЗ
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ЦенныеБумаги КАК ЦенныеБумаги
	|		ПО ТЗ.ISIN = ЦенныеБумаги.ISIN
	|			И ТЗ.НомерРегистрации = ЦенныеБумаги.НомерРегистрации
	|			И (ТЗ.ISIN <> """")
	|			И (НЕ ЦенныеБумаги.ПометкаУдаления)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВЫБОР
	|		КОГДА ЦенныеБумаги.ДатаПриемаНаОбслуживание <> ДАТАВРЕМЯ(1, 1, 1)
	|				И ЦенныеБумаги.ДатаСнятияСОбслуживания = ДАТАВРЕМЯ(1, 1, 1)
	|			ТОГДА 1
	|		ИНАЧЕ 0
	|	КОНЕЦ * 100 + ВЫБОР
	|		КОГДА ДЛИНАСТРОКИ(ЕСТЬNULL(КодыЗагрузки.Код, """")) > 0
	|			ТОГДА ВЫБОР
	|					КОГДА СТРНАЙТИ(ЕСТЬNULL(КодыЗагрузки.Код, """"), ""/"") = 0
	|						ТОГДА 2
	|					ИНАЧЕ 1
	|				КОНЕЦ
	|		ИНАЧЕ 0
	|	КОНЕЦ * 10 КАК Приоритет,
	|	ЦенныеБумаги.ISIN КАК ISIN,
	|	ЦенныеБумаги.НомерРегистрации КАК НомерРегистрации,
	|	ЦенныеБумаги.Ссылка КАК ЦеннаяБумага
	|ПОМЕСТИТЬ втЦенныеБумаги1СДепоСПриоритетом
	|ИЗ
	|	втЦенныеБумаги1СДепоСДублями КАК ЦенныеБумаги
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.КодыЗагрузки КАК КодыЗагрузки
	|		ПО ЦенныеБумаги.Ссылка = КодыЗагрузки.Владелец
	|			И (КодыЗагрузки.Биржа = ЗНАЧЕНИЕ(Справочник.КлассификаторыЗагрузки.NrdCode))
	|			И (НЕ КодыЗагрузки.ПометкаУдаления)
	|			И (ВЫБОР
	|				КОГДА КодыЗагрузки.ДатаОкончанияДействия = ДАТАВРЕМЯ(1, 1, 1)
	|					ТОГДА ИСТИНА
	|				ИНАЧЕ КодыЗагрузки.ДатаОкончанияДействия > &ДатаСверки
	|			КОНЕЦ)
	|			И (КодыЗагрузки.ДатаНачалаДействия <= &ДатаСверки)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	МАКСИМУМ(втЦенныеБумаги1СДепоСПриоритетом.Приоритет) КАК Приоритет,
	|	втЦенныеБумаги1СДепоСПриоритетом.ISIN КАК ISIN,
	|	втЦенныеБумаги1СДепоСПриоритетом.НомерРегистрации КАК НомерРегистрации
	|ПОМЕСТИТЬ втЦенныеБумаги1СДепоСМаксимальнымПриоритетом
	|ИЗ
	|	втЦенныеБумаги1СДепоСПриоритетом КАК втЦенныеБумаги1СДепоСПриоритетом
	|
	|СГРУППИРОВАТЬ ПО
	|	втЦенныеБумаги1СДепоСПриоритетом.ISIN,
	|	втЦенныеБумаги1СДепоСПриоритетом.НомерРегистрации
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЦенныеБумаги.ISIN КАК ISIN,
	|	ЦенныеБумаги.НомерРегистрации КАК НомерРегистрации,
	|	МАКСИМУМ(ЦенныеБумаги.ЦеннаяБумага) КАК ЦеннаяБумага
	|ПОМЕСТИТЬ втЦБпоISINиГосНомерам
	|ИЗ
	|	втЦенныеБумаги1СДепоСПриоритетом КАК ЦенныеБумаги
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ втЦенныеБумаги1СДепоСМаксимальнымПриоритетом КАК втЦенныеБумаги1СДепоСМаксимальнымПриоритетом
	|		ПО ЦенныеБумаги.Приоритет = втЦенныеБумаги1СДепоСМаксимальнымПриоритетом.Приоритет
	|			И ЦенныеБумаги.ISIN = втЦенныеБумаги1СДепоСМаксимальнымПриоритетом.ISIN
	|			И ЦенныеБумаги.НомерРегистрации = втЦенныеБумаги1СДепоСМаксимальнымПриоритетом.НомерРегистрации
	|
	|СГРУППИРОВАТЬ ПО
	|	ЦенныеБумаги.ISIN,
	|	ЦенныеБумаги.НомерРегистрации
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Данные.НомерСчетаДепо КАК НомерСчетаДепо,
	|	Данные.НомерРазделаСчетаДепо КАК НомерРазделаСчетаДепо,
	|	Данные.СчетДепоДепонента КАК СчетДепоДепонента,
	|	МАКСИМУМ(Данные.КодНРД) КАК КодНРД,
	|	МАКСИМУМ(Данные.НомерРегистрации) КАК НомерРегистрации,
	|	МАКСИМУМ(Данные.ISIN) КАК ISIN,
	|	МАКСИМУМ(Данные.ЦеннаяБумагаНаименование) КАК ЦеннаяБумагаНаименование,
	|	Данные.КодКлиента КАК КодКлиента,
	|	Данные.КодСубклиента КАК КодСубклиента,
	|	СУММА(Данные.ОстатокДепо) КАК ОстатокДепо,
	|	СУММА(Данные.ОстатокВнешнегоИсточника) КАК ОстатокВнешнегоИсточника,
	|	ЕСТЬNULL(ЦБпоISINиГосНомерам.ЦеннаяБумага, ЕСТЬNULL(ЦБпоISIN.ЦеннаяБумага, ЕСТЬNULL(ЦБпоГосНомерам.ЦеннаяБумага, Данные.ЦеннаяБумагаНаименование))) КАК ЦеннаяБумага
	|ПОМЕСТИТЬ втДанныеПоЦБ
	|ИЗ
	|	втДанные КАК Данные
	|		ЛЕВОЕ СОЕДИНЕНИЕ втЦБпоISINиГосНомерам КАК ЦБпоISINиГосНомерам
	|		ПО Данные.ISIN = ЦБпоISINиГосНомерам.ISIN
	|			И Данные.НомерРегистрации = ЦБпоISINиГосНомерам.НомерРегистрации
	|		ЛЕВОЕ СОЕДИНЕНИЕ втЦБпоГосНомерам КАК ЦБпоГосНомерам
	|		ПО Данные.НомерРегистрации = ЦБпоГосНомерам.НомерРегистрации
	|		ЛЕВОЕ СОЕДИНЕНИЕ втЦБпоISIN КАК ЦБпоISIN
	|		ПО Данные.ISIN = ЦБпоISIN.ISIN
	|
	|СГРУППИРОВАТЬ ПО
	|	Данные.НомерСчетаДепо,
	|	Данные.НомерРазделаСчетаДепо,
	|	Данные.СчетДепоДепонента,
	|	Данные.КодКлиента,
	|	Данные.КодСубклиента,
	|	ЕСТЬNULL(ЦБпоISINиГосНомерам.ЦеннаяБумага, ЕСТЬNULL(ЦБпоISIN.ЦеннаяБумага, ЕСТЬNULL(ЦБпоГосНомерам.ЦеннаяБумага, Данные.ЦеннаяБумагаНаименование)))
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ДанныеПоЦБ.НомерСчетаДепо КАК НомерСчетаДепо,
	|	ДанныеПоЦБ.НомерРазделаСчетаДепо КАК НомерРазделаСчетаДепо,
	|	ДанныеПоЦБ.СчетДепоДепонента КАК СчетДепоДепонента,
	|	ДанныеПоЦБ.КодНРД КАК КодНРД,
	|	ЕСТЬNULL(ДанныеПоЦБ.ЦеннаяБумага.ISIN, ДанныеПоЦБ.ISIN) КАК ISIN,
	|	ЕСТЬNULL(ДанныеПоЦБ.ЦеннаяБумага.НомерРегистрации, ДанныеПоЦБ.НомерРегистрации) КАК НомерРегистрации,
	|	ЕСТЬNULL(ДанныеПоЦБ.ЦеннаяБумага.Наименование, ДанныеПоЦБ.ЦеннаяБумагаНаименование) КАК ЦеннаяБумагаНаименование,
	|	ДанныеПоЦБ.КодКлиента КАК КодКлиента,
	|	ДанныеПоЦБ.КодСубклиента КАК КодСубклиента,
	|	ДанныеПоЦБ.ОстатокДепо КАК ОстатокДепо,
	|	ДанныеПоЦБ.ОстатокВнешнегоИсточника КАК ОстатокВнешнегоИсточника,
	|	ДанныеПоЦБ.ОстатокДепо - ДанныеПоЦБ.ОстатокВнешнегоИсточника КАК Расхождение,
	|	ЕСТЬNULL(ДанныеПоЦБ.ЦеннаяБумага, ДанныеПоЦБ.ЦеннаяБумагаНаименование) КАК ЦеннаяБумага,
	|	ЕСТЬNULL(Контрагенты.Ссылка, ЗНАЧЕНИЕ(Справочник.Контрагенты.ПустаяСсылка)) КАК Клиент,
	|	ЕСТЬNULL(Субклиенты.Ссылка, ЗНАЧЕНИЕ(Справочник.Субклиенты.ПустаяСсылка)) КАК Субклиент,
	|	ЕСТЬNULL(СчетаДепо.Ссылка, ЗНАЧЕНИЕ(Справочник.СчетаДепо.ПустаяСсылка)) КАК СчетДепоДепонентаСсылка
	|ПОМЕСТИТЬ втСверкаСУточнениемЦБ
	|ИЗ
	|	втДанныеПоЦБ КАК ДанныеПоЦБ
	|		ЛЕВОЕ СОЕДИНЕНИЕ Контрагенты КАК Контрагенты
	|		ПО ДанныеПоЦБ.КодКлиента = Контрагенты.Код
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Субклиенты КАК Субклиенты
	|		ПО ДанныеПоЦБ.КодСубклиента = Субклиенты.Код
	|			И (Контрагенты.Ссылка = Субклиенты.Владелец)
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.СчетаДепо КАК СчетаДепо
	|		ПО ДанныеПоЦБ.СчетДепоДепонента = СчетаДепо.Код
	|ГДЕ
	|	(ДанныеПоЦБ.ОстатокДепо - ДанныеПоЦБ.ОстатокВнешнегоИсточника <> 0
	|			ИЛИ НЕ &ВыводитьТолькоРасхождения)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТЗ.НомерСчетаДепо КАК НомерСчетаДепо,
	|	ТЗ.НомерРазделаСчетаДепо КАК НомерРазделаСчетаДепо,
	|	ТЗ.СчетДепоДепонента КАК СчетДепоДепонента,
	|	ВЫБОР
	|		КОГДА ТЗ.КодНРД = """"
	|			ТОГДА ТЗ.ISIN
	|		ИНАЧЕ ТЗ.КодНРД
	|	КОНЕЦ КАК КодНРД,
	|	ТЗ.НомерРегистрации КАК НомерРегистрации,
	|	ТЗ.ОстатокДепо КАК ОстатокДепо,
	|	ТЗ.ОстатокВнешнегоИсточника КАК ОстатокВнешнегоИсточника,
	|	ТЗ.ЦеннаяБумагаНаименование КАК ЦеннаяБумагаНаименование,
	|	ТЗ.КодКлиента КАК КодКлиента,
	|	ТЗ.КодСубклиента КАК КодСубклиента,
	|	ТЗ.Расхождение КАК Расхождение,
	|	ТЗ.ЦеннаяБумага КАК ЦеннаяБумага,
	|	ТЗ.Клиент КАК Клиент,
	|	ТЗ.Субклиент КАК Субклиент,
	|	ТЗ.СчетДепоДепонентаСсылка КАК СчетДепоДепонентаСсылка
	|ИЗ
	|	втСверкаСУточнениемЦБ КАК ТЗ
	|
	|УПОРЯДОЧИТЬ ПО
	|	НомерСчетаДепо,
	|	НомерРазделаСчетаДепо,
	|	КодКлиента,
	|	КодСубклиента,
	|	СчетДепоДепонента,
	|	КодНРД
	|ИТОГИ
	|	СУММА(ОстатокДепо),
	|	СУММА(ОстатокВнешнегоИсточника),
	|	СУММА(Расхождение),
	|	МАКСИМУМ(Клиент),
	|	МАКСИМУМ(Субклиент),
	|	МАКСИМУМ(СчетДепоДепонентаСсылка)
	|ПО
	|	НомерСчетаДепо,
	|	НомерРазделаСчетаДепо,
	|	КодКлиента,
	|	КодСубклиента,
	|	СчетДепоДепонента";
	Возврат Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам); 
КонецФункции

Процедура ВывестиДанныеПоКлиентам(Дерево, Результат)
	
	Результат.Очистить();
	Макет = ПолучитьМакет("Макет");
	ОбластьШапка = Макет.ПолучитьОбласть("Шапка");
	ОбластьШапкаМестаХранения = Макет.ПолучитьОбласть("ШапкаМестаХранения");
	ОбластьСтрокаГруппировки = Макет.ПолучитьОбласть("СтрокаГруппировки");
	ОбластьСтрокаГруппировкиСчетДепоДепонента = Макет.ПолучитьОбласть("СтрокаГруппировкиСчетДепоДепонента");
	ОбластьСтрокаЦБ = Макет.ПолучитьОбласть("СтрокаЦБ");
	ОбластьПодвал = Макет.ПолучитьОбласть("Подвал");
	
	// Шапка
	ОбластьШапка.Параметры.ДатаСверки		 = "на конец дня: " + Формат(ДатаСверки, "ДЛФ=D");
	ОбластьШапка.Параметры.ИсточникВШапке	 = "Бэкофисом"; // BSLLS:Typo-off
	ОбластьШапка.Параметры.ИсточникВТаблице	 = "BQ:Бэкофис"; // BSLLS:Typo-off
	Результат.Вывести(ОбластьШапка);
	
	Результат.НачатьАвтогруппировкуСтрок();
	
	Пока Дерево.Следующий() Цикл
		ВыборкаРазделов = Дерево.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		Пока ВыборкаРазделов.Следующий() Цикл
			ОбластьШапкаМестаХранения.Параметры.Заполнить(ВыборкаРазделов);
			ОбластьШапкаМестаХранения.Параметры.МестоХранения = "Счет депо МХ: " + ВыборкаРазделов.НомерСчетаДепо
				+ "; раздел счета депо МХ: " + ВыборкаРазделов.НомерРазделаСчетаДепо;
			Результат.Вывести(ОбластьШапкаМестаХранения, 1);
			
			ВыборкаКлиентов = ВыборкаРазделов.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
			Пока ВыборкаКлиентов.Следующий() Цикл
				ВыборкаКлиентовИСубклиентов = ВыборкаКлиентов.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам); // BSLLS:Typo-off
				Пока ВыборкаКлиентовИСубклиентов.Следующий() Цикл
					
					ВывестиДанныеПоКлиентамДоСчетовДепо(Результат,
						ВыборкаКлиентов,
						ВыборкаКлиентовИСубклиентов,
						ОбластьСтрокаГруппировки,
						ОбластьСтрокаГруппировкиСчетДепоДепонента,
						ОбластьСтрокаЦБ);
					
				КонецЦикла;
			КонецЦикла;
		КонецЦикла;
	КонецЦикла;
	
	Результат.ЗакончитьАвтогруппировкуСтрок();
	
	ОбластьПодвал.Параметры.ДатаВремяФормирования = "Время формирования отчета (1С): " + ТекущаяДатаСеанса();
	Результат.Вывести(ОбластьПодвал);
	
	Результат.ПоказатьУровеньГруппировокСтрок(0);
	Результат.ФиксацияСверху = 3;
	Результат.ПовторятьПриПечатиСтроки = Результат.Область("R3:R3");
	
КонецПроцедуры

Процедура ВывестиДанныеПоКлиентамДоСчетовДепо(Результат,
	ВыборкаКлиентов,
	ВыборкаКлиентовИСубклиентов,
	ОбластьСтрокаГруппировки,
	ОбластьСтрокаГруппировкиСчетДепоДепонента,
	ОбластьСтрокаЦБ)
	
	КодСубклиента = ВыборкаКлиентовИСубклиентов.КодСубклиента; // BSLLS:Typo-off
	Если Не ПустаяСтрока(КодСубклиента) Тогда
		ТекстСубклиент = " Код субклиента: " + КодСубклиента; // BSLLS:Typo-off
	Иначе
		ТекстСубклиент = ""; // BSLLS:Typo-off
	КонецЕсли;
	ОбластьСтрокаГруппировки.Параметры.ПредставлениеКлиента = "Код клиента: "
		+ ВыборкаКлиентов.КодКлиента + ТекстСубклиент;
	Если ЗначениеЗаполнено(ВыборкаКлиентов.Клиент) Тогда 
		ОбластьСтрокаГруппировки.Параметры.Клиент = ВыборкаКлиентов.Клиент;
		ЦветТекстаКлиента = WebЦвета.ТемноГрифельноСерый;
	Иначе
		ОбластьСтрокаГруппировки.Параметры.Клиент = ВыборкаКлиентов.КодКлиента;
		ЦветТекстаКлиента = WebЦвета.Красный;
	КонецЕсли;
	Если Не ПустаяСтрока(КодСубклиента) И Не ЗначениеЗаполнено(ВыборкаКлиентов.Субклиент) Тогда
		ЦветТекстаКлиента = WebЦвета.Красный;
	КонецЕсли;
	
	ОбластьСтрокаГруппировки.Область("Клиент").ЦветТекста = ЦветТекстаКлиента;
	Результат.Вывести(ОбластьСтрокаГруппировки, 2);
	
	ВыборкаСчетовДепоДепонента = ВыборкаКлиентовИСубклиентов.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Пока ВыборкаСчетовДепоДепонента.Следующий() Цикл
		
		ПредставлениеСчетаДепоДепонента = "Счет депо Депонента: " + ВыборкаСчетовДепоДепонента.СчетДепоДепонента;
		Если ЗначениеЗаполнено(ВыборкаСчетовДепоДепонента.СчетДепоДепонентаСсылка) Тогда
			ОбластьСтрокаГруппировкиСчетДепоДепонента.Параметры.СчетДепоДепонента = ВыборкаСчетовДепоДепонента.СчетДепоДепонентаСсылка;
			ЦветТекстаСчетаДепоДепонента = WebЦвета.ТемноГрифельноСерый;
			ПредставлениеДепонента = СокрЛП(ВыборкаСчетовДепоДепонента.СчетДепоДепонентаСсылка.Владелец.Код);
			ПредставлениеСчетаДепоДепонента = ПредставлениеСчетаДепоДепонента + " [Код депонента: " + ПредставлениеДепонента + "]";
		Иначе
			ОбластьСтрокаГруппировкиСчетДепоДепонента.Параметры.СчетДепоДепонента = ВыборкаСчетовДепоДепонента.СчетДепоДепонента;
			ЦветТекстаСчетаДепоДепонента = WebЦвета.Красный;
		КонецЕсли;
		ОбластьСтрокаГруппировкиСчетДепоДепонента.Параметры.ПредставлениеСчетаДепоДепонента = ПредставлениеСчетаДепоДепонента;
		
		ОбластьСтрокаГруппировкиСчетДепоДепонента.Область("СчетДепоДепонента").ЦветТекста = ЦветТекстаСчетаДепоДепонента;
		Результат.Вывести(ОбластьСтрокаГруппировкиСчетДепоДепонента, 3);
		
		ВывестиДанныеПоКлиентамДоЦенныхБумаг(Результат,
			ВыборкаСчетовДепоДепонента,
			ОбластьСтрокаЦБ);
		
	КонецЦикла;
	
КонецПроцедуры

Процедура ВывестиДанныеПоКлиентамДоЦенныхБумаг(Результат,
	ВыборкаСчетовДепоДепонента,
	ОбластьСтрокаЦБ)
	
	ВыборкаЦБ = ВыборкаСчетовДепоДепонента.Выбрать();
	Пока ВыборкаЦБ.Следующий() Цикл
		ОбластьСтрокаЦБ.Параметры.Заполнить(ВыборкаЦБ);
		Если ЗначениеЗаполнено(ВыборкаЦБ.ЦеннаяБумага) Тогда
			ОбластьСтрокаЦБ.Область("ЦеннаяБумага").Расшифровка = ВыборкаЦБ.ЦеннаяБумага;
		КонецЕсли;
		Если ВыборкаЦБ.Расхождение = 0 Тогда
			ЦветФонаРасхождения = WebЦвета.МятныйКрем;
		Иначе
			ЦветФонаРасхождения = WebЦвета.Розовый;
		КонецЕсли;
		ОбластьСтрокаЦБ.Область("Расхождение").ЦветФона = ЦветФонаРасхождения;
		Результат.Вывести(ОбластьСтрокаЦБ, 4);
	КонецЦикла;
	
КонецПроцедуры

Функция ТекстЯчейки(ТабличныйДокумент, НомерСтроки, НомерКолонки, ОтсечьПробелы = Ложь)
	Текст = ТабличныйДокумент.Область(НомерСтроки, НомерКолонки, НомерСтроки, НомерКолонки).Текст;
	Если ОтсечьПробелы Тогда
		Текст = СокрЛП(Текст);
	КонецЕсли;
	Возврат Текст;
КонецФункции

Процедура ЗаполнитьЗначенияИзЯчеек(ДанныеФайла, НомерСтроки, ЗначениеЯчейкиПервойКолонки, ЗначениеЯчейкиВторойКолонки)
	НомерКолонки = 1;
	ЗначениеЯчейкиПервойКолонки = ТекстЯчейки(ДанныеФайла, НомерСтроки, НомерКолонки);
	НомерКолонки = 2;
	ЗначениеЯчейкиВторойКолонки = ТекстЯчейки(ДанныеФайла, НомерСтроки, НомерКолонки);
КонецПроцедуры

Процедура ОбработкаФайлаСверкиНРД(НомерСчетаДепо, ИмяФайлаНРД, ДанныеФайла)
	
	ЗначениеЯчейкиПервойКолонки = "";
	ЗначениеЯчейкиВторойКолонки = "";
	НомерРазделаСчетаДепо = "";
	НомерСтроки = 3;
	ЗаполнитьЗначенияИзЯчеек(ДанныеФайла, НомерСтроки, ЗначениеЯчейкиПервойКолонки, ЗначениеЯчейкиВторойКолонки);
	
	Пока ЗначениеЗаполнено(ЗначениеЯчейкиПервойКолонки) Или ЗначениеЗаполнено(ЗначениеЯчейкиВторойКолонки) Цикл
		
		// Строка с номером раздела счета депо
		Если ЗначениеЗаполнено(ЗначениеЯчейкиПервойКолонки) Тогда
			
			Если СтрНайти(ЗначениеЯчейкиПервойКолонки, "Раздел счета депо") > 0 Тогда
				НомерРазделаСчетаДепо = ВыделитьНомерРаздела(ЗначениеЯчейкиПервойКолонки);
			КонецЕсли;
			
			НомерСтроки = НомерСтроки + 1;
			ЗаполнитьЗначенияИзЯчеек(ДанныеФайла, НомерСтроки, ЗначениеЯчейкиПервойКолонки, ЗначениеЯчейкиВторойКолонки);
			Продолжить;
			
			// В любом другом случае - это строка с остатками ЦБ
		Иначе
			
			Попытка
				НоваяСтрока = ТаблицаСверки.Добавить();
				НоваяСтрока.НомерСчетаДепо				= СокрЛП(НомерСчетаДепо);
				НоваяСтрока.НомерРазделаСчетаДепо		= СокрЛП(НомерРазделаСчетаДепо);
				НоваяСтрока.КодНРД						= ЗначениеЯчейкиВторойКолонки;
				ОтсечьПробелы = Истина;
				НоваяСтрока.ЦеннаяБумагаНаименование	= ТекстЯчейки(ДанныеФайла, НомерСтроки, 3, ОтсечьПробелы);
				НоваяСтрока.НомерРегистрации			= ТекстЯчейки(ДанныеФайла, НомерСтроки, 4, ОтсечьПробелы);
				ОстатокВнешнегоИсточника				= ТекстЯчейки(ДанныеФайла, НомерСтроки, 5);
				НоваяСтрока.ОстатокВнешнегоИсточника	= СтроковыеФункцииКлиентСервер.ЧислоИзСтроки(ОстатокВнешнегоИсточника);
			Исключение
				ВызватьИсключение ("Ошибка в строке " + СокрЛП(Строка(НомерСтроки)) + " в файле "
					+ ИмяФайлаНРД + Символы.ПС + ОписаниеОшибки());
			КонецПопытки;
			
		КонецЕсли;
		
		// Переходим к следующей строке
		НомерСтроки = НомерСтроки + 1;
		ЗаполнитьЗначенияИзЯчеек(ДанныеФайла, НомерСтроки, ЗначениеЯчейкиПервойКолонки, ЗначениеЯчейкиВторойКолонки);
		
	КонецЦикла;
КонецПроцедуры

#Область СлужебныйПрограммныйИнтерфейс

// Процедура - Сохранить настройки
//
// Параметры:
//  ИмяОтчета			 - Строка - Название отчета
//  ИмяИсточника		 - Строка - Название источника сверки
//
Процедура СохранитьНастройки(ИмяОтчета, ИмяИсточника) Экспорт
	
	// Локальный фильтр для текущего пользователя
	СтруктураПараметров = Новый Структура;
	СтруктураПараметров.Вставить("ФильтрПоРазделамСчетовДепоМХЛокальный",
		ФильтрПоРазделамСчетовДепоМХЛокальный.ВыгрузитьКолонку("РазделСчетаДепоМХ"));
	ХранилищеОбщихНастроек.Сохранить(ИмяОтчета , "СтруктураПараметров" + ИмяИсточника , СтруктураПараметров);
	
	// Глобальный фильтр для пользователя svcWebService
	СтруктураПараметров = Новый Структура;
	СтруктураПараметров.Вставить("ФильтрПоРазделамСчетовДепоМХ",
		ФильтрПоРазделамСчетовДепоМХ.ВыгрузитьКолонку("РазделСчетаДепоМХ"));
	УстановитьПривилегированныйРежим(Истина);
	ХранилищеОбщихНастроек.Сохранить(ИмяОтчета , "СтруктураПараметров" + ИмяИсточника , СтруктураПараметров, , "svcWebService");
	УстановитьПривилегированныйРежим(Ложь);
	
КонецПроцедуры

// Процедура - Восстановить настройки
//
// Параметры:
//  ИмяОтчета			 - Строка - Название отчета
//  ИмяИсточника		 - Строка - Название источника сверки
//
Процедура ВосстановитьНастройки(ИмяОтчета, ИмяИсточника) Экспорт
	
	// Локальный фильтр текущего пользователя
	ЭтоПервоеВосстановлениеЛокальныхНастроек = Истина;
	СтруктураПараметров = ХранилищеОбщихНастроек.Загрузить(ИмяОтчета , "СтруктураПараметров" + ИмяИсточника);
	Если СтруктураПараметров <> Неопределено Тогда
		Если СтруктураПараметров.Свойство("ФильтрПоРазделамСчетовДепоМХЛокальный") Тогда
			ВосстановитьНастройкиВТаблицу(ФильтрПоРазделамСчетовДепоМХЛокальный, СтруктураПараметров.ФильтрПоРазделамСчетовДепоМХЛокальный);
			ЭтоПервоеВосстановлениеЛокальныхНастроек = Ложь;
		КонецЕсли;
	КонецЕсли;
	
	// Глобальный фильтр пользователя svcWebService
	УстановитьПривилегированныйРежим(Истина);
	СтруктураПараметров = ХранилищеОбщихНастроек.Загрузить(ИмяОтчета , "СтруктураПараметров" + ИмяИсточника, , "svcWebService");
	УстановитьПривилегированныйРежим(Ложь);
	Если СтруктураПараметров <> Неопределено Тогда
		Если СтруктураПараметров.Свойство("ФильтрПоРазделамСчетовДепоМХ") Тогда
			ВосстановитьНастройкиВТаблицу(ФильтрПоРазделамСчетовДепоМХ, СтруктураПараметров.ФильтрПоРазделамСчетовДепоМХ);
			ВосстановитьНастройкиВТаблицу(ФильтрПоРазделамСчетовДепоМХЭталон, СтруктураПараметров.ФильтрПоРазделамСчетовДепоМХ);
			Если ЭтоПервоеВосстановлениеЛокальныхНастроек Тогда
				ВосстановитьНастройкиВТаблицу(ФильтрПоРазделамСчетовДепоМХЛокальный, СтруктураПараметров.ФильтрПоРазделамСчетовДепоМХ);
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Процедура ВосстановитьНастройкиВТаблицу(Таблица, Настройки)
	
	КоличествоРазделов = Настройки.Количество();
	Если КоличествоРазделов > 0 Тогда
		Таблица.Очистить();
		Для ИндексРаздела = 1 По КоличествоРазделов Цикл
			Таблица.Добавить();
		КонецЦикла;
		Таблица.ЗагрузитьКолонку(Настройки, "РазделСчетаДепоМХ");
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область РассылкаСверкаДепо

// Рассылка сверки с BQ/NRD
// Результат Сверки побитовая маска:
// 0 - сверки ок
// 1 - сверка с Нрд error
// 2 - сверка с Bq error
// 3 - сверки Error
// Одноименное регламентное задание
Процедура ВыполнитьРассылку(ДатаСверкиПараметр) Экспорт
	
	ДатаСверки = ДатаСверкиПараметр;
	ВыводитьТолькоРасхождения = Истина;
	ИсточникДанныхДепозитария = "ФайловыйШлюз";
	
	РезультатСверки = 0;
	FileBody = Неопределено;
	ВложенныеФайлы = Новый Соответствие();
	
	МассивВариантовСверки = Новый Массив();
	МассивВариантовСверки.Добавить("ДепозитарийНРД");
	МассивВариантовСверки.Добавить("ДепозитарийБэкофис");
	
	Для Каждого ПерВариантСверки Из МассивВариантовСверки Цикл
		
		ВариантСверки = ПерВариантСверки;
		ВыполнитьСверку();
		РезультатСверки = РезультатСверки + ?(ЕстьРасхождение, pow(2, МассивВариантовСверки.Найти(ВариантСверки)), 0);
		
		Если РезультатСверки > 0 Тогда
			Поток = Новый ПотокВПамяти();
			Результат.Записать(Поток, ТипФайлаТабличногоДокумента.XLSX);
			ДвоичныеДанныеОтчет = Поток.ЗакрытьИПолучитьДвоичныеДанные();
			FileBody = Base64Строка(ДвоичныеДанныеОтчет);
			ВложенныеФайлы.Вставить(ВариантСверки, FileBody);
		КонецЕсли;
		
	КонецЦикла;
	
	ОтправитьEmailСообщение(ДатаСверки, РезультатСверки, ВложенныеФайлы);
	ОтправитьSmsСообщение(ДатаСверки, РезультатСверки);
	
КонецПроцедуры

Процедура ОтправитьEmailСообщение(ДатаСверки, РезультатСверки, ВложенныеФайлы)
	
	ТипСообщения = "EmailGen";
	НаименованиеШаблона = "СверкаДепоMail";
	ВнешнийИсточникРассылки = ПланыВидовХарактеристик.ВнешниеИсточники.KafkaEmailGen;
	ВнешнийИсточникПолучатели = ПланыВидовХарактеристик.ВнешниеИсточники.РассылкаEmailСверкиДепо;
	НастройкиПолучателей = ВнешниеДанные.ПолучитьПараметрыВнешнегоИсточника(ВнешнийИсточникПолучатели).Настройка;
	Получатели = НастройкиПолучателей.АдресПолучателя;
	
	MessageInfo = ОбменДаннымиКафка.ТиповыеДанныеMessageInfo(ТипСообщения, "INS", "1.0.0");
	Data = ДанныеDataEmail(ДатаСверки, Получатели, НаименованиеШаблона, РезультатСверки, ВложенныеФайлы);
	
	ТелоСообщения = РаботаСJSON.ТекстСообщенияJSON(MessageInfo, Data);
	
	Кафка.ПоместитьСообщениеВРегистрКОтправке(ВнешнийИсточникРассылки, ТипСообщения, ТелоСообщения);
	
КонецПроцедуры

Процедура ОтправитьSmsСообщение(ДатаСверки, РезультатСверки)
	
	ТипСообщения = "SmsGen";
	НаименованиеШаблона = "СверкаДепоSms";
	ВнешнийИсточникРассылки = ПланыВидовХарактеристик.ВнешниеИсточники.KafkaSmsGen;
	ВнешнийИсточникПолучатели = ПланыВидовХарактеристик.ВнешниеИсточники.РассылкаSmsСверкиДепо;
	НастройкиПолучателей = ВнешниеДанные.ПолучитьПараметрыВнешнегоИсточника(ВнешнийИсточникПолучатели).Настройка;
	Получатели = НастройкиПолучателей.АдресПолучателя;
	
	MessageInfo = ОбменДаннымиКафка.ТиповыеДанныеMessageInfo(ТипСообщения, "INS", "1.0.0");
	Data = ДанныеDataSms(ДатаСверки, Получатели, НаименованиеШаблона, РезультатСверки);
	
	ТелоСообщения = РаботаСJSON.ТекстСообщенияJSON(MessageInfo, Data);
	
	Кафка.ПоместитьСообщениеВРегистрКОтправке(ВнешнийИсточникРассылки, ТипСообщения, ТелоСообщения);
	
КонецПроцедуры

Функция ДанныеDataEmail(ДатаСверки, Получатели, НаименованиеШаблона, РезультатСверки, ВложенныеФайлы)
	
	Data = Новый Структура();
	Data.Вставить("Email", Получатели);
	Data.Вставить("MailTemplateId", Неопределено);
	Data.Вставить("MailTemplateTitle", НаименованиеШаблона);
	
	ReplaceFields = Новый Структура;
	ReplaceFields.Вставить("ПериодСверки", Формат(ДатаСверки, "ДЛФ=Д"));
	ReplaceFields.Вставить("СтатусСверкиДепоНрд", СтатусыСверки(РезультатСверки).СтатусСверкиДепоНрд);
	ReplaceFields.Вставить("СтатусСверкиДепоБк", СтатусыСверки(РезультатСверки).СтатусСверкиДепоBq);
	
	Attachments = Новый Массив;
	
	Для Каждого Файл Из ВложенныеФайлы Цикл
		File = Новый Структура();
		File.Вставить("FileName", Файл.Ключ);
		File.Вставить("FileExt", "XLSX");
		File.Вставить("FileBody", Файл.Значение);
		Attachments.Добавить(Новый Структура("File", File));
	КонецЦикла;
	
	Data.Вставить("ReplaceFields", ReplaceFields);
	Data.Вставить("Attachments", Attachments);
	
	Возврат Data;
	
КонецФункции

Функция ДанныеDataSms(ДатаСверки, Получатели, НаименованиеШаблона, РезультатСверки)
	
	Data = Новый Структура();
	
	Data.Вставить("Phone", Получатели);
	Data.Вставить("SmsTemplateId", Неопределено);
	Data.Вставить("SmsTemplateTitle", НаименованиеШаблона);
	EmailРассылка = Ложь;
	
	ReplaceFields = Новый Структура;
	ReplaceFields.Вставить("ПериодСверки", Формат(ДатаСверки, "ДЛФ=Д"));
	ReplaceFields.Вставить("СтатусСверкиДепоНрд", СтатусыСверки(РезультатСверки, EmailРассылка).СтатусСверкиДепоНрд);
	ReplaceFields.Вставить("СтатусСверкиДепоБк", СтатусыСверки(РезультатСверки, EmailРассылка).СтатусСверкиДепоBq);
	
	Data.Вставить("ReplaceFields", ReplaceFields);
	
	Возврат Data;
	
КонецФункции

Функция СтатусыСверки(РезультатСверки, ШаблонEmail = Истина)
	
	СтатусСверки = Новый Структура();
	StyleGreen = "<span style=background:LightGreen;>";
	StyleRed = "<span style=background:red;>";
	StyleEnd = "</span>";
	
	Если РезультатСверки = 0 Тогда
		
		СтатусСверкиДепоНрд = ?(ШаблонEmail, (StyleGreen + "OK" + StyleEnd), "OK");
		СтатусСверкиДепоBq = ?(ШаблонEmail, (StyleGreen + "OK" + StyleEnd), "OK");
		
	ИначеЕсли РезультатСверки = 1 Тогда
		
		СтатусСверкиДепоНрд = ?(ШаблонEmail, (StyleRed + "ERROR" + StyleEnd), "ERROR");
		СтатусСверкиДепоBq = ?(ШаблонEmail, (StyleGreen + "OK" + StyleEnd), "OK");
		
	ИначеЕсли РезультатСверки = 2 Тогда
		
		СтатусСверкиДепоНрд = ?(ШаблонEmail, (StyleGreen + "OK" + StyleEnd), "OK");
		СтатусСверкиДепоBq = ?(ШаблонEmail, (StyleRed + "ERROR" + StyleEnd), "ERROR");
		
	Иначе
		
		СтатусСверкиДепоНрд = ?(ШаблонEmail, (StyleRed + "ERROR" + StyleEnd), "ERROR");
		СтатусСверкиДепоBq = ?(ШаблонEmail, (StyleRed + "ERROR" + StyleEnd), "ERROR");
		
	КонецЕсли;
	
	СтатусСверки.Вставить("СтатусСверкиДепоНрд", СтатусСверкиДепоНрд);
	СтатусСверки.Вставить("СтатусСверкиДепоBq", СтатусСверкиДепоBq);
	
	Возврат СтатусСверки;
	
КонецФункции

