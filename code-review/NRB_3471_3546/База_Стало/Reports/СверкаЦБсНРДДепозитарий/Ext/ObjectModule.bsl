
Перем ТаблицаСверки;
Перем АДО;

Процедура ВыполнитьСверку() Экспорт
	
	ТаблицаСверки = СоздатьТаблицуСверкиНаСервере();
	
	ДобавитьВнешниеДанные();
	
	ДобавитьДанныеИзДепозитария();
	
	СформироватьОтчет();
	
КонецПроцедуры

Процедура СформироватьОтчет()
	
	Если ВариантСверки = "ДепозитарийБэкофис" Тогда
		
		Дерево = ДанныеЗапросаСверкиПоКлиентам();
		ЕстьРасхождение = (Дерево.Количество() > 0);
		ВывестиДанныеПоКлиентам(Дерево, ЭтотОбъект.Результат);
		
	ИначеЕсли ВариантСверки = "ДепозитарийНРД" Тогда
		
		Дерево = ДанныеЗапросаСверкиПоЦБ();
		ЕстьРасхождение = (Дерево.Количество() > 0);
		ВывестиДанныеПоЦБ(Дерево, ЭтотОбъект.Результат);
		
	КонецЕсли;
	
КонецПроцедуры

Процедура ДобавитьВнешниеДанные()
	
	Если ЭтотОбъект.ВариантСверки = "ДепозитарийБэкофис" Тогда
		
		ДобавитьДанныеИзБэкофиса();	
		
	Иначе
		
		Если ЭтотОбъект.ИсточникДанныхДепозитария = "ФайловыйШлюз" Тогда
			
			ДобавитьДанныеИзФайловогоШлюза();
			
		Иначе
			
			ДобавитьДанныеИзФайловНРД();
			
		КонецЕсли;
		
	КонецЕсли;

КонецПроцедуры

Функция СоздатьТаблицуСверкиНаСервере()
	
	ТипыЗначений = СоздатьТипыЗначений();
	
	Возврат СоздатьТаблицу(ТипыЗначений); 
	
КонецФункции

Функция СоздатьТипыЗначений()
	
	ТипыЗначений = Новый Структура;
	ТипыЗначений.Вставить("ОписаниеТиповСтрока3",   Новый ОписаниеТипов("Строка",, Новый КвалификаторыСтроки(3, ДопустимаяДлина.Переменная)));
	ТипыЗначений.Вставить("ОписаниеТиповСтрока12",  Новый ОписаниеТипов("Строка",, Новый КвалификаторыСтроки(12, ДопустимаяДлина.Переменная)));
	ТипыЗначений.Вставить("ОписаниеТиповСтрока17",  Новый ОписаниеТипов("Строка",, Новый КвалификаторыСтроки(17, ДопустимаяДлина.Переменная)));
	ТипыЗначений.Вставить("ОписаниеТиповСтрока20",  Новый ОписаниеТипов("Строка",, Новый КвалификаторыСтроки(20, ДопустимаяДлина.Переменная)));
	ТипыЗначений.Вставить("ОписаниеТиповСтрока30",  Новый ОписаниеТипов("Строка",, Новый КвалификаторыСтроки(30, ДопустимаяДлина.Переменная)));
	ТипыЗначений.Вставить("ОписаниеТиповСтрока50",  Новый ОписаниеТипов("Строка",, Новый КвалификаторыСтроки(50, ДопустимаяДлина.Переменная)));
	ТипыЗначений.Вставить("ОписаниеТиповСтрока99",  Новый ОписаниеТипов("Строка",, Новый КвалификаторыСтроки(99, ДопустимаяДлина.Переменная)));
	ТипыЗначений.Вставить("ОписаниеТиповОстаткиЦБ", Метаданные.ОпределяемыеТипы.КоличествоЦБ.Тип);
	
	Возврат ТипыЗначений;
	
КонецФункции

Функция СоздатьТаблицу(ТипыЗначений)
	
	ТЗ = Новый ТаблицаЗначений;
	ТЗ.Колонки.Добавить("НомерСчетаДепо",			ТипыЗначений.ОписаниеТиповСтрока12,  "Номер счета депо");
	ТЗ.Колонки.Добавить("НомерРазделаСчетаДепо",	ТипыЗначений.ОписаниеТиповСтрока17,  "Номер раздела счета депо");
	ТЗ.Колонки.Добавить("КодНРД",					ТипыЗначений.ОписаниеТиповСтрока50,  "Код НРД");
	ТЗ.Колонки.Добавить("ОстатокВнешнегоИсточника",	ТипыЗначений.ОписаниеТиповОстаткиЦБ, "Остаток во внешнем источнике");
	ТЗ.Колонки.Добавить("ОстатокДепо",				ТипыЗначений.ОписаниеТиповОстаткиЦБ, "Остаток в Депозитарии");
	ТЗ.Колонки.Добавить("ЦеннаяБумагаНаименование",	ТипыЗначений.ОписаниеТиповСтрока50,  "Наименование ценной бумаги");
	ТЗ.Колонки.Добавить("НомерРегистрации",			ТипыЗначений.ОписаниеТиповСтрока50,  "Номер гос. регистрации");
	ТЗ.Колонки.Добавить("КодКлиента",				ТипыЗначений.ОписаниеТиповСтрока99,  "Код клиента");
	ТЗ.Колонки.Добавить("КодСубклиента",			ТипыЗначений.ОписаниеТиповСтрока3,   "Код субклиента");
	ТЗ.Колонки.Добавить("ISIN",						ТипыЗначений.ОписаниеТиповСтрока30,  "ISIN");
	Если ВариантСверки = "ДепозитарийБэкофис" Тогда // BSLLS:Typo-off
		ТЗ.Колонки.Добавить("СчетДепоДепонента",	ТипыЗначений.ОписаниеТиповСтрока12,  "Счет депо Депонента");
	КонецЕсли;
	Возврат ТЗ
	
КонецФункции

Процедура ДобавитьДанныеИзФайловНРД()
	
	ФайлыНРД = ФайлыНРДВКлиентскихПапках(ЭтотОбъект.КаталогФайлов, ЭтотОбъект.ДатаСверки);
	
	НайденоФайлов = ФайлыНРД.Количество();
	Если НайденоФайлов = 0 Тогда
		Возврат;
	КонецЕсли;
	
	ЗначениеЯчейкиПервойКолонки = "";
	ЗначениеЯчейкиВторойКолонки = "";
	
	Для СчетчикФайлов = 0 По (НайденоФайлов - 1) Цикл
		ВременныйФайл = ПолучитьИмяВременногоФайла("XLS");
		ФайлНРД = ФайлыНРД.Получить(СчетчикФайлов);
		ИмяФайлаНРД = ФайлНРД.Имя;
		
		Попытка
			КопироватьФайл(ФайлНРД.ПолноеИмя, ВременныйФайл);
		Исключение
			ВызватьИсключение ("Ошибка открытия файла " + ИмяФайлаНРД + Символы.ПС + ОписаниеОшибки());
		КонецПопытки;
		
		Попытка
			ДанныеФайла = Новый ТабличныйДокумент;
			ДанныеФайла.Прочитать(ВременныйФайл);
			УдалитьФайлы(ВременныйФайл);
		Исключение
			ВызватьИсключение ("Ошибка чтения из Excel" + Символы.ПС + ОписаниеОшибки());
		КонецПопытки;
		
		НомерСтроки = 1;
		ЗаполнитьЗначенияИзЯчеек(ДанныеФайла, НомерСтроки, ЗначениеЯчейкиПервойКолонки, ЗначениеЯчейкиВторойКолонки);
		
		// Определяем номер счета депо по заголовку
		Если СтрНайти(ЗначениеЯчейкиПервойКолонки, "Отчет/Выписка по счету") > 0 Тогда
			НомерСчетаДепо = Сред(ЗначениеЯчейкиПервойКолонки, 24, 12);
		Иначе
			// Если нет стандартного заголовка - ошибка
			ВызватьИсключение ("Ошибка формата файла " + ИмяФайлаНРД);
		КонецЕсли;
		
		ОбработкаФайлаСверкиНРД(НомерСчетаДепо, ИмяФайлаНРД, ДанныеФайла);
		
	КонецЦикла;
	
КонецПроцедуры

Функция ВыделитьНомерРаздела(Знач Строка)
	
	Перем ДлинаНомераРазделаСчетаДепо;
	
	ДлинаНомераРазделаСчетаДепо = 17;
	
	Позиция = Найти (Строка, "Раздел счета депо");
	ПозицияДвоеточия = Найти (Строка, ":");
	Строка = СтрЗаменить(Строка, " ", Символы.ПС);
	ЧислоСтрок = СтрЧислоСтрок(Строка);
	Для НомерСтроки = 1 По ЧислоСтрок Цикл
		
		Подстрока = СокрЛП(СтрПолучитьСтроку(Строка, НомерСтроки));
		Если СтрДлина(Подстрока) = ДлинаНомераРазделаСчетаДепо Тогда
			Возврат Подстрока;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат "";
	
КонецФункции

// В каталоге Каталог ищет подкаталоги HL, TL, ML. В них ищет xls-файлы с именем в определенном формате (от даты).
//  Это и есть клиентские счета-файлы НРД.
//
// Параметры:
//  РодительскийКаталог	 - Строка	 - Каталог
//  День				 - Дата		 - День сверки
// 
// Возвращаемое значение:
//  массив - из значений типа Файл
//
Функция ФайлыНРДВКлиентскихПапках(РодительскийКаталог, День)
	
	ИменаКлиентскихКаталогов = Новый Массив;
	ИменаКлиентскихКаталогов.Добавить("HL");
	ИменаКлиентскихКаталогов.Добавить("TL");
	ИменаКлиентскихКаталогов.Добавить("ML");
	ИменаКлиентскихКаталогов.Добавить("L1");
	
	МаскаФайлов = Формат(День, "ДФ=""ддММгггг""") + "*.xls";
	
	ФайлыКлиентов = Новый Массив;
	
	// Найти все подкаталоги клиента
	Каталоги = НайтиФайлы(РодительскийКаталог, "*.*");
	Для Каждого Каталог Из Каталоги Цикл
		Если Каталог.ЭтоКаталог() И ИменаКлиентскихКаталогов.Найти(ВРЕГ(Каталог.Имя)) <> Неопределено Тогда
			// Собираем xls-файлы из этого клиентского каталога
			ФайлыНРД = НайтиФайлы(Каталог.ПолноеИмя, МаскаФайлов, Истина);
			Для Каждого ФайлНРД Из ФайлыНРД Цикл
				ФайлыКлиентов.Добавить(ФайлНРД);
			КонецЦикла;
		КонецЕсли;
	КонецЦикла;
	
	Возврат ФайлыКлиентов;
	
КонецФункции

Процедура ДобавитьДанныеИзБэкофиса()
	
	ШаблонСообщенияОбОшибке = "";
	ДатаСверкиСтрокой = Формат(КонецДня(ДатаСверки) + 1, "ДФ='yyyy-MM-dd'");
	ВходныеПараметры = Новый Структура;
	ВходныеПараметры.Вставить("DateTimeReconciliation", ДатаСверкиСтрокой);
	
	ВнешнийИсточник = ПланыВидовХарактеристик.ВнешниеИсточники.НРБСервисStoredProcSQL;
	
	База = ВнешниеДанные.ПолучитьПараметрыВнешнегоИсточника(ВнешнийИсточник).База;
	Если Не ЗначениеЗаполнено(База) Тогда
		УровеньОшибка = УровеньЖурналаРегистрации.Предупреждение;
		ТекстСообщения = "Не найден внешний источник <<Сервис хранимых процедур НРБ>> для данной базы.";
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
		ЗаписьЖурналаРегистрации("СверкаЦБсНРДДепозитарий:BQ",
			УровеньОшибка, Метаданные.Отчеты.СверкаЦБсНРДДепозитарий, , ТекстСообщения);
		Возврат;
	КонецЕсли;
	
	Параметры = Неопределено;
	ВнешниеДанные.ДобавитьПараметрСоединения(Параметры, "ВнешнийИсточник", ВнешнийИсточник);
	
	Попытка
		ВнешниеДанные.ИнициироватьСоединение(АДО, "АДО", Параметры);
		ОстаткиBQ = АДО.ВыполнитьХранимуюПроцедуру("[Depo].[PositionForCompare]", ВходныеПараметры);
		
		Если Не ЗначениеЗаполнено(ОстаткиBQ) Тогда
			ШаблонСообщенияОбОшибке = "BQ: На дату сверки: %1 нет данных";
		Иначе
			ОстаткиBQ.Колонки.Добавить("CrmClientIdStr", Новый ОписаниеТипов("Строка", , Новый КвалификаторыСтроки(20)));
			Для Каждого ПриведениеТипа Из ОстаткиBQ Цикл
				ПриведениеТипа.CrmClientIdStr = "" + Формат(ПриведениеТипа.CrmClientId, "ЧН=Отсутствует; ЧГ=0");
			КонецЦикла;
		КонецЕсли;
	Исключение
		ТекстОшибки = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		ШаблонСообщенияОбОшибке = "BQ: На дату сверки: %1 произошла ошибка: " + ТекстОшибки;
	КонецПопытки;
	Если ЗначениеЗаполнено(ШаблонСообщенияОбОшибке) Тогда
		ТекстСообщенияОбОшибке = СтрШаблон(ШаблонСообщенияОбОшибке, ДатаСверкиСтрокой);
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщенияОбОшибке);
		Возврат;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("втОстатки"		, ОстаткиBQ);
	Запрос.УстановитьПараметр("ВсеРазделы"		, ФильтрПоРазделамСчетовДепоМХЛокальный.Количество() = 0);
	РазделыМХ = Новый СписокЗначений;
	Для Каждого Фильтр Из ФильтрПоРазделамСчетовДепоМХЛокальный Цикл
		РазделыМХ.Добавить(СокрЛП(Фильтр.РазделСчетаДепоМХ.Код));
	КонецЦикла;
	Запрос.УстановитьПараметр("РазделыМХ"		, РазделыМХ);
	
	// BSLLS:LogicalOrInTheWhereSectionOfQuery-off
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ВЫРАЗИТЬ(втОстатки.CrmClientIdStr КАК СТРОКА(20)) КАК CrmClientId,
	|	"""" КАК CrmSubClientId,
	|	ВЫРАЗИТЬ(ЕСТЬNULL(втОстатки.NrdCode, """") КАК СТРОКА(20)) КАК NrdCode,
	|	ВЫРАЗИТЬ(втОстатки.Isin КАК СТРОКА(30)) КАК Isin,
	|	ВЫРАЗИТЬ(ЕСТЬNULL(втОстатки.RegNum, """") КАК СТРОКА(50)) КАК RegNum,
	|	ВЫРАЗИТЬ(втОстатки.DepoAccount КАК СТРОКА(12)) КАК DepoAccount,
	|	ВЫРАЗИТЬ(втОстатки.DepoAccountSafeKeeping КАК СТРОКА(17)) КАК DepoAccountSafeKeeping,
	|	ВЫРАЗИТЬ(втОстатки.SubDepoAccountSafeKeeping КАК СТРОКА(17)) КАК SubDepoAccountSafeKeeping,
	|	ВЫРАЗИТЬ(втОстатки.Qty КАК ЧИСЛО(20, 7)) КАК Qty
	|ПОМЕСТИТЬ ОстаткиBQ
	|ИЗ
	|	&втОстатки КАК втОстатки
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ОстаткиBQ.DepoAccountSafeKeeping КАК НомерСчетаДепо,
	|	ОстаткиBQ.SubDepoAccountSafeKeeping КАК НомерРазделаСчетаДепо,
	|	ОстаткиBQ.DepoAccount КАК СчетДепоДепонента,
	|	"""" КАК КодНРД,
	|	"""" КАК ЦеннаяБумагаНаименование,
	|	ОстаткиBQ.RegNum КАК НомерРегистрации,
	|	ОстаткиBQ.Isin КАК ISIN,
	|	ОстаткиBQ.CrmClientId КАК КодКлиента,
	|	ОстаткиBQ.CrmSubClientId КАК КодСубклиента,
	|	СУММА(ОстаткиBQ.Qty) КАК ОстатокВнешнегоИсточника
	|ИЗ
	|	ОстаткиBQ КАК ОстаткиBQ
	|ГДЕ
	|	(&ВсеРазделы
	|			ИЛИ ОстаткиBQ.SubDepoAccountSafeKeeping В (&РазделыМХ))
	|
	|СГРУППИРОВАТЬ ПО
	|	ОстаткиBQ.DepoAccountSafeKeeping,
	|	ОстаткиBQ.SubDepoAccountSafeKeeping,
	|	ОстаткиBQ.DepoAccount,
	|	ОстаткиBQ.RegNum,
	|	ОстаткиBQ.Isin,
	|	ОстаткиBQ.CrmClientId,
	|	ОстаткиBQ.CrmSubClientId
	|
	|ИМЕЮЩИЕ
	|	СУММА(ОстаткиBQ.Qty) <> 0";
	// BSLLS:LogicalOrInTheWhereSectionOfQuery-on
	
	Попытка
		Выборка = Запрос.Выполнить().Выбрать();
	Исключение
		УровеньОшибка = УровеньЖурналаРегистрации.Предупреждение;
		ТекстСообщения = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
		ЗаписьЖурналаРегистрации("СверкаЦБсНРДДепозитарий:BQ",
			УровеньОшибка, Метаданные.Отчеты.СверкаЦБсНРДДепозитарий, , ТекстСообщения);
	КонецПопытки;
	
	Пока Выборка.Следующий() Цикл
		
		НоваяСтрока = ТаблицаСверки.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, Выборка);
		
	КонецЦикла;
	
КонецПроцедуры

Процедура ДобавитьДанныеИзДепозитария() 
	
	ЭтоВариантСверкиДепозитарийНРД = ВариантСверки = "ДепозитарийНРД";
	
	Сообщение = Новый СообщениеПользователю;
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	ДатаСверкиНачалоСледующегоДня = КонецДня(ДатаСверки) + 1;
	Запрос.УстановитьПараметр("ДатаСверкиНачалоСледующегоДня", ДатаСверкиНачалоСледующегоДня);
	Запрос.УстановитьПараметр("НДЦ", Справочники.КлассификаторыЗагрузки.НДЦ());
	Запрос.УстановитьПараметр("НРД", Константы.МестоХраненияПоУмолчанию.Получить());
	Запрос.УстановитьПараметр("Клиенты", Справочники.КлассификаторыЗагрузки.Клиенты);
	Запрос.УстановитьПараметр("CrmContractNumber", Справочники.КлассификаторыЗагрузки.CrmContractNumber);
	Запрос.УстановитьПараметр("ВсеРазделы", ФильтрПоРазделамСчетовДепоМХЛокальный.Количество() = 0);
	РазделыМХ = Новый СписокЗначений;
	Для Каждого Фильтр Из ФильтрПоРазделамСчетовДепоМХЛокальный Цикл
		РазделыМХ.Добавить(Фильтр.РазделСчетаДепоМХ);
	КонецЦикла;
	Запрос.УстановитьПараметр("РазделыМХ"		, РазделыМХ);
	
	Запрос.Текст = ТекстЗапросаКодыЗагрузкиКлиентов();
	Запрос.Выполнить();
	
	Запрос.Текст = ТекстЗапросаКодыЗагрузки();
	Запрос.Выполнить();
	
	Если ЭтоВариантСверкиДепозитарийНРД Тогда
		Запрос.Текст = ТекстЗапросаОстаткиНРД();
	Иначе
		Запрос.Текст = ТекстЗапросаОстаткиBQ();
	КонецЕсли;
	
	Запрос.Выполнить();
	
	Если ЭтоВариантСверкиДепозитарийНРД Тогда
		Запрос.Текст = ТекстЗапросаОстаткиЗаблокированныхЦБ();
		Запрос.Выполнить();
	КонецЕсли;
	
	Запрос.Текст = ТекстЗапросаПроверкаНаДублированиеКодовЗагрузки();
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если ЭтоВариантСверкиДепозитарийНРД И Выборка.Количество() > 0 Тогда
		Сообщение.Текст = "Внимание! На " + Формат(ДатаСверки, "ДЛФ=ДД")
			+ " найдено более одного действующего кода загрузки НДЦ для ценных бумаг:";
		Пока Выборка.Следующий() Цикл
			Сообщение.Текст = Сообщение.Текст + Символы.ПС
				+ Выборка.Наименование + " Рег. номер: " + Выборка.НомерРегистрации;
		КонецЦикла;
	КонецЕсли;
	
	Запрос.Текст = ТекстЗапросаПроверкаНаСуществованиеКодовЗагрузки();
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если ЭтоВариантСверкиДепозитарийНРД И Выборка.Количество() > 0 Тогда
		Сообщение.Текст = Сообщение.Текст + Символы.ПС + "Внимание! На " + Формат(ДатаСверки, "ДЛФ=ДД")
			+ " нет действующего кода загрузки НДЦ для ценных бумаг:";
		Пока Выборка.Следующий() Цикл
			Сообщение.Текст = Сообщение.Текст + Символы.ПС
				+ Выборка.Наименование + " Рег. номер: " + Выборка.НомерРегистрации;
		КонецЦикла;
	КонецЕсли;
	
	Если ЭтоВариантСверкиДепозитарийНРД Тогда
		Запрос.Текст = ТекстЗапросаИтоговыеОстаткиСУчетомЗаблокированныхЦБ();
	Иначе
		Запрос.Текст = ТекстЗапросаИтоговыеОстатки();
	КонецЕсли;
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		НоваяСтрока = ТаблицаСверки.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, Выборка);
	КонецЦикла;
	
	Если ЗначениеЗаполнено(Сообщение.Текст) Тогда
		Сообщение.Сообщить();
	КонецЕсли;
	
КонецПроцедуры

Процедура ДобавитьДанныеИзФайловогоШлюза()
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ОстаткиПоЦеннымБумагамНРД.СчетДепоМХ КАК НомерСчетаДепо,
		|	ОстаткиПоЦеннымБумагамНРД.РазделСчетаДепоМХ КАК НомерРазделаСчетаДепо,
		|	КодыЗагрузки.Ссылка КАК КодНРД,
		|	ОстаткиПоЦеннымБумагамНРД.ЦеннаяБумага.Наименование КАК ЦеннаяБумагаНиаменование,
		|	ОстаткиПоЦеннымБумагамНРД.ЦеннаяБумага.НомерРегистрации КАК НомерРегистрации,
		|	СУММА(ОстаткиПоЦеннымБумагамНРД.Количество) КАК ОстатокВнешнегоИсточника
		|ИЗ
		|	РегистрСведений.ОстаткиПоЦеннымБумагамНРД КАК ОстаткиПоЦеннымБумагамНРД
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.КодыЗагрузки КАК КодыЗагрузки
		|		ПО ОстаткиПоЦеннымБумагамНРД.ЦеннаяБумага = КодыЗагрузки.Владелец
		|			И (КодыЗагрузки.Биржа = &НДЦ)
		|			И (КодыЗагрузки.ДатаОкончанияДействия = ДАТАВРЕМЯ(1, 1, 1)
		|				ИЛИ КодыЗагрузки.ДатаОкончанияДействия > ОстаткиПоЦеннымБумагамНРД.Дата)
		|ГДЕ
		|	ОстаткиПоЦеннымБумагамНРД.Дата = &Дата
		|
		|СГРУППИРОВАТЬ ПО
		|	ОстаткиПоЦеннымБумагамНРД.СчетДепоМХ,
		|	ОстаткиПоЦеннымБумагамНРД.РазделСчетаДепоМХ,
		|	КодыЗагрузки.Ссылка,
		|	ОстаткиПоЦеннымБумагамНРД.ЦеннаяБумага.Наименование,
		|	ОстаткиПоЦеннымБумагамНРД.ЦеннаяБумага.НомерРегистрации";
	
	Запрос.УстановитьПараметр("Дата", НачалоДня(ЭтотОбъект.ДатаСверки));
	Запрос.УстановитьПараметр("НДЦ", Справочники.КлассификаторыЗагрузки.НДЦ());
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		
		НоваяСтрока = ТаблицаСверки.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока,ВыборкаДетальныеЗаписи);
		
	КонецЦикла;
	
КонецПроцедуры

Функция ТекстЗапросаКодыЗагрузкиКлиентов()
	
	Возврат
	"ВЫБРАТЬ
	|	КодыЗагрузки.Владелец КАК ЮридическиеФизическиеЛицаПоКодуЗагрузки,
	|	КодыЗагрузки.Код КАК КодЗагрузкиКлиента
	|ПОМЕСТИТЬ втКодыЗагрузкиКлиентов
	|ИЗ
	|	Справочник.КодыЗагрузки КАК КодыЗагрузки
	|ГДЕ
	|	(КодыЗагрузки.Владелец ССЫЛКА Справочник.ФизическиеЛица
	|			ИЛИ КодыЗагрузки.Владелец ССЫЛКА Справочник.ЮридическиеЛица)
	|	И КодыЗагрузки.Биржа = &Клиенты
	|	И НЕ КодыЗагрузки.ПометкаУдаления
	|	И ВЫБОР
	|			КОГДА КодыЗагрузки.ДатаОкончанияДействия = ДАТАВРЕМЯ(1, 1, 1)
	|				ТОГДА ИСТИНА
	|			ИНАЧЕ КодыЗагрузки.ДатаОкончанияДействия >= &ДатаСверкиНачалоСледующегоДня
	|		КОНЕЦ
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	ЮридическиеФизическиеЛицаПоКодуЗагрузки";
	
КонецФункции

Функция ТекстЗапросаКодыЗагрузки()
	Возврат
	"ВЫБРАТЬ
	|	КодыЗагрузки.Владелец КАК ЦБ,
	|	КодыЗагрузки.Код КАК КодНРД
	|ПОМЕСТИТЬ втКодыЗагрузки
	|ИЗ
	|	Справочник.КодыЗагрузки КАК КодыЗагрузки
	|ГДЕ
	|	КодыЗагрузки.Владелец ССЫЛКА Справочник.ЦенныеБумаги
	|	И КодыЗагрузки.Биржа = &НДЦ
	|	И НЕ КодыЗагрузки.ПометкаУдаления
	|	И (КодыЗагрузки.ДатаОкончанияДействия = ДАТАВРЕМЯ(1, 1, 1)
	|			ИЛИ КодыЗагрузки.ДатаОкончанияДействия >= &ДатаСверкиНачалоСледующегоДня)
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	ЦБ;"
КонецФункции

Функция ТекстЗапросаОстаткиНРД()
	// BSLLS:JoinWithVirtualTable-off
	ТекстЗапроса =
	"ВЫБРАТЬ
	|	Остатки.ЦБ КАК ЦБ,
	|	Остатки.СчетДепоМХ.Код КАК НомерСчетаДепо,
	|	Остатки.РазделСчетаДепоМХ.Код КАК НомерРазделаСчетаДепо,
	|	ЕСТЬNULL(КодыЗагрузки.КодНРД, """") КАК КодНРД,
	|	ВЫБОР
	|		КОГДА Остатки.ЦБ.Дробная
	|				И Остатки.ЦБ.Числитель <> 0
	|			ТОГДА Остатки.КоличествоОстаток / Остатки.ЦБ.Числитель * Остатки.ЦБ.Знаменатель
	|		ИНАЧЕ Остатки.КоличествоОстаток
	|	КОНЕЦ КАК ОстатокДепо,
	|	Остатки.ЦБ.НомерРегистрации КАК НомерРегистрации,
	|	Остатки.ЦБ.ISIN КАК ISIN,
	|	Остатки.ЦБ.Наименование КАК ЦеннаяБумагаНаименование,
	|	"""" КАК КодКлиента,
	|	"""" КАК КодСубклиента
	|ПОМЕСТИТЬ втОстатки
	|ИЗ
	|	РегистрНакопления.ОстаткиЦБ.Остатки(&ДатаСверкиНачалоСледующегоДня, СчетДепоМХ.Владелец = &НРД) КАК Остатки
	|		ЛЕВОЕ СОЕДИНЕНИЕ втКодыЗагрузки КАК КодыЗагрузки
	|		ПО Остатки.ЦБ = КодыЗагрузки.ЦБ";
	// BSLLS:JoinWithVirtualTable-on
	
	Возврат ТекстЗапроса;
	
КонецФункции

Функция ТекстЗапросаОстаткиBQ()
	// BSLLS:JoinWithVirtualTable-off
	ТекстЗапроса =
	"ВЫБРАТЬ
	|	Остатки.ЦБ КАК ЦБ,
	|	Остатки.СчетДепоМХ.Код КАК НомерСчетаДепо,
	|	Остатки.РазделСчетаДепоМХ.Код КАК НомерРазделаСчетаДепо,
	|	Остатки.СчетДепо.Код КАК СчетДепоДепонента,
	|	"""" КАК КодНРД,
	|	ВЫБОР
	|		КОГДА Остатки.ЦБ.Дробная
	|				И Остатки.ЦБ.Числитель <> 0
	|			ТОГДА Остатки.КоличествоОстаток / Остатки.ЦБ.Числитель * Остатки.ЦБ.Знаменатель
	|		ИНАЧЕ Остатки.КоличествоОстаток
	|	КОНЕЦ КАК ОстатокДепо,
	|	Остатки.ЦБ.НомерРегистрации КАК НомерРегистрации,
	|	Остатки.ЦБ.ISIN КАК ISIN,
	|	Остатки.ЦБ.Наименование КАК ЦеннаяБумагаНаименование,
	|	ЕСТЬNULL(КодыЗагрузкиКлиентов.КодЗагрузкиКлиента, ""Юр\физ лицо без Кода загрузки, код 1С: "" + Остатки.СчетДепо.Владелец.ЮридическиеФизическиеЛица.Код + "" ["" + Остатки.СчетДепо.Владелец.ЮридическиеФизическиеЛица.Наименование + ""]"") КАК КодКлиента,
	|	"""" КАК КодСубклиента
	|ПОМЕСТИТЬ втОстатки
	|ИЗ
	|	РегистрНакопления.ОстаткиЦБ.Остатки(
	|			&ДатаСверкиНачалоСледующегоДня,
	|			&ВсеРазделы
	|				ИЛИ РазделСчетаДепоМХ В (&РазделыМХ)) КАК Остатки
	|		ЛЕВОЕ СОЕДИНЕНИЕ втКодыЗагрузки КАК КодыЗагрузки
	|		ПО Остатки.ЦБ = КодыЗагрузки.ЦБ
	|		ЛЕВОЕ СОЕДИНЕНИЕ втКодыЗагрузкиКлиентов КАК КодыЗагрузкиКлиентов
	|		ПО Остатки.СчетДепо.Владелец.ЮридическиеФизическиеЛица = КодыЗагрузкиКлиентов.ЮридическиеФизическиеЛицаПоКодуЗагрузки
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.КодыЗагрузки КАК КодыЗагрузкиДепонентов
	|		ПО Остатки.СчетДепо.Владелец = КодыЗагрузкиДепонентов.Владелец
	|ГДЕ
	|	КодыЗагрузкиДепонентов.Владелец ССЫЛКА Справочник.Контрагенты
	|	И КодыЗагрузкиДепонентов.Биржа = &CrmContractNumber
	|	И НЕ КодыЗагрузкиДепонентов.ПометкаУдаления
	|	И ВЫБОР
	|			КОГДА КодыЗагрузкиДепонентов.ДатаОкончанияДействия = ДАТАВРЕМЯ(1, 1, 1)
	|				ТОГДА ИСТИНА
	|			ИНАЧЕ КодыЗагрузкиДепонентов.ДатаОкончанияДействия >= &ДатаСверкиНачалоСледующегоДня
	|		КОНЕЦ";
	// BSLLS:JoinWithVirtualTable-on
	
	Возврат ТекстЗапроса;
	
КонецФункции

Функция ТекстЗапросаИтоговыеОстаткиСУчетомЗаблокированныхЦБ()
	Возврат
	"ВЫБРАТЬ
	|	Остатки.ЦБ КАК ЦБ,
	|	Остатки.НомерСчетаДепо КАК НомерСчетаДепо,
	|	Остатки.НомерРазделаСчетаДепо КАК НомерРазделаСчетаДепо,
	|	Остатки.КодНРД КАК КодНРД,
	|	Остатки.ОстатокДепо КАК ОстатокДепо,
	|	Остатки.ЦеннаяБумагаНаименование КАК ЦеннаяБумагаНаименование,
	|	Остатки.НомерРегистрации КАК НомерРегистрации,
	|	Остатки.ISIN КАК ISIN,
	|	Остатки.КодКлиента КАК КодКлиента
	|ПОМЕСТИТЬ втИтоговыеОстатки
	|ИЗ
	|	втОстатки КАК Остатки
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	Остатки.ЦБ КАК ЦБ,
	|	Остатки.НомерСчетаДепо КАК НомерСчетаДепо,
	|	Остатки.НомерРазделаСчетаДепо КАК НомерРазделаСчетаДепо,
	|	Остатки.КодНРД КАК КодНРД,
	|	Остатки.ОстатокДепо КАК ОстатокДепо,
	|	Остатки.ЦеннаяБумагаНаименование КАК ЦеннаяБумагаНаименование,
	|	Остатки.НомерРегистрации КАК НомерРегистрации,
	|	Остатки.ISIN КАК ISIN,
	|	Остатки.КодКлиента КАК КодКлиента
	|ИЗ
	|	втОстаткиЗаблокированныхЦБ КАК Остатки
	|;
	|//////////////////////////////////////////////////////////
	|
	|ВЫБРАТЬ
	|	Остатки.ЦБ КАК ЦБ,
	|	Остатки.НомерСчетаДепо КАК НомерСчетаДепо,
	|	Остатки.НомерРазделаСчетаДепо КАК НомерРазделаСчетаДепо,
	|	Остатки.КодНРД КАК КодНРД,
	|	Остатки.НомерРегистрации КАК НомерРегистрации,
	|	Остатки.ISIN КАК ISIN,
	|	Остатки.ЦеннаяБумагаНаименование КАК ЦеннаяБумагаНаименование,
	|	Остатки.КодКлиента КАК КодКлиента,
	|	СУММА(Остатки.ОстатокДепо) КАК ОстатокДепо
	|ИЗ
	|	втИтоговыеОстатки КАК Остатки
	|
	|СГРУППИРОВАТЬ ПО
	|	Остатки.ЦБ,
	|	Остатки.НомерСчетаДепо,
	|	Остатки.НомерРазделаСчетаДепо,
	|	Остатки.КодНРД,
	|	Остатки.НомерРегистрации,
	|	Остатки.ISIN,
	|	Остатки.ЦеннаяБумагаНаименование,
	|	Остатки.КодКлиента
	|
	|ИМЕЮЩИЕ
	|	СУММА(Остатки.ОстатокДепо) <> 0
	|
	|УПОРЯДОЧИТЬ ПО
	|	Остатки.ЦеннаяБумагаНаименование";
КонецФункции

Функция ТекстЗапросаИтоговыеОстатки()
	Возврат
	"ВЫБРАТЬ
	|	Остатки.ЦБ КАК ЦБ,
	|	Остатки.НомерСчетаДепо КАК НомерСчетаДепо,
