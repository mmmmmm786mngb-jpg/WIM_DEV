////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	КурсыВалютСрезПоследних.Валюта КАК Валюта,
	КурсыВалютСрезПоследних.Курс КАК Курс,
	ВЫБОР
		КОГДА КурсыВалютСрезПоследних.Кратность &lt;&gt; 0
			ТОГДА КурсыВалютСрезПоследних.Кратность
		ИНАЧЕ 1
	КОНЕЦ КАК Кратность
ПОМЕСТИТЬ ВТ_Курсы
ИЗ
	РегистрСведений.КурсыВалют.СрезПоследних({&amp;ОтчетнаяДата}, ) КАК КурсыВалютСрезПоследних
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	ВТ_ОстаткиЦБ.СчетДепоМХ КАК СчетДепоМестоХранения,
	ВТ_ОстаткиЦБ.ЦБ КАК ЦеннаяБумага,
	ЦенныеБумаги.ISIN КАК ISIN,
	ЦенныеБумаги.ВидЦББанкаРоссии КАК ВидЦБ,
	ЦенныеБумаги.Дефолтная КАК Дефолтная,
	ЦенныеБумаги.ДатаДефолта КАК ДатаДефолта,
	ВЫБОР
		КОГДА ЦенныеБумаги.ТипЦБ В (&amp;ТипыДепозитарныхРасписок)
			И НЕ ЦенныеБумаги.БазовыйАктив = ЗНАЧЕНИЕ(Справочник.ЦенныеБумаги.ПустаяСсылка)
			ТОГДА ЦенныеБумаги.БазовыйАктив.ВалютаНоминала
		ИНАЧЕ ЦенныеБумаги.ВалютаНоминала
	КОНЕЦ КАК ВалютаНоминала,
	ВТ_ОстаткиЦБ.КоличествоОстаток КАК Остаток,
	ЕСТЬNULL(РыночныеЦеныЦенныхБумаг.Цена, 0) КАК РыночнаяЦена,
	РыночныеЦеныЦенныхБумаг.Валюта КАК Валюта,
	ВЫБОР
		КОГДА РыночныеЦеныЦенныхБумаг.Уровень = 5
			ТОГДА "Номинал"
		КОГДА РыночныеЦеныЦенныхБумаг.ИсточникКотировок = ЗНАЧЕНИЕ(Справочник.ИсточникиКотировок.ПустаяСсылка)
			ТОГДА РыночныеЦеныЦенныхБумаг.Биржа
		ИНАЧЕ РыночныеЦеныЦенныхБумаг.ИсточникКотировок
	КОНЕЦ КАК ВидЦены,
	ОКР(РыночныеЦеныЦенныхБумаг.Цена * ВТ_ОстаткиЦБ.КоличествоОстаток, 2) КАК ИтогоВВалюте,
	ОКР(РыночныеЦеныЦенныхБумаг.Цена * ВТ_ОстаткиЦБ.КоличествоОстаток, 2) * ВТ_Курсы.Курс / ВТ_Курсы.Кратность КАК ИтогоВРублях,
	ЕСТЬNULL(РыночныеЦеныЦенныхБумаг404.Цена, 0) КАК РыночнаяЦенаДляФ404,
	ЕСТЬNULL(РыночныеЦеныЦенныхБумаг404.Валюта, 0) КАК ВалютаРыночнойЦеныДляФ404,
	ВТ_Курсы.Курс КАК Курс,
	ВТ_Курсы.Кратность КАК Кратность
ПОМЕСТИТЬ ВТ_ОсновнаяТаблица
ИЗ
	ВТ_ОстаткиЦБ КАК ВТ_ОстаткиЦБ
		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ЦенныеБумаги КАК ЦенныеБумаги
		ПО ВТ_ОстаткиЦБ.ЦБ = ЦенныеБумаги.Ссылка
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.РыночныеЦеныЦенныхБумаг КАК РыночныеЦеныЦенныхБумаг
		ПО ВТ_ОстаткиЦБ.ЦБ = РыночныеЦеныЦенныхБумаг.ЦеннаяБумага
			И (РыночныеЦеныЦенныхБумаг.Период = &amp;ОтчетнаяДата)
			И (РыночныеЦеныЦенныхБумаг.МетодикаРасчета = ЗНАЧЕНИЕ(Перечисление.МетодикиРасчетаРыночныхЦен.Для481))
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.РыночныеЦеныЦенныхБумаг КАК РыночныеЦеныЦенныхБумаг404
		ПО (ВТ_ОстаткиЦБ.ЦБ = РыночныеЦеныЦенныхБумаг404.ЦеннаяБумага)
			И (РыночныеЦеныЦенныхБумаг404.Период = &amp;ОтчетнаяДата)
			И (РыночныеЦеныЦенныхБумаг404.МетодикаРасчета = ЗНАЧЕНИЕ(Перечисление.МетодикиРасчетаРыночныхЦен.Для0409404))
		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_Курсы КАК ВТ_Курсы
		ПО (РыночныеЦеныЦенныхБумаг.Валюта = ВТ_Курсы.Валюта)
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	ВТ_ОсновнаяТаблица.СчетДепоМестоХранения КАК СчетДепоМестоХранения,
	ВТ_ОсновнаяТаблица.ЦеннаяБумага КАК ЦеннаяБумага,
	ВТ_ОсновнаяТаблица.ISIN КАК ISIN,
	ВТ_ОсновнаяТаблица.ВидЦБ КАК ВидЦБ,
	ВТ_ОсновнаяТаблица.Дефолтная КАК Дефолтная,
	ВТ_ОсновнаяТаблица.ДатаДефолта КАК ДатаДефолта,
	ВТ_ОсновнаяТаблица.ВалютаНоминала КАК ВалютаНоминала,
	ВТ_ОсновнаяТаблица.Остаток КАК Остаток,
	ВТ_ОсновнаяТаблица.РыночнаяЦена КАК РыночнаяЦена,
	ВТ_ОсновнаяТаблица.Валюта КАК Валюта,
	ВТ_ОсновнаяТаблица.ВидЦены КАК ВидЦены,
	ВТ_ОсновнаяТаблица.ИтогоВВалюте КАК ИтогоВВалюте,
	ВТ_ОсновнаяТаблица.ИтогоВРублях КАК ИтогоВРублях,
	ВТ_ОсновнаяТаблица.РыночнаяЦенаДляФ404 КАК РыночнаяЦенаДляФ404,
	ВТ_ОсновнаяТаблица.ВалютаРыночнойЦеныДляФ404 КАК ВалютаРыночнойЦеныДляФ404,
	ВТ_ОсновнаяТаблица.Курс КАК Курс,
	ВТ_ОсновнаяТаблица.Кратность КАК Кратность,
	2 КАК Таблица
ИЗ ВТ_ОсновнаяТаблица КАК ВТ_ОсновнаяТаблица

ОБЪЕДИНИТЬ ВСЕ

ВЫБРАТЬ
	NULL КАК СчетДепоМестоХранения,
	NULL КАК ЦеннаяБумага,
	NULL КАК ISIN,
	NULL КАК ВидЦБ,
	NULL КАК Дефолтная,
	NULL КАК ДатаДефолта,
	NULL КАК ВалютаНоминала,
	NULL КАК Остаток,
	NULL КАК РыночнаяЦена,
	ВТ_ОсновнаяТаблица.Валюта КАК Валюта,
	NULL КАК ВидЦены,
	NULL КАК ИтогоВВалюте,
	NULL КАК ИтогоВРублях,
	NULL КАК РыночнаяЦенаДляФ404,
	NULL КАК ВалютаРыночнойЦеныДляФ404,
	МАКСИМУМ(ВТ_ОсновнаяТаблица.Курс) КАК Курс,
	NULL КАК Кратность,
	1 КАК Таблица
ИЗ ВТ_ОсновнаяТаблица КАК ВТ_ОсновнаяТаблица
СГРУППИРОВАТЬ ПО
	ВТ_ОсновнаяТаблица.Валюта</query>
