// Процедура выгружает сформированный отчет (данные в табличных частях отчета) в XML-файл
Процедура ВыгрузитьВXML() Экспорт
	ИмяФормы = "0409718";
	ПространствоИмен = "urn:cbr-ru:rep0409718:v1.0.4.5";
	
	СхемаXSD = ПолучитьМакет("Ф718_Schema_XSD");
	Фабрика = РегуляторнаяОтчетность.ФабрикаИзСхемыXSD(СхемаXSD);
	Отчетность = Фабрика.Создать(Фабрика.Тип(ПространствоИмен, "Ф0409718"));
	
	ОтчетнаяДата = ОтчетнаяДата();
	
	УникИдОЭС = Новый УникальныйИдентификатор;
	Отчетность.УникИдОЭС = Строка(УникИдОЭС);	// Пример: "8b91f09d-da8b-11ed-811d-00155d1a3509";
	Отчетность.ВидОЭС = "Отчетность КО";
	Отчетность.КодФормы = ИмяФормы;
	Отчетность.ОКУД = ИмяФормы;
	Отчетность.ВидОтчета = "КО";
	Отчетность.ОтчДата = ОтчетнаяДата;	// BSLLS:Typo-off
	Отчетность.Периодичность = "месячная";
	Отчетность.ДатаВремяФормирования = ТекущаяДатаСеанса();
	
	Отчетность.Составитель = СоставительОтчета(Фабрика, ПространствоИмен, ОтчетнаяДата);
	
	Отчетность.Данные718 = Данные718(Фабрика, ПространствоИмен);
	
	РегуляторнаяОтчетность.ЗаписатьОтчетностьДляДельтыВXML(Фабрика, Отчетность, ИмяФормы, ПериодНачало, ПериодКонец);
КонецПроцедуры

#КонецОбласти


#Область СлужебныеПроцедурыИФункции

// Процедура осуществляет проверку данных эмитентов, упомянутых в отчете на соответествие схеме XSD.
// Например, проверяется ожидаемая длинна и состав символов ИНН и ОГРН ...
// Параметры:
//	ДанныеЭмитентов - ТаблицаЗначений
Процедура ПроверитьДанныеЭмитентов(ДанныеЭмитентов)
	ДлиныИНН = РегуляторнаяОтчетность.ДопустимыеДлиныИНН();
	ДлиныОГРН = РегуляторнаяОтчетность.ДопустимыеДлиныОГРН();
	
	Для каждого Данные Из ДанныеЭмитентов Цикл
		
		Если НЕ ЗначениеЗаполнено(Данные.ЮридическиеФизическиеЛица) Тогда
			ОписаниеОшибки = "Для эмитента " + Строка(Данные.Эмитент) + " не указано юридическое/физическое лицо";
			РегуляторнаяОтчетность.ДобавитьОписаниеОшибки(ОписаниеОшибок, ОписаниеОшибки);
		КонецЕсли;
		Принадлежность = "эмитента";
		РегуляторнаяОтчетность.ПроверитьЦифровуюСтроку(ОписаниеОшибок, "ИНН", Принадлежность, Данные.ИНН_Эм, Данные.Эмитент, ДлиныИНН);
		РегуляторнаяОтчетность.ПроверитьЦифровуюСтроку(ОписаниеОшибок, "ОГРН", Принадлежность, Данные.ОГРН_Эм, Данные.Эмитент, ДлиныОГРН);
		РегуляторнаяОтчетность.ПроверитьЦифровуюСтроку(ОписаниеОшибок, "Код страны", Принадлежность, Данные.КодСтрЭм, Данные.Эмитент, 3);
		Если Данные.ПризнакКодаЭмНерез = "LEI" И Данные.КоличествоLEI > 1 Тогда
			ОписаниеОшибки = "Для эмитента " + Строка(Данные.Эмитент) + " в справочнике кодов загрузки имеется более одного действующего кода LEI";
			РегуляторнаяОтчетность.ДобавитьОписаниеОшибки(ОписаниеОшибок, ОписаниеОшибки);
		КонецЕсли;
		Если Данные.НетСоответствияИННДляЦБРФ Тогда
			ОписаниеОшибки = "Для ЮЛ [" + Строка(Данные.Эмитент) + "] не найдено соответствие в справочнике ИНН и ОРГН ЦБ РФ";
			РегуляторнаяОтчетность.ДобавитьОписаниеОшибки(ОписаниеОшибок, ОписаниеОшибки);
		КонецЕсли;
		Если Данные.ИНН_Эм = "0000000000" Тогда
			ОписаниеОшибки = "У эмитента " + Строка(Данные.Эмитент) + " отсутствует ИНН";
			РегуляторнаяОтчетность.ДобавитьОписаниеОшибки(ОписаниеОшибок, ОписаниеОшибки);
		КонецЕсли;
		Если Данные.ЭтоРезидентИлиНерезидентМК И Данные.ОГРН_Эм = "" Тогда
			ОписаниеОшибки = "У эмитента " + Строка(Данные.Эмитент) + " отсутствует ОГРН";
			РегуляторнаяОтчетность.ДобавитьОписаниеОшибки(ОписаниеОшибок, ОписаниеОшибки);
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

Процедура ПроверитьДанныеЦБ(ДанныеЦБ)
	Для каждого Данные Из ДанныеЦБ Цикл
		Если Не Данные.ЦББезНоминала Тогда
			Если Не ЗначениеЗаполнено(Данные.НомСтоимЦБ) Тогда
				ОписаниеОшибки = РегуляторнаяОтчетность.ОписаниеОшибкиЦБ(Данные.ЦБ, "не указан номинал", Данные.ISIN);
				РегуляторнаяОтчетность.ДобавитьОписаниеОшибки(ОписаниеОшибок, ОписаниеОшибки);
			КонецЕсли;
			Если Не ЗначениеЗаполнено(Данные.ВалютаНоминала) Тогда
				ОписаниеОшибки = РегуляторнаяОтчетность.ОписаниеОшибкиЦБ(Данные.ЦБ, "не указана валюта номинала", Данные.ISIN);
				РегуляторнаяОтчетность.ДобавитьОписаниеОшибки(ОписаниеОшибок, ОписаниеОшибки);
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

Процедура ПроверитьДанныеМестХранения(ДанныеМХ)
	Для каждого Данные Из ДанныеМХ Цикл
		Если Не ЗначениеЗаполнено(Данные.ЮрЛицо) Тогда
			ОписаниеОшибки = "В карточке места хранения " + Строка(Данные.МестоХранения.Наименование) + " не указано юридическое лицо";
			РегуляторнаяОтчетность.ДобавитьОписаниеОшибки(ОписаниеОшибок, ОписаниеОшибки);
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

Процедура ПроверитьДанныеОрганизаций(ДанныеОрганизаций)
	Для каждого Данные Из ДанныеОрганизаций Цикл
		Если Данные.РезидентИНН = "0000000000" И ЗначениеЗаполнено(Данные.ЮрЛицо) Тогда
			ОписаниеОшибки = "У организации-резидента " + Строка(Данные.Наименование) + " отсутствует ИНН";
			РегуляторнаяОтчетность.ДобавитьОписаниеОшибки(ОписаниеОшибок, ОписаниеОшибки);
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

Процедура ПроверитьВалютыВыплат(ДанныеПоВалютамВыплат)
	Для каждого Данные Из ДанныеПоВалютамВыплат Цикл
		ОписаниеОшибки = "Обнаружены заблокированные выплаты в нескольких разных валютах по ЦБ " + Строка(Данные.ЦБ)
							+ " в организации " + Строка(Данные.Организация) + " как минимум в " + Строка(Данные.МинВалютаВыплаты)
							+ " и " + Строка(Данные.МаксВалютаВыплаты);
			РегуляторнаяОтчетность.ДобавитьОписаниеОшибки(ОписаниеОшибок, ОписаниеОшибки);
	КонецЦикла;
КонецПроцедуры
	

Функция СоставительОтчета(Фабрика, ПространствоИмен, ОтчетнаяДата)
	Составитель = Фабрика.Создать(Фабрика.Тип(ПространствоИмен, "Ф0409718Составитель"));
	
	Составитель.Руководитель = Фабрика.Создать(Фабрика.Тип(ПространствоИмен, "Ф0409718СоставительРуководитель"));
	РегуляторнаяОтчетность.ЗаполнитьИнформациюОбОтветственномЛице(Составитель.Руководитель, Организация,
								Перечисления.ОтветственныеЛицаОрганизаций.ПодписантВРегуляторнойОтчетности, ОтчетнаяДата);
	Составитель.Исполнитель = Фабрика.Создать(Фабрика.Тип(ПространствоИмен, "Ф0409718СоставительИсполнитель"));
	РегуляторнаяОтчетность.ЗаполнитьИнформациюОбОтветственномЛице(Составитель.Исполнитель, Организация,
								Перечисления.ОтветственныеЛицаОрганизаций.ИсполнительВРегуляторнойОтчетности, ОтчетнаяДата);
	
	РегуляторнаяОтчетность.ЗаполнитьИнформациюОбОрганизации(Составитель, Организация, ОтчетнаяДата);
	
	Возврат Составитель;
КонецФункции

Функция Данные718(Фабрика, ПространствоИмен)
	Данные718 = Фабрика.Создать(Фабрика.Тип(ПространствоИмен, "Ф0409718Данные718"));
	Данные718.Ид = "1";
	Данные718.ДанныеОтчета = Данные718ДанныеОтчета(Фабрика, ПространствоИмен);
	
	Возврат Данные718;
КонецФункции

Функция Данные718ДанныеОтчета(Фабрика, ПространствоИмен)
	Данные = Фабрика.Создать(Фабрика.Тип(ПространствоИмен, "Ф0409718Данные718ДанныеОтчета"));
	
	СписокРеквизитов = "ПризнакЭм,НаименованиеЭм,ПризнакКодаЭмНерез,ИНН_Эм,TIN_Эм,ОГРН_Эм,КодСтрЭм,КодТипаЦБ"		// BSLLS:Typo-off
					+ ",НомРегЦБ,ISIN,CFI,КодВал,ВидСчета,КодСекторЭк,КодСтрВладельца,ПризнакВладельцаСчета"		// BSLLS:Typo-off
					+ ",ПризнакИнОрг,НаимИнОрг,ПризнакКодаИнОргНерез,ИНН_ИнОрг,TIN_ИнОрг,КодСтрИнОрг,КодСтрКА"		// BSLLS:Typo-off
					+ ",КодВалЗВыплат,КолКлиентов,ПризнакОрг,НаимОрг,ПризнакКодаОргНерез,ИНН_Орг,TIN_Орг"			// BSLLS:Typo-off
					+ ",ОГРН_Орг,Примечание";																		// BSLLS:Typo-off
	ОбычныеРеквизиты = СтрРазделить(СписокРеквизитов, ",");
	
	СписокРеквизитов = "НомСтоимЦБ,КолЗЦБ,КЗЦБОгрРаспрВсего,КЗЦБОгрРаспрЗалог,КЗЦБОгрРаспрСчДепо"					// BSLLS:Typo-off
					+ ",КЗЦБОгрРаспрКорпДейств,КЗЦБОгрРаспрЗапрОп,КЗЦБОгрРаспрЭскроу,КЗЦБОгрРаспрАрест";			// BSLLS:Typo-off
	РеквизитыСЧислами20Знаков = СтрРазделить(СписокРеквизитов, ",");
	
	Для каждого СтрокаТЧ Из ДанныеОтчета Цикл
		СтруктураXDTO = Фабрика.Создать(Фабрика.Тип(ПространствоИмен, "Ф0409718Данные718ДанныеОтчетаЗаблокЦБ"));	// BSLLS:Typo-off
		СтруктураXDTO.НомСтр = СтрокаТЧ.НомерСтроки;
		ЗаполнитьРеквизитыНепустымиЗначениями(СтруктураXDTO, СтрокаТЧ, ОбычныеРеквизиты);
		// Осторожно! Схема хранимая в конфигурации модифицирована по сравнению с оригинальной:
		// Добалены два новых типа "Строка38-лок" и "Строка32-лок", тип атрибутов 
		// Десят30.20Неотриц-лок заменен на Строка38-лок, а Десят30.2Неотриц-лок - "Строка32-лок"
		// Это потребовалось, чтобы все числа можно было выгрузить в файл дополненными до 20 (или 2) нулей после запятой
		ЗаполнитьРеквизитыВФормате20ЗнаковПослеЗапятой(СтруктураXDTO, СтрокаТЧ, РеквизитыСЧислами20Знаков);
		Если ЗначениеЗаполнено(СтрокаТЧ.СуммаЗВыплат) Тогда
			СтруктураXDTO.СуммаЗВыплат = Формат(СтрокаТЧ.СуммаЗВыплат, "ЧЦ=32; ЧДЦ=2; ЧРД=.; ЧН=; ЧГ=");
		КонецЕсли;
		Данные.ЗаблокЦБ.Добавить(СтруктураXDTO);
	КонецЦикла;
		
	Возврат Данные;
КонецФункции

Процедура ЗаполнитьРеквизитыНепустымиЗначениями(СтруктураXDTO, СтрокаТЧ, Реквизиты)
	Для Каждого ИмяРеквизита Из Реквизиты Цикл
		РегуляторнаяОтчетность.ПрисвоитьНепустое(СтруктураXDTO[ИмяРеквизита], СтрокаТЧ[ИмяРеквизита]);
	КонецЦикла;
КонецПроцедуры

Процедура ЗаполнитьРеквизитыВФормате20ЗнаковПослеЗапятой(СтруктураXDTO, СтрокаТЧ, РеквизитыСЧислами20Знаков)
	ФорматЧисла = "ЧЦ=38; ЧДЦ=20; ЧРД=.; ЧН=; ЧГ=";
	Для Каждого ИмяРеквизита Из РеквизитыСЧислами20Знаков Цикл
		Если ИмяРеквизита <> "НомСтоимЦБ" Или ЗначениеЗаполнено(СтрокаТЧ.НомСтоимЦБ) Тогда
			СтруктураXDTO[ИмяРеквизита] = Формат(СтрокаТЧ[ИмяРеквизита], ФорматЧисла);
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

Функция ОтчетнаяДата()
	Возврат КонецДня(ПериодКонец) + 1; // следующий день после даты конца выбранного отчетного периода
КонецФункции

