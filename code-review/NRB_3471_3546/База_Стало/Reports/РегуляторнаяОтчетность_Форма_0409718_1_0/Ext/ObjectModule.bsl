#Область ПрограммныйИнтерфейс

// Процедура заполняет данными ТЧ ДанныеОтчета
// BSLLS:MethodSize-off
Процедура ПолучитьДанные() Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	// Важно, что реквизит Резидент в справочнике контрагентов, как это ни парадоксально, означает "Нерезидент по документам"
	// - живите теперь с этим, если не знали раньше
	// Условия типа 1 = 1 в нескольких местах запроса в виртуальных таблицах среза последних - это чтобы Sonar не ругался
	// на виртуальную таблицу без параметров
	"ВЫБРАТЬ
	|	ЦенныеБумагиМестаХранения.Ссылка КАК ЦБ,
	|	&ЮрЛицоЕвроклир КАК ИностранныйДепозитарий
	|ПОМЕСТИТЬ ВТ_ЗаблокированныеЦБ
	|ИЗ
	|	Справочник.ЦенныеБумаги.МестаХранения КАК ЦенныеБумагиМестаХранения
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ЦенныеБумаги КАК ЦенныеБумаги
	|		ПО ЦенныеБумагиМестаХранения.Ссылка = ЦенныеБумаги.Ссылка
	|			И (НЕ ЦенныеБумаги.ПометкаУдаления)
	|			И (ЦенныеБумагиМестаХранения.МестоХранения = &ЮрЛицоЕвроклир)
	|
	|СГРУППИРОВАТЬ ПО
	|	ЦенныеБумагиМестаХранения.Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СчетаДепо.Ссылка КАК СчетДепо
	|ПОМЕСТИТЬ ВТ_АктивныеСчетаДепоКлиентовВключаемыхВОтчетВидов
	|ИЗ
	|	Справочник.СчетаДепо КАК СчетаДепо
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.КлассификаторДляОтчетовВидыСчетовДЕПО КАК ВидыСчетовДепоДляОтчетов
	|		ПО СчетаДепо.ТипСчетаДепо = ВидыСчетовДепоДляОтчетов.ТипСчета1С
	|			И (ВидыСчетовДепоДляОтчетов.ВидСчетаДляОтчета В (&ВидыСчетовДепоВключаемыеВОтчет))
	|ГДЕ
	|	НЕ СчетаДепо.ПометкаУдаления
	|	И СчетаДепо.ПризнакСчетаДепо = ЗНАЧЕНИЕ(Перечисление.ПризнакиСчетаДепо.СчетДепонента)
	|	И СчетаДепо.ВидСчетаДепо <> ЗНАЧЕНИЕ(Перечисление.ВидыСчетовДепо.ПустаяСсылка)
	|	И СчетаДепо.ДатаОткрытияСчета <= &ПериодКонец
	|	И ВЫБОР
	|			КОГДА СчетаДепо.СтатусСчетаДепо = ЗНАЧЕНИЕ(Перечисление.СтатусыСчетовДепо.Открыт)
	|					И СчетаДепо.ДатаЗакрытияСчета = ДАТАВРЕМЯ(1, 1, 1)
	|				ТОГДА ИСТИНА
	|			КОГДА СчетаДепо.СтатусСчетаДепо = ЗНАЧЕНИЕ(Перечисление.СтатусыСчетовДепо.Закрыт)
	|					И СчетаДепо.ДатаЗакрытияСчета > &ПериодКонец
	|				ТОГДА ИСТИНА
	|			ИНАЧЕ ЛОЖЬ
	|		КОНЕЦ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Поручение.Ссылка КАК ПоручениеСсылка
	|ПОМЕСТИТЬ ВТ_ПорученияНаВыплатыПоЗаблокированнымЦБ
	|ИЗ
	|	Документ.Поручение КАК Поручение
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ВидыОпераций КАК ВидыОпераций
	|		ПО Поручение.ВидОперацииД = ВидыОпераций.Ссылка
	|			И (НЕ Поручение.ПометкаУдаления)
	|			И (Поручение.Дата <= &ПериодКонец)
	|			И (ВидыОпераций.ВыплатаДоходаВДенежнойФорме)
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.БанковскиеСчета КАК БанковскиеСчета
	|		ПО Поручение.БанковскийСчет = БанковскиеСчета.Ссылка
	|			И (БанковскиеСчета.ЦельОткрытияСчета = ЗНАЧЕНИЕ(Перечисление.ЦельОткрытияСчета0420409.СчетДляЗаблокированныхВыплат))
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.Поручение.ЦенныеБумагиСписываемые КАК ПоручениеЦенныеБумагиСписываемые
	|		ПО Поручение.Ссылка = ПоручениеЦенныеБумагиСписываемые.Ссылка
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_ЗаблокированныеЦБ КАК ВТ_ЗаблокированныеЦБ
	|		ПО Поручение.ЦенныеБумагиСписываемые.ЦеннаяБумага = ВТ_ЗаблокированныеЦБ.ЦБ
	|
	|СГРУППИРОВАТЬ ПО
	|	Поручение.Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СтатусыПорученийСрезПоследних.Поручение КАК ПоручениеСсылка
	|ПОМЕСТИТЬ ВТ_ИсполненныеПорученияНаВыплатыПоЗаблокированнымЦБ
	|ИЗ
	|	РегистрСведений.СтатусыПоручений.СрезПоследних(
	|			&ПериодКонец,
	|			Поручение В
	|				(ВЫБРАТЬ
	|					ПорученияНаВыплаты.ПоручениеСсылка КАК ПоручениеСсылка
	|				ИЗ
	|					ВТ_ПорученияНаВыплатыПоЗаблокированнымЦБ КАК ПорученияНаВыплаты)) КАК СтатусыПорученийСрезПоследних
	|ГДЕ
	|	СтатусыПорученийСрезПоследних.СтатусПоручения = ЗНАЧЕНИЕ(Перечисление.СтатусыПоручений.Исполнено)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ПоручениеЦенныеБумагиСписываемые.СчетДепо КАК СчетДепо,
	|	ПоручениеЦенныеБумагиСписываемые.ЦеннаяБумага КАК ЦеннаяБумага,
	|	ПоручениеЦенныеБумагиСписываемые.РазделСчетаДепо КАК РазделСчетаДепо,
	|	ПоручениеЦенныеБумагиСписываемые.СчетДепоМХ КАК СчетДепоМХ,
	|	СУММА(ПоручениеЦенныеБумагиСписываемые.СуммаКВыплатеПоИПД) КАК СуммаКВыплате,
	|	Поручение.Валюта КАК ВалютаВыплаты
	|ПОМЕСТИТЬ ВТ_ЗаблокированныеВыплаты
	|ИЗ
	|	Документ.Поручение КАК Поручение
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_ПорученияНаВыплатыПоЗаблокированнымЦБ КАК ВТ_ПорученияНаВыплаты
	|		ПО Поручение.Ссылка = ВТ_ПорученияНаВыплаты.ПоручениеСсылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ИсполненныеПорученияНаВыплатыПоЗаблокированнымЦБ КАК ИсполненныеПоручения
	|		ПО Поручение.Ссылка = ИсполненныеПоручения.ПоручениеСсылка
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.Поручение.ЦенныеБумагиСписываемые КАК ПоручениеЦенныеБумагиСписываемые
	|		ПО Поручение.Ссылка = ПоручениеЦенныеБумагиСписываемые.Ссылка
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_ЗаблокированныеЦБ КАК ВТ_ЗаблокированныеЦБ
	|		ПО Поручение.ЦенныеБумагиСписываемые.ЦеннаяБумага = ВТ_ЗаблокированныеЦБ.ЦБ
	|ГДЕ
	|	ИсполненныеПоручения.ПоручениеСсылка ЕСТЬ NULL
	|
	|СГРУППИРОВАТЬ ПО
	|	ПоручениеЦенныеБумагиСписываемые.СчетДепо,
	|	ПоручениеЦенныеБумагиСписываемые.ЦеннаяБумага,
	|	ПоручениеЦенныеБумагиСписываемые.РазделСчетаДепо,
	|	ПоручениеЦенныеБумагиСписываемые.СчетДепоМХ,
	|	Поручение.Валюта
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ОстаткиЦБОстатки.СчетДепо КАК СчетДепо,
	|	ОстаткиЦБОстатки.ЦБ КАК ЦБ,
	|	ОстаткиЦБОстатки.РазделСчетаДепо КАК РазделСчетаДепо,
	|	ОстаткиЦБОстатки.СчетДепоМХ КАК СчетДепоМХ,
	|	ОстаткиЦБОстатки.СтатусЦБ КАК СтатусЦБ,
	|	ОстаткиЦБОстатки.КоличествоОстаток КАК КоличествоОстаток,
	|	0 КАК СуммаКВыплате,
	|	ЗНАЧЕНИЕ(Справочник.Валюты.ПустаяСсылка) КАК ВалютаВыплаты
	|ПОМЕСТИТЬ ВТ_ОстаткиЗаблокированныхЦБ
	|ИЗ
	|	РегистрНакопления.ОстаткиЦБ.Остатки(
	|			&ПериодКонец,
	|			ЦБ В
	|					(ВЫБРАТЬ
	|						ВТ_ЗаблокированныеЦБ.ЦБ КАК ЦБ
	|					ИЗ
	|						ВТ_ЗаблокированныеЦБ КАК ВТ_ЗаблокированныеЦБ)
	|				И СчетДепо В
	|					(ВЫБРАТЬ
	|						ВТ_АктивныеСчетаДепоКлиентовВключаемыхВОтчетВидов.СчетДепо КАК СчетДепо
	|					ИЗ
	|						ВТ_АктивныеСчетаДепоКлиентовВключаемыхВОтчетВидов КАК ВТ_АктивныеСчетаДепоКлиентовВключаемыхВОтчетВидов)) КАК ОстаткиЦБОстатки
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ВТ_ЗаблокированныеВыплаты.СчетДепо,
	|	ВТ_ЗаблокированныеВыплаты.ЦеннаяБумага,
	|	ВТ_ЗаблокированныеВыплаты.РазделСчетаДепо,
	|	ВТ_ЗаблокированныеВыплаты.СчетДепоМХ,
	|	ЗНАЧЕНИЕ(Перечисление.СтатусыЦБ.ПустаяСсылка),
	|	0,
	|	ВТ_ЗаблокированныеВыплаты.СуммаКВыплате,
	|	ВТ_ЗаблокированныеВыплаты.ВалютаВыплаты
	|ИЗ
	|	ВТ_ЗаблокированныеВыплаты КАК ВТ_ЗаблокированныеВыплаты
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_ОстаткиЗаблокированныхЦБ.ЦБ КАК ЦБ
	|ПОМЕСТИТЬ ВТ_ВсеЦБсОстатками
	|ИЗ
	|	ВТ_ОстаткиЗаблокированныхЦБ КАК ВТ_ОстаткиЗаблокированныхЦБ
	|
	|СГРУППИРОВАТЬ ПО
	|	ВТ_ОстаткиЗаблокированныхЦБ.ЦБ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_ВсеЦБсОстатками.ЦБ КАК ЦБ,
	|	ВЫБОР
	|		КОГДА ЦенныеБумаги.ТипЦБ В (&ТипыДепозитарныхРасписок)
	|			ТОГДА БазовыеАктивы.Эмитент
	|		ИНАЧЕ ЦенныеБумаги.Эмитент
	|	КОНЕЦ КАК Эмитент
	|ПОМЕСТИТЬ ВТ_ЭмитентыЦБ
	|ИЗ
	|	ВТ_ВсеЦБсОстатками КАК ВТ_ВсеЦБсОстатками
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ЦенныеБумаги КАК ЦенныеБумаги
	|		ПО ВТ_ВсеЦБсОстатками.ЦБ = ЦенныеБумаги.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ЦенныеБумаги КАК БазовыеАктивы
	|		ПО (ЦенныеБумаги.БазовыйАктив = БазовыеАктивы.Ссылка)
	|
	|СГРУППИРОВАТЬ ПО
	|	ВТ_ВсеЦБсОстатками.ЦБ,
	|	ВЫБОР
	|		КОГДА ЦенныеБумаги.ТипЦБ В (&ТипыДепозитарныхРасписок)
	|			ТОГДА БазовыеАктивы.Эмитент
	|		ИНАЧЕ ЦенныеБумаги.Эмитент
	|	КОНЕЦ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_ЭмитентыЦБ.Эмитент КАК Эмитент
	|ПОМЕСТИТЬ ВТ_Эмитенты
	|ИЗ
	|	ВТ_ЭмитентыЦБ КАК ВТ_ЭмитентыЦБ
	|
	|СГРУППИРОВАТЬ ПО
	|	ВТ_ЭмитентыЦБ.Эмитент
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	КлиентыСУчетомНаСчетахТипаС.Клиент КАК Эмитент
	|ПОМЕСТИТЬ ВТ_ЭмитентыСУчетомНаСчетахТипаС
	|ИЗ
	|	РегистрСведений.КлиентыСУчетомНаСчетахТипаC.СрезПоследних(
	|			&ОтчетнаяДата,
	|			Клиент В
	|				(ВЫБРАТЬ
	|					ВТ_Эмитенты.Эмитент КАК Эмитент
	|				ИЗ
	|					ВТ_Эмитенты КАК ВТ_Эмитенты)) КАК КлиентыСУчетомНаСчетахТипаС
	|ГДЕ
	|	КлиентыСУчетомНаСчетахТипаС.ФлагАктивности
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_Эмитенты.Эмитент КАК Эмитент,
	|	Контрагенты.Резидент КАК Нерезидент
	|ПОМЕСТИТЬ ВТ_РезидентствоЭмитентов
	|ИЗ
	|	ВТ_Эмитенты КАК ВТ_Эмитенты
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Контрагенты КАК Контрагенты
	|		ПО ВТ_Эмитенты.Эмитент = Контрагенты.Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_Эмитенты.Эмитент КАК Эмитент,
	|	МАКСИМУМ(КодыЗагрузки.Код) КАК LEI,
	|	КОЛИЧЕСТВО(*) КАК КоличествоLEI
	|ПОМЕСТИТЬ ВТ_ЭмитентыКодыLEI
	|ИЗ
	|	ВТ_Эмитенты КАК ВТ_Эмитенты
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Контрагенты КАК Контрагенты
	|		ПО ВТ_Эмитенты.Эмитент = Контрагенты.Ссылка
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_РезидентствоЭмитентов КАК ВТ_РезидентствоЭмитентов
	|		ПО ВТ_Эмитенты.Эмитент = ВТ_РезидентствоЭмитентов.Эмитент
	|			И (ВТ_РезидентствоЭмитентов.Нерезидент)
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ЮридическиеЛица КАК ЮридическиеЛица
	|		ПО (Контрагенты.ЮридическиеФизическиеЛица = ЮридическиеЛица.Ссылка)
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.КодыЗагрузки КАК КодыЗагрузки
	|		ПО (ЮридическиеЛица.Ссылка = КодыЗагрузки.Владелец)
	|			И (КодыЗагрузки.Биржа = ЗНАЧЕНИЕ(Справочник.КлассификаторыЗагрузки.LEI_Code))
	|			И (НЕ КодыЗагрузки.ПометкаУдаления)
	|			И (КодыЗагрузки.ДатаОкончанияДействия = ДАТАВРЕМЯ(1, 1, 1)
	|				ИЛИ КодыЗагрузки.ДатаОкончанияДействия > &ПериодКонец)
	|
	|СГРУППИРОВАТЬ ПО
	|	ВТ_Эмитенты.Эмитент
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЮридическиеЛица.ИНН КАК ИНН
	|ПОМЕСТИТЬ ВТ_ИННЭмитентов
	|ИЗ
	|	ВТ_Эмитенты КАК ВТ_Эмитенты
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Контрагенты КАК Контрагенты
	|		ПО ВТ_Эмитенты.Эмитент = Контрагенты.Ссылка
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ЮридическиеЛица КАК ЮридическиеЛица
	|		ПО (Контрагенты.ЮридическиеФизическиеЛица = ЮридическиеЛица.Ссылка)
	|			И ЮридическиеЛица.ИНН <> """"
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЮридическиеЛицаЦБРФСрезПоследних.Период КАК Период,
	|	ЮридическиеЛицаЦБРФСрезПоследних.ИНН КАК ИНН,
	|	ЮридическиеЛицаЦБРФСрезПоследних.ОГРН КАК ОГРН,
	|	ЮридическиеЛицаЦБРФСрезПоследних.Наименование КАК Наименование
	|ПОМЕСТИТЬ ВТ_ЮридическиеЛицаЭмитентовЦБРФ
	|ИЗ
	|	РегистрСведений.ЮридическиеЛицаЦБРФ.СрезПоследних(
	|			&ПериодКонец,
	|			ИНН В
	|				(ВЫБРАТЬ
	|					ВТ_ИНН.ИНН КАК ИНН
	|				ИЗ
	|					ВТ_ИННЭмитентов КАК ВТ_ИНН)) КАК ЮридическиеЛицаЦБРФСрезПоследних
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЮридическиеЛицаМеждународныеКомпанииСрезПоследних.МеждународнаяКомпания КАК МеждународнаяКомпания,
	|	ЮридическиеЛицаМеждународныеКомпанииСрезПоследних.ЮридическоеЛицо КАК ЮридическоеЛицо
	|ПОМЕСТИТЬ ЮридическиеЛицаМеждународныеКомпании
	|ИЗ
	|	РегистрСведений.ЮридическиеЛицаМеждународныеКомпании.СрезПоследних(&ПериодКонец, 1 = 1) КАК ЮридическиеЛицаМеждународныеКомпанииСрезПоследних
	|ГДЕ
	|	ЮридическиеЛицаМеждународныеКомпанииСрезПоследних.МеждународнаяКомпания
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_Эмитенты.Эмитент КАК Эмитент,
