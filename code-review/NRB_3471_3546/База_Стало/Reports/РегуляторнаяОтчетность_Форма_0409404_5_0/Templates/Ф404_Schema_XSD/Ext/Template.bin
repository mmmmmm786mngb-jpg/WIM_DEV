		<xs:attribute name="ВидОтчета" type="Строка" use="required"/>
		<xs:attribute name="ОтчДата" type="Дата" use="required"/>
		<xs:attribute name="Периодичность" type="ТипПериодаТип" use="required"/>
		<xs:attribute name="ДатаВремяФормирования" type="ДатаВремя" use="required"/>
	</xs:complexType>
	<xs:complexType name="Ф0409404Составитель" xmlns:xs="http://www.w3.org/2001/XMLSchema">
		<xs:sequence>
			<xs:element name="Руководитель" type="Ф0409404СоставительРуководитель" minOccurs="1" maxOccurs="1"/>
			<xs:element name="Исполнитель" type="Ф0409404СоставительИсполнитель" minOccurs="1" maxOccurs="1"/>
		</xs:sequence>
