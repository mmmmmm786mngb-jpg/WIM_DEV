			<xs:extension base="СтрокаНепустая"></xs:extension>
		</xs:simpleContent>
	</xs:complexType>
	<xs:complexType name="Ф0409404ПротоколКонтроля" xmlns:xs="http://www.w3.org/2001/XMLSchema">
		<xs:sequence>
			<xs:element name="Сообщение" type="Ф0409404ПротоколКонтроляСообщение" minOccurs="1" maxOccurs="unbounded"/>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="Ф0409404ПротоколКонтроляСообщение" xmlns:xs="http://www.w3.org/2001/XMLSchema">
