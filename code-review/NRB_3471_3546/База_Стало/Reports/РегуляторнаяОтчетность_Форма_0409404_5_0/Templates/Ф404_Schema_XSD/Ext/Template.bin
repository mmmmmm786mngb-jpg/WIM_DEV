		<xs:attribute name="ПризнМестаХр" use="required"><xs:simpleType><xs:restriction base="Строка2"><xs:enumeration value="1"/><xs:enumeration value="2"/><xs:enumeration value="3"/></xs:restriction></xs:simpleType></xs:attribute>
