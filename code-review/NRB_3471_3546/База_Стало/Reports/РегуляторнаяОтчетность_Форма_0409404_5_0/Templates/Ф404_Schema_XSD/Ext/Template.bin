<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema" elementFormDefault="qualified" targetNamespace="urn:cbr-ru:rep0409404:v5.0.4.5" xmlns="urn:cbr-ru:rep0409404:v5.0.4.5"><xs:element name="Ф0409404" type="Ф0409404" xmlns:xs="http://www.w3.org/2001/XMLSchema"/>
	<xs:complexType name="Ф0409404" xmlns:xs="http://www.w3.org/2001/XMLSchema">
		<xs:sequence>
			<xs:element name="Составитель" type="Ф0409404Составитель" minOccurs="1" maxOccurs="1"/>
			<xs:element name="Данные404" type="Ф0409404Данные404" minOccurs="1" maxOccurs="1"/>
			<xs:element name="Пояснение" type="Ф0409404Пояснение" minOccurs="0" maxOccurs="1"/>
