Функция НайтиПоИННилиОГРН(ИНН,ОГРН, ПоискРезидента, Выгодоприобретатель=Неопределено) Экспорт
	Результат = Неопределено;
	Запрос = Новый Запрос("ВЫБРАТЬ
	|	ЮридическиеЛица.Ссылка
	|ИЗ
	|	Справочник.ЮридическиеЛица КАК ЮридическиеЛица");
	Запрос.Текст = Запрос.Текст + ?(ПоискРезидента,
									" ГДЕ ЮридическиеЛица.ИНН = &ИНН И ЮридическиеЛица.НеРезидент = ЛОЖЬ",
									" ГДЕ ЮридическиеЛица.ОГРН = &ОГРН И ЮридическиеЛица.НеРезидент = ИСТИНА");
	Если Выгодоприобретатель <> Неопределено Тогда 
		Запрос.Текст = Запрос.Текст + " И ЮридическиеЛица.Выгодоприобретатель = &Выгодоприобретатель";
		Запрос.УстановитьПараметр("Выгодоприобретатель", Выгодоприобретатель);
	КонецЕсли;
	Запрос.УстановитьПараметр("ИНН", ИНН);
	Запрос.УстановитьПараметр("ОГРН", ОГРН);
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Результат = Выборка.Ссылка;
	КонецЕсли;
	
	Возврат Результат;
КонецФункции