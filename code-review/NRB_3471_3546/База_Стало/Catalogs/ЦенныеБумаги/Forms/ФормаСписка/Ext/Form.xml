	<Attributes>
		<Attribute name="Список" id="1">
			<Type>
				<v8:Type>cfg:DynamicList</v8:Type>
			</Type>
			<MainAttribute>true</MainAttribute>
			<Settings xsi:type="DynamicList">
				<ManualQuery>true</ManualQuery>
				<DynamicDataRead>true</DynamicDataRead>
				<QueryText>ВЫБРАТЬ
	СправочникЦенныеБумаги.Ссылка,
	СправочникЦенныеБумаги.ВерсияДанных,
	СправочникЦенныеБумаги.ПометкаУдаления,
	СправочникЦенныеБумаги.Предопределенный,
	СправочникЦенныеБумаги.Родитель,
	СправочникЦенныеБумаги.ЭтоГруппа,
	СправочникЦенныеБумаги.Код,
	СправочникЦенныеБумаги.Наименование,
	СправочникЦенныеБумаги.ISIN,
	СправочникЦенныеБумаги.CFI,
	СправочникЦенныеБумаги.ДатаГосРег,
	СправочникЦенныеБумаги.ДатаСнятияСОбслуживания,
	СправочникЦенныеБумаги.НомерРегистрации,
	СправочникЦенныеБумаги.Эмитент,
	СправочникЦенныеБумаги.НФИ,
	КодыЗагрузкиНРД.КодНРД,
	КодыЗагрузкиММВБ.КодММВБ
ИЗ
	Справочник.ЦенныеБумаги КАК СправочникЦенныеБумаги
		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
			КодыЗагрузки.Владелец КАК ЦБ,
			МАКСИМУМ(КодыЗагрузки.Код) КАК КодНРД
		ИЗ
			Справочник.КодыЗагрузки КАК КодыЗагрузки
		ГДЕ
			КодыЗагрузки.Биржа = &amp;КлассификаторНДЦ
			И КодыЗагрузки.ДатаОкончанияДействия = ДАТАВРЕМЯ(1, 1, 1, 0, 0, 0)
		
		СГРУППИРОВАТЬ ПО
			КодыЗагрузки.Владелец) КАК КодыЗагрузкиНРД
		ПО СправочникЦенныеБумаги.Ссылка = КодыЗагрузкиНРД.ЦБ
		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
			КодыЗагрузки.Владелец КАК ЦБ,
			МАКСИМУМ(КодыЗагрузки.Код) КАК КодММВБ
		ИЗ
			Справочник.КодыЗагрузки КАК КодыЗагрузки
		ГДЕ
			КодыЗагрузки.Биржа = ЗНАЧЕНИЕ(Справочник.Биржи.MICEX)
			И КодыЗагрузки.ДатаОкончанияДействия = ДАТАВРЕМЯ(1, 1, 1, 0, 0, 0)
		
		СГРУППИРОВАТЬ ПО
			КодыЗагрузки.Владелец) КАК КодыЗагрузкиММВБ
		ПО СправочникЦенныеБумаги.Ссылка = КодыЗагрузкиММВБ.ЦБ</QueryText>
				<MainTable>Catalog.ЦенныеБумаги</MainTable>
				<ListSettings>
					<dcsset:filter>
						<dcsset:viewMode>Normal</dcsset:viewMode>
						<dcsset:userSettingID>dfcece9d-5077-440b-b6b3-45a5cb4538eb</dcsset:userSettingID>
					</dcsset:filter>
					<dcsset:order>
						<dcsset:viewMode>Normal</dcsset:viewMode>
						<dcsset:userSettingID>88619765-ccb3-46c6-ac52-38e9c992ebd4</dcsset:userSettingID>
					</dcsset:order>
					<dcsset:conditionalAppearance>
						<dcsset:item>
							<dcsset:selection>
								<dcsset:item>
									<dcsset:field>ISIN</dcsset:field>
								</dcsset:item>
								<dcsset:item>
									<dcsset:field>Code</dcsset:field>
								</dcsset:item>
								<dcsset:item>
									<dcsset:field>Description</dcsset:field>
								</dcsset:item>
								<dcsset:item>
									<dcsset:field>ДатаГосРег</dcsset:field>
								</dcsset:item>
								<dcsset:item>
									<dcsset:field>ДатаСнятияСОбслуживания</dcsset:field>
								</dcsset:item>
								<dcsset:item>
									<dcsset:field>НомерРегистрации</dcsset:field>
								</dcsset:item>
								<dcsset:item>
									<dcsset:field>Эмитент</dcsset:field>
								</dcsset:item>
							</dcsset:selection>
							<dcsset:filter>
								<dcsset:item xsi:type="dcsset:FilterItemComparison">
									<dcsset:left xsi:type="dcscor:Field">ДатаСнятияСОбслуживания</dcsset:left>
									<dcsset:comparisonType>LessOrEqual</dcsset:comparisonType>
									<dcsset:right xsi:type="v8:StandardBeginningDate">
										<v8:variant xsi:type="v8:StandardBeginningDateVariant">BeginningOfThisDay</v8:variant>
									</dcsset:right>
								</dcsset:item>
								<dcsset:item xsi:type="dcsset:FilterItemComparison">
									<dcsset:left xsi:type="dcscor:Field">ДатаСнятияСОбслуживания</dcsset:left>
									<dcsset:comparisonType>NotEqual</dcsset:comparisonType>
									<dcsset:right xsi:type="v8:StandardBeginningDate">
										<v8:variant xsi:type="v8:StandardBeginningDateVariant">Custom</v8:variant>
										<v8:date>0001-01-01T00:00:00</v8:date>
									</dcsset:right>
								</dcsset:item>
							</dcsset:filter>
							<dcsset:appearance>
								<dcscor:item xsi:type="dcsset:SettingsParameterValue">
									<dcscor:parameter>ЦветФона</dcscor:parameter>
									<dcscor:value xsi:type="v8ui:Color">#C0C0C0</dcscor:value>
								</dcscor:item>
								<dcscor:item xsi:type="dcsset:SettingsParameterValue">
									<dcscor:parameter>Шрифт</dcscor:parameter>
									<dcscor:value xsi:type="v8ui:Font" ref="sys:DefaultGUIFont" bold="false" italic="false" underline="false" strikeout="true" kind="WindowsFont"/>
								</dcscor:item>
							</dcsset:appearance>
						</dcsset:item>
						<dcsset:viewMode>Normal</dcsset:viewMode>
						<dcsset:userSettingID>b75fecce-942b-4aed-abc9-e6a02e460fb3</dcsset:userSettingID>
					</dcsset:conditionalAppearance>
				</ListSettings>
			</Settings>
