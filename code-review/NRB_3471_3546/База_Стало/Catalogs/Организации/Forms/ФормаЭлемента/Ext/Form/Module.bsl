&НаСервере
Процедура ЗаписатьПраваДоступаКОбъекту(Отказ)
	
	Набор = РеквизитФормыВЗначение("ПраваДоступаПользователей");
	ЗаписатьПраваДоступаКОбъектуИзОбщегоМодуля(Набор, Объект.Ссылка, Отказ);
	ЗначениеВРеквизитФормы(Набор,"ПраваДоступаПользователей"); 
	
КонецПроцедуры

&НаСервере
Процедура ПрочитатьПраваДоступаКОбъекту(ПраваДоступаПользователей, Ссылка)
	
	Набор = РеквизитФормыВЗначение("ПраваДоступаПользователей");
	НастройкаПравДоступа.ПрочитатьПраваДоступаКОбъекту(Набор, Ссылка);
	
	ЗначениеВРеквизитФормы(Набор,"ПраваДоступаПользователей");
	Для каждого Запись Из ПраваДоступаПользователей   Цикл
		
		Запись.Чтение = Истина;
	
	КонецЦикла;

	
КонецПроцедуры


&НаСервере
Процедура ЗаписатьНаборыЗаписейНаСервере(Отказ, ТекущийОбъект)	
	ЗначениеОтбора = ТекущийОбъект.Ссылка;
	
	ЗаписатьНаборЗаписейНаСервере("ОтветственныеЛицаОрганизаций", "СтруктурнаяЕдиница", ЗначениеОтбора, Отказ);	
	//ЗаписатьНаборЗаписейНаСервере("ПраваДоступаПользователей", "ОбъектДоступа", ЗначениеОтбора, Отказ);	
	
КонецПроцедуры

&НаСервере
Процедура ПрочитатьНаборыЗаписейНаСервере(ТекущийОбъект)	
	ЗначениеОтбора = ТекущийОбъект.Ссылка;
	
	ПрочитатьНаборЗаписейНаСервере("ОтветственныеЛицаОрганизаций", "СтруктурнаяЕдиница", ЗначениеОтбора);		
	//ПрочитатьНаборЗаписейНаСервере("ПраваДоступаПользователей", "ОбъектДоступа", ЗначениеОтбора);		
	
КонецПроцедуры

&НаСервере
Процедура ЗаписатьНаборЗаписейНаСервере(ИмяЭлемента, ИмяПоля, ЗначениеОтбора, Отказ)
	
	Если Отказ Тогда
		Возврат;		
	КонецЕсли; 
	
	НаборЗначение = РеквизитФормыВЗначение(ИмяЭлемента);
	НаборЗначение.Отбор[ИмяПоля].Установить(ЗначениеОтбора);
	Для каждого ЗаписьНабора Из НаборЗначение Цикл
		ЗаписьНабора[ИмяПоля] = ЗначениеОтбора;		
	КонецЦикла; 
	
	Попытка
		НаборЗначение.Записать();
	Исключение
		МетаНабор = НаборЗначение.Метаданные();
		
		ОписаниеОшибки = ОписаниеОшибки();
		ОбщегоНазначения.СообщитьОбОшибке(ОписаниеОшибки
			, Отказ
			, "Элемент """ + СокрЛП(ЗначениеОтбора) + """ не записан. Не записан набор "+ МетаНабор.Синоним +".");			
	КонецПопытки;
			
КонецПроцедуры

&НаСервере
Процедура ПрочитатьНаборЗаписейНаСервере(ИмяЭлемента, ИмяПоля, ЗначениеОтбора)
	
	Если Не ЗначениеЗаполнено(Объект.Ссылка) Тогда
		Возврат;		
	КонецЕсли; 
	
	НаборЗначение = РеквизитФормыВЗначение(ИмяЭлемента);
	НаборЗначение.Отбор[ИмяПоля].Установить(ЗначениеОтбора);
	НаборЗначение.Прочитать();
	ЗначениеВРеквизитФормы(НаборЗначение, ИмяЭлемента);
		
КонецПроцедуры


// В ОМ почему то закомментировано
&НаСервере
Процедура ЗаписатьПраваДоступаКОбъектуИзОбщегоМодуля(ПраваДоступаПользователей, Ссылка, Отказ) 

	Если НЕ Отказ Тогда
	
		// Сравним наборы записей
		ЭталонныйНабор = РегистрыСведений.ПраваДоступаПользователей.СоздатьНаборЗаписей();
		Если ТипЗнч(Ссылка) = Тип("СправочникСсылка.Пользователи") ИЛИ ТипЗнч(Ссылка) = Тип("СправочникСсылка.ГруппыПользователей") Тогда
			ЭталонныйНабор.Отбор.Пользователь.Значение = Ссылка;
			ЭталонныйНабор.Отбор.Пользователь.Использование = Истина;
		Иначе
			ЭталонныйНабор.Отбор.ОбъектДоступа.Значение = Ссылка;
			ЭталонныйНабор.Отбор.ОбъектДоступа.Использование = Истина;
		КонецЕсли; 
		ЭталонныйНабор.Прочитать();
		
		Для каждого ЗаписьНабора Из ПраваДоступаПользователей Цикл
			Если ТипЗнч(Ссылка) = Тип("СправочникСсылка.Пользователи") ИЛИ ТипЗнч(Ссылка) = Тип("СправочникСсылка.ГруппыПользователей") Тогда
				ЗаписьНабора.Пользователь = Ссылка;
			Иначе
				ЗаписьНабора.ОбъектДоступа = Ссылка;
			КонецЕсли; 
		КонецЦикла; 
			
		Если НЕ НастройкаПравДоступа.СравнитьТаблицыНаборовЗаписей(ЭталонныйНабор.Выгрузить(), ПраваДоступаПользователей.Выгрузить()) Тогда
		
			Если ТипЗнч(Ссылка) = Тип("СправочникСсылка.Пользователи") ИЛИ ТипЗнч(Ссылка) = Тип("СправочникСсылка.ГруппыПользователей") Тогда
				ПраваДоступаПользователей.Отбор.Пользователь.Значение      = Ссылка;
				ПраваДоступаПользователей.Отбор.Пользователь.Использование = Истина;
			Иначе
				ПраваДоступаПользователей.Отбор.ОбъектДоступа.Значение      = Ссылка;
				ПраваДоступаПользователей.Отбор.ОбъектДоступа.Использование = Истина;
			КонецЕсли; 
			
			ПолныеПрава.ЗаписатьПраваДоступа(ПраваДоступаПользователей.Выгрузить(), НастройкаПравДоступа.ПолучитьСтруктуруОтборовНабораЗаписей(ПраваДоступаПользователей), Отказ, ("Элемент """ + СокрЛП(Ссылка) + """ не записан"));
			
			Если НЕ Отказ Тогда
				НастройкаПравДоступа.ПрочитатьПраваДоступаКОбъекту(ПраваДоступаПользователей, Ссылка);
			КонецЕсли; 

		КонецЕсли;
	
	КонецЕсли; 
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьФио() //нет  на форме фамилия, имя, отчество
	
	Запрос = Новый Запрос();
	Запрос.УстановитьПараметр("Ссылка",Объект.Ссылка);

	Запрос.Текст = "ВЫБРАТЬ
	               |	ФИОФизЛицСрезПоследних.Имя,
	               |	ФИОФизЛицСрезПоследних.Отчество,
	               |	ФИОФизЛицСрезПоследних.Фамилия,
	               |	ФИОФизЛицСрезПоследних.ФизЛицо КАК ФизЛицоФИО
	               |ИЗ
	               |	Справочник.Организации КАК Организации
	               |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ФИОФизЛиц.СрезПоследних(, ФизЛицо = &Ссылка) КАК ФИОФизЛицСрезПоследних
	               |		ПО Организации.Ссылка = ФИОФизЛицСрезПоследних.ФизЛицо
	               |
	               |ГДЕ
	               |	Организации.Ссылка = &Ссылка";
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Если Выборка.ФизЛицоФИО <> Неопределено Тогда
			Фамилия = Выборка.Фамилия;
			Имя = Выборка.Имя;
			Отчество = Выборка.Отчество;
		КонецЕсли;
	КонецЕсли;
	
	
КонецПроцедуры

Функция ОбновитьИННОбособленныхОрганизаций()

	ТекстСообщения = "";
	ЗапросОрганизации = Новый Запрос;
	ЗапросОрганизации.УстановитьПараметр("ГоловнаяОрганизация", Объект.Ссылка);
	ЗапросОрганизации.УстановитьПараметр("ИНН", Объект.ИНН);
	
	ТекстЗапроса =
	"ВЫБРАТЬ
	|	Организации.Ссылка
	|ИЗ
	|	Справочник.Организации КАК Организации
	|
	|ГДЕ
	|	Организации.ГоловнаяОрганизация = &ГоловнаяОрганизация И
	|	Организации.ИНН <> &ИНН";
	
	ЗапросОрганизации.Текст = ТекстЗапроса;
	
	ВыборкаЗапроса = ЗапросОрганизации.Выполнить().Выбрать();
	
	Пока ВыборкаЗапроса.Следующий() Цикл
		
		ОбособленнаяОрганизация = ВыборкаЗапроса.Ссылка.ПолучитьОбъект();
		
		Попытка
		    ОбособленнаяОрганизация.Заблокировать();
		Исключение
			
			ТекстСообщения = "Организация: " + ВыборкаЗапроса.Ссылка + " - объект заблокирован.";
			Возврат ТекстСообщения
		
		КонецПопытки;
		
	КонецЦикла;	    
	
	ВыборкаЗапроса.Сбросить(); 
	
	Пока ВыборкаЗапроса.Следующий() Цикл
		
		ОбособленнаяОрганизация = ВыборкаЗапроса.Ссылка.ПолучитьОбъект();
		
		ОбособленнаяОрганизация.ИНН = Объект.ИНН;
		ОбособленнаяОрганизация.Записать()
		
	КонецЦикла; 

	Возврат ТекстСообщения

КонецФункции

&НаКлиенте
Процедура ВыборФайлаДоговора(Элемент, ПроверятьСуществование=Ложь)
	
	ДиалогФыбораФайла	=	Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.Открытие);
	
	ДиалогФыбораФайла.Фильтр						=	"Файл данных (*.dot)|*.dot";
	ДиалогФыбораФайла.Заголовок						=	"Выберите файл";
	ДиалогФыбораФайла.ПредварительныйПросмотр		=	Ложь;
	ДиалогФыбораФайла.Расширение				    =	"dot";
	ДиалогФыбораФайла.ИндексФильтра					=	0;
	ДиалогФыбораФайла.ПолноеИмяФайла				=	Элемент;
	ДиалогФыбораФайла.ПроверятьСуществованиеФайла	=	ПроверятьСуществование;
	
	Если ДиалогФыбораФайла.Выбрать() Тогда
		Элемент = ДиалогФыбораФайла.ПолноеИмяФайла;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура УправлениеВидимостьюИДоступностьюЭлементовФормы(Форма)
	
	ЭлементыФормы = Форма.Элементы;
	Объект = Форма.Объект;

	ЭтоФизЛицо = (Объект.ЮрФизЛицо = ПредопределенноеЗначение("Перечисление.ЮрФизЛицо.ФизЛицо"));

	ЭлементыФормы.КПП.Видимость = НЕ ЭтоФизЛицо;
	ЭлементыФормы.КодОКОНХ.Видимость = НЕ ЭтоФизЛицо;
	ЭлементыФормы.КодПоОКПО.Видимость = НЕ ЭтоФизЛицо;
	ЭлементыФормы.ДатаРегистрации.Видимость = НЕ ЭтоФизЛицо;
	ЭлементыФормы.СвидетельствоКодОргана.Видимость = НЕ ЭтоФизЛицо;
	ЭлементыФормы.СвидетельствоНаименованиеОргана.Видимость = НЕ ЭтоФизЛицо;

	ЭлементыФормы.ИндивидуальныйПредприниматель.Видимость = ЭтоФизЛицо;
		
	ЭлементыФормы.ОГРН.Заголовок = ?(ЭтоФизЛицо, "ОГРНИП:", "ОГРН:");
	
	Если ЭтоФизЛицо Тогда
		ЭлементыФормы.ИНН.Доступность = Ложь;
	Иначе
		ЭлементыФормы.ИНН.Доступность = ОбщегоНазначения.ЗначениеНеЗаполнено(Объект.ГоловнаяОрганизация);
	КонецЕсли;
	
	ЭлементыФормы.СтраницаИностраннаяОрганизация.Видимость = Объект.ИностраннаяОрганизация;
	
	ЭлементыФормы.ЮридическоеЛицо.Видимость = НЕ ЭтоФизЛицо;
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ЗначениеРеквизитаНаСервере(Источник, ИмяРеквизита)
	Перем Результат;
	Если Источник <> Неопределено Тогда
		Результат = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Источник, ИмяРеквизита);
		
	КонецЕсли; 
	
	Возврат Результат;
	
КонецФункции


