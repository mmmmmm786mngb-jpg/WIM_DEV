
//#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	КоличествоЭлементов = 0;
	Выборка				= Справочники.Организации.Выбрать();
	Пока Выборка.Следующий() Цикл		
	   КоличествоЭлементов = КоличествоЭлементов + 1;
	КонецЦикла; 
	Если  (КоличествоЭлементов = 1) и НЕ ЗначениеЗаполнено(Объект.Ссылка) Тогда  //перенес ка есть
		Сообщить("В данном решении многофирменный учет не ведется!!!");
		Отказ = Истина;
	ИначеЕсли 	(КоличествоЭлементов > 1) и (КоличествоЭлементов <> 0) Тогда		
		Сообщить("В данном решении многофирменный учет не ведется!!!");
		Отказ = Истина;		
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(Объект.Ссылка ) Тогда
		
		Объект.ОсновнойБанковскийСчет = Неопределено;
		Объект.ЮрФизЛицо = Перечисления.ЮрФизЛицо.ЮрЛицо;
			
	КонецЕсли;
	Если ОбщегоНазначения.ЗначениеНеЗаполнено(Объект.ЮрФизЛицо) Тогда
		Объект.ЮрФизЛицо = Перечисления.ЮрФизЛицо.ЮрЛицо;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Объект.Ссылка) Тогда
		ПрочитатьПраваДоступаКОбъекту(ПраваДоступаПользователей, Объект.Ссылка);
	КонецЕсли;
	
	//ОбслужитьТаблицуНастройкиПравДоступа();
	
	УправлениеВидимостьюИДоступностьюЭлементовФормы(ЭтаФорма);
	
	КонтактнаяИнформацияСервер.ПриСозданииНаСервере(ЭтаФорма);
	ВерсионированиеОбъектов.ПриСозданииНаСервере(ЭтаФорма);
КонецПроцедуры


&НаСервере
Процедура ПередЗаписьюНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	
	ТекстЗаписиИНН = ОбновитьИННОбособленныхОрганизаций();

	Если НЕ ПустаяСтрока(ТекстЗаписиИНН) Тогда

		Сообщить(ТекстЗаписиИНН + Символы.ПС + "Элемент не записан!");
		Отказ = Истина;
		Возврат;

	КонецЕсли;
	
	//СпасМодифицированность = Модифицированность;
		
	Если Объект.ЮрФизЛицо = Перечисления.ЮрФизЛицо.ФизЛицо И НЕ ОбщегоНазначения.ЗначениеНеЗаполнено(Объект.ИндивидуальныйПредприниматель) Тогда
		Объект.ИНН = Объект.ИндивидуальныйПредприниматель.ИНН;
	КонецЕсли;
	
	Если Объект.ЮрФизЛицо = Перечисления.ЮрФизЛицо.ФизЛицо Тогда
		Объект.КодОКОНХ = "";
		Объект.КодОКПО = "";
		Объект.ГоловнаяОрганизация = Неопределено;
		Объект.КПП = "";
	ИначеЕсли Объект.ЮрФизЛицо = Перечисления.ЮрФизЛицо.ЮрЛицо Тогда
		Объект.ИндивидуальныйПредприниматель = Неопределено;
	КонецЕсли;

	//Модифицированность = СпасМодифицированность;   очень странно
	//Если Модифицированность() Тогда
	//	Записать();
	//КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ПриЗаписиНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	
		
	ЗаписатьНаборыЗаписейНаСервере(Отказ, ТекущийОбъект);
	ЗаписатьПраваДоступаКОбъекту(Отказ);
	КонтактнаяИнформацияСервер.ПриЗаписиНаСервере(ЭтаФорма, ТекущийОбъект, Отказ);

КонецПроцедуры

&НаСервере
Процедура ПриЧтенииНаСервере(ТекущийОбъект)
	
	ОбновитьФио();
	ПрочитатьНаборыЗаписейНаСервере(Объект);
	
	
КонецПроцедуры


