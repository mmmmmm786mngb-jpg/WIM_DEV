Функция КодАльфа2ПоНазваниюСтраны(Страна) Экспорт 
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	КлассификаторСтранМира.КодАльфа2 КАК КодАльфа2
	|ИЗ
	|	Справочник.КлассификаторСтранМира КАК КлассификаторСтранМира
	|ГДЕ
	|	КлассификаторСтранМира.Наименование = &Страна");
	
	Запрос.УстановитьПараметр("Страна",Страна);
	
	Результат = Запрос.Выполнить();
	Если Результат.Пустой() Тогда 
		Возврат "";
	КонецЕсли;
	
	Выборка = Результат.Выбрать();
	Выборка.Следующий();
	Возврат Выборка.КодАльфа2;
	
КонецФункции

