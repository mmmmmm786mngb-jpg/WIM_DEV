// Возвращает элемент справочника СправочникСсылка.КлассификаторСтранМира по двухсимвольному коду страны
// 
// Параметры:
//  КодАльфа - Строка - КодАльфа2 справочника КлассификаторСтранМира
//
// Возвращаемое значение:
//  СправочникСсылка.КлассификаторСтранМира
//
Функция СтранаПоКодуАльфа2(КодАльфа) Экспорт
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	КлассификаторСтранМира.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.КлассификаторСтранМира КАК КлассификаторСтранМира
	|ГДЕ
	|	КлассификаторСтранМира.КодАльфа2 = &КодАльфа2";
	Запрос.УстановитьПараметр("КодАльфа2", КодАльфа);
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Ссылка;
	Иначе
		Возврат Неопределено;
	КонецЕсли;
КонецФункции

// Возвращает страну эмитента
//
// Параметры:
//  Эмитент	 - СправочникСсылка.Контрагенты	 - Эмитент
// 
// Возвращаемое значение:
//   - СправочникСсылка.КлассификаторСтранМира - Страна
//
Функция СтранаЭмитента(Эмитент) Экспорт
	
	Если Не ЗначениеЗаполнено(Эмитент) Тогда
		Возврат Неопределено;
	КонецЕсли;
	ЮридическоеЛицо = Эмитент.ЮридическиеФизическиеЛица;
	Если ЗначениеЗаполнено(ЮридическоеЛицо) И ТипЗнч(ЮридическоеЛицо) = Тип("СправочникСсылка.ЮридическиеЛица") Тогда
		Возврат ЮридическоеЛицо.Страна;
	Иначе
		Возврат Неопределено;
	КонецЕсли;
	
КонецФункции