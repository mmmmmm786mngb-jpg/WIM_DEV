#Область ОбработчикиСобытий

Процедура ПриЗаписи(Отказ)
	
	Если ОбменДанными.Загрузка Тогда
		Возврат;
    КонецЕсли;
	
	Если Активность = Ложь Тогда
		РегистрыСведений.СостоянияМетрик.УдалитьЗапись(ЭтотОбъект);
	КонецЕсли;
	
КонецПроцедуры

Процедура ПередЗаписью(Отказ)
	
	Если ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли;
	
	Если НЕ ТипВычисленияМетрики = Перечисления.ТипыВычисленияМетрик.Алгоритм Тогда
		Алгоритм = "";
	КонецЕсли;
	
	Если НЕ ТипВычисленияМетрики = Перечисления.ТипыВычисленияМетрик.КлючеваяОперацияСредниеЗаПериод Тогда
		КлючеваяОперация = Неопределено;
		ПериодыВычисления.Очистить();
	КонецЕсли;
	
	ОставитьУникальныеПериоды();
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыФункции

Процедура ОставитьУникальныеПериоды()

	Таблица = ПериодыВычисления.Выгрузить();
	Таблица.Свернуть("ПериодВычисления");
	ПериодыВычисления.Загрузить(Таблица);

КонецПроцедуры

#КонецОбласти
