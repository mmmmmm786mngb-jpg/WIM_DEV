// ОБРАБОТЧИКИ СОБЫТИЙ

Процедура ЗапроситьФормуW8ПриНеобходимостиОбработка(ТочкаМаршрутаБизнесПроцесса)
	
	Если ТочкаМаршрутаБизнесПроцесса = БизнесПроцессы.ОбработкаWTRCСообщения.ТочкиМаршрута.ЗапроситьФормуW8ПриНеобходимости Тогда
		ИмяТабЧастиИсточника = "Депоненты";
	ИначеЕсли ТочкаМаршрутаБизнесПроцесса = БизнесПроцессы.ОбработкаWTRCСообщения.ТочкиМаршрута.ДозапроситьФормуW8ПриНеобходимостиПослеФиксации Тогда
		ИмяТабЧастиИсточника = "ДепонентыПослеФиксации";
	КонецЕсли;
	
	Если НЕ РезультатЗапросаФормыW8(ДепонентыБезФормыW8(ИмяТабЧастиИсточника)) Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(
		"Необходимо исправить ошибки и стартовать бизнес-процесс еще раз.");
		Стартован = Ложь;
	КонецЕсли;
	
КонецПроцедуры

Процедура ОбработкаWTRCСообщенияПриСозданииЗадач(ТочкаМаршрутаБизнесПроцесса, ФормируемыеЗадачи, Отказ)
	
	ОставитьОднуЗадачу(ФормируемыеЗадачи, ТочкаМаршрутаБизнесПроцесса);	
	Задача = ФормируемыеЗадачи[0];
	
	Если ТочкаМаршрутаБизнесПроцесса = БизнесПроцессы.ОбработкаWTRCСообщения.ТочкиМаршрута.ОбработкаWTRCСообщения
		ИЛИ ТочкаМаршрутаБизнесПроцесса = БизнесПроцессы.ОбработкаWTRCСообщения.ТочкиМаршрута.ФормированиеУведомленияОКД Тогда
		ИмяТабЧастиИсточника = "Депоненты";
	ИначеЕсли ТочкаМаршрутаБизнесПроцесса = БизнесПроцессы.ОбработкаWTRCСообщения.ТочкиМаршрута.ДопФормированиеУведомленияОКДПослеФиксации Тогда
		ИмяТабЧастиИсточника = "ДепонентыПослеФиксации";
	КонецЕсли;
	ЗаполнитьТаблицуДепонентовЗадачи(Задача, ИмяТабЧастиИсточника);
	
КонецПроцедуры

/////////////////////////////////////////////////////////////
// ФУНКЦИИ РАБОТЫ С ЗАДАЧАМИ

Процедура ОставитьОднуЗадачу(ФормируемыеЗадачи, ТочкаМаршрутаБизнесПроцесса)
	Если ФормируемыеЗадачи.Количество() = 0 Тогда
		НоваяЗадача = Задачи.ОбработкаWTRCСообщения.СоздатьЗадачу();
		НоваяЗадача.УстановитьНовыйНомер();
		НоваяЗадача.Дата = ТекущаяДата();
		НоваяЗадача.БизнесПроцесс = ЭтотОбъект.Ссылка;
		НоваяЗадача.ТочкаМаршрута = ТочкаМаршрутаБизнесПроцесса;
		ФормируемыеЗадачи.Добавить(НоваяЗадача);
		
	ИначеЕсли ФормируемыеЗадачи.Количество() > 1 Тогда
		Для н = 1 По ФормируемыеЗадачи.Количество()-1 Цикл
			ФормируемыеЗадачи.Удалить(1);
		КонецЦикла;
	КонецЕсли;
КонецПроцедуры

Процедура ЗаполнитьТаблицуДепонентовЗадачи(Задача, ИмяТабЧастиИсточника)
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Депоненты.Депонент КАК Депонент,
	|	ЛОЖЬ КАК ОтправленоУведомлениеККОПеремещенииНаНалоговыйРаздел,
	|	ЛОЖЬ КАК ЦБНаНалоговомРазделе,
	|	Депоненты.ЕстьУсловноеДлящеесяПоручение КАК ЕстьУсловноеДлящеесяПоручение
	|ИЗ
	|	БизнесПроцесс.ОбработкаWTRCСообщения.Депоненты КАК Депоненты
	|ГДЕ
	|	Депоненты.Ссылка = &БизнесПроцессWTRC");
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "БизнесПроцесс.ОбработкаWTRCСообщения.Депоненты",
	"БизнесПроцесс.ОбработкаWTRCСообщения." + ИмяТабЧастиИсточника);
	Запрос.УстановитьПараметр("БизнесПроцессWTRC", Ссылка);
	Задача.Депоненты.Загрузить(Запрос.Выполнить().Выгрузить());
КонецПроцедуры

/////////////////////////////////////////////////////////////
// ФУНКЦИИ ОТПРАВКИ ЗАПРОСА НА ФОРМУ W8 ДЕПОНЕНТУ

Функция ДепонентыБезФормыW8(ИмяТабЧастиИсточника = "Депоненты")
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Депоненты.Депонент КАК Депонент,
	|	КодыЗагрузкиКлиента.Код КАК КодЗагрузки,
	|	"""" КАК КодСубклиента
	|ИЗ
	|	БизнесПроцесс.ОбработкаWTRCСообщения.Депоненты КАК Депоненты
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.КодыЗагрузки КАК КодыЗагрузкиКлиента
	|		ПО Депоненты.Депонент = КодыЗагрузкиКлиента.Владелец
	|			И (НЕ КодыЗагрузкиКлиента.ПометкаУдаления)
	|			И (КодыЗагрузкиКлиента.Биржа = &КлассификаторыЗагрузкиКлиенты)
	|ГДЕ
	|	НЕ Депоненты.ЕстьФормаW8BENE_W8BEN
	|	И Депоненты.Ссылка = &БизнесПроцессWTRC
	|	И НЕ Депоненты.Депонент.Субброкер
	|
	|СГРУППИРОВАТЬ ПО
	|	Депоненты.Депонент,
	|	КодыЗагрузкиКлиента.Код
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Депоненты.Депонент,
	|	КодыЗагрузкиКлиента.Код,
	|	Депоненты.РазделСчета.Субклиент.Код
	|ИЗ
	|	БизнесПроцесс.ОбработкаWTRCСообщения.Депоненты КАК Депоненты
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.КодыЗагрузки КАК КодыЗагрузкиКлиента
	|		ПО Депоненты.Депонент = КодыЗагрузкиКлиента.Владелец
	|			И (НЕ КодыЗагрузкиКлиента.ПометкаУдаления)
	|			И (КодыЗагрузкиКлиента.Биржа = &КлассификаторыЗагрузкиКлиенты)
	|ГДЕ
	|	НЕ Депоненты.ЕстьФормаW8BENE_W8BEN
	|	И Депоненты.Ссылка = &БизнесПроцессWTRC
	|	И Депоненты.Депонент.Субброкер
	|
	|СГРУППИРОВАТЬ ПО
	|	Депоненты.Депонент,
	|	КодыЗагрузкиКлиента.Код,
	|	Депоненты.РазделСчета.Субклиент.Код
	|ИТОГИ
	|	МАКСИМУМ(КодЗагрузки)
	|ПО
	|	Депонент");
	
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "БизнесПроцесс.ОбработкаWTRCСообщения.Депоненты",
	"БизнесПроцесс.ОбработкаWTRCСообщения." + ИмяТабЧастиИсточника);
	Запрос.УстановитьПараметр("КлассификаторыЗагрузкиКлиенты", Справочники.КлассификаторыЗагрузки.Клиенты);
	Запрос.УстановитьПараметр("БизнесПроцессWTRC", Ссылка);
	
	ДепонентыБезФорм = Новый ТаблицаЗначений;
	ДепонентыБезФорм.Колонки.Добавить("Депонент");
	ДепонентыБезФорм.Колонки.Добавить("КодЗагрузки");
	ДепонентыБезФорм.Колонки.Добавить("КодыСубклиентов", Новый ОписаниеТипов("Строка"));
	
	ВыборкаПоДепонентам = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Пока ВыборкаПоДепонентам.Следующий() Цикл
		НоваяСтрока = ДепонентыБезФорм.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, ВыборкаПоДепонентам);
		Выборка = ВыборкаПоДепонентам.Выбрать();
		Пока Выборка.Следующий() Цикл
			НоваяСтрока.КодыСубклиентов = НоваяСтрока.КодыСубклиентов
			+ ?(ЗначениеЗаполнено(НоваяСтрока.КодыСубклиентов), ", ", "") + Выборка.КодСубклиента;
		КонецЦикла;
		
	КонецЦикла;
	
	Возврат ДепонентыБезФорм;
	
КонецФункции

Функция РезультатЗапросаФормыW8(СписокДепонентов)
	Если СписокДепонентов.Количество() = 0 Тогда
		Возврат Истина;
	КонецЕсли;
	
	Содержание = СодержаниеЗапросаФормыW8();
	Если Содержание = Неопределено Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Для Каждого Строка Из СписокДепонентов Цикл
		Если ЗначениеЗаполнено(Строка.КодыСубклиентов) Тогда
			Текст = СтрЗаменить(Содержание.Текст, "%C", Символы.ПС + "<p>Список клиентов без формы: " + Строка.КодыСубклиентов + ".</p>");
		Иначе
			Текст = СтрЗаменить(Содержание.Текст, "%C", "");
		КонецЕсли;
		
		Удачно = РезультатОтправкиСообщенияПоЭлПочтеЧерезWebСервис(Строка.КодЗагрузки, Содержание.Тема,
		Текст);
		Если Удачно Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Отправлен запрос по email на форму W8 "
			+ "депоненту " + Строка.Депонент);
		Иначе
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не удалось отправить запрос по email на форму W8 "
			+ "депоненту " + Строка.Депонент);
			Возврат Ложь;
		КонецЕсли;
	КонецЦикла;
	
	Возврат Истина;
КонецФункции

Функция СодержаниеЗапросаФормыW8()
	// {Обязательный блок}
	Текст =
	"<p>#Hello#</p>
	|<p>Уведомляем Вас о том, что в Депозитарий %1 поступила информация о проведении корпоративного действия
	|""%2"" - %3 (%4, Референс КД %5).</p>
	|<p>Дата КД (план.): %6</p>
	|<p>Дата фиксации: %7</p>
	|<p>Для участия в КД необходимо предоставить форму W-8BEN для физических лиц или W-8BENE для 
	|юридических лиц и поручение на прием формы в обработку по форме Приложения 1.10 к РДО.
	|Последний срок подачи документов в %1: %8</p>%C
	|%B";
	
	ВидКД = Справочники.ВидыКорпоративныхДействий.НайтиПоКоду("WTRC");
	Если НЕ ЗначениеЗаполнено(ВидКД) Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не найден вид КД с кодом ""WTRC""");
		Возврат Неопределено;
	КонецЕсли;
	
	Текст = СтрЗаменить(Текст, "%1", СокрЛП(мОрганизация.Наименование));
	Текст = СтрЗаменить(Текст, "%2", СокрЛП(ВидКД.Наименование));
	Текст = СтрЗаменить(Текст, "%3", Справочники.ЦенныеБумаги.НаименованиеЭмитента(ЦеннаяБумага1));
	Текст = СтрЗаменить(Текст, "%4", Документы.УведомлениеКлиентам.ХарактеристикиЦБ(ЦеннаяБумага1, ЦеннаяБумага2));
	Текст = СтрЗаменить(Текст, "%5", СокрЛП(КДРеференс));
	Текст = СтрЗаменить(Текст, "%6", ФорматДаты(ДатаКДПлан));
	Текст = СтрЗаменить(Текст, "%7", ФорматДаты(ДатаФиксации));
	Текст = СтрЗаменить(Текст, "%8", ФорматДаты(Документы.УведомлениеКлиентам.ДобавитьРабочийДень(ДатаКДПлан, -14)));
	Текст = СтрЗаменить(Текст, "%B", Документы.УведомлениеКлиентам.ПодписьСообщения(Дата));
	
	Содержание = Новый Структура;
	Содержание.Вставить("Тема", "Поступила информация о проведении корпоративного действия - подтверждение "
	+ "освобождения от налога");
	Содержание.Вставить("Текст", Текст);
	
	Возврат Содержание;
КонецФункции

// Вызываемый метод Web-сервиса производит отправку произвольного текста на email клиента
//
// Параметры:
//	КлиентИд - Идентификатор клиента, которому необходимо отправить email
//	Тема - Тема письма
//	Текст - Текст письма
//
// Возвращаемое значение:
//	Истина, если отправка успешна, иначе Ложь
//
Функция РезультатОтправкиСообщенияПоЭлПочтеЧерезWebСервис(КлиентИд, Тема, Текст)
	ИдентификаторыКлиентов = Новый Массив;
	ИдентификаторыКлиентов.Добавить(СокрЛП(КлиентИд));
	
	ОпубликованоУспешно = ВебСервисыСервер.РезультатОтправкиИнформационногоПисьмаКлиентам(ИдентификаторыКлиентов, Тема, Текст);
	
	Возврат ОпубликованоУспешно;
КонецФункции

Функция ФорматДаты(Д)
	Возврат	Формат(Д, "ДЛФ=Д");
КонецФункции

Процедура ИспользоватьСхемуУведомленийWTRC_QIПроверкаУсловия(ТочкаМаршрутаБизнесПроцесса, Результат)
	
	Результат = WTRCСообщенияQI.ИспользоватьСхемуУведомленийWTRC_QI(ЭтотОбъект.Дата);
	
КонецПроцедуры

Процедура ЦБПопадаетПодНалоговоеРегулированиеСШАПроверкаУсловия(ТочкаМаршрутаБизнесПроцесса, Результат)
	
	Если Не ЗначениеЗаполнено(ЦеннаяБумага2) Тогда 
		Результат = Справочники.ЦенныеБумаги.ЦБПодпадаетПодНалоговоеРегулированиеСША(ЦеннаяБумага1)
	ИначеЕсли Справочники.ЦенныеБумаги.ЦБПодпадаетПодНалоговоеРегулированиеСША(ЦеннаяБумага1) = Истина 
		И Справочники.ЦенныеБумаги.ЦБПодпадаетПодНалоговоеРегулированиеСША(ЦеннаяБумага2) = Истина Тогда 
		Результат = Истина;
	Иначе
		Комментарий = "Режим налогового регулирования США для Ценной бумаги 1 и Ценной бумаги 2, отличаються!";
		Завершен = Истина;
	КонецЕсли;
	
КонецПроцедуры

Процедура ПриКопировании(ОбъектКопирования)
	
	ВыполненаПроверкаОстатков = Ложь;
	Для Каждого Строка Из Депоненты Цикл 
		Строка.ЕстьФормаW8BENE_W8BEN = Ложь;
		Строка.УведомлениеW8 = Перечисления.СтатусыЗавершенияБПОбработкаWTRCСообщения.ПустаяСсылка();
		Строка.Уведомление1_10 = Перечисления.СтатусыЗавершенияБПОбработкаWTRCСообщения.ПустаяСсылка();
		Строка.ЗапросНаРаскрытие = Перечисления.СтатусыЗавершенияБПОбработкаWTRCСообщения.ПустаяСсылка();	
	КонецЦикла;
	
КонецПроцедуры

Процедура ИспользоватьСхемуУсловногоДлящегосяПоручения_ПроверкаУсловия(ТочкаМаршрутаБизнесПроцесса, Результат)
	
	Результат = ЭтотОбъект.ИспользоватьСхемуУсловногоДлящегосяПоручения;
	
КонецПроцедуры

Процедура ДатаФиксацииБольшеДатыСообщения_ПроверкаУсловия(ТочкаМаршрутаБизнесПроцесса, Результат)
	
	ДатаФиксацииСоВременем = ЭтотОбъект.ДатаФиксации;
	ОбщегоНазначения.СкопироватьВремя(ДатаФиксацииСоВременем, '00010101190000');
	Результат = ДатаФиксацииСоВременем > ЭтотОбъект.ДатаСообщения;
	
КонецПроцедуры

Процедура ИспользоватьСхемуУведомленийWTRC_QI_НеАмериканскихЦБПроверкаУсловия(ТочкаМаршрутаБизнесПроцесса, Результат)
	
	Результат = WTRCСообщенияQI.ИспользоватьСхемуУведомленийWTRC_QI(ЭтотОбъект.Дата);
	
КонецПроцедуры

// Процедура - Обновить статусы отправки запросов субброкера
// Обновляет в табличной части статусы отправки запросов субброкера на раскрытие
Процедура ОбновитьСтатусыОтправкиЗапросовСубброкера() Экспорт
	
	Если WTRCСообщенияQI.ИспользоватьРегистрациюЗапросовСубброкераДляДокумента(КД) 
		И WTRCСообщенияQI.ИспользоватьСхемуУведомленийWTRC_QIДляДокумента(КД) Тогда 
		
		Запрос = Новый Запрос(
		"ВЫБРАТЬ
		|	ЗапросСубброкеруНаРаскрытие.Клиент КАК Депонент,
		|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ЗапросСубброкеруНаРаскрытие.Ссылка) КАК Ссылка
		|ИЗ
		|	Документ.ЗапросСубброкеруНаРаскрытие КАК ЗапросСубброкеруНаРаскрытие
		|ГДЕ
		|	ЗапросСубброкеруНаРаскрытие.Статус В(&СтатусыОтправленныеУведомления)
		|	И ЗапросСубброкеруНаРаскрытие.КД = &КД
		|
		|СГРУППИРОВАТЬ ПО
		|	ЗапросСубброкеруНаРаскрытие.Клиент");
		
		СтатусыОтправленныеУведомления = Новый Массив();
		СтатусыОтправленныеУведомления.Добавить(Перечисления.СтатусыДокументаЗапросСубброкеруНаРаскрытие.Отправлен);
		СтатусыОтправленныеУведомления.Добавить(Перечисления.СтатусыДокументаЗапросСубброкеруНаРаскрытие.ОтправленПовторно);
		СтатусыОтправленныеУведомления.Добавить(Перечисления.СтатусыДокументаЗапросСубброкеруНаРаскрытие.ПолученОтвет);
		Запрос.УстановитьПараметр("СтатусыОтправленныеУведомления", СтатусыОтправленныеУведомления);
		Запрос.УстановитьПараметр("КД", КД);
		Результат = Запрос.Выполнить();
		Если Результат.Пустой() Тогда 
			Возврат;	
		КонецЕсли;
		
		Выборка = Результат.Выбрать();
		Пока Выборка.Следующий() Цикл 
			СтрокиДепонента = Депоненты.НайтиСтроки(Новый Структура("Депонент",Выборка.Депонент));
			Для Каждого СтрокаДепонента Из СтрокиДепонента Цикл 
				СтрокаДепонента.ЗапросНаРаскрытие = Перечисления.СтатусыЗавершенияБПОбработкаWTRCСообщения.Отправлено;		
			КонецЦикла;
		КонецЦикла;
		
		Документы.РаскрытиеСпискаВладельцев.ДополнитьСписокВладельцевЗапросамиСубброкера(КД);
		
	КонецЕсли;
	
КонецПроцедуры

