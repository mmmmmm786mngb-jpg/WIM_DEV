// ИНТЕРФЕЙС
Процедура ЗаполнитьТаблицуДепонентов(ИмяТабЧасти = "Депоненты") Экспорт
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Остатки.ЦБ КАК ЦеннаяБумага,
	|	Остатки.СчетДепо.Владелец КАК Депонент,
	|	Остатки.РазделСчетаДепо КАК РазделСчета,
	|	СУММА(Остатки.КоличествоОстаток) КАК Количество
	|ПОМЕСТИТЬ втОстатки
	|ИЗ
	|	РегистрНакопления.ОстаткиЦБМестоРасчетов.Остатки(
	|			&ДатаОстатков,
	|			ЦБ В (&МассивЦенныхБумаг)
	|				И СчетДепоМХ = &СчетДепоМХ) КАК Остатки
	|
	|СГРУППИРОВАТЬ ПО
	|	Остатки.ЦБ,
	|	Остатки.СчетДепо.Владелец,
	|	Остатки.РазделСчетаДепо
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ФормаW8.Депонент КАК Депонент,
	|	ИСТИНА КАК ЕстьФормаW8
	|ПОМЕСТИТЬ втФормаW8
	|ИЗ
	|	РегистрСведений.ПредоставленныеДокументы.СрезПоследних(
	|			&ДатаОстатков,
	|			ВидДокумента = &ФормаW8
	|				И (СрокДействия = ДАТАВРЕМЯ(1, 1, 1)
	|					ИЛИ СрокДействия >= НАЧАЛОПЕРИОДА(&ДатаОстатков, ДЕНЬ))) КАК ФормаW8
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	УсловноеДлящеесяПоручение.Депонент КАК Депонент,
	|	ИСТИНА КАК ЕстьУДП
	|ПОМЕСТИТЬ втУсловноеДлящеесяПоручение
	|ИЗ
	|	РегистрСведений.ПредоставленныеДокументы.СрезПоследних(
	|			&ДатаОстатков,
	|			ВидДокумента = &УсловноеДлящеесяПоручение
	|				И (СрокДействия = ДАТАВРЕМЯ(1, 1, 1)
	|					ИЛИ СрокДействия >= НАЧАЛОПЕРИОДА(&ДатаОстатков, ДЕНЬ))) КАК УсловноеДлящеесяПоручение
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Остатки.Депонент КАК Депонент,
	|	МАКСИМУМ(Разделы.Ссылка) КАК РазделСчетаПолучатель
	|ПОМЕСТИТЬ втНалоговыеРазделыПолучатели
	|ИЗ
	|	Справочник.РазделыСчетаДепо КАК Разделы
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ втОстатки КАК Остатки
	|		ПО (Остатки.Депонент = Разделы.Владелец.Владелец)
	|ГДЕ
	|	Разделы.ТипРазделаСчетаДЕПО = &Налоговый
	|	И НЕ Разделы.ПометкаУдаления
	|	И НЕ Остатки.Депонент.Субброкер
	|
	|СГРУППИРОВАТЬ ПО
	|	Остатки.Депонент
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	Остатки.РазделСчета.Субклиент,
	|	МАКСИМУМ(Разделы.Ссылка)
	|ИЗ
	|	втОстатки КАК Остатки
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.РазделыСчетаДепо КАК Разделы
	|		ПО Остатки.Депонент = Разделы.Владелец.Владелец
	|			И Остатки.РазделСчета.Субклиент = Разделы.Ссылка.Субклиент
	|ГДЕ
	|	Разделы.ТипРазделаСчетаДЕПО = &Налоговый
	|	И НЕ Разделы.ПометкаУдаления
	|	И Остатки.Депонент.Субброкер
	|
	|СГРУППИРОВАТЬ ПО
	|	Остатки.РазделСчета.Субклиент
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Остатки.ЦеннаяБумага КАК ЦеннаяБумага,
	|	Остатки.Депонент КАК Депонент,
	|	Остатки.РазделСчета КАК РазделСчета,
	|	Остатки.Количество КАК Количество,
	|	ЕСТЬNULL(ФормаW8.ЕстьФормаW8, ЛОЖЬ) КАК ЕстьФормаW8BENE_W8BEN,
	|	ЕСТЬNULL(УсловноеДлящеесяПоручение.ЕстьУДП, ЛОЖЬ) КАК ЕстьУсловноеДлящеесяПоручение,
	|	НалоговыеРазделы.РазделСчетаПолучатель КАК РазделСчетаПолучатель,
	|	Остатки.ЦеннаяБумага.Наименование КАК ЦеннаяБумагаНаименование,
	|	Остатки.Депонент.Наименование КАК ДепонентНаименование,
	|	Остатки.РазделСчета.Наименование КАК РазделСчетаНаименование
	|ИЗ
	|	втОстатки КАК Остатки
	|		ЛЕВОЕ СОЕДИНЕНИЕ втФормаW8 КАК ФормаW8
	|		ПО Остатки.Депонент = ФормаW8.Депонент
	|		ЛЕВОЕ СОЕДИНЕНИЕ втУсловноеДлящеесяПоручение КАК УсловноеДлящеесяПоручение
	|		ПО Остатки.Депонент = УсловноеДлящеесяПоручение.Депонент
	|		ЛЕВОЕ СОЕДИНЕНИЕ втНалоговыеРазделыПолучатели КАК НалоговыеРазделы
	|		ПО Остатки.Депонент = НалоговыеРазделы.Депонент
	|ГДЕ
	|	НЕ Остатки.Депонент.Субброкер
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	Остатки.ЦеннаяБумага,
	|	Остатки.Депонент,
	|	Остатки.РазделСчета,
	|	Остатки.Количество,
	|	ЕСТЬNULL(ФормаW8.ЕстьФормаW8, ЛОЖЬ),
	|	ЕСТЬNULL(УсловноеДлящеесяПоручение.ЕстьУДП, ЛОЖЬ),
	|	НалоговыеРазделы.РазделСчетаПолучатель,
	|	Остатки.ЦеннаяБумага.Наименование,
	|	Остатки.Депонент.Наименование,
	|	Остатки.РазделСчета.Наименование
	|ИЗ
	|	втОстатки КАК Остатки
	|		ЛЕВОЕ СОЕДИНЕНИЕ втФормаW8 КАК ФормаW8
	|		ПО Остатки.РазделСчета.Субклиент = ФормаW8.Депонент
	|		ЛЕВОЕ СОЕДИНЕНИЕ втУсловноеДлящеесяПоручение КАК УсловноеДлящеесяПоручение
	|		ПО Остатки.РазделСчета.Субклиент = УсловноеДлящеесяПоручение.Депонент
	|		ЛЕВОЕ СОЕДИНЕНИЕ втНалоговыеРазделыПолучатели КАК НалоговыеРазделы
	|		ПО Остатки.РазделСчета.Субклиент = НалоговыеРазделы.Депонент
	|ГДЕ
	|	Остатки.Депонент.Субброкер
	|
	|УПОРЯДОЧИТЬ ПО
	|	ЦеннаяБумагаНаименование,
	|	ДепонентНаименование,
	|	РазделСчетаНаименование";
	
	МассивЦенныхБумаг = Новый Массив;
	Если ЗначениеЗаполнено(ЦеннаяБумага1) Тогда
		МассивЦенныхБумаг.Добавить(ЦеннаяБумага1);
	КонецЕсли;
	Если ЗначениеЗаполнено(ЦеннаяБумага2) Тогда
		МассивЦенныхБумаг.Добавить(ЦеннаяБумага2);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ДатаФиксации) Тогда
		ДатаОстатков = КонецДня(ДатаФиксации);
	Иначе
		ДатаОстатков = Дата;
	КонецЕсли;
	Запрос.УстановитьПараметр("ДатаОстатков",		ДатаОстатков);
	Запрос.УстановитьПараметр("МассивЦенныхБумаг",	МассивЦенныхБумаг);
	Запрос.УстановитьПараметр("Налоговый",			Перечисления.ТипыРазделовСчетовДЕПО.Налоговый);
	Запрос.УстановитьПараметр("ФормаW8", Справочники.ВидыДокументовУдостоверяющихПолномочия.ФормаW8BENE_W8BEN);
	Запрос.УстановитьПараметр("УсловноеДлящеесяПоручение", Справочники.ВидыДокументовУдостоверяющихПолномочия.УсловноеДлящеесяПоручение);
	Запрос.УстановитьПараметр("СчетДепоМХ",			СчетДепоМХ);	
	
	ЭтотОбъект[ИмяТабЧасти].Загрузить(Запрос.Выполнить().Выгрузить());
КонецПроцедуры

