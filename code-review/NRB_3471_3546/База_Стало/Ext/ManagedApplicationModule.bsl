#Область ОписаниеПеременных

// СтандартныеПодсистемы

// Хранилище глобальных переменных.
//
// ПараметрыПриложения - Соответствие - хранилище переменных, где:
//   * Ключ - Строка - имя переменной в формате "ИмяБиблиотеки.ИмяПеременной";
//   * Значение - Произвольный - значение переменной.
//
// Инициализация (на примере СообщенияДляЖурналаРегистрации):
//   ИмяПараметра = "СтандартныеПодсистемы.СообщенияДляЖурналаРегистрации";
//   Если ПараметрыПриложения[ИмяПараметра] = Неопределено Тогда
//     ПараметрыПриложения.Вставить(ИмяПараметра, Новый СписокЗначений);
//   КонецЕсли;
//  
// Использование (на примере СообщенияДляЖурналаРегистрации):
//   ПараметрыПриложения["СтандартныеПодсистемы.СообщенияДляЖурналаРегистрации"].Добавить(...);
//   ПараметрыПриложения["СтандартныеПодсистемы.СообщенияДляЖурналаРегистрации"] = ...;
Перем ПараметрыПриложения Экспорт;

// Конец СтандартныеПодсистемы

// СписокЗначений для накапливания пакета сообщений в журнал регистрации, 
// формируемых в клиентской бизнес-логике.
Перем СообщенияДляЖурналаРегистрации Экспорт; 

// Структура, содержащая в себе время начала и окончания обновления программы.
Перем ПараметрыРаботыКлиентаПриОбновлении Экспорт;

#КонецОбласти

// Выполнить стандартные действия перед началом работы пользователя
//
Процедура ПередНачаломРаботыСистемы(Отказ)
	
	Если ПараметрыПриложения = Неопределено Тогда
		ПараметрыПриложения = Новый Соответствие;
	КонецЕсли;

КонецПроцедуры

Процедура ПриНачалеРаботыСистемы()
	
	ОбщегоНазначенияКлиент.УстановитьПроизвольныйЗаголовокПриложения();
	
	ЭтоТестоваяБаза = Привилегированный.ЭтоТестоваяБаза();
	ПараметрыЗапуска = СтроковыеФункцииКлиентСервер.ПараметрыИзСтроки(ПараметрЗапуска);
	
	ПутьКНастройкамОбезличивания = Неопределено;
	КлючевоеСловоDepersonalization = "Depersonalization";
	Если ЭтоТестоваяБаза И
		ПараметрыЗапуска.Свойство(КлючевоеСловоDepersonalization, ПутьКНастройкамОбезличивания) И ЗначениеЗаполнено(ПутьКНастройкамОбезличивания) Тогда
		
		Параметры = Новый Структура;
		Параметры.Вставить(КлючевоеСловоDepersonalization, Истина);
		Параметры.Вставить("ПутьКНастройкамОбезличивания", ПутьКНастройкамОбезличивания);
		
		ИмяПараметраИзменятьДвиженияЦенныхБумаг = "ИзменятьДвиженияЦенныхБумаг";
		ПараметрИзменятьДвиженияЦенныхБумаг = Истина;
		Если ПараметрыЗапуска.Свойство(ИмяПараметраИзменятьДвиженияЦенныхБумаг	, ПараметрИзменятьДвиженияЦенныхБумаг) Тогда
			Параметры.Вставить(ИмяПараметраИзменятьДвиженияЦенныхБумаг	, ПараметрИзменятьДвиженияЦенныхБумаг);
		Иначе
			Параметры.Вставить(ИмяПараметраИзменятьДвиженияЦенныхБумаг	, Истина);
		КонецЕсли;
		
		ОткрытьФорму("Обработка.СкрытиеКонфиденциальнойИнформации.Форма.Форма", Параметры);
		
	КонецЕсли;
	
КонецПроцедуры


