//#Область ОбработчикиКомандФормы 
&НаКлиенте
Процедура Выбрать(Команда)
	ТекущиеДанные = Элементы.СписокВыбораПечатнойФормы.ТекущиеДанные;
	
	Если ТекущиеДанные = Неопределено Тогда
		
		Предупреждение("Не выбран макет");
		
	Иначе
		
		Закрыть(ТекущиеДанные.Значение);
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура Очистить(Команда)
	Закрыть("");
КонецПроцедуры
//#КонецОбласти