
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	Если Объект.Ссылка.Пустая() Тогда
		Объект.Дата							= ТекущаяДата();
		Объект.Инициатор					= Константы.ОрганизацияПоУмолчанию.Получить();
		Объект.ВидКорпоративногоДействия	= Справочники.ВидыКорпоративныхДействий.НайтиПоКоду("TEND");
		Объект.Автор						= ПараметрыСеанса.ТекущийПользователь;
		Если Объект.МестоХранения.Пустая() Тогда
			Объект.МестоХранения			= Константы.МестоХраненияПоУмолчанию.Получить();
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура ПриЧтенииНаСервере(ТекущийОбъект)
	Оболочки.ПриЧтенииНаСервереДокумента(ЭтотОбъект, ТекущийОбъект);
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьДанныеБлокировкиСервер()
	Документ	= РеквизитФормыВЗначение("Объект");
	Документ.ЗаполнитьДанныеБлокировки();
	ЗначениеВРеквизитФормы(Документ, "Объект");
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьДанныеБлокировки(Команда)
	ЗаполнитьДанныеБлокировкиСервер();
КонецПроцедуры

&НаКлиенте
Процедура ЦеннаяБумагаПриИзменении(Элемент)
	Если Объект.Ссылка.Пустая() Тогда
		Объект.СписокДанныхБлокировки.Очистить();
	Иначе 
		ОбъектСсылкаЦеннаяБумага = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.Ссылка, "ЦеннаяБумага");
		Если Не ОбъектСсылкаЦеннаяБумага = Объект.ЦеннаяБумага Тогда
			Объект.СписокДанныхБлокировки.Очистить();
		КонецЕсли;	
	КонецЕсли;
КонецПроцедуры

