
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
 	Отказ = ?(Объект.Проверка, Истина, Отказ);
	 
	 Если Объект.Ссылка.Пустая() Тогда 
		 
		ЗаполнитьШапкуДокументаСервер();
		ЗаполнитьТарифныйПлан();		
	КонецЕсли;
	
	// СтандартныеПодсистемы.ВерсионированиеОбъектов
	ВерсионированиеОбъектов.ПриСозданииНаСервере(ЭтаФорма);
	// Конец СтандартныеПодсистемы.ВерсионированиеОбъектов

КонецПроцедуры

&НаСервере
Процедура ПриЧтенииНаСервере(ТекущийОбъект)
	
	Оболочки.ПриЧтенииНаСервереДокумента(ЭтотОбъект, ТекущийОбъект);
	
КонецПроцедуры

#КонецОбласти


#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура ЗаполнитьШапкуДокументаСервер()
	ТекущийОбъект = РеквизитФормыВЗначение("Объект");
	ОбщегоНазначения.ЗаполнитьШапкуДокумента(ТекущийОбъект, ПараметрыСеанса.ТекущийПользователь, , );
	ЗначениеВРеквизитФормы(ТекущийОбъект, "Объект");
КонецПроцедуры

&НаСервере 
Процедура  ЗаполнитьТарифныйПлан()
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ТарифныеПланы.Ссылка
	|ИЗ
	|	Справочник.ТарифныеПланы КАК ТарифныеПланы
	|ГДЕ
	|	ТарифныеПланы.ОсновнойТарифныйПлан.Наименование <> &Наименование";
	Запрос.УстановитьПараметр("Наименование","");
	Результат = Запрос.Выполнить().Выбрать();
	Результат.Следующий();
	Объект.ТарифныйПлан = Результат.Ссылка;
	
КонецПроцедуры

#КонецОбласти
