
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)

	ПоручениеДляОтбора = Неопределено;
	Если Параметры.Свойство("Поручение", ПоручениеДляОтбора) Тогда
		
		Настройки = Список.КомпоновщикНастроек.Настройки;
		
		Для каждого СтрокаОтбора из Настройки.Отбор.Элементы Цикл
			Если НЕ ТипЗнч(СтрокаОтбора) = Тип("ЭлементОтбораКомпоновкиДанных") Тогда
				Продолжить;
			КонецЕсли;
			Если СтрокаОтбора.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("Основание") Тогда
				СтрокаОтбора.ПравоеЗначение = ПоручениеДляОтбора;
				СтрокаОтбора.Использование = Истина;
			ИначеЕсли СтрокаОтбора.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("Подтвержден") Тогда
				СтрокаОтбора.Использование = Ложь;
			КонецЕсли;
		КонецЦикла;
		
		Список.АвтоматическоеСохранениеПользовательскихНастроек = Ложь;
		
	КонецЕсли;
	
	Список.Параметры.УстановитьЗначениеПараметра("ВыбранныеДокументы", Новый СписокЗначений);
	АдресХранилищаВыбранныхДокументов = ПоместитьВоВременноеХранилище(Новый СписокЗначений, УникальныйИдентификатор);
	Список.КомпоновщикНастроек.Настройки.ДополнительныеСвойства.Вставить("АдресХранилищаВыбранныхДокументов", АдресХранилищаВыбранныхДокументов);

КонецПроцедуры

&НаСервереБезКонтекста
Процедура СписокПриПолученииДанныхНаСервере(ИмяЭлемента, Настройки, Строки)

	ВыбранныеДокументы = ПолучитьИзВременногоХранилища(Настройки.ДополнительныеСвойства.АдресХранилищаВыбранныхДокументов);
		
	Для Каждого СтрокаСписка Из Строки Цикл
		Если СтрокаСписка.Значение.Данные.Пометка И ВыбранныеДокументы.НайтиПоЗначению(СтрокаСписка.Ключ) = Неопределено Тогда
			ВыбранныеДокументы.Добавить(СтрокаСписка.Ключ);
		КонецЕсли;
	КонецЦикла;

	ПоместитьВоВременноеХранилище(ВыбранныеДокументы, Настройки.ДополнительныеСвойства.АдресХранилищаВыбранныхДокументов);

КонецПроцедуры

&НаКлиенте
Процедура СписокВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	Если Поле.Имя = "Пометка" Тогда
		
		ТекущиеДанные = Элементы.Список.ТекущиеДанные;
		ВыбранныеДокументы = ПолучитьИзВременногоХранилища(АдресХранилищаВыбранныхДокументов);
		Если ТекущиеДанные.Пометка Тогда
			СтрокаСписка = ВыбранныеДокументы.НайтиПоЗначению(Элементы.Список.ТекущаяСтрока);
			Если СтрокаСписка <> Неопределено Тогда
				ВыбранныеДокументы.Удалить(СтрокаСписка);
			КонецЕсли;
		Иначе
			ВыбранныеДокументы.Добавить(Элементы.Список.ТекущаяСтрока);
		КонецЕсли;	
		
		ПоместитьВоВременноеХранилище(ВыбранныеДокументы, АдресХранилищаВыбранныхДокументов);
		
		Список.Параметры.УстановитьЗначениеПараметра("ВыбранныеДокументы", ВыбранныеДокументы);
		
		СтандартнаяОбработка = Ложь;
		
	КонецЕсли;
	
КонецПроцедуры

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура УстановитьПометки(Команда)
	
	ВыбранныеДокументы = ПолучитьИзВременногоХранилища(АдресХранилищаВыбранныхДокументов);
	
	ТекущаяВидимостьСсылки = Элементы.Список.ПодчиненныеЭлементы.Ссылка.Видимость;
	Элементы.Список.ПодчиненныеЭлементы.Ссылка.Видимость = Истина;
	
	СтруктураПараметров = Новый Структура;
	ПолучитьДанныеИЗаполнитьПараметры(СтруктураПараметров);
		
	Для Каждого СтрокаСписка Из СтруктураПараметров.ВыбранныеДокументы Цикл
		
		СтрокаВыбранных = ВыбранныеДокументы.НайтиПоЗначению(СтрокаСписка.Ссылка);
		
		Если СтрокаВыбранных = Неопределено Тогда
			ВыбранныеДокументы.Добавить(СтрокаСписка.Ссылка);
		КонецЕсли;
		
	КонецЦикла;
	
	ПоместитьВоВременноеХранилище(ВыбранныеДокументы, АдресХранилищаВыбранныхДокументов);
	
	Список.Параметры.УстановитьЗначениеПараметра("ВыбранныеДокументы", ВыбранныеДокументы);
	
	Элементы.Список.ПодчиненныеЭлементы.Ссылка.Видимость = ТекущаяВидимостьСсылки;
	
КонецПроцедуры

&НаКлиенте
Процедура СнятьПометки(Команда)
	
	ВыбранныеДокументы = ПолучитьИзВременногоХранилища(АдресХранилищаВыбранныхДокументов);
	ВыбранныеДокументы.Очистить();
	ПоместитьВоВременноеХранилище(ВыбранныеДокументы, АдресХранилищаВыбранныхДокументов);
	Список.Параметры.УстановитьЗначениеПараметра("ВыбранныеДокументы", ВыбранныеДокументы);
	
КонецПроцедуры

&НаСервере
Процедура УстановитьПровереноИПровестиНаСервере(Документ, Подтвержден = Ложь)
	ДокументНачисления = Документ.ПолучитьОбъект();
	// Проверка на возможность подтверждения налога в автоматическом режиме
	РасхожденияПоПричинеНеподтвержденныхНалогов =
		Документы.НачисленныйНалог.ИнформацияОРанееНеподтвержденныхНалогах(ДокументНачисления.Ссылка);
	Если ЗначениеЗаполнено(РасхожденияПоПричинеНеподтвержденныхНалогов) Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("[ОШИБКА] Не возможно подтвердить " + Документ
		+ " так как по данному клиенту и коду дохода существует ранее не подтвержденный налог");
		Возврат;
	КонецЕсли;
	РасхожденияПоПричинеПодтвержденныхНалогов =
		Документы.НачисленныйНалог.ИнформацияОПодтвержденныхНалогахПозжеТекущего(ДокументНачисления.Ссылка);
	Если ЗначениеЗаполнено(РасхожденияПоПричинеПодтвержденныхНалогов) Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("[ОШИБКА] Не возможно подтвердить " + Документ
		+ " так как по данному клиенту и коду дохода существует подтвержденный налог (после данного документа)");
		Возврат;
	КонецЕсли;
	
	РасхожденияРасчетаНалога = Документы.НачисленныйНалог.ИнформацияОКорректностиРасчетаНалога(ДокументНачисления.Ссылка, ДокументНачисления);
	Если ЗначениеЗаполнено(РасхожденияРасчетаНалога) Тогда
		ДокументНачисления.Заполнить(Неопределено);
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("[ВНИМАНИЕ] Произведен перерасчет " + Документ
		+ " после чего произошло подтверждение налога, проверьте расчет.");
	КонецЕсли;
	ДокументНачисления.Подтвержден = Истина;
	ДокументНачисления.Записать(РежимЗаписиДокумента.Проведение);
	Подтвержден = Истина;
КонецПроцедуры

&НаКлиенте
Процедура ПодтвердитьВыбранные(Команда)
	
	Настройки = Список.КомпоновщикНастроек.Настройки;
	ВыбранныеДокументы = ПолучитьИзВременногоХранилища(АдресХранилищаВыбранныхДокументов);
	Для Каждого ВыбранныйДокумент Из ВыбранныеДокументы Цикл
		Подтвержден = Ложь;
		УстановитьПровереноИПровестиНаСервере(ВыбранныйДокумент.Значение, Подтвержден);
		Если Подтвержден Тогда
			УдалитьВыбранныйИПодтвержденныйДокументИзСписка(Настройки, ВыбранныйДокумент.Значение);
		КонецЕсли;
	КонецЦикла;
	Элементы.Список.Обновить();
	
КонецПроцедуры

&НаСервереБезКонтекста
Процедура УдалитьВыбранныйИПодтвержденныйДокументИзСписка(Настройки, Ключ)
	
	ВыбранныеДокументы = ПолучитьИзВременногоХранилища(Настройки.ДополнительныеСвойства.АдресХранилищаВыбранныхДокументов);
	ДокументКУдалению = ВыбранныеДокументы.НайтиПоЗначению(Ключ);
	Если ДокументКУдалению <> Неопределено Тогда
		ВыбранныеДокументы.Удалить(ДокументКУдалению);
	КонецЕсли;
	ПоместитьВоВременноеХранилище(ВыбранныеДокументы, Настройки.ДополнительныеСвойства.АдресХранилищаВыбранныхДокументов);
	
КонецПроцедуры

&НаСервере
Процедура ПодтвердитьВыделенныеНаСервере()

	Для Каждого ВыделеннаяСтрока Из Элементы.Список.ВыделенныеСтроки Цикл
		УстановитьПровереноИПровестиНаСервере(ВыделеннаяСтрока);
	КонецЦикла;
	
	Элементы.Список.Обновить();

КонецПроцедуры

&НаКлиенте
Процедура ПодтвердитьВыделенные(Команда)
	ПодтвердитьВыделенныеНаСервере();
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Функция ПолучитьСписокТаблицойЗначений()
	
	СКД = Элементы.Список.ПолучитьИсполняемуюСхемуКомпоновкиДанных();
	Настройки = Элементы.Список.ПолучитьИсполняемыеНастройкиКомпоновкиДанных();

	КомпоновщикМакета = Новый КомпоновщикМакетаКомпоновкиДанных();
	МакетКомпоновки = КомпоновщикМакета.Выполнить(СКД, Настройки , , , Тип("ГенераторМакетаКомпоновкиДанныхДляКоллекцииЗначений"));
	
	ПроцессорКомпоновки = Новый ПроцессорКомпоновкиДанных;
	ПроцессорКомпоновки.Инициализировать(МакетКомпоновки);
	
	ТЗ = Новый ТаблицаЗначений;
	
	ПроцессорВывода = Новый ПроцессорВыводаРезультатаКомпоновкиДанныхВКоллекциюЗначений;
	Возврат ПроцессорВывода.Вывести(ПроцессорКомпоновки);
	
КонецФункции

&НаСервере
Процедура ПолучитьДанныеИЗаполнитьПараметры(СтруктураПараметров)
	
	Результат = ПолучитьСписокТаблицойЗначений();
	
	СтруктураПараметров.Вставить("ВыбранныеДокументы", ОбщегоНазначения.ТаблицаЗначенийВМассив(Результат));
	
КонецПроцедуры

#КонецОбласти