
// Проверка на существование документа созданного на основании
// переданного через параметр.
//
// Параметры
//  Основание  – Документ.Поручение
//                 
// Возвращаемое значение:
//   Булево.Истина   – если уже есть докумнт созданный на переданном основании.
//
Функция ПроверкаНаСозданныеДокументыНаОснованииТекщего(Основание)
	
		ЗапретРедактирования   = Ложь;
	
		ЗапретРедактирования = НЕ Документы.ОтменаПредставителяСчетаДепо.НайтиПоРеквизиту("ДокументОснование",Основание).Пустая();
			
		Если ЗапретРедактирования Тогда
			
			Возврат Истина;
			
		Иначе	
			
			Возврат Ложь;
			
		КонецЕсли;
		
КонецФункции // ПроверкаНаСозданныеДокументыНаОснованииТекщего()

Процедура ОбработкаЗаполнения(Основание)
	
		
	Если ТипЗнч(Основание) = Тип("ДокументСсылка.Поручение") Тогда
		Если 	Основание.ВидОперацииД   = Справочники.ВидыОпераций.ОтзывПопечителяСчетаДепо
			ИЛИ Основание.ВидОперацииД   = Справочники.ВидыОпераций.ОтменаОператораСчетаДепо
			ИЛИ Основание.ВидОперацииД   = Справочники.ВидыОпераций.ОтменаРаспорядителяСчетаДепо Тогда
			
			//проверка на существование документов введенных на основании текущего основания.	
			Если ПроверкаНаСозданныеДокументыНаОснованииТекщего(Основание) Тогда
				
				Проверка = Истина;
				Сообщить("На основании данного поручения уже есть введенный документ!!!");
				Возврат;
				
			КонецЕсли;

			Если ЭтоНовый() Тогда
				ОбщегоНазначения.ЗаполнитьШапкуДокумента(ЭтотОбъект, ПараметрыСеанса.ТекущийПользователь, , );
			КонецЕсли;
			
			ДокументОснование 			= Основание.Ссылка;			
			ВладелецСчета 				= Основание.Инициатор;
			СчетДепо					= Основание.СчетДепо;
			ВидПредставителяСчетаДепо 	= Основание.ВидПредставителяСчетаДепо;
			ПредставительСчетаДепо		= Основание.ПредставительСчетаДепо;
			Дата						= ОбщегоНазначения.ДатаДокумента(Основание);
			
		Иначе
			Проверка = Истина;
			Сообщить("На основании данного вида поручения нельзя создать документ Отмена представителя счета депо !!!");
			Возврат;	
		КонецЕсли;
			
	КонецЕсли;
	
КонецПроцедуры

Процедура ОбработкаПроведения(Отказ, Режим)
		
	Если ОбщегоНазначения.ЗначениеНеЗаполнено(ВидПредставителяСчетаДепо) 
		ИЛИ ОбщегоНазначения.ЗначениеНеЗаполнено(ПредставительСчетаДепо) Тогда
		
		Сообщить("Не заполенен вид или не выбран представитель счета депо!");
		Отказ	=	Истина;
		
	КонецЕсли; 
	
	//проверка  ВладелецСчета.
	Если ОбщегоНазначения.ПроверкаЗаполненностиРеквизитов1(ВладелецСчета) Тогда
		
		Сообщить("Не заполнены реквизиты документа!!!");
		Отказ = Истина;
	
	КонецЕсли; 
	
	Если ВидПредставителяСчетаДепо = Перечисления.ВидыПредставителейСчетаДепо.Оператор      Тогда
		ОперацияУслуги = Справочники.ВидыОпераций.ОтменаОператораСчетаДепо; 
	ИначеЕсли ВидПредставителяСчетаДепо = Перечисления.ВидыПредставителейСчетаДепо.Попечитель Тогда 												
		ОперацияУслуги = Справочники.ВидыОпераций.ОтзывПопечителяСчетаДепо; 
	ИначеЕсли ВидПредставителяСчетаДепо = Перечисления.ВидыПредставителейСчетаДепо.Распорядитель Тогда
		ОперацияУслуги = Справочники.ВидыОпераций.ОтменаРаспорядителяСчетаДепо; 
	КонецЕсли;											
	
	РасчетныеПараметры = РасчетТарифов.РасчетСтоимостиУслуги(
							Дата,
							Справочники.ДоговорыКонтрагентов.НайтиПоКоду(Лев(СокрЛП(ДокументОснование.СчетДЕПО),7)),
							Новый Структура("Операция, МестоХранения1, МестоХранения2",ОперацияУслуги,Неопределено,Неопределено));
	Если РасчетныеПараметры <> Неопределено Тогда
		Движение = Движения.УслугиДепозитария.ДобавитьПриход();
		Движение.Период = Дата;
		Движение.Инициатор = ВладелецСчета;
		Движение.Услуга = РасчетныеПараметры.Услуга;
		Движение.СтавкаНДС = Перечисления.СтавкиНДС.НДС18_118;
		Движение.Валюта = РасчетныеПараметры.Валюта;
		Движение.Сумма = РасчетныеПараметры.Сумма;
		Движение.СуммаВВалюте = Конвертации.КонвертацияВалюты(Дата, Движение.Сумма, РасчетныеПараметры.Валюта);
		Движение.СуммаНДС = РасчетТарифов.РТ_РасчетНДС(Движение.СтавкаНДС, Движение.Сумма);
		Движение.СуммаВсего = РасчетТарифов.РТ_ОбщаяСумма(Движение.СтавкаНДС,Движение.Сумма,Движение.СуммаНДС);
		Движение.Сумма = Движение.СуммаВсего - Движение.СуммаНДС;
		Движение.ТипТарифа = РасчетныеПараметры.ТипТарифа;
		Движение.Тариф = РасчетныеПараметры.Тариф;
		Движения.УслугиДепозитария.Записать();
	КонецЕсли; 	
	
	Движение 						= Движения.ПредставителиСчетаДепо.Добавить();
	Движение.Период					= Дата;
	Движение.СчетДепо 				= СчетДепо;		  
	Движение.ВидПредставителя 		= ВидПредставителяСчетаДепо;
	Движение.Представитель 			= ПредставительСчетаДепо;
	Движение.СтатусПредставителя 	= Перечисления.СтатусыПредставителей.Отменен;
	Движения.ПредставителиСчетаДепо.Записать();
	
КонецПроцедуры

Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
    
	Если ОбменДанными.Загрузка = Истина Тогда
		Возврат;
	КонецЕсли;
	
	УстановитьновыйНомер();
КонецПроцедуры

