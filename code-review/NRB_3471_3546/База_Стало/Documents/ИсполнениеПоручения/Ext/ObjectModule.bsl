
Процедура ОбработкаПроведения(Отказ, РежимПроведения)
	
	ДвиженияПоРегиструИсполнениеПоручения(Отказ);
	ОбработкаПоручений(Отказ, РежимЗаписиДокумента.Проведение);
	
КонецПроцедуры

Процедура ОбработкаУдаленияПроведения(Отказ)
	
	ОбработкаПоручений(Отказ, РежимЗаписиДокумента.ОтменаПроведения);
	
КонецПроцедуры

Процедура ОбработкаПоручений(Отказ, РежимЗаписиИсполнения)
	
	ДатаВвода = Константы.ДатаВводаЧастичногоИсполненияИнвентарныхПоручений.Получить();
	Если НЕ ЗначениеЗаполнено(ДатаВвода) ИЛИ ДокументОснование.Дата < ДатаВвода Тогда
		Возврат;
	КонецЕсли;
	
	ТекстОшибки = РезультатОбновленияНеттоПоручения();
	Если ЗначениеЗаполнено(ТекстОшибки) Тогда
		ОбщегоНазначения.СообщитьОбОшибке(ТекстОшибки, Отказ);
		Возврат;
	КонецЕсли;
	
	ОстаткиВПорядкеЗачислениеСписание = ОстаткиЦБ.Выгрузить();
	ОстаткиВПорядкеЗачислениеСписание.Сортировать("ВидОперации");
	
	Для Каждого Строка Из ОстаткиВПорядкеЗачислениеСписание Цикл
		Если Строка.КоличествоОтчета = 0 Тогда // Поручения, обработанные в других исполнениях, пропускаем
			Продолжить;
		КонецЕсли;
		
		Поручение = Строка.Поручение.ПолучитьОбъект();
		Поручение.Исполнение = Ссылка;
		Поручение.КодОтчетаНРД = КодОтчетаВышестоящегоДепозитария;
		
		Если Строка.Статус = Перечисления.СтатусыПоручений.Исполнено Тогда
			Поручение.ДатаИсполненияПоручения				= Дата;
			Поручение.ДатаИсполненияПорученияВДепозитарииМХ	= ДатаИсполненияВДепозитарииМХ;
			Поручение.ДатаИсполненияПорученияВМестеРасчетов	= ДатаИсполненияВМестеРасчетов;
			
		ИначеЕсли Строка.Статус = Перечисления.СтатусыПоручений.ИсполненоЧастично Тогда
			Поручение.ДатаИсполненияПоручения				= '00010101';
			Поручение.ДатаИсполненияПорученияВДепозитарииМХ	= '00010101';
			Поручение.ДатаИсполненияПорученияВМестеРасчетов	= '00010101';
		КонецЕсли;
		
		Если ДополнительныеСвойства.Свойство("Комментарий") Тогда
			Поручение.Комментарий = Поручение.Комментарий + ?(ЗначениеЗаполнено(Поручение.Комментарий), " | ", "")
				+ ДополнительныеСвойства.Комментарий;
		КонецЕсли;
		
		Поручение.ДополнительныеСвойства.Вставить("РежимЗаписиИсполнения", РежимЗаписиИсполнения);
		
		Попытка
			Поручение.Записать(РежимЗаписиДокумента.Проведение);
		Исключение
			ТекстСообщения = "Не удалось провести документ " + Поручение + ". "
				+ КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
			ОбщегоНазначения.СообщитьОбОшибке(ТекстСообщения, Отказ);
			Возврат;
		КонецПопытки;
	КонецЦикла;
	
КонецПроцедуры

Функция РезультатОбновленияНеттоПоручения()
	
	НеттоПоручение = ДокументОснование.ПолучитьОбъект();
	НеттоПоручение.ДатаИсполнения = Дата;
	НеттоПоручение.КодОтчетаВышестоящегоДепозитария = КодОтчетаВышестоящегоДепозитария;
	РежимЗаписи = ?(НеттоПоручение.Проведен, РежимЗаписиДокумента.Проведение, РежимЗаписиДокумента.Запись);
	Попытка
		НеттоПоручение.Записать(РежимЗаписи);
	Исключение
		Возврат "Не удалось " + ?(НеттоПоручение.Проведен, "провести", "записать")
			+ " документ " + НеттоПоручение + ". " + КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
	КонецПопытки;
	Возврат "";
	
КонецФункции

Процедура ДвиженияПоРегиструИсполнениеПоручения(Отказ)
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ВЫБОР
	|		КОГДА ИсполнениеПорученияОстаткиЦБ.ВидОперации = &Зачисление
	|			ТОГДА ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход)
	|		КОГДА ИсполнениеПорученияОстаткиЦБ.ВидОперации = &Списание
	|			ТОГДА ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход)
	|		ИНАЧЕ НЕОПРЕДЕЛЕНО
	|	КОНЕЦ КАК ВидДвижения,
	|	ИсполнениеПорученияОстаткиЦБ.Поручение КАК Поручение,
	|	ИсполнениеПорученияОстаткиЦБ.Ссылка.Дата КАК Период,
	|	ИсполнениеПорученияОстаткиЦБ.Ссылка.ДокументОснование КАК НеттоПоручение,
	|	ИсполнениеПорученияОстаткиЦБ.КоличествоОтчета КАК Количество
	|ИЗ
	|	Документ.ИсполнениеПоручения.ОстаткиЦБ КАК ИсполнениеПорученияОстаткиЦБ
	|ГДЕ
	|	ИсполнениеПорученияОстаткиЦБ.Ссылка = &ИсполнениеПоручения";
	Запрос.УстановитьПараметр("Зачисление", Справочники.ВидыОпераций.Депонирование);
	Запрос.УстановитьПараметр("Списание", Справочники.ВидыОпераций.СнятиеСДепонирования);
	Запрос.УстановитьПараметр("ИсполнениеПоручения", Ссылка);
	Выборка = Запрос.Выполнить().Выбрать();
	Движения.ИсполнениеПоручения.Записывать = Истина;
	Пока Выборка.Следующий() Цикл
		Если Выборка.ВидДвижения = Неопределено Тогда
			ЗаписьЖурналаРегистрации("Проведение исполнения поручения", УровеньЖурналаРегистрации.Ошибка,, Ссылка,
				"Ожидается исполнение поручения с видом операции Депонирование/СнятиеСДепонирования");
			Отказ = Истина;
			Возврат;
		КонецЕсли;
		Движение = Движения.ИсполнениеПоручения.Добавить();
		ЗаполнитьЗначенияСвойств(Движение, Выборка);
	КонецЦикла;
			
КонецПроцедуры
