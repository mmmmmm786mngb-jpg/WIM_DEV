
//#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	 Отказ = ?(Объект.Проверка, Истина, Отказ);
	 
	 Если Объект.Ссылка.Пустая() Тогда 
		  
		УстановитьНомерДокументаСервер();
		ЗаполнитьШапкуДокументаСервер();
		
	КонецЕсли;
	
	Если ОбщегоНазначения.ЗначениеНеЗаполнено(Объект.ВидОтчета) Тогда
		Объект.ВидОтчета = Перечисления.ВидыОтчетов.ОтчетОбОперацияхПоСчетуДЕПО;
	КонецЕсли;
	
	ДоступностьСтраниц(ЭтаФорма);
	ОпределитьДоступныеОтчеты(ЭтаФорма);
	
	// СтандартныеПодсистемы.ВерсионированиеОбъектов
	ВерсионированиеОбъектов.ПриСозданииНаСервере(ЭтаФорма);
	// Конец СтандартныеПодсистемы.ВерсионированиеОбъектов

	
КонецПроцедуры

&НаСервере
Процедура ПриЧтенииНаСервере(ТекущийОбъект)
	Оболочки.ПриЧтенииНаСервереДокумента(ЭтотОбъект, ТекущийОбъект);
КонецПроцедуры

//#КонецОбласти

//#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ДатаПриИзменении(Элемент)
	
	УстановитьНомерДокументаСервер();

КонецПроцедуры


&НаКлиенте
Процедура ВидОтчетаПриИзменении(Элемент)
	ДоступностьСтраниц(ЭтаФорма);	
    ОпределитьДоступныеОтчеты(ЭтаФорма);
КонецПроцедуры


&НаКлиенте
Процедура ВладелецСчетаПриИзменении(Элемент)
	ДоступныеТипы = Новый Массив;
	Если ТипЗнч(Объект.ВладелецСчета) = Тип("СправочникСсылка.Контрагенты") Тогда
		ДоступныеТипы.Добавить(Тип("СправочникСсылка.СчетаДепо"));
	ИначеЕсли ТипЗнч(Объект.ВладелецСчета) = Тип("СправочникСсылка.МестаХранения") Тогда
		ДоступныеТипы.Добавить(Тип("СправочникСсылка.СчетаДепоМХ"));
	КонецЕсли;
	Элементы.СчетДепо.ОграничениеТипа = Новый ОписаниеТипов(ДоступныеТипы);
КонецПроцедуры

//#КонецОбласти


//#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура НастройкаПериода(Команда)
	
	ОписаниеОповещения = Новый ОписаниеОповещения("НастройкаПериодаЗавершение", ЭтаФорма);
	
	Диалог = Новый ДиалогРедактированияСтандартногоПериода;
	Диалог.Период.ДатаНачала = Объект.ДатаНачПериода ;
	Диалог.Период.ДатаОкончания = Объект.ДатаКонПериода; 
	Диалог.Показать(ОписаниеОповещения);
	
КонецПроцедуры


&НаКлиенте
Процедура ВыпискаПоСчетуДепо(Команда)
	
	ФормированиеВыпискиОСостоянииСчетаДЕПО();

КонецПроцедуры

&НаКлиенте
Процедура ВыпискаОперации(Команда)
	
	ФормированиеВыпискиОбОперацияхПоСчетуДЕПО();

КонецПроцедуры

&НаКлиенте
Процедура Отчет(Команда)
	
	ФормированиеОтчетаОВыполненнойОперации();

КонецПроцедуры

&НаКлиенте
Процедура СводныйОтчетОСовершеннойОперации(Команда)
	
	ФормированиеСводногоОтчетаОСовершеннойОперации();
	
КонецПроцедуры

//#КонецОбласти

//#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура ФормированиеОтчетаОВыполненнойОперации(Знач ПроверятьИсходящийНомер = Ложь) Экспорт
	Если ПроверятьИсходящийНомер Тогда
		Если ЗначениеЗаполнено(Объект.ИсходящийНомер) Тогда
			Возврат;
		КонецЕсли;
	КонецЕсли;
		
	Если ЗначениеЗаполнено(Объект.ОперацияЦБ) Тогда
		//Форма	= Отчеты.ОтчетОВыполненнойОперации_Новый.ПолучитьФорму("Форма");
		Форма = ПолучитьФорму("Отчет.ОтчетОВыполненнойОперации_Новый.Форма.ФормаОтчета");
		Форма.Отчет.Основание		= Объект.Ссылка;
		Форма.Отчет.ОперацияЦБ	= Объект.ОперацияЦБ;
		Форма.Отчет.ДатаВыписки	= Объект.Дата;
		Форма.Открыть();
		Форма.Отчет.ТипОперации	= ПолучитьИмя(Объект.ОперацияЦБ);
		Форма.ЗаполнитьОтчет();
	Иначе
		Сообщить("Не определена 'Операция ЦБ'!!!");
	КонецЕсли;
КонецПроцедуры

&НаСервереБезКонтекста
Функция ПолучитьИмя(ОперацияЦБ)
	
	Возврат ОперацияЦБ.Метаданные().Имя;
КонецФункции

&НаКлиенте
Процедура ФормированиеВыпискиОбОперацияхПоСчетуДЕПО(Знач ПроверятьИсходящийНомер = Ложь)
	Если ПроверятьИсходящийНомер Тогда
		Если ЗначениеЗаполнено(Объект.ИсходящийНомер) Тогда
			Возврат;
		КонецЕсли;
	КонецЕсли;
	
	Если ЕстьПравоФормироватьВыписку() Тогда
		
		Форма = ПолучитьФорму("Отчет.ВыпискаОбОперацияхСчетамДепо_Новая.Форма.ФормаОтчета");
		//---
		Форма.Элементы.ФормаНастройкиФормированияВыписок.Пометка	= Истина;
		Форма.Отчет.ВыпискаДокумент									= Объект.Ссылка;
		Форма.Отчет.Выписка											= Истина;
		
		Форма.Открыть();
		
		Форма.ВыпискаДокументПриИзменении();
		
		Форма.Сформировать();
		
	Иначе
		
		Возврат;
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ФормированиеСводногоОтчетаОСовершеннойОперации(Знач ПроверятьИсходящийНомер = Ложь)
	Если ПроверятьИсходящийНомер Тогда
		Если ЗначениеЗаполнено(Объект.ИсходящийНомер) Тогда
			Возврат;
		КонецЕсли;
	КонецЕсли;
	Форма = ПолучитьФорму("Обработка.ФормированиеОтчетовОСовершенныхОперациях.Форма.Форма");
	Попытка
		Форма.Объект.ИнформационнаяВыписка = Объект.Ссылка;
	Исключение
		Возврат;
	КонецПопытки;
	
	ФильтрОперацииПоВыписке = ФильтрОперацииПоВыпискеНаСервере(Объект.Ссылка);
	Форма.Объект.ДокументОперацииСводногоОтчета  = ФильтрОперацииПоВыписке.ДокументОперацииСводногоОтчета;
	Форма.Объект.ДатаОпераций					 = ФильтрОперацииПоВыписке.ДатаОпераций;
	Форма.Объект.ДатаФормированияОтчетов		 = Объект.Дата;
	
	Форма.Открыть();
	Форма.СформироватьНаСервере();
	
КонецПроцедуры

&НаСервере
Функция ФильтрОперацииПоВыпискеНаСервере(Выписка)
	ДокументОперацииСводногоОтчета = Обработки.ФормированиеОтчетовОСовершенныхОперациях.ОперацияПоВыписке(Выписка);
	ДатаОпераций = ДокументОперацииСводногоОтчета.Дата;
	Результат = Новый Структура("ДокументОперацииСводногоОтчета, ДатаОпераций", ДокументОперацииСводногоОтчета, ДатаОпераций);
	Возврат Результат;
КонецФункции

&НаКлиенте
Процедура ФормированиеВыпискиОСостоянииСчетаДЕПО(Знач ПроверятьИсходящийНомер = Ложь)
	Если ПроверятьИсходящийНомер Тогда
		Если ЗначениеЗаполнено(Объект.ИсходящийНомер) Тогда
			Возврат;
		КонецЕсли;
	КонецЕсли;
	
	
	Если ЕстьПравоФормироватьВыписку() Тогда
		ПараметрыОтчета = Новый Структура("Выписка", Объект.Ссылка);
		ОткрытьФорму("Отчет.ВыпискаОСостоянииСчетаДепо.Форма.ФормаОтчета", ПараметрыОтчета);
	КонецЕсли;
	
КонецПроцедуры 

&НаСервере
Функция ЕстьПравоФормироватьВыписку()
	
	Если Не Справочники.Контрагенты.ОсобыеУсловия(Объект.ВладелецСчета)
		Или РегистрыСведений.ОтветственныеЛицаОрганизаций.ПользовательМожетРедактироватьОсобыеУсловия() Тогда 
		Возврат Истина;
	Иначе
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Особые условия: " + Объект.ВладелецСчета
		+ ". Выполнение операции доступно Ответственному за особых клиентов");
		Возврат Ложь;
	КонецЕсли;
	
КонецФункции

&НаСервереБезКонтекста
Процедура ОпределитьДоступныеОтчеты(Форма)
	
	Элементы = Форма.Элементы;
	Объект = Форма.Объект;
		
	Если Объект.ВидОтчета = ПредопределенноеЗначение("Перечисление.ВидыОтчетов.ВыпискаОСостоянииСчетаДЕПО") Тогда
		Элементы.ФормаВыпискаПоСчетуДепо.Доступность	= Истина;
		Элементы.ФормаВыпискаОперации.Доступность		= Ложь;
		Элементы.ФормаОтчет.Доступность				= Ложь;
		Элементы.ФормаСводныйОтчетОСовершеннойОперации.Доступность	= Ложь;
	ИначеЕсли Объект.ВидОтчета = ПредопределенноеЗначение("Перечисление.ВидыОтчетов.ОтчетОбОперацияхПоСчетуДЕПО") Или Объект.ВидОтчета = ПредопределенноеЗначение("Перечисление.ВидыОтчетов.Выписка") Тогда
		Элементы.ФормаВыпискаПоСчетуДепо.Доступность	= Ложь;
		Элементы.ФормаВыпискаОперации.Доступность		= Истина;
		Элементы.ФормаОтчет.Доступность				= Ложь;
		Элементы.ФормаСводныйОтчетОСовершеннойОперации.Доступность	= Ложь;
	ИначеЕсли Объект.ВидОтчета = ПредопределенноеЗначение("Перечисление.ВидыОтчетов.СводныйОтчетОСовершеннойОперации") Тогда
		Элементы.ФормаВыпискаПоСчетуДепо.Доступность				= Ложь;
		Элементы.ФормаВыпискаОперации.Доступность					= Ложь;
		Элементы.ФормаОтчет.Доступность								= Ложь;
		Элементы.ФормаСводныйОтчетОСовершеннойОперации.Доступность	= Истина;
	Иначе
		Элементы.ФормаВыпискаПоСчетуДепо.Доступность	= Ложь;
		Элементы.ФормаВыпискаОперации.Доступность		= Ложь;
		Элементы.ФормаОтчет.Доступность				= Истина;
		Элементы.ФормаСводныйОтчетОСовершеннойОперации.Доступность	= Ложь;
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьШапкуДокументаСервер()
	ТекущийОбъект = РеквизитФормыВЗначение("Объект");
	ОбщегоНазначения.ЗаполнитьШапкуДокумента(ТекущийОбъект, ПараметрыСеанса.ТекущийПользователь, , );
	ЗначениеВРеквизитФормы(ТекущийОбъект, "Объект");
КонецПроцедуры

&НаСервере
Процедура УстановитьНомерДокументаСервер()
	ТекущийОбъект = РеквизитФормыВЗначение("Объект");
	Если НЕ ЗначениеЗаполнено(ТекущийОбъект.Дата) Тогда
		ТекущийОбъект.Дата = НачалоДня(ТекущаяДата());
	КонецЕсли;
	ТекущийОбъект.УстановитьНовыйНомер();
	ЗначениеВРеквизитФормы(ТекущийОбъект, "Объект");
КонецПроцедуры


&НаКлиенте
Процедура НастройкаПериодаЗавершение(Период, ДополнительныеПараметры) Экспорт
	
	Если Период <> Неопределено Тогда
		Объект.ДатаНачПериода = Период.ДатаНачала;
		Объект.ДатаКонПериода = Период.ДатаОкончания;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура ДоступностьСтраниц(Форма)
	
	Элементы = Форма.Элементы;
	Объект = Форма.Объект;
	
	Если Объект.ВидОтчета = ПредопределенноеЗначение("Перечисление.ВидыОтчетов.Отчет")  Тогда
		ВидимаяСтраница   = Элементы.Отчет;
		НеВидимаяСтарница1 = Элементы.Выписка;		
		НеВидимаяСтарница2 = Элементы.ВыпискаОСостоянииСчета;		
	ИначеЕсли Объект.ВидОтчета = ПредопределенноеЗначение("Перечисление.ВидыОтчетов.Выписка")  Тогда
		ВидимаяСтраница   = Элементы.Выписка;
		НеВидимаяСтарница1 = Элементы.Отчет;		
		НеВидимаяСтарница2 = Элементы.ВыпискаОСостоянииСчета;		
	ИначеЕсли Объект.ВидОтчета = ПредопределенноеЗначение("Перечисление.ВидыОтчетов.ОтчетОбОперацияхПоСчетуДЕПО")  Тогда
		ВидимаяСтраница   = Элементы.Выписка;
		НеВидимаяСтарница1 = Элементы.Отчет;		
		НеВидимаяСтарница2 = Элементы.ВыпискаОСостоянииСчета;		
	ИначеЕсли Объект.ВидОтчета = ПредопределенноеЗначение("Перечисление.ВидыОтчетов.СводныйОтчетОСовершеннойОперации")  Тогда
		ВидимаяСтраница   = Элементы.Выписка;
		НеВидимаяСтарница1 = Элементы.Отчет;		
		НеВидимаяСтарница2 = Элементы.ВыпискаОСостоянииСчета;		
	Иначе
		ВидимаяСтраница   = Элементы.ВыпискаОСостоянииСчета;;
		НеВидимаяСтарница1 = Элементы.Отчет;		
		НеВидимаяСтарница2 = Элементы.Выписка;		
	КонецЕсли; 
	
	ВидимаяСтраница.Видимость    = Истина;
	НеВидимаяСтарница1.Видимость  = Ложь;
	НеВидимаяСтарница2.Видимость  = Ложь;
	Элементы.Страницы.ТекущаяСтраница = ВидимаяСтраница;

КонецПроцедуры

//#КонецОбласти



