Функция СтруктураДляСозданияКоллекции(ИмяКоллекции, ИмяЭкземпляра, ВходящаяКоллекция, ИмяВходящейКоллекции = "")
	СтруктураКВозврату = Новый Структура();
	СтруктураКВозврату.Вставить("ИмяКоллекции", ИмяКоллекции);
	СтруктураКВозврату.Вставить("ИмяЭкземпляра", ИмяЭкземпляра);
	СтруктураКВозврату.Вставить("ВходящаяКоллекция", ВходящаяКоллекция);
	СтруктураКВозврату.Вставить("ИмяВходящейКоллекции", ИмяВходящейКоллекции);
	Возврат СтруктураКВозврату;
КонецФункции

Функция СоздатьИЗаполнитьКоллекциюОбъектаXDTO(Фабрика, Источник, ПространствоИмен, СтруктураКоллекции)	
	ТипКоллекции = Фабрика.Тип(ПространствоИмен, СтруктураКоллекции.ИмяКоллекции);
	Коллекция = Фабрика.Создать(ТипКоллекции);					  
	Если ТипЗнч(Источник) = Тип("ТаблицаЗначений") Тогда
		Для каждого СтрокаТЧ из Источник Цикл                                    
			ТипЭкземпляра = Фабрика.Тип(ПространствоИмен, СтруктураКоллекции.ИмяЭкземпляра);
			Экземпляр = Фабрика.Создать(ТипЭкземпляра); 
			ЗаполнитьЗначенияСвойств(Экземпляр, СтрокаТЧ);                                   
			Коллекция[СтруктураКоллекции.ИмяЭкземпляра].Добавить(Экземпляр);						
		КонецЦикла;
	Иначе 
		Пока Источник.Следующий() Цикл
			ТипЭкземпляра = Фабрика.Тип(ПространствоИмен, СтруктураКоллекции.ИмяЭкземпляра);
			Экземпляр = Фабрика.Создать(ТипЭкземпляра); 
			ЗаполнитьЗначенияСвойств(Экземпляр, Источник);                                   
			Если НЕ СтруктураКоллекции.ВходящаяКоллекция = Неопределено Тогда
				ВыборкаСледующегоУровня = Источник.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
				ВходящаяКоллекция = СоздатьИЗаполнитьКоллекциюОбъектаXDTO(Фабрика, ВыборкаСледующегоУровня, ПространствоИмен, СтруктураКоллекции.ВходящаяКоллекция);
				Экземпляр.Установить(СтруктураКоллекции.ИмяВходящейКоллекции, ВходящаяКоллекция);
			КонецЕсли;
			Коллекция[СтруктураКоллекции.ИмяЭкземпляра].Добавить(Экземпляр);						
		КонецЦикла;
	КонецЕсли;
	Возврат Коллекция;
КонецФункции


Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
	Если ОбменДанными.Загрузка = Истина Тогда
		Возврат;
	КонецЕсли;
	УстановитьНовыйНомер();
КонецПроцедуры

