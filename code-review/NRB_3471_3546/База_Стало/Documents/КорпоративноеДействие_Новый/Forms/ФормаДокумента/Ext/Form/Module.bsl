// ПРОЦЕДУРЫ УПРАВЛЕНИЯ СТАТУСАМИ

&НаСервере
Функция ОтправленЗапросСубброкера()

	Запрос = Новый Запрос(
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	ЗапросСубброкеруНаРаскрытие.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.ЗапросСубброкеруНаРаскрытие КАК ЗапросСубброкеруНаРаскрытие
	|ГДЕ
	|	ЗапросСубброкеруНаРаскрытие.КД = &КД
	|	И ЗапросСубброкеруНаРаскрытие.Статус В(&СтатусыОтправлено)");
	
	СтатусыОтправлено = Новый Массив();
	СтатусыОтправлено.Добавить(Перечисления.СтатусыДокументаЗапросСубброкеруНаРаскрытие.Сформирован);
	СтатусыОтправлено.Добавить(Перечисления.СтатусыДокументаЗапросСубброкеруНаРаскрытие.Отправлен);
	СтатусыОтправлено.Добавить(Перечисления.СтатусыДокументаЗапросСубброкеруНаРаскрытие.ОтправленПовторно);
	Запрос.УстановитьПараметр("КД",Объект.Ссылка);
	Запрос.УстановитьПараметр("СтатусыОтправлено",СтатусыОтправлено);
	Результат = Запрос.Выполнить();
	Возврат Не Результат.Пустой();

КонецФункции





&НаСервере
Процедура ОбновитьСтатусыНаСервере()
	СтруктураРесурсов 	= РегистрыСведений.СтатусыКорпоративныхДействий.ПолучитьПоследнее(,Новый Структура("КорпоративноеДействие", Объект.Ссылка));
	ТекущийСтатус 		= СтруктураРесурсов.Статус;
	СтруктураРесурсов 	= РегистрыСведений.СостоянияКорпоративныхДействий.ПолучитьПоследнее(,Новый Структура("КорпоративноеДействие", Объект.Ссылка));
	ТекущееСостояние 	= СтруктураРесурсов.Состояние;
	ОтправленЗапросСубброкера = ОтправленЗапросСубброкера();
КонецПроцедуры

&НаКлиенте
Процедура ТекущийСтатусНажатие(Элемент, СтандартнаяОбработка)
	СтандартнаяОбработка = Ложь;
	ПараметрыФормы = Новый Структура("Отбор", Новый Структура("КорпоративноеДействие", Объект.Ссылка)); 
	ФормаСписка = ОткрытьФорму("РегистрСведений.СтатусыКорпоративныхДействий.ФормаСписка", ПараметрыФормы);
КонецПроцедуры

&НаКлиенте
Процедура ТекущееСостояниеНажатие(Элемент, СтандартнаяОбработка)
	СтандартнаяОбработка = Ложь;
	ПараметрыФормы = Новый Структура("Отбор", Новый Структура("КорпоративноеДействие", Объект.Ссылка)); 
	ФормаСписка = ОткрытьФорму("РегистрСведений.СостоянияКорпоративныхДействий.ФормаСписка", ПараметрыФормы);
КонецПроцедуры

