// ВСПОМОГАТЕЛЬНЫЕ ПРОЦЕДУРЫ И ФУНКЦИИ

&НаСервере
Процедура ПроверитьЗаполнениеДанныхНаСервере()
	МассивСообщенийОбОшибкеЗаполнения = Новый Массив;
	Документы.КорпоративноеДействие_Новый.ПроверитьКорректностьВводаРаскрытияСпискаВладельцев(Объект.Ссылка, МассивСообщенийОбОшибкеЗаполнения);
	Документы.КорпоративноеДействие_Новый.ПроверитьДостаточностьДанныхДляОтправкиУведомлений(Объект.Ссылка, МассивСообщенийОбОшибкеЗаполнения);
	Если МассивСообщенийОбОшибкеЗаполнения.Количество() > 0 Тогда 
		Для каждого СтрокаОшибки из МассивСообщенийОбОшибкеЗаполнения Цикл
			ОбщегоНазначения.СообщитьОбОшибке(СтрокаОшибки);
		КонецЦикла;
	КонецЕсли;
КонецПроцедуры

&НаСервере
Функция НаименованиеВалютыБанковскогоСчетаСервер(БанковскийСчет)
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("БанковскийСчет", БанковскийСчет);
	Запрос.Текст =
	"ВЫБРАТЬ
	|	БанковскиеСчета.ВалютаДенежныхСредств.Наименование КАК НаименованиеВалюты
	|ИЗ
	|	Справочник.БанковскиеСчета КАК БанковскиеСчета
	|ГДЕ
	|	БанковскиеСчета.Ссылка = &БанковскийСчет";
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.НаименованиеВалюты;
	Иначе
		Возврат "";
	КонецЕсли;
	
КонецФункции

&НаСервере
Функция ВидКДВСписке(СписокКодовКД)
	// Удалить лишние разделители
	Стр = СтрЗаменить(СписокКодовКД, " ", "");
	Стр = СтрЗаменить(Стр, Символы.ПС, "");
	Стр = СтрЗаменить(Стр, Символы.Таб, "");
	МассивПодстрок = СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(Стр);	
	Возврат МассивПодстрок.Найти(Объект.ВидКД.Код) <> Неопределено;
КонецФункции

&НаСервере
Процедура ДатаОкончанияПриемаИнструкцийНРДПриИзмененииНаСервере()
	Если СокрЛП(Объект.ВидКД.Код) = "TREC"
		ИЛИ ЭтоПодтверждениеОсвобожденияОтНалоговПоЦБНеПодпадающимПодНалоговоеРегулированиеСША() Тогда
		// Предусмотрен ручной ввод даты НРД, при этом пересчитывается дата ВТБКБ
		НоваяДата = Документы.КорпоративноеДействие_Новый.TREC_ДатаОкончанияПриемаИнструкцийВТБКБ(Объект);
		Если Объект.ДатаОкончанияПриемаИнструкцийВТБКБ <> НоваяДата Тогда
			Объект.ДатаОкончанияПриемаИнструкцийВТБКБ = НоваяДата;
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Изменена дата окончания приема инструкций ВТБКБ.");
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

&НаСервере
Функция ЭтоПодтверждениеОсвобожденияОтНалоговПоЦБНеПодпадающимПодНалоговоеРегулированиеСША()
	Возврат СокрЛП(Объект.ВидКД.Код) = "WTRC"
			И НЕ Справочники.ЦенныеБумаги.ЦБПодпадаетПодНалоговоеРегулированиеСША(Объект.ЦеннаяБумага1);
КонецФункции

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	Если ИмяСобытия = "КорпоративноеДействие_Новый/СформироватьУведомление" Тогда 
		ОбновитьСтатусыНаСервере();	
	КонецЕсли;
КонецПроцедуры
