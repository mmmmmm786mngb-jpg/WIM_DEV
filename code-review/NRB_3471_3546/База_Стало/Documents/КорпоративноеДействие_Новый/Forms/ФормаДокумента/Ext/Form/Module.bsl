// ПРОЦЕДУРЫ И ФУНКЦИИ ДЛЯ УПРАВЛЕНИЯ ВНЕШНИМ ВИДОМ ФОРМЫ

&НаСервере
Процедура УправлениеОтображениемРеквизитов()
	// Видимость связанных КД Собрания
	Видимость = ВидКДВСписке("XMET, MEET, BMET, OMET");
	Элементы.СтраницыГолосованиеВариантыУчастия.Видимость = Видимость;
	
	Видимость = ВидКДВСписке("BIDS, TEND, MCAL, MCAL/BN, PRIO, BPUT");
	Элементы.ВидВыкупа.Видимость						= Видимость;
	Элементы.МинКоличествоДляУчастияВКД.Видимость		= Видимость;
	Элементы.ГруппаПериодПриемаЗаявокНаВыкуп.Видимость	= Видимость;
	
	Видимость = ВидКДВСписке("BIDS, TEND, MCAL, MCAL/BN, DVCA, CAPG, INTR, PRII, BPUT, REDM, PRED, PRIO");
	Элементы.ВыплатаНа1ЦБ.Видимость			= Видимость;
	Элементы.ДатаВыплатыНеПозднее.Видимость	= Видимость;
	Элементы.ГруппаБанковскийСчет.Видимость	= Видимость;
	
	Обязательность = ВидКДВСписке("TREC")
		ИЛИ ЭтоПодтверждениеОсвобожденияОтНалоговПоЦБНеПодпадающимПодНалоговоеРегулированиеСША();
	Элементы.ДатаОкончанияПриемаИнструкцийНРД.АвтоОтметкаНезаполненного = Обязательность;
		
	// Страницы дополнительных реквизитов
	Элементы.ДатаФиксацииНеизвестна.Видимость = Ложь;
	
	ФормаСообщенияКК = РегистрыСведений.ФормыСообщенийКабинетаКлиентаВТБКБ.ФормаСообщения(Объект.ВидКД,
		Объект.Этап, Объект.ТипУведомления,
		НЕ Справочники.ЦенныеБумаги.ЦБПодпадаетПодНалоговоеРегулированиеСША(Объект.ЦеннаяБумага1));
	
	Если Перечисления.ФормыСообщенийКК.ЭтоФормаСвязаннаяСВыкупомИлиПриобретениемЦБ(ФормаСообщенияКК) Тогда
		ТекущаяСтраница = Элементы.СтраницаСообщениеОПроведенииКД_ВыкупПриобретениеЦБ;
		
	ИначеЕсли ФормаСообщенияКК = Перечисления.ФормыСообщенийКК.ОПроведенииКД_КонвертацияОбменЦБ Тогда
		ТекущаяСтраница = Элементы.СтраницаСообщениеОПроведенииКД_КонвертацияОбменЦБ;
		
	ИначеЕсли ФормаСообщенияКК = Перечисления.ФормыСообщенийКК.ОПроведенииКД_ОбъединениеВыпусковЦБ Тогда
		ТекущаяСтраница = Элементы.СтраницаСообщениеОПроведенииКД_ОбъединениеВыпусковЦБ;
		
	ИначеЕсли ФормаСообщенияКК = Перечисления.ФормыСообщенийКК.ОПроведенииКД_РеорганизацииОбщества Тогда
		ТекущаяСтраница = Элементы.СтраницаСообщениеОПроведенииКД_РеорганизацииОбщества;
		Элементы.ДатаФиксацииНеизвестна.Видимость = Истина;
		
	ИначеЕсли ФормаСообщенияКК = Перечисления.ФормыСообщенийКК.ОбОтменеКД Тогда
		ТекущаяСтраница = Элементы.СтраницаСообщениеОбОтменеКД;
		
	ИначеЕсли ФормаСообщенияКК = Перечисления.ФормыСообщенийКК.ОПроведенииКД_CписаниеЦБ Тогда
		ТекущаяСтраница = Элементы.СтраницаСообщениеОПроведенииКД_CписаниеЦБ;
		
	ИначеЕсли Перечисления.ФормыСообщенийКК.ЭтоФормаСвязаннаяСВыплатой(ФормаСообщенияКК) Тогда
		ТекущаяСтраница = Элементы.СтраницаСообщениеОПроведенииКД_CвязанногоСВыплатой;
		
	ИначеЕсли ФормаСообщенияКК = Перечисления.ФормыСообщенийКК.ОПоступленииИнформацииИзБюллетеня Тогда
		ТекущаяСтраница = Элементы.СтраницаСообщениеОПоступленииИнформацииИзБюллетеня;
		
	ИначеЕсли ФормаСообщенияКК = Перечисления.ФормыСообщенийКК.ОПроведенииКД_ПодтверждениеОсвобожденияОтНалога Тогда
		ТекущаяСтраница = Элементы.СтраницаСообщениеОПроведенииКД_ОсвобожденияОтНалога;
		
	ИначеЕсли ФормаСообщенияКК = Перечисления.ФормыСообщенийКК.ОПроведенииКД_РаскрытиеИнформации Тогда
		ТекущаяСтраница = Элементы.СтраницаСообщениеОПроведенииКД_РаскрытиеИнформации;
		
	Иначе
		ТекущаяСтраница = Неопределено;
	КонецЕсли;
	
	Если ТекущаяСтраница <> Неопределено Тогда
		Элементы.СтраницыРеквизитыСообщений.ТекущаяСтраница = ТекущаяСтраница;
	КонецЕсли;
	Элементы.СтраницыРеквизитыСообщений.Видимость = ТекущаяСтраница <> Неопределено;
	Элементы.СтраницаВариантыУчастия.Видимость = Не Элементы.СтраницыГолосованиеВариантыУчастия.Видимость;
	Элементы.СтраницаДополнительнаяИнформация2.Видимость = Не Элементы.СтраницыГолосованиеВариантыУчастия.Видимость;
КонецПроцедуры

