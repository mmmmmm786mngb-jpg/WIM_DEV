
//#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	Если Объект.Ссылка.Пустая() Тогда 
		
		УстановитьНомерДокументаСервер();
		ЗаполнитьШапкуДокументаСервер();
				
	КонецЕсли;	
	
	// СтандартныеПодсистемы.ВерсионированиеОбъектов
	ВерсионированиеОбъектов.ПриСозданииНаСервере(ЭтаФорма);
	// Конец СтандартныеПодсистемы.ВерсионированиеОбъектов

КонецПроцедуры

&НаСервере
Процедура ПриЧтенииНаСервере(ТекущийОбъект)
	Оболочки.ПриЧтенииНаСервереДокумента(ЭтотОбъект, ТекущийОбъект);
КонецПроцедуры

//#КонецОбласти

//#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ДатаПриИзменении(Элемент)
	УстановитьНомерДокументаСервер();
КонецПроцедуры

//#КонецОбласти

//#Область ОбработчикиСобытийЭлементовТаблицыФормыОстатки

&НаКлиенте
Процедура ОстаткиЦБОбработкаВыбора(Элемент, ВыбранноеЗначение, СтандартнаяОбработка)
	СтандартнаяОбработка	= Ложь;
	
	ДатаПроверки	= ?(НЕ ЗначениеЗаполнено(Объект.Ссылка), ТекущаяДата(), Объект.Дата);
	
	ЦенныеБумагиКлиент.ЦеннаяБумагаПроверкаВыборка(ВыбранноеЗначение, ДатаПроверки, СтандартнаяОбработка);
КонецПроцедуры

&НаКлиенте
Процедура ОстаткиДепонентПриИзменении(Элемент)
	ТекущаяСтрока = Элементы.Остатки.ТекущиеДанные;
	Если ТекущаяСтрока = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если ЗначениеРеквизитаНаСервере(ТекущаяСтрока.СчетДепо,"Владелец") <> ТекущаяСтрока.Депонент Тогда
		
		ТекущаяСтрока.СчетДепо = ПредопределенноеЗначение("Справочник.СчетаДепо.ПустаяСсылка");
		
	КонецЕсли;
	
	Если ЗначениеРеквизитаНаСервере(ТекущаяСтрока.РазделСчетаДепо,"Владелец") <> ТекущаяСтрока.СчетДепо Тогда
		
		ТекущаяСтрока.РазделСчетаДепо = ПредопределенноеЗначение("Справочник.РазделыСчетаДепо.ПустаяСсылка");
		
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ОстаткиСчетДепоПриИзменении(Элемент)
	ТекущаяСтрока = Элементы.Остатки.ТекущиеДанные;
	Если ТекущаяСтрока = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если ОбщегоНазначения.ЗначениеНеЗаполнено(ТекущаяСтрока.Депонент) Тогда
		
		ТекущаяСтрока.Депонент = ЗначениеРеквизитаНаСервере(ТекущаяСтрока.СчетДепо,"Владелец");
		
	КонецЕсли;
	
	Если ЗначениеРеквизитаНаСервере(ТекущаяСтрока.РазделСчетаДепо,"Владелец") <> ТекущаяСтрока.СчетДепо Тогда
		
		ТекущаяСтрока.РазделСчетаДепо = ПредопределенноеЗначение("Справочник.РазделыСчетаДепо.ПустаяСсылка");
		
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ОстаткиРазделСчетаДепоПриИзменении(Элемент)
	
	ТекущаяСтрока = Элементы.Остатки.ТекущиеДанные;
	Если ТекущаяСтрока = Неопределено Тогда
		Возврат;
	КонецЕсли;
	Если ОбщегоНазначения.ЗначениеНеЗаполнено(ТекущаяСтрока.СчетДепо) Тогда
		
		ТекущаяСтрока.СчетДепо = ЗначениеРеквизитаНаСервере(ТекущаяСтрока.РазделСчетаДепо,"Владелец");
		
	КонецЕсли;
	
	Владелец = ЗначениеРеквизитаНаСервере(ТекущаяСтрока.СчетДепо,"Владелец");
	
	Если ТекущаяСтрока.Депонент <> Владелец Тогда
		
		ТекущаяСтрока.Депонент = Владелец;
		
	КонецЕсли;
КонецПроцедуры

