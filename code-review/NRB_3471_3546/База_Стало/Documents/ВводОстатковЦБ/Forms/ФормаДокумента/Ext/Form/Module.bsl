//#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура Заполнить(Команда)
	Если Объект.Остатки.Количество() > 0 Тогда
		ТекстВопроса = "Данные из таблицы документа будут удалены. Продолжить?";
		Ответ = Вопрос(ТекстВопроса, РежимДиалогаВопрос.ДаНет, 0);
		Если Ответ = КодВозвратаДиалога.Нет Тогда
			Возврат;
		КонецЕсли; 
	КонецЕсли;
	
	ЗаполнитьНаСервере();
КонецПроцедуры

//#КонецОбласти

//#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура ЗаполнитьШапкуДокументаСервер()
	ТекущийОбъект = РеквизитФормыВЗначение("Объект");
	ОбщегоНазначения.ЗаполнитьШапкуДокумента(ТекущийОбъект, ПараметрыСеанса.ТекущийПользователь, , );
	ЗначениеВРеквизитФормы(ТекущийОбъект, "Объект");
КонецПроцедуры

&НаСервере
Процедура УстановитьНомерДокументаСервер()
	ТекущийОбъект = РеквизитФормыВЗначение("Объект");
	Если НЕ ЗначениеЗаполнено(ТекущийОбъект.Дата) Тогда
		ТекущийОбъект.Дата = НачалоДня(ТекущаяДата());
	КонецЕсли;
	ТекущийОбъект.УстановитьНовыйНомер();
	ЗначениеВРеквизитФормы(ТекущийОбъект, "Объект");
КонецПроцедуры



&НаСервереБезКонтекста
Функция ЗначениеРеквизитаНаСервере(Источник, ИмяРеквизита, ПроверятьСуществование = Ложь)
	Перем Результат;
	Если Источник <> Неопределено Тогда
		ЕстьРеквизит = Истина;
		Если ПроверятьСуществование Тогда		
			ЕстьРеквизит = ОбщегоНазначения.ЕстьРеквизитДокумента(
				ИмяРеквизита, Источник.Метаданные());
		КонецЕсли; 
		Если ЕстьРеквизит Тогда
			Результат = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Источник, ИмяРеквизита);
		КонецЕсли; 		
	КонецЕсли; 
	
	Возврат Результат;
	
КонецФункции

&НаСервере
Процедура ЗаполнитьНаСервере()
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ОстаткиЦБОстатки.СчетДепо КАК СчетДепо,
	|	ОстаткиЦБОстатки.СчетДепо.Владелец КАК Депонент,
	|	ОстаткиЦБОстатки.РазделСчетаДепо КАК РазделСчетаДепо,
	|	ОстаткиЦБОстатки.ЦБ КАК ЦБ,
	|	ОстаткиЦБОстатки.ЦБ.ISIN КАК ISIN,
	|	ОстаткиЦБОстатки.СчетДепоМХ КАК СчетДепоМХ,
	|	ОстаткиЦБОстатки.РазделСчетаДепоМХ КАК РазделСчетаДепоМХ,
	|	ОстаткиЦБОстатки.СтатусЦБ КАК СтатусЦБ,
	|	ОстаткиЦБОстатки.КоличествоОстаток КАК Количество
	|ИЗ
	|	РегистрНакопления.ОстаткиЦБ.Остатки(&Период, ) КАК ОстаткиЦБОстатки
	|
	|УПОРЯДОЧИТЬ ПО
	|	ОстаткиЦБОстатки.ЦБ.Наименование,
	|	СчетДепо,
	|	РазделСчетаДепо,
	|	СчетДепоМХ,
	|	РазделСчетаДепоМХ,
	|	СтатусЦБ";
	Запрос.УстановитьПараметр("Период", Объект.Дата);
	Объект.Остатки.Загрузить(Запрос.Выполнить().Выгрузить());

КонецПроцедуры



//#КонецОбласти

