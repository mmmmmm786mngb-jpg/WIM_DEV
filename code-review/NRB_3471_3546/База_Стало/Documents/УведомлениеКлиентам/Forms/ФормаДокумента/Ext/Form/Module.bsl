&НаСервере
Процедура ДокументОснованиеПриИзмененииНаСервере()
	Если Объект.ФормаСообщенияКК = Перечисления.ФормыСообщенийКК.СвободнаяФорма Тогда
		Объект.ВидКД = Объект.ДокументОснование.ВидКД;
		Объект.ЦеннаяБумага1 = Объект.ДокументОснование.ЦеннаяБумага1;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ПолучитьКлиентовДляРассылкиУведомлений(Команда)
	ТабличныйДокумент = ОтчетПоКлиентамНаСервере();
	Если ТабличныйДокумент = Неопределено Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Нет актуальных данных или произошла ошибка.");
	Иначе
		ТабличныйДокумент.Показать("Список клиентов для отправки уведомлений.");
	КонецЕсли;
КонецПроцедуры

&НаСервере
Функция ОтчетПоКлиентамНаСервере()
	
	ДокументОбъект = РеквизитФормыВЗначение("Объект");
	Клиенты = ДокументОбъект.КлиентыДляОтправкиУведомлений();
	
	Если ЗначениеЗаполнено(Клиенты) Тогда
		ТабличныйДокумент = ОбщегоНазначения.ДанныеТаблицыЗначенийВТабличныйДокументСКД(Клиенты);
		Возврат ТабличныйДокумент;
	Иначе
		Возврат Неопределено;
	КонецЕсли;
	
КонецФункции

