Процедура ОбработкаЗаполнения(ДанныеЗаполненияИлиСтруктура, СтандартнаяОбработка)
	
	Если ТипЗнч(ДанныеЗаполненияИлиСтруктура) = Тип("Структура") Тогда 
		Клиенты = ДанныеЗаполненияИлиСтруктура.Клиенты;
		ДанныеЗаполнения = ДанныеЗаполненияИлиСтруктура.Основание;
	Иначе
		ДанныеЗаполнения = ДанныеЗаполненияИлиСтруктура;	
	КонецЕсли;
	
	Если ТипЗнч(ДанныеЗаполнения) = Тип("БизнесПроцессСсылка.ОбработкаWTRCСообщения") Тогда 
		
		КорпоративноеДействиеСсылка = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДанныеЗаполнения,"КД");
		ДокументОснование = КорпоративноеДействиеСсылка;
		ПараметрыКД = РегистрыСведений.ЭтапыКД.ПоследниеВходящиеПараметрыКД(ДокументОснование, Дата);
		АктуальныеРеквизиты = Документы.УведомлениеКлиентам.АктуальныеРеквизиты(ФормаСообщенияКК);
	ИначеЕсли ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.ЗапросСубброкеруНаРаскрытие") Тогда 
		
		КорпоративноеДействиеСсылка = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДанныеЗаполнения,"КД");
		ДокументОснование = ДанныеЗаполнения;
		РСВ = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДанныеЗаполнения,"РСВ");
		ЗаголовокСообщения = ДанныеЗаполнения.ЗаголовокСообщения;
		ТелоСообщения = ДанныеЗаполнения.ТелоСообщения;
		ПараметрыКД = РегистрыСведений.ЭтапыКД.ПоследниеВходящиеПараметрыКД(КорпоративноеДействиеСсылка, Дата);
		АктуальныеРеквизиты = Документы.УведомлениеКлиентам.АктуальныеРеквизиты(ФормаСообщенияКК);
		Если ЗначениеЗаполнено(КорпоративноеДействиеСсылка) И ЗначениеЗаполнено(АктуальныеРеквизиты.ОбщиеКопируемые) Тогда
			ЗаполнитьЗначенияСвойств(ЭтотОбъект, КорпоративноеДействиеСсылка, АктуальныеРеквизиты.ОбщиеКопируемые);
		Иначе
			ЗаполнитьЗначенияСвойств(ЭтотОбъект, РСВ, "Эмитент, ЦеннаяБумага1, ЦеннаяБумага2, КДРеференс, ДатаФиксации");
			ЭтотОбъект.ВидКД = РСВ.ВидКорпоративногоДействия;
			ЭтотОбъект.ДатаСообщения = ТекущаяДатаСеанса();
		КонецЕсли;
		Статус = Перечисления.СтатусыУведомленийКлиентам.ОжидаетОтправки;
		Возврат;
		
	ИначеЕсли ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.Поручение") Тогда
		ДокументОснование = ДанныеЗаполнения;
		Если ЗначениеЗаполнено(ВходящийПакетИзФайловогоШлюза) Тогда
			ДатаСообщения = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ВходящийПакетИзФайловогоШлюза, "Дата");
		Иначе
			ДатаСообщения = ТекущаяДатаСеанса();
		КонецЕсли;
		РезультатЗапроса = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДанныеЗаполнения, "ЦенныеБумагиСписываемые");
		Выборка = РезультатЗапроса.Выбрать();
		Выборка.Следующий();
		ЦеннаяБумага1 = Выборка.ЦеннаяБумага;
		Эмитент = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ЦеннаяБумага1, "Эмитент");
		СформироватьJSON();
		Возврат;
		
	ИначеЕсли НЕ ЗначениеЗаполнено(ДанныеЗаполнения)
		ИЛИ ТипЗнч(ДанныеЗаполнения) <> Тип("ДокументСсылка.КорпоративноеДействие_Новый") Тогда
		
		ФормаСообщенияКК = Перечисления.ФормыСообщенийКК.СвободнаяФорма;
		Статус = Перечисления.СтатусыУведомленийКлиентам.Новый;
		
		Если НЕ ЗначениеЗаполнено(ДанныеЗаполнения) Тогда
			СформироватьJSON();
		КонецЕсли;
		Возврат;
		
	Иначе
		
		ДокументОснование = ДанныеЗаполнения;
		ПараметрыКД = РегистрыСведений.ЭтапыКД.ПоследниеВходящиеПараметрыКД(ДокументОснование, Дата);
		Если Не ЗначениеЗаполнено(ФормаСообщенияКК) Тогда 
			ФормаСообщенияКК = РегистрыСведений.ФормыСообщенийКабинетаКлиентаВТБКБ.ФормаСообщения(ДокументОснование.ВидКД,
			ПараметрыКД.Этап, ПараметрыКД.ТипУведомления,
			НЕ Справочники.ЦенныеБумаги.ЦБПодпадаетПодНалоговоеРегулированиеСША(ДокументОснование.ЦеннаяБумага1));
		КонецЕсли;
		АктуальныеРеквизиты = Документы.УведомлениеКлиентам.АктуальныеРеквизиты(ФормаСообщенияКК);
	
	КонецЕсли;

	
	Если ЗначениеЗаполнено(АктуальныеРеквизиты.ОбщиеКопируемые) Тогда
		ЗаполнитьЗначенияСвойств(ЭтотОбъект, ДокументОснование, АктуальныеРеквизиты.ОбщиеКопируемые);
	КонецЕсли;	
	Этап = ПараметрыКД.Этап;
	ТипУведомления = ПараметрыКД.ТипУведомления;
	
	Если ЗначениеЗаполнено(АктуальныеРеквизиты.СпецифичныеКопируемые) Тогда
		ЗаполнитьЗначенияСвойств(ЭтотОбъект, ДокументОснование, АктуальныеРеквизиты.СпецифичныеКопируемые);
	КонецЕсли;

	ДатаСообщения = ДокументОснование.Дата;
	
	// Маркер заменяется на реальную ссылку для голосования/участия в КД на стороне Web-сервиса
	СсылкаДляУчастияВКД = "#UrlToVote#";
	
	Если Эмитент <> ЦеннаяБумага1.Эмитент Тогда
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "Эмитент в документе отличается от эмитента ценной бумаги №1";
		Сообщение.Сообщить();
	КонецЕсли;
	
	// Реквизиты, специфические для уведомлений, которые устанавливаются произвольно
	Если ФормаСообщенияКК = Перечисления.ФормыСообщенийКК.ОПоступленииМатериаловКОбщемуСобраниюВладельцев Тогда
		ДатаОкончанияГолосования	= ДокументОснование.ДатаОкончанияПриемаИнструкцийВТБКБ;
		ДатаКДПлан					= ДокументОснование.ДатаПроведенияСобрания;
		ПризнакОбязательностиКД		= Перечисления.ПризнакиОбязательностиКД.VOLU; // Не предусмотрен отправителем, заполняется для целей отбора
		ДатаОкончанияПриемаИнструкцийНРДИностранногоЭмитента = ДокументОснование.ДатаОкончанияПриемаИнструкцийНРДИностранногоЭмитента;
		
	ИначеЕсли ФормаСообщенияКК = Перечисления.ФормыСообщенийКК.ОПоступленииИнформацииИзБюллетеня Тогда
		ДатаОкончанияГолосования	= ДокументОснование.ДатаОкончанияПриемаИнструкцийВТБКБ;
		ПризнакОбязательностиКД		= Перечисления.ПризнакиОбязательностиКД.VOLU; // Не предусмотрен отправителем, заполняется для целей отбора
		
	ИначеЕсли  Перечисления.ФормыСообщенийКК.ЭтоФормаСвязаннаяСВыкупомИлиПриобретениемЦБ(ФормаСообщенияКК) Тогда
		ДатаНачалаПериода			= ДокументОснование.ДатаНачалаПриемаЗаявокНаВыкуп;
		ДатаОкончанияПериода		= ДокументОснование.ДатаОкончанияПриемаЗаявокНаВыкуп;
		ВалютаПлатежа				= ДокументОснование.БанковскийСчет.ВалютаДенежныхСредств;
		ВалютаДивидендаКупона		= ДокументОснование.ВалютаДивидендаКупона;
		ДатаКДПлан					= ДокументОснование.ДатаПроведенияСобрания;
		ДатаОкончанияГолосования	= ДокументОснование.ДатаОкончанияПриемаИнструкцийВТБКБ;
		КДРеференсСвязанныйСобрание	= КДРеференсСвязанныйСобрание(ДокументОснование);
			
	ИначеЕсли ФормаСообщенияКК = Перечисления.ФормыСообщенийКК.ОПроведенииКД_КонвертацияОбменЦБ Тогда
		ДатаОкончанияГолосования	= ДокументОснование.ДатаОкончанияПриемаИнструкцийНРД;
		КДРеференсСвязанныйСобрание	= КДРеференсСвязанныйСобрание(ДокументОснование);
			
	ИначеЕсли ФормаСообщенияКК = Перечисления.ФормыСообщенийКК.ОПроведенииКД_ОбъединениеВыпусковЦБ Тогда
		ЦенныеБумаги.Очистить();
		Для Каждого Строка из ДокументОснование.ЦенныеБумаги Цикл
			НоваяСтрока = ЦенныеБумаги.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, Строка);
		КонецЦикла;
			
	ИначеЕсли ФормаСообщенияКК = Перечисления.ФормыСообщенийКК.ОПроведенииКД_РеорганизацииОбщества Тогда
		ДатаНачалаПериода			= ДокументОснование.ДатаНачалаБлокировки;
		ДатаОкончанияПериода		= ДокументОснование.ДатаОкончанияБлокировки;
		КДРеференсСвязанныйСобрание	= КДРеференсСвязанныйСобрание(ДокументОснование);
		
		ЦенныеБумаги.Очистить();
		Для Каждого Строка из ДокументОснование.ЦенныеБумаги Цикл
			НоваяСтрока = ЦенныеБумаги.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, Строка);
		КонецЦикла;
		
	ИначеЕсли Перечисления.ФормыСообщенийКК.ЭтоФормаСвязаннаяСВыплатой(ФормаСообщенияКК) Тогда
		ДатаНачалаПериода		= ДокументОснование.ДатаНачалаКупонногоПериода;
		ДатаОкончанияПериода	= ДокументОснование.ДатаОкончанияКупонногоПериода;
		ВалютаДивидендаКупона	= ДокументОснование.ВалютаДивидендаКупона;
		
	ИначеЕсли ФормаСообщенияКК = Перечисления.ФормыСообщенийКК.ОПроведенииКД_ПодтверждениеОсвобожденияОтНалога Тогда
		ДатаОкончанияПриемаФормыW8 = Документы.КорпоративноеДействие_Новый.WTRC_ДатаОкончанияПриемаФормыW8(ДокументОснование);
		ДатаОкончанияПриемаПоручений1_5 = Документы.КорпоративноеДействие_Новый.WTRC_ДатаОкончанияПриемаПоручений1_5(ДокументОснование);
		ДатаОкончанияПриемаПоручений1_10 = Документы.КорпоративноеДействие_Новый.WTRC_ДатаОкончанияПриемаПоручений1_10(ДокументОснование);
	
	ИначеЕсли ФормаСообщенияКК = Перечисления.ФормыСообщенийКК.ОПроведенииКД_РаскрытиеИнформации Тогда
		ДатаНачалаПериода		= ДокументОснование.ДатаНачалаПриемаЗаявокНаВыкуп;
		ДатаОкончанияПериода	= ДокументОснование.ДатаОкончанияПриемаЗаявокНаВыкуп;
	КонецЕсли;
	
	Если ОбщегоНазначенияКлиентСервер. ЕстьРеквизитИлиСвойствоОбъекта(ДокументОснование, "ДополнительнаяИнформация") Тогда
		ДополнительнаяИнформация = ДокументОснование.ДополнительнаяИнформация;
	Иначе
		ДополнительнаяИнформация = "";
	КонецЕсли;
	
	СформироватьJSON();
	Если ФормаСообщенияКК <> Перечисления.ФормыСообщенийКК.ОПроведенииКД_ВозвратЧастиНалогаНДИНД 
		Или мНезаполненныеОбязательныеПоля.Количество() = 0 Тогда
		// При загрузке КД TREC из НРД не загружается дата окончания приема инструкцию НРД, пользователь указывает ее вручную
		// только после этого мы создаем запросы по данному уведомлению
		СоздатьЗапросыСубброкераНаРаскрытие(Клиенты);
	КонецЕсли;
КонецПроцедуры
// BSLLS:CognitiveComplexity-on
// BSLLS:CyclomaticComplexity-on

Процедура ПриКопировании(ОбъектКопирования)
	// Скопировать можно только заголовок и тело сообщения
	Для Каждого Реквизит Из ЭтотОбъект.Метаданные().Реквизиты Цикл
		Если НЕ (Реквизит.Имя = "ЗаголовокСообщения" ИЛИ Реквизит.Имя = "ТелоСообщения") Тогда
			ЭтотОбъект[Реквизит.Имя] = "";
		КонецЕсли;
	КонецЦикла;
	
	ФормаСообщенияКК = Перечисления.ФормыСообщенийКК.СвободнаяФорма;
	Статус = Перечисления.СтатусыУведомленийКлиентам.Новый;
КонецПроцедуры

Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
	Если НЕ ЗначениеЗаполнено(ДокументОснование) ТОгда
		ОбщегоНазначения.СообщитьОбОшибке("Не указан документ-основание!", Отказ);
	КонецЕсли;
КонецПроцедуры

