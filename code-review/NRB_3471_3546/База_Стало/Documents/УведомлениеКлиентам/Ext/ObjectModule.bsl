КонецФункции

Функция ПредставлениеНомераСтатьи()
	Представление = "";
	Если Справочники.ЦенныеБумаги.ЭтоБумагаРоссийскогоЭмитента(ЦеннаяБумага1)
		И НЕ Документы.УведомлениеКлиентам.ВидКДВСписке(ВидКД, "BPUT") Тогда
		Если НомерСтатьи = "L400" Тогда
			НомерСтатьиВСообщении = "40 ОП";
		ИначеЕсли НомерСтатьи = "L401" Тогда
			НомерСтатьиВСообщении = "40 ЗП";
		ИначеЕсли НомерСтатьи = "L720" Тогда
			НомерСтатьиВСообщении = "72";
		ИначеЕсли НомерСтатьи = "L750" Тогда
			НомерСтатьиВСообщении = "75";
		ИначеЕсли НомерСтатьи = "L841" Тогда
			НомерСтатьиВСообщении = "84.1";
		ИначеЕсли НомерСтатьи = "L842" Тогда
			НомерСтатьиВСообщении = "84.2";
		ИначеЕсли НомерСтатьи = "L848" Тогда
			НомерСтатьиВСообщении = "84.8";
		Иначе
			НомерСтатьиВСообщении = "";
			мНезаполненныеОбязательныеПоля.Добавить("НомерСтатьи_ВыкупПриобретениеЦБ");
		КонецЕсли;
		Представление = "по статье " + НомерСтатьиВСообщении;
	КонецЕсли;
	Возврат Представление;
КонецФункции

Функция ПредставлениеПериодаПроведения()
	Представление = "";
	Если Справочники.ЦенныеБумаги.ЭтоБумагаРоссийскогоЭмитента(ЦеннаяБумага1) Тогда
		Представление = "Период проведения: с %1 по %2";
		Представление = СтрЗаменить(Представление, "%1", ФорматОбязательнойДаты(ДатаНачалаПериода, "ДатаНачалаПериодаПроведения"));
		Представление = СтрЗаменить(Представление, "%2", ФорматОбязательнойДаты(ДатаОкончанияПериода, "ДатаОкончанияПериодаПроведения"));
		
	ИначеЕсли ЗначениеЗаполнено(ДатаНачалаПериода) И ЗначениеЗаполнено(ДатаОкончанияПериода) Тогда
		Представление = "Период проведения: с %1 по %2";
		Представление = СтрЗаменить(Представление, "%1", ФорматДаты(ДатаНачалаПериода));
		Представление = СтрЗаменить(Представление, "%2", ФорматДаты(ДатаОкончанияПериода));
	КонецЕсли;
	
	Возврат Представление;
КонецФункции

Функция ПредставлениеПризнакаОбязательностиКД(ИмяЭлементаФормы)
	Если ПризнакОбязательностиКД = Перечисления.ПризнакиОбязательностиКД.VOLU Тогда
		Представление = "Добровольное событие, для участия требуются инструкции.";
		
	ИначеЕсли ПризнакОбязательностиКД = Перечисления.ПризнакиОбязательностиКД.MAND Тогда
		Представление = "Обязательное событие, инструкций не требуется.";
		
	ИначеЕсли ПризнакОбязательностиКД = Перечисления.ПризнакиОбязательностиКД.CHOS Тогда
		Представление = "Обязательное событие, требуются инструкции.";
		
	Иначе
		мНезаполненныеОбязательныеПоля.Добавить(ИмяЭлементаФормы);
		Представление = "";
	КонецЕсли;
	Возврат Представление;
КонецФункции

Функция ДатаФиксацииВыкупаПриобретенияЦБ()
	Если ЗначениеЗаполнено(ДатаФиксации) Тогда
		Представление = ФорматДаты(ДатаФиксации);
	Иначе
		Если (ВидКД.Код = "TEND" И ПризнакОбязательностиКД = "VOLU")
			ИЛИ (ВидКД.Код = "BIDS" И НомерСтатьи = "L720")
			ИЛИ ВидКД.Код = "PRIO" Тогда
			Представление = "";
				
		ИначеЕсли (ВидКД.Код = "TEND" И ПризнакОбязательностиКД = "MAND")
			ИЛИ (ВидКД.Код = "BIDS" И НомерСтатьи = "L750") Тогда
			мНезаполненныеОбязательныеПоля.Добавить("ДатаФиксации_ВыкупПриобретениеЦБ");
			Представление = "";
		КонецЕсли;
	КонецЕсли;
	
	ДатаФиксацииОбязательна = (ВидКД.Код = "TEND" И ПризнакОбязательностиКД = "MAND")
								ИЛИ (ВидКД.Код = "BIDS" И НомерСтатьи = "L750");	
	
	Возврат Представление;
КонецФункции

Функция ХарактеристикиЦБ()
	Если ЗначениеЗаполнено(ЦеннаяБумага1)
		И ЗначениеЗаполнено(ЦеннаяБумага1.ТипЦБ)
		И ЗначениеЗаполнено(ЦеннаяБумага1.ISIN) Тогда
		Возврат СокрЛП(ЦеннаяБумага1.ТипЦБ) + " " + СокрЛП(ЦеннаяБумага1.ISIN)
				+ ?(ЗначениеЗаполнено(ЦеннаяБумага2), " / " + СокрЛП(ЦеннаяБумага2.ТипЦБ) + " "
					+ СокрЛП(ЦеннаяБумага2.ISIN), "");
	Иначе
		мНезаполненныеОбязательныеПоля.Добавить("ЦеннаяБумага1");
		Возврат "";
	КонецЕсли;
КонецФункции

// Каждая строка преобразуется в параграф HTML <p></p>. Пустые строки игнорируются.
//
// Параметры:
// Текст - многострочная строка
//
// Возвращаемое значение:
// строка
Функция ДобавитьПараграфыHTML(Текст) Экспорт
	Строки = СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(Текст, Символы.ПС);	
	Результат = "";
	Для Каждого Строка Из Строки Цикл
		Если ЗначениеЗаполнено(Строка) Тогда
			Результат = Результат + ?(ЗначениеЗаполнено(Результат), Символы.ПС, "") + "<p>" + СокрЛП(Строка) + "</p>";
		КонецЕсли;
	КонецЦикла;
	Возврат Результат;
КонецФункции

Процедура ДобавитьЦенныеБумагиПоISIN(СписокЦБ, ISIN)
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ЦенныеБумаги.Ссылка КАК ЦеннаяБумага
	|ИЗ
	|	Справочник.ЦенныеБумаги КАК ЦенныеБумаги
	|ГДЕ
	|	ЦенныеБумаги.ISIN В (&СписокISIN)";
	Запрос.УстановитьПараметр("СписокISIN", ISIN);
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		Если СписокЦБ.Найти(Выборка.ЦеннаяБумага) = Неопределено Тогда
			СписокЦБ.Добавить(Выборка.ЦеннаяБумага);
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

// Для данного КД выбираем записи последнего уведомления, т.к. интересны остатки на дату фиксации,
// которыми клиент имеет право участвовать в КД.
Функция КлиентыПоследнегоУведомленияНаОснованииКД(КД)
	Возврат СообщенияПоследнегоУведомленияНаОснованииКД(КД);
КонецФункции

Функция КлиентыПоследнегоУведомленияДляОтчетаПоКлиентам(КД)
	
	Клиенты = СообщенияПоследнегоУведомленияНаОснованииКД(КД);
    ПроверитьНаличиеКодаЗагрузкиКлиенты(Клиенты);
	Возврат Клиенты;
	
КонецФункции

Процедура ПроверитьНаличиеКодаЗагрузкиКлиенты(Клиенты)
	
	Для Каждого Клиент Из Клиенты Цикл
		Если Не Клиент.ЕстьКодЗагрузкиКлиенты Тогда
			СообщениеПользователю = Новый СообщениеПользователю;
			СообщениеПользователю.Текст = СтрШаблон("У клиента %1 в %2 лице нет кода загрузки с типом ""Клиенты""",
				Клиент.КлиентНаименование, Клиент.ЮрФизЛицо);
			СообщениеПользователю.Сообщить();
		КонецЕсли;
	КонецЦикла;

КонецПроцедуры

Функция СообщенияПоследнегоУведомленияНаОснованииКД(Знач КД)
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Уведомления.Клиент КАК Клиент,
	|	Уведомления.Договор КАК Договор,
	|	Уведомления.СчетДепо КАК СчетДепо,
	|	Уведомления.РазделСчетаДепо КАК РазделСчетаДепо,
	|	Уведомления.ЦеннаяБумага КАК ЦеннаяБумага,
	|	Уведомления.Количество КАК Количество,
	|	КодыЗагрузкиКлиента.Код КАК ClientId,
	|	ВЫБОР
	|		КОГДА КодыЗагрузкиКлиента.Ссылка ЕСТЬ NULL
	|			ТОГДА ЛОЖЬ
	|		ИНАЧЕ ИСТИНА
	|	КОНЕЦ КАК ЕстьКодЗагрузкиКлиенты,
	|	ВЫБОР
	|		КОГДА Уведомления.Клиент.ЮрФизЛицо = ЗНАЧЕНИЕ(Перечисление.ЮрФизЛицо.ФизЛицо)
	|			ТОГДА ""физ""
	|		ИНАЧЕ ""юр""
	|	КОНЕЦ КАК ЮрФизЛицо,
	|	ЕСТЬNULL(Уведомления.Договор.Наименование, """") КАК НомерДоговора,
	|	ЕСТЬNULL(Уведомления.Договор.ДатаНачалоДействия, ДАТАВРЕМЯ(1, 1, 1)) КАК ДатаДоговора
	|ПОМЕСТИТЬ ВТ_ДанныеУведомления
	|ИЗ
	|	РегистрСведений.УведомленияОтправленныеЧерезЛичныйКабинет КАК Уведомления
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.КодыЗагрузки КАК КодыЗагрузкиКлиента
	|		ПО Уведомления.Клиент.ЮридическиеФизическиеЛица = КодыЗагрузкиКлиента.Владелец
	|			И (НЕ КодыЗагрузкиКлиента.ПометкаУдаления)
	|			И (КодыЗагрузкиКлиента.Биржа = &КлассификаторыЗагрузкиКлиенты)
	|ГДЕ
	|	Уведомления.КД ССЫЛКА Документ.УведомлениеКлиентам
	|	И НЕ Уведомления.КД.ПометкаУдаления
	|	И ВЫРАЗИТЬ(Уведомления.КД КАК Документ.УведомлениеКлиентам).ДокументОснование = &КД
	|	И Уведомления.КД.Дата В
	|			(ВЫБРАТЬ
	|				МАКСИМУМ(Уведомления.КД.Дата) КАК Дата
	|			ИЗ
	|				РегистрСведений.УведомленияОтправленныеЧерезЛичныйКабинет КАК Уведомления
	|			ГДЕ
	|				Уведомления.КД ССЫЛКА Документ.УведомлениеКлиентам
	|				И НЕ Уведомления.КД.ПометкаУдаления
	|				И ВЫРАЗИТЬ(Уведомления.КД КАК Документ.УведомлениеКлиентам).ДокументОснование = &КД)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_ДанныеУведомления.Клиент КАК Клиент,
	|	ВТ_ДанныеУведомления.Договор КАК Договор,
	|	ВТ_ДанныеУведомления.СчетДепо КАК СчетДепо,
	|	ВТ_ДанныеУведомления.РазделСчетаДепо КАК РазделСчетаДепо,
	|	ВТ_ДанныеУведомления.ЦеннаяБумага КАК ЦеннаяБумага,
	|	ВТ_ДанныеУведомления.Количество КАК Количество,
	|	ВТ_ДанныеУведомления.ClientId КАК ClientId,
	|	ВТ_ДанныеУведомления.ЕстьКодЗагрузкиКлиенты КАК ЕстьКодЗагрузкиКлиенты,
	|	ВТ_ДанныеУведомления.ЮрФизЛицо КАК ЮрФизЛицо,
	|	ВТ_ДанныеУведомления.НомерДоговора КАК НомерДоговора,
	|	ВТ_ДанныеУведомления.ДатаДоговора КАК ДатаДоговора,
	|	ВЫБОР
	|		КОГДА ВТ_ДанныеУведомления.Клиент.ЮридическиеФизическиеЛица ССЫЛКА Справочник.ФизическиеЛица
	|			ТОГДА ЕСТЬNULL(ФИОФизЛицСрезПоследних.Фамилия, """")
	|		ИНАЧЕ ""клиент""
	|	КОНЕЦ КАК Фамилия,
	|	ВЫБОР
	|		КОГДА ВТ_ДанныеУведомления.Клиент.ЮридическиеФизическиеЛица ССЫЛКА Справочник.ФизическиеЛица
	|			ТОГДА ЕСТЬNULL(ФИОФизЛицСрезПоследних.Имя, """")
	|		ИНАЧЕ ВТ_ДанныеУведомления.Клиент.Наименование
	|	КОНЕЦ КАК Имя,
	|	ВТ_ДанныеУведомления.Клиент.Наименование КАК КлиентНаименование
	|ИЗ
	|	ВТ_ДанныеУведомления КАК ВТ_ДанныеУведомления
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ФИОФизЛиц.СрезПоследних(
	|				,
	|				ФизЛицо В
	|					(ВЫБРАТЬ
	|						ВТ_ДанныеУведомления.Клиент.ЮридическиеФизическиеЛица КАК КлиентЮридическиеФизическиеЛица
	|					ИЗ
	|						ВТ_ДанныеУведомления КАК ВТ_ДанныеУведомления)) КАК ФИОФизЛицСрезПоследних
	|		ПО ВТ_ДанныеУведомления.Клиент.ЮридическиеФизическиеЛица = ФИОФизЛицСрезПоследних.ФизЛицо";
	Запрос.УстановитьПараметр("КД", КД);
	Запрос.УстановитьПараметр("КлассификаторыЗагрузкиКлиенты", Справочники.КлассификаторыЗагрузки.Клиенты);
	Возврат Запрос.Выполнить().Выгрузить();

КонецФункции

// Возвращаемое значение:
//	Истина, если для данного КД уже была создана страница для голосования в кабинете клиента
Функция УжеСозданаСтраницаГолосованияВКабинетеКлиента()
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	УведомлениеКлиентам.Ссылка КАК ДокументУведомлениеСсылка
	|ИЗ
	|	Документ.УведомлениеКлиентам КАК УведомлениеКлиентам
	|ГДЕ
	|	УведомлениеКлиентам.ДокументОснование = &ДокументОснование
	|	И НЕ УведомлениеКлиентам.ПометкаУдаления
	|	И УведомлениеКлиентам.СозданаСтраницаГолосованияВКабинетеКлиента";
	Запрос.УстановитьПараметр("ДокументОснование", ДокументОснование);
	Возврат НЕ Запрос.Выполнить().Пустой();
КонецФункции

Функция ОбновитьДанныеСтраницыГолосования()
	СообщитьОбОшибке("Страница для голосования была создана ранее.");
	Возврат Истина;
КонецФункции

Процедура СообщитьОбОшибке(ОписаниеОшибки)
	ИмяСобытия = "Вызов внешнего веб-сервиса для отправки уведомления о КД";
	ЗаписьЖурналаРегистрации(ИмяСобытия, УровеньЖурналаРегистрации.Предупреждение,,, ОписаниеОшибки);
	Сообщение = Новый СообщениеПользователю;
	Сообщение.Текст = ОписаниеОшибки;
	Сообщение.Сообщить();
КонецПроцедуры

Процедура УстановитьСтатусЕстьРахожденияВПоследнихПолученныхЗапросах(КорпоративноеДействиеСсылка, ЗапросыСубброкеру)
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	ЗапросСубброкеруНаРаскрытие.Клиент КАК Клиент,
	|	ЗапросСубброкеруНаРаскрытие.Ссылка КАК Запрос
	|ПОМЕСТИТЬ НовыеЗапросы
	|ИЗ
	|	Документ.ЗапросСубброкеруНаРаскрытие КАК ЗапросСубброкеруНаРаскрытие
	|ГДЕ
	|	ЗапросСубброкеруНаРаскрытие.Ссылка В(&ЗапросыСубброкеру)
	|
	|СГРУППИРОВАТЬ ПО
	|	ЗапросСубброкеруНаРаскрытие.Клиент,
	|	ЗапросСубброкеруНаРаскрытие.Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЗапросСубброкеруНаРаскрытие.Клиент КАК Клиент,
	|	МАКСИМУМ(ЗапросСубброкеруНаРаскрытие.ДатаВремяОтправкиЗапроса) КАК ДатаПоследнейОтправки
	|ПОМЕСТИТЬ ДатаИВремяОтправкиЗапросов
	|ИЗ
	|	Документ.ЗапросСубброкеруНаРаскрытие КАК ЗапросСубброкеруНаРаскрытие
	|ГДЕ
	|	ЗапросСубброкеруНаРаскрытие.КД = &КорпоративноеДействиеСсылка
	|
	|СГРУППИРОВАТЬ ПО
	|	ЗапросСубброкеруНаРаскрытие.Клиент
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЗапросСубброкеруНаРаскрытие.Ссылка КАК ЗапросСубброкеру,
	|	ЗапросСубброкеруНаРаскрытие.Клиент КАК Клиент
	|ПОМЕСТИТЬ ПоследниеОтправленныеЗапросыСубброкеру
	|ИЗ
	|	ДатаИВремяОтправкиЗапросов КАК ДатаИВремяОтправкиЗапросов
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ЗапросСубброкеруНаРаскрытие КАК ЗапросСубброкеруНаРаскрытие
	|		ПО (ЗапросСубброкеруНаРаскрытие.КД = &КорпоративноеДействиеСсылка)
	|			И ДатаИВремяОтправкиЗапросов.Клиент = ЗапросСубброкеруНаРаскрытие.Клиент
	|			И ДатаИВремяОтправкиЗапросов.ДатаПоследнейОтправки = ЗапросСубброкеруНаРаскрытие.ДатаВремяОтправкиЗапроса
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ОтветСубброкераНаРаскрытие.Ссылка КАК ОтветСубброкера,
	|	ОтветСубброкераНаРаскрытие.ЗапросНаРСВ.Клиент КАК Клиент,
	|	ОтветСубброкераНаРаскрытие.Дата КАК ДатаПолучения,
	|	ОтветСубброкераНаРаскрытие.ЗапросНаРСВ КАК ЗапросНаРСВ
	|ПОМЕСТИТЬ ОтветыСубброкера
	|ИЗ
	|	Документ.ОтветСубброкераНаРаскрытие КАК ОтветСубброкераНаРаскрытие
	|ГДЕ
	|	ОтветСубброкераНаРаскрытие.ЗапросНаРСВ.Клиент В
	|			(ВЫБРАТЬ
	|				НовыеЗапросы.Клиент
	|			ИЗ
	|				НовыеЗапросы)
	|	И ОтветСубброкераНаРаскрытие.ЗапросНаРСВ.КД = &КорпоративноеДействиеСсылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ОтветыСубброкера.Клиент КАК Клиент,
	|	МАКСИМУМ(ОтветыСубброкера.ДатаПолучения) КАК ДатаПолучения
	|ПОМЕСТИТЬ ДатаИВремяПолученияОтвета
	|ИЗ
	|	ОтветыСубброкера КАК ОтветыСубброкера
	|
	|СГРУППИРОВАТЬ ПО
	|	ОтветыСубброкера.Клиент
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ОтветыСубброкера.ОтветСубброкера КАК ОтветСубброкера,
	|	ОтветыСубброкера.Клиент КАК Клиент,
	|	ОтветыСубброкера.ЗапросНаРСВ КАК ЗапросНаРСВ
	|ПОМЕСТИТЬ ПоследниеПолученныеОтветыСубброкера
	|ИЗ
	|	ДатаИВремяПолученияОтвета КАК ПоследниеПолученныеОтветы
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ОтветыСубброкера КАК ОтветыСубброкера
	|		ПО ПоследниеПолученныеОтветы.Клиент = ОтветыСубброкера.Клиент
	|			И (ОтветыСубброкера.ДатаПолучения = ПоследниеПолученныеОтветы.ДатаПолучения)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	НовыеЗапросы.Клиент КАК Клиент,
	|	НовыеЗапросы.Запрос КАК НовыйЗапрос,
	|	ЕСТЬNULL(ПоследниеПолученныеОтветыСубброкера.ЗапросНаРСВ, ПоследниеОтправленныеЗапросыСубброкеру.ЗапросСубброкеру) КАК СтарыйЗапрос,
	|	ПоследниеПолученныеОтветыСубброкера.ОтветСубброкера КАК ОтветСубброкера
	|ИЗ
	|	НовыеЗапросы КАК НовыеЗапросы
	|		ЛЕВОЕ СОЕДИНЕНИЕ ПоследниеОтправленныеЗапросыСубброкеру КАК ПоследниеОтправленныеЗапросыСубброкеру
	|		ПО НовыеЗапросы.Клиент = ПоследниеОтправленныеЗапросыСубброкеру.Клиент
	|		ЛЕВОЕ СОЕДИНЕНИЕ ПоследниеПолученныеОтветыСубброкера КАК ПоследниеПолученныеОтветыСубброкера
	|		ПО НовыеЗапросы.Клиент = ПоследниеПолученныеОтветыСубброкера.Клиент");
	
	Запрос.УстановитьПараметр("ЗапросыСубброкеру",ЗапросыСубброкеру);
	Запрос.УстановитьПараметр("СтатусПолученОтвет",Перечисления.СтатусыДокументаОтветСубброкераНаРаскрытие.Загружен);
	Запрос.УстановитьПараметр("КорпоративноеДействиеСсылка", КорпоративноеДействиеСсылка);
	
	ПВХ = ПланыВидовХарактеристик.ВнешниеИсточники.РассылкаУведомленийОСозданииЗапросаНаРаскрытиеTrec;
	Результат = Запрос.Выполнить();	
	Выборка = Результат.Выбрать();
	Пока Выборка.Следующий() Цикл
		Если ЗначениеЗаполнено(Выборка.ОтветСубброкера) Тогда
			ОтветОбъект = Выборка.ОтветСубброкера.ПолучитьОбъект();
			ОтветОбъект.Статус = Перечисления.СтатусыДокументаОтветСубброкераНаРаскрытие.ИзменилсяОстатокЦБ;
			ОтветОбъект.Записать();
		КонецЕсли;
		СлужебноеУведомление = СообщенияQI.СлужебноеУведомлениеОбИзмененииОстаткаЦБ(Выборка.СтарыйЗапрос, Выборка.НовыйЗапрос);
		СообщенияQI.ОтправитьСлужебноеУведомление(ПВХ,СлужебноеУведомление.Тема,СлужебноеУведомление.Тело);
	КонецЦикла;
	
КонецПроцедуры 


Процедура СоздатьЗапросыСубброкераНаРаскрытие(Клиенты = Неопределено)
	
	ПВХ = ПланыВидовХарактеристик.ВнешниеИсточники.РассылкаУведомленийОСозданииЗапросаНаРаскрытиеTrec;
	Если Не WTRCСообщенияQI.ИспользоватьРегистрациюЗапросовСубброкера(ДокументОснование.Дата) Тогда 
		Возврат;
	ИначеЕсли АктивнаяСсылка И ВидКД.Код = "TREC" И ФормаСообщенияКК = Перечисления.ФормыСообщенийКК.ОПроведенииКД_ВозвратЧастиНалогаНДИНД Тогда 
		ЗапросСубброкеру = Документы.ЗапросСубброкеруНаРаскрытие.СоздатьЗапросыСубброкеруНаРаскрытиеTrec(ДокументОснование, ЭтотОбъект);
		Для Каждого ЗапросСубброкеруСсылка Из ЗапросСубброкеру Цикл
			Если ФормаСообщенияКК = Перечисления.ФормыСообщенийКК.ОПроведенииКД_ВозвратЧастиНалогаНДИНД Тогда  
				СлужебноеУведомление = СообщенияQI.СлужебноеУведомлениеОФормированииЗапросаСубброкеру(ЗапросСубброкеруСсылка);
				СообщенияQI.ОтправитьСлужебноеУведомление(ПВХ,СлужебноеУведомление.Тема,СлужебноеУведомление.Тело);
			КонецЕсли;
		КонецЦикла;
	ИначеЕсли ФормаСообщенияКК = Перечисления.ФормыСообщенийКК.ОбИзмененииОстатковЦБ Тогда
		ЗапросСубброкеру = Документы.ЗапросСубброкеруНаРаскрытие.СоздатьЗапросыСубброкеруНаРаскрытиеTrec(ДокументОснование, ЭтотОбъект, Клиенты);
		УстановитьСтатусЕстьРахожденияВПоследнихПолученныхЗапросах(ДокументОснование,ЗапросСубброкеру);  
	КонецЕсли;
	
КонецПроцедуры

//////////////////////////////////////////////////////////////////////////////
// ФУНКЦИИ ФОРМИРОВАНИЯ ТЕКСТА СООБЩЕНИЙ (реквизиты ЗаголовокСообщения и ТелоСообщения)

// BSLLS:CognitiveComplexity-off
// BSLLS:CyclomaticComplexity-off
// Формирует текст заголовка и тела сообщения
Процедура СформироватьТекстСообщения() Экспорт
	Если ФормаСообщенияКК <> Перечисления.ФормыСообщенийКК.СвободнаяФорма
		И (НЕ ЗначениеЗаполнено(Статус)
			ИЛИ Статус = Перечисления.СтатусыУведомленийКлиентам.ОжидаетОтправки
			ИЛИ Статус = Перечисления.СтатусыУведомленийКлиентам.СформированоСОшибками) Тогда

		мНезаполненныеОбязательныеПоля = Новый Массив;
		ДатаФиксацииОбязательна = Ложь;
		ЗаголовокСообщения = "";
		ТелоСообщения = "";
		Если ФормаСообщенияКК = Перечисления.ФормыСообщенийКК.ОПоступленииМатериаловКОбщемуСобраниюВладельцев Тогда
			ЗаголовокСообщения = "Поступила информация о проведении общего собрания владельцев";
			ТелоСообщения = ТекстСообщенияОПоступленииМатериаловКОбщемуСобраниюВладельцев();
			
		ИначеЕсли ФормаСообщенияКК = Перечисления.ФормыСообщенийКК.ОПоступленииИнформацииИзБюллетеня Тогда
			ЗаголовокСообщения = "Поступила информация из бюллетеня к общему собранию владельцев";
			ТелоСообщения = ТекстСообщенияОПоступленииИнформацииИзБюллетеня();
			
		ИначеЕсли Перечисления.ФормыСообщенийКК.ЭтоФормаСвязаннаяСВыплатой(ФормаСообщенияКК) Тогда
			ЗаголовокСообщения = "Поступила информация о проведении выкупа/приобретении ценных бумаг";
			ТелоСообщения = ТекстСообщенияОПроведенииКД_ВыкупПриобретениеЦБ();
			
		ИначеЕсли ФормаСообщенияКК = Перечисления.ФормыСообщенийКК.ОПроведенииКД_КонвертацияОбменЦБ Тогда
			ЗаголовокСообщения = "Поступила информация о конвертации/обмене ценных бумаг";
			ТелоСообщения = ТекстСообщенияОПроведенииКД_КонвертацияОбменЦБ();
			
		ИначеЕсли ФормаСообщенияКК = Перечисления.ФормыСообщенийКК.ОПроведенииКД_ОбъединениеВыпусковЦБ Тогда
			ЗаголовокСообщения = "Поступила информация об объединении выпусков ценных бумаг/аннулировании доп. выпусков акций";
			ТелоСообщения = ТекстСообщенияОПроведенииКД_ОбъединениеВыпусковЦБ();
			
		ИначеЕсли ФормаСообщенияКК = Перечисления.ФормыСообщенийКК.ОПроведенииКД_РеорганизацииОбщества Тогда
			ЗаголовокСообщения = "Поступила информация о реорганизации общества";
			ТелоСообщения = ТекстСообщенияОПроведенииКД_РеорганизацииОбщества();
			
		ИначеЕсли ФормаСообщенияКК = Перечисления.ФормыСообщенийКК.ОПроведенииКД_ПрочихВидов Тогда
			ЗаголовокСообщения = "Поступила информация о корпоративном действии";
			ТелоСообщения = ТекстСообщенияОПроведенииКД_ПрочихВидов();
			
		ИначеЕсли ФормаСообщенияКК = Перечисления.ФормыСообщенийКК.ОбОтменеКД Тогда
			ЗаголовокСообщения = "Отмена корпоративного действия";
			ТелоСообщения = ТекстСообщенияОбОтменеКД();
			
		ИначеЕсли ФормаСообщенияКК = Перечисления.ФормыСообщенийКК.ОПроведенииКД_CписаниеЦБ Тогда
			ЗаголовокСообщения = "Поступила информация о списании ценных бумаг";
			ТелоСообщения = ТекстСообщенияОПроведенииКД_CписаниеЦБ();
			
		ИначеЕсли ФормаСообщенияКК = Перечисления.ФормыСообщенийКК.ОПроведенииКД_CвязанногоСВыплатой Тогда
			ЗаголовокСообщения = "Поступила информация о выплатах по ценным бумагам";
			ТелоСообщения = ТекстСообщенияОПроведенииКД_CвязанногоСВыплатой();
			
		ИначеЕсли ФормаСообщенияКК = Перечисления.ФормыСообщенийКК.ОПроведенииКД_ПодтверждениеОсвобожденияОтНалога Тогда
			ЗаголовокСообщения = "Поступила информация о проведении корпоративного действия - подтверждение "
				+ "освобождения от налога";
			ТелоСообщения = ТекстСообщенияОПроведенииКД_ПодтверждениеОсвобожденияОтНалога();
			
		ИначеЕсли ФормаСообщенияКК = Перечисления.ФормыСообщенийКК.ОПроведенииКД_ВозвратЧастиНалога Тогда
			ЗаголовокСообщения = "Поступила информация о возврате части удержанного налога";
			ТелоСообщения = ТекстСообщенияОПроведенииКД_ВозвратЧастиНалога();
		ИначеЕсли ФормаСообщенияКК = Перечисления.ФормыСообщенийКК.ОПроведенииКД_ВозвратЧастиНалогаНДИНД Тогда
			ЗаголовокСообщения = "Поступила информация о возврате части удержанного налога";
			ТелоСообщения = ТекстСообщенияОПроведенииКД_ВозвратЧастиНалогаНДИНД();
			
		ИначеЕсли ФормаСообщенияКК = Перечисления.ФормыСообщенийКК.ОПроведенииКД_СущественноеИзменениеПоЦБИноеСобытие Тогда
			ЗаголовокСообщения = "Поступила информация о проведении корпоративного действия";
			ТелоСообщения = ТекстСообщенияОПроведенииКД_СущественноеИзменениеПоЦБИноеСобытие();
			
		ИначеЕсли ФормаСообщенияКК = Перечисления.ФормыСообщенийКК.ОПроведенииКД_РаскрытиеИнформации Тогда
			ЗаголовокСообщения = "Поступила информация о проведении корпоративного действия";
			ТелоСообщения = ТекстСообщенияОПроведенииКД_РаскрытиеИнформации();
			
		ИначеЕсли ФормаСообщенияКК = Перечисления.ФормыСообщенийКК.ОбИтогахСобрания Тогда
			ЗаголовокСообщения = "Поступила информация о решениях, принятых общим собранием акционеров, "
				+ "а также об итогах голосования на общем собрании акционеров";
			ТелоСообщения = ТекстСообщенияОбИтогахСобрания();
			
		ИначеЕсли ФормаСообщенияКК = Перечисления.ФормыСообщенийКК.ОбОтменеСобрания Тогда
			ЗаголовокСообщения = "Поступила информация об отмене общего собрания акционеров";
			ТелоСообщения = ТекстСообщенияОбОтменеСобрания();
			
		ИначеЕсли ФормаСообщенияКК = Перечисления.ФормыСообщенийКК.ОПроведенииКД_ПодтверждениеОсвобожденияОтНалогаПоЦБНеПодпадающимПодНалоговоеРегулированиеСША Тогда
			ЗаголовокСообщения = "Поступила информация о проведении корпоративного действия - подтверждение освобождения от налога";
			ТелоСообщения = ТекстСообщенияОПроведенииКД_ПодтверждениеОсвобожденияОтНалогаПоЦБНеПодпадающимПодНалоговоеРегулированиеСША();
		ИначеЕсли ФормаСообщенияКК = Перечисления.ФормыСообщенийКК.ОбИзмененииОстатковЦБ Тогда
	        ЗаголовокСообщения = "Поступила информация о проведении корпоративного действия";
			ТелоСообщения = ТекстСообщенияОбИзмененииОстатков();
		ИначеЕсли ФормаСообщенияКК = Перечисления.ФормыСообщенийКК.УведомлениеОРегистрацииЗаявкиВУКПаи Тогда
			ЗаголовокСообщения = Строка(ФормаСообщенияКК);
			ТелоСообщения = ТекстСообщенияОРегистрацииЗаявкиВУКПаи();
		КонецЕсли;
		
		ТелоСообщения = "<p>#Hello#</p>" + Символы.ПС	// Этот маркер заменяется на текст приветствия на стороне Web-сервиса
			+ ТелоСообщения + Символы.ПС
			+ ПодписьСообщения();						// {Обязательный блок}
		
		Если ТипЗнч(ДокументОснование) = Тип("ДокументСсылка.КорпоративноеДействие_Новый")
			И ДокументОснование.Инициатор = ОбщегоНазначенияПовтИсп.ЗначениеКонстанты("МестоХраненияБЭБ") Тогда
			ТелоСообщения = СтрЗаменить(ТелоСообщения, "#СсылкаДляУчастияВКорпоративномДействии#", "");
		КонецЕсли;
		
		// Общие обязательные поля
		Если НЕ ЗначениеЗаполнено(Эмитент) Тогда
			мНезаполненныеОбязательныеПоля.Добавить("Эмитент");
		КонецЕсли;
		Если НЕ ЗначениеЗаполнено(ЦеннаяБумага1) Тогда
			мНезаполненныеОбязательныеПоля.Добавить("ЦеннаяБумага1");
		КонецЕсли;
		
		Если ЗначениеЗаполнено(мНезаполненныеОбязательныеПоля) Тогда
			Статус = Перечисления.СтатусыУведомленийКлиентам.СформированоСОшибками;
			СписокНезаполненныхОбязательныхПолей = ЗначениеВСтрокуВнутр(мНезаполненныеОбязательныеПоля);
		Иначе
			Статус = Перечисления.СтатусыУведомленийКлиентам.ОжидаетОтправки;
			СписокНезаполненныхОбязательныхПолей = "";
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры
