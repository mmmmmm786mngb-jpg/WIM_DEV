Процедура ЗаполнитьТекстСообщенияОПроведенииКД_ВыкупПриобретениеЦБ(ТекстJSON)
	
	Data = ТекстJSON.Data;
	Data.Вставить("MailTemplateTitle", "ОПроведенииКД_ВыкупПриобретениеЦБ");
	
	ReplaceFields = Data.ReplaceFields;
	
	ReplaceFields.Вставить("ПредставлениеПериодаПроведения", ПредставлениеПериодаПроведения());
	ReplaceFields.Вставить("ИнициаторВыкупа", ФорматОбязательнойСтроки(ИнициаторВыкупа, "ИнициаторВыкупа"));
	ReplaceFields.Вставить("ЦенаПредложения", ФорматОбязательнойСуммыСВалютой(ВыплатаНа1ЦБ, ВалютаДивидендаКупона, "ЦенаПредложения"));
	ReplaceFields.Вставить("ДатаКДРеестр", ?(ЗначениеЗаполнено(ДатаКДРеестр), ФорматДаты(ДатаКДРеестр),
		ФорматДаты(ТекущаяДатаСеанса())));
	ReplaceFields.Вставить("ЦенаРазмещения", ФорматОбязательнойСуммыСВалютой(ЦенаРазмещения,
		ВалютаЦеныРазмещения, "ЦенаРазмещения"));
	ReplaceFields.Вставить("ДатаКДПлан", ФорматОбязательнойДатыСоВременем(ДатаКДПлан, "ДатаКДПлан_ВыкупПриобретениеЦБ"));
	ReplaceFields.Вставить("ПризнакОбязательностиКД_КонвертацияОбменЦБ",
		ПредставлениеПризнакаОбязательностиКД("ПризнакОбязательностиКД_ВыкупПриобретениеЦБ"));
	ReplaceFields.Вставить("ДатаФиксации", ДатаФиксацииВыкупаПриобретенияЦБ());
	
	Если ВидКД.Код = "BPUT" Тогда
		Если ЗначениеЗаполнено(ДатаОкончанияПериода) Тогда
			ДатаОкончанияПриемаЗаявлений = КонецДня(Документы.УведомлениеКлиентам.ДобавитьРабочийДень(ДатаОкончанияПериода, -2));
