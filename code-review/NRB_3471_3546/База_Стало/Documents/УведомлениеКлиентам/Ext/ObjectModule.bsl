Функция ТекстСообщенияОПроведенииКД_CвязанногоСВыплатой()
	// {Обязательный блок}
	Текст =
	"<p>Уведомляем Вас о том, что в %1 поступила информация о проведении корпоративного действия
	|""%2"" - %3 (%4, Референс КД %5).</p>";
	Текст = СтрЗаменить(Текст, "%1", мНаименованиеДепозитария);
	Текст = СтрЗаменить(Текст, "%2", ФорматОбязательнойСтроки(ВидКД.Наименование, "ВидКД"));
	Текст = СтрЗаменить(Текст, "%3", Справочники.ЦенныеБумаги.НаименованиеЭмитента(ЦеннаяБумага1));
	Текст = СтрЗаменить(Текст, "%4", ХарактеристикиЦБ());
	Текст = СтрЗаменить(Текст, "%5", ФорматОбязательнойСтроки(КДРеференс, "КДРеференс"));
	
	Если Справочники.ЦенныеБумаги.ЭтоБумагаРоссийскогоЭмитента(ЦеннаяБумага1)
		ИЛИ (НЕ Справочники.ЦенныеБумаги.ЭтоБумагаРоссийскогоЭмитента(ЦеннаяБумага1) И ЗначениеЗаполнено(ДатаКДПлан)) Тогда
		Текст = Текст + "
		|<p>Дата проведения (план.): %1</p>";
		Текст = СтрЗаменить(Текст, "%1", ФорматОбязательнойДаты(ДатаКДПлан, "ДатаКДПлан_CвязанногоСВыплатой"));
	КонецЕсли;
	
	Текст = Текст + "
	|<p>Дата фиксации: %1</p>";
	Текст = СтрЗаменить(Текст, "%1", ФорматОбязательнойДаты(ДатаФиксации, "ДатаФиксации_CвязанногоСВыплатой"));
	ДатаФиксацииОбязательна = Истина;
	
	// {Опциональный блок, только для КД иностранных эмитентов}
	Если НЕ Справочники.ЦенныеБумаги.ЭтоБумагаРоссийскогоЭмитента(ЦеннаяБумага1) Тогда
		Текст = Текст + "
		|<p>Признак обязательности КД: %1</p>";
		Текст = СтрЗаменить(Текст, "%1", ПредставлениеПризнакаОбязательностиКД("ПризнакОбязательностиКД_CвязанногоСВыплатой"));
	КонецЕсли;
	
	// {Опциональный блок, только для КД иностранных эмитентов по КД типов CAPG, DVCA, DVSE}
	Если ВидимостьГруппы_БезДивидендов() Тогда
		Если ЗначениеЗаполнено(ХДивДата) Тогда
			Текст = Текст + "
			|<p>Дата, с которой ценные бумаги торгуются ""без дивидендов"": %1</p>";
			Текст = СтрЗаменить(Текст, "%1", ФорматДаты(ХДивДата));
		КонецЕсли;
		
		Если ЗначениеЗаполнено(СтавкаНалога) Тогда
			Текст = Текст + "
			|<p>Ставка удерживаемого налога, %: %1</p>";
			Текст = СтрЗаменить(Текст, "%1", СтавкаНалога);
		КонецЕсли;
		
		Если ЗначениеЗаполнено(ЧистаяСтавкаДивидендов) Тогда
			Текст = Текст + "
			|<p>Чистая ставка дивидендов: %1 %2</p>";
			Текст = СтрЗаменить(Текст, "%1", ЧистаяСтавкаДивидендов);
			Текст = СтрЗаменить(Текст, "%2", Справочники.Валюты.ПредставлениеВалюты(ВалютаЧистойСтавкиДивидендов));
		КонецЕсли;
	КонецЕсли;
	
	// {Опциональный блок, только для DVCA, DVSE, CAPG, LIQU}
	Если ВидимостьГруппы_РазмерДивидендов() Тогда
		Текст = Текст + "
		|<p>Размер дивидендов на одну ценную бумагу в валюте платежа: %1</p>
		|<p>Валюта платежа: %2</p>";
		ПредставлениеВыплатаНа1ЦБ = ФорматОбязательнойСуммыСВалютой(ВыплатаНа1ЦБ, ВалютаПлатежа, "РазмерДивидендов");
		Текст = СтрЗаменить(Текст, "%1", ПредставлениеВыплатаНа1ЦБ);
		Текст = СтрЗаменить(Текст, "%2", Справочники.Валюты.ПредставлениеВалюты(ВалютаПлатежа));
		
		Если Справочники.ЦенныеБумаги.ЭтоБумагаРоссийскогоЭмитента(ЦеннаяБумага1) И ЗначениеЗаполнено(Период) Тогда
			Текст = Текст + "
			|<p>Период: %1</p>";
			Текст = СтрЗаменить(Текст, "%1", Период);
		КонецЕсли;
	КонецЕсли;
	
	// {Опциональный блок, только для REDM, MCAL, PRED}
	Если ВидимостьГруппы_ПогашаемаяЧасть() Тогда
		Текст = Текст + "
		|<p>Погашаемая часть в %: %1</p>";
		Текст = СтрЗаменить(Текст, "%1", ФорматОбязательнойСуммы(ПогашаемаяЧасть, "ПогашаемаяЧасть"));
		
		Если Справочники.ЦенныеБумаги.ЭтоБумагаРоссийскогоЭмитента(ЦеннаяБумага1) Тогда
			Текст = Текст + "
			|<p>Размер погашаемой части в валюте платежа: %1</p>";
			Текст = СтрЗаменить(Текст, "%1", ФорматОбязательнойСуммыСВалютой(РазмерПогашаемойЧасти,
				ВалютаПлатежа, "РазмерПогашаемойЧасти"));
		КонецЕсли;
		Текст = Текст + "
		|<p>Валюта платежа: %1</p>";
		Текст = СтрЗаменить(Текст, "%1", ПредставлениеОбязательнойВалюты(ВалютаПлатежа, "ВалютаПлатежа_ПогашаемаяЧасть"));
	КонецЕсли;
	
	// {Опциональный блок, только для INTR}
	Если ВидимостьГруппы_КупонныйДоход() Тогда
		Текст = Текст + "
		|<p>Ставка купонного дохода (%, годовых): %1</p>
		|<p>Размер купонного дохода в валюте платежа: %2</p>
		|<p>Валюта платежа: %3</p>
		|<p>Дата начала текущего купонного периода: %4</p>
		|<p>Дата окончания текущего купонного периода: %5</p>
		|<p>Количество дней в купонном периоде: %6</p>";
		Текст = СтрЗаменить(Текст, "%1", ФорматОбязательнойСуммы(СтавкаКупонногоДоходаГодовых, "СтавкаКупонногоДоходаГодовых"));
		Текст = СтрЗаменить(Текст, "%2", ФорматОбязательнойСуммыСВалютой(ВыплатаНа1ЦБ, ВалютаПлатежа,
			"РазмерКупонногоДохода"));
		Текст = СтрЗаменить(Текст, "%3", ПредставлениеОбязательнойВалюты(ВалютаПлатежа, "ВалютаПлатежаКупонногоДохода"));
		Текст = СтрЗаменить(Текст, "%4", ФорматОбязательнойДаты(ДатаНачалаПериода, "ДатаНачалаКупонногоПериода"));
		Текст = СтрЗаменить(Текст, "%5", ФорматОбязательнойДаты(ДатаОкончанияПериода, "ДатаОкончанияКупонногоПериода"));
		Текст = СтрЗаменить(Текст, "%6", ФорматОбязательнойСуммы(КоличествоДнейВКупонномПериоде, "КоличествоДнейВКупонномПериоде"));
	КонецЕсли;
	
	// {Опциональный блок}
	Если ТребуетсяДобавитьИнформациюДляСубброкеров() Тогда
		Текст = Текст + "
		|#ИнформацияДляСубброкера#";
	КонецЕсли;
	
	// {Опциональный блок, только при наличии ссылки}
	Если ЗначениеЗаполнено(АдресВСетиИнтернет) Тогда
		Текст = Текст + "
		|<p>С деталями корпоративного действия Вы можете ознакомиться по ссылке: %1</p>";
		Текст = СтрЗаменить(Текст, "%1", ПредставлениеСсылки(АдресВСетиИнтернет));
	КонецЕсли;
	
	Возврат Текст;
КонецФункции

