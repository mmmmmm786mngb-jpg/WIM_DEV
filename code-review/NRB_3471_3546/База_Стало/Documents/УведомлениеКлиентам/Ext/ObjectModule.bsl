	|	ОстаткиПоКлиентам.Количество	КАК Количество
	|ПОМЕСТИТЬ втОстаткиПоКлиентамИсходная
	|ИЗ
	|	&ОстаткиПоКлиентам КАК ОстаткиПоКлиентам
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|// Запрос 2
	|ВЫБРАТЬ
	|	ОстаткиПоКлиентам.ЦеннаяБумага		КАК ЦеннаяБумага,
	|	ОстаткиПоКлиентам.ClientId			КАК ClientId,
	|	СУММА(ОстаткиПоКлиентам.Количество)	КАК Количество
	|ПОМЕСТИТЬ втОстаткиПоКлиентам
	|ИЗ
	|	втОстаткиПоКлиентамИсходная КАК ОстаткиПоКлиентам
	|
	|СГРУППИРОВАТЬ ПО
	|	ОстаткиПоКлиентам.ЦеннаяБумага,
	|	ОстаткиПоКлиентам.ClientId
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|// Запрос 3: ВыборкаДокументов
	|ВЫБРАТЬ
	|	Документ.ВидКДКод КАК type,
	|	Документ.КДРеференс КАК reference,
	|	Документ.АдресВСетиИнтернет КАК ftpFile,
	|	Документ.ЭмитентПредставление КАК issuerName,
	|	Документ.ДатаПроведенияСобрания КАК MeetDate,
	|	Документ.ДатаОкончанияПриемаИнструкцийВТБКБ КАК deadLineDate,
	|	Документ.ДатаФиксации КАК cutOffDate
	|ИЗ
	|	втДанныеДокумента КАК Документ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|// Запрос 4: ВыборкаВопросов
	|ВЫБРАТЬ
	|	Вопросы.ДляИнформации КАК ForInformationOnly,
	|	Вопросы.КуммулятивныйВопрос КАК CumulativeVoting,
	|	Вопросы.ТекстВопроса КАК Description,
	|	ВЫБОР
	|		КОГДА Вопросы.Коэффициент = 0
	|			ТОГДА 1
	|		ИНАЧЕ Вопросы.Коэффициент
	|	КОНЕЦ КАК VoteMultiplier,
	|	Вопросы.ВариантыГолосования КАК VoteInstrTp,
	|	Вопросы.НомерВопроса КАК Number
	|ИЗ
	|	Документ.КорпоративноеДействие_Новый.ВопросыКГолосованию КАК Вопросы
	|ГДЕ
	|	Вопросы.Ссылка = &Ссылка
	|
	|УПОРЯДОЧИТЬ ПО
	|	Вопросы.НомерСтроки
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|// Запрос 5: ВыборкаКлиентов
	|ВЫБРАТЬ
	|	ОстаткиПоКлиентам.Количество КАК Unit,
	|	ОстаткиПоКлиентам.ЦеннаяБумага.ISIN КАК Isin,
	|	ОстаткиПоКлиентам.ЦеннаяБумага.Наименование КАК SecName,
	|	ВЫБОР
	|		КОГДА ОстаткиПоКлиентам.ЦеннаяБумага.ВидЦБ = &ВидыАкцийОбыкновенная
	|			ТОГДА ""Ordinary""
	|		ИНАЧЕ ""Preference""
	|	КОНЕЦ КАК SecType,
	|	КодыЗагрузки.Код КАК SecCode,
	|	ОстаткиПоКлиентам.ClientId КАК ClientId,
	|	ОстаткиПоКлиентам.ЦеннаяБумага.НомерРегистрации КАК GosRegNumber,
	|	ЕСТЬNULL(НоминалЦБСрезПоследних.Сумма, 0) КАК NominalValue,
	|	ОстаткиПоКлиентам.ЦеннаяБумага.ВалютаНоминала.Наименование КАК NominalCurrency,
	|	0 КАК StakeToParticipate,
	|	ОстаткиПоКлиентам.Количество КАК VoteNb
	|ИЗ
	|	втОстаткиПоКлиентам КАК ОстаткиПоКлиентам
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.КодыЗагрузки КАК КодыЗагрузки
	|		ПО ОстаткиПоКлиентам.ЦеннаяБумага = КодыЗагрузки.Владелец
	|			И (КодыЗагрузки.Биржа = &НДЦ)
	|			И (НЕ КодыЗагрузки.ПометкаУдаления)
	|			И (КодыЗагрузки.ДатаОкончанияДействия = ДАТАВРЕМЯ(1, 1, 1)
	|				ИЛИ КодыЗагрузки.ДатаОкончанияДействия > &ДатаДокумента)
	|
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.НоминалЦБ.СрезПоследних КАК НоминалЦБСрезПоследних
	|		ПО ОстаткиПоКлиентам.ЦеннаяБумага = НоминалЦБСрезПоследних.ЦеннаяБумага
	|ИТОГИ
	|	СУММА(Unit),
	|	СУММА(VoteNb)
	|ПО
	|	ClientId";
КонецФункции

