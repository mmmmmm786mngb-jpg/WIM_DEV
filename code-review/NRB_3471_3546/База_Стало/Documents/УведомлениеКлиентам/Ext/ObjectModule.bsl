Функция ОтправитьУведомлениеИнформационноеДляСубброкеров(ЗаголовокСообщения, ТекстСообщения, Клиенты, ОбработкаВебСервисы)
	Если Клиенты.Количество() = 0 Тогда
		СообщитьОбОшибке("Нет данных для отправки.");
		Возврат Ложь;
	КонецЕсли;
	
	СпискиКлиентов = КлиентыСКлассификациейПоСубброкеру(Клиенты);
	Успешно = Истина;
	
	Если СпискиКлиентов.Субброкеры.Количество() > 0 Тогда
		ТекстСубброкера = СтрЗаменить(ТекстСообщения, "#ИнформацияДляСубброкера#",
			"<p>По данному корпоративному действию необходимо предоставить информацию о владельцах ценных бумаг на дату фиксации для выплаты дохода.</p>");
		Если НЕ ОтправитьУведомлениеИнформационное(ЗаголовокСообщения, ТекстСубброкера, СпискиКлиентов.Субброкеры,
					ОбработкаВебСервисы) Тогда
			Успешно = Ложь;
		КонецЕсли;
	КонецЕсли;
	
	Если СпискиКлиентов.Клиенты.Количество() > 0 Тогда
		ТекстКлиента = СтрЗаменить(ТекстСообщения, "#ИнформацияДляСубброкера#", "");
		Если НЕ ОтправитьУведомлениеИнформационное(ЗаголовокСообщения, ТекстКлиента, СпискиКлиентов.Клиенты,
					ОбработкаВебСервисы) Тогда
			Успешно = Ложь;
		КонецЕсли;
	КонецЕсли;
	
	Возврат Успешно;
КонецФункции

Функция ПодготовитьУведомлениеИнформационноеДляСубброкеров(ОбъектJSON, Клиенты, ВнешнийИсточник)
	Если Клиенты.Количество() = 0 Тогда
		СообщитьОбОшибке("Нет данных для отправки.");
		Возврат Ложь;
	КонецЕсли;
	
	СпискиКлиентов = КлиентыСКлассификациейПоСубброкеру(Клиенты);
	Успешно = Истина;
	
	Если СпискиКлиентов.Субброкеры.Количество() > 0 Тогда
		Если НЕ ПодготовитьУведомлениеИнформационное(ОбъектJSON, СпискиКлиентов.Субброкеры, ВнешнийИсточник) Тогда
			Успешно = Ложь;
		КонецЕсли;
	КонецЕсли;
	
	Если СпискиКлиентов.Клиенты.Количество() > 0 Тогда
		Если НЕ ПодготовитьУведомлениеИнформационное(ОбъектJSON, СпискиКлиентов.Клиенты, ВнешнийИсточник) Тогда
			Успешно = Ложь;
		КонецЕсли;
	КонецЕсли;
	
	Возврат Успешно;
КонецФункции

Функция КлиентыСКлассификациейПоСубброкеру(ВсеКлиенты)
	Субброкеры = ВсеКлиенты.СкопироватьКолонки();
	Клиенты = ВсеКлиенты.СкопироватьКолонки();
	
	Для Каждого Строка Из ВсеКлиенты Цикл
		Если Строка.Субброкер Тогда
			НоваяСтрока = Субброкеры.Добавить();
		Иначе
			НоваяСтрока = Клиенты.Добавить();
		Конецесли;
		ЗаполнитьЗначенияСвойств(НоваяСтрока, Строка);
	КонецЦикла;
	
	Возврат Новый Структура("Субброкеры, Клиенты", Субброкеры, Клиенты);
КонецФункции

Процедура ОтправитьСвязанныеЗапросыСубброкеруНаРаскрытие()
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	ЗапросСубброкеруНаРаскрытие.Ссылка КАК Ссылка,
	|	ЗапросСубброкеруНаРаскрытие.Клиент.Наименование КАК КлиентНаименование,
	|	ЗапросСубброкеруНаРаскрытие.СчетДЕПО.НомерДепозитарногоДоговора КАК НомерДепозитарногоДоговора
	|ИЗ
	|	Документ.ЗапросСубброкеруНаРаскрытие КАК ЗапросСубброкеруНаРаскрытие
	|ГДЕ
	|	ЗапросСубброкеруНаРаскрытие.Статус = &Статус
	|	И ЗапросСубброкеруНаРаскрытие.УведомлениеКлиентам = &УведомлениеКлиентам
	|	И НЕ ЗапросСубброкеруНаРаскрытие.ПометкаУдаления");
	
	Запрос.УстановитьПараметр("УведомлениеКлиентам", Ссылка);
	Запрос.УстановитьПараметр("Статус", Перечисления.СтатусыДокументаЗапросСубброкеруНаРаскрытие.Сформирован);
	Результат = Запрос.Выполнить();
	Если Результат.Пустой() Тогда 
		Возврат;
	КонецЕсли;
	
	Выборка = Результат.Выбрать();
	Пока Выборка.Следующий() Цикл 
		ЗапросСубброкера = Выборка.Ссылка.ПолучитьОбъект();
		ЗапросСубброкера.Отправить();
		Если ЗапросСубброкера.Статус = Перечисления.СтатусыДокументаЗапросСубброкеруНаРаскрытие.Отправлен Тогда 
			ТекстСообщения = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку("Отправлен запрос субброкеру на раскрытие %1 %2 по клиенту %3 %4",
			ЗапросСубброкера.Номер, ЗапросСубброкера.Дата,Выборка.КлиентНаименование, Выборка
			.НомерДепозитарногоДоговора);
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

Процедура ЗаполнитьMessageId(Клиенты)
	
	Клиенты.Колонки.Добавить("MessageId");
	Для Каждого СтрокаТЗ Из Клиенты Цикл
		СтрокаТЗ.MessageId = Строка(Новый УникальныйИдентификатор());
	КонецЦикла;

КонецПроцедуры

