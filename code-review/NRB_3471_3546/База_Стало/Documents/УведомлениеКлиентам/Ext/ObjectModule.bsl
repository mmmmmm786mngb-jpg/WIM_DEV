// ВЫГРУЗКА УВЕДОМЛЕНИЙ О КД

// Вызываемый метод Web-сервиса выполняет функции:
// 1. рассылает сообщение клиентам по эл.почте;
// 2. публикует сообщение в кабинете клиента;
// 3. создает в кабинете клиента форму поручения для участия в выкупе.
//
// В теле сообщения может содержаться маркер, который на стороне Web-сервиса заменяется на ссылку для участия в выкупе.
//
// Параметры:
//	ЗаголовокСообщения - простая строка
//	ТекстСообщения - строка HTML
//	Клиенты - таблица значений с данными клиентов для рассылки
//
// Возвращаемое значение:
//	Истина, если рассылка успешна, иначе Ложь
//
Функция ОтправитьУведомлениеПоВыкупам(ЗаголовокСообщения, ТекстСообщения, Клиенты, ОбработкаВебСервисы)
	Если Клиенты.Количество() = 0 Тогда
		СообщитьОбОшибке("Нет данных для отправки.");
		Возврат Ложь;
	КонецЕсли;
	
	ЗаменитьМаркерНаСсылкуДляУчастия(ТекстСообщения, СсылкаДляУчастияВКД);
	
	Запрос = Новый Запрос(ТекстЗапросаДляСообщенияTendBids());
	ЗаполнитьПараметрыЗапроса(Запрос, Клиенты);
	Результат = Запрос.ВыполнитьПакет();
	
	РезультатЗапросаПоДокументуКД = Результат[3];
	ТаблицаОпций = Результат[4].Выгрузить();
	РезультатЗапросаПоКлиентам = Результат[5];	
	
	ОпубликованоУспешно = ВебСервисыСервер.РезультатОтправкиУведомленияПоВыкупам(ТаблицаОпций,
		РезультатЗапросаПоКлиентам, РезультатЗапросаПоДокументуКД, ЗаголовокСообщения, ТекстСообщения,
		Строка(Ссылка.УникальныйИдентификатор()), ОбработкаВебСервисы);
	
	Возврат ОпубликованоУспешно;
КонецФункции

// Вызываемый метод Web-сервиса выполняет функции:
// 1. рассылает сообщение клиентам по эл.почте;
// 2. публикует сообщение в кабинете клиента;
// 3. создает страницу для голосования в кабинете клиента.
//
// В теле сообщения может содержаться маркер, который на стороне Web-сервиса заменяется на ссылку для голосования.
//
// Параметры:
//	ЗаголовокСообщения - простая строка
//	ТекстСообщения - строка HTML
//	Клиенты - таблица значений с данными клиентов для рассылки
//
// Возвращаемое значение:
//	Истина, если рассылка успешна, иначе Ложь
//
Функция ОтправитьУведомлениеПоСобраниям(ЗаголовокСообщения, ТекстСообщения, Клиенты, ОбработкаВебСервисы)
	Если Клиенты.Количество() = 0 Тогда
		СообщитьОбОшибке("Нет данных для отправки.");
		Возврат Ложь;
	КонецЕсли;
	
	ЗаменитьМаркерНаСсылкуДляУчастия(ТекстСообщения, СсылкаДляУчастияВКД);					
	
	Запрос = Новый Запрос(ТекстЗапросаДляСообщенияMeet());
	ЗаполнитьПараметрыЗапроса(Запрос, Клиенты);
	Результат = Запрос.ВыполнитьПакет();
	
	РезультатЗапросаПоДокументуКД	= Результат[3];
	РезультатЗапросаПоВопросам		= Результат[4];
	РезультатЗапросаПоКлиентам		= Результат[5];
	
	ОпубликованоУспешно = ВебСервисыСервер.РезультатОтправкиУведомленияПоСобраниям(РезультатЗапросаПоКлиентам,
		РезультатЗапросаПоВопросам, РезультатЗапросаПоДокументуКД,
		ЗаголовокСообщения, ТекстСообщения, Строка(Ссылка.УникальныйИдентификатор()), ОбработкаВебСервисы);
	
	Если ОпубликованоУспешно Тогда
		ЭтотОбъект.СозданаСтраницаГолосованияВКабинетеКлиента = Истина;	
	КонецЕсли;
	
	Возврат ОпубликованоУспешно;
КонецФункции

// Вызываемый метод Web-сервиса выполняет функции:
// 1. рассылает сообщение клиентам по эл.почте
// 2. публикует сообщение в кабинете клиента
//
// Параметры:
//	ЗаголовокСообщения - простая строка
//	ТекстСообщения - строка HTML
//	Клиенты - таблица значений с данными клиентов для рассылки
//
// Возвращаемое значение:
//	Истина, если рассылка успешна, иначе Ложь
//
Функция ОтправитьУведомлениеИнформационное(ЗаголовокСообщения, ТекстСообщения, Клиенты, ОбработкаВебСервисы,
		Маркер = "")
		
	Если Клиенты.Количество() = 0 Тогда
		СообщитьОбОшибке("Нет данных для отправки.");
		Возврат Ложь;
	КонецЕсли;
	
	ЗаменитьМаркерНаСсылкуДляУчастия(ТекстСообщения, Маркер);
	
	// Каждое сообщение должно быть опубликовано в кабинете клиента только 1 раз
	Если Ссылка = Документы.УведомлениеКлиентам.ПустаяСсылка() Тогда 
		Идентификатор = Строка(ПолучитьСсылкуНового().УникальныйИдентификатор());
	Иначе 
		Идентификатор = Строка(Ссылка.УникальныйИдентификатор());
	КонецЕсли;
	Если СтрНайти(ТекстСообщения, "<ИнформацияДляКлиентовИНД>") > 0 Тогда
		ТипыСчетовИНД = БизнесПроцессы.ОбработкаWTRCСообщения.ТипыСчетовИНД();
		ИдентификаторыКлиентовИНД = Новый Массив;
		ИдентификаторыКлиентовНеИНД = Новый Массив;
		Для Каждого Клиент Из Клиенты Цикл
			ClientId = СокрЛП(Клиент.ClientId);
			Если ТипыСчетовИНД.Найти(Клиент.СчетДепо.ТипСчетаДепо) = Неопределено Тогда
				ИдентификаторыКлиентовНеИНД.Добавить(ClientId);
			Иначе
				ИдентификаторыКлиентовИНД.Добавить(ClientId);
			КонецЕсли;
		КонецЦикла;
		Если ИдентификаторыКлиентовИНД.Количество() > 0 Тогда
			ТекстСообщенияИНД = ЗаменитьТекстУведомленияДляИНД(ТекстСообщения);
			ОпубликованоУспешноИНД = ВебСервисыСервер.РезультатОтправкиУведомленияИнформационного(ИдентификаторыКлиентовИНД,
				ЗаголовокСообщения, ТекстСообщенияИНД, Идентификатор, ОбработкаВебСервисы);
		Иначе
			ОпубликованоУспешноИНД = Истина;	
		КонецЕсли;
			
		Если ИдентификаторыКлиентовНеИНД.Количество() > 0 Тогда
			ТекстСообщения = СтрЗаменить(ТекстСообщения, "<ИнформацияДляКлиентовИНД>", "");
			ОпубликованоУспешноНеИНД = ВебСервисыСервер.РезультатОтправкиУведомленияИнформационного(ИдентификаторыКлиентовНеИНД,
				ЗаголовокСообщения, ТекстСообщения, Идентификатор, ОбработкаВебСервисы);
		Иначе
			ОпубликованоУспешноНеИНД = Истина;	
		КонецЕсли;
			
		ОпубликованоУспешно = ОпубликованоУспешноИНД И ОпубликованоУспешноНеИНД;	
		
	Иначе
		ТаблицаКлиентов = Клиенты.Скопировать(, "ClientId");
		ТаблицаКлиентов.Свернуть("ClientId");
		ИдентификаторыКлиентов = ТаблицаКлиентов.ВыгрузитьКолонку("ClientId");
	
		
		ОпубликованоУспешно = ВебСервисыСервер.РезультатОтправкиУведомленияИнформационного(ИдентификаторыКлиентов,
			ЗаголовокСообщения, ТекстСообщения, Идентификатор, ОбработкаВебСервисы);

	КонецЕсли;
	Возврат ОпубликованоУспешно;
КонецФункции

Функция ПодготовитьУведомлениеИнформационное(ОбъектJSON, Клиенты, ВнешнийИсточник, Маркер = "")
		
	Если Клиенты.Количество() = 0 Тогда
		СообщитьОбОшибке("Нет данных для отправки.");
		Возврат Ложь;
	КонецЕсли;
	
	ЗаменитьМаркерНаСсылкуДляУчастия(ОбъектJSON, Маркер);
	Если Клиенты.Колонки.Найти("СпособОтправкиОтчетов") = Неопределено Тогда
		Клиенты.Колонки.Добавить("СпособОтправкиОтчетов");
	КонецЕсли;
	
	Если ОбъектJSON.Data.ReplaceFields.Свойство("ИнформацияДляКлиентовИНД") Тогда
		ТипыСчетовИНД = БизнесПроцессы.ОбработкаWTRCСообщения.ТипыСчетовИНД();
		ИдентификаторыКлиентовИНД = Новый Массив;
		ИдентификаторыКлиентовНеИНД = Новый Массив;
		Для Каждого ДанныеКлиента Из Клиенты Цикл
			ДанныеКлиента.ClientId = СокрЛП(ДанныеКлиента.ClientId);
			ДанныеКлиента.СпособОтправкиОтчетов = ДанныеКлиента.Клиент.СпособОтправкиОтчетов;
			ИдентификаторыКлиента = ЗаполненныеДанныеКлиента(ДанныеКлиента);

			Если ТипыСчетовИНД.Найти(ДанныеКлиента.СчетДепо.ТипСчетаДепо) = Неопределено Тогда
				ИдентификаторыКлиентовНеИНД.Добавить(ИдентификаторыКлиента);
			Иначе
				ИдентификаторыКлиентовИНД.Добавить(ИдентификаторыКлиента);
			КонецЕсли;
		КонецЦикла;
		Если ИдентификаторыКлиентовИНД.Количество() > 0 Тогда
			ЗаменитьИнформацияДляКлиентовИНД(ОбъектJSON);
			Для Каждого ИдентификаторыКлиента Из ИдентификаторыКлиентовИНД Цикл
				Документы.УведомлениеКлиентам.ПоместитьСообщениеВРегистрКОтправке(ВнешнийИсточник, ИдентификаторыКлиента, ОбъектJSON, Ссылка);
			КонецЦикла;
		КонецЕсли;
			
		Если ИдентификаторыКлиентовНеИНД.Количество() > 0 Тогда
			ЗаменитьИнформацияДляКлиентовИНД(ОбъектJSON, "");
			Для Каждого ИдентификаторыКлиента Из ИдентификаторыКлиентовНеИНД Цикл
				Документы.УведомлениеКлиентам.ПоместитьСообщениеВРегистрКОтправке(ВнешнийИсточник, ИдентификаторыКлиента, ОбъектJSON, Ссылка);
			КонецЦикла;
		КонецЕсли;
	Иначе
		ИдентификаторыКлиентов = Новый Массив;
		Для Каждого ДанныеКлиента Из Клиенты Цикл
			ДанныеКлиента.СпособОтправкиОтчетов = ДанныеКлиента.Клиент.СпособОтправкиОтчетов;
			ИдентификаторыКлиента = ЗаполненныеДанныеКлиента(ДанныеКлиента);
			ИдентификаторыКлиентов.Добавить(ИдентификаторыКлиента);
		КонецЦикла;
		Для Каждого ИдентификаторыКлиента Из ИдентификаторыКлиентов Цикл
			Документы.УведомлениеКлиентам.ПоместитьСообщениеВРегистрКОтправке(ВнешнийИсточник, ИдентификаторыКлиента, ОбъектJSON, Ссылка);
		КонецЦикла;
	КонецЕсли;
	
	Возврат Истина;
	
КонецФункции

Функция ЗаполненныеДанныеКлиента(ДанныеКлиента)
	
	ИдентификаторыКлиента = Новый Структура("ClientId, MessageId, Имя, Фамилия, НомерДоговора, ДатаДоговора, СпособОтправкиОтчетов");
	ЗаполнитьЗначенияСвойств(ИдентификаторыКлиента, ДанныеКлиента);
	Возврат ИдентификаторыКлиента;

КонецФункции

// Вызываемый метод Web-сервиса выполняет функции:
// 1. рассылает сообщение клиентам по эл.почте;
// 2. публикует сообщение в кабинете клиента;
// 3. создает в кабинете клиента форму поручения для участия в выкупе.
//
// В теле сообщения может содержаться маркер, который на стороне Web-сервиса заменяется на ссылку для участия
//
// Параметры:
//	ЗаголовокСообщения - простая строка
//	ТекстСообщения - строка HTML
//	Клиенты - таблица значений с данными клиентов для рассылки
//
// Возвращаемое значение:
//	Истина, если рассылка успешна, иначе Ложь
//
Функция ОтправитьУведомлениеПоВозвратуЧастиНалога(ЗаголовокСообщения, ТекстСообщения, Клиенты, ОбработкаВебСервисы, ВидКД)
	Если Клиенты.Количество() = 0 Тогда
		СообщитьОбОшибке("Нет данных для отправки.");
		Возврат Ложь;
	КонецЕсли;
	
	ЗаменитьМаркерНаСсылкуДляУчастия(ТекстСообщения, СсылкаДляУчастияВКД);
	
	Запрос = Новый Запрос(ТекстЗапросаДляСообщенияTrec());
	ЗаполнитьПараметрыЗапроса(Запрос, Клиенты);
	Результат = Запрос.ВыполнитьПакет();
	
	РезультатЗапросаПоДокументуКД = Результат[3];
	ТаблицаКлиентов = Результат[4].Выгрузить();
	
	ОпубликованоУспешно = ВебСервисыСервер.РезультатОтправкиУведомленияПоВозвратуЧастиНалога(ТаблицаКлиентов,
		РезультатЗапросаПоДокументуКД, ЗаголовокСообщения, ТекстСообщения, Строка(Ссылка.УникальныйИдентификатор()), ВидКД,
		ОбработкаВебСервисы);
	
	Возврат ОпубликованоУспешно;
КонецФункции

