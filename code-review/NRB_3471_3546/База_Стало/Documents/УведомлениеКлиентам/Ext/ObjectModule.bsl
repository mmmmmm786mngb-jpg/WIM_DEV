Функция ТекстСообщенияОПроведенииКД_ВыкупПриобретениеЦБ()
	// {Обязательный блок}
	Текст =
	"<p>Уведомляем Вас о том, что в %1 поступила информация о проведении корпоративного действия
	|""%2"" %3 - %4 (%5, Референс КД %6).</p>";
	Текст = СтрЗаменить(Текст, "%1", мНаименованиеДепозитария);
	Текст = СтрЗаменить(Текст, "%2", ФорматОбязательнойСтроки(ВидКД.Наименование, "ВидКД"));
	Текст = СтрЗаменить(Текст, "%3", ПредставлениеНомераСтатьи());
	Текст = СтрЗаменить(Текст, "%4", Справочники.ЦенныеБумаги.НаименованиеЭмитента(ЦеннаяБумага1));
	Текст = СтрЗаменить(Текст, "%5", ХарактеристикиЦБ());
	Текст = СтрЗаменить(Текст, "%6", ФорматОбязательнойСтроки(КДРеференс, "КДРеференс"));
	
	Если ЗначениеЗаполнено(ПредставлениеПериодаПроведения()) Тогда
		Текст = Текст + "
		|<p>%1</p>";
		Текст = СтрЗаменить(Текст, "%1", ПредставлениеПериодаПроведения());
	КонецЕсли;
	
	// {Опциональный блок, для КД типа BIDS, TEND}
	Если ВидимостьГруппы_ИнициаторВыкупа() Тогда
		Текст = Текст + "
		|<p>Инициатор выкупа: %1</p>
		|<p>Цена предложения за 1 ц/б: %2</p>
		|<p>Дата проведения корпоративного действия в реестре: %3</p>";
		Текст = СтрЗаменить(Текст, "%1", ФорматОбязательнойСтроки(ИнициаторВыкупа, "ИнициаторВыкупа"));
		Текст = СтрЗаменить(Текст, "%2", ФорматОбязательнойСуммыСВалютой(ВыплатаНа1ЦБ, ВалютаПлатежа, "ЦенаПредложения"));
		Текст = СтрЗаменить(Текст, "%3", ?(ЗначениеЗаполнено(ДатаКДРеестр), ФорматДаты(ДатаКДРеестр), ФорматДаты(ТекущаяДатаСеанса())));
	КонецЕсли;
		
	// {Опциональный блок, для КД типа PRIO}	
	Если ВидимостьГруппы_ЦенаРазмещения() Тогда
		Текст = Текст + "
		|<p>Цена размещения: %1</p>";
		Текст = СтрЗаменить(Текст, "%1", ФорматОбязательнойСуммыСВалютой(ЦенаРазмещения,
			ВалютаЦеныРазмещения, "ЦенаРазмещения"));
	КонецЕсли;
	
	// {Опциональный блок, для КД типа BPUT}
	Если ВидимостьДатаКДПлан_ВыкупПриобретениеЦБ() Тогда
		Текст = Текст + "
		|<p>Плановая дата проведения корпоративного действия: %1</p>";
		Текст = СтрЗаменить(Текст, "%1", ФорматОбязательнойДатыСоВременем(ДатаКДПлан, "ДатаКДПлан_ВыкупПриобретениеЦБ"));
	КонецЕсли;
	
	// {Опциональный блок, только для КД иностранных эмитентов }
	Если НЕ Справочники.ЦенныеБумаги.ЭтоБумагаРоссийскогоЭмитента(ЦеннаяБумага1) Тогда
		Текст = Текст + "
		|<p>Признак обязательности КД: %1</p>";
		Текст = СтрЗаменить(Текст, "%1", ПредставлениеПризнакаОбязательностиКД("ПризнакОбязательностиКД_ВыкупПриобретениеЦБ"));
	КонецЕсли;
	
	// {Опциональный блок, при наличии данных}
	Если ЗначениеЗаполнено(ДатаФиксацииВыкупаПриобретенияЦБ()) Тогда
		Текст = Текст + "
		|<p>Дата фиксации: %1</p>";
		Текст = СтрЗаменить(Текст, "%1", ДатаФиксацииВыкупаПриобретенияЦБ());
	КонецЕсли;
	
	// {Опциональный блок, при наличии возможности участия КД}
	Текст = Текст + Символы.ПС + "#СсылкаДляУчастияВКорпоративномДействии#";	// Этот маркер заменяется на ссылку при отправке уведомления
	
	Текст = Текст + "
	|<p>Дата окончания приема заявлений: %1</p>";
	Если ВидКД.Код = "BPUT" Тогда
		Если ЗначениеЗаполнено(ДатаОкончанияПериода) Тогда
			ДатаОкончанияПриемаЗаявлений = КонецДня(Документы.УведомлениеКлиентам.ДобавитьРабочийДень(ДатаОкончанияПериода, -2));
		Иначе
			ДатаОкончанияПриемаЗаявлений = ФорматОбязательнойДатыСоВременем('00010101', "ДатаОкончанияПериодаПроведения");
		КонецЕсли;
	Иначе
		ДатаОкончанияПриемаЗаявлений = ФорматОбязательнойДатыСоВременем(?(ЗначениеЗаполнено(ДатаОкончанияГолосования),
			ДатаОкончанияГолосования, ПоследнийСрокРынка), "ПоследнийСрокРынка");
	КонецЕсли;
	Текст = СтрЗаменить(Текст, "%1", ДатаОкончанияПриемаЗаявлений);
	
	// {Опциональный блок, при наличии связанного КД типа собрание}
	Если ЗначениеЗаполнено(КДРеференсСвязанныйСобрание) Тогда
		Текст = Текст + "
		|<p>Референс связанного КД ""Общее собрание владельцев"": %1</p>";
		Текст = СтрЗаменить(Текст, "%1", КДРеференсСвязанныйСобрание);
	КонецЕсли;
	
	// {Опциональный блок, только при наличии ссылки}
	Если ЗначениеЗаполнено(АдресВСетиИнтернет) Тогда
		Текст = Текст + "
		|<p>С деталями корпоративного действия Вы можете ознакомиться по ссылке: %1</p>";
		Текст = СтрЗаменить(Текст, "%1", ПредставлениеСсылки(АдресВСетиИнтернет));
	КонецЕсли;
	
	Возврат Текст;
КонецФункции

Функция ТекстСообщенияОПроведенииКД_КонвертацияОбменЦБ()
	// {Обязательный блок}
	Текст =
	"<p>Уведомляем Вас о том, что в %1 поступила информация о проведении корпоративного действия
	|""%2"" - %3 (%4, Референс КД %5).</p>
	|<p>Дата конвертации: %6</p>";
	Текст = СтрЗаменить(Текст, "%1", мНаименованиеДепозитария);
	Текст = СтрЗаменить(Текст, "%2", ФорматОбязательнойСтроки(ВидКД.Наименование, "ВидКД"));
	Текст = СтрЗаменить(Текст, "%3", Справочники.ЦенныеБумаги.НаименованиеЭмитента(ЦеннаяБумага1));
	Текст = СтрЗаменить(Текст, "%4", ХарактеристикиЦБ());
	Текст = СтрЗаменить(Текст, "%5", ФорматОбязательнойСтроки(КДРеференс, "КДРеференс"));
	Текст = СтрЗаменить(Текст, "%6", ФорматОбязательнойДаты(ДатаКДРеестр, "ДатаКДРеестр_КонвертацияОбменЦБ"));
	
	// {Опциональный блок, только для КД иностранных эмитентов}
	Если НЕ Справочники.ЦенныеБумаги.ЭтоБумагаРоссийскогоЭмитента(ЦеннаяБумага1) Тогда
		Текст = Текст + "
		|<p>Признак обязательности КД: %1</p>";
		Текст = СтрЗаменить(Текст, "%1", ПредставлениеПризнакаОбязательностиКД("ПризнакОбязательностиКД_КонвертацияОбменЦБ"));
	КонецЕсли;
	
	// {Опциональный блок, только для КД типов SPLF, SPLR, DECR, EXOF}
	Если ВидимостьДатаФиксации_КонвертацияОбменЦБ() Тогда
		Если Справочники.ЦенныеБумаги.ЭтоБумагаРоссийскогоЭмитента(ЦеннаяБумага1) Тогда
			Текст = Текст + "
			|<p>Дата фиксации: %1</p>";
			Текст = СтрЗаменить(Текст, "%1", ФорматОбязательнойДаты(ДатаФиксации, "ДатаФиксации_КонвертацияОбменЦБ"));
			ДатаФиксацииОбязательна = Истина;
			
		ИначеЕсли ЗначениеЗаполнено(ДатаФиксации) Тогда
			Текст = Текст + "
			|<p>Дата фиксации: %1</p>";
			Текст = СтрЗаменить(Текст, "%1", ФорматДаты(ДатаФиксации));
		КонецЕсли;
	КонецЕсли;

	// {Опциональный блок, только для КД только для SPLF, SPLR, INCR}
	Если ВидимостьНовыйНоминалАкций() И НовыйНоминалАкций <> 0 Тогда
		Текст = Текст + "
		|<p>Новый номинал акций: %1</p>";
		Текст = СтрЗаменить(Текст, "%1", НовыйНоминалАкций);
	КонецЕсли;
	
	// {Опциональный блок, при наличии данных}
	Если ЗначениеЗаполнено(КоэффициентКонвертации) Тогда
		Текст = Текст + "
		|<p>Коэффициент: %1</p>";
		Текст = СтрЗаменить(Текст, "%1", КоэффициентКонвертации);
	КонецЕсли;
	
	// {Опциональный блок, при наличии данных}
	Если ЗначениеЗаполнено(ПравилоОкругления) Тогда
		Текст = Текст + "
		|<p>Правило округления:<br/>
		|%1</p>";
		Текст = СтрЗаменить(Текст, "%1", ПравилоОкругления);
	КонецЕсли;

    // {Опциональный блок, в случае КД CONV (типа VOLU) для российского эмитента}
	Если ВидимостьГруппы_КрайнийСрокПриемаТребованийОКонвертации() Тогда
		// {Опциональный блок, при наличии возможности участия}
		Текст = Текст + Символы.ПС + "#СсылкаДляУчастияВКорпоративномДействии#";	// Этот маркер заменяется на ссылку при отправке уведомления
		
		Если ЗначениеЗаполнено(ДатаОкончанияГолосования) Тогда
			Текст = Текст + "
			|<p>Крайний срок приема требований о конвертации: %1</p>";
			Текст = СтрЗаменить(Текст, "%1", ФорматДаты(ДатаОкончанияГолосования));
		КонецЕсли;
	КонецЕсли;

	// {Опциональный блок, при наличии связанного КД типа собрание}
	Если ЗначениеЗаполнено(КДРеференсСвязанныйСобрание) Тогда
		Текст = Текст + "
		|<p>Референс связанного КД ""Общее собрание владельцев"": %1</p>";
		Текст = СтрЗаменить(Текст, "%1", КДРеференсСвязанныйСобрание);
	КонецЕсли;
	
	// {Опциональный блок, только при наличии ссылки}
	Если ЗначениеЗаполнено(АдресВСетиИнтернет) Тогда
		Текст = Текст + "
		|<p>С деталями корпоративного действия Вы можете ознакомиться по ссылке: %1</p>";
		Текст = СтрЗаменить(Текст, "%1", ПредставлениеСсылки(АдресВСетиИнтернет));
	КонецЕсли;
			
	Возврат Текст;	
КонецФункции

Функция ТекстСообщенияОПроведенииКД_ОбъединениеВыпусковЦБ()
	// {Обязательный блок}
	Текст =
	"<p>Уведомляем Вас о том, что в %1 поступила информация о проведении корпоративного действия
	|""%2"" - %3 (%4, Референс КД %5).</p>
	|<p>Дата проведения операции в реестре: %6</p>
	|<p>Дата проведения операции в НРД: %7</p>
	|<p>Объединяемые выпуски:<br/>
	|%8</p>
	|<p>Объединённый выпуск:
	|%9</p>";
	Текст = СтрЗаменить(Текст, "%1", мНаименованиеДепозитария);
	Текст = СтрЗаменить(Текст, "%2", НаименованиеКД_ОбъединениеВыпусковЦБ());
	Текст = СтрЗаменить(Текст, "%3", Справочники.ЦенныеБумаги.НаименованиеЭмитента(ЦеннаяБумага1));
	Текст = СтрЗаменить(Текст, "%4", ХарактеристикиЦБ_ОбъединениеВыпусковЦБ());
	Текст = СтрЗаменить(Текст, "%5", ФорматОбязательнойСтроки(КДРеференс, "КДРеференс"));
	Текст = СтрЗаменить(Текст, "%6", ФорматОбязательнойДаты(ДатаКДРеестр, "ДатаКДРеестр_ОбъединениеВыпусковЦБ"));
	Текст = СтрЗаменить(Текст, "%7", ФорматОбязательнойДаты(ДатаКДНРД, "ДатаКДНРД_ОбъединениеВыпусковЦБ"));
	Текст = СтрЗаменить(Текст, "%8", Выпуски_ОбъединениеВыпусковЦБ("DBIT"));
	Текст = СтрЗаменить(Текст, "%9", Выпуски_ОбъединениеВыпусковЦБ("CRDT"));
	
	Возврат Текст;
КонецФункции

Функция ТекстСообщенияОПроведенииКД_РеорганизацииОбщества()
	// {Обязательный блок}
	Текст =
	"<p>Уведомляем Вас о том, что в %1 поступила информация о проведении корпоративного действия
	|""%2"" - %3 (%4, Референс КД %5).</p>";
	Текст = СтрЗаменить(Текст, "%1", мНаименованиеДепозитария);
	Текст = СтрЗаменить(Текст, "%2", ФорматОбязательнойСтроки(ВидКД.Наименование, "ВидКД"));
	Текст = СтрЗаменить(Текст, "%3", Справочники.ЦенныеБумаги.НаименованиеЭмитента(ЦеннаяБумага1));
	Текст = СтрЗаменить(Текст, "%4", ХарактеристикиЦБ());
	Текст = СтрЗаменить(Текст, "%5", ФорматОбязательнойСтроки(КДРеференс, "КДРеференс"));
	
	Если Справочники.ЦенныеБумаги.ЭтоБумагаРоссийскогоЭмитента(ЦеннаяБумага1) Тогда
		Текст = Текст + "
		|<p>Размещённые ценные бумаги (ISIN): %1</p>
		|<p>Размещаемые ценные бумаги (ISIN): %2</p>";
		Текст = СтрЗаменить(Текст, "%1", СписокISINЦенныхБумаг("DBIT"));
		Текст = СтрЗаменить(Текст, "%2", СписокISINЦенныхБумаг("CRDT"));
	Иначе
		Текст = Текст + "
		|<p>Признак обязательности КД: %1</p>";
		Текст = СтрЗаменить(Текст, "%1", ПредставлениеПризнакаОбязательностиКД("ПризнакОбязательностиКД_РеорганизацииОбщества"));
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ДатаФиксации) ИЛИ ДатаФиксацииНеизвестна Тогда
		Текст = Текст + "
		|<p>Дата фиксации: %1</p>";
		Текст = СтрЗаменить(Текст, "%1", ?(ДатаФиксацииНеизвестна, "Неизвестна", ФорматДаты(ДатаФиксации)));
	КонецЕсли;

	Если ЗначениеЗаполнено(ДатаЕГРЮЛ) И ВидимостьДатаВнесенияЗаписиЕГРЮЛ() Тогда
		Текст = Текст + "
		|<p>Дата внесения записи ЕГРЮЛ: %1</p>";
		Текст = СтрЗаменить(Текст, "%1", ФорматДаты(ДатаЕГРЮЛ));
	КонецЕсли;
	
	Если (ЗначениеЗаполнено(ДатаКДРеестр) ИЛИ ДатаКДРеестрНеизвестна)
		И Справочники.ЦенныеБумаги.ЭтоБумагаРоссийскогоЭмитента(ЦеннаяБумага1) Тогда
		Текст = Текст + "
		|<p>Дата проведения операции в реестре: %1</p>";
		Текст = СтрЗаменить(Текст, "%1", ?(ДатаКДРеестрНеизвестна, "Неизвестна", ФорматДаты(ДатаКДРеестр)));
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ДатаКДНРД) ИЛИ ДатаКДНРДНеизвестна Тогда
		Текст = Текст + "
		|<p>Дата проведения операции в НРД: %1</p>";
		Текст = СтрЗаменить(Текст, "%1", ?(ДатаКДНРДНеизвестна, "Неизвестна", ФорматДаты(ДатаКДНРД)));
	КонецЕсли;
	
	Если ЗначениеЗаполнено(КоэффициентКонвертации) Тогда
		Текст = Текст + "
		|<p>Коэффициент конвертации (Количество новых ЦБ за имеющиеся): %1</p>";
		Текст = СтрЗаменить(Текст, "%1", КоэффициентКонвертации);
	КонецЕсли;
	
