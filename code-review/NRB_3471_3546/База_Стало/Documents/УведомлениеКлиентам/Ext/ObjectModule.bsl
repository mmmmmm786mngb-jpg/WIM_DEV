	ReplaceFields.Вставить("ДатаДоговора", "");
	Если ФормаСообщенияКК = Перечисления.ФормыСообщенийКК.УведомлениеОРегистрацииЗаявкиВУКПаи Тогда
		ReplaceFields.Вставить("ЗаголовокСообщения", ФормаСообщенияКК);
		ReplaceFields.Вставить("ТелоСообщения", "");
	ИначеЕсли ФормаСообщенияКК <> Перечисления.ФормыСообщенийКК.СвободнаяФорма Тогда
		ReplaceFields.Вставить("НаименованиеДепозитария", мНаименованиеДепозитария);
		ReplaceFields.Вставить("ВидКД", ФорматОбязательнойСтроки(ВидКД.Наименование, "ВидКД"));
		ReplaceFields.Вставить("НаименованиеЭмитента", Справочники.ЦенныеБумаги.НаименованиеЭмитента(ЦеннаяБумага1));
		ReplaceFields.Вставить("ХарактеристикиЦБ", ХарактеристикиЦБ());
		ReplaceFields.Вставить("КДРеференс", ФорматОбязательнойСтроки(КДРеференс, "КДРеференс"));
	Иначе
		ReplaceFields = Новый Структура;
	КонецЕсли;
	
	Data.Вставить("ReplaceFields", ReplaceFields);
	
	Результат.Вставить("MessageInfo", MessageInfo);
	Результат.Вставить("Data", Data);
	
	Возврат Результат;

КонецФункции

