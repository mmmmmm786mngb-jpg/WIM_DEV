Функция РезультатПодготовкиКОтправкеВЛКSendEmailToClients(ОбъектJSON, ПараметрыУведомления, ВнешнийИсточник = Неопределено) Экспорт
	
	ТекстСообщения = ТелоСообщения;
	Маркер = "#UrlToInstr#";
	ЗаменитьМаркерНаСсылкуДляУчастия(ТекстСообщения, Маркер);
	
	Клиенты = ПараметрыУведомления.ТаблицаКлиентов;
	Возврат ПодготовитьУведомлениеИнформационное(ОбъектJSON, Клиенты, ВнешнийИсточник);
КонецФункции

Функция РезультатОтправкиВЛКSendEmailToClients(ПараметрыУведомления, ОбработкаВебСервисы = Неопределено) Экспорт
	
	ТекстСообщения = ТелоСообщения;
	Маркер = "#UrlToInstr#";
	ЗаменитьМаркерНаСсылкуДляУчастия(ТекстСообщения, Маркер);
	
	Клиенты = ПараметрыУведомления.ТаблицаКлиентов;
	Возврат ОтправитьУведомлениеИнформационное(ЗаголовокСообщения, ТекстСообщения, Клиенты,
				ОбработкаВебСервисы);	
КонецФункции
			
Функция РезультатОтправкиВЛКCreateCorporateActionTrec(ПараметрыУведомления, ОбработкаВебСервисы = Неопределено)
	
	ТекстСообщения = СтрЗаменить(ТелоСообщения, WTRCСообщенияQI.БлокУведомленияУчастиеВКорпоративномДействии(), "#UrlToVote#");	
	Если Ссылка = Документы.УведомлениеКлиентам.ПустаяСсылка() Тогда 
		Идентификатор = Строка(ПолучитьСсылкуНового().УникальныйИдентификатор());
	Иначе 
		Идентификатор = Строка(Ссылка.УникальныйИдентификатор());
	КонецЕсли;
	РезультатЗапросаПоДокументуКД = БизнесПроцессы.ОбработкаWTRCСообщения.РезультатЗапросаПоДокументуКД(ДокументОснование);
	ТаблицаКлиентов = ПараметрыУведомления.ТаблицаКлиентов.Скопировать(,"Unit, Isin, SecType, SecName, SecCode, ClientId, GosRegNumber, NominalValue, NominalCurrency, StakeToParticipate");	
	КодКД = ВидКД.Код;
	КодКД = СтрЗаменить(КодКД,"WTRC","NTRC");
	Возврат ВебСервисыСервер.РезультатОтправкиУведомленияПоВозвратуЧастиНалога(ТаблицаКлиентов,
				РезультатЗапросаПоДокументуКД, ЗаголовокСообщения, ТекстСообщения, Идентификатор, КодКД,
				ОбработкаВебСервисы);	
КонецФункции
			

// BSLLS:CognitiveComplexity-off
// BSLLS:CyclomaticComplexity-off

// Процедура - Отправить уведомление
// Отправляет уведомление в кабинет клиента
// Параметры:
//  ОбработкаВебСервисы	 - Неопределено, Обработка.TEST_ВебСервисы	 	- Обработка используемая для вызова методов веб сервиса кабинета клиента, используется для тестирования при недоступности кабинета клиента
//  ПараметрыУведомления - Структура 									- Дополнительные параметры отправки уведомлений 
//
Процедура ОтправитьУведомление(ОбработкаВебСервисы = Неопределено, ПараметрыУведомления = Неопределено) Экспорт
	
	Записывать = Истина;
	Если Документы.УведомлениеКлиентам.СтатусРазрешенДляОтправки(Статус)
		И НЕ ПометкаУдаления
		И (ВидКД.СпособУведомления = Перечисления.СпособыУведомления.ЛичныйКабинет
			ИЛИ ФормаСообщенияКК = Перечисления.ФормыСообщенийКК.СвободнаяФорма) Тогда
		
		ТекущийМомент		= ТекущаяДата();
		ТекстСообщения		= ЭтотОбъект.ТелоСообщения;
		ГраницаДатыФиксации = Новый Граница(?(ЗначениеЗаполнено(ДатаФиксации), КонецДня(ДатаФиксации), КонецДня(ТекущаяДатаСеанса())),
			ВидГраницы.Включая);
		Успешно				= Ложь;
		ЦБПодпадаетПодНалоговоеРегулированиеСША = Справочники.ЦенныеБумаги.ЦБПодпадаетПодНалоговоеРегулированиеСША(ЦеннаяБумага1);
		
		Если Не ПараметрыУведомления = Неопределено Тогда 
		
			Записывать = Ложь;
			Успешно = Ложь;
			Если ФормаСообщенияКК = Перечисления.ФормыСообщенийКК.SendEmailToClients
				ИЛИ ФормаСообщенияКК = Перечисления.ФормыСообщенийКК.CreateCorporateActionWtrc Тогда
				
				Успешно = РезультатОтправкиВЛКSendEmailToClients(ПараметрыУведомления, ОбработкаВебСервисы);
				
			ИначеЕсли ФормаСообщенияКК = Перечисления.ФормыСообщенийКК.CreateCorporateActionTrec Тогда
				
				Успешно = РезультатОтправкиВЛКCreateCorporateActionTrec(ПараметрыУведомления, ОбработкаВебСервисы);
					
			КонецЕсли;
			
			Клиенты = ПараметрыУведомления.ТаблицаКлиентов.Скопировать(,
				"Клиент, Договор, СчетДепо, РазделСчетаДепо, ЦеннаяБумага, Количество");
		ИначеЕсли ФормаСообщенияКК = Перечисления.ФормыСообщенийКК.ОбИзмененииОстатковЦБ Тогда 
			
			Клиенты = СписокКлиентовСвязанныхЗапросовСубброкераДляУведомлений();
			Успешно = ОтправитьУведомлениеИнформационное(ЗаголовокСообщения, ТекстСообщения, Клиенты,
					ОбработкаВебСервисы);
			Если ВидКД.Код = "TREC" И Успешно Тогда 
				ОтправитьСвязанныеЗапросыСубброкеруНаРаскрытие();	
			КонецЕсли;
		ИначеЕсли ФормаСообщенияКК = Перечисления.ФормыСообщенийКК.УведомлениеОРегистрацииЗаявкиВУКПаи Тогда
			
			Клиенты = СписокКлиентовЗаявкиВУК();
			Успешно = ОтправитьУведомлениеИнформационное(ЗаголовокСообщения, ТекстСообщения, Клиенты,
					ОбработкаВебСервисы);
			
		ИначеЕсли Документы.УведомлениеКлиентам.ВидКДВСписке(ВидКД, "MEET, XMET, BMET, OMET") Тогда
			Если ФормаСообщенияКК = Перечисления.ФормыСообщенийКК.ОбОтменеКД
				ИЛИ ФормаСообщенияКК = Перечисления.ФормыСообщенийКК.ОбИтогахСобрания
				ИЛИ ФормаСообщенияКК = Перечисления.ФормыСообщенийКК.ОбОтменеСобрания Тогда
				
				Клиенты = КлиентыПоследнегоУведомленияНаОснованииКД(ДокументОснование);
				Успешно = ОтправитьУведомлениеИнформационное(ЗаголовокСообщения, ТекстСообщения, Клиенты,
					ОбработкаВебСервисы);
				
			ИначеЕсли НЕ ЗначениеЗаполнено(ДатаФиксации) ИЛИ ДатаФиксации > ТекущийМомент Тогда
				Клиенты = СписокКлиентовДляОтправкиУведомлений(ТекущийМомент);
				Успешно = ОтправитьУведомлениеИнформационное(ЗаголовокСообщения, ТекстСообщения, Клиенты,
					ОбработкаВебСервисы);
				
			Иначе
				Клиенты = СписокКлиентовДляОтправкиУведомлений(ГраницаДатыФиксации);
				Если ЕстьДанныеБюллетеня(ДокументОснование)
					И Справочники.ЦенныеБумаги.ЭтоБумагаРоссийскогоЭмитента(ЦеннаяБумага1) Тогда
					Если УжеСозданаСтраницаГолосованияВКабинетеКлиента() Тогда
						Успешно = ОбновитьДанныеСтраницыГолосования();
					Иначе
						Успешно = ОтправитьУведомлениеПоСобраниям(ЗаголовокСообщения, ТекстСообщения, Клиенты,
							ОбработкаВебСервисы);
					КонецЕсли;
				Иначе
					Успешно = ОтправитьУведомлениеИнформационное(ЗаголовокСообщения, ТекстСообщения, Клиенты,
						ОбработкаВебСервисы);
				КонецЕсли;
			Конецесли;
			
		ИначеЕсли ВидКД.Код = "TEND"
			И (ПризнакОбязательностиКД = Перечисления.ПризнакиОбязательностиКД.MAND ИЛИ НомерСтатьи = "L848") Тогда
			Если ФормаСообщенияКК = Перечисления.ФормыСообщенийКК.ОбОтменеКД Тогда
				Клиенты = КлиентыПоследнегоУведомленияНаОснованииКД(ДокументОснование);				
			ИначеЕсли НЕ ЗначениеЗаполнено(ДатаФиксации) ИЛИ ДатаФиксации > ТекущийМомент Тогда
				Клиенты = СписокКлиентовДляОтправкиУведомлений(ТекущийМомент);				
			Иначе
				Клиенты = СписокКлиентовДляОтправкиУведомлений(ГраницаДатыФиксации);
			Конецесли;
			// Участия в КД не предполагается
			Успешно = ОтправитьУведомлениеИнформационное(ЗаголовокСообщения, ТекстСообщения, Клиенты,
				ОбработкаВебСервисы);
			
		ИначеЕсли (ВидКД.Код = "BIDS" И НомерСтатьи = "L750")
				ИЛИ (ВидКД.Код = "BIDS" И НомерСтатьи = "L720")
				ИЛИ (ВидКД.Код = "BIDS" И НомерСтатьи = "")
				ИЛИ (ВидКД.Код = "TEND" И НомерСтатьи = "L841")
				ИЛИ (ВидКД.Код = "TEND" И НомерСтатьи = "L842")
				ИЛИ (ВидКД.Код = "TEND" И НомерСтатьи = "") Тогда
			
			Если ФормаСообщенияКК = Перечисления.ФормыСообщенийКК.ОбОтменеКД Тогда
				Клиенты = КлиентыПоследнегоУведомленияНаОснованииКД(ДокументОснование);
				Успешно = ОтправитьУведомлениеИнформационное(ЗаголовокСообщения, ТекстСообщения, Клиенты,
					ОбработкаВебСервисы);
				
			ИначеЕсли ДатаФиксации > ТекущийМомент Тогда
				Клиенты = СписокКлиентовДляОтправкиУведомлений(ТекущийМомент);
				Успешно = ОтправитьУведомлениеИнформационное(ЗаголовокСообщения, ТекстСообщения, Клиенты,
					ОбработкаВебСервисы);
				
			Иначе
				Клиенты = СписокКлиентовДляОтправкиУведомлений(ГраницаДатыФиксации);
				Если ЗначениеЗаполнено(СписокНезаполненныхОбязательныхПолей) Тогда
					Успешно = ОтправитьУведомлениеИнформационное(ЗаголовокСообщения, ТекстСообщения, Клиенты,
						ОбработкаВебСервисы);
				Иначе	// Все обязательные поля заполнены
					Успешно = ОтправитьУведомлениеПоВыкупам(ЗаголовокСообщения, ТекстСообщения, Клиенты,
						ОбработкаВебСервисы);
				КонецЕсли;
			Конецесли;
			
		ИначеЕсли ВидКД.Код = "BPUT" Тогда
			Если ФормаСообщенияКК = Перечисления.ФормыСообщенийКК.ОбОтменеКД Тогда
				Клиенты = КлиентыПоследнегоУведомленияНаОснованииКД(ДокументОснование);
			Иначе
				Клиенты = СписокКлиентовДляОтправкиУведомлений(ТекущийМомент);
			Конецесли;
			// Возможность участия в КД пока не реализована
			Успешно = ОтправитьУведомлениеИнформационное(ЗаголовокСообщения, ТекстСообщения, Клиенты,
				ОбработкаВебСервисы);
			
		ИначеЕсли ВидКД.Код = "PRIO" Тогда
			Если ФормаСообщенияКК = Перечисления.ФормыСообщенийКК.ОбОтменеКД Тогда
				Клиенты = КлиентыПоследнегоУведомленияНаОснованииКД(ДокументОснование);
			ИначеЕсли НЕ ЗначениеЗаполнено(ДатаФиксации) ИЛИ ДатаФиксации > ТекущийМомент Тогда
				Клиенты = СписокКлиентовДляОтправкиУведомлений(ТекущийМомент);
			Иначе
				Клиенты = СписокКлиентовДляОтправкиУведомлений(ГраницаДатыФиксации);
			Конецесли;
			// Возможность участия в КД пока не реализована
			Успешно = ОтправитьУведомлениеИнформационное(ЗаголовокСообщения, ТекстСообщения, Клиенты,
				ОбработкаВебСервисы);
			
		ИначеЕсли ВидКД.Код = "WTRC" И ЦБПодпадаетПодНалоговоеРегулированиеСША Тогда
			ПараметрыWebСервиса = ПараметрыWebСервисаДляСообщенияWTRC();
			Клиенты = ПараметрыWebСервиса.Данные.Скопировать(,
				"Клиент, Договор, СчетДепо, РазделСчетаДепо, ЦеннаяБумага, Количество");
			Успешно = Документы.УведомлениеКлиентам.СохранитьКорпоративноеДействиеWTRC(ПараметрыWebСервиса, Ссылка, ОбработкаВебСервисы);
			
		ИначеЕсли ВидКД.Код = "TREC" ИЛИ (ВидКД.Код = "WTRC" И НЕ ЦБПодпадаетПодНалоговоеРегулированиеСША) Тогда
			Если НЕ ЗначениеЗаполнено(ДатаФиксации) ИЛИ ДатаФиксации > ТекущийМомент Тогда
				МоментФормирования = КонецДня(ДатаСообщения);
			Иначе
				МоментФормирования = ГраницаДатыФиксации;
			Конецесли;
			КодКД = ВидКД.Код;
			КодКД = СтрЗаменить(КодКД,"WTRC","NTRC");
			
			Если ВидКД.Код = "WTRC" ИЛИ ФормаСообщенияКК = Перечисления.ФормыСообщенийКК.ОПроведенииКД_ВозвратЧастиНалога Тогда
				// Отправка уведомления с поручением в КК
				Если ВидКД.Код = "WTRC" ИЛИ НЕ WTRCСообщенияQI.ИспользоватьРегистрациюЗапросовСубброкера() Тогда
					// Отправка уведомления всем
					Клиенты = СписокКлиентовДляОтправкиУведомлений(МоментФормирования);
					Успешно = ОтправитьУведомлениеПоВозвратуЧастиНалога(ЗаголовокСообщения, ТекстСообщения, Клиенты,
					ОбработкаВебСервисы, КодКД);					
				КонецЕсли;
			ИначеЕсли WTRCСообщенияQI.ИспользоватьРегистрациюЗапросовСубброкера(Дата)
				И ФормаСообщенияКК = Перечисления.ФормыСообщенийКК.ОПроведенииКД_ВозвратЧастиНалогаНДИНД Тогда
				Клиенты = СписокКлиентовДляОтправкиУведомлений(МоментФормирования);
				Если АктивнаяСсылка Тогда
					Успешно = ОтправитьУведомлениеПоВозвратуЧастиНалога(ЗаголовокСообщения, ТекстСообщения, Клиенты,
					ОбработкаВебСервисы, КодКД);
				Иначе 
					Успешно = ОтправитьУведомлениеИнформационное(ЗаголовокСообщения, ТекстСообщения, Клиенты,
					ОбработкаВебСервисы);
				КонецЕсли;
			КонецЕсли;
			
			Если ВидКД.Код = "TREC" И Успешно Тогда 
				ОтправитьСвязанныеЗапросыСубброкеруНаРаскрытие();	
			КонецЕсли;
				
		ИначеЕсли ТребуетсяДобавитьИнформациюДляСубброкеров() Тогда
			Если НЕ ЗначениеЗаполнено(ДатаФиксации) ИЛИ ДатаФиксации > ТекущийМомент Тогда
				МоментФормирования = ТекущийМомент;
			Иначе
				МоментФормирования = ГраницаДатыФиксации;
			КонецЕсли;
			Клиенты = СписокКлиентовДляОтправкиУведомлений(МоментФормирования);
			Успешно = ОтправитьУведомлениеИнформационноеДляСубброкеров(ЗаголовокСообщения, ТекстСообщения, Клиенты,
				ОбработкаВебСервисы);
			
		ИначеЕсли Документы.УведомлениеКлиентам.ВидКДВСписке(ВидКД, "CHAN, OTHR") Тогда
			МоментФормирования = ТекущийМомент;
			Если ЗначениеЗаполнено(ДатаФиксации) и ДатаФиксации < ТекущийМомент Тогда				
				МоментФормирования = ГраницаДатыФиксации;
			КонецЕсли;

			Если ФормаСообщенияКК = Перечисления.ФормыСообщенийКК.ОбОтменеКД Тогда
				Клиенты = КлиентыПоследнегоУведомленияНаОснованииКД(ДокументОснование);
			Иначе
				Клиенты = СписокКлиентовДляОтправкиУведомлений(МоментФормирования);
			Конецесли;
			
			Успешно = ОтправитьУведомлениеИнформационное(ЗаголовокСообщения, ТекстСообщения, Клиенты,
				ОбработкаВебСервисы);
			
		ИначеЕсли ВидКД.Код = "DSCL" Тогда
			Если ЗначениеЗаполнено(ДатаФиксации) Тогда
				Если ДатаФиксации > ТекущийМомент Тогда
					МоментФормирования = ТекущийМомент;
				Иначе
					МоментФормирования = ГраницаДатыФиксации;
				КонецЕсли;
			Иначе
				МоментФормирования = ДатаСообщения;
			Конецесли;
			
			Если ФормаСообщенияКК = Перечисления.ФормыСообщенийКК.ОбОтменеКД Тогда
				Клиенты = КлиентыПоследнегоУведомленияНаОснованииКД(ДокументОснование);
			Иначе
				Клиенты = СписокКлиентовДляОтправкиУведомлений(МоментФормирования);
			Конецесли;
			
			Успешно = ОтправитьУведомлениеИнформационное(ЗаголовокСообщения, ТекстСообщения, Клиенты,
				ОбработкаВебСервисы, СсылкаДляУчастияВКД);
			
		Иначе
			Если НЕ ЗначениеЗаполнено(ДатаФиксации) ИЛИ ДатаФиксации > ТекущийМомент Тогда
				Клиенты = СписокКлиентовДляОтправкиУведомлений(ТекущийМомент);
			Иначе
				Клиенты = СписокКлиентовДляОтправкиУведомлений(ГраницаДатыФиксации);
			КонецЕсли;
			Успешно = ОтправитьУведомлениеИнформационное(ЗаголовокСообщения, ТекстСообщения, Клиенты,
				ОбработкаВебСервисы);
		КонецЕсли;
		
		Сообщение = Новый СообщениеПользователю;
		Если Успешно Тогда
			
			Если Ссылка = Документы.УведомлениеКлиентам.ПустаяСсылка() Тогда
				УведомлениеСсылка = ПолучитьСсылкуНового();
			Иначе 
				УведомлениеСсылка = Ссылка;
			КонецЕсли;
			
			РегистрацияУведомлений = WTRCСообщенияQI.КлиентыДляРегистрацииОтправленныхУведомлений(Клиенты);
			РегистрыСведений.УведомленияОтправленныеЧерезЛичныйКабинет.ЗафиксироватьУведомления(ТекущийМомент,
				УведомлениеСсылка, РегистрацияУведомлений);
			
			Запись = РегистрыСведений.ЭтапыКД.СоздатьМенеджерЗаписи();
			Запись.Период					= ТекущийМомент;
			Запись.КД						= УведомлениеСсылка;
			Запись.КодОтчета				= "";
			Запись.НомерСообщения			= "";
			Запись.НомерСообщенияИсходный	= "";
			Запись.Исходящее				= Истина;
			Запись.ТипУведомления			= Справочники.ТипыУведомления.NEWM();
			Запись.ЭтапКД					= Справочники.ЭтапыКД.УведомлениеКлиентов;
			Запись.Записать();
			
			ЭтотОбъект.Статус = Перечисления.СтатусыУведомленийКлиентам.Отправлено;
			Сообщение.Текст = "Отправлено: " + Ссылка;
		Иначе
			ЭтотОбъект.Статус = Перечисления.СтатусыУведомленийКлиентам.СбойОтправки;
			Сообщение.Текст = "Не отправлено: " + Ссылка;
		КонецЕсли;
		Если Записывать Тогда
			Сообщение.Сообщить();
			Записать();
		КонецЕсли;
	КонецЕсли;
		
КонецПроцедуры

Процедура ДоотправитьУведомлениеСубброкерам(Клиенты, ОбработкаВебСервисы = Неопределено) Экспорт
	Если Статус = Перечисления.СтатусыУведомленийКлиентам.Отправлено
		И НЕ ПометкаУдаления
		И ТребуетсяДобавитьИнформациюДляСубброкеров() Тогда
		ТекстСообщения = ЭтотОбъект.ТелоСообщения;
		Успешно = ОтправитьУведомлениеИнформационноеДляСубброкеров(ЗаголовокСообщения, ТекстСообщения, Клиенты,
			ОбработкаВебСервисы);
		Если Успешно Тогда
			РегистрыСведений.УведомленияОтправленныеЧерезЛичныйКабинет.ДобавитьКлиентов(ТекущаяДата(),
				Ссылка, Клиенты);
			ТекстСообщенияПользователю = "Доотправлено субброкерам: " + Ссылка;
		Иначе
			ТекстСообщенияПользователю = "Не отправлено субброкерам: " + Ссылка;
		КонецЕсли;
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщенияПользователю);
	КонецЕсли;
КонецПроцедуры

// Процедура создает записи типа Email в РС ЖурналИсходящихСообщенийKafka
//
// Параметры:
//  ПараметрыУведомления - Структура - Дополнительные параметры отправки уведомлений
//
Процедура ПодготовитьУведомление(ПараметрыУведомления = Неопределено) Экспорт
	
	ЭтоУведомлениеБезКД = ФормаСообщенияКК = Перечисления.ФормыСообщенийКК.УведомлениеОРегистрацииЗаявкиВУКПаи;
	
	ВнешнийИсточник = ПланыВидовХарактеристик.ВнешниеИсточники.KafkaEmail;
	Записывать = Истина;
	ФормироватьJSON = Документы.УведомлениеКлиентам.СтатусРазрешенДляОтправки(Статус)
		И Не ПометкаУдаления
		И (ЭтоУведомлениеБезКД
			Или ВидКД.СпособУведомления = Перечисления.СпособыУведомления.ЛичныйКабинет
			Или ФормаСообщенияКК = Перечисления.ФормыСообщенийКК.СвободнаяФорма);
	Если ФормироватьJSON Тогда
		ЧтениеJSON = Новый ЧтениеJSON;
		ЧтениеJSON.УстановитьСтроку(ТелоСообщения);
		ОбъектJSON = ПрочитатьJSON(ЧтениеJSON);
		ЧтениеJSON.Закрыть();
		
		ТекущийМомент = ТекущаяДатаСеанса();
		ДатаПоследнегоВходящегоСообщения = ДатаПоследнегоВходящегоСообщенияЭтапыКД();
		ТекстСообщения		= ЭтотОбъект.ТелоСообщения;
		ГраницаДатыФиксации = Новый Граница(?(ЗначениеЗаполнено(ДатаФиксации), КонецДня(ДатаФиксации), КонецДня(ТекущаяДатаСеанса())),
			ВидГраницы.Включая);
			
		Если ЗначениеЗаполнено(ДатаФиксации) Тогда
			МоментФормирования = ГраницаДатыФиксации;
		Иначе
			МоментФормирования = ДатаПоследнегоВходящегоСообщения;
		КонецЕсли;
		Успешно = Ложь;
		
		ЦБПодпадаетПодНалоговоеРегулированиеСША = Справочники.ЦенныеБумаги.ЦБПодпадаетПодНалоговоеРегулированиеСША(ЦеннаяБумага1);
		
		Если Не ПараметрыУведомления = Неопределено Тогда 
			Записывать = Ложь;
			Успешно = Ложь;
			Если ФормаСообщенияКК = Перечисления.ФормыСообщенийКК.SendEmailToClients
				ИЛИ ФормаСообщенияКК = Перечисления.ФормыСообщенийКК.CreateCorporateActionWtrc Тогда
				
				Успешно = РезультатПодготовкиКОтправкеВЛКSendEmailToClients(ОбъектJSON, ПараметрыУведомления, ВнешнийИсточник);
				// Открытый вопрос, пока не доработано
				//ИначеЕсли ФормаСообщенияКК = Перечисления.ФормыСообщенийКК.CreateCorporateActionTrec Тогда
				//	
				//	Успешно = РезультатОтправкиВЛКCreateCorporateActionTrec(ПараметрыУведомления, ВнешнийИсточник);
				
			КонецЕсли;
			
			Клиенты = ПараметрыУведомления.ТаблицаКлиентов.Скопировать(,
			"Клиент, Договор, СчетДепо, РазделСчетаДепо, ЦеннаяБумага, Количество");
			ЗаполнитьMessageId(Клиенты);
		ИначеЕсли ФормаСообщенияКК = Перечисления.ФормыСообщенийКК.ОбИзмененииОстатковЦБ Тогда
			
			Клиенты = СписокКлиентовСвязанныхЗапросовСубброкераДляУведомлений();
			ЗаполнитьMessageId(Клиенты);
			Успешно = ПодготовитьУведомлениеИнформационное(ОбъектJSON, Клиенты, ВнешнийИсточник);
			
		ИначеЕсли ФормаСообщенияКК = Перечисления.ФормыСообщенийКК.УведомлениеОРегистрацииЗаявкиВУКПаи Тогда
			
			Клиенты = СписокКлиентовЗаявкиВУК();
			ЗаполнитьMessageId(Клиенты);
			Успешно = ПодготовитьУведомлениеИнформационное(ОбъектJSON, Клиенты, ВнешнийИсточник);
			
		ИначеЕсли Документы.УведомлениеКлиентам.ВидКДВСписке(ВидКД, "MEET, XMET, BMET, OMET") Тогда
			Если ФормаСообщенияКК = Перечисления.ФормыСообщенийКК.ОбОтменеКД
				ИЛИ ФормаСообщенияКК = Перечисления.ФормыСообщенийКК.ОбИтогахСобрания
				ИЛИ ФормаСообщенияКК = Перечисления.ФормыСообщенийКК.ОбОтменеСобрания Тогда
				Клиенты = КлиентыПоследнегоУведомленияНаОснованииКД(ДокументОснование);
			Иначе
				Клиенты = СписокКлиентовДляОтправкиУведомлений(МоментФормирования);
			КонецЕсли;
			ЗаполнитьMessageId(Клиенты);
			Успешно = ПодготовитьУведомлениеИнформационное(ОбъектJSON, Клиенты, ВнешнийИсточник);
			
		ИначеЕсли (ВидКД.Код = "BIDS" И НомерСтатьи = "L750")
			Или (ВидКД.Код = "BIDS" И НомерСтатьи = "L720")
			Или (ВидКД.Код = "BIDS" И НомерСтатьи = "")
			Или (ВидКД.Код = "TEND" И НомерСтатьи = "L841")
			Или (ВидКД.Код = "TEND" И НомерСтатьи = "L842")
			Или (ВидКД.Код = "TEND" И НомерСтатьи = "") 
			Или (ВидКД.Код = "TEND"
				И (ПризнакОбязательностиКД = Перечисления.ПризнакиОбязательностиКД.MAND ИЛИ НомерСтатьи = "L848"))
			Или Документы.УведомлениеКлиентам.ВидКДВСписке(ВидКД, "CHAN, OTHR, PRIO, DSCL") Тогда
			Клиенты = КлиентыДляОтправкиУведомленийСУчетомОтменыКД(МоментФормирования);
			ЗаполнитьMessageId(Клиенты);
			Успешно = ПодготовитьУведомлениеИнформационноеСУчетомОтменыКД(ВнешнийИсточник, МоментФормирования, ОбъектJSON, Клиенты);
			
		ИначеЕсли ВидКД.Код = "BPUT" Тогда
			Клиенты = КлиентыДляОтправкиУведомленийСУчетомОтменыКД(ДатаПоследнегоВходящегоСообщения);
			ЗаполнитьMessageId(Клиенты);
			Успешно = ПодготовитьУведомлениеИнформационноеСУчетомОтменыКД(ВнешнийИсточник, ДатаПоследнегоВходящегоСообщения, ОбъектJSON, Клиенты);
			
		ИначеЕсли ВидКД.Код = "TREC" ИЛИ (ВидКД.Код = "WTRC" И НЕ ЦБПодпадаетПодНалоговоеРегулированиеСША) Тогда
			КодКД = ВидКД.Код;
			КодКД = СтрЗаменить(КодКД, "WTRC", "NTRC");
			
			// открытый вопрос
			//Если ВидКД.Код = "WTRC" ИЛИ ФормаСообщенияКК = Перечисления.ФормыСообщенийКК.ОПроведенииКД_ВозвратЧастиНалога Тогда
			// Отправка уведомления с поручением в КК
			
			//Если ВидКД.Код = "WTRC" ИЛИ НЕ WTRCСообщенияQI.ИспользоватьРегистрациюЗапросовСубброкера() Тогда
			//	// Отправка уведомления всем
			//	Клиенты = СписокКлиентовДляОтправкиУведомлений(МоментФормирования);
			//	Успешно = ОтправитьУведомлениеПоВозвратуЧастиНалога(ЗаголовокСообщения, ТекстСообщения, Клиенты,
			//	ВнешнийИсточник, КодКД);					
			//КонецЕсли;
			//ИначеЕсли WTRCСообщенияQI.ИспользоватьРегистрациюЗапросовСубброкера(Дата)
			Если WTRCСообщенияQI.ИспользоватьРегистрациюЗапросовСубброкера(Дата)
				И ФормаСообщенияКК = Перечисления.ФормыСообщенийКК.ОПроведенииКД_ВозвратЧастиНалогаНДИНД Тогда
				Клиенты = СписокКлиентовДляОтправкиУведомлений(МоментФормирования);
				// открытый вопрос
				//Если АктивнаяСсылка Тогда
				//	Успешно = ОтправитьУведомлениеПоВозвратуЧастиНалога(ЗаголовокСообщения, ТекстСообщения, Клиенты,
				//	ВнешнийИсточник, КодКД);
				//Иначе 
				ЗаполнитьMessageId(Клиенты);
				Успешно = ПодготовитьУведомлениеИнформационное(ОбъектJSON, Клиенты, ВнешнийИсточник);
				//КонецЕсли;
			КонецЕсли;
			
		ИначеЕсли ТребуетсяДобавитьИнформациюДляСубброкеров() Тогда
			Клиенты = СписокКлиентовДляОтправкиУведомлений(МоментФормирования);
			ЗаполнитьMessageId(Клиенты);
			Успешно = ПодготовитьУведомлениеИнформационноеДляСубброкеров(ОбъектJSON, Клиенты, ВнешнийИсточник);
			
		Иначе
			Клиенты = СписокКлиентовДляОтправкиУведомлений(МоментФормирования);
			ЗаполнитьMessageId(Клиенты);
			Успешно = ПодготовитьУведомлениеИнформационное(ОбъектJSON, Клиенты, ВнешнийИсточник);
		КонецЕсли;
		
		Сообщение = Новый СообщениеПользователю;
		Если Успешно Тогда
			
			Если Ссылка = Документы.УведомлениеКлиентам.ПустаяСсылка() Тогда
				УведомлениеСсылка = ПолучитьСсылкуНового();
			Иначе 
				УведомлениеСсылка = Ссылка;
			КонецЕсли;
			
			РегистрацияУведомлений = WTRCСообщенияQI.КлиентыДляРегистрацииОтправленныхУведомлений(Клиенты);
			РегистрыСведений.УведомленияОтправленныеЧерезЛичныйКабинет.ЗафиксироватьУведомления(ТекущийМомент,
				УведомлениеСсылка, РегистрацияУведомлений);
				
			Если Не ЭтоУведомлениеБезКД Тогда
				Запись = РегистрыСведений.ЭтапыКД.СоздатьМенеджерЗаписи();
				Запись.Период					= ТекущийМомент;
				Запись.КД						= УведомлениеСсылка;
				Запись.КодОтчета				= "";
				Запись.НомерСообщения			= "";
				Запись.НомерСообщенияИсходный	= "";
				Запись.Исходящее				= Истина;
				Запись.ТипУведомления			= Справочники.ТипыУведомления.NEWM();
				Запись.ЭтапКД					= Справочники.ЭтапыКД.УведомлениеКлиентов;
				Запись.Записать();
			КонецЕсли;
			
			ЭтотОбъект.Статус = Перечисления.СтатусыУведомленийКлиентам.Отправлено;
			Сообщение.Текст = "Отправлено: " + Ссылка;
		Иначе
			ЭтотОбъект.Статус = Перечисления.СтатусыУведомленийКлиентам.СбойОтправки;
			Сообщение.Текст = "Не отправлено: " + Ссылка;
		КонецЕсли;
		Если Записывать Тогда
			Сообщение.Сообщить();
			Записать();
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

Функция ПодготовитьУведомлениеИнформационноеСУчетомОтменыКД(ВнешнийИсточник, МоментФормирования, ОбъектJSON, Клиенты)
	
	Возврат ПодготовитьУведомлениеИнформационное(ОбъектJSON, Клиенты, ВнешнийИсточник);

КонецФункции

