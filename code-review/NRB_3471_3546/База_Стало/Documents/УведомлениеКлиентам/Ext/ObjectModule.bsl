Функция НаименованиеКД_ОбъединениеВыпусковЦБ()
	Если ЦенныеБумаги.Количество() = 0 Тогда
		мНезаполненныеОбязательныеПоля.Добавить("ЦБ_ОбъединениеВыпусковЦБ");
		Возврат "";
	КонецЕсли;
	
	СписокISIN = Новый Структура;
	Для Каждого Строка из ЦенныеБумаги Цикл
		ISIN = СокрЛП(Строка.ЦеннаяБумага.ISIN);
		Если ЗначениеЗаполнено(ISIN) Тогда
			СписокISIN.Вставить(ISIN);
		Иначе
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Текст = "В строке " + Строка.НомерСтроки + " таблицы ценных бумаг не указана ЦБ или ее ISIN";
			Сообщение.Сообщить();
			мНезаполненныеОбязательныеПоля.Добавить("ЦБ_ОбъединениеВыпусковЦБ");
			Возврат "";
		КонецЕсли;
	КонецЦикла;
	
	Если СписокISIN.Количество() = 1 Тогда	// ISIN бумаг, участвующих в КД, одинаковый
		Возврат "Объединение выпусков ценных бумаг";
	Иначе									// ISIN бумаг, участвующих в КД, различный
		Возврат "Аннулирование дополнительных выпусков акций";
	КонецЕсли;
КонецФункции

Функция ХарактеристикиЦБ_ОбъединениеВыпусковЦБ()
	ХарактеристикиЦБ = "";
	Если ЦенныеБумаги.Количество() = 0 Тогда
		мНезаполненныеОбязательныеПоля.Добавить("ЦБ_ОбъединениеВыпусковЦБ");
		ХарактеристикиЦБ = "";
	Иначе	
		Для Каждого Строка Из ЦенныеБумаги Цикл
			ХарактеристикиЦБ = ХарактеристикиЦБ
				+ Строка(Строка.ЦеннаяБумага.ТипЦБ) + " "
				+ СокрЛП(Строка.ЦеннаяБумага.НомерРегистрации) + ", "
				+ СокрЛП(Строка.ЦеннаяБумага.ISIN)
				+ ?(Строка.НомерСтроки < ЦенныеБумаги.Количество(), " / ", "");
		КонецЦикла;
	КонецЕсли;
	Возврат ХарактеристикиЦБ;
КонецФункции

Функция Выпуски_ОбъединениеВыпусковЦБ(Тип)
	Выпуски = "";
	Отбор = Новый Структура("ДтКт", Тип);
	Строки = ЦенныеБумаги.НайтиСтроки(Отбор);
	Если Строки.Количество() = 0 Тогда
		мНезаполненныеОбязательныеПоля.Добавить("ЦБ_ОбъединениеВыпусковЦБ");
		Выпуски = "";
	Иначе
		Для Каждого Строка из Строки Цикл
			Выпуски = Выпуски + СокрЛП(Строка.ЦеннаяБумага.НомерРегистрации) + " / "
			+ СокрЛП(Строка.ЦеннаяБумага.ISIN) + "<br/>";
		КонецЦикла;
	КонецЕсли;
	Возврат Выпуски;
КонецФункции

Функция СписокISINЦенныхБумаг(Тип)
	СписокISIN = "";
	Отбор = Новый Структура("ДтКт", Тип);
	Строки = ЦенныеБумаги.НайтиСтроки(Отбор);
	Если Строки.Количество() = 0 Тогда
		мНезаполненныеОбязательныеПоля.Добавить("ЦБ_РеорганизацииОбщества");
		СписокISIN = "";
	Иначе
		Для Инд = 0 По Строки.Количество()-1 Цикл
			СписокISIN = СписокISIN	+ СокрЛП(Строки[Инд].ЦеннаяБумага.ISIN)	+ ?(Инд < Строки.Количество()-1, ", ", "");
		КонецЦикла;
	КонецЕсли;
	Возврат СписокISIN;
КонецФункции

Функция ПредставлениеСсылки(URL)
	Возврат ?(ЗначениеЗаполнено(URL), "С деталями корпоративного действия Вы можете ознакомиться по ссылке: " + URL, "");
КонецФункции

Процедура ЗаменитьМаркерНаСсылкуДляУчастия(ОбъектJSON, Ссылка)
	Если ОбъектJSON.Data.ReplaceFields.Свойство("СсылкаДляУчастияВГолосовании") Тогда
		ОбъектJSON.Data.ReplaceFields.СсылкаДляУчастияВГолосовании = "";
	ИначеЕсли ОбъектJSON.Data.ReplaceFields.Свойство("СсылкаДляУчастияВКорпоративномДействии") Тогда
		ОбъектJSON.Data.ReplaceFields.СсылкаДляУчастияВКорпоративномДействии = "";
	ИначеЕсли ОбъектJSON.Data.ReplaceFields.Свойство("СсылкаНаСтраницуКДВКабинетеКлиента") Тогда
		ОбъектJSON.Data.ReplaceFields.СсылкаНаСтраницуКДВКабинетеКлиента = "";
	КонецЕсли;
КонецПроцедуры

Функция ПодписьСообщения()
	КомментарийHTML = "";
	Если ФормаСообщенияКК <> Перечисления.ФормыСообщенийКК.СвободнаяФорма Тогда
		КомментарийHTML = ДобавитьПараграфыHTML(Комментарий);
	КонецЕсли;
	Возврат КомментарийHTML + Символы.ПС + Документы.УведомлениеКлиентам.ПодписьСообщения(Дата);
