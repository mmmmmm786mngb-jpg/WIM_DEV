Функция СписокКлиентовСвязанныхЗапросовСубброкера()
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	ЗапросСубброкеруНаРаскрытие.Клиент КАК Клиент,
	|	Договоры.Ссылка КАК Договор,
	|	ЦенныеБумаги.Ссылка КАК ЦеннаяБумага,
	|	ЗапросСубброкеруНаРаскрытие.СчетДЕПО КАК СчетДЕПО,
	|	ЕСТЬNULL(Договоры.ДатаНачалоДействия, ДАТАВРЕМЯ(1, 1, 1)) КАК ДатаДоговора,
	|	ЕСТЬNULL(Договоры.Наименование, """") КАК НомерДоговора
	|ПОМЕСТИТЬ ВТ_Договоры
	|ИЗ
	|	Документ.ЗапросСубброкеруНаРаскрытие КАК ЗапросСубброкеруНаРаскрытие
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ЦенныеБумаги КАК ЦенныеБумаги
	|		ПО ЗапросСубброкеруНаРаскрытие.ISIN = ЦенныеБумаги.ISIN
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ДоговорыКонтрагентов КАК Договоры
	|		ПО ЗапросСубброкеруНаРаскрытие.СчетДЕПО.Владелец = Договоры.Владелец
	|			И ЗапросСубброкеруНаРаскрытие.СчетДЕПО.Владелец.Код = Договоры.Код
	|ГДЕ
	|	ЗапросСубброкеруНаРаскрытие.УведомлениеКлиентам = &УведомлениеКлиентам
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	КодыЗагрузкиКлиента.Код КАК ClientId,
	|	ВТ_Договоры.Клиент КАК Клиент,
	|	ВТ_Договоры.Договор КАК Договор,
	|	ВТ_Договоры.СчетДЕПО КАК СчетДЕПО,
	|	ВЫБОР
	|		КОГДА КодыЗагрузкиКлиента.Ссылка ЕСТЬ NULL
	|			ТОГДА ЛОЖЬ
	|		ИНАЧЕ ИСТИНА
	|	КОНЕЦ КАК ЕстьКодЗагрузкиКлиенты,
	|	ВЫБОР
	|		КОГДА ВТ_Договоры.Клиент.ЮрФизЛицо = ЗНАЧЕНИЕ(Перечисление.ЮрФизЛицо.ФизЛицо)
	|			ТОГДА ""физ""
	|		ИНАЧЕ ""юр""
	|	КОНЕЦ КАК ЮрФизЛицо,
	|	ВТ_Договоры.ЦеннаяБумага КАК ЦеннаяБумага,
	|	ВЫБОР
	|		КОГДА Контрагенты.ЮридическиеФизическиеЛица ССЫЛКА Справочник.ФизическиеЛица
	|			ТОГДА ЕСТЬNULL(ФИОФизЛицСрезПоследних.Фамилия, """")
	|		ИНАЧЕ ""клиент""
	|	КОНЕЦ КАК Фамилия,
	|	ВЫБОР
	|		КОГДА Контрагенты.ЮридическиеФизическиеЛица ССЫЛКА Справочник.ФизическиеЛица
	|			ТОГДА ЕСТЬNULL(ФИОФизЛицСрезПоследних.Имя, """")
	|		ИНАЧЕ Контрагенты.Наименование
	|	КОНЕЦ КАК Имя,
	|	ВТ_Договоры.ДатаДоговора КАК ДатаДоговора,
	|	ВТ_Договоры.НомерДоговора КАК НомерДоговора,
	|	ВТ_Договоры.Клиент.Наименование КАК КлиентНаименование
	|ИЗ
	|	ВТ_Договоры КАК ВТ_Договоры
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Контрагенты КАК Контрагенты
	|			ЛЕВОЕ СОЕДИНЕНИЕ Справочник.КодыЗагрузки КАК КодыЗагрузкиКлиента
	|			ПО Контрагенты.ЮридическиеФизическиеЛица = КодыЗагрузкиКлиента.Владелец
	|				И (НЕ КодыЗагрузкиКлиента.ПометкаУдаления)
	|				И (КодыЗагрузкиКлиента.Биржа = &КлассификаторыЗагрузкиКлиенты)
	|			ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ФИОФизЛиц.СрезПоследних(
	|					,
	|					ФизЛицо В
	|						(ВЫБРАТЬ
	|							ВТ_Договоры.Клиент.ЮридическиеФизическиеЛица КАК КлиентЮридическиеФизическиеЛица
	|						ИЗ
	|							ВТ_Договоры КАК ВТ_Договоры)) КАК ФИОФизЛицСрезПоследних
	|			ПО Контрагенты.ЮридическиеФизическиеЛица = ФИОФизЛицСрезПоследних.ФизЛицо
	|		ПО ВТ_Договоры.СчетДЕПО.Владелец = Контрагенты.Ссылка");
	
	Запрос.УстановитьПараметр("КлассификаторыЗагрузкиКлиенты", Справочники.КлассификаторыЗагрузки.Клиенты);
	
	Если Ссылка.Пустая() Тогда 
		Запрос.УстановитьПараметр("УведомлениеКлиентам",		ПолучитьСсылкуНового());
	Иначе 
		Запрос.УстановитьПараметр("УведомлениеКлиентам",		Ссылка);
	КонецЕсли;
	Возврат Запрос.Выполнить().Выгрузить();

КонецФункции

Функция СписокКлиентовЗаявкиВУК()
	
	СтруктураРеквизитовПоручения = Новый Структура;
	СтруктураРеквизитовПоручения.Вставить("Депонент",					 "Депонент");
	СтруктураРеквизитовПоручения.Вставить("ДепонентИмя",				 "Депонент.Наименование");
	СтруктураРеквизитовПоручения.Вставить("ЮридическиеФизическиеЛица",	 "Депонент.ЮридическиеФизическиеЛица");
	СтруктураРеквизитовПоручения.Вставить("ЮрФизЛицо",					 "Депонент.ЮрФизЛицо");
	СтруктураРеквизитовПоручения.Вставить("СчетДепо",					 "СчетДепо");
	СтруктураРеквизитовПоручения.Вставить("РазделСчетаДепо",			 "РазделСчетаДепо");
	РеквизитыПоручения = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ДокументОснование, СтруктураРеквизитовПоручения);
	
	Клиенты = НоваяТаблицаКлиентов();
	КлиентВЗаявке = Клиенты.Добавить();
	КлиентВЗаявке.Клиент = РеквизитыПоручения.Депонент;
	КлиентВЗаявке.Договор = Справочники.ДоговорыКонтрагентов.ДоговорПоКлиенту(РеквизитыПоручения.Депонент);
	КлиентВЗаявке.СчетДепо = РеквизитыПоручения.СчетДепо;
	КлиентВЗаявке.РазделСчетаДепо = РеквизитыПоручения.РазделСчетаДепо;
	КлиентВЗаявке.ЦеннаяБумага = ЦеннаяБумага1;
	CrmClientId = Обработки.РегистрацияКлиентаЧерезKafka.CrmClientId(РеквизитыПоручения.ЮридическиеФизическиеЛица);
	КлиентВЗаявке.ClientId = ?(ЗначениеЗаполнено(CrmClientId), СокрЛП(CrmClientId), Неопределено);
	Если Не ЗначениеЗаполнено(КлиентВЗаявке.ClientId) Тогда
		Если ЗначениеЗаполнено(КлиентВЗаявке.Договор) Тогда
			РеквизитыДоговора = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(КлиентВЗаявке.Договор, "Наименование, ДатаНачалоДействия");
			КлиентВЗаявке.НомерДоговора = СокрЛП(РеквизитыДоговора.Наименование);
			КлиентВЗаявке.ДатаДоговора = РеквизитыДоговора.ДатаНачалоДействия;
		КонецЕсли;
		Если РеквизитыПоручения.ЮрФизЛицо = Перечисления.ЮрФизЛицо.ФизЛицо Тогда
			ФИО = РегистрыСведений.ФИОФизЛиц.СрезПоследних(ТекущаяДатаСеанса(),
				Новый Структура("ФизЛицо", РеквизитыПоручения.ЮридическиеФизическиеЛица));
			Если ЗначениеЗаполнено(ФИО) Тогда
				КлиентВЗаявке.Имя = ФИО[0].Имя;
				КлиентВЗаявке.Фамилия = ФИО[0].Фамилия;
			КонецЕсли;
		Иначе
			КлиентВЗаявке.Имя = РеквизитыПоручения.ДепонентИмя;
			КлиентВЗаявке.Фамилия = "клиент";
		КонецЕсли;
	КонецЕсли;
	
	Возврат Клиенты;
	
КонецФункции

Функция НоваяТаблицаКлиентов()
	
	ТаблицаКлиентов = Новый ТаблицаЗначений();
	ТаблицаКлиентов.Колонки.Добавить("Клиент",			, Новый ОписаниеТипов("СправочникСсылка.Контрагенты"));
	ТаблицаКлиентов.Колонки.Добавить("Договор"			, Новый ОписаниеТипов("СправочникСсылка.ДоговорыКонтрагентов"));
	ТаблицаКлиентов.Колонки.Добавить("СчетДепо"			, Новый ОписаниеТипов("СправочникСсылка.СчетаДепо"));
	ТаблицаКлиентов.Колонки.Добавить("РазделСчетаДепо"	, Новый ОписаниеТипов("СправочникСсылка.РазделыСчетаДепо"));
	ТаблицаКлиентов.Колонки.Добавить("ЦеннаяБумага"		, Новый ОписаниеТипов("СправочникСсылка.ЦенныеБумаги"));
	ТаблицаКлиентов.Колонки.Добавить("Количество"		, Метаданные.ОпределяемыеТипы.КоличествоЦБ.Тип);
	ТаблицаКлиентов.Колонки.Добавить("ClientId"			, ОбщегоНазначения.ОписаниеТипаСтрока("20"));
	ТаблицаКлиентов.Колонки.Добавить("Имя"				, ОбщегоНазначения.ОписаниеТипаСтрока("50"));
	ТаблицаКлиентов.Колонки.Добавить("Фамилия"			, ОбщегоНазначения.ОписаниеТипаСтрока("50"));
	ТаблицаКлиентов.Колонки.Добавить("НомерДоговора"	, ОбщегоНазначения.ОписаниеТипаСтрока("150"));
	ТаблицаКлиентов.Колонки.Добавить("ДатаДоговора"		, ОбщегоНазначения.ОписаниеТипаДата(ЧастиДаты.Дата));
	
	Возврат ТаблицаКлиентов;
	
КонецФункции


Функция ЕстьДанныеБюллетеня(КД)
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ЭтапыКД.КД КАК КД
	|ИЗ
	|	РегистрСведений.ЭтапыКД КАК ЭтапыКД
