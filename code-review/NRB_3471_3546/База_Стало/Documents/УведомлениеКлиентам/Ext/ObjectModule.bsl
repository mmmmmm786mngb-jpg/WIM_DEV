	ReplaceFields.Вставить("ПризнакОбязательностиКД_СвязанногоСВыплатой",
		ПредставлениеПризнакаОбязательностиКД("ПризнакОбязательностиКД_СвязанногоСВыплатой"));
	ReplaceFields.Вставить("ХДивДата", ФорматДаты(ХДивДата));
	
	ЭтоБумагаРоссийскогоЭмитента = Справочники.ЦенныеБумаги.ЭтоБумагаРоссийскогоЭмитента(ЦеннаяБумага1);
	Если Документы.УведомлениеКлиентам.ВидКДВСписке(ВидКД, "DVCA, CAPG, CAPD")
		И НЕ ЭтоБумагаРоссийскогоЭмитента Тогда
		ReplaceFields.Вставить("ЧистаяСтавкаДивидендов", "Чистая ставка дивидендов: " + Формат(ЧистаяСтавкаДивидендов, "ЧН=0"));
		ReplaceFields.Вставить("ВалютаЧистойСтавкиДивидендов", Справочники.Валюты.ПредставлениеВалюты(ВалютаЧистойСтавкиДивидендов));
		
	Иначе
		ReplaceFields.Вставить("ЧистаяСтавкаДивидендов", "");
		ReplaceFields.Вставить("ВалютаЧистойСтавкиДивидендов", "");
	КонецЕсли;
	ВалютаПлатежаТекст = ?(ЗначениеЗаполнено(ВалютаПлатежа), "Валюта платежа: " + Справочники.Валюты.ПредставлениеВалюты(ВалютаПлатежа), "");
