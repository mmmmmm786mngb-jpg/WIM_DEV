		КонецЕсли;
	Иначе
		ДатаОкончанияПриемаЗаявленийСрокРынка = ?(ЗначениеЗаполнено(ДатаОкончанияГолосования), ДатаОкончанияГолосования, ПоследнийСрокРынка);
		ДатаОкончанияПриемаЗаявлений = ФорматОбязательнойДаты(ДатаОкончанияПриемаЗаявленийСрокРынка, "ПоследнийСрокРынка");
	КонецЕсли;
	ReplaceFields.Вставить("ДатаОкончанияПриемаЗаявлений", ДатаОкончанияПриемаЗаявлений);
	ReplaceFields.Вставить("КДРеференсСвязанныйСобрание", КДРеференсСвязанныйСобрание);
	ДополнитьТекстСообщенияАдресомВСетиИнтернет(ReplaceFields, АдресВСетиИнтернет);
	ReplaceFields.Вставить("СсылкаДляУчастияВКорпоративномДействии", "");
	
