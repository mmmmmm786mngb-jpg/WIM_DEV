	Если Документы.УведомлениеКлиентам.ВидКДВСписке(ВидКД, "DVCA, CAPG, DVSE, LIQU") Тогда
		ReplaceFields.Вставить("Период", Период);
	Иначе
		ReplaceFields.Вставить("Период", "");
	КонецЕсли;
	ДополнитьТекстСообщенияАдресомВСетиИнтернет(ReplaceFields, АдресВСетиИнтернет);
	
КонецПроцедуры

