// Инициализирует структуру для документа JSON
Процедура СформироватьJSON(Шаблон = Неопределено) Экспорт
	
	Если (Не ЗначениеЗаполнено(Статус)
			Или Статус = Перечисления.СтатусыУведомленийКлиентам.ОжидаетОтправки
			Или Статус = Перечисления.СтатусыУведомленийКлиентам.СформированоСОшибками)
			Или ФормаСообщенияКК = Перечисления.ФормыСообщенийКК.УведомлениеОРегистрацииЗаявкиВУКПаи
			Или ФормаСообщенияКК = Перечисления.ФормыСообщенийКК.СвободнаяФорма Тогда
		
		ДатаФиксацииОбязательна = Ложь;
		ТелоСообщения = "";
		ОбъектJSON = ОбщийEmailJSON();
		
		Если Шаблон <> Неопределено Тогда
			ФормаСообщенияКК = Шаблон;
		КонецЕсли;
		
		Если ФормаСообщенияКК = Перечисления.ФормыСообщенийКК.ОПоступленииМатериаловКОбщемуСобраниюВладельцев Тогда
			ЗаполнитьТекстСообщенияОПоступленииМатериаловКОбщемуСобраниюВладельцев(ОбъектJSON);
			
		ИначеЕсли ФормаСообщенияКК = Перечисления.ФормыСообщенийКК.ОПоступленииИнформацииИзБюллетеня Тогда
			ЗаполнитьТекстСообщенияОПоступленииИнформацииИзБюллетеня(ОбъектJSON);
			
		ИначеЕсли ФормаСообщенияКК = Перечисления.ФормыСообщенийКК.ОПроведенииКД_ВыкупПриобретениеЦБ Тогда
			ЗаполнитьТекстСообщенияОПроведенииКД_ВыкупПриобретениеЦБ(ОбъектJSON);
					
		ИначеЕсли ФормаСообщенияКК = Перечисления.ФормыСообщенийКК.ОПроведенииКД_BPUT Тогда
			ЗаполнитьТекстСообщенияОПроведенииКД_BPUT(ОбъектJSON);
			
		ИначеЕсли ФормаСообщенияКК = Перечисления.ФормыСообщенийКК.ОПроведенииКД_BIDS_TEND Тогда
			ЗаполнитьТекстСообщенияОПроведенииКД_BIDS_TEND(ОбъектJSON);
			
		ИначеЕсли ФормаСообщенияКК = Перечисления.ФормыСообщенийКК.ОПроведенииКД_PRIO Тогда
			ЗаполнитьТекстСообщенияОПроведенииКД_PRIO(ОбъектJSON);
			
		ИначеЕсли ФормаСообщенияКК = Перечисления.ФормыСообщенийКК.ОПроведенииКД_КонвертацияОбменЦБ Тогда
			ЗаполнитьТекстСообщенияОПроведенииКД_КонвертацияОбменЦБ(ОбъектJSON);
			
		ИначеЕсли ФормаСообщенияКК = Перечисления.ФормыСообщенийКК.ОПроведенииКД_ОбъединениеВыпусковЦБ Тогда
			ЗаполнитьТекстСообщенияОПроведенииКД_ОбъединениеВыпусковЦБ(ОбъектJSON);
			
		ИначеЕсли ФормаСообщенияКК = Перечисления.ФормыСообщенийКК.ОПроведенииКД_РеорганизацииОбщества Тогда
			ЗаполнитьТекстСообщенияОПроведенииКД_РеорганизацииОбщества(ОбъектJSON);
			
		ИначеЕсли ФормаСообщенияКК = Перечисления.ФормыСообщенийКК.ОПроведенииКД_ПрочихВидов Тогда
			ЗаполнитьТекстСообщенияОПроведенииКД_ПрочихВидов(ОбъектJSON);
			
		ИначеЕсли ФормаСообщенияКК = Перечисления.ФормыСообщенийКК.ОбОтменеКД Тогда
			ЗаполнитьТекстСообщенияОбОтменеКД(ОбъектJSON);
			
		ИначеЕсли ФормаСообщенияКК = Перечисления.ФормыСообщенийКК.ОПроведенииКД_CписаниеЦБ Тогда
			ЗаполнитьТекстСообщенияОПроведенииКД_CписаниеЦБ(ОбъектJSON);
			
		ИначеЕсли ФормаСообщенияКК = Перечисления.ФормыСообщенийКК.ОПроведенииКД_CвязанногоСВыплатой Тогда
			ЗаполнитьТекстСообщенияОПроведенииКД_CвязанногоСВыплатой(ОбъектJSON);
			
		ИначеЕсли ФормаСообщенияКК = Перечисления.ФормыСообщенийКК.ОПроведенииКД_CвязанногоСВыплатой_INTR_PRII Тогда
			ЗаполнитьТекстСообщенияОПроведенииКД_CвязанногоСВыплатой_INTR_PRII(ОбъектJSON);
			
		ИначеЕсли ФормаСообщенияКК = Перечисления.ФормыСообщенийКК.ОПроведенииКД_CвязанногоСВыплатой_PRED_REDM_MCAL_others Тогда
			ЗаполнитьТекстСообщенияОПроведенииКД_CвязанногоСВыплатой_PRED_REDM_MCAL_others(ОбъектJSON);
			
		ИначеЕсли ФормаСообщенияКК = Перечисления.ФормыСообщенийКК.ОПроведенииКД_ПодтверждениеОсвобожденияОтНалога Тогда
			ЗаполнитьТекстСообщенияОПроведенииКД_ПодтверждениеОсвобожденияОтНалога(ОбъектJSON);
			
		ИначеЕсли ФормаСообщенияКК = Перечисления.ФормыСообщенийКК.ОПроведенииКД_ВозвратЧастиНалога
			Или ФормаСообщенияКК = Перечисления.ФормыСообщенийКК.ОПроведенииКД_ВозвратЧастиНалогаНДИНД Тогда
			ЗаполнитьТекстСообщенияОПроведенииКД_ВозвратЧастиНалога(ОбъектJSON);
			
		ИначеЕсли ФормаСообщенияКК = Перечисления.ФормыСообщенийКК.ОПроведенииКД_СущественноеИзменениеПоЦБИноеСобытие Тогда
			ЗаполнитьТекстСообщенияОПроведенииКД_СущественноеИзменениеПоЦБИноеСобытие(ОбъектJSON);
			
		ИначеЕсли ФормаСообщенияКК = Перечисления.ФормыСообщенийКК.ОПроведенииКД_РаскрытиеИнформации Тогда
			ЗаполнитьТекстСообщенияОПроведенииКД_РаскрытиеИнформации(ОбъектJSON);
			
		ИначеЕсли ФормаСообщенияКК = Перечисления.ФормыСообщенийКК.ОбИтогахСобрания Тогда
			ЗаполнитьТекстСообщенияОбИтогахСобрания(ОбъектJSON);
			
		ИначеЕсли ФормаСообщенияКК = Перечисления.ФормыСообщенийКК.ОбОтменеСобрания Тогда
			ЗаполнитьТекстСообщенияОбОтменеСобрания(ОбъектJSON);
			
		ИначеЕсли ФормаСообщенияКК = Перечисления.ФормыСообщенийКК.ОПроведенииКД_ПодтверждениеОсвобожденияОтНалогаПоЦБНеПодпадающимПодНалоговоеРегулированиеСША Тогда
			ЗаполнитьТекстСообщенияОПроведенииКД_ПодтверждениеОсвобожденияОтНалогаПоЦБНеПодпадающимПодНалоговоеРегулированиеСША(ОбъектJSON);
			
		ИначеЕсли ФормаСообщенияКК = Перечисления.ФормыСообщенийКК.ОбИзмененииОстатковЦБ Тогда
			
		ИначеЕсли ФормаСообщенияКК = Перечисления.ФормыСообщенийКК.УведомлениеОРегистрацииЗаявкиВУКПаи Тогда
			ЗаполнитьТекстСообщенияОРегистрацииЗаявкиВУКПаи(ОбъектJSON);
			ЗаголовокСообщения = ОбъектJSON.Data.ReplaceFields.ЗаголовокСообщения;
		ИначеЕсли ФормаСообщенияКК = Перечисления.ФормыСообщенийКК.СвободнаяФорма Тогда
			ЗаполнитьТекстСообщенияСвободнаяФорма(ОбъектJSON);
		КонецЕсли;
		
		Если ФормаСообщенияКК <> Перечисления.ФормыСообщенийКК.СвободнаяФорма
			И ФормаСообщенияКК <> Перечисления.ФормыСообщенийКК.УведомлениеОРегистрацииЗаявкиВУКПаи Тогда
			ТекстДопИнфо = Документы.УведомлениеКлиентам.УбратьЛишниеСимволы(Комментарий);
			Если ЗначениеЗаполнено(ДополнительнаяИнформация) Тогда
				ТекстДопИнфо = ДополнительнаяИнформация + Символы.ПС + ТекстДопИнфо;
			КонецЕсли;
			ТекстДопИнфо = СтрЗаменить(ТекстДопИнфо, Символы.ПС, "<br/>");
			ОбъектJSON.Data.ReplaceFields.Вставить("ДопИнфо", ТекстДопИнфо);
		КонецЕсли;
		ОбъектJSON.Data.ReplaceFields.Вставить("Подпись", ПодписьДляJSON());
		
		Для Каждого ПолеReplaceFields Из ОбъектJSON.Data.ReplaceFields Цикл
			Если ПолеReplaceFields.Значение = 0 Или СокрЛП(ПолеReplaceFields.Значение) = "0" Тогда
				ОбъектJSON.Data.ReplaceFields[ПолеReplaceFields.Ключ] = "";
			КонецЕсли;
		КонецЦикла;
		
		ТелоСообщения = РаботаСJSON.ТекстСообщенияJSON(ОбъектJSON.MessageInfo, ОбъектJSON.Data);
		
		// Общие обязательные поля
		Если ФормаСообщенияКК <> Перечисления.ФормыСообщенийКК.СвободнаяФорма Тогда
			Если НЕ ЗначениеЗаполнено(Эмитент) Тогда
				мНезаполненныеОбязательныеПоля.Добавить("Эмитент");
			КонецЕсли;
			Если НЕ ЗначениеЗаполнено(ЦеннаяБумага1) Тогда
				мНезаполненныеОбязательныеПоля.Добавить("ЦеннаяБумага1");
			КонецЕсли;
			
			РеквизитыЭмитента = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Эмитент, "ЮрФизЛицо, ЮридическиеФизическиеЛица");
			Если РеквизитыЭмитента.ЮрФизЛицо = Перечисления.ЮрФизЛицо.ЮрЛицо Тогда
				РеквизитыЮрлица = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(РеквизитыЭмитента.ЮридическиеФизическиеЛица,
					"МеждународнаяКомпания, Страна");
				Если РеквизитыЮрлица.МеждународнаяКомпания И РеквизитыЮрлица.Страна = Справочники.КлассификаторСтранМира.РОССИЯ Тогда
					ИндексДатыОкончанияПриемаИнструкций = мНезаполненныеОбязательныеПоля.Найти("ДатаОкончанияПриемаИнструкцийНРДИностранногоЭмитента");
					Если ИндексДатыОкончанияПриемаИнструкций <> Неопределено Тогда
						мНезаполненныеОбязательныеПоля.Удалить(ИндексДатыОкончанияПриемаИнструкций);
					КонецЕсли;
				КонецЕсли;
			КонецЕсли;
			
			Если ЗначениеЗаполнено(мНезаполненныеОбязательныеПоля) Тогда
				Статус = Перечисления.СтатусыУведомленийКлиентам.СформированоСОшибками;
				СписокНезаполненныхОбязательныхПолей = ЗначениеВСтрокуВнутр(мНезаполненныеОбязательныеПоля);
			Иначе
				Статус = Перечисления.СтатусыУведомленийКлиентам.ОжидаетОтправки;
				СписокНезаполненныхОбязательныхПолей = "";
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры
