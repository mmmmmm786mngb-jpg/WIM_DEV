Функция ТекстСообщенияОПоступленииМатериаловКОбщемуСобраниюВладельцев()
	// {Обязательный блок}
	Текст =
	"<p>Уведомляем Вас о том, что в %1 поступила информация о проведении корпоративного действия
	|""%2"" - %3 (%4, Референс КД %5).</p>
	|<p>Дата КД (план.): %6</p>";
	Текст = СтрЗаменить(Текст, "%1", мНаименованиеДепозитария);
	Текст = СтрЗаменить(Текст, "%2", ФорматОбязательнойСтроки(ВидКД.Наименование, "ВидКД"));
	Текст = СтрЗаменить(Текст, "%3", Справочники.ЦенныеБумаги.НаименованиеЭмитента(ЦеннаяБумага1));
	Текст = СтрЗаменить(Текст, "%4", ХарактеристикиЦБ());
	Текст = СтрЗаменить(Текст, "%5", ФорматОбязательнойСтроки(КДРеференс, "КДРеференс"));
	Текст = СтрЗаменить(Текст, "%6", ФорматОбязательнойДатыСоВременем(ДатаКДПлан, "ДатаКДПлан_КОбщемуСобраниюВладельцев"));
	
	// {Опциональный блок, только для КД российских Эмитентов}
	Если Справочники.ЦенныеБумаги.ЭтоБумагаРоссийскогоЭмитента(ЦеннаяБумага1)
		ИЛИ (НЕ Справочники.ЦенныеБумаги.ЭтоБумагаРоссийскогоЭмитента(ЦеннаяБумага1) И ЗначениеЗаполнено(ДатаФиксации)) Тогда
		Текст = Текст + "
		|<p>Дата фиксации: %1</p>";
		Текст = СтрЗаменить(Текст, "%1", ФорматОбязательнойДаты(ДатаФиксации, "ДатаФиксации_КОбщемуСобраниюВладельцев"));
		ДатаФиксацииОбязательна = Истина;
	КонецЕсли;
	
	// {Опциональный блок, при наличии ссылки}
	Если ЗначениеЗаполнено(АдресВСетиИнтернет) Тогда
		Текст = Текст + "
		|<p>Для ознакомления с материалами перейдите по ссылке: %1</p>";
		Текст = СтрЗаменить(Текст, "%1", ПредставлениеСсылки(АдресВСетиИнтернет));
	КонецЕсли;
		
	// {Опциональный блок, при наличии возможности участия}
	Текст = Текст + Символы.ПС + "#СсылкаДляУчастияВГолосовании#";	// Этот маркер заменяется на ссылку при отправке уведомления
	
	// {Обязательный блок}
	Текст = Текст + "
	|<p>Последний срок участия в голосовании не позднее: %1</p>";
	Текст = СтрЗаменить(Текст, "%1", 
		?(Справочники.ЦенныеБумаги.ЭтоБумагаРоссийскогоЭмитента(ЦеннаяБумага1),
			ФорматОбязательнойДатыСоВременем(ДатаОкончанияГолосования, "ДатаОкончанияГолосования_КОбщемуСобраниюВладельцев"),
			ФорматОбязательнойДатыСоВременем(ДатаОкончанияПриемаИнструкцийНРДИностранногоЭмитента, "ДатаОкончанияПриемаИнструкцийНРДИностранногоЭмитента")));
			
	Возврат Текст;			
КонецФункции

Процедура ДополнитьТекстСообщенияАдресомВСетиИнтернет(ReplaceFields, АдресВСетиИнтернет)
	
