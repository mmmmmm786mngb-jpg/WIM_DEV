Функция ПараметрыWebСервисаДляСообщенияWTRC()
	МассивДепонентов = ДепонентыДляОтправкиУведомленияWTRC();
	Данные = Документы.УведомлениеКлиентам.ДанныеДляWebСервисовWTRC(ДокументОснование, МассивДепонентов, Дата);
	
	ПараметрыWebСервиса = Новый Структура;
	ПараметрыWebСервиса.Вставить("Данные", Данные);
	ПараметрыWebСервиса.Вставить("РеференсКД", СокрЛП(КДРеференс));	
	ПараметрыWebСервиса.Вставить("НаименованиеЭмитента",
		Справочники.ЦенныеБумаги.НаименованиеЭмитента(ЦеннаяБумага1));
	ПараметрыWebСервиса.Вставить("НаименованиеЦБ",		Справочники.ЦенныеБумаги.РусскоеНаименование(ЦеннаяБумага1));
	ПараметрыWebСервиса.Вставить("ДатаОкончанияПриемаПоручений1_10", ДатаОкончанияПриемаПоручений1_10);
	ПараметрыWebСервиса.Вставить("ДатаОкончанияПриемаПоручений1_5", ДатаОкончанияПриемаПоручений1_5);
	ПараметрыWebСервиса.Вставить("ЗаголовокСообщения",	ЗаголовокСообщения);
	ПараметрыWebСервиса.Вставить("ТекстСообщения",		ТелоСообщения);
	Возврат ПараметрыWebСервиса;
КонецФункции

Функция ДепонентыДляОтправкиУведомленияWTRC()
	// Депоненты с формой W8, у которых ЦБ не на налоговом разделе и нет условного длящегося поручения
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ФормаW8.Депонент КАК Депонент
	|ПОМЕСТИТЬ втФормаW8
	|ИЗ
	|	РегистрСведений.ПредоставленныеДокументы.СрезПоследних(, ВидДокумента = &ФормаW8) КАК ФормаW8
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	УсловноеДлящеесяПоручение.Депонент КАК Депонент
	|ПОМЕСТИТЬ втУсловноеДлящеесяПоручение
	|ИЗ
	|	РегистрСведений.ПредоставленныеДокументы.СрезПоследних(, ВидДокумента = &УсловноеДлящеесяПоручение) КАК УсловноеДлящеесяПоручение
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Депоненты.Депонент КАК Депонент
	|ИЗ
	|	БизнесПроцесс.ОбработкаWTRCСообщения.Депоненты КАК Депоненты
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ втФормаW8 КАК ФормаW8
	|		ПО (ФормаW8.Депонент = Депоненты.Депонент)
	|		ЛЕВОЕ СОЕДИНЕНИЕ втУсловноеДлящеесяПоручение КАК УсловноеДлящеесяПоручение
	|		ПО (УсловноеДлящеесяПоручение.Депонент = Депоненты.Депонент)
	|ГДЕ
	|	Депоненты.Ссылка.КД = &КД
	|	И НЕ Депоненты.РазделСчетаПолучатель ЕСТЬ NULL 
	|	И НЕ Депоненты.Ссылка.ПометкаУдаления
	|	И Депоненты.Депонент.Субброкер = ЛОЖЬ
	|	И Депоненты.РазделСчета.ТипРазделаСчетаДЕПО <> &Налоговый
	|	И УсловноеДлящеесяПоручение.Депонент ЕСТЬ NULL
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Депоненты.Депонент
	|ИЗ
	|	БизнесПроцесс.ОбработкаWTRCСообщения.Депоненты КАК Депоненты
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ втФормаW8 КАК ФормаW8
	|		ПО Депоненты.РазделСчета.Субклиент = ФормаW8.Депонент
	|		ЛЕВОЕ СОЕДИНЕНИЕ втУсловноеДлящеесяПоручение КАК УсловноеДлящеесяПоручение
	|		ПО (УсловноеДлящеесяПоручение.Депонент = Депоненты.РазделСчета.Субклиент)
	|ГДЕ
	|	Депоненты.Ссылка.КД = &КД
	|	И НЕ Депоненты.РазделСчетаПолучатель ЕСТЬ NULL 
	|	И НЕ Депоненты.Ссылка.ПометкаУдаления
	|	И Депоненты.РазделСчета.РазделСубклиента = ИСТИНА
	|	И Депоненты.РазделСчета.ТипРазделаСчетаДЕПО <> &Налоговый
	|	И УсловноеДлящеесяПоручение.Депонент ЕСТЬ NULL
	|";
	Запрос.УстановитьПараметр("КД",			ДокументОснование);
	Запрос.УстановитьПараметр("Дата",		Дата);
	Запрос.УстановитьПараметр("ФормаW8",	Справочники.ВидыДокументовУдостоверяющихПолномочия.ФормаW8BENE_W8BEN);
	Запрос.УстановитьПараметр("УсловноеДлящеесяПоручение", Справочники.ВидыДокументовУдостоверяющихПолномочия.УсловноеДлящеесяПоручение);
	Запрос.УстановитьПараметр("Налоговый",	Перечисления.ТипыРазделовСчетовДЕПО.Налоговый);
	Возврат Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Депонент");
