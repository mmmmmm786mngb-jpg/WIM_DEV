	Data.Вставить("MailTemplateTitle", "ОПроведенииКД_СвязанногоСВыплатой");
	
	ReplaceFields = Data.ReplaceFields;
	ReplaceFields.Вставить("ДатаКДПлан", ФорматОбязательнойДаты(ДатаКДПлан, "ДатаКДПлан_СвязанногоСВыплатой"));
