	<Attributes>
		<Attribute name="Список" id="1">
			<Type>
				<v8:Type>cfg:DynamicList</v8:Type>
			</Type>
			<MainAttribute>true</MainAttribute>
			<Settings xsi:type="DynamicList">
				<ManualQuery>true</ManualQuery>
				<DynamicDataRead>true</DynamicDataRead>
				<QueryText>ВЫБРАТЬ РАЗЛИЧНЫЕ
	ДокументПоручение.Ссылка КАК Ссылка,
	ДокументПоручение.ПометкаУдаления КАК ПометкаУдаления,
	ДокументПоручение.Номер КАК Номер,
	ДокументПоручение.Дата КАК Дата,
	ДокументПоручение.Проведен КАК Проведен,
	ДокументПоручение.Автор КАК Автор,
	ДокументПоручение.ВидОперацииД КАК ВидОперацииД,
	ДокументПоручение.ТипКонвертации КАК ТипКонвертации,
	ДокументПоручение.ВидПредставителяСчетаДепо КАК ВидПредставителяСчетаДепо,
	ДокументПоручение.ВидПредставителяСчетаДепоПодпись КАК ВидПредставителяСчетаДепоПодпись,
	ДокументПоручение.ВходящийНомерПоручения КАК ВходящийНомерПоручения,
	ДокументПоручение.ДатаКонПериода КАК ДатаКонПериода,
	ДокументПоручение.ДатаНачалаДоверенности КАК ДатаНачалаДоверенности,
	ДокументПоручение.ДатаНачПериода КАК ДатаНачПериода,
	ДокументПоручение.ДатаОкончанияДоверенности КАК ДатаОкончанияДоверенности,
	ДокументПоручение.ДатаПриема КАК ДатаПриема,
	ДокументПоручение.ДокументОснование КАК ДокументОснование,
	ДокументПоручение.Изменил КАК Изменил,
	ДокументПоручение.Инициатор КАК Инициатор,
	ДокументПоручение.КоличествоЦБ КАК КоличествоЦБ,
	ВЫРАЗИТЬ(ДокументПоручение.Комментарий КАК СТРОКА(1000)) КАК Комментарий,
	ДокументПоручение.Контрагент КАК Контрагент,
	ДокументПоручение.МХ_ПоУмолчанию КАК МХ_ПоУмолчанию,
	ДокументПоручение.МХДепонента КАК МХДепонента,
	ДокументПоручение.МХКонтрагент КАК МХКонтрагент,
	ДокументПоручение.НомерДоверенностиПредставителя КАК НомерДоверенностиПредставителя,
	ДокументПоручение.ОснованиеОтмены КАК ОснованиеОтмены,
	ДокументПоручение.ОтменяемоеПоручение КАК ОтменяемоеПоручение,
	ДокументПоручение.ПредставительСчетаДепо КАК ПредставительСчетаДепо,
	ДокументПоручение.РазделСчетаДепо КАК РазделСчетаДепо,
	ДокументПоручение.РазделСчетаДепоКонтрагента КАК РазделСчетаДепоКонтрагента,
	ДокументПоручение.СпособПриемаПоручений КАК СпособПриемаПоручений,
	ДокументПоручение.СуммаСделки КАК СуммаСделки,
	ДокументПоручение.СчетДепо КАК СчетДепо,
	ДокументПоручение.СчетДепоКонтрагента КАК СчетДепоКонтрагента,
	ДокументПоручение.ТипСчетаДепо КАК ТипСчетаДепо,
	ДокументПоручение.ЦБ КАК ЦБ,
	ДокументПоручение.ЦенаСделкиЦБ КАК ЦенаСделкиЦБ,
	ДокументПоручение.ЭмитентВыписка КАК ЭмитентВыписка,
	ДокументПоручение.ЭмитентУведомление КАК ЭмитентУведомление,
	ДокументПоручение.Валюта КАК Валюта,
	ДокументПоручение.РучнойВвод КАК РучнойВвод,
	ДокументПоручение.ДатаИсполненияПоручения КАК ДатаИсполненияПоручения,
	ДокументПоручение.ТипРазделаСчетаДЕПО КАК ТипРазделаСчетаДЕПО,
	ДокументПоручение.ИдентификаторЗагрузки КАК ИдентификаторЗагрузки,
	ДокументПоручение.МоментВремени КАК МоментВремени,
	СтатусыПорученийСрезПоследних.СтатусПоручения КАК СтатусПоручения,
	ВЫБОР
		КОГДА ДокументПоручение.СчетДепо = НЕОПРЕДЕЛЕНО
				ИЛИ ДокументПоручение.СчетДепо = ЗНАЧЕНИЕ(Справочник.СчетаДепо.)
				ИЛИ ДокументПоручение.СчетДепо = ЗНАЧЕНИЕ(Справочник.СчетаДепоМХ.)
			ТОГДА ДокументПоручение.Депонент
		ИНАЧЕ ДокументПоручение.СчетДепо.Владелец
	КОНЕЦ КАК Депонент,
	ДокументПоручение.УведомлениеОтправлено КАК УведомлениеОтправлено,
	ЕСТЬNULL(СостоянияДокументовВФайловомШлюзеСрезПоследних.Статус, СостоянияДокументовВФайловомШлюзеСрезПоследнихНетто.Статус) КАК СтатусФайловыйШлюз,
	ДокументПоручение.Периодичность КАК Периодичность
ИЗ
	Документ.Поручение КАК ДокументПоручение
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СтатусыПоручений.СрезПоследних КАК СтатусыПорученийСрезПоследних
		ПО (СтатусыПорученийСрезПоследних.Поручение = ДокументПоручение.Ссылка)
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СостоянияДокументовВФайловомШлюзе.СрезПоследних(, ) КАК СостоянияДокументовВФайловомШлюзеСрезПоследних
		ПО (СостоянияДокументовВФайловомШлюзеСрезПоследних.Документ В
				(ВЫБРАТЬ ПЕРВЫЕ 1
					Документ.ТехническаяОперация.Ссылка
				ИЗ
					Документ.ТехническаяОперация
				ГДЕ
					Документ.ТехническаяОперация.ДокументОснование = ДокументПоручение.Ссылка
				УПОРЯДОЧИТЬ ПО
					Документ.ТехническаяОперация.Дата УБЫВ))
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СостоянияДокументовВФайловомШлюзе.СрезПоследних(, ) КАК СостоянияДокументовВФайловомШлюзеСрезПоследнихНетто
		ПО (СостоянияДокументовВФайловомШлюзеСрезПоследнихНетто.Документ В
				(ВЫБРАТЬ ПЕРВЫЕ 1
					Документ.ТехническаяОперация.Ссылка
				ИЗ
					Документ.ТехническаяОперация
				ГДЕ
					Документ.ТехническаяОперация.ДокументОснование В
						(ВЫБРАТЬ РАЗЛИЧНЫЕ
							Документ.НеттоПоручение.Поручения.Ссылка
						ИЗ
							Документ.НеттоПоручение.Поручения
						ГДЕ
							Документ.НеттоПоручение.Поручения.Поручение = ДокументПоручение.Ссылка
