		Область.Параметры.ДанныеДоговор = СчетДепо.НомерДепозитарногоДоговора + " от " + Формат(СчетДепо.ДатаЗаключенияДепозитарногоДоговора,"ДФ=dd.MM.yyyy; ДЛФ=DD");	
	КонецЕсли; 
	
	Область.Параметры.НомерДоверенности = НомерДоверенностиПредставителя + " от "+ Формат(ДатаНачалаДоверенности,"ДЛФ=DD");
	
	ТабДок.Вывести(Область);
	
	//Подвал Оператора или Распорядителя
	Если ВидОперацииД   = Справочники.ВидыОпераций.НазначениеОператораСчетаДепо
		ИЛИ ВидОперацииД   = Справочники.ВидыОпераций.ОтменаОператораСчетаДепо   Тогда
		Область = Макет.ПолучитьОбласть("ПодвалОператор");
		Область.Параметры.ПодписьДепонент     = Инициатор.Наименование;
		Область.Параметры.ПодписьОператора    = ПредставительСчетаДепо.Руководитель;
		ТабДок.Вывести(Область);
	Иначе
		Область = Макет.ПолучитьОбласть("ПодвалРаспорядитель");
		Область.Параметры.ПодписьДепонент 	 = Инициатор.Наименование;
		Область.Параметры.ПодписьРапорядитель = ПредставительСчетаДепо.Руководитель;
		ТабДок.Вывести(Область);  
	КонецЕсли;
	
	ФормированиеПечатныхФорм.ПоказатьТабличныйДокумент(ТабДок);
	
КонецПроцедуры

Процедура ПечатьПорученияОперацииЦБ()
	
	ТабДок 	= Новый ТабличныйДокумент;
	Макет 	= Документы.Поручение.ПолучитьМакет("ОперацииСЦБ");
	// Заголовок
	Область = Макет.ПолучитьОбласть("Заголовок");
	//установка параметров Заголовка
	Депозитарий = Константы.ОрганизацияПоУмолчанию.Получить();
	Если Депозитарий.Пустая() тогда
		Сообщить("Не выбрано значение организации, используемое по умолчанию!!!");
		Возврат;
	КонецЕсли;
	Область.Параметры.Организация = Депозитарий.НаименованиеПолное;
	ДанныеЛицензии = ФормированиеПечатныхФорм.ДанныеЛицензииОрганизации(Депозитарий);	 
	Область.Параметры.ЛицензияНомер = "Лицензия № "+ДанныеЛицензии.НомерЛицензии + " от ";
	Область.Параметры.ЛицензияДата = ДанныеЛицензии.ДатаЛицензии + " г. ";
	ТабДок.Вывести(Область);
	
	//Форма Д11
	Область = Макет.ПолучитьОбласть("ФормаД11");
	Область.Параметры.Дата = Формат(Дата,"ДЛФ=DD");
	
	ТабДок.Вывести(Область);
	//Шапка
	Область = Макет.ПолучитьОбласть("Шапка");
	//Депонент
	Если ЗначениеЗаполнено(Инициатор) Тогда
		Область.Параметры.Депонент						= Инициатор.НаименованиеПолное;
		Область.Параметры.СчетДепоНомер 				= СчетДепо.Код;
		Область.Параметры.РазделСчетаДепо				= РазделСчетаДепо.Наименование+" "+СокрЛП(РазделСчетаДепо.Код);
		Область.Параметры.ТипСчета						= СчетДепо.ТипСчетаДепо;
		// МХ Депонент
		Если МХ_ПоУмолчанию Тогда	
			Область.Параметры.МХДепонента               = МХ_Константа;
		Иначе	
			Область.Параметры.МХДепонента				= МХДепонента.Наименование;	
		КонецЕсли;
		//Документ депонент
		Если Инициатор.ЮрФизЛицо = Перечисления.ЮрФизЛицо.ФизЛицо Тогда
			Область.Параметры.Документ_Депонент  = ФормированиеПечатныхФорм.ПолучитьПаспорныеДанныеСтрокой(Инициатор.ФизЛицо);//паспортные данные
		Иначе
			Область.Параметры.Документ_Депонент  = "Свидетельство о регистрации № " + Инициатор.НомерГосударственнойРегистрации
			+ " выдано " + Инициатор. НаименованиеОрганаРегистрации
			+ " дата выдачи " + Формат(Инициатор.ДатаГосударственнойРегистрации,"ДЛФ=DD");//свидетельство о регистрации
		КонецЕсли;                                   
		Область.Параметры.КонтактноеЛицо				= Инициатор.ОсновноеКонтактноеЛицо;	
	КонецЕсли; 
	//Контрагент
	Если ЗначениеЗаполнено(Контрагент) Тогда
		Область.Параметры.Контрагент					= Контрагент.НаименованиеПолное;
		Область.Параметры.СчетДепоНомерКонтрагент 		= СчетДепоКонтрагента.Код;
		Область.Параметры.РазделСчетаДепоКонтрагент		= РазделСчетаДепоКонтрагента.Наименование+" "+СокрЛП(РазделСчетаДепоКонтрагента.Код);	
		Область.Параметры.ТипСчетаКонтрагент			= СчетДепоКонтрагента.ТипСчетаДепо;
		// МХ Контрагент
		Если МХ_ПоУмолчанию Тогда		
			Область.Параметры.МХДепонентаКонтрагент		= МХ_Константа;
		Иначе		
			Область.Параметры.МХДепонентаКонтрагент		= МХКонтрагент.Наименование;
		КонецЕсли; 
		//Документ Контрагент
		Если Контрагент.ЮрФизЛицо = Перечисления.ЮрФизЛицо.ФизЛицо Тогда
			Область.Параметры.Документ_Контрагент  = ФормированиеПечатныхФорм.ПолучитьПаспорныеДанныеСтрокой(Контрагент.ФизЛицо);//паспортные данные
		Иначе
			Область.Параметры.Документ_Контрагент  = "Свидетельство о регистрации № " + Контрагент.НомерГосударственнойРегистрации
			+ " выдано " + Контрагент. НаименованиеОрганаРегистрации
			+ " дата выдачи " + Формат(Контрагент.ДатаГосударственнойРегистрации,"ДЛФ=DD");//свидетельство о регистрации
		КонецЕсли;            
		Область.Параметры.КонтактноеЛицоКонтрагент		= Контрагент.ОсновноеКонтактноеЛицо;
	КонецЕсли;
	//ЦБ
	Область.Параметры.Эмитент						= ЦБ.Эмитент.НаименованиеПолное;
	Область.Параметры.ВидЦБ                         = Строка(ЦБ.ТипЦБ) + " " + Строка(ЦБ.ВидЦБ);
	Область.Параметры.НомРег                        = ЦБ.НомерРегистрации;
	Область.Параметры.ДатаРег                       = Формат(ЦБ.ДатаГосРег,"ДЛФ=DD");
	//получение номинал ЦБ из регистра сведений НоминалЦБ.
	Номинал	=	РегистрыСведений.НоминалЦБ.ПолучитьПоследнее(Дата,Новый Структура("ЦеннаяБумага",ЦБ)).Сумма;
	
	Область.Параметры.Номинал                       = Номинал;
	Область.Параметры.НоминалПрописью               = ФормированиеПечатныхФорм.КоличествоПрописью(Номинал);
	Область.Параметры.Количество                    = КоличествоЦБ;
	Область.Параметры.КоличествоПрописью            = ФормированиеПечатныхФорм.КоличествоПрописью(КоличествоЦБ);
	Область.Параметры.ЦенаСделки					= ЦенаСделкиЦБ * КоличествоЦБ;
	Область.Параметры.ЦенаСделкиПрописью            = ФормированиеПечатныхФорм.КоличествоПрописью(ЦенаСделкиЦБ * КоличествоЦБ);
	ТабДок.Вывести(Область);  
	
	//Операция   
	Область = Макет.ПолучитьОбласть("Операция");
	Область.Параметры.ВидОперации = ВидОперацииД;
	Область.Параметры.Комментарий = Комментарий;
	ТабДок.Вывести(Область);  
	
	//Отметки   
	Область = Макет.ПолучитьОбласть("Отметки");
	Если Инициатор.ЮрФизЛицо = Перечисления.ЮрФизЛицо.ФизЛицо Тогда
		Область.Параметры.ПодписьДепонент    = ОбщегоНазначения.ДанныеФизЛица(Константы.ОрганизацияПоУмолчанию.Получить(), Инициатор.ФизЛицо, РабочаяДата).Представление;
	Иначе
		Область.Параметры.ПодписьДепонент    = Инициатор.Руководитель;
	КонецЕсли;
	Если Контрагент.ЮрФизЛицо = Перечисления.ЮрФизЛицо.ФизЛицо Тогда
		Область.Параметры.ПодписьКонтрагент  = Контрагент.Наименование;
	Иначе
		Область.Параметры.ПодписьКонтрагент  = Контрагент.Руководитель;	
	КонецЕсли; 	
	
	ТабДок.Вывести(Область);  	
	ФормированиеПечатныхФорм.ПоказатьТабличныйДокумент(ТабДок);
	
КонецПроцедуры

Процедура ПечатьПорученияУведомлениеВыписка()
	
	ТабДок = Новый ТабличныйДокумент;
	Макет = Документы.Поручение.ПолучитьМакет("Уведомление");
	// Заголовок	
	Область = Макет.ПолучитьОбласть("Заголовок");
	
	Депозитарий = Константы.ОрганизацияПоУмолчанию.Получить();
	Если Депозитарий.Пустая() тогда
		Сообщить("Не выбрано значение организации, используемое по умолчанию!!!");
		Возврат;
	КонецЕсли;
	
	Область.Параметры.Организация	= Депозитарий.Наименование; 
	ДанныеЛицензии					= ФормированиеПечатныхФорм.ДанныеЛицензииОрганизации(Депозитарий);
	Область.Параметры.ДатаЛицензии	= ДанныеЛицензии.ДатаЛицензии + " г.";
	Область.Параметры.НомерЛицензии	= ДанныеЛицензии.НомерЛицензии;
	
	// фактический адрес - не квартира, а офис
	ФактАдрес						= КонтактнаяИнформация.ПолучитьАдресИзКонтактнойИнформации(Депозитарий,"Фактический");
	Область.Параметры.ФактАдрес		= СтрЗаменить(ФактАдрес,"кв.","офис");
	Область.Параметры.ТелФакс		= КонтактнаяИнформация.ПолучитьТелефонИзКонтактнойИнформации(Депозитарий);
	
	ТабДок.Вывести(Область);
	//Шапка
	Область = Макет.ПолучитьОбласть("Шапка");
	Область.Параметры.ДанныеДепонент	=	"Депонент " + Инициатор.НаименованиеПолное;
	//установка номера счета депо
	НомерКодаСчета = 1;
	Пока НомерКодаСчета < 12 Цикл
		
		Область.Параметры["П"+НомерКодаСчета]        = Сред(СокрЛП(СчетДепо.Код),НомерКодаСчета,1);
		НомерКодаСчета	 =	НомерКодаСчета + 1;
		
	КонецЦикла; 
	ТабДок.Вывести(Область);
	
	//Уведомление
	Область = Макет.ПолучитьОбласть("Уведомление");	
	Если ( НЕ ОбщегоНазначения.ЗначениеНеЗаполнено(ДатаНачПериода)) И ( НЕ ОбщегоНазначения.ЗначениеНеЗаполнено(ДатаКонПериода))  Тогда
		Область.Параметры.в1			= "V";
		Область.Параметры.ВыбрПериод	= "с " + Формат(ДатаНачПериода,"ДЛФ=DD")+ " по " + Формат(ДатаКонПериода,"ДЛФ=DD");
	Иначе		
		Область.Параметры.в1			= "";		
		Область.Параметры.ВыбрПериод	= "с______________________г. по_______________________г. ";
	КонецЕсли; 
	Область.Параметры.в2    = "";
	Область.Параметры.в3    = "";
	Область.Параметры.в4    = "";
	Область.Параметры.в5    = "";
	Область.Параметры.в6    = "";
	Область.Параметры.в7    = "";
	
	//уведомление
	Если ЭмитентУведомление.Пустая() Тогда
		Если НЕ МХДепонента.Пустая() Тогда		
			Область.Параметры.в2    = "V";	
		Иначе 
			Область.Параметры.в2    = "";	
		КонецЕсли; 
	Иначе	
		Если НЕ МХКонтрагент.Пустая() Тогда		
			Область.Параметры.в4    = "V";	
		Иначе 
			Область.Параметры.в3    = "V";	
		КонецЕсли; 		
	КонецЕсли;
	//выписка
	Если ЭмитентВыписка.Пустая() Тогда
		Область.Параметры.в5    = "V";	
	Иначе	
		Если МХКонтрагент.Пустая() Тогда		
			Область.Параметры.в7    = "V";	
		Иначе 
			Область.Параметры.в6    = "V";	
		КонецЕсли; 		
	КонецЕсли;
	
	ТабДок.Вывести(Область);	
	
	ВывестиПодвалМакетаВТабличныйДокумент(Макет, ТабДок);
	
	ФормированиеПечатныхФорм.ПоказатьТабличныйДокумент(ТабДок);
	
КонецПроцедуры

Процедура ВывестиПодвалМакетаВТабличныйДокумент(Макет, ТабДок)
	
	Область = Макет.ПолучитьОбласть("Подвал");
	Область.Параметры.ПодписьДепонент = Инициатор.Наименование;
	ТабДок.Вывести(Область);
	
КонецПроцедуры

Процедура Печать(ИмяМакета, КоличествоЭкземпляров = 1, НаПринтер = Ложь, НепосредственнаяПечать = Ложь) Экспорт
		
	Перем ВидыОпераций;
	
	ВидыОпераций = Справочники.ВидыОпераций;
	
	Если Не ЗначениеЗаполнено(Инициатор) Тогда
		
		Сообщить("Не выбран Инициатор поручения! Печать не возможна!");
		Возврат;
		
	КонецЕсли; 
	
	Если ВидОперацииД = ВидыОпераций.ОткрытиеСчетаДепо Тогда
		
		Если ТипЗнч(Инициатор) = Тип("СправочникСсылка.МестаХранения") Тогда
			Сообщить("Для вида операции: " + ВидОперацииД + " - Нет печатной формы.");
		Иначе
			ПечатьПорученияОткрытиеСчетаДепо();
		КонецЕсли;
		
	ИначеЕсли ВидОперацииД = ВидыОпераций.НазначениеОператораСчетаДепо
		ИЛИ ВидОперацииД = ВидыОпераций.ОтменаОператораСчетаДепо   
		ИЛИ ВидОперацииД = ВидыОпераций.НазначениеРаспорядителяСчетаДепо 
		ИЛИ ВидОперацииД = ВидыОпераций.ОтменаРаспорядителяСчетаДепо Тогда
		
		ПечатьПорученияОператораРаспорядителяСчетаДепо();
		
	ИначеЕсли ВидОперацииД = ВидыОпераций.НазначениеПопечителяСчетаДепо Тогда
		
		ПечатьПорученияНазначениеПопечителяСчетаДепо();
		
	ИначеЕсли ВидОперацииД = ВидыОпераций.ОтзывПопечителяСчетаДепо Тогда 
		
		ПечатьПорученияОтзывПопечителяСчетаДепо();
		
	ИначеЕсли ВидОперацииД = ВидыОпераций.ЗакрытиеСчетаДепо Тогда	
		
		ПечатьПорученияЗакрытияСчетаДепо();
		
	ИначеЕсли ВидОперацииД = ВидыОпераций.КорректировкаРеквизитовСчетаДепо Тогда	
		
		ПечатьПорученияКорректировкаСчетаДепо();		    					
		
	ИначеЕсли ВидОперацииД = ВидыОпераций.ПредоставлениеУведомления Тогда	
		
		ПечатьПорученияУведомлениеВыписка();
		
	ИначеЕсли ВидОперацииД = ВидыОпераций.ОткрытиеРазделаСчетаДепо Тогда	
		
		Сообщить("Для данного вида поручения печатной формы не предусмотренно!");
		
	ИначеЕсли ВидОперацииД = ВидыОпераций.Депонирование  
		ИЛИ ВидОперацииД = ВидыОпераций.СнятиеСДепонирования				
		ИЛИ ВидОперацииД = ВидыОпераций.Обременение
		ИЛИ ВидОперацииД = ВидыОпераций.ВозвратИзЗалога
		ИЛИ ВидОперацииД = ВидыОпераций.Конвертация
		ИЛИ ВидОперацииД = ВидыОпераций.Перевод
		ИЛИ ВидОперацииД = ВидыОпераций.ПередачаВЗалог
		ИЛИ ВидОперацииД = ВидыОпераций.Перемещение
		ИЛИ ВидОперацииД = ВидыОпераций.ПереводМеждуРазделамиСчетаДепо
		ИЛИ ВидОперацииД = ВидыОпераций.Погашение
		ИЛИ ВидОперацииД = ВидыОпераций.СписаниеАкцийПриЛиквидацииЭмитента
		ИЛИ ВидОперацииД = ВидыОпераций.СписаниеОбесценившихсяЦенныхБумаг
		ИЛИ ВидОперацииД = ВидыОпераций.ВыкупСписаниеЦБ
		ИЛИ ВидОперацииД = ВидыОпераций.СнятиеОбременения
		ИЛИ ВидОперацииД = ВидыОпераций.Разблокирование Тогда
		
		ПечатьПорученияОперацииЦБ();
		
	Иначе
		
		Сообщить("Для данного вида поручения печатной формы не предусмотренно!");
		
	КонецЕсли;   
		
КонецПроцедуры
	
#КонецЕсли

Процедура ОтправитьУведомлениеСУДК(ВебСервисДоступен = Истина) Экспорт
	
	Если Не Проведен Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Документ должен быть проведен!");
		Возврат;
	ИначеЕсли Не ЗначениеЗаполнено(ДатаИсполненияПоручения) Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Поручение ещё не исполнено!");
		Возврат;
	КонецЕсли;
	РегламентнаяВалюта = Константы.ВалютаРегламентированногоУчета.Получить();
	Если Не ЗначениеЗаполнено(РегламентнаяВалюта) Тогда
		ТекстОшибки = "Не задана валюта регламентированного учета!";
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстОшибки);
		Возврат;
