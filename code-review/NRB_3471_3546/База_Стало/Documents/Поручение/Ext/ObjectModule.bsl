Процедура СнятьЦенныеБумагиСОбслуживания(Отказ)
	Перем ЦеннаяБумага, МассивЦБ;
	
	МассивЦБ = Новый Массив;
	Если ВидОперацииД = Справочники.ВидыОпераций.Конвертация Тогда
		ТаблицаЦБ = Списание.Выгрузить(, "ЦеннаяБумага");
		ТаблицаЦБ.Свернуть("ЦеннаяБумага");
		МассивЦБ = ТаблицаЦБ.ВыгрузитьКолонку("ЦеннаяБумага");
	ИначеЕсли ВидОперацииД = Справочники.ВидыОпераций.Погашение
				ИЛИ ВидОперацииД = Справочники.ВидыОпераций.СписаниеАкцийПриЛиквидацииЭмитента
				ИЛИ ВидОперацииД = Справочники.ВидыОпераций.СписаниеОбесценившихсяЦенныхБумаг
				ИЛИ ВидОперацииД = Справочники.ВидыОпераций.ВыкупСписаниеЦБ Тогда
		МассивЦБ.Добавить(ЦБ);
	КонецЕсли;
	Для Каждого ЦеннаяБумага Из МассивЦБ Цикл
		СоздатьОбновитьДокументСнятияЦБСОбслуживания(ЦеннаяБумага, Отказ);
	КонецЦикла;
КонецПроцедуры

Процедура СоздатьОбновитьДокументСнятияЦБСОбслуживания(ЦеннаяБумага, Отказ)
	Перем Параметры, Документ;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ВидОперацииД",		Справочники.ВидыОпераций.СнятиеЦБсОбслуживания);
	Запрос.УстановитьПараметр("ДокументОснование",	Ссылка);
	Запрос.УстановитьПараметр("ЦеннаяБумага",		ЦеннаяБумага);
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ЦенныеБумагиОбслуживание.Ссылка КАК ДокументОбслуживания
	|ИЗ
	|	Документ.ЦенныеБумагиОбслуживание КАК ЦенныеБумагиОбслуживание
	|ГДЕ
	|	ЦенныеБумагиОбслуживание.ВидОперацииД = &ВидОперацииД
	|	И ЦенныеБумагиОбслуживание.ДокументОснование = &ДокументОснование
	|	И ЦенныеБумагиОбслуживание.ЦБ = &ЦеннаяБумага
	|
	|ДЛЯ ИЗМЕНЕНИЯ";
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Документ = Выборка.ДокументОбслуживания.ПолучитьОбъект();
	Иначе
		Документ = Документы.ЦенныеБумагиОбслуживание.СоздатьДокумент();
	КонецЕсли;
	
	Если Документ.ПометкаУдаления Тогда
		Документ.ПометкаУдаления = Ложь;
		Документ.Записать(РежимЗаписиДокумента.Запись);
	КонецЕсли;	
	
	// Структура для заполнения документа снятия с обслуживания
	Параметры = Новый Структура;
	Параметры.Вставить("ВидОперацииД", Справочники.ВидыОпераций.СнятиеЦБсОбслуживания);
	Параметры.Вставить("ДатаИсполненияПоручения", ДатаИсполненияПоручения);
	Параметры.Вставить("Дата", Дата);
	Параметры.Вставить("Ссылка", Ссылка);
	Параметры.Вставить("ВходящийНомерПоручения", ВходящийНомерПоручения);
	Параметры.Вставить("Инициатор", Инициатор);
	Параметры.Вставить("ЦБ", ЦеннаяБумага);
	
	Документ.Заполнить(Параметры);
	Попытка
		Документ.Записать(РежимЗаписиДокумента.Проведение);
	Исключение
		Отказ = Истина;
	КонецПопытки;
КонецПроцедуры

Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
	Если ОбменДанными.Загрузка = Истина Тогда
		Если ДополнительныеСвойства.Свойство("Перенумерация") И ДополнительныеСвойства.Перенумерация Тогда // BSLLS:Typo-off
			ЗаполнитьОчиститьУИН();
		КонецЕсли;
		
		Возврат;
	КонецЕсли;
	
	СтатусПоручения = РегистрыСведений.СтатусыПоручений.СтатусПоручения(Ссылка);
	
	Если РежимЗаписи = РежимЗаписиДокумента.Проведение И Ссылка.Проведен И Ссылка.ВидОперацииД <> ВидОперацииД Тогда
		ТекстСообщения = "Нельзя изменять вид операции проведенного поручения, т.к. на основании данного поручения созданы документы!";
		ОбщегоНазначения.СообщитьОбОшибке(ТекстСообщения, Отказ);
	КонецЕсли;

	ЭтоПерепроведениеИсполненногоПорученияПоДвижениюЦБ = (РежимЗаписи = РежимЗаписиДокумента.Проведение И Ссылка.Проведен
															И СтатусПоручения = Перечисления.СтатусыПоручений.Исполнено
															И Документы.Поручение.ЭтоПоручениеПоДвижениюЦБ(ВидОперацииД));
	Если ЭтоПерепроведениеИсполненногоПорученияПоДвижениюЦБ Тогда
		ТекстСообщения = "Повторное проведение " + Ссылка + " в статусе Исполнено запрещено, обратитесь в команду Поддержки!";
		ОбщегоНазначения.СообщитьОбОшибке(ТекстСообщения, Отказ);
	КонецЕсли;
	
	Если РежимЗаписи = РежимЗаписиДокумента.Проведение И Ссылка.Проведен И Ссылка.ВидОперацииД <> ВидОперацииД Тогда
		ТекстСообщения = "Нельзя изменять вид операции проведенного поручения, т.к. на основании данного поручения созданы документы!";
		ОбщегоНазначения.СообщитьОбОшибке(ТекстСообщения, Отказ);
	КонецЕсли;
		
	// Продублируем единственную ЦБ в шапке для поддержания работоспособности неттинга и отбора в списке
	Если Документы.Поручение.ЭтоНеторговоеПоручениеСоСпискомЦБ(ЭтотОбъект) Тогда
		Если ЦенныеБумагиСписываемые.Количество() = 1 Тогда
			ЦБ = ЦенныеБумагиСписываемые[0].ЦеннаяБумага;
			КоличествоЦБ = ЦенныеБумагиСписываемые[0].Количество;
			ЦенаСделкиЦБ = ЦенныеБумагиСписываемые[0].Цена;
			СуммаСделки = ЦенныеБумагиСписываемые[0].Сумма;
		Иначе
			ЦБ = Неопределено;
			КоличествоЦБ = 0;
			ЦенаСделкиЦБ = 0;
			СуммаСделки = 0;
			Если ЕстьСтрокиСПовторяющейсяЦБ() Тогда
				Отказ = Истина;
				Возврат;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	УстановитьНачислениеНалога();
	Если Не ЗначениеЗаполнено(ПричинаОтмены) И ВидОперацииД = Справочники.ВидыОпераций.ОтменаПоручения Тогда
		ОбщегоНазначения.СообщитьОбОшибке("Не указана причина отмены для поручения на отмену!!!", Отказ);
		Возврат;
	КонецЕсли;	
	
	Если ВидОперацииД = Справочники.ВидыОпераций.Конвертация И Не ЗначениеЗаполнено(ТипКонвертации) Тогда
		ОбщегоНазначения.СообщитьОбОшибке("Не указан 'Тип конвертации' по поручению на конвертацию!!!", Отказ);
		Возврат;
	КонецЕсли;	
	
	Если ВидОперацииД = Справочники.ВидыОпераций.ОткрытиеСчетаДепо И Не ЗначениеЗаполнено(ВидСчетаДепо) Тогда
		ОбщегоНазначения.СообщитьОбОшибке("Не указан 'Вид счета ДЕПО' для поручения на Открытие счета ДЕПО!!!", Отказ);
		Возврат;
	КонецЕсли;
	
	Если ВидОперацииД = Перечисления.ВидыОтчетов.ВыпискаОСостоянииСчетаДЕПО
		Или ВидОперацииД = Перечисления.ВидыОтчетов.ОтчетОбОперацияхПоСчетуДЕПО
		Или ВидОперацииД = Перечисления.ВидыОтчетов.СводныйОтчетОСовершеннойОперации Тогда
		
		Если Справочники.Контрагенты.ОсобыеУсловия(Инициатор) Тогда
			Если НЕ РегистрыСведений.ОтветственныеЛицаОрганизаций.ПользовательМожетРедактироватьОсобыеУсловия() Тогда
				ОбщегоНазначения.СообщитьОбОшибке("Особые условия: " + Инициатор 
				+ ". Выполнение операции доступно Ответственному за особых клиентов", Отказ);
				Возврат;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	Если Документы.Поручение.ЭтоПериодическиеВыпискиОСостоянииСчетаДЕПО(ЭтотОбъект) Тогда
		Если Не ЗначениеЗаполнено(ДатаНачПериода) Тогда
			ТекстСообщения = "Не указано начиная с какой даты нужно присылать выписку!";
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
			Отказ = Истина;
			Возврат;
		КонецЕсли;
		
		Если Не ОбщегоНазначения.РабочийДень(ДатаНачПериода) Тогда
			ТекстСообщения = "Дата, начиная с которой нужно присылать выписку не является рабочим днем!";
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
			Отказ = Истина;
			Возврат;
		КонецЕсли;
		
		Если Не ЗначениеЗаполнено(СчетДепо) Тогда
			ТекстСообщения = "Не указан счет ДЕПО по которому необходимо предоставлять выписку!";
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
			Отказ = Истина;
			Возврат;
		КонецЕсли;
		
		ВладелецСчета = СчетДепо.Владелец;
		КлассификаторНРД = Справочники.КлассификаторыЗагрузки.НДЦ();
		ТекущаяДата = НачалоДня(ТекущаяДатаСеанса());
		КодНРДВладельцаСчета = Справочники.КодыЗагрузки.НайтиПоВладельцуИБирже(ВладелецСчета, КлассификаторНРД, ТекущаяДата);
		Если Не ЗначениеЗаполнено(КодНРДВладельцаСчета) Тогда
			ТекстСообщения = "Для владельца счета (" + Строка(ВладелецСчета) + ") не задан актуальный код НРД!";
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
			Отказ = Истина;
			Возврат;
		КонецЕсли;
	КонецЕсли;
	
	УстановитьНовыйНомер();
	
	Если ЭтоНовый() Тогда
		Если Не ЗначениеЗаполнено(Автор) Тогда
			Автор	= ПараметрыСеанса.ТекущийПользователь;
		КонецЕсли;
		Изменил	= Справочники.Пользователи.ПустаяСсылка();
	Иначе
		Изменил	= ПараметрыСеанса.ТекущийПользователь;
	КонецЕсли;
	
	Если Отказ Тогда
		Сообщить("Этот документ не является последним. Запись запрещена",СтатусСообщения.ОченьВажное);
	Иначе
		Если РежимЗаписи = РежимЗаписиДокумента.Проведение
			 И ВходящийНомерПоручения <> Номер
			 И НЕ ЗначениеЗаполнено(ВходящийНомерПоручения) Тогда
			ВходящийНомерПоручения = Номер;
		КонецЕсли;
	КонецЕсли;
	
	// Обновим комментарий если надо
	Если Не ЗначениеЗаполнено(Комментарий)
		 И ( ВидОперацииД = Справочники.ВидыОпераций.ОткрытиеСчетаДепо
		 	 ИЛИ ВидОперацииД = Справочники.ВидыОпераций.ОткрытиеРазделаСчетаДепо
			 ИЛИ ВидОперацииД = Справочники.ВидыОпераций.НазначениеОператораСчетаДепо ) Тогда
		ПараметрыДоговора = ПолучитьПараметрыДоговораПоПоручению();
		Если ПараметрыДоговора.Количество()>0 Тогда
			Если ВидОперацииД = Справочники.ВидыОпераций.ОткрытиеСчетаДепо
				 ИЛИ ВидОперацииД = Справочники.ВидыОпераций.ОткрытиеРазделаСчетаДепо Тогда
				Комментарий	= "Депозитарный договор №"+ПараметрыДоговора[0].Код+" от "
					+Формат(ПараметрыДоговора[0].ДатаНачалоДействия, "ДФ=dd.MM.yyyy");
			ИначеЕсли ВидОперацииД = Справочники.ВидыОпераций.НазначениеОператораСчетаДепо Тогда
				Комментарий	= "Договор обслуживания на финансовых рынках №"+ПараметрыДоговора[0].Код
					+" от "+Формат(ПараметрыДоговора[0].ДатаНачалоДействия, "ДФ=dd.MM.yyyy");
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;	
	
	Если (ТипЗнч(ВидОперацииД) = Тип("СправочникСсылка.ВидыОпераций")) И ВидОперацииД.ДвижениеПоЦБ Тогда
		Если ЗначениеЗаполнено(ДатаИсполненияПоручения)
			И (НЕ ЗначениеЗаполнено(ДатаИсполненияПорученияВДепозитарииМХ)
			ИЛИ НЕ ЗначениеЗаполнено(ДатаИсполненияПорученияВМестеРасчетов)) Тогда
			ОбщегоНазначения.СообщитьОбОшибке("Необходимо указывать даты исполнения в депозитарии МХ и в месте расчетов!", Отказ);
			Возврат;
		КонецЕсли;
	КонецЕсли;
	
	Если ТипЗнч(ВидОперацииД) = Тип("СправочникСсылка.ВидыОпераций")
		И (ВидОперацииД = Справочники.ВидыОпераций.ПередачаВЗалог
			ИЛИ ВидОперацииД = Справочники.ВидыОпераций.ВозвратИзЗалога)
		И НЕ ЗначениеЗаполнено(Залогодержатель) Тогда
		ОбщегоНазначения.СообщитьОбОшибке("Для операций с залогами необходимо указать залогодержателя.", Отказ);
		Возврат;
	КонецЕсли;
	
	Если ВидОперацииД = Справочники.ВидыОпераций.НачислениеДоходовЦБ
			И НЕ ЗначениеЗаполнено(ЦББазовая) Тогда
		ОбщегоНазначения.СообщитьОбОшибке("Для операций начисления доходов ценными бумагами необходимо указать базовую ЦБ.", Отказ);
		Возврат;
	КонецЕсли;
	
	// Контроль равенства счетов ДЕПО и счетов МХ для перевода между разделами
	Если ВидОперацииД = Справочники.ВидыОпераций.ПереводМеждуРазделамиСчетаДепо Тогда 
		Если СчетДепо <> СчетДепоКонтрагента Тогда
			ОбщегоНазначения.СообщитьОбОшибке("Счет ДЕПО депонента не равен счету ДЕПО контрагента!", Отказ);
			Возврат;
		КонецЕсли;
		Если СчетДепоМХ <> СчетДепоМХКонтрагента Тогда
			ОбщегоНазначения.СообщитьОбОшибке("Счет ДЕПО МХ депонента не равен счету ДЕПО МХ контрагента!", Отказ);
			Возврат;
		КонецЕсли;
	КонецЕсли;
	
	//Контроль квалифицированного инвестора
	//Возможно изменим режим проведения
	КонтрольКвалИнвестора(РежимЗаписи, Отказ);
		
	Если (РежимЗаписи = РежимЗаписиДокумента.Проведение И ЗначениеЗаполнено(ДатаИсполненияПоручения))
			ИЛИ РежимЗаписи = РежимЗаписиДокумента.ОтменаПроведения
			ИЛИ ПометкаУдаления Тогда
		Если РегистрыСведений.СтатусыПоручений.СтатусПоручения(Ссылка) = Перечисления.СтатусыПоручений.Отменено Тогда
			ОбщегоНазначения.СообщитьОбОшибке("Это поручение отменено. Распроведите поручение на отмену.", Отказ);
			Возврат;
		КонецЕсли;
	КонецЕсли;
	
	
	Если (РежимЗаписи = РежимЗаписиДокумента.Проведение И ЗначениеЗаполнено(ДатаИсполненияПоручения))
			ИЛИ РежимЗаписи = РежимЗаписиДокумента.ОтменаПроведения
			ИЛИ ПометкаУдаления Тогда
		Если РегистрыСведений.СтатусыПоручений.СтатусПоручения(Ссылка) = Перечисления.СтатусыПоручений.Отменено Тогда
			ОбщегоНазначения.СообщитьОбОшибке("Это поручение отменено. Распроведите поручение на отмену.", Отказ);
			Возврат;
		КонецЕсли;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ДатаИсполненияПоручения) И РежимЗаписи = РежимЗаписиДокумента.Проведение Тогда
		Если ЕстьНеттоПоручениеСПустойДатойИсполнения() Тогда
			ОбщегоНазначения.СообщитьОбОшибке("Сначала необходимо исполнить связанное нетто-поручение!", Отказ);
			Возврат;
		КонецЕсли;
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(Ссылка) И ПринятьВОбработку
		ИЛИ ЗначениеЗаполнено(Ссылка) И НЕ Ссылка.ПринятьВОбработку И ПринятьВОбработку Тогда // Попытка установки флажка
		Причина = ПричинаЗапретаУстановкиФлажкаПринятьВОбработку();
		Если ЗначениеЗаполнено(Причина) Тогда
			ОбщегоНазначения.СообщитьОбОшибке("Запрещено устанавливать флажок ""Принять в обработку"" в "
			+ ?(ЗначениеЗаполнено(Ссылка), Ссылка, "поручении") + " по причине: " + Символы.ПС + Причина, Отказ);
			Возврат;
		КонецЕсли;
	КонецЕсли;
	
	Если ТипРазделаСчетаДЕПО = Перечисления.ТипыРазделовСчетовДЕПО.ОбеспеченияДержатель И Не ЗначениеЗаполнено(Брокер) Тогда
		ОбщегоНазначения.СообщитьОбОшибке("Для раздела Обеспечения (Держатель) необходимо указать брокера", Отказ);
		Возврат;
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(ВидПоручения) Тогда
		ВидПоручения = ВидПоручения();
	КонецЕсли;
	
	Если НеобходимоФормироватьУведомлениеОИсполненииОперацийСЦБ(РежимЗаписи) Тогда
		ДополнительныеСвойства.Вставить("НеобходимоФормироватьУведомлениеОИсполненииОперацийСЦБ", Истина);
	ИначеЕсли НеобходимоУдалитьУведомлениеОИсполненииОперацийСЦБ(РежимЗаписи) Тогда
		УдалитьЗаписьИзРССостоянияУведомленийОбОперацияхСЦБ();
	КонецЕсли;
	
	Если ТипЗнч(ВидОперацииД) = Тип("СправочникСсылка.ВидыОпераций")
		И ВидОперацииД.ВыплатаДоходаВДенежнойФорме
		И Документы.НачисленныйНалог.ИспользоватьРасчетНДФЛПоПрогрессивнойШкале(Дата)
		И РежимЗаписи = РежимЗаписиДокумента.Проведение Тогда
		
		СчетаДепо = ЦенныеБумагиСписываемые.Выгрузить(, "СчетДепо");
		МаксДаты = Документы.Поручение.МаксимальныеПлановыеДатыРасчетов(Дата, СчетаДепо);
		Для Каждого Строка Из ЦенныеБумагиСписываемые Цикл
			Если Не (Строка.ПлановаяДатаРасчетов >= НачалоДня(Дата)
					И Строка.ПлановаяДатаРасчетов <= МаксДаты[Строка.СчетДепо]) Тогда
					
				ОбщегоНазначения.СообщитьОбОшибке("Плановая дата расчетов для счета Депо " + СокрЛП(Строка.СчетДепо)
					+ " должна быть в интервале с " + Формат(Дата, "ДФ=dd.MM.yyyy") + " по "
					+ Формат(МаксДаты[Строка.СчетДепо], "ДФ=dd.MM.yyyy"), Отказ);
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(ОснованиеОперацииДКУ) И ЮрФизЛицоДепонентаКонтрагентаОдинаково() Тогда
	
		КодыВидовПорученийДляЗаполненияСтрока =
			РегистрыСведений.ПараметрыГлобальные.ЗначениеПараметра("696.КодыВидовПорученийДляЗаполненияКодаОснованияОперацииВПоручении");
		КодыВидовПорученийДляЗаполнения = СтрРазделить(КодыВидовПорученийДляЗаполненияСтрока, ",", Ложь);
		КодВидаПоручения = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ВидПоручения, "Код");
		Если КодыВидовПорученийДляЗаполнения.Найти(КодВидаПоручения) <> Неопределено Тогда
			ОснованиеОперацииДКУ = Справочники.КодыОснованияОперацийДКУ.TR01;
		КонецЕсли;
	
	КонецЕсли;
	
	ВидыОперацийДляПередачиВКафка = Новый Массив;
	ВидыОперацийДляПередачиВКафка.Добавить(Справочники.ВидыОпераций.Погашение);
	ВидыОперацийДляПередачиВКафка.Добавить(Справочники.ВидыОпераций.ВыкупСписаниеЦБ);
	
	Если ТипЗнч(ВидОперацииД) = Тип("СправочникСсылка.ВидыОпераций")
		И ВидыОперацийДляПередачиВКафка.Найти(ВидОперацииД) <> Неопределено Тогда
		Для Каждого СтрокаТЧ Из ЦенныеБумагиСписываемые Цикл
			Если Не ЗначениеЗаполнено(СтрокаТЧ.DepoId) Тогда
				СтрокаТЧ.DepoId = Строка(Новый УникальныйИдентификатор);
			КонецЕсли;
		КонецЦикла;
		СтрокиКУдалению = Новый Массив;
		Для Каждого СтараяСтрока Из Ссылка.ЦенныеБумагиСписываемые Цикл
			Если ЦенныеБумагиСписываемые.Найти(СтараяСтрока.DepoId, "DepoId") = Неопределено Тогда
				ДанныеУдаляемойСтроки = Новый Структура("DepoId, СчетДепо, РазделСчетаДепо, РазделСчетаДепоМХ, ЦеннаяБумага, Количество");
				ЗаполнитьЗначенияСвойств(ДанныеУдаляемойСтроки, СтараяСтрока);
				СтрокиКУдалению.Добавить(ДанныеУдаляемойСтроки);
			КонецЕсли;
		КонецЦикла;
		Если СтрокиКУдалению.Количество() Тогда
			ДополнительныеСвойства.Вставить("СтрокиКУдалению", СтрокиКУдалению);
		КонецЕсли;
	КонецЕсли;
	
	Документы.Поручение.ЭтоПоручениеПрошлоКонтрольПоУказу520(ЭтотОбъект);
	
	ЗаполнитьОчиститьУИН();
	
КонецПроцедуры

Процедура ПриЗаписи(Отказ)
	Если ПометкаУдаления Тогда
		ПометитьНаУдалениеПодчиненныеДокументы();
	Иначе
		ВыполнитьКонтрольПоручения(Перечисления.СобытияКонтроляПоручений.ПриЗаписи, Отказ);
	КонецЕсли;
	Если Не Проведен Тогда
		ОбменДаннымиКафка.ЗаписатьОбъектВИсходящиеСообщенияКафкаПриЗаписиДокумента(ЭтотОбъект);
	КонецЕсли;
КонецПроцедуры

Процедура УстановитьНачислениеНалога() Экспорт 
	Если ВидОперацииД = Справочники.ВидыОпераций.НачислениеДивидендов Тогда
		Для Каждого Строка Из ЦенныеБумагиСписываемые Цикл
			Если ЗначениеЗаполнено(ЦБ.ГруппаЦБ) И ЦБ.ГруппаЦБ = Справочники.ГруппаЦБДляНалогообложения.НайтиПоКоду("1C") Тогда
				Строка.НачислитьНалог = НЕ Строка.СчетДепо.Владелец.УправляющаяКомпания;
			КонецЕсли;
			ПроверитьНеобходимостьНачисленияНалога(Строка);
		КонецЦикла;
	ИначеЕсли ВидОперацииД = Справочники.ВидыОпераций.ПогашениеНКД 
		И НЕ (ЦБ.ТипЦБ = Перечисления.ТипыЦБ.Облигация И ЦБ.ВидЦБ = Перечисления.ВидыОблигаций.Государственная) Тогда 
		Для Каждого Строка Из ЦенныеБумагиСписываемые Цикл
			Если Строка.СчетДепо.Владелец.НеРезидент И Строка.СчетДепо.Владелец.ЮрФизЛицо = Перечисления.ЮрФизЛицо.ЮрЛицо Тогда
				Строка.НачислитьНалог = Истина;
			КонецЕсли;
			ПроверитьНеобходимостьНачисленияНалога(Строка);
		КонецЦикла;
	КонецЕсли;
КонецПроцедуры

Процедура ОбработкаУдаленияПроведения(Отказ)
	Если ЕстьПроведенныеПодчиненныеПоручения() Тогда
		ОбщегоНазначения.СообщитьОбОшибке("Вначале отмените проведение подчиненных поручений.", Отказ);
	Иначе
		УдалятьПодчиненныеПоручения = Ложь;
		Если Не Документы.Поручение.ЭтоПериодическиеВыпискиОСостоянииСчетаДЕПО(ЭтотОбъект) Тогда
			Документы.Поручение.УдалитьДокументыНаОснованииПоручения(Ссылка, УдалятьПодчиненныеПоручения);
		КонецЕсли;
	КонецЕсли;
	
	// Свойство ОбработкаУдаленияПроведения присваивается, чтобы при отмене встречного поручение не искать первое встречное поручение
	Если ВидОперацииД = Справочники.ВидыОпераций.Перевод И ДополнительныеСвойства.Свойство("ОбработкаУдаленияПроведения") = Ложь Тогда
		ВстречноеПоручение = Документы.Поручение.ВстречноеПоручениеПеревод(Ссылка);
		Если ВстречноеПоручение.Проведен И ЗначениеЗаполнено(ВстречноеПоручение)  Тогда
			ОбъектВстречноеПоручение = ВстречноеПоручение.ПолучитьОбъект();
			ОбъектВстречноеПоручение.ДополнительныеСвойства.Вставить("ОбработкаУдаленияПроведения",Истина);
			ОбъектВстречноеПоручение.Записать(РежимЗаписиДокумента.ОтменаПроведения);
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

Процедура ПриУстановкеНовогоНомера(СтандартнаяОбработка, Префикс)
	
	СтандартнаяОбработка = Ложь;
	
	Если РучнойВвод Тогда
		Возврат;
	КонецЕсли;
	
	Префикс 				= НумераторыОбъектов.ПолучитьПрефиксНомера(ЭтотОбъект);
	Номер					= НумераторыОбъектов.ПолучитьНомерДокумента(ЭтотОбъект, Префикс);
	ВходящийНомерПоручения	= ?(ЗначениеЗаполнено(ВходящийНомерПоручения), ВходящийНомерПоручения, Номер);
	
КонецПроцедуры

Процедура ПриКопировании(ОбъектКопирования)
	ВходящийНомерПоручения	= "";
	НомерПорученияВБО		= "";
	ОчиститьЗависимыеОтВидаОперацииРеквизиты();
	КодОтчетаНРД			= "";
	ИдентификаторЗагрузки	= "";
	ПринятьВОбработку		= Ложь;
	ДатаИсполненияПоручения	= '00010101';
	ДатаИсполненияПорученияВДепозитарииМХ	= '00010101';
	ДатаИсполненияПорученияВМестеРасчетов	= '00010101';
	ПланируемаяДатаРасчетов	= '00010101';
	ДатаСделки				= '00010101';
	РучнойВвод              = Ложь;
	Проверено               = Ложь;
	ЗагруженоИзВнешнегоИсточника = Ложь;	
	Если Документы.НачисленныйНалог.ИспользоватьРасчетНДФЛПоПрогрессивнойШкале(ТекущаяДатаСеанса()) Тогда
		ОчиститьПоляТабЧастиЦенныеБумагиСписываемые();
	КонецЕсли;
	УведомлениеСУДКОтправлено = Ложь;
	ДокументОснование = Неопределено;
	ДоговорОснованияДКУНомер = "";
	ДоговорОснованияДКУДата = '00010101';
	ОснованиеОперацииДКУ = Неопределено;
	ИсточникЗагрузки = Неопределено;
	Для Каждого Строка Из ЦенныеБумагиСписываемые Цикл
		Строка.ИдентификаторЗагрузки = "";
		Строка.ИдентификаторДействияВQUIK = Неопределено;
	КонецЦикла;
	ДополнительнаяИнформацияДляНРД = "";
	УИН = "";
КонецПроцедуры

Процедура ПередУдалением(Отказ)
	УдалятьПодчиненныеПоручения = Истина;
	Документы.Поручение.УдалитьДокументыНаОснованииПоручения(Ссылка, УдалятьПодчиненныеПоручения);
КонецПроцедуры

Процедура ОбработкаПроверкиЗаполнения(Отказ, ПроверяемыеРеквизиты)
	
	Если ВидОперацииД = Справочники.ВидыОпераций.Перемещение
		ИЛИ ВидОперацииД = Справочники.ВидыОпераций.ПереводМеждуРазделамиСчетаДепо Тогда
		ПроверяемыеРеквизиты.Добавить("МХКонтрагент");
		ПроверяемыеРеквизиты.Добавить("СчетДепоМХКонтрагента");
		ПроверяемыеРеквизиты.Добавить("РазделСчетаДепоМХКонтрагента");
	КонецЕсли;
	Если ВидОперацииД = Справочники.ВидыОпераций.ОткрытиеРазделаСчетаДепо И ТипЗнч(СчетДепо) = Тип("СправочникСсылка.СчетаДепо")
		И Перечисления.ТипыСчетовДепо.НоминальныхДержателей().Найти(СчетДепо.ТипСчетаДепо) <> Неопределено Тогда
		Если РазделСубклиента Тогда
			ПроверяемыеРеквизиты.Добавить("Субклиент");
		ИначеЕсли ЗначениеЗаполнено(Субклиент) И Не РазделСубклиента Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не установлен флаг ""Раздел субклиента"" при заполненном поле ""Субклиент""");
			Отказ = Истина;
		КонецЕсли;
	КонецЕсли; 
	
	ИмяПараметра = "2060.ДатаНачалаОбязательногоЗаполненияТипаПереводаВПоручении";
	Если ВидОперацииД = Справочники.ВидыОпераций.Перевод
			И Не ЗначениеЗаполнено(ТипПеревода)
			И РегистрыСведений.ПараметрыГлобальные.ЗначениеПараметра(ИмяПараметра, Дата(3999, 12, 31)) <= НачалоДня(Дата) Тогда
		ПроверяемыеРеквизиты.Добавить("ТипПеревода");
	КонецЕсли;
	
	Если Документы.Поручение.ТребуетсяПроверкаКарточкиКД(ЭтотОбъект) Тогда
		УведомлятьПочтовымСообщениемПриНезаполненнойКарточкеКД = Ложь;
		ПроверятьНаличиеКарточкиКД = НЕ НеПроверятьНаличиеКарточкиКД;
		Если ПроверятьНаличиеКарточкиКД И НЕ ЗначениеЗаполнено(КарточкаКД) Тогда
			Если УведомлятьПочтовымСообщениемПриНезаполненнойКарточкеКД Тогда
				Документы.Поручение.ОтложенноеУведомлениеПисьмом_КарточкаКД_НеЗаполнена(ЭтотОбъект);
			КонецЕсли;
			ОбщегоНазначения.СообщитьОбОшибке("Для проведения поручения необходима карточка КД!", Отказ);
		КонецЕсли;
	КонецЕсли;
	Документы.Поручение.ПроверитьДлинуКомментария(ЭтотОбъект, Отказ);
	
	ДополнитьПроверяемыеРеквизиты(ПроверяемыеРеквизиты);
	
	СобытияКонтроля = Новый Массив;
	СобытияКонтроля.Добавить(Перечисления.СобытияКонтроляПоручений.ПриПроведении);
	СобытияКонтроля.Добавить(Перечисления.СобытияКонтроляПоручений.ПриПроведенииСЗапретом);
	ВыполнитьКонтрольПоручения(СобытияКонтроля, Отказ);
КонецПроцедуры

Процедура ДополнитьПроверяемыеРеквизиты(ПроверяемыеРеквизиты)
	
	Если ВидПоручения = Справочники.ВидыИнвентарныхПоручений.П35_2
		Или ВидПоручения = Справочники.ВидыИнвентарныхПоручений.П36_2 Тогда
		ПроверяемыеРеквизиты.Добавить("ПаиБИК");
		ПроверяемыеРеквизиты.Добавить("ПаиНаименованиеБанка");
		ПроверяемыеРеквизиты.Добавить("ПаиГородБанка");
		ПроверяемыеРеквизиты.Добавить("ПаиКоррСчет");
		ПроверяемыеРеквизиты.Добавить("ПаиРасчетныйСчет");
		ПроверяемыеРеквизиты.Добавить("ПаиИНН");
		ПроверяемыеРеквизиты.Добавить("ПаиПолучатель");
	КонецЕсли;
	Если Документы.ПлатежнаяОперация.РазрешеныПлатежныеОперацииПоПоручению(Ссылка) Тогда
		ПроверяемыеРеквизиты.Добавить("ЦенныеБумагиСписываемые.БанковскийСчет");
	КонецЕсли;
	
	Если ОснованиеОперацииДКУ = Справочники.КодыОснованияОперацийДКУ.TR39 Тогда
		ПроверяемыеРеквизиты.Добавить("ОснованиеОперацииДКУИноеНаименование");
	КонецЕсли; 
	
	Если ВидПоручения = Справочники.ВидыИнвентарныхПоручений.П16
		Или ВидПоручения = Справочники.ВидыИнвентарныхПоручений.П16_1 Тогда
		
		Если Не ЗначениеЗаполнено(КраткийКодНРД) Тогда
			ПроверяемыеРеквизиты.Добавить("СчетДепоКонтрагента");
			ПроверяемыеРеквизиты.Добавить("РазделСчетаДепоКонтрагента");
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

