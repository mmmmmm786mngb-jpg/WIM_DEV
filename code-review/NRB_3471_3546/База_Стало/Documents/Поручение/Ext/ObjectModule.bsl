			ПараметрВебСервиса.clientId 		= ?(ДанныеСчетаДепо = Неопределено, "", СокрЛП(ДанныеСчетаДепо.КодВладельца));
			ПараметрВебСервиса.bondsPaymentType	= ?(ВидОперацииД = Справочники.ВидыОпераций.ПогашениеЦБПолное, "Full", "Partial");
