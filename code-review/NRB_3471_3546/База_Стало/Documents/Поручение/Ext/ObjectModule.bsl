// СЛУЖЕБНЫЕ ПРОЦЕДУРЫ И ФУНКЦИИ

Процедура СформироватьДвиженияПоРегиструДенежныхСредств()
	
	НеобходимыДвижения = ОбщегоНазначенияПовтИсп.ЗначениеКонстанты("ДатаДвиженийПоДС") <= Дата
		И ТипЗнч(ВидОперацииД) = Тип("СправочникСсылка.ВидыОпераций") И ВидОперацииД.ВыплатаДоходаВДенежнойФорме;
	Если НеобходимыДвижения Тогда
		Для Каждого СтрокаВыплаты Из ЦенныеБумагиСписываемые Цикл
			Движение = Движения.ДенежныеСредства.Добавить();
			Движение.ВидДвижения = ВидДвиженияНакопления.Приход;
			Движение.Период = Дата;
			Движение.Выплата = Ссылка;
			Движение.БанковскийСчет = БанковскийСчет;
			Движение.Депонент = СтрокаВыплаты.СчетДепо.Владелец;
			Движение.Валюта = Валюта;
			ЭтоИностраннаяЦБ = Справочники.ВидыЦББанкаРоссии.ЭтоВидИностраннойЦБ(ЦБ.ВидЦББанкаРоссии);
			Если ЭтоИностраннаяЦБ Тогда
				Движение.ВалютнаяСумма = СтрокаВыплаты.СуммаКВыплатеПоИПД;
			ИначеЕсли ВидОперацииД = Справочники.ВидыОпераций.НачислениеДоходаПрочие И СтрокаВыплаты.НДФЛУдержан Тогда
				Движение.ВалютнаяСумма = СтрокаВыплаты.Сумма - СтрокаВыплаты.СуммаНалога;
			Иначе
				Движение.ВалютнаяСумма = СтрокаВыплаты.Сумма;
			КонецЕсли;
			ПараметрыКурсаВалюты = ОбщегоНазначения.ПолучитьКурсВалюты(Валюта, СтрокаВыплаты.ПлановаяДатаРасчетов);
			Курс = ?(ЗначениеЗаполнено(ПараметрыКурсаВалюты.Курс), ПараметрыКурсаВалюты.Курс, 1);
			Кратность = ?(ЗначениеЗаполнено(ПараметрыКурсаВалюты.Кратность), ПараметрыКурсаВалюты.Кратность, 1);
			Движение.Сумма = Движение.ВалютнаяСумма * (Курс / Кратность);
		КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры

Процедура ОчиститьПоляТабЧастиЦенныеБумагиСписываемые()
	Для Каждого Строка Из ЦенныеБумагиСписываемые Цикл
		Строка.СуммаНалога = 0;
		Строка.DepoId = "";
	КонецЦикла;
КонецПроцедуры

Процедура ПереформироватьОперацииЦБ(Отказ)
	
	ДанныеИсполнения = Документы.ИсполнениеПоручения.ДанныеИсполненияПоручения(Ссылка);
	
	Если ДополнительныеСвойства.Свойство("РежимЗаписиИсполнения") Тогда
		РежимЗаписиИсполнения = ДополнительныеСвойства.РежимЗаписиИсполнения;
	Иначе
		РежимЗаписиИсполнения = РежимЗаписиДокумента.Проведение;
	КонецЕсли;
	
	Если РежимЗаписиИсполнения = РежимЗаписиДокумента.Проведение Тогда
		ФлагПроведения = Истина;
		ОперацияЦБ = ПодчиненнаяОперацияЦБ(ДанныеИсполнения.КоличествоОтчета, ДанныеИсполнения.Дата, ФлагПроведения);
		Если ЗначениеЗаполнено(ОперацияЦБ) Тогда
			Возврат;
		КонецЕсли;
		
		Если ДанныеИсполнения.Статус = Перечисления.СтатусыПоручений.Исполнено Тогда
			ФлагПроведения = Ложь;
			ОперацияЦБ = ПодчиненнаяОперацияЦБ(ДанныеИсполнения.КоличествоОтчета, Неопределено, ФлагПроведения);
			Если НЕ ЗначениеЗаполнено(ОперацияЦБ) Тогда
				ОперацияЦБ = НоваяОперацияЦБ(ДанныеИсполнения.КоличествоОтчета);
			КонецЕсли;
			
			ЗаполнитьПровестиОперациюЦБ(ОперацияЦБ, РежимЗаписиДокумента.Проведение);
			
		ИначеЕсли ДанныеИсполнения.Статус = Перечисления.СтатусыПоручений.ИсполненоЧастично Тогда
			ФлагПроведения = Ложь;
			ОперацияЦБ = ПодчиненнаяОперацияЦБ(ДанныеИсполнения.НачальныйОстаток, Неопределено, ФлагПроведения);
			Если НЕ ЗначениеЗаполнено(ОперацияЦБ) Тогда
				ОперацияЦБ = НоваяОперацияЦБ(ДанныеИсполнения.НачальныйОстаток);
			КонецЕсли;
			
			ТекстОшибки = РезультатПроведенияОперацииЦБ(ОперацияЦБ, ДанныеИсполнения);
			Если ЗначениеЗаполнено(ТекстОшибки) Тогда
				ОбщегоНазначения.СообщитьОбОшибке(ТекстОшибки, Отказ);
				Возврат;
			КонецЕсли;
			
			ТекстОшибки = РезультатСозданияОперацииЦБ(ОперацияЦБ, ДанныеИсполнения.КонечныйОстаток);
			Если ЗначениеЗаполнено(ТекстОшибки) Тогда
				ОбщегоНазначения.СообщитьОбОшибке(ТекстОшибки, Отказ);
				Возврат;
			КонецЕсли;
			
		КонецЕсли;
		
	ИначеЕсли РежимЗаписиИсполнения = РежимЗаписиДокумента.ОтменаПроведения Тогда
		ФлагПроведения = Истина;
		ОтменяемаяОперацияЦБ = ПодчиненнаяОперацияЦБ(ДанныеИсполнения.КоличествоОтчета, ДанныеИсполнения.Дата,
			ФлагПроведения);
		Если НЕ ЗначениеЗаполнено(ОтменяемаяОперацияЦБ) Тогда
			Возврат;
		КонецЕсли;
		
		СписокОпераций = СписокПодчиненныхОперацийЦБ();
		Если СписокОпераций[СписокОпераций.Количество()-1] <> ОтменяемаяОперацияЦБ Тогда
			ОбщегоНазначения.СообщитьОбОшибке("Исполнения поручений нужно распроводить в обратном порядке!", Отказ);
			Возврат;
		КонецЕсли;
			
		Если ДанныеИсполнения.Статус = Перечисления.СтатусыПоручений.Исполнено Тогда
			ТекстОшибки = РезультатОтменыОперацииЦБ(ОтменяемаяОперацияЦБ);
			Если ЗначениеЗаполнено(ТекстОшибки) Тогда
				ОбщегоНазначения.СообщитьОбОшибке(ТекстОшибки, Отказ);
				Возврат;
			КонецЕсли;
			
		ИначеЕсли ДанныеИсполнения.Статус = Перечисления.СтатусыПоручений.ИсполненоЧастично Тогда
			ФлагПроведения = Ложь;
			ОперацияПолучатель = ПодчиненнаяОперацияЦБ(Неопределено, Неопределено, ФлагПроведения);
			Если НЕ ЗначениеЗаполнено(ОперацияПолучатель) Тогда
				ТекстОшибки = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
					"У %1 не найдена подчиненная непроведенная операция ЦБ", Ссылка);
				ОбщегоНазначения.СообщитьОбОшибке(ТекстОшибки, Отказ);
				Возврат;
			КонецЕсли;
			
			ТекстОшибки = РезультатОбъединенияОперацийЦБ(ОперацияПолучатель, ОтменяемаяОперацияЦБ.Количество);
			Если ЗначениеЗаполнено(ТекстОшибки) Тогда
				ОбщегоНазначения.СообщитьОбОшибке(ТекстОшибки, Отказ);
				Возврат;
			КонецЕсли;
			
			Выписка = ПодчиненнаяВыписка(ОтменяемаяОперацияЦБ);
			УдалитьДокумент(Выписка);
			УдалитьДокумент(ОтменяемаяОперацияЦБ);
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

Функция ПодчиненнаяВыписка(ОперацияЦБ)
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	Выписка.Ссылка КАК Выписка
	|ИЗ
	|	Документ.Выписка КАК Выписка
	|ГДЕ
	|	Выписка.ДокументОснование = &Поручение
	|	И Выписка.ОперацияЦБ = &ОперацияЦБ
	|";
	Запрос.УстановитьПараметр("Поручение",	Ссылка);
	Запрос.УстановитьПараметр("ОперацияЦБ",	ОперацияЦБ);
	Результат = Запрос.Выполнить();
	Если НЕ Результат.Пустой() Тогда
		Выборка = Результат.Выбрать();
		Если Выборка.Следующий() Тогда
			Возврат Выборка.Выписка;
		КонецЕсли;
	КонецЕсли;
	Возврат Документы.Выписка.ПустаяСсылка();
	
КонецФункции

Процедура УдалитьДокумент(ДокументСсылка)
	
	Если ЗначениеЗаполнено(ДокументСсылка) Тогда
		Документ = ДокументСсылка.ПолучитьОбъект();
		Сообщить("Удален документ: " + Документ + Символы.ПС, СтатусСообщения.Информация);
		Документ.Удалить();
	КонецЕсли;
	
КонецПроцедуры

Функция СписокПодчиненныхОперацийЦБ()
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ОперацииЦБ.Ссылка КАК ОперацияЦБ
	|ИЗ
	|	Документ.ОперацииЦБ КАК ОперацииЦБ
	|ГДЕ
	|	ОперацииЦБ.ДокументОснование = &ДокументОснование
	|	И НЕ ОперацииЦБ.ПометкаУдаления
	|
	|УПОРЯДОЧИТЬ ПО
	|	ОперацииЦБ.Дата
	|";
	Запрос.УстановитьПараметр("ДокументОснование", Ссылка);
	Возврат Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("ОперацияЦБ");
	
КонецФункции

Функция РезультатОтменыОперацииЦБ(ОтменяемаяОперацияЦБ)
	
	ОперацияЦБ = ОтменяемаяОперацияЦБ.ПолучитьОбъект();
	ОперацияЦБ.Дата = Дата;
	ОперацияЦБ.ДатаИсполненияВДепозитарииМХ	= '00010101';
	ОперацияЦБ.ДатаИсполненияВМестеРасчетов	= '00010101';
	
	Попытка
		ОперацияЦБ.Записать(РежимЗаписиДокумента.ОтменаПроведения);
	Исключение
		ТекстОшибки = "Не удалось отменить проведение " + ОперацияЦБ + ". " + КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
		Возврат ТекстОшибки;
	КонецПопытки;
	Возврат "";
	
КонецФункции
			
Процедура ЗаполнитьПровестиОперациюЦБ(ОперацияЦБ, РежимЗаписиОперации)
	
	Документ = ОперацияЦБ.ПолучитьОбъект();
	
	Если Документ.ПометкаУдаления Тогда
		Документ.ПометкаУдаления = Ложь;
		Документ.Записать(РежимЗаписиДокумента.Запись);
	КонецЕсли;	
	
	Документ.ДополнительныеСвойства.Вставить("ОставитьБезИзмененийКоличествоСуммуОперацииЦБ");
	Документ.Заполнить(Ссылка);
	
	Документ.Записать(РежимЗаписиОперации);
	
КонецПроцедуры

Функция НоваяОперацияЦБ(Количество)
	
	ДокументОбъект = Документы.ОперацииЦБ.СоздатьДокумент();
	ДокументОбъект.Заполнить(Ссылка);
	ДокументОбъект.ДатаИсполненияВДепозитарииМХ	= '00010101';
	ДокументОбъект.ДатаИсполненияВМестеРасчетов	= '00010101';
	ДокументОбъект.Количество = Количество;
	ДокументОбъект.Сумма = ДокументОбъект.Количество * ДокументОбъект.Цена;
	ДокументОбъект.Записать(РежимЗаписиДокумента.Запись);
	Возврат ДокументОбъект.Ссылка;
	
КонецФункции

Функция ПодчиненнаяОперацияЦБ(Количество = Неопределено, Дата = Неопределено, ФлагПроведения = Неопределено)
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	ОперацииЦБ.Ссылка КАК ОперацияЦБ
	|ИЗ
	|	Документ.ОперацииЦБ КАК ОперацииЦБ
	|ГДЕ
	|	ОперацииЦБ.ДокументОснование = &ДокументОснование
	|	И (&ФлагПроведения = Неопределено ИЛИ ОперацииЦБ.Проведен = &ФлагПроведения)
	|	И (&Дата = Неопределено ИЛИ ОперацииЦБ.Дата = &Дата)
	|	И (&Количество = Неопределено ИЛИ ОперацииЦБ.Количество = &Количество) 
	|";
	Запрос.УстановитьПараметр("ДокументОснование", Ссылка);
	Запрос.УстановитьПараметр("ФлагПроведения", ФлагПроведения);
	Запрос.УстановитьПараметр("Дата", Дата);
	Запрос.УстановитьПараметр("Количество", Количество);
	Результат = Запрос.Выполнить();
	Если НЕ Результат.Пустой() Тогда
		Выборка = Результат.Выбрать();
		Если Выборка.Следующий() Тогда
			Возврат Выборка.ОперацияЦБ;
		КонецЕсли;
	КонецЕсли;
	Возврат Документы.ОперацииЦБ.ПустаяСсылка();
	
КонецФункции

Функция РезультатОбъединенияОперацийЦБ(ОперацияЦБСсылка, КоличествоДругойОперации)
	
	ОперацияЦБ = ОперацияЦБСсылка.ПолучитьОбъект();
	ОперацияЦБ.Количество = ОперацияЦБ.Количество + КоличествоДругойОперации;
	ОперацияЦБ.Сумма = ОперацияЦБ.Количество * ОперацияЦБ.Цена;
	
	Попытка
		ОперацияЦБ.Записать(РежимЗаписиДокумента.Запись);
	Исключение
		ТекстОшибки = "Не удалось записать " + ОперацияЦБ + ". " + КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
		Возврат ТекстОшибки;
	КонецПопытки;
	Возврат "";
	
КонецФункции

Функция РезультатПроведенияОперацииЦБ(ОперацияЦБСсылка, ДанныеИсполнения)
	
	ОперацияЦБ = ОперацияЦБСсылка.ПолучитьОбъект();
	ОперацияЦБ.Дата = ДанныеИсполнения.Дата;
	ОперацияЦБ.ДатаИсполненияВДепозитарииМХ	= ДанныеИсполнения.ДатаИсполненияВДепозитарииМХ;
	ОперацияЦБ.ДатаИсполненияВМестеРасчетов	= ДанныеИсполнения.ДатаИсполненияВМестеРасчетов;
	ОперацияЦБ.Количество = ДанныеИсполнения.КоличествоОтчета;
	ОперацияЦБ.Сумма = ОперацияЦБ.Количество * ОперацияЦБ.Цена;
	
	Попытка
		ОперацияЦБ.Записать(РежимЗаписиДокумента.Проведение);
	Исключение
		ТекстОшибки = "Не удалось провести " + ОперацияЦБ + ". " + КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
		Возврат ТекстОшибки;
	КонецПопытки;
	Возврат "";
	
КонецФункции

Функция РезультатСозданияОперацииЦБ(ИсходнаяОперацияЦБ, КонечныйОстаток)
	
	ОперацияЦБ = Документы.ОперацииЦБ.СоздатьДокумент();
	ЗаполнитьЗначенияСвойств(ОперацияЦБ, ИсходнаяОперацияЦБ);
	ОперацияЦБ.Проведен = Ложь;
	ОперацияЦБ.ПометкаУдаления = Ложь;
	ОперацияЦБ.Дата = Дата;
	ОперацияЦБ.ДатаИсполненияВДепозитарииМХ	= '00010101';
	ОперацияЦБ.ДатаИсполненияВМестеРасчетов	= '00010101';
	ОперацияЦБ.Количество = КонечныйОстаток;
	ОперацияЦБ.Сумма = ОперацияЦБ.Количество * ОперацияЦБ.Цена;
	Попытка
		ОперацияЦБ.Записать(РежимЗаписиДокумента.Запись);
	Исключение
		ТекстОшибки = "Не удалось записать новую операцию ЦБ на основании " + Ссылка + ". "
			+ КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
		Возврат ТекстОшибки;
	КонецПопытки;
	Возврат "";
	
КонецФункции

Функция ПолучитьПараметрыДоговораПоПоручению()
	Запрос = Новый Запрос(
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	Код,
	|	ДатаНачалоДействия,
	|	Ссылка
	|ИЗ
	|	Справочник.ДоговорыКонтрагентов
	|ГДЕ
	|	НЕ ПометкаУдаления
	|	И (ДатаНачалоДействия <= НАЧАЛОПЕРИОДА(&Дата, ДЕНЬ) ИЛИ ДатаНачалоДействия = ДАТАВРЕМЯ(1,1,1))
	|	И (ДатаОкончанияДействия >= НАЧАЛОПЕРИОДА(&Дата, ДЕНЬ) ИЛИ ДатаОкончанияДействия = ДАТАВРЕМЯ(1,1,1))
	|	И Владелец		= &Владелец
	|	И ТипДоговора	= ЗНАЧЕНИЕ(Перечисление.ТипыДоговоров.Депозитарный)");

	Запрос.УстановитьПараметр("Владелец", Инициатор);
	Запрос.УстановитьПараметр("Дата"	, Дата);
	
	Возврат Запрос.Выполнить().Выгрузить();
КонецФункции

Функция ПроверкаНаНаличиеДокументовСозданныхНаОснованииТекущего() Экспорт
	
	Перем ЗапретРедактирования;
	Перем ВидыОпераций;
	
	ВидыОпераций = Справочники.ВидыОпераций;
	
	ЗапретРедактирования = Ложь;
	
	Если ЭтоНовый() Тогда
		Возврат ЗапретРедактирования;
	КонецЕсли; 
	
	Если ВидОперацииД = ВидыОпераций.ОткрытиеСчетаДепо Тогда
		
		ЗапретРедактирования = НЕ Документы.ОткрытиеСчетаДепо.НайтиПоРеквизиту("ДокументОснование", Ссылка).Пустая();
		
	ИначеЕсли ВидОперацииД = ВидыОпераций.ОткрытиеРазделаСчетаДепо Тогда
		
		ЗапретРедактирования = НЕ Документы.ОткрытиеРазделаСчетаДепо.НайтиПоРеквизиту("ДокументОснование", Ссылка).Пустая();
		
	ИначеЕсли ВидОперацииД = ВидыОпераций.ЗакрытиеСчетаДепо Тогда
		
		ЗапретРедактирования = НЕ Документы.ЗакрытиеСчетаДепо.НайтиПоРеквизиту("ДокументОснование", Ссылка).Пустая();
		
	ИначеЕсли	ВидОперацииД = ВидыОпераций.НазначениеОператораСчетаДепо 
			  	ИЛИ ВидОперацииД = ВидыОпераций.НазначениеПопечителяСчетаДепо 
			  	ИЛИ ВидОперацииД = ВидыОпераций.НазначениеРаспорядителяСчетаДепо	Тогда	
		
		ЗапретРедактирования = НЕ Документы.НазначениеПредставителяСчетаДепо.НайтиПоРеквизиту("ДокументОснование", Ссылка).Пустая();
		
	ИначеЕсли   ВидОперацииД = ВидыОпераций.ОтзывПопечителяСчетаДепо
				ИЛИ ВидОперацииД = ВидыОпераций.ОтменаОператораСчетаДепо
				ИЛИ ВидОперацииД = ВидыОпераций.ОтменаРаспорядителяСчетаДепо Тогда	
		
		ЗапретРедактирования = НЕ Документы.ОтменаПредставителяСчетаДепо.НайтиПоРеквизиту("ДокументОснование", Ссылка).Пустая();	
		
	ИначеЕсли	ВидОперацииД = ВидыОпераций.Депонирование
				ИЛИ ВидОперацииД = ВидыОпераций.СнятиеСДепонирования
				ИЛИ ВидОперацииД = ВидыОпераций.Блокирование
				ИЛИ ВидОперацииД = ВидыОпераций.Обременение 
				ИЛИ ВидОперацииД = ВидыОпераций.Перевод 
				ИЛИ ВидОперацииД = ВидыОпераций.Перемещение
				ИЛИ ВидОперацииД = ВидыОпераций.ПереводМеждуРазделамиСчетаДепо
				ИЛИ ВидОперацииД = ВидыОпераций.ПередачаВЗалог
				ИЛИ ВидОперацииД = ВидыОпераций.ВозвратИзЗалога 
				ИЛИ ВидОперацииД = ВидыОпераций.СнятиеОбременения 
				ИЛИ ВидОперацииД = ВидыОпераций.Разблокирование Тогда	
		
		ЗапретРедактирования = НЕ Документы.ОперацииЦБ.НайтиПоРеквизиту("ДокументОснование", Ссылка).Пустая();	 	
		
	ИначеЕсли ВидОперацииД = ВидыОпераций.ПредоставлениеУведомления Тогда
		
		ЗапретРедактирования = НЕ Документы.Выписка.НайтиПоРеквизиту("ДокументОснование", Ссылка).Пустая();	
		
	КонецЕсли;          
	
	Если ЗапретРедактирования Тогда
		Сообщить("На основании данного поручения есть введенные документы!");
	КонецЕсли; 
	
	Возврат ЗапретРедактирования;
	
КонецФункции

Процедура ПометитьНаУдалениеПодчиненныеДокументы()
	Сообщение = Новый СообщениеПользователю;
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	ДокументыПоПоручению.Ссылка КАК Ссылка
	|ИЗ
	|	КритерийОтбора.СтруктураПодчиненности(&Ссылка) КАК ДокументыПоПоручению
	|ГДЕ НЕ ДокументыПоПоручению.Ссылка ССЫЛКА ДОкумент.ТехническаяОперация");
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		ДокументОбъект = Выборка.Ссылка.ПолучитьОбъект();
		Если ДокументОбъект <> Неопределено Тогда
			Сообщение.Текст = Сообщение.Текст + "Помечен на удаление: " + ДокументОбъект + Символы.ПС;
			ДокументОбъект.УстановитьПометкуУдаления(Истина);
		КонецЕсли;
	КонецЦикла;
	
	Если ЗначениеЗаполнено(Сообщение.Текст) Тогда
		Сообщение.Сообщить();
	КонецЕсли;
КонецПроцедуры

Функция ЕстьПроведенныеПодчиненныеПоручения()
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	ДокументыПоПоручению.Ссылка КАК Ссылка
	|ИЗ
	|	КритерийОтбора.СтруктураПодчиненности(&Ссылка) КАК ДокументыПоПоручению
	|ГДЕ
	|	ДокументыПоПоручению.Ссылка.Проведен
	|	И ДокументыПоПоручению.Ссылка ССЫЛКА Документ.Поручение");
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	Возврат НЕ Запрос.Выполнить().Пустой()
КонецФункции

Функция ЕстьНеисполненныеПорученияПоПассивномуРазделу()
	
	ЕстьНеисполненныеПоручения = Ложь;
	
	СтатусыПоручений = Новый Массив;
	СтатусыПоручений.Добавить(Перечисления.СтатусыПоручений.Обрабатывается);
	СтатусыПоручений.Добавить(Перечисления.СтатусыПоручений.ИсполненоЧастично);
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("РазделСчетаДепо", РазделСчетаДепо);
	Запрос.УстановитьПараметр("СтатусыПоручений", СтатусыПоручений);
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ДокументПоручение.Ссылка КАК Ссылка,
	|	СтатусыПорученийСрезПоследних.СтатусПоручения КАК СтатусПоручения
	|ИЗ
	|	Документ.Поручение КАК ДокументПоручение
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.СтатусыПоручений.СрезПоследних КАК СтатусыПорученийСрезПоследних
	|		ПО ДокументПоручение.Ссылка = СтатусыПорученийСрезПоследних.Поручение
	|			И (СтатусыПорученийСрезПоследних.СтатусПоручения В (&СтатусыПоручений))
	|ГДЕ
	|	ДокументПоручение.РазделСчетаДепо = &РазделСчетаДепо
	|	И ДокументПоручение.Проведен
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ДокументПоручение.Ссылка,
	|	СтатусыПорученийСрезПоследних.СтатусПоручения
	|ИЗ
	|	Документ.Поручение.ЦенныеБумагиСписываемые КАК ДокументПоручение
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.СтатусыПоручений.СрезПоследних КАК СтатусыПорученийСрезПоследних
	|		ПО ДокументПоручение.Ссылка = СтатусыПорученийСрезПоследних.Поручение
	|			И (СтатусыПорученийСрезПоследних.СтатусПоручения В (&СтатусыПоручений))
	|ГДЕ
	|	ДокументПоручение.РазделСчетаДепо = &РазделСчетаДепо
	|	И ДокументПоручение.Ссылка.Проведен
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ДокументПоручение.Ссылка,
	|	СтатусыПорученийСрезПоследних.СтатусПоручения
	|ИЗ
	|	Документ.Поручение.Списание КАК ДокументПоручение
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.СтатусыПоручений.СрезПоследних КАК СтатусыПорученийСрезПоследних
	|		ПО ДокументПоручение.Ссылка = СтатусыПорученийСрезПоследних.Поручение
	|			И (СтатусыПорученийСрезПоследних.СтатусПоручения В (&СтатусыПоручений))
	|ГДЕ
	|	ДокументПоручение.РазделСчетаДепо = &РазделСчетаДепо
	|	И ДокументПоручение.Ссылка.Проведен
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ДокументПоручение.Ссылка,
	|	СтатусыПорученийСрезПоследних.СтатусПоручения
	|ИЗ
	|	Документ.Поручение.Зачисление КАК ДокументПоручение
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.СтатусыПоручений.СрезПоследних КАК СтатусыПорученийСрезПоследних
	|		ПО ДокументПоручение.Ссылка = СтатусыПорученийСрезПоследних.Поручение
	|			И (СтатусыПорученийСрезПоследних.СтатусПоручения В (&СтатусыПоручений))
	|ГДЕ
	|	ДокументПоручение.РазделСчетаДепо = &РазделСчетаДепо
	|	И ДокументПоручение.Ссылка.Проведен";
	
	РезультатЗапроса = Запрос.Выполнить();
	ВыборкаЗапроса = РезультатЗапроса.Выбрать();
	
	Если НЕ РезультатЗапроса.Пустой() Тогда
		ЕстьНеисполненныеПоручения = Истина;
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("По закрываемому разделу счета есть неисполненные поручения:");
		Пока ВыборкаЗапроса.Следующий() Цикл
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ВыборкаЗапроса.Ссылка, ВыборкаЗапроса.Ссылка);				
		КонецЦикла;
	КонецЕсли;
	
	Возврат ЕстьНеисполненныеПоручения;
	
КонецФункции

Процедура СформироватьДвижениеПоСтатусуПоручения(Отказ)
	
	КлючСтрокиПоручения = Неопределено;
	Если Документы.Поручение.ЭтоИнвентарноеПоручениеСИсполнениемВРежимеЧастичногоИсполнения(Ссылка) Тогда
		// Установка статуса для этого кейса выполняется в Операции ЦБ
	
	ИначеЕсли ЗначениеЗаполнено(ДатаИсполненияПоручения) Тогда
		РегистрыСведений.СтатусыПоручений.УстановитьСтатус(Движения, Ссылка, ДатаИсполненияПоручения,
			Перечисления.СтатусыПоручений.Исполнено);
		Если ВидОперацииД = Справочники.ВидыОпераций.ОтменаПоручения
			И ТипЗнч(ОтменяемоеПоручение) = Тип("ДокументСсылка.Поручение") Тогда
			РегистрыСведений.СтатусыПоручений.УстановитьСтатус(Движения, ОтменяемоеПоручение, ДатаИсполненияПоручения,
				Перечисления.СтатусыПоручений.Отменено);
		КонецЕсли;
		
	ИначеЕсли Документы.НачисленныйНалог.НеподтвержденныеДокументыНачисленияНДФЛПоДивидендам(Ссылка) Тогда
		Документы.ПлатежнаяОперация.СоздатьПлатежныеОперацииПоПоручению(Ссылка, КлючСтрокиПоручения, Отказ);
		РегистрыСведений.СтатусыПоручений.УстановитьСтатус(Движения, Ссылка, Дата,
			Перечисления.СтатусыПоручений.ПодтверждениеНалога);
	Иначе
		Документы.ПлатежнаяОперация.СоздатьПлатежныеОперацииПоПоручению(Ссылка, КлючСтрокиПоручения, Отказ);
		РегистрыСведений.СтатусыПоручений.УстановитьСтатус(Движения, Ссылка, Дата, Перечисления.СтатусыПоручений.Обрабатывается);
	КонецЕсли;
	
КонецПроцедуры

Процедура СоздатьОбновитьДокумент(ИмяДокумента, Отказ)
	ДокументСсылка = Документы[ИмяДокумента].НайтиПоРеквизиту("ДокументОснование", Ссылка);
	
	Если ДокументСсылка.Пустая() Тогда
		Документ = Документы[ИмяДокумента].СоздатьДокумент();
	Иначе
		Документ = ДокументСсылка.ПолучитьОбъект();
	КонецЕсли;
	
	Если Документ.ПометкаУдаления Тогда
		Документ.ПометкаУдаления = Ложь;
		Документ.Записать(РежимЗаписиДокумента.Запись);
	КонецЕсли;	
	
	Документ.Заполнить(Ссылка);
	
	Если ДополнительныеСвойства.Свойство("ВведеноИнтерактивно")
		И ДополнительныеСвойства.ВведеноИнтерактивно = Истина Тогда
		// При записи поручения из формы не перезаполняем признак "Начислить комиссию Депо"
		Документ.ДополнительныеСвойства.Вставить("ОтключитьЗаполнениеПризнакаНачислитьКомиссию", Истина);
	КонецЕсли;
	
	Документ.Записать(РежимЗаписиДокумента.Проведение);
	
КонецПроцедуры

Процедура ОчиститьЗависимыеОтВидаОперацииРеквизиты() Экспорт
	
	Исключения = Новый Массив;
	Исключения.Добавить(Справочники.ВидыОпераций.НазначениеОператораСчетаДепо);
	Исключения.Добавить(Справочники.ВидыОпераций.ОтменаОператораСчетаДепо);
	
	Исключения.Добавить(Справочники.ВидыОпераций.НазначениеПопечителяСчетаДепо);	
	Исключения.Добавить(Справочники.ВидыОпераций.ОтзывПопечителяСчетаДепо);
	Исключения.Добавить(Справочники.ВидыОпераций.НазначениеРаспорядителяСчетаДепо);
	Исключения.Добавить(Справочники.ВидыОпераций.ОтменаРаспорядителяСчетаДепо);
	
	Исключения.Добавить(Справочники.ВидыОпераций.ОтменаПоручения);
	Исключения.Добавить(Справочники.ВидыОпераций.Конвертация);
	Исключения.Добавить(Справочники.ВидыОпераций.Выкуп);
	Исключения.Добавить(Справочники.ВидыОпераций.Погашение);
	
	Исключения.Добавить(Справочники.ВидыОпераций.СписаниеАкцийПриЛиквидацииЭмитента);
	Исключения.Добавить(Справочники.ВидыОпераций.СписаниеОбесценившихсяЦенныхБумаг);
	Исключения.Добавить(Справочники.ВидыОпераций.ВыкупСписаниеЦБ);
	Исключения.Добавить(Справочники.ВидыОпераций.НачислениеДоходовЦБ);
	
	Исключения.Добавить(Справочники.ВидыОпераций.СнятиеЦБсОбслуживания);
	Исключения.Добавить(Справочники.ВидыОпераций.ПриемЦБНаОбслуживание);
	
	ДобавитьОперацииВыплатыДоходаВДенежнойФорме(Исключения);
	
	Если Исключения.Найти(ВидОперацииД) <> Неопределено Тогда
		Депонент = Справочники.Контрагенты.ПустаяСсылка();
	КонецЕсли;
	
	МассивОперацийСТипомСчета = Новый Массив;
	МассивОперацийСТипомСчета.Добавить(Справочники.ВидыОпераций.ОткрытиеСчетаДепо);
	Если МассивОперацийСТипомСчета.Найти(ВидОперацииД) = Неопределено Тогда
		ТипСчетаДепо = Перечисления.ТипыСчетовДепо.ПустаяСсылка();
	КонецЕсли;
	
	МассивОперацийСТипомРазделаСчета = Новый Массив;
	МассивОперацийСТипомРазделаСчета.Добавить(Справочники.ВидыОпераций.ОткрытиеРазделаСчетаДепо);
	МассивОперацийСТипомРазделаСчета.Добавить(Справочники.ВидыОпераций.ЗакрытиеРазделаСчетаДепо);
	
	Если МассивОперацийСТипомРазделаСчета.Найти(ВидОперацииД) = Неопределено Тогда
		ТипРазделаСчетаДЕПО = Перечисления.ТипыРазделовСчетовДЕПО.ПустаяСсылка();
	КонецЕсли;
		
	МассивОперацийБезСчетаДепо = Новый Массив;
	МассивОперацийБезСчетаДепо.Добавить(Справочники.ВидыОпераций.ОткрытиеСчетаДепо);
	Если НЕ МассивОперацийБезСчетаДепо.Найти(ВидОперацииД) = Неопределено Тогда
		СчетДепо = Справочники.СчетаДепо.ПустаяСсылка();
	КонецЕсли;
	
КонецПроцедуры

Процедура ДобавитьОперацииВыплатыДоходаВДенежнойФорме(Исключения)
	Операции = Справочники.ВидыОпераций.ОперацииВыплатыДоходаВДенежнойФорме();
	Для Каждого Операция Из Операции Цикл
		Исключения.Добавить(Операция);
	КонецЦикла;
КонецПроцедуры

Функция ЕстьНеттоПоручениеСПустойДатойИсполнения()
	
	Если ЭтоНовый() Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ТЧПоручения.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.НеттоПоручение.Поручения КАК ТЧПоручения
	|ГДЕ
	|	ТЧПоручения.Ссылка.Проведен
	|	И ТЧПоручения.Ссылка.ДатаИсполнения = ДАТАВРЕМЯ(1, 1, 1)
	|	И ТЧПоручения.Поручение = &Поручение");
	Запрос.УстановитьПараметр("Поручение", ЭтотОбъект.Ссылка);
	Результат = Запрос.Выполнить();
	Возврат Не Результат.Пустой();
	
КонецФункции

Функция ПричинаЗапретаУстановкиФлажкаПринятьВОбработку()
	ПричинаЗапрета = "";
	Если ЗначениеЗаполнено(ДатаИсполненияПоручения) Тогда
		ПричинаЗапрета = "У поручения заполнена дата исполнения";
	ИначеЕсли Документы.Поручение.ОперацияБлокирована(ЭтотОбъект) Тогда
		ПричинаЗапрета = "Инициатор блокирован, внешние операции с ЦБ запрещены";
	ИначеЕсли Не ЗначениеЗаполнено(Ссылка) Тогда
		ПричинаЗапрета = "";
	Иначе
		Запрос = Новый Запрос(
		"ВЫБРАТЬ
		|	ТЧПоручения.Ссылка КАК Ссылка
		|ИЗ
		|	Документ.НеттоПоручение.Поручения КАК ТЧПоручения
		|ГДЕ
		|	ТЧПоручения.Ссылка.Проведен
		|	И ТЧПоручения.Поручение = &Поручение");
		Запрос.УстановитьПараметр("Поручение", Ссылка);
		Если НЕ Запрос.Выполнить().Пустой() Тогда
			ПричинаЗапрета = "Поручение учтено в нетто-поручении";
		КонецЕсли;
	КонецЕсли;	
	Возврат ПричинаЗапрета;		
КонецФункции

Процедура СформироватьПоручениеНаОткрытиеРазделаСчетаМХ(Отказ)
	
	Если ЗначениеЗаполнено(СчетДепоМХ) И ЗначениеЗаполнено(НомерРазделаСчетаДепоМХ) Тогда
		
		ДокОткрытияРазделаМХ = Документы.Поручение.НайтиПоРеквизиту("ДокументОснование", Ссылка);
		Если ДокОткрытияРазделаМХ = Документы.Поручение.ПустаяСсылка() Тогда
			
			ДокОткрытияРазделаМХ = Документы.Поручение.СоздатьДокумент();
			ДокОткрытияРазделаМХ.Дата					= Дата;
			ДокОткрытияРазделаМХ.ДокументОснование		= Ссылка;
			ДокОткрытияРазделаМХ.ОткрытьВМХ				= Истина;
			ДокОткрытияРазделаМХ.ВидОперацииД			= Справочники.ВидыОпераций.ОткрытиеРазделаСчетаДепо;
			ДокОткрытияРазделаМХ.Инициатор				= СчетДепоМХ.ВладелецСчетаДепоМХ;
			ДокОткрытияРазделаМХ.Депонент				= СчетДепоМХ.Владелец;
			ДокОткрытияРазделаМХ.СчетДепо				= СчетДепоМХ;
			ДокОткрытияРазделаМХ.ТипРазделаСчетаДЕПО	= ТипРазделаСчетаДЕПО;
			ДокОткрытияРазделаМХ.РазделСчетаДепоМХ		= НомерРазделаСчетаДепоМХ;
			ЭтоТипРазделаОбеспеченияДержатель			= (ТипРазделаСчетаДЕПО = Перечисления.ТипыРазделовСчетовДЕПО.ОбеспеченияДержатель);
			ДокОткрытияРазделаМХ.Брокер					= ?(ЭтоТипРазделаОбеспеченияДержатель, Брокер, Неопределено);
			
			Попытка
				ДокОткрытияРазделаМХ.Записать(РежимЗаписиДокумента.Проведение);
				Если ЭтоТипРазделаОбеспеченияДержатель Тогда
					Документы.Поручение.ВыгрузитьПоручение(ДокОткрытияРазделаМХ.Ссылка);
				КонецЕсли;
			Исключение
				ЗаписьЖурналаРегистрации("Проведение Открытия раздела счета МХ", УровеньЖурналаРегистрации.Ошибка,,, ОписаниеОшибки());
				ИнформацияОбОшибке = ИнформацияОбОшибке();
				ОписаниеОшибки = ПодробноеПредставлениеОшибки(ИнформацияОбОшибке);
				ВызватьИсключение ОписаниеОшибки;				
			КонецПопытки;
		КонецЕсли;
	Иначе
		ОбщегоНазначения.СообщитьОбОшибке("Для создания поручения на открытие раздела счета МХ должны быть заполнены:
																|Счет депо МХ и Номер раздела счета депо МХ", Отказ);		
	КонецЕсли;
	
КонецПроцедуры

Процедура СформироватьПоручениеНаЗакрытиеРазделаСчетаМХ(Отказ)
	
	Если ЗначениеЗаполнено(СчетДепоМХ) И ЗначениеЗаполнено(РазделСчетаДепоМХ) Тогда
		
		// Если активный раздел счета депо общий (т.е. относится к нескольким разным пассивным разделам),
		// то такой активный раздел не закрывать
		Запрос = Новый Запрос;
		Запрос.Текст = 
			"ВЫБРАТЬ
			|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ РазделыСчетаДепо.Ссылка) КАК КоличествоСсылок
			|ИЗ
			|	Справочник.РазделыСчетаДепо КАК РазделыСчетаДепо
			|ГДЕ
			|	РазделыСчетаДепо.РазделСчетаДепоМХ = &РазделыСчетаДепоМХ
			|	И РазделыСчетаДепо.СтатусСчетаДепо = &СтатусСчетаДепо
			|	И РазделыСчетаДепо.Ссылка <> &РазделыСчетаДепо";
		
		Запрос.УстановитьПараметр("РазделыСчетаДепоМХ", РазделСчетаДепоМХ); 
		Запрос.УстановитьПараметр("СтатусСчетаДепо", Перечисления.СтатусыСчетовДепо.Открыт);
		Запрос.УстановитьПараметр("РазделыСчетаДепо", РазделСчетаДепо);
		
		Выборка = Запрос.Выполнить().Выбрать();
		
		Если Выборка.Следующий() Тогда 
			
			Если Выборка.КоличествоСсылок = 0 Тогда 
		
				ДокЗакрытияРазделаМХ = Документы.Поручение.НайтиПоРеквизиту("ДокументОснование", Ссылка);
				Если ДокЗакрытияРазделаМХ = Документы.Поручение.ПустаяСсылка() Тогда
					
					ДокЗакрытияРазделаМХ = Документы.Поручение.СоздатьДокумент();
					ДокЗакрытияРазделаМХ.Дата					= Дата;
					ДокЗакрытияРазделаМХ.ДокументОснование		= Ссылка;
					ДокЗакрытияРазделаМХ.ЗакрытьВМХ				= Истина;
					ДокЗакрытияРазделаМХ.ВидОперацииД			= Справочники.ВидыОпераций.ЗакрытиеРазделаСчетаДепо;
					ДокЗакрытияРазделаМХ.Инициатор				= СчетДепоМХ.ВладелецСчетаДепоМХ;
					ДокЗакрытияРазделаМХ.Депонент				= СчетДепоМХ.Владелец;
					ДокЗакрытияРазделаМХ.СчетДепо				= СчетДепоМХ;
					ДокЗакрытияРазделаМХ.ТипРазделаСчетаДЕПО	= ТипРазделаСчетаДЕПО;
					ДокЗакрытияРазделаМХ.РазделСчетаДепоМХ		= РазделСчетаДепоМХ.Код;
					
					Попытка
						ДокЗакрытияРазделаМХ.Записать(РежимЗаписиДокумента.Проведение);
					Исключение
						ЗаписьЖурналаРегистрации("Проведение Закрытия раздела счета МХ", УровеньЖурналаРегистрации.Ошибка,,, ОписаниеОшибки());
						ИнформацияОбОшибке = ИнформацияОбОшибке();
						ОписаниеОшибки = ПодробноеПредставлениеОшибки(ИнформацияОбОшибке);
						ВызватьИсключение ОписаниеОшибки;				
					КонецПопытки;
				КонецЕсли;	
					
			Иначе 
				ОбщегоНазначения.СообщитьОбОшибке("Активный раздел не может быть закрыт, т.к. по нему есть активные пассивные разделы", Отказ);	
			КонецЕсли;
		КонецЕсли;	
		
	Иначе
		ОбщегоНазначения.СообщитьОбОшибке("Для создания поручения на закрытие раздела счета МХ должны быть заполнены:
																|Счет депо МХ и Раздел счета депо МХ", Отказ);		
	КонецЕсли;
	
КонецПроцедуры

Процедура СформироватьПорученияНаЗакрытиеРазделовСчета(Отказ)
	
	Если ЗначениеЗаполнено(СчетДепо) Тогда
	
		Запрос = Новый Запрос;
		Запрос.Текст = 
			"ВЫБРАТЬ
			|	РазделыСчетаДепо.Ссылка КАК РазделСчетаДепо,
			|	РазделыСчетаДепо.Владелец.Владелец КАК Депонент,
			|	РазделыСчетаДепоМХ.Ссылка КАК РазделСчетаДепоМХ,
			|	РазделыСчетаДепо.ТипРазделаСчетаДЕПО КАК ТипРазделаСчетаДЕПО,
			|	Поручение.Ссылка КАК Поручение,
			|	РазделыСчетаДепоМХ.Владелец КАК СчетДепоМХ
			|ПОМЕСТИТЬ ВТПредварительноНаЗакрытие
			|ИЗ
			|	Справочник.РазделыСчетаДепо КАК РазделыСчетаДепо
			|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.РазделыСчетаДепоМХ КАК РазделыСчетаДепоМХ
			|		ПО РазделыСчетаДепо.РазделСчетаДепоМХ = РазделыСчетаДепоМХ.Ссылка
			|			И (РазделыСчетаДепоМХ.СтатусСчетаДепо = ЗНАЧЕНИЕ(Перечисление.СтатусыСчетовДепо.Открыт))
			|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.Поручение КАК Поручение
			|		ПО РазделыСчетаДепо.Владелец = Поручение.СчетДепо
			|			И РазделыСчетаДепо.Ссылка = Поручение.РазделСчетаДепо
			|			И (Поручение.ДокументОснование = &ДокументОснование)
			|			И (Поручение.ВидОперацииД = ЗНАЧЕНИЕ(Справочник.ВидыОпераций.ЗакрытиеРазделаСчетаДепо))
			|ГДЕ
			|	РазделыСчетаДепо.Владелец = &СчетДепо
			|	И РазделыСчетаДепо.СтатусСчетаДепо = ЗНАЧЕНИЕ(Перечисление.СтатусыСчетовДепо.Открыт)
			|	И Поручение.Ссылка ЕСТЬ NULL
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ
			|	РазделыСчетаДепо.РазделСчетаДепоМХ КАК РазделСчетаДепоМХ,
			|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ РазделыСчетаДепо.Ссылка) КАК КоличествоСсылок
			|ПОМЕСТИТЬ ВТСчетчикИспользованияРазделаМХ
			|ИЗ
			|	Справочник.РазделыСчетаДепо КАК РазделыСчетаДепо
			|ГДЕ
			|	РазделыСчетаДепо.РазделСчетаДепоМХ <> ЗНАЧЕНИЕ(Справочник.РазделыСчетаДепоМХ.ПустаяСсылка)
			|	И РазделыСчетаДепо.РазделСчетаДепоМХ В
			|			(ВЫБРАТЬ
			|				ВТПредварительноНаЗакрытие.РазделСчетаДепоМХ КАК РазделСчетаДепоМХ
			|			ИЗ
			|				ВТПредварительноНаЗакрытие КАК ВТПредварительноНаЗакрытие)
			|	И РазделыСчетаДепо.РазделСчетаДепоМХ.СтатусСчетаДепо = ЗНАЧЕНИЕ(Перечисление.СтатусыСчетовДепо.Открыт)
			|
			|СГРУППИРОВАТЬ ПО
			|	РазделыСчетаДепо.РазделСчетаДепоМХ
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ
			|	ВТПредварительноНаЗакрытие.РазделСчетаДепо КАК РазделСчетаДепо,
			|	ВТПредварительноНаЗакрытие.Депонент КАК Депонент,
			|	ВЫБОР
			|		КОГДА ВТСчетчикИспользованияРазделаМХ.КоличествоСсылок = 1
			|			ТОГДА ВТПредварительноНаЗакрытие.РазделСчетаДепоМХ
			|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.РазделыСчетаДепоМХ.ПустаяСсылка)
			|	КОНЕЦ КАК РазделСчетаДепоМХ,
			|	ВТПредварительноНаЗакрытие.ТипРазделаСчетаДЕПО КАК ТипРазделаСчетаДЕПО,
			|	ВТПредварительноНаЗакрытие.Поручение КАК Поручение,
			|	ВЫБОР
			|		КОГДА ВТСчетчикИспользованияРазделаМХ.КоличествоСсылок = 1
			|			ТОГДА ВТПредварительноНаЗакрытие.СчетДепоМХ
			|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.РазделыСчетаДепоМХ.ПустаяСсылка)
			|	КОНЕЦ КАК СчетДепоМХ
			|ИЗ
			|	ВТПредварительноНаЗакрытие КАК ВТПредварительноНаЗакрытие
			|		ЛЕВОЕ СОЕДИНЕНИЕ ВТСчетчикИспользованияРазделаМХ КАК ВТСчетчикИспользованияРазделаМХ
			|		ПО ВТПредварительноНаЗакрытие.РазделСчетаДепоМХ = ВТСчетчикИспользованияРазделаМХ.РазделСчетаДепоМХ";
		
		Запрос.УстановитьПараметр("ДокументОснование", Ссылка); 		
		Запрос.УстановитьПараметр("СчетДепо", СчетДепо);
		
		Выборка = Запрос.Выполнить().Выбрать();
		
		Пока Выборка.Следующий() Цикл 
			
			ДокЗакрытияРаздела = Документы.Поручение.СоздатьДокумент();
			ДокЗакрытияРаздела.Дата					= Дата;
			ДокЗакрытияРаздела.ДокументОснование	= Ссылка;  			
			ДокЗакрытияРаздела.ВидОперацииД			= Справочники.ВидыОпераций.ЗакрытиеРазделаСчетаДепо;
			ДокЗакрытияРаздела.Инициатор			= Константы.ОрганизацияПоУмолчанию.Получить();
			ДокЗакрытияРаздела.СчетДепо				= СчетДепо;
			ДокЗакрытияРаздела.Депонент				= Выборка.Депонент;
			ДокЗакрытияРаздела.РазделСчетаДепо		= Выборка.РазделСчетаДепо;
			ДокЗакрытияРаздела.ТипРазделаСчетаДЕПО	= Выборка.ТипРазделаСчетаДЕПО;
			
			Если ЗначениеЗаполнено(Выборка.СчетДепоМХ) И ЗначениеЗаполнено(Выборка.РазделСчетаДепоМХ) Тогда 
				ДокЗакрытияРаздела.ЗакрытьВМХ	= Истина;
				ДокЗакрытияРаздела.СчетДепоМХ	= Выборка.СчетДепоМХ;
			    ДокЗакрытияРаздела.РазделСчетаДепоМХ	= Выборка.РазделСчетаДепоМХ;
			КонецЕсли;	
			
			ДанныеПоОстаткам = ДокЗакрытияРаздела.ОстаткиЦБПоРазделамСчетовДепоДокумента();
			Если ДанныеПоОстаткам.ЕстьОстаткиЦБ Тогда 
				РежимЗаписи = РежимЗаписиДокумента.Запись;
				Для Каждого СтруктОстатки Из ДанныеПоОстаткам.МассивОстатки Цикл 
					Сообщить(	"По закрываемому разделу счета есть не нулевые остатки:
								| - Счет ДЕПО МХ: "+СтруктОстатки.СчетДепоМХ+";
								| - Раздел счета ДЕПО МХ: "+СтруктОстатки.РазделСчетаДепоМХ+";
								| - Счет ДЕПО: "+СтруктОстатки.СчетДепо+";
								| - Раздел счета ДЕПО: "+СтруктОстатки.РазделСчетаДепо+";
								| - Ценная бумага: "+СтруктОстатки.ЦБ+";
								| - Остаток: "+СтруктОстатки.КоличествоОстаток+".");
				КонецЦикла;
			Иначе 
				РежимЗаписи = РежимЗаписиДокумента.Проведение;
			КонецЕсли;
			
			Попытка
				ДокЗакрытияРаздела.ДополнительныеСвойства.Вставить("ЭтоЗакрытиеСчетаДепо",Истина);
				ДокЗакрытияРаздела.Записать(РежимЗаписи);
			Исключение
				ЗаписьЖурналаРегистрации("Проведение Закрытия раздела счета", УровеньЖурналаРегистрации.Ошибка,,, ОписаниеОшибки());
				ИнформацияОбОшибке = ИнформацияОбОшибке();
				ОписаниеОшибки = ПодробноеПредставлениеОшибки(ИнформацияОбОшибке);
				ВызватьИсключение ОписаниеОшибки;				
			КонецПопытки;
			
		КонецЦикла;

	Иначе
		ОбщегоНазначения.СообщитьОбОшибке("Для создания поручения на закрытие раздела счета должны быть заполнены:
																|Счет депо", Отказ);		
	КонецЕсли;
	
КонецПроцедуры

Функция ОстаткиЦБПоРазделамСчетовДепоДокумента() Экспорт 
	
	Запрос = Новый Запрос(
		"ВЫБРАТЬ
		|	ОстаткиЦБОстатки.СчетДепо КАК СчетДепо,
		|	ОстаткиЦБОстатки.РазделСчетаДепо КАК РазделСчетаДепо,
		|	ОстаткиЦБОстатки.ЦБ КАК ЦБ,
		|	ОстаткиЦБОстатки.КоличествоОстаток КАК КоличествоОстаток,
		|	ОстаткиЦБОстатки.СчетДепоМХ КАК СчетДепоМХ,
		|	ОстаткиЦБОстатки.РазделСчетаДепоМХ КАК РазделСчетаДепоМХ
		|ИЗ
		|	РегистрНакопления.ОстаткиЦБ.Остатки(
		|			&Период,
		|			    СчетДепо = &СчетДепо
		|				И РазделСчетаДепо = &РазделСчетаДепо
		|				//УСЛОВИЕ_СЧЕТ_ДЕПО_МХ
		|				//УСЛОВИЕ_РАЗДЕЛ_СЧЕТА_ДЕПО_МХ
		|				) КАК ОстаткиЦБОстатки
		|
		|УПОРЯДОЧИТЬ ПО
		|	ОстаткиЦБОстатки.СчетДепо.Владелец.Наименование,
		|	ОстаткиЦБОстатки.СчетДепо,
		|	ОстаткиЦБОстатки.РазделСчетаДепо");
	
	    // Текущая дата - чтобы учитывать актуальный остаток ЦБ
		Запрос.УстановитьПараметр("Период", НачалоДня(ТекущаяДатаСеанса())); 		
		Запрос.УстановитьПараметр("СчетДепо", СчетДепо);
		Запрос.УстановитьПараметр("РазделСчетаДепо", РазделСчетаДепо);
		
		Если ЗакрытьВМХ Тогда 
			
			Если ЗначениеЗаполнено(СчетДепоМХ) Тогда 
				Запрос.Текст = СтрЗаменить(Запрос.Текст,"//УСЛОВИЕ_СЧЕТ_ДЕПО_МХ","И СчетДепоМХ = &СчетДепоМХ");
				Запрос.УстановитьПараметр("СчетДепоМХ", СчетДепоМХ);
			КонецЕсли;
			
			Если ЗначениеЗаполнено(РазделСчетаДепоМХ) Тогда
				Запрос.Текст = СтрЗаменить(Запрос.Текст,"//УСЛОВИЕ_РАЗДЕЛ_СЧЕТА_ДЕПО_МХ","И РазделСчетаДепоМХ = &РазделСчетаДепоМХ");
			    Запрос.УстановитьПараметр("РазделСчетаДепоМХ", РазделСчетаДепоМХ);
			КонецЕсли;
			
		КонецЕсли;
		
		РезультатОстатки = Запрос.Выполнить();
		Результат = Новый Структура("ЕстьОстаткиЦБ,МассивОстатки", Ложь, Новый Массив);
		
		Если Не РезультатОстатки.Пустой() Тогда 
			
			Результат.ЕстьОстаткиЦБ = Истина;
			ВыборкаОстатки = РезультатОстатки.Выбрать();
			
			МассивОстатки = Новый Массив;
			Пока ВыборкаОстатки.Следующий() Цикл
				
				СтруктОстатки = Новый Структура;
				СтруктОстатки.Вставить("СчетДепоМХ",ВыборкаОстатки.СчетДепоМХ);
				СтруктОстатки.Вставить("РазделСчетаДепоМХ",ВыборкаОстатки.РазделСчетаДепоМХ);
				СтруктОстатки.Вставить("СчетДепо",ВыборкаОстатки.СчетДепо);
				СтруктОстатки.Вставить("РазделСчетаДепо",ВыборкаОстатки.РазделСчетаДепо);
				СтруктОстатки.Вставить("ЦБ",ВыборкаОстатки.ЦБ);
				СтруктОстатки.Вставить("КоличествоОстаток",ВыборкаОстатки.КоличествоОстаток);
				
				Результат.МассивОстатки.Добавить(СтруктОстатки);
				
			КонецЦикла;
			
		КонецЕсли;
		
	Возврат Результат;
	
КонецФункции

Процедура СоздатьДокументРазблокировкиЦБ(Отказ)
	
	Если Не ОтменяемоеПоручение.ВидОперацииД = Справочники.ВидыОпераций.СнятиеСДепонирования Тогда
		Возврат;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ПоручениеБлокировкиЦБ.Ссылка КАК ПоручениеБлокировкиЦБ
	|ИЗ
	|	Документ.Поручение КАК ПоручениеБлокировкиЦБ
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.Поручение КАК ПоручениеРазблокировкиЦБ
	|		ПО (ПоручениеРазблокировкиЦБ.ДокументОснование = &ПоручениеОтмены)
	|			И (ПоручениеРазблокировкиЦБ.ВидОперацииД = &Перевод)
	|ГДЕ
	|	ПоручениеБлокировкиЦБ.ДокументОснование = &ОтменяемоеПоручение
	|	И ПоручениеБлокировкиЦБ.ВидОперацииД = &Перевод
	|	И ПоручениеРазблокировкиЦБ.Ссылка ЕСТЬ NULL ";
	
	Запрос.УстановитьПараметр("ОтменяемоеПоручение"	, ОтменяемоеПоручение);
	Запрос.УстановитьПараметр("ПоручениеОтмены"		, Ссылка);
	Запрос.УстановитьПараметр("Перевод", Справочники.ВидыОпераций.ПереводМеждуРазделамиСчетаДепо);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		ДокументОбъект = Выборка.ПоручениеБлокировкиЦБ.Скопировать();
		РазделСчетаДепо = ДокументОбъект.РазделСчетаДепо;
		ДокументОбъект.РазделСчетаДепо = ДокументОбъект.РазделСчетаДепоКонтрагента;
		ДокументОбъект.РазделСчетаДепоКонтрагента = РазделСчетаДепо;
		ДокументОбъект.ДокументОснование = Ссылка;
		ДокументОбъект.Дата = ДатаИсполненияПоручения + 1;
		ДокументОбъект.ДатаИсполненияПоручения = ДокументОбъект.Дата;
		ДокументОбъект.ДатаИсполненияПорученияВДепозитарииМХ = ДокументОбъект.Дата;
		ДокументОбъект.ДатаИсполненияПорученияВМестеРасчетов = ДокументОбъект.Дата;
		
		Попытка
			ДокументОбъект.Записать(РежимЗаписиДокумента.Проведение);
			ТекстСообщения = "Создано поручение на перевод ЦБ с блокировочного раздела, номер документа " + ДокументОбъект.Номер;
		Исключение
			Отказ = Истина;
			ТекстСообщения = "Не удалось провести поручение на перевод ЦБ с блокировочного раздела";
		КонецПопытки;
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
	КонецЕсли;
	
КонецПроцедуры

Функция НеобходимоФормироватьУведомлениеОИсполненииОперацийСЦБ(РежимЗаписи)
	
	СнятиеСДепонирования = Справочники.ВидыОпераций.СнятиеСДепонирования;
	ПереводМеждуРазделамиСчетаДепо = Справочники.ВидыОпераций.ПереводМеждуРазделамиСчетаДепо;
	БлокированоРасчеты = Перечисления.ТипыРазделовСчетовДЕПО.БлокированоРасчеты;
	Перемещение = Справочники.ВидыОпераций.Перемещение;
	
	КодыВидовОперацийЦБ = РегистрыСведений.ПараметрыГлобальные.ЗначениеПараметра("2163.КодыВидовОперацийЦБДляУведомления");
	МассивКодовВидовОперацийЦБДляУведомления = СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(КодыВидовОперацийЦБ);
	
	Если ТипЗнч(ВидОперацииД) = Тип("СправочникСсылка.ВидыОпераций") Тогда
		Если НЕ МассивКодовВидовОперацийЦБДляУведомления.Найти(Строка(ВидОперацииД.Код)) <> Неопределено Тогда
			Возврат Ложь;
		КонецЕсли;
	КонецЕсли;
	
	Если (ВидОперацииД = СнятиеСДепонирования И РазделСчетаДепо.ТипРазделаСчетаДЕПО <> БлокированоРасчеты)
		Или (ВидОперацииД = ПереводМеждуРазделамиСчетаДепо И РазделСчетаДепоКонтрагента.ТипРазделаСчетаДЕПО <> БлокированоРасчеты)
		Или (ВидОперацииД = Перемещение И РазделСчетаДепоКонтрагента.ТипРазделаСчетаДЕПО <> БлокированоРасчеты)
		Или ВидОперацииД = Справочники.ВидыОпераций.Перевод Или ВидОперацииД = Справочники.ВидыОпераций.Депонирование Тогда
		ЭтоТорговаяОперация = ЗначениеЗаполнено(БанковскийСчет) И (СуммаСделки <> 0 Или ЦенныеБумагиСписываемые.Итог("Сумма") <> 0);
		Если Не ЭтоТорговаяОперация И РежимЗаписи = РежимЗаписиДокумента.Проведение И ЗначениеЗаполнено(ДатаИсполненияПоручения)
			И (РегистрыСведений.СтатусыПоручений.СтатусПоручения(Ссылка) <> Перечисления.СтатусыПоручений.Исполнено Или Ссылка = Документы.Поручение.ПустаяСсылка()) Тогда
			Возврат Истина;
		КонецЕсли;
	КонецЕсли;
	Возврат Ложь;
	
КонецФункции

Функция НеобходимоУдалитьУведомлениеОИсполненииОперацийСЦБ(РежимЗаписи)
	
	Если Ссылка = Документы.Поручение.ПустаяСсылка() Тогда
		Возврат Ложь;
	КонецЕсли;
	Если РегистрыСведений.СтатусыПоручений.СтатусПоручения(Ссылка) = Перечисления.СтатусыПоручений.Исполнено И 
		(РежимЗаписи = РежимЗаписиДокумента.ОтменаПроведения Или Не ЗначениеЗаполнено(ДатаИсполненияПоручения)) Тогда
		Возврат Истина;
	КонецЕсли;
	Возврат Ложь;
	
КонецФункции

Процедура КонтрольКвалИнвестора(РежимЗаписи, Отказ)
	ЭтоПроведение = (РежимЗаписи = РежимЗаписиДокумента.Проведение) Или (Проведен И РежимЗаписи = РежимЗаписиДокумента.Запись);
	
	Если ВидОперацииД <> Справочники.ВидыОпераций.Депонирование Или Не ЭтоПроведение Тогда
		Возврат;
	КонецЕсли;
	
	Если КвалифицированныйИнвесторПо11_8_пзн Тогда
		Возврат;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ЦенныеБумаги.ВидЦББанкаРоссии.ВидИнструмента КАК ВидИнструмента,
	|	ЦенныеБумаги.ДляКвалифицированныхИнвесторов КАК ДляКвалифицированныхИнвесторов,
	|	ЦенныеБумаги.Представление КАК ЦБ,
	|	ЦенныеБумаги.ISIN КАК ISIN
	|ИЗ
	|	Справочник.ЦенныеБумаги КАК ЦенныеБумаги
	|ГДЕ
	|	ЦенныеБумаги.Ссылка В(&ЦБДляПроверки)
	|	И ЦенныеБумаги.ДляКвалифицированныхИнвесторов";
	
	Запрос.УстановитьПараметр("ЦБДляПроверки", ЦенныеБумагиСписываемые.ВыгрузитьКолонку("ЦеннаяБумага"));
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() Тогда
		Возврат;
	КонецЕсли;
	
	ДанныеДепонента = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Депонент, "ЮридическиеФизическиеЛица, Код");
	ЮрФизЛицо = ДанныеДепонента.ЮридическиеФизическиеЛица;
	НомерДоговораДепонента = СокрЛП(ДанныеДепонента.Код);
	ЭтоКвалифицированныйИнвестор = РегистрыСведений.РеестрКвалифицированныхИнвесторовПоЗакону.ЕстьКИПОЗакону(ЮрФизЛицо, ТекущаяДатаСеанса());
	Если ЭтоКвалифицированныйИнвестор Тогда
		Возврат;
	КонецЕсли;
	
	ВыборкаЦБ = РезультатЗапроса.Выбрать();
	Пока ВыборкаЦБ.Следующий() Цикл
		ЕстьКвалификацияИнвестора = РегистрыСведений.РеестрКвалифицированныхИнвесторовРОФР.ЕстьКвалификацияИнвестора(
		ЮрФизЛицо, ВыборкаЦБ.ВидИнструмента, ТекущаяДатаСеанса());
		Если Не ЕстьКвалификацияИнвестора Тогда
			ТекстСообщения = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
			"Проведение поручения %1 невозможно, т.к. клиент %2 (договор %3) 
			|не является Квалифицированным инвестором, а ЦБ %4 (ISIN %5) предназначена для квалифицированных инвесторов",
			Ссылка, Депонент, НомерДоговораДепонента, ВыборкаЦБ.ЦБ, ВыборкаЦБ.ISIN);
			ТемаПисьма = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку("Проведение поручения %1 невозможно", Ссылка);
			Если ДополнительныеСвойства.Свойство("ВведеноИнтерактивно") и ДополнительныеСвойства.ВведеноИнтерактивно Тогда
				Отказ = (РежимЗаписи = РежимЗаписиДокумента.Проведение);
				ОбщегоНазначения.СообщитьОбОшибке(ТекстСообщения);
			Иначе
				РежимЗаписи = РежимЗаписиДокумента.Запись;
				СформироватьУведомлениеВCustody(ТемаПисьма,ТекстСообщения);
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

Процедура СформироватьУведомлениеВCustody(ТемаПисьма, ТекстСообщения)
	    
	ВнешнийИсточник = ПланыВидовХарактеристик.ВнешниеИсточники.РассылкаУведомленийОНеПройденномКонтролеКвалИнвестораПриИсполненииПоручений;
	НастройкиОбмена = ВнешниеДанные.ПолучитьПараметрыВнешнегоИсточника(ВнешнийИсточник).Настройка;
	Если Не ЗначениеЗаполнено(НастройкиОбмена) Тогда
		ОписаниеОшибки = "Не заполнены параметры внешнего источника рассылки'"+ВнешнийИсточник+"'";
		ЗаписьЖурналаРегистрации("Поручение клиента. Проверка на квал инвестора",
									УровеньЖурналаРегистрации.Ошибка,
									,
									,
									ОписаниеОшибки);
        Возврат;                            
       
	КонецЕсли;
	
	ТекстПисьма	= ТекстСообщения;
	ПараметрыУведомления = Новый Соответствие;
	ПараметрыУведомления.Вставить("НастройкиОбмена"		, НастройкиОбмена);
	ПараметрыУведомления.Вставить("ТемаПисьма"			, ТемаПисьма);
	ПараметрыУведомления.Вставить("ТекстПисьма"			, ТекстПисьма);
	ПараметрыУведомления.Вставить("ТипТекстаПисьма"		, ТипТекстаПочтовогоСообщения.ПростойТекст);
	ПараметрыУведомления.Вставить("Кодировка"			, "UTF-8");
	ПараметрыУведомления.Вставить("Важность"			, ВажностьИнтернетПочтовогоСообщения.Обычная);
    
	РегистрыСведений.УведомленияКОтправке.ДобавитьУведомлениеКотправке(ПараметрыУведомления);
	
КонецПроцедуры

Функция ЕстьСтрокиСПовторяющейсяЦБ()
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ЦенныеБумагиСписываемые.ЦеннаяБумага КАК ЦеннаяБумага,
	|	ЦенныеБумагиСписываемые.НомерСтроки КАК НомерСтроки
	|ПОМЕСТИТЬ ЦенныеБумагиСписываемые
	|ИЗ
	|	&ЦенныеБумагиСписываемые КАК ЦенныеБумагиСписываемые
	|ГДЕ
	|	ЦенныеБумагиСписываемые.ЦеннаяБумага <> &ПустаяЦеннаяБумага
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЦенныеБумагиСписываемые.ЦеннаяБумага КАК ЦеннаяБумага,
	|	КОЛИЧЕСТВО(*) КАК КоличествоСтрок
	|ИЗ
	|	ЦенныеБумагиСписываемые КАК ЦенныеБумагиСписываемые
	|
	|СГРУППИРОВАТЬ ПО
	|	ЦенныеБумагиСписываемые.ЦеннаяБумага
	|
	|ИМЕЮЩИЕ
	|	КОЛИЧЕСТВО(*) > 1";
	
	Запрос.УстановитьПараметр("ЦенныеБумагиСписываемые", ЦенныеБумагиСписываемые.Выгрузить(, "НомерСтроки, ЦеннаяБумага"));
	Запрос.УстановитьПараметр("ПустаяЦеннаяБумага", Справочники.ЦенныеБумаги.ПустаяСсылка());
	
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() Тогда
		Возврат Ложь;
	КонецЕсли;
	
	ПовторяющиесяЦБ = РезультатЗапроса.Выбрать();
	ТекстОшибки = "В табличной части имеются строки с повторяющейся ЦБ: ";
	Пока ПовторяющиесяЦБ.Следующий() Цикл
		ТекстОшибки = ТекстОшибки + ПовторяющиесяЦБ.ЦеннаяБумага + "; ";
	КонецЦикла;
	ОбщегоНазначения.СообщитьОбОшибке(ТекстОшибки);
	Возврат Истина;
КонецФункции
////////////////////////////////////////////////////////////////////////////////
// ПРОЦЕДУРЫ И ФУНКЦИИ ЗАПОЛНЕНИЯ ОПЕРАЦИЙ НКД И ПОГАШЕНИЙ (ПОЛНОЕ + ЧАСТИЧНОЕ)

Процедура ПересчетПогашенияПоСуммеИПД()
	КоличествоЦБ = ЦенныеБумагиСписываемые.Итог("Количество");
	
	Если КоличествоЦБ = 0 Тогда
		ОбщегоНазначения.СообщитьОбОшибке("Итоговое количество для пересчета меньше или рано 0! Пересчет 'сумм' невозможен!");
		Возврат;
	КонецЕсли;
	
	СуммаИПДНаЕд = СуммаИПД / КоличествоЦБ;
	
	Для Каждого Строка ИЗ ЦенныеБумагиСписываемые Цикл
		Строка.Сумма = Строка.Количество * СуммаИПДНаЕд;
	КонецЦикла;	
КонецПроцедуры

// Выполняет запрос для получения облигаций и купонов, которые необходимо погасить 
// на дату документа. Вызывается в документе ПогашениеКупона
//
// Параметры
//  Ссылка       - ссылка на документ
//
// Возвращаемое значение:
//   результат запроса
//
Функция ВыполнитьЗапросДляПодбораОблигацийКупоновДляПогашения(ТолькоКупонные = Истина, СчетДепоМХДокумента = Неопределено)
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	ОстаткиЦБОстатки.СчетДепо.Владелец КАК Депонент,
	|	ОстаткиЦБОстатки.СчетДепо КАК СчетДепо,
	|	ОстаткиЦБОстатки.ЦБ КАК ЦеннаяБумага,
	|	ОстаткиЦБОстатки.РазделСчетаДепо КАК РазделСчетаДепо,
	|	ОстаткиЦБОстатки.СчетДепоМХ КАК СчетДепоМХ,
	|	ОстаткиЦБОстатки.РазделСчетаДепоМХ КАК РазделСчетаДепоМХ,
	|	ОстаткиЦБОстатки.СтатусЦБ КАК СтатусЦБ,
	|	ОстаткиЦБОстатки.КоличествоОстаток КАК Количество,
	|	ЕСТЬNULL(НоминалЦБСрезПоследних.Сумма, 0) КАК Номинал,
	|	ЕСТЬNULL(КотировкиСрезПоследних.Nkd, 0) КАК НКД,
	|	ОстаткиЦБОстатки.ЦБ.ISIN КАК ISIN,
	|	ОстаткиЦБОстатки.ЦБ.НомерРегистрации КАК НомерРегистрации,
	|	ОстаткиЦБОстатки.РазделСчетаДепо.ТипРазделаСчетаДЕПО КАК ТипРазделаСчетаДЕПО
	|ИЗ
	|	РегистрНакопления.ОстаткиЦБ.Остатки(
	|			&Дата,
	|			ЦБ = &ЦБ
	|				И &ОтборПоКупоннымОблигациям
	|				И &ОтборПоСчетуДепоМХ) КАК ОстаткиЦБОстатки
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.НоминалЦБ.СрезПоследних(&Дата, ) КАК НоминалЦБСрезПоследних
	|		ПО ОстаткиЦБОстатки.ЦБ = НоминалЦБСрезПоследних.ЦеннаяБумага
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.Котировки.СрезПоследних(
	|				&Дата,
	|				Биржа = &Биржа
	|					И РежимТоргов = &РежимТоргов) КАК КотировкиСрезПоследних
	|		ПО ОстаткиЦБОстатки.ЦБ = КотировкиСрезПоследних.ЦеннаяБумага");
	
	Если ЗначениеЗаполнено(ДатаФиксации) Тогда
		Если ФиксацияНаУтро = ИСТИНА Тогда
			СекундВЧасе = 60 * 60;
			ДатаФиксацииСУчетомВремени = НачалоДня(ДатаФиксации) + (СекундВЧасе * 7);
		Иначе
			ДатаФиксацииСУчетомВремени = КонецДня(ДатаФиксации);
		Конецесли;
		Запрос.УстановитьПараметр("Дата", Новый Граница(ДатаФиксацииСУчетомВремени, ВидГраницы.Включая));
	Иначе
		Запрос.УстановитьПараметр("Дата", МоментВремени());
	КонецЕсли;
	Запрос.УстановитьПараметр("ЦБ", ЦБ);
	
	СтрокаУсловия = ?(ТолькоКупонные, "ЦБ.КупоннаяОблигация", "ИСТИНА");
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "&ОтборПоКупоннымОблигациям", СтрокаУсловия);
	
	Запрос.УстановитьПараметр("РежимТоргов", Справочники.РежимыТоргов.Рыночный);
	Если БанковскийСчет.ВалютаДенежныхСредств = ВалютаРегламентированногоУчета Тогда
		Запрос.УстановитьПараметр("Биржа", Справочники.Биржи.MICEX);
	Иначе
		Запрос.УстановитьПараметр("Биржа", Справочники.Биржи.Внебирж);
	КонецЕсли;

	Запрос.УстановитьПараметр("СчетДепоМХ", СчетДепоМХДокумента);
	СтрокаУсловия = ?(ЗначениеЗаполнено(СчетДепоМХДокумента), "СчетДепоМХ = &СчетДепоМХ", "ИСТИНА");
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "&ОтборПоСчетуДепоМХ", СтрокаУсловия);
	
	Возврат Запрос.Выполнить();
КонецФункции

// Выполняет автоматическое заполнение табличной части документа, облигациями,
// которые (или купоны которых) необходимо погасить.
//
// Параметры
//  Ссылка      - ДокументСсылка.ПогашениеКупона - Ссылка на документ
Процедура ЗаполнитьПогашаемыеОблигацииКупоны(ТолькоКупонные, СчетДепоМХДокумента = Неопределено) Экспорт
	Если (ВидОперацииД = Справочники.ВидыОпераций.НачислениеДивидендов
		ИЛИ ВидОперацииД = Справочники.ВидыОпераций.НачислениеДоходаПрочие)
		И НЕ ЗначениеЗаполнено(ДатаФиксации) Тогда
		ОбщегоНазначения.СообщитьОбОшибке("Не заполнена 'Дата фиксации' для 'Начисления дивидендов'!!!");
		Возврат;
	КонецЕсли;
	
	Результат = ВыполнитьЗапросДляПодбораОблигацийКупоновДляПогашения(ТолькоКупонные, СчетДепоМХДокумента);
	
	ЗаполнитьПогашаемыеОблигацииКупоныПоВидуОперации(Результат);
	ОповеститьОНаличииОбособленныхСчетов(Результат);
	
	ВыплатаВВалютеРеглУчета = Валюта = ВалютаРегламентированногоУчета;
	РеквизитыЦБ = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ЦБ, "ВидЦБ, ВидЦББанкаРоссии");
	РасчетПоИностраннойЦБ = Справочники.ВидыЦББанкаРоссии.ЭтоВидИностраннойЦБ(РеквизитыЦБ.ВидЦББанкаРоссии);
	НачислитьНДФЛНаИностранныеДивиденды = РасчетПоИностраннойЦБ
		И Справочники.ВидыОпераций.ЭтоВыплатаДоходаПоАкциямИлиИнымЦБ(ВидОперацииД);
	Если ВидОперацииД = Справочники.ВидыОпераций.ПогашениеНКД И Дата >= Константы.ДатаНачалаНачисленияНДФЛНаГособлигации.Получить() Тогда 
		НачислятьНалог = Не Справочники.ВидыЦББанкаРоссии.ЭтоВидИностраннойЦБ(РеквизитыЦБ.ВидЦББанкаРоссии);
	Иначе 
		НачислятьНалог = (ВыплатаВВалютеРеглУчета И НЕ РеквизитыЦБ.ВидЦБ = Перечисления.ВидыОблигаций.Государственная
			Или НачислитьНДФЛНаИностранныеДивиденды);
	КонецЕсли;
						
	Если НачислятьНалог Тогда
		РассчитатьИЗаполнитьНалогиПоВыплатеДохода();
	КонецЕсли;
	
	ЗаполнитьБанковскиеСчета();
	
	Если ТипЗнч(ВидОперацииД) = Тип("СправочникСсылка.ВидыОпераций")
		И ВидОперацииД.ВыплатаДоходаВДенежнойФорме
		И Документы.НачисленныйНалог.ИспользоватьРасчетНДФЛПоПрогрессивнойШкале(Дата) Тогда
		
		Для Каждого Строка Из ЦенныеБумагиСписываемые Цикл
			Строка.ПлановаяДатаРасчетов = ПланируемаяДатаРасчетов;
		КонецЦикла;
		Документы.Поручение.ЗаполнитьВалютуНалога(Ссылка, ЦенныеБумагиСписываемые);
		Документы.Поручение.ЗаполнитьСуммуНалога(Ссылка, ЦенныеБумагиСписываемые);
	КонецЕсли;
	
КонецПроцедуры

Процедура ЗаполнитьПогашаемыеОблигацииКупоныПоВидуОперации(Результат)
	
	Если ВидОперацииД = Справочники.ВидыОпераций.ПогашениеНКД Или ВидОперацииД = Справочники.ВидыОпераций.Выкуп Тогда
		Выборка = Результат.Выбрать();
		ИнформацияОКупоне = ЦБ.Купоны.Найти(ДатаФиксации, "ДатаФиксацииСписка");
		Пока Выборка.Следующий() Цикл
			стрЦБ = ЦенныеБумагиСписываемые.Добавить();
			ЗаполнитьЗначенияСвойств(стрЦБ, Выборка);
			Если ИнформацияОКупоне <> Неопределено Тогда
				стрЦБ.Сумма = ОпределитьПолученныйНКД(Выборка, ИнформацияОКупоне);
			КонецЕсли;
		КонецЦикла;
		ОбщееКоличествоЦБ = ЦенныеБумагиСписываемые.Итог("Количество");
		РаспределяемСуммуИПДПропорциональноКоличествуЦБ = Не РасчетнымМетодом И ЗначениеЗаполнено(СуммаИПД) И ОбщееКоличествоЦБ <> 0;
		Если РаспределяемСуммуИПДПропорциональноКоличествуЦБ Тогда
			РаспределитьСуммуВыплатыПоСтрокамПропорциональноКоличествуЦБ(ОбщееКоличествоЦБ);
		Иначе
			СуммаИПД = ЦенныеБумагиСписываемые.Итог("Сумма");
		КонецЕсли;
	ИначеЕсли ВидОперацииД = Справочники.ВидыОпераций.ПогашениеЦБПолное И Не ЗначениеЗаполнено(СуммаИПД) Тогда
		Выборка = Результат.Выбрать();
		Пока Выборка.Следующий() Цикл
			НоваяСтрока = ЦенныеБумагиСписываемые.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, Выборка);
			
			НоваяСтрока.Сумма = НоваяСтрока.Количество * Выборка.Номинал;
		КонецЦикла;
		СуммаИПД = ЦенныеБумагиСписываемые.Итог("Сумма");
	Иначе
		ЦенныеБумагиСписываемые.Загрузить(Результат.Выгрузить());
		ПересчетПогашенияПоСуммеИПД();
	КонецЕсли;
	
КонецПроцедуры

// Определение полученного НКД; Если установлен флаг рассчитывать, то рассчитываем НКД исходя из данных в
// таблице купонов для бумаги, в противном случае берем из котировок.
//
// Параметры:
//  Выборка				- ВыборкаИзРезультатаЗапроса - Выборка из запроса
//  ИнформацияОКупоне	- СтрокаТабличнойЧасти - Строка табличной части купоны справочника ЦенныеБумаги
//							справочника ЦенныеБумаги
//
// Возвращаемое значение:
//  Число - Рассчитанная сумма
Функция ОпределитьПолученныйНКД(Выборка, ИнформацияОКупоне)
	// Расчет суммы погашения
	Если РасчетнымМетодом Тогда
		Если ИнформацияОКупоне.Сумма = 0 Тогда
			Если ИнформацияОКупоне.Купон = 0 Тогда
				ОбщегоНазначения.СообщитьОбОшибке("Неверно заполнен текущий купонный период для " + Выборка.ЦБКод + ".
				| Заполнение купонных периодов осуществляется в справочнике ""Ценные бумаги"".
				| Документ проведен не будет!");
				Возврат 0;
			Иначе
				Сто = 100;
				ДлинаПериода = (ИнформацияОКупоне.ДатаПогашения - ИнформацияОКупоне.ДатаВыпуска) / ОбщегоНазначенияПовтИсп.СекундВСутках() + 1;
				СуммаТЧ = Окр(ИнформацияОКупоне.Купон / ИнформацияОКупоне.СрокОбращения * ДлинаПериода * Выборка.Номинал / Сто, 2);
			КонецЕсли;
		Иначе
			СуммаТЧ = ИнформацияОКупоне.Сумма;
		КонецЕсли;
	ИначеЕсли Не ЗначениеЗаполнено(СуммаИПД) Тогда
		Если Выборка.НКД = 0 Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("НКД по " + Выборка.ЦеннаяБумага + " равно 0.");
		КонецЕсли;
		СуммаТЧ = Окр(Выборка.НКД, 2);
	Иначе
		СуммаТЧ = 0;
	КонецЕсли;
	
	СуммаТЧ = СуммаТЧ * Выборка.Количество;
	
	Возврат СуммаТЧ;
КонецФункции

Процедура РаспределитьСуммуВыплатыПоСтрокамПропорциональноКоличествуЦБ(ОбщееКоличествоЦБ)
	СуммаИПДНаЕд = СуммаИПД / ОбщееКоличествоЦБ;
	Для Каждого Строка Из ЦенныеБумагиСписываемые Цикл
		Строка.Сумма = Строка.Количество * СуммаИПДНаЕд;
	КонецЦикла;
КонецПроцедуры

Процедура ОповеститьОНаличииОбособленныхСчетов(Результат)
	Выборка = Результат.Выбрать();
	Пока Выборка.Следующий() Цикл
		Если Выборка.ТипРазделаСчетаДЕПО = Перечисления.ТипыРазделовСчетовДЕПО.БлокированоОбособленный Тогда
			
			ТекстОбособленныйСчет = "Поручение " + СокрЛП(Номер) + " от "
			+ Дата + " указан раздел с типом Блокировано (обособл.), Счет депо: " + СокрЛП(Выборка.СчетДепо)
			+ ", Раздел счета депо: " + СокрЛП(Выборка.РазделСчетаДепо)
			+ ?(ЗначениеЗаполнено(Выборка.ISIN), ", ISIN: " + Выборка.ISIN, "Регистрационный номер ЦБ: "
			+ Выборка.НомерРегистрации);
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстОбособленныйСчет);
			
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

Процедура ЗаполнитьБанковскиеСчета() Экспорт
	
	СчетаДляВыплатыДоходов			 = СчетаДляВыплатыДоходов(Дата, БанковскийСчет.ВалютаДенежныхСредств);
	РасчетныеКодыДляВыплатыДоходов	 = РасчетныеКодыДляВыплатыДоходов(Дата, БанковскийСчет.ВалютаДенежныхСредств);
	БрокерскиеСчета					 = БрокерскиеСчета(Дата, БанковскийСчет.ВалютаДенежныхСредств);
	
	Для Каждого Строка Из ЦенныеБумагиСписываемые Цикл
		
		ТекущийДепонент = Строка.СчетДепо.Владелец;
		
		НайденБанковскийСчет = НайденБанковскийСчетИзСчетовДляВыплатыДоходов(ТекущийДепонент, Строка, СчетаДляВыплатыДоходов);
		Если Не НайденБанковскийСчет Тогда
			НайденБанковскийСчет
				= НайденБанковскийСчетИзРасчетныхКодовДляВыплатыДоходовКлиентам(ТекущийДепонент, Строка, РасчетныеКодыДляВыплатыДоходов);
		КонецЕсли;
		Если Не НайденБанковскийСчет Тогда
			НайденБанковскийСчет = НайденБанковскийСчетИзБрокерскихСчетов(ТекущийДепонент, Строка, БрокерскиеСчета);
		КонецЕсли;
		
		Если НайденБанковскийСчет Тогда
			ПроверитьНеобходимостьНачисленияНалога(Строка);
		КонецЕсли;
		
		Строка.Комментарий = Документы.НачисленныйНалог.КомментарийОНалогеУдержанномВИностраннойЮрисдикции(
			Строка.СуммаНалогаВИностраннойЮрисдикции,
			Строка.ВалютаНалога,
			СтавкаИПДНалогаВИностраннойЮрисдикции);
		
	КонецЦикла;
	
КонецПроцедуры

Функция СчетаДляВыплатыДоходов(Дата, Валюта)
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	СчетаСрезПоследних.Счет.Владелец КАК Депонент,
	|	МАКСИМУМ(СчетаСрезПоследних.Счет) КАК БанковскийСчет
	|ИЗ
	|	РегистрСведений.СчетаДляВыплатыДоходов.СрезПоследних(
	|			&ДатаСреза,
	|			Счет.ВалютаДенежныхСредств = &Валюта
	|				И ФлагАктивности) КАК СчетаСрезПоследних
	|
	|СГРУППИРОВАТЬ ПО
	|	СчетаСрезПоследних.Счет.Владелец";
	Запрос.УстановитьПараметр("ДатаСреза",	Дата);
	Запрос.УстановитьПараметр("Валюта",		Валюта);
	Возврат Запрос.Выполнить().Выгрузить();
КонецФункции

Функция РасчетныеКодыДляВыплатыДоходов(Дата, Валюта)
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	РасчетныеКоды.Клиент КАК Депонент,
	|	РасчетныеКоды.РасчетныйКод КАК РасчетныйКод
	|ИЗ
	|	РегистрСведений.РасчетныеКодыДляВыплатыДоходовКлиентам.СрезПоследних(&ДатаСреза, Валюта = &Валюта) КАК РасчетныеКоды";
	Запрос.УстановитьПараметр("ДатаСреза",	Дата);
	Запрос.УстановитьПараметр("Валюта",		Валюта);
	Возврат Запрос.Выполнить().Выгрузить();
КонецФункции

Функция БрокерскиеСчета(Дата, Валюта)
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Право.Клиент КАК Депонент,
	|	Право.Значение КАК ПравоПредоставлено
	|ПОМЕСТИТЬ втПравоИспользованияЦБКлиентов
	|ИЗ
	|	РегистрСведений.ПравоИспользованияЦБКлиентов.СрезПоследних(&ДатаСреза, ) КАК Право
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	БС.Клиент КАК Депонент,
	|	БС.Счет КАК БанковскийСчет
	|ПОМЕСТИТЬ втБрокерскиеСчета
	|ИЗ
	|	РегистрСведений.БрокерскиеСчета.СрезПоследних(
	|			&ДатаСреза,
	|			Банк = &БанкНРД
	|				И ТипСчета = &ТипСпецБрокерский
	|				И Валюта = &Валюта) КАК БС
	|ГДЕ
	|	БС.ФлагАктивности
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Депонент
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Право.Депонент КАК Депонент,
	|	Право.ПравоПредоставлено КАК ПравоПредоставлено
	|ИЗ
	|	втПравоИспользованияЦБКлиентов КАК Право
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	БС.Депонент КАК Депонент,
	|	БС.БанковскийСчет КАК БанковскийСчет,
	|	ЕСТЬNULL(Права.ПравоПредоставлено, ЛОЖЬ) КАК ИспользованиеДС
	|ИЗ
	|	втБрокерскиеСчета КАК БС
	|		ЛЕВОЕ СОЕДИНЕНИЕ втПравоИспользованияЦБКлиентов КАК Права
	|		ПО БС.Депонент = Права.Депонент";
	Запрос.УстановитьПараметр("ДатаСреза",			Дата);
	Запрос.УстановитьПараметр("БанкНРД",			Константы.РасчетныйБанк.Получить());
	Запрос.УстановитьПараметр("ТипСпецБрокерский",	Перечисления.ТипыНазначенияБанковскихСчетов.Брокерский);
	Запрос.УстановитьПараметр("Валюта",				Валюта);
	Запрос.УстановитьПараметр("ПустойДепонент",		Справочники.Контрагенты.ПустаяСсылка());
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	
	Результат = Новый Структура;
	Результат.Вставить("Права",	РезультатЗапроса[2].Выгрузить());
	Результат.Вставить("БС",	РезультатЗапроса[3].Выгрузить());
	Возврат Результат;
КонецФункции

Процедура РассчитатьИЗаполнитьНалогиПоВыплатеДохода() Экспорт
	
	СтруктураНачисленияНалога = Документы.Поручение.СтруктураНачисленияНалогаПоВыплатеДохода(ЭтотОбъект);
	
	НужноНачислитьНДФЛНаЕврооблигацию = Документы.Поручение.НужноНачислитьНДФЛНаЕврооблигацию(СтруктураНачисленияНалога);
	Если НужноНачислитьНДФЛНаЕврооблигацию Тогда 
		СтруктураКурсаВалюты = ОбщегоНазначения.ПолучитьКурсВалюты(СтруктураНачисленияНалога.ВалютаНоминала, СтруктураНачисленияНалога.ДатаПогашения);
	КонецЕсли;
	
	ДатаНачалаИсключенияНерезидентовИзНачисленияНДФЛНаГособлигации = ОбщегоНазначенияПовтИсп.ЗначениеКонстанты("ДатаНачалаИсключенияНерезидентовИзНачисленияНДФЛНаГособлигации");
	
	Для Каждого СтрокаДанных ИЗ ЦенныеБумагиСписываемые Цикл
		
		ДепонентСтроки			= СтрокаДанных.СчетДепо.Владелец;
		СтрокаДанных.Резидент	= ДанныеФизлиц.ЯвляетсяНалоговымРезидентом(Дата, ДепонентСтроки);
		
		Если СтрокаДанных.НДФЛУдержан Тогда
			Продолжить;
		КонецЕсли;
			
		Если ДепонентСтроки.Субброкер = Истина Тогда
			ДепонентСтроки = Новый Структура("ЮрФизЛицо, УправляющаяКомпания", СтрокаДанных.РазделСчетаДепо.Субклиент.ЮрФизЛицо, Ложь);
		КонецЕсли;
		
		НачислятьНалог 			= Документы.Поручение.ЯвляемсяНалоговымАгентомДляДепонента(ДепонентСтроки,
			СтруктураНачисленияНалога);
		
		НалогооблагаемаяБаза	= СтрокаДанных.Сумма;
		Если НужноНачислитьНДФЛНаЕврооблигацию Тогда 
			НалогооблагаемаяБазаВРуб = ОбщегоНазначения.ПересчитатьИзВалютыВВалюту(НалогооблагаемаяБаза, СтруктураНачисленияНалога.ВалютаНоминала,
				ВалютаРегламентированногоУчета, СтруктураКурсаВалюты.Курс, 1, СтруктураКурсаВалюты.Кратность, 1); 
		Иначе 
			НалогооблагаемаяБазаВРуб = НалогооблагаемаяБаза;
		КонецЕсли;
		Количество = СтрокаДанных.Количество; 
				
		Документы.Поручение.ЗаполнитьСтавкуИСуммуНалогаВСтруктуреНачисления(СтруктураНачисленияНалога,
			СтрокаДанных.Резидент, НалогооблагаемаяБазаВРуб, Количество, СтрокаДанных.СчетДепо, СтрокаДанных.РазделСчетаДепо); 		 		
		Если НачислятьНалог Тогда
			Если Документы.НачисленныйНалог.ИспользоватьРасчетНДФЛПоПрогрессивнойШкале(Дата) Тогда
				ИсключаяСвойства = "СуммаНалога";
			Иначе
				ИсключаяСвойства = Неопределено;
			КонецЕсли;
			ЗаполнитьЗначенияСвойств(СтрокаДанных, СтруктураНачисленияНалога,, ИсключаяСвойства);
			
			Если Не СтрокаДанных.Резидент И Дата >= ДатаНачалаИсключенияНерезидентовИзНачисленияНДФЛНаГособлигации 
				И СтруктураНачисленияНалога.ЭтоГосОблигация Тогда 
				СтрокаДанных.НачислитьНалог = Ложь;
			КонецЕсли;
			
			Если Не НужноНачислитьНДФЛНаЕврооблигацию 
				И Не Документы.НачисленныйНалог.ИспользоватьРасчетНДФЛПоПрогрессивнойШкале(Дата) Тогда 
				СтрокаДанных.СуммаОсвобожденнаяОтНалога = СтрокаДанных.Сумма - НалогооблагаемаяБазаВРуб;
			КонецЕсли;
		Иначе
			ОчиститьНалогиВСтроке(СтрокаДанных);
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

////////////////////////////////////////////////////////////////////////////////
// ПРОЦЕДУРЫ И ФУНКЦИИ ЗАПОЛНЕНИЯ ДИВИДЕНДОВ

Процедура СоздатьНачислениеНалога(ТекущиеДанныеСчетДепо = Неопределено) Экспорт
	
	ТаблицаНалогов = Документы.Поручение.ДанныеДляСозданияДокументовПоНалогам(Ссылка, ТекущиеДанныеСчетДепо);
	
	Если ТекущиеДанныеСчетДепо = Неопределено Тогда
		УдалитьЛишниеНачислениеНалога(ЦенныеБумагиСписываемые.ВыгрузитьКолонку("СчетДепо"));
	КонецЕсли;
	
	МассивНачислений = Новый Массив();
	
	Для Каждого СтрокаНалогов Из ТаблицаНалогов Цикл
		
		Если Не ЗначениеЗаполнено(СтрокаНалогов.СсылкаНаНачисленныйНалог) Тогда
			ДокументНачисленныйНалог = Документы.НачисленныйНалог.СоздатьДокумент();
			ДокументНачисленныйНалог.ОбменДанными.Загрузка = Истина;
			ДокументНачисленныйНалог.Дата = Дата(Лев(Строка(СтрокаНалогов.Дата), 11) + Формат(ТекущаяДатаСеанса(), "ДЛФ=В"));
			ДокументНачисленныйНалог.Записать(РежимЗаписиДокумента.Запись);
			ДокументНачисленныйНалог.ОбменДанными.Загрузка = Ложь;
			ДокументНачисленныйНалог.Заполнить(СтрокаНалогов);
		ИначеЕсли СтрокаНалогов.Перезаполнить Тогда
			ДокументНачисленныйНалог = СтрокаНалогов.СсылкаНаНачисленныйНалог.ПолучитьОбъект();
			ДокументНачисленныйНалог.Подтвержден = Ложь;
			ДокументНачисленныйНалог.Записать(РежимЗаписиДокумента.ОтменаПроведения);
			ДокументНачисленныйНалог.Заполнить(СтрокаНалогов);
		Иначе
			Продолжить;
		КонецЕсли;
		
		ДокументНачисленныйНалог.Записать(РежимЗаписиДокумента.Проведение, РежимПроведенияДокумента.Неоперативный);
		
		МассивНачислений.Добавить(ДокументНачисленныйНалог.Ссылка);
		
	КонецЦикла;
	
	Если ЗначениеЗаполнено(МассивНачислений) Тогда
		СформироватьУведомлениеПоНачислениюНалога(МассивНачислений);
	КонецЕсли;
	
КонецПроцедуры

Процедура УдалитьЛишниеНачислениеНалога(МассивСчетовДепо)
		
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	НачисленныйНалог.Ссылка КАК Ссылка
		|ИЗ
		|	Документ.НачисленныйНалог КАК НачисленныйНалог
		|ГДЕ
		|	НачисленныйНалог.Основание = &Основание
		|	И НЕ НачисленныйНалог.СчетДепо В (&СчетДепо)
		|	И НЕ НачисленныйНалог.Подтвержден";
	
	Запрос.УстановитьПараметр("Основание", Ссылка);
	Запрос.УстановитьПараметр("СчетДепо", МассивСчетовДепо);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		НачисленныйНалогСсылка = ВыборкаДетальныеЗаписи.Ссылка;
		НачисленныйНалогОбъект = НачисленныйНалогСсылка.ПолучитьОбъект();
		НачисленныйНалогОбъект.ПометкаУдаления = Истина;
		НачисленныйНалогОбъект.Записать(РежимЗаписиДокумента.ОтменаПроведения);
	КонецЦикла;
	
КонецПроцедуры

Процедура СформироватьУведомлениеПоНачислениюНалога(МассивНачислений)
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	НачисленныйНалог.Основание КАК Основание,
	|	НачисленныйНалог.Основание.Дата КАК ОснованиеДата,
	|	НачисленныйНалог.Основание.Номер КАК ОснованиеНомер,
	|	НачисленныйНалог.Основание.ПериодНачисления КАК ОснованиеПериодНачисления,
	|	НачисленныйНалог.Номер КАК Номер,
	|	НачисленныйНалог.Дата КАК Дата,
	|	НачисленныйНалог.Депонент.Представление КАК ДепонентПредставление,
	|	НачисленныйНалог.СчетДепо.Владелец.Код КАК ДепонентКод,
	|	НачисленныйНалог.Депонент.ЮрФизЛицо КАК ЮрФизЛицо
	|ИЗ
	|	Документ.НачисленныйНалог КАК НачисленныйНалог
	|ГДЕ
	|	НачисленныйНалог.Ссылка В(&МассивНачислений)
	|ИТОГИ
	|	МИНИМУМ(Основание),
	|	МИНИМУМ(ОснованиеДата),
	|	МИНИМУМ(ОснованиеНомер),
	|	МИНИМУМ(ОснованиеПериодНачисления)
	|ПО
	|	ЮрФизЛицо";
	
	Запрос.УстановитьПараметр("МассивНачислений", МассивНачислений);
	ВыборкаЮрФизЛицо = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	Пока ВыборкаЮрФизЛицо.Следующий() Цикл
		
		Если ВыборкаЮрФизЛицо.ЮрФизЛицо = Перечисления.ЮрФизЛицо.ЮрЛицо Тогда
			ВнешнийИсточник = ПланыВидовХарактеристик.ВнешниеИсточники.РассылкаУведомленийОПодтвержденииНачисленияНалоговЮЛ;
			ВидЮрФизЛица = "ЮЛ";
		ИначеЕсли ВыборкаЮрФизЛицо.ЮрФизЛицо = Перечисления.ЮрФизЛицо.ФизЛицо Тогда
			ВнешнийИсточник = ПланыВидовХарактеристик.ВнешниеИсточники.РассылкаУведомленийОПодтвержденииНачисленияНалоговФЛ;
			ВидЮрФизЛица = "ФЛ";
		Иначе
			ВызватьИсключение "Не удалось определить вид лица депонента!";
		КонецЕсли;
		НастройкиОбмена = ВнешниеДанные.ПолучитьПараметрыВнешнегоИсточника(ВнешнийИсточник).Настройка;
		
		Если Не ЗначениеЗаполнено(НастройкиОбмена) Тогда
			ОписаниеОшибки = "Не заполнены параметры внешнего источника рассылки'" + ВнешнийИсточник + "'";
			ЗаписьЖурналаРегистрации("Поручение клиента. Уведомление по начислению налога",
				УровеньЖурналаРегистрации.Ошибка, , , ОписаниеОшибки);
			Возврат;
		КонецЕсли;
		
		ТипОснования = ТипЗнч(ВыборкаЮрФизЛицо.Основание);
		ОписаниеОснования = Строка(ТипОснования) + " №" + СокрЛП(ВыборкаЮрФизЛицо.ОснованиеНомер) + " от: "
			+ Формат(ВыборкаЮрФизЛицо.ОснованиеДата, "ДФ=dd.MM.yyyy");
		
		ВидВыплаты = ВыборкаЮрФизЛицо.ОснованиеПериодНачисления;
		ТемаПисьма = "Просьба подтвердить налог по выплате для " + ВидЮрФизЛица + " (" + ВидВыплаты + ")";
			
		ТекстПисьма =
			"Уважаемые коллеги,
			|
			|Согласно договоренности направляю вам уведомление на подтверждение исчисленного и подлежащего удержанию НДФЛ по выплате доходов указанного(ых) клиента(ов) в 1С.
			|
			|Обратите внимание, согласно внесенным изменениям в порядок удержания НДФЛ у клиентов и в соответствии с регламентом ДС не могут быть перечислены клиенту(ам) без подтверждения налога (несмотря на отсутствие в поручении «согласия на частичное исполнение»).
			|
			|Во избежание нарушения регуляторных требований (11-7/пз-н) просьба подтвердить сумму налога в течение 2 часов после получения данного уведомления. 
			|
			|На основании " + ОписаниеОснования + " 
			|";
		
		ВыборкаНачисления = ВыборкаЮрФизЛицо.Выбрать();
		
		Пока ВыборкаНачисления.Следующий() Цикл
			ТекстПисьма = ТекстПисьма + "
				|Начисление налога №" + ВыборкаНачисления.Номер + " от: " + ВыборкаНачисления.Дата + "
				|
				|	Клиент: " + ВыборкаНачисления.ДепонентПредставление + "
				|	Договор: " + СокрЛП(ВыборкаНачисления.ДепонентКод) + "
				|";
		КонецЦикла;
		
		ТекстПисьма = ТекстПисьма + Символы.ПС + "Пожалуйста обращайтесь, если возникнут вопросы/уточнения.";
		
		ПараметрыУведомления = Новый Соответствие;
		ПараметрыУведомления.Вставить("НастройкиОбмена"	, НастройкиОбмена);
		ПараметрыУведомления.Вставить("ТемаПисьма"		, ТемаПисьма);
		ПараметрыУведомления.Вставить("ТекстПисьма"		, ТекстПисьма);
		ПараметрыУведомления.Вставить("ТипТекстаПисьма"	, ТипТекстаПочтовогоСообщения.ПростойТекст);
		ПараметрыУведомления.Вставить("Кодировка"		, "UTF-8");
		ПараметрыУведомления.Вставить("Важность"		, ВажностьИнтернетПочтовогоСообщения.Обычная);
		
		РегистрыСведений.УведомленияКОтправке.ДобавитьУведомлениеКотправке(ПараметрыУведомления);
		
	КонецЦикла;
	
КонецПроцедуры

