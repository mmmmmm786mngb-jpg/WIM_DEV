//////////////////////////////////////////////////////////////////////////////// 
// ПЕРЕМЕННЫЕ МОДУЛЯ 

Перем МХ_Константа;
Перем ВалютаРегламентированногоУчета;

//////////////////////////////////////////////////////////////////////////////////
// ОБРАБОТЧИКИ СОБЫТИЙ


Процедура ОбработкаЗаполнения(ДанныеЗаполнения, СтандартнаяОбработка)
	
	Если ДанныеЗаполнения = Неопределено Тогда
		ТипПеревода = Перечисления.ТипыПереводов.Списание;
		Возврат;
	КонецЕсли;
	
КонецПроцедуры

// BSLLS:CognitiveComplexity-off
// BSLLS:CyclomaticComplexity-off

Процедура ОбработкаПроведения(Отказ, Режим)
	
	КонтрольНаВидПорученияИОперации();
	
	ЕстьДопСвойствоОперацияЦБ = ДополнительныеСвойства.Свойство("ОперацияЦБ");
	
	// Проверка "Конвертации" - документы с незаполненными ТЧ конвертаций в зависимости от типа не проводим и ругаемся!
	Если ВидОперацииД = Справочники.ВидыОпераций.Конвертация Тогда
		Если (ТипКонвертации = Перечисления.ТипыКонвертаций.Аннулирование) И (ЦенныеБумагиСписываемые.Количество()=0 ИЛИ Списание.Количество()=0) Тогда
			ОбщегоНазначения.СообщитьОбОшибке("Не верное указано количество списания по операции 'Конвертация - Аннулирование' - проверьте данные табличных частей!", Отказ);
			Возврат;
		ИначеЕсли (ЦенныеБумагиСписываемые.Количество()=0 ИЛИ ЦенныеБумагиЗачисляемые.Количество()=0 ИЛИ Списание.Количество()=0 ИЛИ Зачисление.Количество()=0) И Не (ТипКонвертации = Перечисления.ТипыКонвертаций.Аннулирование) Тогда 
			ОбщегоНазначения.СообщитьОбОшибке("Не верное указано количество по операции 'Конвертация' - проверьте данные табличных частей!", Отказ);
			Возврат;
		КонецЕсли;
	ИначеЕсли ВидОперацииД = Справочники.ВидыОпераций.УчастиеВКД Тогда
		Если НеПроверятьНаличиеКарточкиКД Тогда
			НеобходимыеРеквизиты = "";
		Иначе
			НеобходимыеРеквизиты = "КарточкаКД";
		КонецЕсли;
		РеквизитыШапки = Новый Структура(НеобходимыеРеквизиты);
		Заголовок = ОбщегоНазначения.ПредставлениеДокументаПриПроведении(Ссылка);
		ОбщегоНазначения.ПроверитьЗаполнениеШапкиДокумента(ЭтотОбъект, РеквизитыШапки, Отказ, Заголовок);
	ИначеЕсли ЗначениеЗаполнено(ПаиТипЗаявки) Тогда
		ТекстОшибкиЗаполнения = "";
		Если Не ПройденКонтрольЗаполненияПаи(ПаиТипЗаявки, ТекстОшибкиЗаполнения) Тогда
			ОбщегоНазначения.СообщитьОбОшибке(ТекстОшибкиЗаполнения, Отказ);
			Возврат;
		КонецЕсли;
	КонецЕсли;
	
	Если ВидОперацииД = Справочники.ВидыОпераций.ЗакрытиеРазделаСчетаДепо
		И ТипЗнч(Депонент) = Тип("СправочникСсылка.Контрагенты") Тогда
		// Проверить возможность закрытия раздела счета
		
		// Если ручное проведение пользователем - дополнительно проверить остатки ЦБ
		Если Не ДополнительныеСвойства.Свойство("ЭтоЗакрытиеСчетаДепо") Тогда
			
			ДанныеПоОстаткам = ОстаткиЦБПоРазделамСчетовДепоДокумента();
			Если ДанныеПоОстаткам.ЕстьОстаткиЦБ Тогда 
				
				Для Каждого СтруктОстатки Из ДанныеПоОстаткам.МассивОстатки Цикл 
					Сообщить(	"По закрываемому разделу счета есть не нулевые остатки:
								| - Счет ДЕПО МХ: "+СтруктОстатки.СчетДепоМХ+";
								| - Раздел счета ДЕПО МХ: "+СтруктОстатки.РазделСчетаДепоМХ+";
								| - Счет ДЕПО: "+СтруктОстатки.СчетДепо+";
								| - Раздел счета ДЕПО: "+СтруктОстатки.РазделСчетаДепо+";
								| - Ценная бумага: "+СтруктОстатки.ЦБ+";
								| - Остаток: "+СтруктОстатки.КоличествоОстаток+".");
				КонецЦикла;
				
				Отказ	= Истина;
				Возврат;
				
			КонецЕсли;
			
		КонецЕсли;
		
		Если ЕстьНеисполненныеПорученияПоПассивномуРазделу()Тогда
			Отказ	= Истина;
			Возврат;
		КонецЕсли;
		
	КонецЕсли;
	
	НеобходимРасчетНалога = Документы.НачисленныйНалог.РасчетНалогаРазрешен(ВидОперацииД);
	Если НеобходимРасчетНалога Тогда
		СоздатьНачислениеНалога();
	КонецЕсли;
	
	Если Документы.Поручение.ЭтоИнвентарноеПоручениеСИсполнениемВРежимеЧастичногоИсполнения(Ссылка) Тогда
		
		ПереформироватьОперацииЦБ(Отказ);
	
	ИначеЕсли ЗначениеЗаполнено(ДатаИсполненияПоручения) Тогда
	
		Если Документы.Поручение.ОперацияБлокирована(ЭтотОбъект) Тогда
			ОбщегоНазначения.СообщитьОбОшибке("Инициатор блокирован, внешние операции с ЦБ запрещены!", Отказ);
			Возврат;
		КонецЕсли;				
				
		Если ТипЗнч(ВидОперацииД) = Тип("СправочникСсылка.ВидыОпераций") Тогда
			Если ВидОперацииД = Справочники.ВидыОпераций.ОткрытиеСчетаДепо Тогда
				СоздатьОбновитьДокумент("ОткрытиеСчетаДепо", Отказ);
			ИначеЕсли ВидОперацииД = Справочники.ВидыОпераций.ОткрытиеРазделаСчетаДепо
						И (ТипЗнч(Депонент) = Тип("СправочникСсылка.Контрагенты")
						Или ТипЗнч(Депонент) = Тип("СправочникСсылка.МестаХранения")) Тогда
				СоздатьОбновитьДокумент("ОткрытиеРазделаСчетаДепо", Отказ);
				
				Если ОткрытьВМХ И ТипЗнч(Депонент) = Тип("СправочникСсылка.МестаХранения") Тогда
					ДокОткрытиеРазделаСчетаДепо = ДокументОснование.ПолучитьОбъект();
					ДокОткрытиеРазделаСчетаДепо.ДатаИсполненияПоручения = ДатаИсполненияПоручения;
					ДокОткрытиеРазделаСчетаДепо.РазделСчетаДепоМХ = РазделСчетаДепоМХПоДокументуОснованию(ДокОткрытиеРазделаСчетаДепо);
					Если Не ЗначениеЗаполнено(ДокОткрытиеРазделаСчетаДепо.РазделСчетаДепоМХ) Тогда
						Комментарий = "Не удалось получить Раздел счета депо МХ '" + ДокОткрытиеРазделаСчетаДепо.НомерРазделаСчетаДепоМХ + "'.";
						ЗаписьЖурналаРегистрации("Получение раздела счета депо МХ", УровеньЖурналаРегистрации.Ошибка, 
						Метаданные.Документы.Поручение, Ссылка, Комментарий);
						ОбщегоНазначения.СообщитьОбОшибке(Комментарий, Отказ);
						Возврат;
					КонецЕсли;
					
					Попытка
						ДокОткрытиеРазделаСчетаДепо.Записать(РежимЗаписиДокумента.Проведение);
					Исключение
						ЗаписьЖурналаРегистрации("Проведение Открытия раздела счета депо", УровеньЖурналаРегистрации.Ошибка,,,
												"Не удалось провести поручение на открытие счета депо");
						ИнформацияОбОшибке = ИнформацияОбОшибке();
						ОписаниеОшибки = ПодробноеПредставлениеОшибки(ИнформацияОбОшибке);
						ВызватьИсключение ОписаниеОшибки;
					КонецПопытки;
				КонецЕсли;
			ИначеЕсли ВидОперацииД = Справочники.ВидыОпераций.ЗакрытиеРазделаСчетаДепо
						И (ТипЗнч(Депонент) = Тип("СправочникСсылка.Контрагенты")
						Или ТипЗнч(Депонент) = Тип("СправочникСсылка.МестаХранения")) Тогда
				СоздатьОбновитьДокумент("ЗакрытиеРазделаСчетаДепо", Отказ);
				
				Если ЗакрытьВМХ И ТипЗнч(Депонент) = Тип("СправочникСсылка.МестаХранения") Тогда
					// Если это поручение на закрытие активного раздела
					ДокЗакрытиеРазделаСчетаДепо = ДокументОснование.ПолучитьОбъект();
					ДокЗакрытиеРазделаСчетаДепо.ДатаИсполненияПоручения = ДатаИсполненияПоручения;
					ДокЗакрытиеРазделаСчетаДепо.КодОтчетаНРД = КодОтчетаНРД;
					
					Попытка
						ДокЗакрытиеРазделаСчетаДепо.Записать(РежимЗаписиДокумента.Проведение);
					Исключение
						ЗаписьЖурналаРегистрации("Проведение Закрытия раздела счета депо", УровеньЖурналаРегистрации.Ошибка,,,
												"Не удалось провести поручение на закрытие раздела счета депо");
						ИнформацияОбОшибке = ИнформацияОбОшибке();
						ОписаниеОшибки = ПодробноеПредставлениеОшибки(ИнформацияОбОшибке);
						ВызватьИсключение ОписаниеОшибки;
					КонецПопытки;
				КонецЕсли;
				
				Если ТипЗнч(Депонент) = Тип("СправочникСсылка.Контрагенты") Тогда
					// Если это поручение на закрытие пассивного раздела, то проверяем, что это последний открытый пассивный раздел
					Запрос = Новый Запрос;
					Запрос.Текст = 
						"ВЫБРАТЬ
						|	КОЛИЧЕСТВО(*) КАК КоличествоНезакрытыхРазделов
						|ПОМЕСТИТЬ ВТНезакрытыеРазделы
						|ИЗ
						|	Справочник.РазделыСчетаДепо КАК РазделыСчетаДепо
						|ГДЕ
						|	РазделыСчетаДепо.Владелец = &СчетДепо
						|	И РазделыСчетаДепо.СтатусСчетаДепо = ЗНАЧЕНИЕ(Перечисление.СтатусыСчетовДепо.Открыт)
						|	И РазделыСчетаДепо.Ссылка <> &РазделСчетаДепо
						|;
						|
						|////////////////////////////////////////////////////////////////////////////////
						|ВЫБРАТЬ
						|	Поручение.Ссылка КАК Ссылка
						|ПОМЕСТИТЬ ВТПоручения
						|ИЗ
						|	Документ.Поручение КАК Поручение
						|ГДЕ
						|	Поручение.СчетДепо = &СчетДепо
						|	И Поручение.ВидОперацииД = &ВидОперацииД
						|	И Поручение.Проведен
						|;
						|
						|////////////////////////////////////////////////////////////////////////////////
						|ВЫБРАТЬ ПЕРВЫЕ 1
						|	ВТПоручения.Ссылка КАК Ссылка
						|ИЗ
						|	ВТПоручения КАК ВТПоручения
						|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СтатусыПоручений.СрезПоследних(
						|				&Период,
						|				Поручение В
						|					(ВЫБРАТЬ
						|						ВТПоручения.Ссылка КАК Ссылка
						|					ИЗ
						|						ВТПоручения КАК ВТПоручения)) КАК СтатусыПорученийСрезПоследних
						|		ПО ВТПоручения.Ссылка = СтатусыПорученийСрезПоследних.Поручение
						|			И (СтатусыПорученийСрезПоследних.СтатусПоручения ЕСТЬ NULL
						|				ИЛИ СтатусыПорученийСрезПоследних.СтатусПоручения <> ЗНАЧЕНИЕ(Перечисление.СтатусыПоручений.Исполнено))
						|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТНезакрытыеРазделы КАК ВТНезакрытыеРазделы
						|		ПО (ВТНезакрытыеРазделы.КоличествоНезакрытыхРазделов = 0)
						|
						|УПОРЯДОЧИТЬ ПО
						|	Ссылка УБЫВ
						|АВТОУПОРЯДОЧИВАНИЕ";
					
					Запрос.УстановитьПараметр("ВидОперацииД", Справочники.ВидыОпераций.ЗакрытиеСчетаДепо);
					Запрос.УстановитьПараметр("СчетДепо", СчетДепо);
					Запрос.УстановитьПараметр("Период", Дата);
					Запрос.УстановитьПараметр("РазделСчетаДепо", РазделСчетаДепо);
					
					Выборка = Запрос.Выполнить().Выбрать();
					
					Если Выборка.Следующий() Тогда
						
						ДокЗакрытиеСчетаДепо = Выборка.Ссылка.ПолучитьОбъект();
						ДокЗакрытиеСчетаДепо.ДатаИсполненияПоручения = ТекущаяДата();
						
						Попытка
							ДокЗакрытиеСчетаДепо.Записать(РежимЗаписиДокумента.Проведение);
						Исключение
							ЗаписьЖурналаРегистрации("Проведение Закрытия раздела счета депо", УровеньЖурналаРегистрации.Ошибка,,,
													"Не удалось провести поручение на закрытие раздела счета депо");
							ИнформацияОбОшибке = ИнформацияОбОшибке();
							ОписаниеОшибки = ПодробноеПредставлениеОшибки(ИнформацияОбОшибке);
							ВызватьИсключение ОписаниеОшибки;
						КонецПопытки;
						
					КонецЕсли; 					
					
				КонецЕсли;
			ИначеЕсли ВидОперацииД = Справочники.ВидыОпераций.ЗакрытиеСчетаДепо Тогда
				СоздатьОбновитьДокумент("ЗакрытиеСчетаДепо", Отказ);
			ИначеЕсли ВидОперацииД = Справочники.ВидыОпераций.ОтменаПоручения Тогда
				СоздатьОбновитьДокумент("ОтменаПоручения", Отказ);
				СоздатьДокументРазблокировкиЦБ(Отказ);
			ИначеЕсли ВидОперацииД = Справочники.ВидыОпераций.ОтменаОператораСчетаДепо Тогда
				СоздатьОбновитьДокумент("ОтменаПредставителяСчетаДепо", Отказ);
			ИначеЕсли ВидОперацииД = Справочники.ВидыОпераций.НазначениеОператораСчетаДепо Тогда
				СоздатьОбновитьДокумент("НазначениеПредставителяСчетаДепо", Отказ);
			ИначеЕсли ВидОперацииД = Справочники.ВидыОпераций.Перевод Тогда
				// Документ ОперацияЦБ создается вводом на основании
			ИначеЕсли ВидОперацииД.КлассОпераций = Перечисления.КлассыОпераций.Инвентарные
					Или ВидОперацииД.КлассОпераций = Перечисления.КлассыОпераций.Комплексные Тогда
				// BSLLS:EmptyCodeBlock-off
				Если Документы.Поручение.ЭтоМультиПоручениеП35_2(Ссылка) Тогда
					// Документ ОперацияЦБ создается при загрузке входящего пакета MS035
				ИначеЕсли Документы.Поручение.ЭтоНеторговоеПоручениеСоСпискомЦБ(ЭтотОбъект) Тогда
					Документы.Поручение.СоздатьОбновитьОперацииЦБ(Ссылка, РежимЗаписиДокумента.Проведение, , , КодОтчетаНРД);
				Иначе
					СоздатьОбновитьДокумент("ОперацииЦБ", Отказ);
				КонецЕсли;
				// BSLLS:EmptyCodeBlock-on
			ИначеЕсли ЗначениеЗаполнено(Константы.ДатаНачалаФормированияГО.Получить())
					  И НачалоДня(Дата) >= НачалоДня(Константы.ДатаНачалаФормированияГО.Получить())
					  И (ВидОперацииД = Справочники.ВидыОпераций.НачислениеДоходаПрочие
						ИЛИ ВидОперацииД = Справочники.ВидыОпераций.ВыкупСписаниеЦБ
						ИЛИ ВидОперацииД = Справочники.ВидыОпераций.ПогашениеНКД
						ИЛИ ВидОперацииД = Справочники.ВидыОпераций.Погашение
						ИЛИ ВидОперацииД = Справочники.ВидыОпераций.ПогашениеЦБЧастичное
						ИЛИ ВидОперацииД = Справочники.ВидыОпераций.ПогашениеЦБПолное
						ИЛИ ВидОперацииД = Справочники.ВидыОпераций.СписаниеАкцийПриЛиквидацииЭмитента
						ИЛИ ВидОперацииД = Справочники.ВидыОпераций.СписаниеОбесценившихсяЦенныхБумаг
						ИЛИ ВидОперацииД = Справочники.ВидыОпераций.НачислениеДивидендов
						ИЛИ ВидОперацииД = Справочники.ВидыОпераций.НачислениеДоходаПрочие
						ИЛИ ВидОперацииД = Справочники.ВидыОпераций.Конвертация
						ИЛИ ВидОперацииД = Справочники.ВидыОпераций.НачислениеДоходовЦБ
						ИЛИ ВидОперацииД = Справочники.ВидыОпераций.Выкуп) Тогда
				Если Документы.НачисленныйНалог.ИспользоватьРасчетНДФЛПоПрогрессивнойШкале(Дата)
					И ВидОперацииД.ВыплатаДоходаВДенежнойФорме Тогда
					// Для этого кейса глобальные операции и выписки формируются в документе ПлатежнаяОперация
				Иначе
					Документы.Поручение.СоздатьОбновитьДокументыГО(Ссылка, Отказ, ОбщегоНазначения.ДатаДокумента(Ссылка));
				КонецЕсли;
			ИначеЕсли ВидОперацииД = Справочники.ВидыОпераций.Конвертация Тогда
				СоздатьОбновитьДокумент("КонвертацияЦБ", Отказ);
			ИначеЕсли ВидОперацииД = Справочники.ВидыОпераций.ПогашениеНКД Тогда 
				СоздатьОбновитьДокумент("ПогашениеНКД", Отказ);
			ИначеЕсли ВидОперацииД = Справочники.ВидыОпераций.Погашение
					  ИЛИ ВидОперацииД = Справочники.ВидыОпераций.СписаниеАкцийПриЛиквидацииЭмитента
					  ИЛИ ВидОперацииД = Справочники.ВидыОпераций.СписаниеОбесценившихсяЦенныхБумаг
					  ИЛИ ВидОперацииД = Справочники.ВидыОпераций.ВыкупСписаниеЦБ Тогда 
				СоздатьОбновитьДокумент("ПогашениеЦБ", Отказ);
			ИначеЕсли ВидОперацииД = Справочники.ВидыОпераций.ПогашениеЦБЧастичное Тогда 	
				СоздатьОбновитьДокумент("ПогашениеЦБЧастичное", Отказ);
			ИначеЕсли ВидОперацииД = Справочники.ВидыОпераций.ПогашениеЦБПолное
					  ИЛИ ВидОперацииД = Справочники.ВидыОпераций.Выкуп  Тогда 		
				СоздатьОбновитьДокумент("ПогашениеЦБПолное", Отказ);
			// {{ Новый функционал по задаче ACC-1922
			ИначеЕсли ВидОперацииД = Справочники.ВидыОпераций.ПриемЦБНаОбслуживание
					  ИЛИ ВидОперацииД = Справочники.ВидыОпераций.СнятиеЦБсОбслуживания Тогда 
				СоздатьОбновитьДокумент("ЦенныеБумагиОбслуживание", Отказ);
			ИначеЕсли ВидОперацииД = Справочники.ВидыОпераций.УчастиеВКД Тогда 
				СоздатьОбновитьДокумент("УчастиеВКД", Отказ);
			ИначеЕсли ВидОперацииД = Справочники.ВидыОпераций.ВидОперацииИзменениеАнкетныхДанных() Тогда
				НачалоФормированияЦепочки = Константы.ДатаНачалаФормированияЦепочкиОперацийПоПоручениям.Получить();
				Если Дата >= НачалоФормированияЦепочки И ЗначениеЗаполнено(НачалоФормированияЦепочки) Тогда
					СоздатьОбновитьДокумент("ИзменениеАнкетныхДанных", Отказ);
				КонецЕсли;
			ИначеЕсли ВидОперацииД = Справочники.ВидыОпераций.ИзменениеКатегорииСчетовДепонента И ЗначениеЗаполнено(ДатаИсполненияПоручения) Тогда
				УчетНаСчетахТипаЦ = РегистрыСведений.КлиентыСУчетомНаСчетахТипаC.ЦБКлиентаУчитываютсяНаСчетеТипаС(ДатаИсполненияПоручения, Депонент);
				Если УчетНаСчетахТипаЦ = ИмеетСчетаТипаC Тогда
					ТекстОшибки = "Этот депонент по данным учета " + ?(ИмеетСчетаТипаC, "уже имеет счета", "и так не имеет счетов")
									+ " типа С на дату " + Формат(ДатаИсполненияПоручения, "ДФ=дд.ММ.гггг""");
					ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстОшибки, , , Отказ);
					Возврат;
				Иначе
					СоздатьОбновитьДокумент("ИзменениеКатегорииСчетовДепонента", Отказ);
				КонецЕсли;
			КонецЕсли;
			Если СнятьЦеннуюБумагуСОбслуживания Тогда
				СнятьЦенныеБумагиСОбслуживания(Отказ);
			КонецЕсли;
		ИначеЕсли ТипЗнч(ВидОперацииД) = Тип("ПеречислениеСсылка.ВидыОтчетов") 
					И Не Документы.Поручение.ЭтоПериодическиеВыпискиОСостоянииСчетаДЕПО(ЭтотОбъект) Тогда
			Если ЗначениеЗаполнено(Константы.ДатаНачалаФормированияОперацийПоПоручениямНаОтчет.Получить())
				И НачалоДня(Дата) >= НачалоДня(Константы.ДатаНачалаФормированияОперацийПоПоручениямНаОтчет.Получить()) Тогда
				СоздатьОбновитьДокумент("ФормированиеОтчетаВыписки", Отказ);
			Иначе
				СоздатьОбновитьДокумент("Выписка", Отказ);
			КонецЕсли;
		КонецЕсли;
	Иначе
		Если Не ЕстьДопСвойствоОперацияЦБ И Не ЭтоВыплатаДоходаПоПрогрессивнойШкалеНДФЛ() Тогда
			УдалятьПодчиненныеПоручения = Ложь;
			Если Не Документы.Поручение.ЭтоПериодическиеВыпискиОСостоянииСчетаДЕПО(ЭтотОбъект) Тогда
				Документы.Поручение.УдалитьДокументыНаОснованииПоручения(Ссылка, УдалятьПодчиненныеПоручения);
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	Если Проведен И ОткрытьВМХ 
		И ВидОперацииД = Справочники.ВидыОпераций.ОткрытиеРазделаСчетаДепо
		И ТипЗнч(Депонент) = Тип("СправочникСсылка.Контрагенты") Тогда
		
		СформироватьПоручениеНаОткрытиеРазделаСчетаМХ(Отказ);
	КонецЕсли;
	
	Если Проведен И ЗакрытьВМХ 
		И ВидОперацииД = Справочники.ВидыОпераций.ЗакрытиеРазделаСчетаДепо
		И ТипЗнч(Депонент) = Тип("СправочникСсылка.Контрагенты") Тогда
		
		СформироватьПоручениеНаЗакрытиеРазделаСчетаМХ(Отказ);
	КонецЕсли;
	
	Если Проведен И ВидОперацииД = Справочники.ВидыОпераций.ЗакрытиеСчетаДепо Тогда
		СформироватьПорученияНаЗакрытиеРазделовСчета(Отказ);
	КонецЕсли;
	
	Если ДополнительныеСвойства.Свойство("НеобходимоФормироватьУведомлениеОИсполненииОперацийСЦБ") Тогда
		Если ДополнительныеСвойства.НеобходимоФормироватьУведомлениеОИсполненииОперацийСЦБ Тогда
			ДобавитьЗаписьВРССостоянияУведомленийОбОперацияхСЦБ();
		КонецЕсли;
	КонецЕсли;
	
	Если ВидОперацииД = Справочники.ВидыОпераций.Перевод И ЗначениеЗаполнено(ДатаИсполненияПоручения)
		И Не ЕстьДопСвойствоОперацияЦБ Тогда
		
		ВстречноеПоручение = Документы.Поручение.ВстречноеПоручениеПеревод(Ссылка);
		Если Не ЗначениеЗаполнено(ВстречноеПоручение) Тогда 
			ОбщегоНазначения.СообщитьОбОшибке("Не найдено или не проведено встречное поручение для " + Ссылка, Отказ);
			Возврат;
		КонецЕсли;
		
		ОперацияЦБСсылка = СвязаннаяОперацияЦБ();
		Если ОперацияЦБСсылка.Проведен Тогда 
			ОбщегоНазначения.СообщитьОбОшибке("Для данного поручения уже проведена операция с ценными бумагами " + ОперацияЦБСсылка + " отмените ее проведение перед изменением этого поручения.", Отказ);
			Возврат;
		КонецЕсли;
		
		ОперацияЦБ = ОперацияЦБСсылка.ПолучитьОбъект();
		Если ОперацияЦБ <> Неопределено Или КодОтчетаНРД <> "" Тогда
			ВстречноеПоручениеОбъект = ВстречноеПоручение.ПолучитьОбъект();
			ВстречноеПоручениеОбъект.ДополнительныеСвойства.Вставить("ОперацияЦБ",ОперацияЦБСсылка);
			ВстречноеПоручениеОбъект.КодОтчетаНРД = КодОтчетаНРД;
			ВстречноеПоручениеОбъект.Записать(РежимЗаписиДокумента.Проведение);
		КонецЕсли;
		
		Если ОперацияЦБ = Неопределено Тогда 
			ОперацияЦБ = Документы.ОперацииЦБ.СоздатьДокумент();
			ОперацияЦБ.УстановитьСсылкуНового(ОперацияЦБСсылка);
		КонецЕсли;
		
		Если Инициатор = Депонент ИЛИ ТипПеревода = Перечисления.ТипыПереводов.Списание Тогда
			ОперацияЦБ.ЗаполнитьОперациюНаОснованииПорученияИСвязатьПоручения(Ссылка);
		Иначе 
			ОперацияЦБ.ЗаполнитьОперациюНаОснованииПорученияИСвязатьПоручения(ВстречноеПоручение);
		КонецЕсли;
		
		НеобходимоНачислятьКомиссиюСтароеЗначение = РегистрыСведений.ДокументыКНачислениюКомиссииДепо.НеобходимоНачислитьКомиссию(Ссылка);
		ПровестиОперациюЦБ = (СчетДепоМХ = СчетДепоМХКонтрагента И РазделСчетаДепоМХ = РазделСчетаДепоМХКонтрагента)
			ИЛИ (ДатаИсполненияПоручения <> Дата(1, 1, 1)
				И ДатаИсполненияПорученияВДепозитарииМХ <> Дата(1, 1, 1)
				И ДатаИсполненияПорученияВМестеРасчетов <> Дата(1, 1, 1));
		Если ДополнительныеСвойства.Свойство("ПереводЦБПоМежклиентскойСделкеПоДаннымКафка") Тогда
			ОперацияЦБ.Дата = КонецДня(ТекущаяДатаСеанса());
			ОперацияЦБ.ДатаИсполненияВДепозитарииМХ = ОперацияЦБ.Дата;
			ОперацияЦБ.ДатаИсполненияВМестеРасчетов = ОперацияЦБ.Дата;
			ОперацияЦБ.Записать(РежимЗаписиДокумента.Запись);
		ИначеЕсли ПровестиОперациюЦБ Тогда
			ОперацияЦБ.Записать(РежимЗаписиДокумента.Проведение);
		Иначе
			ОперацияЦБ.Записать(РежимЗаписиДокумента.Запись);
		КонецЕсли;
		ДополнительныеСвойства.Вставить("ОперацияЦБ", ОперацияЦБ.Ссылка);
		НеобходимоНачислятьКомиссиюНовоеЗначение = РегистрыСведений.ДокументыКНачислениюКомиссииДепо.НеобходимоНачислитьКомиссию(Ссылка);
		Если НеобходимоНачислятьКомиссиюНовоеЗначение <> НеобходимоНачислятьКомиссиюСтароеЗначение Тогда
			ДополнительныеСвойства.Вставить("ФлагНачислитьКомиссиюДепоИзмененАвтоматически", Истина);
		КонецЕсли;
		
	КонецЕсли;

	СформироватьДвижениеПоСтатусуПоручения(Отказ);
	
	ОтключитьЗаполнениеПризнакаНачислитьКомиссию = ДополнительныеСвойства.Свойство("ВведеноИнтерактивно")
		И ДополнительныеСвойства.ВведеноИнтерактивно = Истина;
	
	Если Не ОтключитьЗаполнениеПризнакаНачислитьКомиссию
		И НеобходимоИзменитьПризнакНачислитьКомиссиюДепоПриИсполнении() Тогда
		НачислитьКомиссиюДепо = ЗначениеЗаполнено(ДатаИсполненияПоручения);
		РегистрыСведений.ДокументыКНачислениюКомиссииДепо.УстановитьЗначение(Ссылка, НачислитьКомиссиюДепо);
	КонецЕсли;
	
	СформироватьДвиженияПоРегиструДенежныхСредств();
	
	ОбменДаннымиКафка.ЗаписатьОбъектВИсходящиеСообщенияКафкаПриЗаписиДокумента(ЭтотОбъект);
	
КонецПроцедуры

