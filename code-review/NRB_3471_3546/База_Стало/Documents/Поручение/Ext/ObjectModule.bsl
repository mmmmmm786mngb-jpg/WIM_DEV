				ПараметрВебСервиса.accrualAmount 	= СтрокаКупон.СуммаКВыплатеПоИПД + СтрокаКупон.СуммаНалога;
				ПараметрВебСервиса.taxCurrency 		= Валюта.НаименованиеДляОтчетов;
				ПараметрВебСервиса.incomeAmount 	= СтрокаКупон.СуммаКВыплатеПоИПД;
			Иначе
				ПараметрВебСервиса.rateSize 		= ?(СтрокаКупон.Количество = 0, 0, СтрокаКупон.Сумма / СтрокаКупон.Количество);
				ПараметрВебСервиса.accrualAmount 	= СтрокаКупон.Сумма;
				ПараметрВебСервиса.taxCurrency 		= РегламентнаяВалюта.НаименованиеДляОтчетов;
				ПараметрВебСервиса.incomeAmount 	= СуммаБезНалога;
			КонецЕсли;
			Если ВебСервисДоступен Тогда
				РезультатВызова = Прокси.SendEmailAboutBondsCouponPayment(ПараметрВебСервиса);
			КонецЕсли;
		КонецЦикла;
	ИначеЕсли ВидОперацииД = Справочники.ВидыОпераций.НачислениеДивидендов Или ВидОперацииД = Справочники.ВидыОпераций.НачислениеДоходаПрочие Тогда
		ПараметрВебСервиса = НовыйПараметрВебСервиса(Прокси, "SendEmailAboutDividend1");
		Если ЦБ.ТипЦБ = Перечисления.ТипыЦБ.Акция Или ЦБ.ТипЦБ = Перечисления.ТипыЦБ.Облигация Тогда
			securityName = Строка(ЦБ.Эмитент) + " / " + ?(ЦБ.ВидЦБ = Перечисления.ВидыАкций.Обыкновенная, "АО", "АП") + " / ";
		Иначе
			securityName = Строка(ЦБ);
		КонецЕсли;
		Для Каждого СтрокаДивиденд Из ЦенныеБумагиСписываемые Цикл
			СуммаБезНалога = СтрокаДивиденд.Сумма - ?(СтрокаДивиденд.НачислитьНалог И (Валюта = РегламентнаяВалюта), СтрокаДивиденд.СуммаНалога, 0);
			ДанныеСчетаДепо = ВладельцыСчетовДепо.Найти(СтрокаДивиденд.СчетДепо);
			ПараметрВебСервиса.accrualCurrency 	= СокрП(Валюта.НаименованиеДляОтчетов);
			ПараметрВебСервиса.clientId 		= ?(ДанныеСчетаДепо = Неопределено, "", СокрЛП(ДанныеСчетаДепо.КодВладельца));
			ПараметрВебСервиса.d1 				= КоэффициентД1;
			ПараметрВебСервиса.d2 				= КоэффициентД2;
			ПараметрВебСервиса.dateCutOff 		= ДатаФиксации;
			ПараметрВебСервиса.gosRegNumber 	= ЦБ.НомерРегистрации;
			ПараметрВебСервиса.incomeCurrency 	= Валюта.НаименованиеДляОтчетов;
			ПараметрВебСервиса.isin 			= ЦБ.ISIN;
			ПараметрВебСервиса.quantity 		= СтрокаДивиденд.Количество;
			ПараметрВебСервиса.rateCurrency 	= Валюта.НаименованиеДляОтчетов;
			ПараметрВебСервиса.securityName 	= securityName;			
			ПараметрВебСервиса.taxAmount 		= СтрокаДивиденд.СуммаНалога;
			Если ЭтоИностраннаяЦБ Тогда
				ПараметрВебСервиса.accrualAmount 	= СтрокаДивиденд.СуммаКВыплатеПоИПД + СтрокаДивиденд.СуммаНалога;
				ПараметрВебСервиса.incomeAmount 	= СтрокаДивиденд.СуммаКВыплатеПоИПД;
				ПараметрВебСервиса.rateSize 		= ВыплатаНа1ЦБ;
				ПараметрВебСервиса.taxCurrency 		= Валюта.НаименованиеДляОтчетов;
			Иначе
				ПараметрВебСервиса.accrualAmount 	= СтрокаДивиденд.Сумма;
				ПараметрВебСервиса.incomeAmount 	= СуммаБезНалога;
				ПараметрВебСервиса.rateSize 		= ?(СтрокаДивиденд.Количество = 0, 0 , СтрокаДивиденд.Сумма / СтрокаДивиденд.Количество);
				ПараметрВебСервиса.taxCurrency 		= РегламентнаяВалюта.НаименованиеДляОтчетов;
			КонецЕсли;
			Если ВебСервисДоступен Тогда
				Прокси.SendEmailAboutDividend1(ПараметрВебСервиса);
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	ЗаписьЖурналаРегистрации("Уведомления СУДК", УровеньЖурналаРегистрации.Информация, , , "Отправлено уведомление по "+Ссылка);
	Если ВебСервисДоступен Тогда
		УведомлениеСУДКОтправлено = Истина;
		ОбменДанными.Загрузка = Истина;
		Записать();
	Иначе
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Симуляция отправки уведомления СУДК прошла успешно.");
	КонецЕсли;
	
КонецПроцедуры

Функция ВладельцыСчетовДепо(СчетаДепо, Дата)
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	СчетаДепо.Ссылка КАК СчетДепо,
	|	СчетаДепо.Владелец КАК Владелец,
	|	КодыЗагрузки.Код КАК КодВладельца
	|ИЗ
	|	Справочник.СчетаДепо КАК СчетаДепо
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.КодыЗагрузки КАК КодыЗагрузки
	|		ПО СчетаДепо.Владелец = КодыЗагрузки.Владелец
	|			И (КодыЗагрузки.Биржа = &Клиенты)
	|			И (КодыЗагрузки.ДатаОкончанияДействия = ДАТАВРЕМЯ(1, 1, 1)
	|				ИЛИ КодыЗагрузки.ДатаОкончанияДействия > &Дата)
	|			И (ЛОЖЬ = КодыЗагрузки.ПометкаУдаления)
	|ГДЕ
	|	СчетаДепо.Ссылка В(&СчетаДепо)");
	Запрос.УстановитьПараметр("Клиенты", Справочники.КлассификаторыЗагрузки.Клиенты);
	Запрос.УстановитьПараметр("СчетаДепо", СчетаДепо);
	Запрос.УстановитьПараметр("Дата", Дата);
	РезультатЗапроса = Запрос.Выполнить();
	Возврат РезультатЗапроса.Выгрузить();
КонецФункции

Функция НовыйПараметрВебСервиса(Прокси, ИмяФункции)
	Если Прокси = Неопределено Тогда
		Возврат Новый Структура("accrualAmount,accrualCurrency,bondsPaymentType,clientId,d1,d2,dateCutOff,gosRegNumber,incomeAmount,incomeCurrency,isin,quantity,rateCurrency,rateSize,securityName,taxAmount,taxCurrency");
	КонецЕсли;
	Фабрика = Прокси.ФабрикаXDTO;
	ПространствоИмен = Прокси.ТочкаПодключения.Интерфейс.URIПространстваИмен;
	ТипПараметраВебСервиса = Фабрика.Тип(ПространствоИмен, ИмяФункции);
	ПараметрВебСервиса = Фабрика.Создать(ТипПараметраВебСервиса);
	Возврат ПараметрВебСервиса;
КонецФункции

Функция ВидПоручения()
	
	Если ВидОперацииД = Справочники.ВидыОпераций.ПереводМеждуРазделамиСчетаДепо Тогда
		Возврат Справочники.ВидыИнвентарныхПоручений.П20;
	ИначеЕсли ВидОперацииД = Справочники.ВидыОпераций.Перемещение Тогда
		Возврат Справочники.ВидыИнвентарныхПоручений.П10;
	ИначеЕсли ВидОперацииД = Справочники.ВидыОпераций.ОткрытиеРазделаСчетаДепо Тогда
		Возврат Справочники.ВидыИнвентарныхПоручений.П90;
	ИначеЕсли ВидОперацииД = Справочники.ВидыОпераций.ЗакрытиеРазделаСчетаДепо Тогда
		Возврат Справочники.ВидыИнвентарныхПоручений.П91;
	Иначе
		Если ВидОперацииД = Справочники.ВидыОпераций.Депонирование
			Или ВидОперацииД = Справочники.ВидыОпераций.СнятиеСДепонирования Тогда
			
			ЭтоПоручениеПоПаям = ЭтоПоручениеПоПаям();
			ЮрФизЛицоДепонентаКонтрагентаОдинаково = ЮрФизЛицоДепонентаКонтрагентаОдинаково();
			
			Если ВидОперацииД = Справочники.ВидыОпераций.Депонирование И ЮрФизЛицоДепонентаКонтрагентаОдинаково Тогда
				Возврат Справочники.ВидыИнвентарныхПоручений.П35;
			ИначеЕсли ВидОперацииД = Справочники.ВидыОпераций.СнятиеСДепонирования И ЮрФизЛицоДепонентаКонтрагентаОдинаково Тогда
				Возврат Справочники.ВидыИнвентарныхПоручений.П36_Реестр;
			ИначеЕсли ВидОперацииД = Справочники.ВидыОпераций.Депонирование И ЭтоПоручениеПоПаям Тогда
				Возврат Справочники.ВидыИнвентарныхПоручений.П35_2;
			ИначеЕсли ВидОперацииД = Справочники.ВидыОпераций.СнятиеСДепонирования И ЭтоПоручениеПоПаям Тогда
				Возврат Справочники.ВидыИнвентарныхПоручений.П36_2;
			КонецЕсли;
		КонецЕсли;
		
		Если СчетДепоКонтрагента.ПризнакСчетаДепо = Перечисления.ПризнакиСчетаДепо.СчетКонтрагента ИЛИ СчетДепоКонтрагента = Справочники.СчетаДепо.ПустаяСсылка() Тогда
			Если МХКонтрагент = Константы.МестоХраненияПоУмолчанию.Получить() Тогда
				Если ВидОперацииД = Справочники.ВидыОпераций.СнятиеСДепонирования Тогда
					Если СуммаСделки = 0 И ЦенныеБумагиСписываемые.Итог("Сумма") = 0 Тогда
						Возврат Справочники.ВидыИнвентарныхПоручений.П16;
					Иначе
						Возврат Справочники.ВидыИнвентарныхПоручений.П19_0;
					КонецЕсли;
				ИначеЕсли ВидОперацииД = Справочники.ВидыОпераций.Депонирование Тогда
					Если СуммаСделки = 0 И ЦенныеБумагиСписываемые.Итог("Сумма") = 0 Тогда
						Возврат Справочники.ВидыИнвентарныхПоручений.П16_1;
					Иначе
						Возврат Справочники.ВидыИнвентарныхПоручений.П19_1;
					КонецЕсли;
				КонецЕсли;
			Иначе
				Если ВидОперацииД = Справочники.ВидыОпераций.СнятиеСДепонирования Тогда
					Возврат Справочники.ВидыИнвентарныхПоручений.П36;
				ИначеЕсли ВидОперацииД = Справочники.ВидыОпераций.Депонирование Тогда
					Возврат Справочники.ВидыИнвентарныхПоручений.П37;
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	Возврат Справочники.ВидыИнвентарныхПоручений.ПустаяСсылка();
КонецФункции // ВидПоручения()

Процедура ДобавитьЗаписьВРССостоянияУведомленийОбОперацияхСЦБ()
	
	Запись = РегистрыСведений.СостоянияУведомленийОбОперацияхСЦБ.СоздатьМенеджерЗаписи();
	Запись.Поручение = Ссылка;
	Запись.Подготовлено = Ложь;
	Запись.Записать();

КонецПроцедуры

Процедура УдалитьЗаписьИзРССостоянияУведомленийОбОперацияхСЦБ()
	
	НаборЗаписей = РегистрыСведений.СостоянияУведомленийОбОперацияхСЦБ.СоздатьНаборЗаписей();
	НаборЗаписей.Отбор.Поручение.Установить(Ссылка);
	НаборЗаписей.Прочитать();
	Если НаборЗаписей.Количество() > 0 Тогда
		НаборЗаписей.Очистить();
		НаборЗаписей.Записать();
	КонецЕсли;
	
КонецПроцедуры

Функция ЭтоВыплатаДоходаПоПрогрессивнойШкалеНДФЛ()
	Возврат ТипЗнч(ВидОперацииД) = Тип("СправочникСсылка.ВидыОпераций")
		И ВидОперацииД.ВыплатаДоходаВДенежнойФорме
		И Документы.НачисленныйНалог.ИспользоватьРасчетНДФЛПоПрогрессивнойШкале(Дата);
КонецФункции

// Возвращает необходимость изменения признака "Начислить комиссию депо" при исполнении или отмене исполнения
//   поручений с видами Отмена и УчастиеВКД
// 
// Возвращаемое значение:
//  Булево - признак необходимости изменения НачислитьКомиссиюДепо
//
Функция НеобходимоИзменитьПризнакНачислитьКомиссиюДепоПриИсполнении() Экспорт
	
	ОрганизацияПоУмолчанию = ОбщегоНазначенияПовтИсп.ОрганизацияПоУмолчанию();
	МестоХраненияПоУмолчанию = ОбщегоНазначенияПовтИсп.ЗначениеКонстанты("МестоХраненияПоУмолчанию");
	
	Возврат Инициатор <> ОрганизацияПоУмолчанию
		И Инициатор <> МестоХраненияПоУмолчанию
		И (ВидОперацииД = Справочники.ВидыОпераций.УчастиеВКД
		Или ВидОперацииД = Справочники.ВидыОпераций.ОтменаПоручения);
	
КонецФункции

Функция ЮрФизЛицоДепонентаКонтрагентаОдинаково()
	
	Если ЗначениеЗаполнено(Депонент) И ТипЗнч(Депонент) = Тип("СправочникСсылка.Контрагенты")
		И ЗначениеЗаполнено(Контрагент) Тогда
		
		ДепонентЮрФизЛицо = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Депонент, "ЮридическиеФизическиеЛица");
		КонтрагентЮрФизЛицо = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Контрагент, "ЮридическиеФизическиеЛица");
		
		Результат = ЗначениеЗаполнено(ДепонентЮрФизЛицо)
			И ЗначениеЗаполнено(КонтрагентЮрФизЛицо) И (ДепонентЮрФизЛицо = КонтрагентЮрФизЛицо);
	Иначе
		Результат = Ложь;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Процедура ПроверитьНеобходимостьНачисленияНалога(Строка)
	
	РеквизитыДепонента = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Строка.СчетДепо, Новый Структура("ЮрФизЛицо", "Владелец.ЮрФизЛицо"));
	ВалютаПоручения = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(БанковскийСчет, "ВалютаДенежныхСредств");
	ДепонентЮрЛицо = РеквизитыДепонента.ЮрФизЛицо = Перечисления.ЮрФизЛицо.ЮрЛицо;
	ОчиститьНалог =
		ЗначениеЗаполнено(ВалютаПоручения) И ВалютаПоручения <> ОбщегоНазначенияПовтИсп.ЗначениеКонстанты("ВалютаРегламентированногоУчета")
		И (Не Строка.Резидент Или ДепонентЮрЛицо);
	Если Не ОчиститьНалог И ВидОперацииД = Справочники.ВидыОпераций.ПогашениеНКД И ЗначениеЗаполнено(Строка.БанковскийСчет) Тогда
		Если Не Строка.Резидент И ДепонентЮрЛицо Тогда
			Возврат;
		КонецЕсли;
		ТипыБрокерскихБанковскихСчетов = Новый СписокЗначений;
		ТипыБрокерскихБанковскихСчетов.Добавить(Перечисления.ТипыНазначенияБанковскихСчетов.Брокерский);
		ТипыБрокерскихБанковскихСчетов.Добавить(Перечисления.ТипыНазначенияБанковскихСчетов.БрокерскийТранзит);
		ТипНазначения = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Строка.БанковскийСчет, "ТипНазначения");
		Если ТипыБрокерскихБанковскихСчетов.НайтиПоЗначению(ТипНазначения) <> Неопределено Тогда
			ОчиститьНалог = Истина;
		КонецЕсли;
	КонецЕсли;
	Если ОчиститьНалог Тогда
		ОчиститьНалогиВСтроке(Строка);
	КонецЕсли;
	
КонецПроцедуры

Функция НайденБанковскийСчетИзСчетовДляВыплатыДоходов(ТекущийДепонент, Строка, СчетаДляВыплатыДоходов)
	
	НайденБанковскийСчет = Ложь;
	
	Если ВидОперацииД.ВыплатаДоходаВДенежнойФорме Тогда
		
		ТекущийСчетДляВыплатыДоходов = СчетаДляВыплатыДоходов.Найти(ТекущийДепонент, "Депонент");
		Если ТекущийСчетДляВыплатыДоходов <> Неопределено Тогда
			Строка.БанковскийСчет = ТекущийСчетДляВыплатыДоходов.БанковскийСчет;
			НайденБанковскийСчет = Истина;
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат НайденБанковскийСчет;
	
КонецФункции

Функция НайденБанковскийСчетИзРасчетныхКодовДляВыплатыДоходовКлиентам(ТекущийДепонент, Строка, РасчетныеКодыДляВыплатыДоходов)
	
	НайденБанковскийСчет = Ложь;
	
	ТекущийРасчетныйКод = РасчетныеКодыДляВыплатыДоходов.Найти(ТекущийДепонент, "Депонент");
	Если ТекущийРасчетныйКод <> Неопределено Тогда
		Строка.БанковскийСчет = ТекущийРасчетныйКод.РасчетныйКод;
		НайденБанковскийСчет = Истина;
	КонецЕсли;
	
	Возврат НайденБанковскийСчет;
	
КонецФункции

Функция НайденБанковскийСчетИзБрокерскихСчетов(ТекущийДепонент, Строка, БрокерскиеСчета)
	
	НайденБанковскийСчет = Ложь;
	
	ИмяРеквизитаДепонент = "Депонент";
	ТекущийБС = БрокерскиеСчета.БС.Найти(ТекущийДепонент, ИмяРеквизитаДепонент);
	Если ТекущийБС <> Неопределено Тогда
		Строка.БанковскийСчет = ТекущийБС.БанковскийСчет;
		НайденБанковскийСчет = Истина;
	Иначе
		// Продолжим поиск в БС по пустому депоненту с правом для текущего депонента
		Права = БрокерскиеСчета.Права.Найти(ТекущийДепонент, ИмяРеквизитаДепонент);
		Если Права <> Неопределено Тогда
			ПравоИспользованияДС = Права.ПравоПредоставлено;
		Иначе
			ПравоИспользованияДС = Ложь;
		КонецЕсли;
		
		Отбор = Новый Структура;
		Отбор.Вставить(ИмяРеквизитаДепонент,	Справочники.Контрагенты.ПустаяСсылка());
		Отбор.Вставить("ИспользованиеДС",		ПравоИспользованияДС);
		СтрокиБС = БрокерскиеСчета.БС.НайтиСтроки(Отбор);
		Если СтрокиБС.Количество() > 0 Тогда
			Строка.БанковскийСчет = СтрокиБС[0].БанковскийСчет;
			НайденБанковскийСчет = Истина;
		КонецЕсли;
	КонецЕсли;
	
	Возврат НайденБанковскийСчет;
	
КонецФункции

Процедура ОчиститьНалогиВСтроке(СтрокаДанных)
	
	СтрокаДанных.НачислитьНалог 			= Ложь;
	СтрокаДанных.СуммаОсвобожденнаяОтНалога = 0;
	СтрокаДанных.СтавкаНалога				= 0;
	СтрокаДанных.СуммаНалога				= 0;
	СтрокаДанных.СтатьиНКРФСоглашения		= "";
	
КонецПроцедуры

Функция ЭтоПоручениеПоПаям()
	Если Не ЗначениеЗаполнено(ПаиТипЗаявки) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Если Документы.Поручение.ЭтоНеторговоеПоручениеСоСпискомЦБ(ЭтотОбъект) И ЦенныеБумагиСписываемые.Количество() > 0 Тогда
		ТипЦБ = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ЦенныеБумагиСписываемые[0].ЦеннаяБумага, "ТипЦБ");
	Иначе
		ТипЦБ = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ЦБ, "ТипЦБ");
	КонецЕсли;
	
	Возврат ТипЦБ = Перечисления.ТипыЦБ.Пай;
КонецФункции

Функция ПройденКонтрольЗаполненияПаи(ПаиТипЗаявки, ТекстОшибкиЗаполнения)
	
	Если ПаиТипЗаявки = Перечисления.ПаиТипыЗаявок.REDEMPTION Тогда
		ПройденКонтроль = ЦенныеБумагиСписываемые.Итог("Количество") > 0;
		ТекстОшибкиЗаполнения = ?(ПройденКонтроль, "", "Не указано количество!");
	ИначеЕсли ПаиТипЗаявки = Перечисления.ПаиТипыЗаявок.SINGLE_BUY Или ПаиТипЗаявки = Перечисления.ПаиТипыЗаявок.MULTI_BUY Тогда
		ПройденКонтроль = ЦенныеБумагиСписываемые.Итог("Сумма") > 0;
		ТекстОшибкиЗаполнения = ?(ПройденКонтроль, "", "Не указана сумма!");
	Иначе
		ТекстОшибкиЗаполнения = "";
		ПройденКонтроль = Истина;
	КонецЕсли;
	
	Возврат ПройденКонтроль;
	
КонецФункции

Процедура КонтрольНаВидПорученияИОперации()
	ИмяПараметра = ИмяПараметраКонтроляПоВидуОперации(ВидОперацииД);
	Если ИмяПараметра <> Неопределено Тогда
		КодыВидовПорученийСтрокой = РегистрыСведений.ПараметрыГлобальные.ЗначениеПараметра(ИмяПараметра, "");
		КодыВидовПоручений = СтрРазделить(КодыВидовПорученийСтрокой, ",");
		КодВидаПоручения = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ВидПоручения, "Код");
		Если КодыВидовПоручений.Найти(КодВидаПоручения) = Неопределено Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Вид поручения не соответствует виду операции!", ЭтотОбъект, "ВидПоручения");
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

Функция ИмяПараметраКонтроляПоВидуОперации(ВидОперации)
	ПараметрыКонтроляПоВидуПоручения = Новый Соответствие;
	ПараметрыКонтроляПоВидуПоручения.Вставить(Справочники.ВидыОпераций.Депонирование,
		"1365.КонтрольПорученийНаВидПорученияИОперации.ЗачислениеЦБ");
	ПараметрыКонтроляПоВидуПоручения.Вставить(Справочники.ВидыОпераций.СнятиеСДепонирования,
		"1365.КонтрольПорученийНаВидПорученияИОперации.СписаниеЦБ");
	Возврат ПараметрыКонтроляПоВидуПоручения[ВидОперации];
КонецФункции

Функция РазделСчетаДепоМХПоДокументуОснованию(ДокОткрытиеРазделаСчетаДепо)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	РазделыСчетаДепоМХ.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.РазделыСчетаДепоМХ КАК РазделыСчетаДепоМХ
	|ГДЕ
	|	РазделыСчетаДепоМХ.Код = &Код
	|	И РазделыСчетаДепоМХ.Владелец = &Владелец
	|	И РазделыСчетаДепоМХ.ТипРазделаСчетаДЕПО = &ТипРаздела
	|	И РазделыСчетаДепоМХ.СтатусСчетаДепо = ЗНАЧЕНИЕ(Перечисление.СтатусыСчетовДепо.Открыт)";
	
	Запрос.УстановитьПараметр("Код", ДокОткрытиеРазделаСчетаДепо.НомерРазделаСчетаДепоМХ);
	Запрос.УстановитьПараметр("Владелец", ДокОткрытиеРазделаСчетаДепо.СчетДепоМХ);
	Запрос.УстановитьПараметр("ТипРаздела", ДокОткрытиеРазделаСчетаДепо.ТипРазделаСчетаДЕПО);
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда 
		Результат = Выборка.Ссылка;
	Иначе 
		Результат = Справочники.РазделыСчетаДепоМХ.ПустаяСсылка();
	КонецЕсли;
	Возврат Результат; 
	
КонецФункции

Функция СвязаннаяОперацияЦБ()
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	ОперацииЦБ.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.ОперацииЦБ КАК ОперацииЦБ
	|ГДЕ
	|	(ОперацииЦБ.ДокументОснование = &ДокументОснование
	|			ИЛИ ОперацииЦБ.ДокументОснованиеВстречный = &ДокументОснование)
	|	");
	
	Запрос.УстановитьПараметр("ДокументОснование",Ссылка);
	Результат = Запрос.Выполнить();
	Если Результат.Пустой() Тогда
		Возврат Документы.ОперацииЦБ.ПолучитьСсылку();
	Иначе
		Выборка = Результат.Выбрать();
		Выборка.Следующий();
		Возврат Выборка.Ссылка;
	КонецЕсли;
	
КонецФункции

Процедура ЗаполнитьОчиститьУИН()
	Если Документы.Поручение.ТребуетсяУИН(ВидОперацииД, ВидПоручения, РазделСчетаДепо) Тогда
		ИННОрганизации = Константы.ОрганизацияПоУмолчанию.Получить().ИНН;
		ИсточникИНН = "";
		ИННКонтрагента = ИННКонтрагента(ИсточникИНН);
		ДатаПоручения = Формат(Дата, "ДФ=""ддММгггг""");
		НомерПоручения = СтроковыеФункцииКлиентСервер.ДополнитьСтроку(Номер, 18, "0", "Слева");
		УИН = "1" + СокрЛП(ИННОрганизации) + ИННКонтрагента + ДатаПоручения + НомерПоручения;
		ДлинаУИН = СтрДлина(УИН);
		СтандартнаяДлинаУИН = 47;
		ДлинаИННЮрЛиц = 10;
		Если ДлинаУИН <> СтандартнаяДлинаУИН Тогда
			ТекстСообщения = "Длина УИН не равна ожидавшимся " + Строка(СтандартнаяДлинаУИН) + " символам (" + Строка(ДлинаУИН) + ")!";
			Если Не ЗначениеЗаполнено(Контрагент) Тогда
				Причина = "в поручении не указан контрагент - не возможно определить его ИНН и вставить в УИН ...";
				ТекстСообщения = ТекстСообщения + " Вероятная причина - " + Причина;
			ИначеЕсли Не ЗначениеЗаполнено(ИННКонтрагента) Тогда
				Причина = "не заполнены ни ИНН в карточке Контрагента, ни ИНН в карточке его Юрлица ...";
				ТекстСообщения = ТекстСообщения + " Вероятная причина - " + Причина;
			Иначе
				Если СтрДлина(ИННКонтрагента) <> ДлинаИННЮрЛиц Тогда
					Причина = "длина " + ИсточникИНН + " (" + ИННКонтрагента + ") не равна 10 символам ...";
					ТекстСообщения = ТекстСообщения + " Вероятная причина - " + Причина;
				КонецЕсли;
			КонецЕсли;
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Текст = ТекстСообщения;
			Сообщение.Поле = "УИН";
			Сообщение.УстановитьДанные(ЭтотОбъект);
			Сообщение.Сообщить();
		КонецЕсли;
	Иначе
		УИН = "";
	КонецЕсли;
КонецПроцедуры

Функция ИННКонтрагента(ИсточникИНН)
	ИННКонтрагента = "";
	Если ЗначениеЗаполнено(Контрагент) Тогда
		ЮрЛицо = Контрагент.ЮридическиеФизическиеЛица;
		Если ЗначениеЗаполнено(ЮрЛицо) И ТипЗнч(ЮрЛицо) = Тип("СправочникСсылка.ЮридическиеЛица") Тогда
			ИННКонтрагента = СокрЛП(ЮрЛицо.ИНН);
		КонецЕсли;
		Если Не ЗначениеЗаполнено(ИННКонтрагента) Тогда
			ИННКонтрагента = СокрЛП(Контрагент.ИНН);
			ИсточникИНН = "ИНН в карточке контрагента";
		Иначе
			ИсточникИНН = "ИНН в карточке юридического лица контрагента";
		КонецЕсли;
	КонецЕсли;
	
	Возврат ИННКонтрагента;
КонецФункции

Процедура ВыполнитьКонтрольПоручения(СобытиеКонтроля, Отказ)
	Если ДополнительныеСвойства.Свойство("ОтменитьКонтроль") И ДополнительныеСвойства.ОтменитьКонтроль Тогда
		Возврат;
	КонецЕсли;
	
	СообщенияКонтроля = Справочники.КонтрольПоручений.СообщенияКонтроляПоручений(Ссылка, СобытиеКонтроля);
	
	Если СообщенияКонтроля.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	Справочники.КонтрольПоручений.ПоказатьСообщенияКонтроляПоручений(СообщенияКонтроля, Отказ);
	Для Каждого РезультатКонтроля Из СообщенияКонтроля Цикл
		Если РезультатКонтроля.ОтправкаУведомленияПоЭлектроннойПочте Тогда
			Если Отказ Тогда
				// Это может происходить внутри транзакции, пример в обработчике собития ПередЗаписью, поэтому если писать
				// в регистр уведомлений к отправке  в том же сеансе, то при при откате транзакции исчезнет и новая запись
				// с уведомлением. Приходится писать в другом сеансе с использованием механизма фоновых заданий
				ПараметрыФоновогоЗадания = Новый Массив;
				ПараметрыФоновогоЗадания.Добавить(Ссылка);
				ПараметрыФоновогоЗадания.Добавить(СообщенияКонтроля);
				Ключ = Новый УникальныйИдентификатор;
				Наименование = "Отправить письмо с результатом сработавшего контроля поручения";
				ФоновыеЗадания.Выполнить("УправлениеЭлектроннойПочтой.ОтправитьСообщенияКонтроляПорученийПоЭлектроннойПочте",
											ПараметрыФоновогоЗадания, Ключ, Наименование);
			Иначе
				УправлениеЭлектроннойПочтой.ОтправитьСообщенияКонтроляПорученийПоЭлектроннойПочте(Ссылка, СообщенияКонтроля);
			КонецЕсли;
			Прервать;
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

