Функция ПолучитьСтруктуруПечатныхФорм() Экспорт
	
	СтруктураПечатныхФорм = Новый Структура;
	Если ВидОперацииД = Справочники.ВидыОпераций.ОткрытиеСчетаДепо Тогда
		СтруктураПечатныхФорм.Вставить("ОткрытиеСчетаДепо","Открытие счета депо");
	ИначеЕсли ВидОперацииД   = Справочники.ВидыОпераций.КорректировкаРеквизитовСчетаДепо Тогда	
		СтруктураПечатныхФорм.Вставить("КорректировкаСчетаДепо","Корректировка счета депо");
	ИначеЕсли ВидОперацииД   = Справочники.ВидыОпераций.ЗакрытиеСчетаДепо Тогда	
		СтруктураПечатныхФорм.Вставить("ЗакрытиеСчетаДепо","Закрытие счета депо");
	ИначеЕсли ВидОперацииД   = Справочники.ВидыОпераций.НазначениеПопечителяСчетаДепо Тогда
		СтруктураПечатныхФорм.Вставить("НазначениеПопечителя","Назначение попечителя");
	ИначеЕсли ВидОперацииД   = Справочники.ВидыОпераций.ОтзывПопечителяСчетаДепо Тогда
		СтруктураПечатныхФорм.Вставить("ОтзывПопечителя","Отзыв попечителя");
	ИначеЕсли ВидОперацииД   = Справочники.ВидыОпераций.НазначениеОператораСчетаДепо Тогда
		СтруктураПечатныхФорм.Вставить("ОператорРапорядительСчетаДепо", "Оператор рапорядитель счета депо");
	ИначеЕсли  ВидОперацииД   = Справочники.ВидыОпераций.Депонирование  
		ИЛИ    ВидОперацииД   = Справочники.ВидыОпераций.СнятиеСДепонирования				
		ИЛИ    ВидОперацииД   = Справочники.ВидыОпераций.Обременение
		ИЛИ    ВидОперацииД   = Справочники.ВидыОпераций.ВозвратИзЗалога
		ИЛИ    ВидОперацииД   = Справочники.ВидыОпераций.Конвертация
		ИЛИ    ВидОперацииД   = Справочники.ВидыОпераций.Перевод
		ИЛИ    ВидОперацииД   = Справочники.ВидыОпераций.ПередачаВЗалог
		ИЛИ    ВидОперацииД   = Справочники.ВидыОпераций.Перемещение
		ИЛИ    ВидОперацииД   = Справочники.ВидыОпераций.ПереводМеждуРазделамиСчетаДепо
		ИЛИ    ВидОперацииД   = Справочники.ВидыОпераций.Погашение
	    ИЛИ    ВидОперацииД   = Справочники.ВидыОпераций.СписаниеАкцийПриЛиквидацииЭмитента
	    ИЛИ    ВидОперацииД   = Справочники.ВидыОпераций.СписаниеОбесценившихсяЦенныхБумаг
		ИЛИ    ВидОперацииД   = Справочники.ВидыОпераций.ВыкупСписаниеЦБ
		ИЛИ    ВидОперацииД   = Справочники.ВидыОпераций.СнятиеОбременения
		ИЛИ    ВидОперацииД   = Справочники.ВидыОпераций.Разблокирование Тогда
		
		СтруктураПечатныхФорм.Вставить("ОперацииСЦБ", "Операции СЦБ");
	ИначеЕсли ВидОперацииД   = Справочники.ВидыОпераций.ПредоставлениеУведомления  Тогда
		СтруктураПечатныхФорм.Вставить("Уведомление", "Уведомление");
	ИначеЕсли ВидОперацииД = Справочники.ВидыОпераций.ПустаяСсылка() Тогда 
		СтруктураПечатныхФорм.Вставить("ОткрытиеСчетаДепо","Открытие счета депо");
		СтруктураПечатныхФорм.Вставить("КорректировкаСчетаДепо","Корректировка счета депо");
		СтруктураПечатныхФорм.Вставить("ЗакрытиеСчетаДепо","Закрытие счета депо");
		СтруктураПечатныхФорм.Вставить("НазначениеПопечителя","Назначение попечителя");
		СтруктураПечатныхФорм.Вставить("ОтзывПопечителя","Отзыв попечителя");
		СтруктураПечатныхФорм.Вставить("ОператорРапорядительСчетаДепо", "Оператор рапорядитель счета депо");
		СтруктураПечатныхФорм.Вставить("ОперацииСЦБ", "Операции СЦБ");
		СтруктураПечатныхФорм.Вставить("ОперацииСЦБ", "Операции СЦБ");
		СтруктураПечатныхФорм.Вставить("Уведомление", "Уведомление");
	КонецЕсли;
	
	Возврат СтруктураПечатныхФорм;
	
КонецФункции

Процедура ПечатьПорученияОткрытиеСчетаДепо()
	
	ТабДок = Новый ТабличныйДокумент;
	Макет = Документы.Поручение.ПолучитьМакет("ОткрытиеСчетаДепо");
	
	Область = Макет.ПолучитьОбласть("Заголовок");
	
	Депозитарий = Константы.ОрганизацияПоУмолчанию.Получить();
	Если Депозитарий.Пустая() тогда
		Сообщить("Не выбрано значение организации, используемое по умолчанию!!!");
		Возврат;
	КонецЕсли;
	
	Область.Параметры.Организация	= "Депозитарий " + Депозитарий.Наименование; 
	ДанныеЛицензии					= ФормированиеПечатныхФорм.ДанныеЛицензииОрганизации(Депозитарий);
	Область.Параметры.ДатаЛицензии	= Формат(ДанныеЛицензии.ДатаЛицензии,"ДЛФ=DD");
	Область.Параметры.НомерЛицензии	= "Лицензия № " + ДанныеЛицензии.НомерЛицензии; 
	Область.Параметры.ФактАдрес		= КонтактнаяИнформация.ПолучитьАдресИзКонтактнойИнформации(Депозитарий,"Фактический");
	Область.Параметры.ТелФакс		= КонтактнаяИнформация.ПолучитьТелефонИзКонтактнойИнформации(Депозитарий);
	ТабДок.Вывести(Область);
	
	Если Инициатор.ЮрФизЛицо = Перечисления.ЮрФизЛицо.ФизЛицо Тогда
		
		Область = Макет.ПолучитьОбласть("ШапкаФизик");
		Область.Параметры.ФИО = Инициатор.НаименованиеПолное;
		ДанныеПаспорта = ОбщегоНазначения.ПаспортныеДанные(Инициатор.ФизЛицо, Дата);
		Область.Параметры.ПаспортСерия = ДанныеПаспорта.Серия;
		Область.Параметры.ПаспортНомер = ДанныеПаспорта.Номер;
		Область.Параметры.ДатаВыдачиПаспорта = Формат(ДанныеПаспорта.ДатаВыдачи,"ДФ=dd.MM.yyyy")+"г.";
		Область.Параметры.МестоВыдачиПаспорта = ДанныеПаспорта.Выдан;
		Область.Параметры.Организация = Депозитарий.Наименование;
		
		Если ТипСчетаДепо = Перечисления.ТипыСчетовДепо.Залогодержателя Тогда
			
			Область.Параметры.Собственник 			= "[ ]" ;
			Область.Параметры.Залогодержатель		= "[Х]";
			
		ИначеЕсли ТипСчетаДепо = Перечисления.ТипыСчетовДепо.Владельца  Тогда	
			Область.Параметры.Собственник 			= "[Х]";
			Область.Параметры.Залогодержатель		= "[ ]";
		Иначе
			Область.Параметры.Собственник 			="[ ]";
			Область.Параметры.Залогодержатель		="[ ]";
			Сообщить("Не правильно указан тип счета депо!");
		КонецЕсли; 
		
		Область.Параметры.ДоговорНомер				= Инициатор.ОсновнойДоговорКонтрагента.Наименование + " №"
		+ Строка(Инициатор.ОсновнойДоговорКонтрагента.Код)
		+ " от " + Формат(Инициатор.ОсновнойДоговорКонтрагента.ДатаНачалоДействия,"ДЛФ=DD");
		
		Область.Параметры.ОрганизацияОзнакомлен		= "		С условиями осуществления депозитарной деятельности "
		+ Депозитарий.НаименованиеПлательщикаПриПеречисленииНалогов+" ознакомлен.";
		Область.Параметры.ОрганизацияГарантия		= "		Настоящим гарантирую, что все ценные бумаги, которые будут" 
		+ "	депонироваться мною в Депозитарий "	+Депозитарий.НаименованиеПлательщикаПриПеречисленииНалогов
		+ ", принадлежат или переданны мне в залог в полном"
		+ " соответствии с законодательством Российской Федерации.";
	Иначе	
		
		Область = Макет.ПолучитьОбласть("ШапкаЮрик");        
		ПараметрыОбласти = Область.Параметры;
		ПараметрыОбласти.ФИО = "Я, нижеподписавшийся " + Инициатор.ОсновноеКонтактноеЛицо.Наименование
		+ ", "+Инициатор.ОсновноеКонтактноеЛицо.Должность;
		ПараметрыОбласти.ОрганизацияНаименование 	= Депозитарий.Наименование;
		ПараметрыОбласти.ДепонентСчет      		= "отдельный счет депо на имя "+Инициатор.НаименованиеПолное;
		//установка типа счета
		Если ТипСчетаДепо = Перечисления.ТипыСчетовДепо.Залогодержателя Тогда
			ПараметрыОбласти.Собственник = "[ ]";
			ПараметрыОбласти.Залогодержатель = "[Х]";
			ПараметрыОбласти.ДУ = "[ ]";
			ПараметрыОбласти.НД = "[ ]"; 
			
		ИначеЕсли ТипСчетаДепо = Перечисления.ТипыСчетовДепо.Владельца  Тогда	
			ПараметрыОбласти.Собственник = "[Х]";
			ПараметрыОбласти.Залогодержатель = "[ ]";
			ПараметрыОбласти.ДУ = "[ ]";
			ПараметрыОбласти.НД = "[ ]";
		ИначеЕсли ТипСчетаДепо = Перечисления.ТипыСчетовДепо.ДоверительногоУправляющего  Тогда	
			ПараметрыОбласти.Собственник = "[ ]";
			ПараметрыОбласти.Залогодержатель = "[ ]";
			ПараметрыОбласти.ДУ = "[Х]";
			ПараметрыОбласти.НД = "[ ]";
		ИначеЕсли ТипСчетаДепо = Перечисления.ТипыСчетовДепо.НоминальногоДержателя  Тогда	
			ПараметрыОбласти.Собственник = "[ ]";
			ПараметрыОбласти.Залогодержатель = "[ ]";
			ПараметрыОбласти.ДУ = "[ ]";
			ПараметрыОбласти.НД = "[Х]";
		Иначе
			ПараметрыОбласти.Собственник = "[ ]";
			ПараметрыОбласти.Залогодержатель = "[ ]";
			ПараметрыОбласти.ДУ = "[ ]";
			ПараметрыОбласти.НД = "[ ]";
			Сообщить("Не правильно указан тип счета депо!");
		КонецЕсли; 
		ПараметрыОбласти.ДанныеДоговор  = "для учета и/или хранения ценных бумаг на основании договора "
		+ "счета депо (договора о междепозитарных отношениях) №"
		+ Строка(Инициатор.ОсновнойДоговорКонтрагента.Код) + " "
		+ Строка(Инициатор.ОсновнойДоговорКонтрагента.Наименование)  + " от "
		+ Формат(Инициатор.ОсновнойДоговорКонтрагента.ДатаНачалоДействия,"ДЛФ=DD");                                            
		ПараметрыОбласти.ОрганизацияОзнакомлен 	= "		С условиями осуществления депозитарной деятельности "
		+ Депозитарий.НаименованиеПлательщикаПриПеречисленииНалогов+" ознакомлен.";
		ПараметрыОбласти.ОрганизацияГарантия = "		Настоящим гарантирую, что все ценные бумаги, которые будут" 
		+ "	депонироваться в Депозитарий "	+Депозитарий.НаименованиеПлательщикаПриПеречисленииНалогов
		+ ", принадлежат, или доверены, или переданны в залог или на депозитарное обслуживание";
		ПараметрыОбласти.ДепонентНаименование = Инициатор.НаименованиеПолное;
		
	КонецЕсли;
	
	ТабДок.Вывести(Область);
	
	ВывестиПодвалМакетаВТабличныйДокумент(Макет, ТабДок);
	
	ФормированиеПечатныхФорм.ПоказатьТабличныйДокумент(ТабДок);
	
КонецПроцедуры

Процедура ПечатьПорученияКорректировкаСчетаДепо()
	
	ТабДок = Новый ТабличныйДокумент;
	Макет = Документы.Поручение.ПолучитьМакет("КорректировкаСчетаДепо");
	// Заголовок
	Область = Макет.ПолучитьОбласть("Заголовок");
	ТабДок.Вывести(Область);
	//Шапка
	Область = Макет.ПолучитьОбласть("Шапка");
	Область.Параметры.ДанныеДепонент	=	"Депонент " + Инициатор.НаименованиеПолное;
	//установка номера счета депо
	НомерКодаСчета = 1;
	Пока НомерКодаСчета < 12 Цикл
		
		Область.Параметры["П"+НомерКодаСчета]        = Сред(СокрЛП(СчетДепо.Код),НомерКодаСчета,1);
		НомерКодаСчета	 =	НомерКодаСчета + 1;
		
	КонецЦикла; 
	//установка данных депозитарного договора.
	Если  (ТипЗнч(СчетДепо)=Тип("СправочникСсылка.СчетаДепоМХ")) И (НЕ ОбщегоНазначения.ЗначениеНеЗаполнено(СчетДепо)) Тогда
		Область.Параметры.ДанныеДоговор		=	СчетДепо.НомерДоговора + " от " + Формат(СчетДепо.ДатаДоговора,"ДЛФ=DD");
	Иначе 	
