/////////////////////////////////////////////////////////////////////
// ОБРАБОТЧИКИ СОБЫТИЙ ФОРМЫ

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	// Заполнить список выбора "Вид глобальной операции"
	Операции = Новый Массив;
	Операции.Добавить(Справочники.ВидыОпераций.НачислениеДивидендов);
	Операции.Добавить(Справочники.ВидыОпераций.НачислениеДоходовЦБ);
	Операции.Добавить(Справочники.ВидыОпераций.НачислениеДоходаПрочие);
	Операции.Добавить(Справочники.ВидыОпераций.ПогашениеНКД);
	Операции.Добавить(Справочники.ВидыОпераций.Погашение);
	Операции.Добавить(Справочники.ВидыОпераций.ПогашениеЦБПолное);
	Операции.Добавить(Справочники.ВидыОпераций.ПогашениеЦБЧастичное);
	Операции.Добавить(Справочники.ВидыОпераций.СписаниеАкцийПриЛиквидацииЭмитента);
	Операции.Добавить(Справочники.ВидыОпераций.СписаниеОбесценившихсяЦенныхБумаг);
	Операции.Добавить(Справочники.ВидыОпераций.Конвертация);
	Операции.Добавить(Справочники.ВидыОпераций.Выкуп);
	Операции.Добавить(Справочники.ВидыОпераций.ВыкупСписаниеЦБ);
	Для Каждого Вид Из Перечисления.ВидыОтчетов Цикл
		Операции.Добавить(Вид);
	КонецЦикла;
	
	Для Каждого Элемент Из Операции Цикл
		Если ТипЗнч(Элемент) = Тип("СправочникСсылка.ВидыОпераций") Тогда
			Элементы.ВидГлобальнойОперации.СписокВыбора.Добавить(Элемент.Ссылка, Элемент.Наименование);
		Иначе
			Элементы.ВидГлобальнойОперации.СписокВыбора.Добавить(Элемент, СокрЛП(Элемент));
		КонецЕсли;
	КонецЦикла;

	УправлениеЭлементамиФормыСервер();
КонецПроцедуры

&НаСервере
Процедура ПриЧтенииНаСервере(ТекущийОбъект)
	Оболочки.ПриЧтенииНаСервереДокумента(ЭтотОбъект, ТекущийОбъект);
КонецПроцедуры

/////////////////////////////////////////////////////////////////////
// ОБРАБОТЧИКИ СОБЫТИЙ ЭЛЕМЕНТОВ ФОРМЫ

&НаКлиенте
Процедура ВидГлобальнойОперацииПриИзменении(Элемент)
	УправлениеЭлементамиФормыСервер();
КонецПроцедуры

&НаКлиенте
Процедура ВидГлобальнойОперацииОчистка(Элемент, СтандартнаяОбработка)
	СтандартнаяОбработка	= Ложь;
КонецПроцедуры

&НаКлиенте
Процедура ЦеннаяБумагаОбработкаВыбора(Элемент, ВыбранноеЗначение, СтандартнаяОбработка)
	СтандартнаяОбработка	= Ложь;
	ДатаПроверки			= ?(Объект.Ссылка.Пустая(), ТекущаяДата(), Объект.Дата);
	ЦенныеБумагиКлиент.ЦеннаяБумагаПроверкаВыборка(ВыбранноеЗначение, ДатаПроверки, СтандартнаяОбработка);
КонецПроцедуры

&НаКлиенте
Процедура ДокументОснованиеПриИзменении(Элемент)
	ОбработатьИзменениеДокументаОснованияСервер();
КонецПроцедуры

/////////////////////////////////////////////////////////////////////
// СЛУЖЕБНЫЕ ФУНКЦИИ

&НаСервере
Процедура УправлениеЭлементамиФормыСервер()
	ВыплатаДоходаВДенежнойФорме = ТипЗнч(Объект.ВидГлобальнойОперации) = Тип("СправочникСсылка.ВидыОпераций")
		И Объект.ВидГлобальнойОперации.ВыплатаДоходаВДенежнойФорме;
		
	Вид = Объект.ВидГлобальнойОперации;
								
	Элементы.ТарифныйПлан.Видимость =
		Вид = Справочники.ВидыОпераций.Погашение
		ИЛИ Вид = Справочники.ВидыОпераций.НачислениеДоходовЦБ
		ИЛИ Вид = Справочники.ВидыОпераций.СписаниеАкцийПриЛиквидацииЭмитента
		ИЛИ Вид = Справочники.ВидыОпераций.СписаниеОбесценившихсяЦенныхБумаг
		ИЛИ Вид = Справочники.ВидыОпераций.Конвертация
		ИЛИ Вид = Справочники.ВидыОпераций.ВыкупСписаниеЦБ;
	
	// Управление видимостью колонок ТЧ
	ПогашениеВыкуп =
		Вид = Справочники.ВидыОпераций.Погашение
		ИЛИ Вид = Справочники.ВидыОпераций.НачислениеДоходовЦБ
		ИЛИ Вид = Справочники.ВидыОпераций.СписаниеАкцийПриЛиквидацииЭмитента
		ИЛИ Вид = Справочники.ВидыОпераций.СписаниеОбесценившихсяЦенныхБумаг
		ИЛИ Вид = Справочники.ВидыОпераций.ВыкупСписаниеЦБ;
	Элементы.ЦенныеБумагиРазделСчетаДепо.Видимость				= ПогашениеВыкуп;
	Элементы.ЦенныеБумагиСчетДепоМестаХранения.Видимость		= ПогашениеВыкуп;
	Элементы.ЦенныеБумагиРазделСчетаДепоМестаХранения.Видимость	= ПогашениеВыкуп;
	Элементы.ЦенныеБумагиЦеннаяБумага.Видимость					= ПогашениеВыкуп;
	Элементы.ЦенныеБумагиСтатусЦБ.Видимость						= ПогашениеВыкуп;
	Элементы.ЦенныеБумагиСумма.Видимость = ВыплатаДоходаВДенежнойФорме;
	
	// Управление доступностью элементов
	Элементы.ГруппаБанковскийСчетВалюта.ТолькоПросмотр =
		Вид = Справочники.ВидыОпераций.ПогашениеНКД 
		ИЛИ Вид = Справочники.ВидыОпераций.ПогашениеЦБЧастичное 
		ИЛИ Вид = Справочники.ВидыОпераций.Выкуп
		ИЛИ Вид = Справочники.ВидыОпераций.ПогашениеЦБПолное;
		
	// Управление реквизитами "Конвертации"
	Элементы.ГруппаГООбщие.Видимость				= НЕ Вид = Справочники.ВидыОпераций.Конвертация;
	Элементы.Проверка.Видимость						= НЕ Вид = Справочники.ВидыОпераций.Конвертация;
	Элементы.Биржа.Видимость						=
		НЕ (Вид = Справочники.ВидыОпераций.Конвертация
			ИЛИ Вид = Справочники.ВидыОпераций.НачислениеДивидендов
			ИЛИ Вид = Справочники.ВидыОпераций.НачислениеДоходаПрочие
			ИЛИ Вид = Справочники.ВидыОпераций.Погашение
			ИЛИ Вид = Справочники.ВидыОпераций.НачислениеДоходовЦБ
			ИЛИ Вид = Справочники.ВидыОпераций.СписаниеАкцийПриЛиквидацииЭмитента
			ИЛИ Вид = Справочники.ВидыОпераций.СписаниеОбесценившихсяЦенныхБумаг
			ИЛИ Вид = Справочники.ВидыОпераций.ВыкупСписаниеЦБ);
	Элементы.ЦеннаяБумага.Видимость					= НЕ Вид = Справочники.ВидыОпераций.Конвертация;
	Элементы.ГруппаБанковскийСчетВалюта.Видимость	= НЕ Вид = Справочники.ВидыОпераций.Конвертация;
	Элементы.ГруппаТипКонвертации.Видимость			= Вид = Справочники.ВидыОпераций.Конвертация;
	Элементы.ДокументОснованиеОкруглятьДробноеКоличествоЦБ.Видимость = Вид = Справочники.ВидыОпераций.Конвертация;
	Элементы.ГруппаГОКонвертация.Видимость			= Вид = Справочники.ВидыОпераций.Конвертация;
	
	Если Вид = Справочники.ВидыОпераций.Конвертация Тогда
		Если Объект.ТипКонвертации = Перечисления.ТипыКонвертаций.Аннулирование Тогда
			Элементы.ГруппаЗачисление.Видимость	= Ложь;
			Если Объект.Зачисление.Количество()>0 Тогда
				Объект.Зачисление.Очистить();
			КонецЕсли;
		Иначе
			Элементы.ГруппаЗачисление.Видимость	= Истина;
		КонецЕсли;
	КонецЕсли;
	
	Элементы.ЦенныеБумагиСуммаНалога.Видимость = ВыплатаДоходаВДенежнойФорме;
	Элементы.ЦенныеБумагиСуммаБезНалога.Видимость = ВыплатаДоходаВДенежнойФорме;
	
	Элементы.ДополнительныеДатыИсполнения.Видимость = Ложь;
	Если ТипЗнч(Объект.ВидГлобальнойОперации) = Тип("СправочникСсылка.ВидыОпераций") И Объект.ВидГлобальнойОперации.ДвижениеПоЦБ Тогда
		Элементы.ДополнительныеДатыИсполнения.Видимость = Истина;
	КонецЕсли;
	Элементы.ГруппаДляВидовОперацийСФлагомВыплата.Видимость = ВыплатаДоходаВДенежнойФорме;
	
	ЭтоНачислениеДоходовЦБ = Объект.ВидГлобальнойОперации = Справочники.ВидыОпераций.НачислениеДоходовЦБ;
	Элементы.ГруппаНачислениеДоходовЦБ.Видимость = ЭтоНачислениеДоходовЦБ;
	Элементы.ЦеннаяБумага.Подсказка = "Ценная бумага" + ?(ЭтоНачислениеДоходовЦБ, ", начисленная в виде дохода", "");
	Элементы.ЦенныеБумагиКоличествоБазовойЦБ.Видимость = ЭтоНачислениеДоходовЦБ;
КонецПроцедуры

&НаСервере
Процедура ОбработатьИзменениеДокументаОснованияСервер()
	Документ = РеквизитФормыВЗначение("Объект");
	Документ.Заполнить(Документ.ДокументОснование);
	ЗначениеВРеквизитФормы(Документ, "Объект");
КонецПроцедуры

