
#Область ПрограммныйИнтерфейс

Процедура НачалоВыбораПредставления(Форма, ВладелецКИ = Неопределено, ИмяРеквизитаНабора = "НаборКонтактнаяИнформация") Экспорт
	
	Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(Форма, "ПараметрыКонтактнойИнформации") Тогда
		ИмяРеквизитаНабора = Форма.ПараметрыКонтактнойИнформации.ИмяРеквизитаНабора;		
	КонецЕсли; 	
	
	ТекДанные = Форма.Элементы[ИмяРеквизитаНабора].ТекущиеДанные;
	
	Если ТекДанные = Неопределено Тогда
		Возврат;		
	КонецЕсли; 
	
	Если НЕ ЗначениеЗаполнено(ТекДанные.Тип) Тогда
		Сообщить("Не указан тип контактной информации");
		Возврат;
	КонецЕсли;	
	
	Если НЕ ЗначениеЗаполнено(ТекДанные.Вид) Тогда
		Сообщить("Не указан вид контактной информации");
		Возврат;
	КонецЕсли;
	
	Если Не Пользователи.ЭтоПолноправныйПользовательИБ() И ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(Форма, "Объект") Тогда
		
		РазрешитьРедактирование = ТекДанные.Тип = ПредопределенноеЗначение("Перечисление.ТипыКонтактнойИнформации.Адрес") И (ТипЗнч(Форма.Объект.Ссылка) = Тип("СправочникСсылка.ЮридическиеЛица") Или ТипЗнч(Форма.Объект.Ссылка) = Тип("СправочникСсылка.ФизическиеЛица")) 
		И ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Форма.Объект.Ссылка, "Выгодоприобретатель");
		
		Если Не РазрешитьРедактирование Тогда
			ВызватьИсключение "Недостаточно прав для просмотра";
		КонецЕсли;
		
	КонецЕсли;
	
	Запись = СтруктураЗаписи();
	ЗаполнитьЗначенияСвойств(Запись, ТекДанные);
	
	Если НЕ ЗначениеЗаполнено(Запись.Период) Тогда
		Запись.Период = ТекущаяДата();		
	КонецЕсли; 
	
	Если НЕ ЗначениеЗаполнено(Запись.Объект) Тогда
		Если ВладелецКИ = Неопределено Тогда
			ВладелецКИ = КонтактнаяИнформацияКлиентСервер.ВладелецКИ(Форма);			
		КонецЕсли; 
		Запись.Объект = ВладелецКИ;
	КонецЕсли; 
	
	ПараметрыОткрытия = Новый Структура;
	ПараметрыОткрытия.Вставить("Запись", Запись);	
	
	ДопПараметры = Новый Структура("Форма, ТекДанные", Форма, ТекДанные);
	Оповещение = Новый ОписаниеОповещения("ПриОкончанииРедактированияПредставления", ЭтотОбъект, ДопПараметры);
	
	ИмяФормы = ОбщегоНазначения.ИмяЗначенияПеречисления(ТекДанные.Тип);	
	ОткрытьФорму("Обработка.РедактированиеКИУпр.Форма." + ИмяФормы
		, ПараметрыОткрытия
		, Форма
		, 
		,
		,
		, Оповещение
		, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
		
КонецПроцедуры

Процедура ВводКИ_СохранитьИЗакрытьНаКлиенте(Форма) Экспорт
	
	Если Форма.Модифицированность Тогда
		Результат = СтруктураЗаписи();
		ЗаполнитьЗначенияСвойств(Результат, Форма.Объект);
		Форма.Модифицированность = Ложь;
		Форма.Закрыть(Результат);
	Иначе
		Форма.Закрыть();		
	КонецЕсли; 
		
КонецПроцедуры

Процедура ВводКИ_ПередЗакрытием(Форма, Отказ) Экспорт
	
	Если НЕ Форма.Модифицированность Тогда
		Возврат;
	КонецЕсли;
	
	Отказ = Истина;		
	Ответ = Вопрос("Данные были изменены. Сохранить изменения перед выходом?", РежимДиалогаВопрос.ДаНетОтмена);
	
	Если Ответ = КодВозвратаДиалога.Да Тогда
		ВводКИ_СохранитьИЗакрытьНаКлиенте(Форма);
		
	ИначеЕсли Ответ = КодВозвратаДиалога.Нет Тогда 
		Форма.Модифицированность = Ложь;
		Форма.Закрыть();
		
	КонецЕсли; 		
		
КонецПроцедуры

Процедура ОбновитьПараметрыВыбораДляВидаКИ(Форма) Экспорт
	
	ВидОбъекта = КонтактнаяИнформация.ВидОбъектаКИ(Форма.Объект.Объект);		
	ЭлемФормы = Форма.Элементы.Вид;
	
	СписокПарамВыбора = Новый Массив;
	ПарамВыбора = Новый ПараметрВыбора("Отбор.ВидОбъектаКонтактнойИнформации", ВидОбъекта);
	СписокПарамВыбора.Добавить(ПарамВыбора);
	
	ПарамВыбора = Новый ПараметрВыбора("Отбор.Тип", Форма.Объект.Тип);
	СписокПарамВыбора.Добавить(ПарамВыбора);
	
	ЭлемФормы.ПараметрыВыбора = Новый ФиксированныйМассив(СписокПарамВыбора);					
	
КонецПроцедуры
 
#КонецОбласти 

#Область СлужебныеПроцедурыИФункции

Процедура ПриОкончанииРедактированияПредставления(Результат, ДопПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;		
	КонецЕсли; 
	
	ЗаполнитьЗначенияСвойств(ДопПараметры.ТекДанные, Результат);
	ДопПараметры.Форма.Модифицированность = Истина;
	
КонецПроцедуры

Функция СтруктураЗаписи()
	
	Результат = Новый Структура;
	Результат.Вставить("Период");
	Результат.Вставить("Объект");
	Результат.Вставить("Тип");
	Результат.Вставить("Вид");
	Результат.Вставить("Представление");
	Результат.Вставить("Поле1");
	Результат.Вставить("Поле2");
	Результат.Вставить("Поле3");
	Результат.Вставить("Поле4");
	Результат.Вставить("Поле5");
	Результат.Вставить("Поле6");
	Результат.Вставить("Поле7");
	Результат.Вставить("Поле8");
	Результат.Вставить("Поле9");
	Результат.Вставить("Поле10");
	Результат.Вставить("Комментарий");
	Результат.Вставить("ЭтоРоссийскийАдрес");
	
	Возврат Результат;
	
КонецФункции
 
#КонецОбласти 
