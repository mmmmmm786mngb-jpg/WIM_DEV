// Обработчик регламентного задания ЗапросДанныхВDiasoft.
// Параметры:
//	НомерРабочегоДняВМесяцеКогдаВыполнять - Число - номер рабочего дня в месяце когда должен выполнять запрос данных из Диасофт.
//		Если вызов процедуры произошел не в указанный порядковый рабочий день текущего месяца, дальнешее выполнение прерывается.
//		Если не указан или равен нулю - проверка не выполняется.
Процедура ЗапросДанныхВDiasoft(НомерРабочегоДняВМесяцеКогдаВыполнять = 0) Экспорт
	ДатаЗапроса = НачалоДня(ТекущаяДатаСеанса());
	Если ЗначениеЗаполнено(НомерРабочегоДняВМесяцеКогдаВыполнять) Тогда
		ДеньНачалаОтсчета = НачалоДня(НачалоМесяца(ДатаЗапроса) - 1);	// Последний день предыдущего месяца
		ДатаКогдаВыполнять = ОбщегоНазначения.ДобавитьРабочийКалендарныйДень(ДеньНачалаОтсчета, НомерРабочегоДняВМесяцеКогдаВыполнять);
		Если ДатаЗапроса <> ДатаКогдаВыполнять Тогда
			Возврат;
		КонецЕсли;
	КонецЕсли;
	
	ПолучениеДанныхДиасофтВызовСервера.СоздатьЗапросДанных(ДатаЗапроса);
КонецПроцедуры

