// Обработчик регламентного задания СервисыНРД
//
// Параметры:
//  Действие					 - Строка						 - ЗагрузкаИтоговТорговЧерезNSDAPI
//  ТипПериодаЗагрузкиКотировок	 - ПеречислениеСсылка.ПериодыДней	 - ПредыдущийДень, ПредыдущийРабочийДень, ТекущийДень
//  ISINs						 - Строка							 - Фильтр по ISIN через запятую
//
Процедура СервисыНРД(Действие = Неопределено, ТипПериодаЗагрузкиКотировок = Неопределено, ISINs = "") Экспорт
	
	ИмяНастроекСервиса = "НастройкиНРД";
	
	MarketData.ВнешниеСервисыВыполнитьДействие(ИмяНастроекСервиса, Действие, ТипПериодаЗагрузкиКотировок, ISINs);
	
	Если ЗначениеЗаполнено(ТипПериодаЗагрузкиКотировок) Тогда
