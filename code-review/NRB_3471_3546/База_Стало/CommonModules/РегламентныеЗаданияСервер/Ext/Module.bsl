Процедура СписаниеЦБПолученныхОтПринудительнойКонвертации(ДатаРегламента = Неопределено) Экспорт
	
	Если Не ОбщегоНазначения.РабочийДень() Тогда
		Возврат;
	КонецЕсли;
	
	Если ДатаРегламента = Неопределено Тогда
		ДатаРегламента = ТекущаяДатаСеанса();
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ОбособленныйРаздел", Перечисления.ТипыРазделовСчетовДЕПО.БлокированоОбособленный);
	Запрос.УстановитьПараметр("Основной", Перечисления.ТипыРазделовСчетовДЕПО.Основной);
	Запрос.УстановитьПараметр("Период", ДатаРегламента);
	Запрос.УстановитьПараметр("НачалоПериода", НачалоДня(ДатаРегламента));
	Запрос.УстановитьПараметр("ОкончаниеПериода", КонецДня(ДатаРегламента));
	Запрос.УстановитьПараметр("Акция", Перечисления.ТипыЦБ.Акция);
	Запрос.УстановитьПараметр("ВидОперацииПеревод", Справочники.ВидыОпераций.ПереводМеждуРазделамиСчетаДепо);
	Запрос.УстановитьПараметр("ВидПорученияПереводВРамкахСчета", Справочники.ВидыИнвентарныхПоручений.П20);
	Запрос.УстановитьПараметр("SHS1", "SHS1");
	Запрос.УстановитьПараметр("SHS2", "SHS2");
	Запрос.УстановитьПараметр("SHS3", "SHS3");
	Запрос.УстановитьПараметр("SHS4", "SHS4");
	Запрос.Текст = ТекстЗапросаСписаниеЦБПолученныхОтПринудительнойКонвертации();
	
	ДанныеДляПоручений = Запрос.Выполнить().Выбрать();
	Организация = ОбщегоНазначенияПовтИсп.ОрганизацияПоУмолчанию();
	Пока ДанныеДляПоручений.Следующий() Цикл
		
		ПоручениеСуществует = ЗначениеЗаполнено(ДанныеДляПоручений.Поручение);
		Если ПоручениеСуществует Тогда
			Поручение = ДанныеДляПоручений.Поручение.ПолучитьОбъект();
			Поручение.Заблокировать();
		Иначе
			Поручение = Документы.Поручение.СоздатьДокумент();
			Поручение.Заполнить(Неопределено);
		КонецЕсли;
		ДвенадцатьЧасов = 12 * 60 * 60;
		Поручение.Дата = НачалоДня(ДатаРегламента) + ДвенадцатьЧасов;
		Поручение.УстановитьНовыйНомер();
		Поручение.ДатаИсполненияПоручения = НачалоДня(ДатаРегламента) + ДвенадцатьЧасов + 1;
		Поручение.ДатаИсполненияПорученияВДепозитарииМХ = Поручение.ДатаИсполненияПоручения;
		Поручение.ДатаИсполненияПорученияВМестеРасчетов = Поручение.ДатаИсполненияПоручения;
		Поручение.ВидОперацииД = Справочники.ВидыОпераций.ПереводМеждуРазделамиСчетаДепо;
		Поручение.ВидПоручения = Справочники.ВидыИнвентарныхПоручений.П20;
		Поручение.Инициатор = Организация;
		Поручение.Депонент = ДанныеДляПоручений.Клиент;
		Поручение.СчетДепо = ДанныеДляПоручений.СчетДепо;
		Поручение.РазделСчетаДепо = ДанныеДляПоручений.РазделСчетаДепо;
		Поручение.МХДепонента = ДанныеДляПоручений.МХДепонента;
		Поручение.СчетДепоМХ = ДанныеДляПоручений.СчетДепоМХ;
		Поручение.РазделСчетаДепоМХ = ДанныеДляПоручений.РазделСчетаДепоМХ;
		Поручение.Контрагент = ДанныеДляПоручений.Клиент;
		Поручение.СчетДепоКонтрагента = ДанныеДляПоручений.СчетДепо;
		Поручение.РазделСчетаДепоКонтрагента = ДанныеДляПоручений.РазделСчетаДепоКонтрагента;
		Поручение.МХКонтрагент = ДанныеДляПоручений.МХКонтрагент;
		Поручение.СчетДепоМХКонтрагента = ДанныеДляПоручений.СчетДепоМХКонтрагента;
		Поручение.РазделСчетаДепоМХКонтрагента = ДанныеДляПоручений.РазделСчетаДепоМХКонтрагента;
		Поручение.Комментарий = "Уменьшение количества обособленных акций согласно п. 6 Предписания Банка России  № 018-34/12822 от 28.12.2022 г.";
		Если Документы.Поручение.ЭтоНеторговоеПоручениеСоСпискомЦБ(Поручение) Тогда
			НоваяСтрокаЦБ = Поручение.ЦенныеБумагиСписываемые.Добавить();
			НоваяСтрокаЦБ.ЦеннаяБумага = ДанныеДляПоручений.ЦБ;
			НоваяСтрокаЦБ.Количество = ДанныеДляПоручений.КоличествоКПереводу;
		Иначе
			Поручение.ЦБ = ДанныеДляПоручений.ЦБ;
			Поручение.КоличествоЦБ = ДанныеДляПоручений.КоличествоКПереводу;
		КонецЕсли;
		
		Попытка
			Поручение.Записать(РежимЗаписиДокумента.Проведение);
		Исключение
			Если ПоручениеСуществует Тогда
				ОписаниеОшибки = "Не удалось обновить поручение %1 на перевод между разделами счета.";
				ОписаниеОшибки = СтрШаблон(ОписаниеОшибки, ДанныеДляПоручений.Поручение);
			Иначе
				ОписаниеОшибки = "Не удалось записать поручение на перевод между разделами счета. Раздел счета ДЕПО %1, ЦБ %2";
				ОписаниеОшибки = СтрШаблон(ОписаниеОшибки, ДанныеДляПоручений.РазделСчетаДепо, ДанныеДляПоручений.ЦБ);
			КонецЕсли;
			ОписаниеОшибки = ОписаниеОшибки + " По причине: " + ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
			ЗаписьЖурналаРегистрации("Снятие обособления по Предписанию БР", УровеньЖурналаРегистрации.Ошибка, , , ОписаниеОшибки);
		КонецПопытки;
		
	КонецЦикла;
	
КонецПроцедуры

Функция ТекстЗапросаСписаниеЦБПолученныхОтПринудительнойКонвертации()
	
	Возврат
	"ВЫБРАТЬ
	|	ЦенныеБумаги.Ссылка КАК Ссылка
	|ПОМЕСТИТЬ АкцииРФ
	|ИЗ
	|	Справочник.ЦенныеБумаги КАК ЦенныеБумаги
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ВидыЦББанкаРоссии КАК ВидыЦБАкцийРФ
	|		ПО ЦенныеБумаги.ВидЦББанкаРоссии = ВидыЦБАкцийРФ.Ссылка
	|			И (ЦенныеБумаги.ТипЦБ = &Акция)
	|			И (ВидыЦБАкцийРФ.Код В (&SHS1, &SHS2, &SHS3, &SHS4))
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ОстаткиЦБОстатки.СчетДепо КАК СчетДепо,
	|	ОстаткиЦБОстатки.РазделСчетаДепо КАК РазделСчетаДепо,
	|	ОстаткиЦБОстатки.ЦБ КАК ЦБ,
	|	ОстаткиЦБОстатки.СчетДепоМХ КАК СчетДепоМХ,
	|	ОстаткиЦБОстатки.РазделСчетаДепоМХ КАК РазделСчетаДепоМХ,
	|	ОстаткиЦБОстатки.КоличествоОстаток КАК КоличествоОстаток
	|ПОМЕСТИТЬ ОстаткиЦБНаТекущуюДату
	|ИЗ
	|	РегистрНакопления.ОстаткиЦБ.Остатки(
	|			&Период,
	|			РазделСчетаДепо.ТипРазделаСчетаДЕПО = &ОбособленныйРаздел
	|				И ЦБ В
	|					(ВЫБРАТЬ
	|						АкцииРФ.Ссылка КАК Ссылка
	|					ИЗ
	|						АкцииРФ КАК АкцииРФ)) КАК ОстаткиЦБОстатки
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	МИНИМУМ(ОстаткиЦБ.Период) КАК Период,
	|	ОстаткиЦБ.СчетДепо КАК СчетДепо,
	|	ОстаткиЦБ.РазделСчетаДепо КАК РазделСчетаДепо,
	|	ОстаткиЦБ.ЦБ КАК ЦБ,
	|	ОстаткиЦБ.СчетДепоМХ КАК СчетДепоМХ,
	|	ОстаткиЦБ.РазделСчетаДепоМХ КАК РазделСчетаДепоМХ
	|ПОМЕСТИТЬ ДатыВводаЦБ
	|ИЗ
	|	РегистрНакопления.ОстаткиЦБ КАК ОстаткиЦБ
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ОстаткиЦБНаТекущуюДату КАК ОстаткиЦБНаТекущуюДату
	|		ПО ОстаткиЦБ.ЦБ = ОстаткиЦБНаТекущуюДату.ЦБ
	|			И ОстаткиЦБ.СчетДепо = ОстаткиЦБНаТекущуюДату.СчетДепо
	|			И ОстаткиЦБ.РазделСчетаДепо = ОстаткиЦБНаТекущуюДату.РазделСчетаДепо
	|			И ОстаткиЦБ.СчетДепоМХ = ОстаткиЦБНаТекущуюДату.СчетДепоМХ
	|			И ОстаткиЦБ.РазделСчетаДепоМХ = ОстаткиЦБНаТекущуюДату.РазделСчетаДепоМХ
	|ГДЕ
	|	ОстаткиЦБ.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход)
	|
	|СГРУППИРОВАТЬ ПО
	|	ОстаткиЦБ.СчетДепо,
	|	ОстаткиЦБ.РазделСчетаДепо,
	|	ОстаткиЦБ.ЦБ,
	|	ОстаткиЦБ.СчетДепоМХ,
	|	ОстаткиЦБ.РазделСчетаДепоМХ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ОстаткиЦБ.СчетДепо КАК СчетДепо,
	|	ОстаткиЦБ.РазделСчетаДепо КАК РазделСчетаДепо,
	|	ОстаткиЦБ.ЦБ КАК ЦБ,
	|	ОстаткиЦБ.СчетДепоМХ КАК СчетДепоМХ,
	|	ОстаткиЦБ.РазделСчетаДепоМХ КАК РазделСчетаДепоМХ,
	|	СУММА(ОстаткиЦБ.Количество) КАК Количество
	|ПОМЕСТИТЬ ОстаткиЦБНачальные
	|ИЗ
	|	РегистрНакопления.ОстаткиЦБ КАК ОстаткиЦБ
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ДатыВводаЦБ КАК ДатыВводаЦБ
	|		ПО ОстаткиЦБ.Период = ДатыВводаЦБ.Период
	|			И ОстаткиЦБ.СчетДепо = ДатыВводаЦБ.СчетДепо
	|			И ОстаткиЦБ.РазделСчетаДепо = ДатыВводаЦБ.РазделСчетаДепо
	|			И ОстаткиЦБ.ЦБ = ДатыВводаЦБ.ЦБ
	|			И ОстаткиЦБ.СчетДепоМХ = ДатыВводаЦБ.СчетДепоМХ
	|			И ОстаткиЦБ.РазделСчетаДепоМХ = ДатыВводаЦБ.РазделСчетаДепоМХ
	|
	|СГРУППИРОВАТЬ ПО
	|	ОстаткиЦБ.РазделСчетаДепо,
	|	ОстаткиЦБ.РазделСчетаДепоМХ,
	|	ОстаткиЦБ.СчетДепо,
	|	ОстаткиЦБ.ЦБ,
	|	ОстаткиЦБ.СчетДепоМХ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	РазделыСчетаДепо.Владелец КАК Владелец,
	|	РазделыСчетаДепо.Ссылка КАК РазделСчетаДепоКонтрагента,
	|	РазделыСчетаДепо.РазделСчетаДепоМХ.Владелец.Владелец КАК МХКонтрагент,
	|	РазделыСчетаДепо.РазделСчетаДепоМХ.Владелец КАК СчетДепоМХКонтрагента,
	|	РазделыСчетаДепо.РазделСчетаДепоМХ КАК РазделСчетаДепоМХКонтрагента
	|ПОМЕСТИТЬ ОсновныеРазделыСчетовДепо
	|ИЗ
	|	Справочник.РазделыСчетаДепо КАК РазделыСчетаДепо
	|ГДЕ
	|	РазделыСчетаДепо.ТипРазделаСчетаДЕПО = &Основной
	|	И НЕ РазделыСчетаДепо.Наименование ПОДОБНО ""%обособл%""
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ОстаткиЦБНачальные.ЦБ КАК ЦБ,
	|	ВЫБОР
	|		КОГДА ОстаткиЦБНачальные.Количество * ПроцентыСписанияЦБСОбособленногоРазделаСрезПоследних.ПроцентСписания / 100 < 0.5
	|			ТОГДА 1
	|		ИНАЧЕ ВЫРАЗИТЬ(ОстаткиЦБНачальные.Количество * ПроцентыСписанияЦБСОбособленногоРазделаСрезПоследних.ПроцентСписания / 100 КАК ЧИСЛО(20, 0))
	|	КОНЕЦ КАК РасчетноеКоличествоКПереводу,
	|	ОстаткиЦБНачальные.СчетДепо КАК СчетДепо,
	|	ОстаткиЦБНачальные.РазделСчетаДепо КАК РазделСчетаДепо,
	|	ОстаткиЦБНачальные.СчетДепоМХ КАК СчетДепоМХ,
	|	ОстаткиЦБНачальные.РазделСчетаДепоМХ КАК РазделСчетаДепоМХ
	|ПОМЕСТИТЬ ЦенныеБумагиКПереводу
	|ИЗ
	|	ОстаткиЦБНачальные КАК ОстаткиЦБНачальные
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ПроцентыСписанияЦБСОбособленногоРаздела.СрезПоследних(&Период, РазделСчетаДЕПО.ТипРазделаСчетаДЕПО = &ОбособленныйРаздел) КАК ПроцентыСписанияЦБСОбособленногоРазделаСрезПоследних
	|		ПО ОстаткиЦБНачальные.РазделСчетаДепо = ПроцентыСписанияЦБСОбособленногоРазделаСрезПоследних.РазделСчетаДЕПО
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЦенныеБумагиКПереводу.ЦБ КАК ЦБ,
	|	ВЫБОР
	|		КОГДА ЦенныеБумагиКПереводу.РасчетноеКоличествоКПереводу > ОстаткиЦБНаТекущуюДату.КоличествоОстаток
	|			ТОГДА ОстаткиЦБНаТекущуюДату.КоличествоОстаток
	|		ИНАЧЕ ЦенныеБумагиКПереводу.РасчетноеКоличествоКПереводу
	|	КОНЕЦ КАК КоличествоКПереводу,
	|	ОстаткиЦБНаТекущуюДату.СчетДепо.Владелец КАК Клиент,
	|	ОстаткиЦБНаТекущуюДату.СчетДепо КАК СчетДепо,
	|	ОстаткиЦБНаТекущуюДату.РазделСчетаДепо КАК РазделСчетаДепо,
	|	ОстаткиЦБНаТекущуюДату.СчетДепоМХ.Владелец КАК МХДепонента,
	|	ОстаткиЦБНаТекущуюДату.СчетДепоМХ КАК СчетДепоМХ,
	|	ОстаткиЦБНаТекущуюДату.РазделСчетаДепоМХ КАК РазделСчетаДепоМХ,
	|	РазделыСчетаДепо.РазделСчетаДепоКонтрагента КАК РазделСчетаДепоКонтрагента,
	|	РазделыСчетаДепо.МХКонтрагент КАК МХКонтрагент,
	|	РазделыСчетаДепо.СчетДепоМХКонтрагента КАК СчетДепоМХКонтрагента,
	|	РазделыСчетаДепо.РазделСчетаДепоМХКонтрагента КАК РазделСчетаДепоМХКонтрагента,
	|	Поручение.Ссылка КАК Поручение
	|ИЗ
	|	ЦенныеБумагиКПереводу КАК ЦенныеБумагиКПереводу
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ОстаткиЦБНаТекущуюДату КАК ОстаткиЦБНаТекущуюДату
	|		ПО ЦенныеБумагиКПереводу.ЦБ = ОстаткиЦБНаТекущуюДату.ЦБ
	|			И ЦенныеБумагиКПереводу.СчетДепо = ОстаткиЦБНаТекущуюДату.СчетДепо
	|			И ЦенныеБумагиКПереводу.РазделСчетаДепо = ОстаткиЦБНаТекущуюДату.РазделСчетаДепо
	|			И ЦенныеБумагиКПереводу.СчетДепоМХ = ОстаткиЦБНаТекущуюДату.СчетДепоМХ
	|			И ЦенныеБумагиКПереводу.РазделСчетаДепоМХ = ОстаткиЦБНаТекущуюДату.РазделСчетаДепоМХ
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.Поручение КАК Поручение
	|		ПО ЦенныеБумагиКПереводу.СчетДепо = Поручение.СчетДепо
	|			И ЦенныеБумагиКПереводу.РазделСчетаДепо = Поручение.РазделСчетаДепо
	|			И ЦенныеБумагиКПереводу.ЦБ = Поручение.ЦБ
	|			И ЦенныеБумагиКПереводу.СчетДепоМХ = Поручение.СчетДепоМХ
	|			И ЦенныеБумагиКПереводу.РазделСчетаДепоМХ = Поручение.РазделСчетаДепоМХ
	|			И (Поручение.Дата МЕЖДУ &НачалоПериода И &ОкончаниеПериода)
	|			И (НЕ Поручение.ПометкаУдаления)
	|			И (Поручение.ВидОперацииД = &ВидОперацииПеревод)
	|			И (Поручение.ВидПоручения = &ВидПорученияПереводВРамкахСчета)
	|			И (Поручение.РазделСчетаДепо.ТипРазделаСчетаДЕПО = &ОбособленныйРаздел)
	|		ЛЕВОЕ СОЕДИНЕНИЕ ОсновныеРазделыСчетовДепо КАК РазделыСчетаДепо
	|		ПО ЦенныеБумагиКПереводу.СчетДепо = РазделыСчетаДепо.Владелец";
	
КонецФункции

// Обработчик регламентного задания ОтправкаПредупрежденийОПриближенииОкончанияПриемаУведомленийПоОфертам
Процедура ОтправкаПредупрежденийОСкоромОкончанииСрокаУчастияВОферте() Экспорт
	ТекДата = НачалоДня(ТекущаяДатаСеанса());
	Если Не ОбщегоНазначения.РабочийДень(ТекДата) Тогда
		Возврат;
	КонецЕсли;
	
	СледующийРабочийДень = ОбщегоНазначения.ДобавитьРабочийДень(ТекДата, 1);
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	КарточкаОферты.Ссылка КАК Ссылка,
	|	КарточкаОферты.ДатаОферты КАК ДатаОферты,
	|	КарточкаОферты.ЦеннаяБумага КАК ЦеннаяБумага,
	|	КарточкаОферты.ЦеннаяБумага.ISIN КАК ISIN,
	|	КарточкаОферты.ДатаОкончанияПриемаУведомлений КАК ДатаОкончанияПриемаУведомлений
	|ИЗ
	|	Документ.КарточкаОферты КАК КарточкаОферты
	|ГДЕ
	|	НЕ КарточкаОферты.ПометкаУдаления
	|	И КарточкаОферты.ДатаОкончанияПриемаУведомлений МЕЖДУ &НачалоСледующегоКалендарногоДня И &КонецСледующегоРабочегоДня
	|";
	Запрос.УстановитьПараметр("НачалоСледующегоКалендарногоДня", КонецДня(ТекДата) + 1);
	Запрос.УстановитьПараметр("КонецСледующегоРабочегоДня", КонецДня(СледующийРабочийДень));
	РезультатЗапроса = Запрос.Выполнить();
	Если Не РезультатЗапроса.Пустой() Тогда
		
		ВнешнийИсточник = ПланыВидовХарактеристик.ВнешниеИсточники.РассылкаПредупрежденийОПриближенииОкончанияПриемаУведомленийПоОфертам;
		НастройкиОбмена = ВнешниеДанные.ПолучитьПараметрыВнешнегоИсточника(ВнешнийИсточник).Настройка;
		Если НастройкиОбмена = Неопределено Тогда
			ТекстОшибки = "Не заданы параметры внешнего источника """ + Строка(ВнешнийИсточник) + """";
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстОшибки);
			ИмяСобытия = "Предупреждения о приближении окончания приема уведомлений по офертам не отправлены";
			ЗаписьЖурналаРегистрации(ИмяСобытия, УровеньЖурналаРегистрации.Ошибка, , , ТекстОшибки);
			Возврат;
		КонецЕсли;

		Выборка = РезультатЗапроса.Выбрать();
		Пока Выборка.Следующий() Цикл
			ОтправитьПредупреждениеОПриближенииОкончанияПриемаУведомленийПоОферте(Выборка, НастройкиОбмена);
		КонецЦикла;
		
	КонецЕсли;
	
КонецПроцедуры

Процедура ОтправитьПредупреждениеОПриближенииОкончанияПриемаУведомленийПоОферте(Выборка, НастройкиОбмена)
	
	ТемаПисьма = "Заканчивается срок приема уведомлений агентом по оферте";
	ШаблонТекста = "Подходит срок приема уведомлений агентом по оферте ISIN %1. Дата оферты = %2";
	ДатаОфертыСтрокой = Формат(Выборка.ДатаОферты, "ДФ=""дд.ММ.гггг""");
	ТекстПисьма = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(ШаблонТекста, Выборка.ISIN, ДатаОфертыСтрокой);
	
	ПараметрыУведомления = Новый Соответствие;
	ПараметрыУведомления.Вставить("Вложения",			Неопределено);
	ПараметрыУведомления.Вставить("НастройкиОбмена",	НастройкиОбмена);
	ПараметрыУведомления.Вставить("Кодировка",			"UTF-8");
	ПараметрыУведомления.Вставить("ТемаПисьма",			ТемаПисьма);
	ПараметрыУведомления.Вставить("ТекстПисьма",		ТекстПисьма);
	ПараметрыУведомления.Вставить("ТипТекстаПисьма",	ТипТекстаПочтовогоСообщения.ПростойТекст);
	ПараметрыУведомления.Вставить("Важность",			ВажностьИнтернетПочтовогоСообщения.Обычная);
	
	РегистрыСведений.УведомленияКОтправке.ДобавитьУведомлениеКотправке(ПараметрыУведомления);
	
КонецПроцедуры

Процедура ОтправкаУведомленийОПоступленииЗаявленияНаОферту() Экспорт
	ТриЧаса = 10800; // Три часа в секундах
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ЗаявлениеНаУчастиеВОферте.Ссылка КАК Заявление
	|ИЗ
	|	Документ.ЗаявлениеНаУчастиеВОферте КАК ЗаявлениеНаУчастиеВОферте
	|ГДЕ
	|	НЕ ЗаявлениеНаУчастиеВОферте.ПометкаУдаления
	|	И НЕ ЗаявлениеНаУчастиеВОферте.УведомитьОПриемеКлиента";
	ТекДата = ТекущаяДатаСеанса();
	Запрос.УстановитьПараметр("ТекущаяДата", ТекДата);
	Запрос.УстановитьПараметр("Вчера", НачалоДня(НачалоДня(ТекДата) - 1) );
	Запрос.УстановитьПараметр("ТриЧаса", ТриЧаса);
	РезультатЗапроса = Запрос.Выполнить();
	Если Не РезультатЗапроса.Пустой() Тогда
		
		ВнешнийИсточник = ПланыВидовХарактеристик.ВнешниеИсточники.РассылкаУведомленийОПоявленииНовыхЗаявленийНаУчастиеВОферте;
		НастройкиОбмена = ВнешниеДанные.ПолучитьПараметрыВнешнегоИсточника(ВнешнийИсточник).Настройка;
		Если НастройкиОбмена = Неопределено Тогда
			ТекстОшибки = "Не заданы параметры внешнего источника """ + Строка(ВнешнийИсточник) + """";
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстОшибки);
			ИмяСобытия = "Уведомления о появлении новых заявлений на участие в оферте не отправлены";
			ЗаписьЖурналаРегистрации(ИмяСобытия, УровеньЖурналаРегистрации.Ошибка, , , ТекстОшибки);
			Возврат;
		КонецЕсли;
		
		Выборка = РезультатЗапроса.Выбрать();
