Процедура ЭтапыОбработкиПоручений() Экспорт
	ИмяСобытия = "Этапы обработки поручений";
	ОбработкаОбъект = Обработки.ЭтапыОбработкиПоручений.Создать();
	ОбработкаОбъект.ЗаполнитьПоДокументам();
	Если ОбработкаОбъект.ДокументыКОбработке.Количество() > 0 Тогда
		Ошибка = ОбработкаОбъект.РезультатИсполненияЭтапаОбработки();
		Если ЗначениеЗаполнено(Ошибка) Тогда
			Уровень = УровеньЖурналаРегистрации.Ошибка;
			Комментарий = Ошибка;
		Иначе
			Уровень = УровеньЖурналаРегистрации.Информация;
			Комментарий = "Обработано поручений: " + ОбработкаОбъект.ДокументыКОбработке.Количество();
		КонецЕсли;	
	Иначе
		Уровень = УровеньЖурналаРегистрации.Предупреждение;
		Комментарий = "Поручений для обработки не обнаружено.";
	КонецЕсли;
	ЗаписьЖурналаРегистрации(ИмяСобытия, Уровень,,, Комментарий);
КонецПроцедуры

