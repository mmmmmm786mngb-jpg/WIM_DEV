			Кафка.ОбработкаВходящегоСообщения(ВнешнийИсточник);
		КонецЦикла;
	Иначе
		РегЗадание = Метаданные.РегламентныеЗадания.ЧтениеТопикаKafka;
		ОписаниеОшибки = "Не определен внешний источника для топика Kafka";
		ЗаписьЖурналаРегистрации(ОписаниеОшибки, УровеньЖурналаРегистрации.Ошибка,
			РегЗадание,
			РегЗадание.Наименование);
	КонецЕсли;
КонецПроцедуры

