// Выполняет регистрацию клиента
// Параметры:
//  КлючиСообщений - Строка - имена ключей сообщений строкой
Процедура РегистрацияКлиентов(КлючиСообщений) Экспорт
	
	МассивКлючей = СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(КлючиСообщений);
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	ЖурналВходящихСообщенийKafka.Ключ КАК Ключ,
	|	ЖурналВходящихСообщенийKafka.Сообщение КАК Сообщение,
	|	ЖурналВходящихСообщенийKafka.Идентификатор КАК Идентификатор,
	|	ЖурналВходящихСообщенийKafka.ВнешнийИсточник КАК ВнешнийИсточник
	|ИЗ
	|	РегистрСведений.ЖурналВходящихСообщенийKafka КАК ЖурналВходящихСообщенийKafka
	|ГДЕ
	|	НЕ ЖурналВходящихСообщенийKafka.Обработан
	|	И НЕ ЖурналВходящихСообщенийKafka.ОшибкаОбработки
	|	И ЖурналВходящихСообщенийKafka.Ключ В(&КлючиСообщений)
	|
	|УПОРЯДОЧИТЬ ПО
	|	ЖурналВходящихСообщенийKafka.Ключ,
	|	ЖурналВходящихСообщенийKafka.ПериодСообщения");
	Запрос.УстановитьПараметр("КлючиСообщений", МассивКлючей);
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		КлючСообщения = СокрЛП(НРег(Выборка.Ключ));
		Если КлючСообщения = "client" Тогда
			Обработки.РегистрацияКлиентаЧерезKafka.ВыполнитьРегистрациюКлиента(Выборка);
		ИначеЕсли КлючСообщения = "contract" Тогда
			Обработки.РегистрацияКлиентаЧерезKafka.ВыполнитьРегистрациюДоговора(Выборка);
		Иначе
			ЗаписьЖурналаРегистрации("Регистрация клиента",
				УровеньЖурналаРегистрации.Ошибка, , ,
				"Тип сообщения не определен: " + КлючСообщения);
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

// Читает сообщения из топика кафка и записывает в РС ЖурналВходящихСообщенийKafka
// Параметры:
