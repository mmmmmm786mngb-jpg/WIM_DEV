Процедура УведомленияОСкоромОкончанииПриемаИнструкцийПоWTRCНаДату(ДатаВыполнения) Экспорт
	
	ДатаВвода = Константы.ДатаВводаУведомленийОСкоромОкончанииПриемаИнструкцийПоWTRC.Получить();
	Если ЗначениеЗаполнено(ДатаВвода) И ДатаВвода <= НачалоДня(ДатаВыполнения) Тогда
		Обработчик = Обработки.УведомленияОСкоромОкончанииПриемаИнструкцийПоWTRC.Создать();
		Обработчик.ДатаУведомления = ДатаВыполнения;
		
		Если НЕ Обработчик.УведомлениеОтправлено() Тогда
			Обработчик.СформироватьСписокДепонентов();
			Обработчик.ОтправитьУведомление();
			Обработчик.ЗафиксироватьОтправленноеУведомлениеВРегистре();
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

Процедура ОбменПередачаПакетовФайловогоШлюза() Экспорт
	
	УзелОбмена = ПланыОбмена.ВыпискиПоЦеннымБумагам.НайтиПоКоду("000");
	
	НастройкаОбмена = ВнешниеДанные.ПолучитьПараметрыВнешнегоИсточника(ПланыВидовХарактеристик.ВнешниеИсточники.CustodyExchange).Настройка;
	
	Определение = Новый WSОпределения(НастройкаОбмена.ВебСервисАдрес,НастройкаОбмена.ВебСервисПользователь, НастройкаОбмена.ВебСервисПароль);
	Прокси = Новый WSПрокси(Определение, НастройкаОбмена.ВебСервисПространствоИмен, НастройкаОбмена.ВебСервисИмяСервиса, НастройкаОбмена.ВебСервисИмяТочкиПодключения);
	Прокси.Пользователь = НастройкаОбмена.ВебСервисПользователь;
	Прокси.Пароль = НастройкаОбмена.ВебСервисПароль;
	
	StatementOfSecuritiesType = Прокси.ФабрикаXDTO.Тип("StatementOfSecurities", "StatementOfSecurities");
	StatementOfSecurities = Прокси.ФабрикаXDTO.Создать(StatementOfSecuritiesType);
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Узел", УзелОбмена);
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 100
	|	ВходящийПакетИзФайловогоШлюзаИзменения.Ссылка КАК Ссылка,
	|	ДокументСсылка.ПолныйПуть КАК Source,
	|	ДокументСсылка.КодОперации КАК КодОперации,
	|	ДокументСсылка.Дата КАК Дата
	|ПОМЕСТИТЬ ИзмененныеДокументы
	|ИЗ
	|	Документ.ВходящийПакетИзФайловогоШлюза.Изменения КАК ВходящийПакетИзФайловогоШлюзаИзменения
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ВходящийПакетИзФайловогоШлюза КАК ДокументСсылка
	|		ПО ВходящийПакетИзФайловогоШлюзаИзменения.Ссылка = ДокументСсылка.Ссылка
	|ГДЕ
	|	ВходящийПакетИзФайловогоШлюзаИзменения.Узел = &Узел
	|
	|УПОРЯДОЧИТЬ ПО
	|	ДокументСсылка.МоментВремени УБЫВ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ИзмененныеДокументы.Ссылка КАК Ссылка,
	|	ИзмененныеДокументы.Source КАК Source,
	|	_ReportID.Значение КАК REPORT_ID,
	|	_RepForm.Значение КАК ВидЗапроса,
	|	_RegDate.Значение КАК RegDate,
	|	_TRegDate.Значение КАК TRegDate,
	|	ЕСТЬNULL(_StartDate.Значение, """") КАК StartDate,
	|	ЕСТЬNULL(_EndDate.Значение, """") КАК EndDate,
	|	_OrderType.Значение КАК ORD_TYPE_I,
	|	_DepoCode.Значение КАК DepoCode,
	|	_DepoAccount.Значение КАК DepoAccount,
	|	ИзмененныеДокументы.Дата КАК Дата
	|ПОМЕСТИТЬ РеквизитыШапки
	|ИЗ
	|	ИзмененныеДокументы КАК ИзмененныеДокументы
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ВходящийПакетИзФайловогоШлюза.СодержимоеФайла КАК _ReportID
	|		ПО ИзмененныеДокументы.Ссылка = _ReportID.Ссылка
	|			И (_ReportID.НомерСтрокиФайла = 1)
	|			И (_ReportID.ИмяФайла = ""reporth.dbf"")
	|			И (_ReportID.Элемент = ""IN_REG_NO"")
