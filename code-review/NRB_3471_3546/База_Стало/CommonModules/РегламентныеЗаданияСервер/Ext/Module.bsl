Процедура ОтправкаУведомленийОРаскрытииСпискаВладельцевЦБ() Экспорт
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	РСВ.Ссылка КАК ДокументРаскрытия
	|ИЗ
	|	Документ.РаскрытиеСпискаВладельцев КАК РСВ
	|ГДЕ
	|	НЕ РСВ.УведомлениеОтправлено
	|	И НЕ РСВ.ПометкаУдаления
	|	И РСВ.ДатаИсполнения <> ДАТАВРЕМЯ(1, 1, 1)
	|	И РСВ.ДатаКДПлан <> ДАТАВРЕМЯ(1, 1, 1)
	|	И ВЫРАЗИТЬ(РСВ.ЗаголовокСообщения КАК СТРОКА(100)) <> """"
	|	И ВЫРАЗИТЬ(РСВ.ТелоСообщения КАК СТРОКА(100)) <> """"
	|
	|УПОРЯДОЧИТЬ ПО
	|	РСВ.Дата");
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		Документы.РаскрытиеСпискаВладельцев.ОтправитьУведомлениеОРаскрытииСпискаВладельцевЦБ(Выборка.ДокументРаскрытия);
	КонецЦикла;
КонецПроцедуры

Процедура КонтрольНепринятыхНеснятыхЦБ() Экспорт
	
	ПредыдущийМесяц = ДобавитьМесяц(ТекущаяДата(), -1);
	
	ОбработкаОперацииПоОбслуживаниюЦБ = Обработки.ОбработкаОперацийПоОбслуживаниюЦБ.Создать();
	ОбработкаОперацииПоОбслуживаниюЦБ.ПериодНачало = НачалоМесяца(ПредыдущийМесяц);
	ОбработкаОперацииПоОбслуживаниюЦБ.ПериодКонец = КонецМесяца(ПредыдущийМесяц);
	
	ОбработкаОперацииПоОбслуживаниюЦБ.ВыполнитьКонтроль();
	
КонецПроцедуры	

Процедура АвтоматическаяПриемкаЦБНаОбслуживание() Экспорт
	
	ПредыдущийРабочийДень = ОбщегоНазначения.ПредыдущийРабочийДень(ТекущаяДата());
	
	ОбработкаОперацииПоОбслуживаниюЦБ = Обработки.ОбработкаОперацийПоОбслуживаниюЦБ.Создать();
	ОбработкаОперацииПоОбслуживаниюЦБ.ПериодНачало = НачалоДня(ПредыдущийРабочийДень);
	ОбработкаОперацииПоОбслуживаниюЦБ.ПериодКонец = КонецДня(ПредыдущийРабочийДень);
	
	ОбработкаОперацииПоОбслуживаниюЦБ.ОтобратьЦенныеБумаги(Истина, Ложь);
	ОбработкаОперацииПоОбслуживаниюЦБ.СоздатьПоручения(Истина, Ложь);
 	
КонецПроцедуры

Процедура АвтоматическоеСнятиеЦБСОбслуживания() Экспорт
	
	ТекущаяДата = ТекущаяДатаСеанса();
	ДатаНачала = ДобавитьМесяц(ТекущаяДата, -1);
	
	Обработки.ОбработкаОперацийПоОбслуживаниюЦБ.ВыполнитьСнятиеЗаПериод(ДатаНачала, ТекущаяДата);
	

КонецПроцедуры

Процедура ФормированиеУведомленийОИсполненийОперацийСЦБ() Экспорт
	
	
	Если Час(ТекущаяДата()) = 8 Тогда
		ПредыдущийДень = Истина;
	Иначе
		ПредыдущийДень = Ложь;
	КонецЕсли;
	Обработки.ФормированиеУведомленийООперацияхЦБ.ЗапуститьФормированиеУведомленийОИсполненииОперацииЦБ(ПредыдущийДень);
	
КонецПроцедуры

Процедура ПроверитьЗаписиВСЭДПоИсполненнымИнвентарнымПоручениям() Экспорт
	
	ДатаЗапуска = ТекущаяДатаСеанса();
	
	Если Не ОбщегоНазначения.РабочийДень(ДатаЗапуска) Тогда
		Возврат;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст =   
	"ВЫБРАТЬ
	|	ДокументПоручение.Ссылка КАК Ссылка,
	|	ДокументПоручение.РазделСчетаДепо КАК РазделСчетаДепо,
	|	ДокументПоручение.ЦБ КАК ЦБ,
	|	ДокументПоручение.ЦБ.ISIN КАК ISIN,
	|	ДокументПоручение.ВидОперацииД КАК ВидОперации
	|ИЗ
	|	Документ.Поручение КАК ДокументПоручение
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СтатусыПорученийВСЭД КАК СтатусыПорученийВСЭД
	|		ПО ДокументПоручение.Ссылка = СтатусыПорученийВСЭД.Поручение
	|			И (СтатусыПорученийВСЭД.Статус = &Статус)
	|ГДЕ
	|	ДокументПоручение.ДатаИсполненияПоручения МЕЖДУ &ДатаНачала И &ДатаОкончания
	|	И ДокументПоручение.ВидОперацииД В(&ВидыОперацииД)
	|	И ДокументПоручение.Проведен
	|	И СтатусыПорученийВСЭД.Поручение ЕСТЬ NULL 
	|	И НЕ ДокументПоручение.НомерПорученияВБО = """""; 					
					
	Запрос.УстановитьПараметр("ДатаНачала", НачалоДня(ДатаЗапуска));
	Запрос.УстановитьПараметр("ДатаОкончания", ДатаЗапуска - 600);	
	Запрос.УстановитьПараметр("Статус", Перечисления.СтатусыДокументовВСЭД.Загружено); 					
	
	Запрос.УстановитьПараметр("ВидыОперацииД", РегистрыСведений.ЭтапыОбработкиПоручений.ВидыОперацийИнвентарныхПоручений());
	
	Результат = Запрос.Выполнить();
	
	ТемаПисьма = "1С Депозитарий. Инвентарные поручения. Контроль выгрузки в СЭД.";
	
	Если Результат.Пустой() Тогда		
		ТекстПисьма = "<p>За "+Формат(ДатаЗапуска, "ДФ=dd.MM.yyyy")+" все исполненные инвентарные поручения отправлены в СЭД</p>";
        ВажностьСообщения = ВажностьИнтернетПочтовогоСообщения.Обычная;
	Иначе		
		ТекстПисьма = Документы.Поручение.ТекстУведомленияОбОтсутствииВыгрузкиВСЭДдляИнвентарныхПоручений(Результат, НачалоДня(ДатаЗапуска));		
		ВажностьСообщения = ВажностьИнтернетПочтовогоСообщения.Высокая;
	КонецЕсли;	
	
	ВнешнийИсточник = ПланыВидовХарактеристик.ВнешниеИсточники.РассылкаУведомленийОНаличииВыгрузкиВСЭДДляИнвентарныхПоручений;
	НастройкиОбмена = ВнешниеДанные.ПолучитьПараметрыВнешнегоИсточника(ВнешнийИсточник).Настройка;
	
	Если НастройкиОбмена = Неопределено Тогда
		ТекстОшибки = "Не заданы параметры внешнего источника " + ВнешнийИсточник;
		#Если Клиент Тогда
		ОбщегоНазначения.СообщитьОбОшибке(ТекстОшибки);
		#КонецЕсли
		ИмяСобытия = "Уведомления о проверке выгрузки в СЭД по исполненным инвентарным поручениям";
		ЗаписьЖурналаРегистрации(ИмяСобытия, УровеньЖурналаРегистрации.Ошибка,, ВнешнийИсточник, ТекстОшибки);
		Возврат;
	КонецЕсли;
	
	ПараметрыУведомления = Новый Соответствие;
	ПараметрыУведомления.Вставить("НастройкиОбмена",	НастройкиОбмена);
	ПараметрыУведомления.Вставить("Кодировка",			"UTF-8");
	ПараметрыУведомления.Вставить("ТемаПисьма",			ТемаПисьма);
	ПараметрыУведомления.Вставить("ТекстПисьма",		ТекстПисьма);
	ПараметрыУведомления.Вставить("ТипТекстаПисьма",	ТипТекстаПочтовогоСообщения.HTML);
	ПараметрыУведомления.Вставить("Важность",			ВажностьСообщения);
	
	РегистрыСведений.УведомленияКОтправке.ДобавитьУведомлениеКотправке(ПараметрыУведомления);
	
КонецПроцедуры

