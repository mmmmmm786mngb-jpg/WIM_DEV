	ВходящиеПараметры.Вставить("МетодикаРасчета", Перечисления.МетодикиРасчетаРыночныхЦен.Для481);
	ВходящиеПараметры.Вставить("ПоОстаткам", ПоОстаткам);
	ВходящиеПараметры.Вставить("ISINs", ISINs);
	ВходящиеПараметры.Вставить("ЗапросЦеныПоследнейСделкиПоISIN", ЗапросЦеныПоследнейСделкиПоISIN);
	ВходящиеПараметры.Вставить("БезЗапросаЦеныПоследнейСделки", Ложь);
	ВходящиеПараметры.Вставить("ДатаРасчета", ДатаРасчета);
		
	РасчетРыночныхЦенДля481.РассчитатьРыночныеЦены(ВходящиеПараметры, Отказ, ТекстОтказа, ОтправлятьУведомление);
	
	Если Отказ Тогда
		ВызватьИсключение ТекстОтказа;
	КонецЕсли;
	
КонецПроцедуры

// Обработчик регламентного задания СозданиеПорученийНаПереводЦБ
//
Процедура СозданиеПорученийНаПереводЦБ() Экспорт
	Ключ = "TransactionTransf";
	ОбработкаРегламентногоЗадания = Обработки.СозданиеПорученийНаПереводЦБПоДаннымKafka.Создать();
	ВыполнитьДействиеПоВходящемуСообщениюKafka(Ключ, ОбработкаРегламентногоЗадания);
КонецПроцедуры

// Обработчик регламентного задания КонтрольОперацийСОбособленнымиЦБ
Процедура КонтрольОперацийСОбособленнымиЦБ() Экспорт
	Отчет = Отчеты.КонтрольОперацийСОбособленнымиЦБ.Создать();
	ПредыдущийКалендарныйДень = НачалоДня(НачалоДня(ТекущаяДатаСеанса()) - 1);
	Отчет.ПериодНачало = ПредыдущийКалендарныйДень;
	Отчет.ПериодКонец = ПредыдущийКалендарныйДень;
	Ошибки = "";
	ДанныеДляЗаполнения = Отчет.ДанныеДляЗаполнения(Ошибки);
	Если ДанныеДляЗаполнения.Количество() > 0 Тогда
		ВнешнийИсточник = ПланыВидовХарактеристик.ВнешниеИсточники.РассылкаУведомленийОбОперацияхСОбособленнымиЦБ;
		НастройкаОтправки = ВнешниеДанные.ПолучитьПараметрыВнешнегоИсточника(ВнешнийИсточник).Настройка;
		Если Не НастройкаОтправки = Неопределено Тогда
			Результат = Новый ТабличныйДокумент;
			Отчет.ЗаполнитьОтчет(Результат, ДанныеДляЗаполнения);
			Расширение = "xlsx";
			ВременныйФайл = ПолучитьИмяВременногоФайла(Расширение);
			ПредыдущийКалендарныйДеньСтрокой = Формат(ПредыдущийКалендарныйДень, "ДФ=dd_MM_yyyy");
			ИмяВременногоФайла = "ИнформацияОЦенныхБумагахВОтношенииКоторыхОбеспеченОбособленныйУчетЗа_" + ПредыдущийКалендарныйДеньСтрокой;
			Результат.Записать(ВременныйФайл, ТипФайлаТабличногоДокумента.XLSX);
			Вложения = Новый Соответствие;
			ПараметрыУведомления = Новый Соответствие;
			ПараметрыУведомления.Вставить("НастройкиОбмена",	НастройкаОтправки);
			ПараметрыУведомления.Вставить("ТемаПисьма",			"Контроль за операциями с обособленными цб за дату " + ПредыдущийКалендарныйДеньСтрокой);
			ТекстПисьма = "За дату " + ПредыдущийКалендарныйДеньСтрокой
							+ " найдены операции с обособленными ценными бумагами. Информация в приложенном файле";
			Если Не ПустаяСтрока(Ошибки) Тогда
				ТекстПисьма = ТекстПисьма + Символы.ВК + Символы.ВК 
								+ "В процессе построения отчета выявлены следующие ошибки:" + Символы.ВК + Ошибки;
			КонецЕсли;
			ПараметрыУведомления.Вставить("ТекстПисьма",		ТекстПисьма);
			ПараметрыУведомления.Вставить("ТипТекстаПисьма",	ТипТекстаПочтовогоСообщения.HTML);
			ПараметрыУведомления.Вставить("Кодировка",			"windows-1251");
			ДанныеФайла = Новый ДвоичныеДанные(ВременныйФайл);
			Вложения.Вставить(ИмяВременногоФайла + "." + Расширение, ДанныеФайла);
			ПараметрыУведомления.Вставить("Вложения", Вложения);
			РегистрыСведений.УведомленияКОтправке.ДобавитьУведомлениеКотправке(ПараметрыУведомления);
			УдалитьФайлы(ВременныйФайл);
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

// Выполняет выгрузку измененных объектов, а именно ЦБ и юридических лиц - эмитентов в очередь Kafka для экспорта
// в другие системы (в момент написания этого комментария - только backQORT). Под объектами понимаются не только
// сами справочники, но и ряд регистров, содержащих связанную c основным объектом информацию (например, РС НоминалЦБ).
// С другой стороны, выгружается только часть реквизитов и именно эта часть реквизитов проверяется на наличие
// реальных изменений по сравнению с прошлой выгрузкой.
// Параметры:
//	ТолькоОбновлениеХэшей - Булево - необязательный параметр, при его наличии со значением Истина, не происходит реальной
//									выгрузки изменений в Kafka, но происходит перерасчет и обновление хэшей измененных
//									объектов в РС СтатусыОбъектовКОтправке, причем они получают статус обработанных.
Процедура ВыгрузкаОбъектовВKafka(ТолькоОбновлениеХэшей = Ложь) Экспорт
	Если Не ОбщегоНазначенияПовтИсп.ВыгрузкаИзмененныхОбъектовВКафкаВключена() И Не ТолькоОбновлениеХэшей Тогда
		Возврат;
	КонецЕсли;
	
	Задержка = 1;	// Задержка в секундах - нужно, чтобы в одну и ту же секунду не произошло три события:
					// изменение объекта, считывание измененных записей и еще одно изменение этого же объекта
					// в ту же секунду. В таком случае мы бы не поняли, что еще одно необработанное изменение
					// произошло, так как время последнего изменения осталось прежним.
	
	ДатаОтбора = ТекущаяДатаСеанса() - Задержка;
	ИзмененныеОбъекты = ВыгрузкаИзмененныхОбъектов.ИзмененныеОбъекты(ДатаОтбора);
	
	// Выгрузим все ценные бумаги, у которых есть реальные изменения и вместе с ними их эмитентов, если у них есть реальные изменения
	ВыгрузкаИзмененныхОбъектов.ВыгрузитьЦенныеБумаги(ИзмененныеОбъекты.ЦенныеБумаги, ИзмененныеОбъекты.Эмитенты, ТолькоОбновлениеХэшей);
	
	// Выгрузим остаток эмитентов у которых есть реальные изменения (по которым не было реальных изменений у ЦБ этих эмитентов и которые,
	// соответственно не были выгружены ранее вместе с ЦБ)
	ВыгрузкаИзмененныхОбъектов.ВыгрузитьЭмитентов(ИзмененныеОбъекты.Эмитенты, ТолькоОбновлениеХэшей);
КонецПроцедуры




