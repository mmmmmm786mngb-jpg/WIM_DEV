// Выполняет сверку статики ЦБ с backQORT
Процедура СверкаСтатикиЦБ_ДЕПО_BQ() Экспорт
	ОбработкаОбъект = Обработки.СверкаПоСтатикеЦБв1СиBQ.Создать();
	ОбработкаОбъект.ЗаполнитьСписокЦБ();
	ТабДокРезультат = ОбработкаОбъект.РезультатСверкиДанных();
	
	Если ОбработкаОбъект.НайденыРасхождения() Тогда
		ОтправитьУведомлениеОРасхожденияхВСтатике(ТабДокРезультат);
	КонецЕсли;
	
	ОбработкаОбъект = Неопределено;
КонецПроцедуры

Процедура ОтправитьУведомлениеОРасхожденияхВСтатике(ТабДокРезультат)
	ВнешнийИсточник = ПланыВидовХарактеристик.ВнешниеИсточники.РассылкаУведомленийОРасхожденияхПриСверкеСтатикиЦБМежду1СДепоИBQ;
	НастройкиОбмена = ВнешниеДанные.ПолучитьПараметрыВнешнегоИсточника(ВнешнийИсточник).Настройка;
	Если НастройкиОбмена = Неопределено Тогда
		ТекстОшибки = "Не заданы параметры внешнего источника """ + Строка(ВнешнийИсточник) + """";
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстОшибки);
		ИмяСобытия = "Уведомление о расхождениях в статике ЦБ с backQORT не отправлено";
		ЗаписьЖурналаРегистрации(ИмяСобытия, УровеньЖурналаРегистрации.Предупреждение, , , ТекстОшибки);
		Возврат;
	КонецЕсли;
	
	// Нам нужно получить из табличного документа HTML в виде текстовой строки. Можно писать НТML в файл на диск,
	// а можно в поток в память и из потока уже получить в виде текста (это конечно красивей, правильней и безопасней
	// чем временный файл создавать). Но у платформы 1С текущей версии 8.3.21.1674 оказывается есть не отраженное 
	// в справке ограничение: другие типы файлов, напрмер таблицы Excel в поток в памяти писать можно, а HTML почему-то
	// нет - только на диск. Поэтому делаем через временный файл.
	ИмяФайла = ПолучитьИмяВременногоФайла("html");
	ТабДокРезультат.Записать(ИмяФайла, ТипФайлаТабличногоДокумента.HTML);
	ТекстДок = Новый ТекстовыйДокумент;
	ТекстДок.Прочитать(ИмяФайла);
	ТекстПисьма = ТекстДок.ПолучитьТекст();
	УдалитьФайлы(ИмяФайла);
	
	ПараметрыУведомления = Новый Соответствие;
	ПараметрыУведомления.Вставить("НастройкиОбмена",	НастройкиОбмена);
	ПараметрыУведомления.Вставить("Кодировка",			"UTF-8");
	ПараметрыУведомления.Вставить("ТемаПисьма",			"Обнаружены расхождения в статике ЦБ между 1С ДЕПО и backQORT");
	ПараметрыУведомления.Вставить("ТекстПисьма",		ТекстПисьма);
	ПараметрыУведомления.Вставить("ТипТекстаПисьма",	ТипТекстаПочтовогоСообщения.HTML);
	ПараметрыУведомления.Вставить("Важность",			ВажностьИнтернетПочтовогоСообщения.Обычная);
	РегистрыСведений.УведомленияКОтправке.ДобавитьУведомлениеКОтправке(ПараметрыУведомления);
КонецПроцедуры

