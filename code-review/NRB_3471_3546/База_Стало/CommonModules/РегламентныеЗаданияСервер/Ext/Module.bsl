	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ВходящийПакетИзФайловогоШлюза.СодержимоеФайла КАК _OperDate
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ВходящийПакетИзФайловогоШлюза.СодержимоеФайла КАК _ToOperDate
	|			ПО _OperDate.Ссылка = _ToOperDate.Ссылка
	|				И _OperDate.НомерСтрокиФайла = _ToOperDate.НомерСтрокиФайла
	|				И (_ToOperDate.ИмяФайла = ""oprp.dbf"")
	|				И (_ToOperDate.Элемент = ""TOPERDAY"")
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ВходящийПакетИзФайловогоШлюза.СодержимоеФайла КАК _DepoAccount
	|			ПО _OperDate.Ссылка = _DepoAccount.Ссылка
	|				И _OperDate.НомерСтрокиФайла = _DepoAccount.НомерСтрокиФайла
	|				И (_DepoAccount.ИмяФайла = ""oprp.dbf"")
	|				И (_DepoAccount.Элемент = ""DEPO_ACC_C"")
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ВходящийПакетИзФайловогоШлюза.СодержимоеФайла КАК _DepoSection
	|			ПО _OperDate.Ссылка = _DepoSection.Ссылка
	|				И _OperDate.НомерСтрокиФайла = _DepoSection.НомерСтрокиФайла
	|				И (_DepoSection.ИмяФайла = ""oprp.dbf"")
	|				И (_DepoSection.Элемент = ""SECTION_CO"")
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ВходящийПакетИзФайловогоШлюза.СодержимоеФайла КАК _SecurityCode
	|			ПО _OperDate.Ссылка = _SecurityCode.Ссылка
	|				И _OperDate.НомерСтрокиФайла = _SecurityCode.НомерСтрокиФайла
	|				И (_SecurityCode.ИмяФайла = ""oprp.dbf"")
	|				И (_SecurityCode.Элемент = ""SECURITY_C"")
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ВходящийПакетИзФайловогоШлюза.СодержимоеФайла КАК _RegNo
	|			ПО _OperDate.Ссылка = _RegNo.Ссылка
	|				И _OperDate.НомерСтрокиФайла = _RegNo.НомерСтрокиФайла
	|				И (_RegNo.ИмяФайла = ""oprp.dbf"")
	|				И (_RegNo.Элемент = ""STATE_REGI"")
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ВходящийПакетИзФайловогоШлюза.СодержимоеФайла КАК _Amount
	|			ПО _OperDate.Ссылка = _Amount.Ссылка
	|				И _OperDate.НомерСтрокиФайла = _Amount.НомерСтрокиФайла
	|				И (_Amount.ИмяФайла = ""oprp.dbf"")
	|				И (_Amount.Элемент = ""BALANCE_TU"")
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ВходящийПакетИзФайловогоШлюза.СодержимоеФайла КАК _OrdersNumber
	|			ПО _OperDate.Ссылка = _OrdersNumber.Ссылка
	|				И _OperDate.НомерСтрокиФайла = _OrdersNumber.НомерСтрокиФайла
	|				И (_OrdersNumber.ИмяФайла = ""oprp.dbf"")
	|				И (_OrdersNumber.Элемент = ""DEPO_OPER_"")
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ВходящийПакетИзФайловогоШлюза.СодержимоеФайла КАК _OrdersType
	|			ПО _OperDate.Ссылка = _OrdersType.Ссылка
	|				И _OperDate.НомерСтрокиФайла = _OrdersType.НомерСтрокиФайла
	|				И (_OrdersType.ИмяФайла = ""oprp.dbf"")
	|				И (_OrdersType.Элемент = ""ORDERS_TYP"")
	|		ПО РеквизитыШапки.Ссылка = _OperDate.Ссылка
	|			И (_OperDate.ИмяФайла = ""oprp.dbf"")
	|			И (_OperDate.Элемент = ""OPERDAY"")
	|			И (_OperDate.Значение <> ДАТАВРЕМЯ(1, 1, 1))
	|ГДЕ
	|	РеквизитыШапки.ORD_TYPE_I = ""41""
	|
	|ОБЪЕДИНИТЬ
	|
	|ВЫБРАТЬ
	|	РеквизитыШапки.Ссылка,
	|	_SecurityCode.НомерСтрокиФайла,
	|	РеквизитыШапки.RegDate,
	|	РеквизитыШапки.TRegDate,
	|	РеквизитыШапки.DepoAccount,
	|	_DepoSection.Значение,
	|	_SecurityCode.Значение,
	|	_RegNo.Значение,
	|	_Amount.Значение,
	|	"""",
	|	""""
	|ИЗ
	|	РеквизитыШапки КАК РеквизитыШапки
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ВходящийПакетИзФайловогоШлюза.СодержимоеФайла КАК _SecurityCode
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ВходящийПакетИзФайловогоШлюза.СодержимоеФайла КАК _RegNo
	|			ПО _SecurityCode.Ссылка = _RegNo.Ссылка
	|				И _SecurityCode.НомерСтрокиФайла = _RegNo.НомерСтрокиФайла
	|				И (_RegNo.ИмяФайла = ""sttds.dbf"")
	|				И (_RegNo.Элемент = ""STATE_REGI"")
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ВходящийПакетИзФайловогоШлюза.СодержимоеФайла КАК _Amount
	|			ПО _SecurityCode.Ссылка = _Amount.Ссылка
	|				И _SecurityCode.НомерСтрокиФайла = _Amount.НомерСтрокиФайла
	|				И (_Amount.ИмяФайла = ""sttds.dbf"")
	|				И (_Amount.Элемент = ""SEQ_AMO"")
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ВходящийПакетИзФайловогоШлюза.СодержимоеФайла КАК _DepoSection
	|			ПО _SecurityCode.Ссылка = _DepoSection.Ссылка
	|				И _SecurityCode.НомерСтрокиФайла = _DepoSection.НомерСтрокиФайла
	|				И (_DepoSection.ИмяФайла = ""sttds.dbf"")
	|				И (_DepoSection.Элемент = ""SECTION_CO"")
	|		ПО РеквизитыШапки.Ссылка = _SecurityCode.Ссылка
	|			И (_SecurityCode.ИмяФайла = ""sttds.dbf"")
	|			И (_SecurityCode.Элемент = ""SECURITY_C"")
	|ГДЕ
	|	РеквизитыШапки.ORD_TYPE_I = ""40""";
	
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	ВыборкаРеквизитыШапки = РезультатЗапроса[2].Выбрать(); 
	ДанныеТабличнойЧасти = РезультатЗапроса[3].Выгрузить();
	
	Пока ВыборкаРеквизитыШапки.Следующий() Цикл
		
		StatementOfSecuritiesType = Прокси.ФабрикаXDTO.Тип("StatementOfSecurities", "StatementOfSecurities");
		StatementOfSecurities = Прокси.ФабрикаXDTO.Создать(StatementOfSecuritiesType);
		StatementOfSecurities.IdDoc 		= ВыборкаРеквизитыШапки.DepoCode + "_" + ВыборкаРеквизитыШапки.DepoAccount + "_" + СокрЛП(ВыборкаРеквизитыШапки.ORD_TYPE_I);
		StatementOfSecurities.RegDate 		= ВыборкаРеквизитыШапки.RegDate + Лев(ВыборкаРеквизитыШапки.TRegDate, 2) * 60 * 60 +Сред(ВыборкаРеквизитыШапки.TRegDate, 4,2) * 60 + Прав(ВыборкаРеквизитыШапки.TRegDate, 2);
		StatementOfSecurities.StartDate 	= ВыборкаРеквизитыШапки.StartDate;
		StatementOfSecurities.EndDate 		= ВыборкаРеквизитыШапки.EndDate;
		StatementOfSecurities.OrderType 	= СокрЛП(ВыборкаРеквизитыШапки.ORD_TYPE_I);
		StatementOfSecurities.Source	 	= СокрЛП(ВыборкаРеквизитыШапки.Source);
		StatementOfSecurities.DepoCode 		= СокрЛП(ВыборкаРеквизитыШапки.DepoCode);
		
		ТабличнаяЧастьДокумента = ДанныеТабличнойЧасти.НайтиСтроки(Новый Структура("Ссылка", ВыборкаРеквизитыШапки.Ссылка));
		Для каждого СтрокаДокумента из ТабличнаяЧастьДокумента Цикл
			КоличествоФормат = СтрЗаменить(СтрокаДокумента.Amount, Символ(32),"");
			
			Если СокрЛП(СтрокаДокумента.SecurityCode) = "" ИЛИ СокрЛП(СтрокаДокумента.SecurityCode) = "-" Тогда
				ЗаписьЖурналаРегистрации(
					"ВходящийПакетФайловогоШлюза.ОбменДанными", 
					УровеньЖурналаРегистрации.Информация,
					, 
					ВыборкаРеквизитыШапки.Ссылка, 
					"Не требуется выгрузка по ценной бумаге с кодом '" + СтрокаДокумента.SecurityCode + "'");
			Иначе
				SecurityType = Прокси.ФабрикаXDTO.Тип("StatementOfSecurities","Security");
				Security = Прокси.ФабрикаXDTO.Создать(SecurityType);
				Security.OperDate 		= СтрокаДокумента.OperDate + Лев(СтрокаДокумента.ToOperDate, 2) * 60 * 60 +Сред(СтрокаДокумента.ToOperDate, 4,2) * 60 + Прав(СтрокаДокумента.ToOperDate, 2);
				Security.DepoAccount 	= СокрЛП(СтрокаДокумента.DepoAccount);
				Security.DepoSection 	= СокрЛП(СтрокаДокумента.DepoSection);
				Security.SecurityCode 	= СокрЛП(СтрокаДокумента.SecurityCode);
				Security.RegNo 			= СокрЛП(СтрокаДокумента.RegNo);
				Security.Amount 		= ?(КоличествоФормат = "", 0, Число(КоличествоФормат));
				Security.OrdersNumber 	= СокрЛП(СтрокаДокумента.OrdersNumber);
				Security.OrdersType 	= СокрЛП(СтрокаДокумента.OrdersType);
				StatementOfSecurities.Securities.Добавить(Security);
			КонецЕсли;
		КонецЦикла;
		
		Если StatementOfSecurities.Securities.Количество() = 0 Тогда
			ЗаписьЖурналаРегистрации(
				"ВходящийПакетФайловогоШлюза.ОбменДанными", 
				УровеньЖурналаРегистрации.Информация,
				, 
				ВыборкаРеквизитыШапки.Ссылка, 
				"Не требуется выгрузка документа с пустой табличной частью");
			ПланыОбмена.УдалитьРегистрациюИзменений(УзелОбмена, ВыборкаРеквизитыШапки.Ссылка); 			
		Иначе			
			РезультатЗапроса = Прокси.StatementOfSecurities(StatementOfSecurities);
			Если РезультатЗапроса.Error = Истина Тогда
				ЗаписьЖурналаРегистрации("ВходящийПакетФайловогоШлюза.ОбменДанными", УровеньЖурналаРегистрации.Ошибка,, ВыборкаРеквизитыШапки.Ссылка, РезультатЗапроса.Message);
			ИначеЕсли РезультатЗапроса.EventLogLevel = 2 Тогда
				ЗаписьЖурналаРегистрации("ВходящийПакетФайловогоШлюза.ОбменДанными", УровеньЖурналаРегистрации.Предупреждение,, ВыборкаРеквизитыШапки.Ссылка, РезультатЗапроса.Message);
				ПланыОбмена.УдалитьРегистрациюИзменений(УзелОбмена, ВыборкаРеквизитыШапки.Ссылка);
			Иначе
				ЗаписьЖурналаРегистрации("ВходящийПакетФайловогоШлюза.ОбменДанными", УровеньЖурналаРегистрации.Информация,, ВыборкаРеквизитыШапки.Ссылка, "Документ загружен в 1С ИЦ");
				ПланыОбмена.УдалитьРегистрациюИзменений(УзелОбмена, ВыборкаРеквизитыШапки.Ссылка);
			КонецЕсли;
		КонецЕсли;		
	КонецЦикла;
	
КонецПроцедуры

