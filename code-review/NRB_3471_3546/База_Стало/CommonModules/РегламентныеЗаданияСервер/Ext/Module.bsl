// Процедура - Выполнить действие по входящему сообщению kafka
//
// Параметры:
//  Ключ							 - Строка						 - ресурс "Ключ"
//  ОбработкаРегламентногоЗадания	 - ЛюбаяСсылка					 - Ссылка на объект конфигурации,
//  					у которого, через "точку", можно вызвать процедуру ВыполнитьСоздание, для обработки записи регистра
//  ВнешнийИсточник					 - ПланВидовХарактеристикСсылка.ВнешниеИсточники - Измерение "ВнешнийИсточник" (по-умолчанию по всем источникам)
//
Процедура ВыполнитьДействиеПоВходящемуСообщениюKafka(Ключ, ОбработкаРегламентногоЗадания, ВнешнийИсточник = Неопределено) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Ключ"			, Ключ);
	Запрос.УстановитьПараметр("ПоВсемИсточникам", Не ЗначениеЗаполнено(ВнешнийИсточник));
	Запрос.УстановитьПараметр("ВнешнийИсточник"	, ВнешнийИсточник);
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ЖурналВходящихСообщенийKafka.Сообщение КАК Сообщение,
	|	ЖурналВходящихСообщенийKafka.Идентификатор КАК Идентификатор,
	|	ЖурналВходящихСообщенийKafka.ВнешнийИсточник КАК ВнешнийИсточник
	|ИЗ
	|	РегистрСведений.ЖурналВходящихСообщенийKafka КАК ЖурналВходящихСообщенийKafka
	|ГДЕ
	|	ЖурналВходящихСообщенийKafka.Обработан = ЛОЖЬ
	|	И ЖурналВходящихСообщенийKafka.ОшибкаОбработки = ЛОЖЬ
	|	И ВЫБОР
	|			КОГДА &ПоВсемИсточникам
	|				ТОГДА ИСТИНА
	|			ИНАЧЕ ЖурналВходящихСообщенийKafka.ВнешнийИсточник = &ВнешнийИсточник
	|		КОНЕЦ
	|	И ЖурналВходящихСообщенийKafka.Ключ = &Ключ
	|
	|УПОРЯДОЧИТЬ ПО
	|	ЖурналВходящихСообщенийKafka.ПериодСообщения";
	Если ТипЗнч(ВнешнийИсточник) = Тип("Массив") Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "ВнешнийИсточник = &ВнешнийИсточник", "ВнешнийИсточник В (&ВнешнийИсточник)");
	КонецЕсли;
	
	РезультатЗапроса = Запрос.Выполнить();
	Если Не РезультатЗапроса.Пустой() Тогда
		ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
		
		ВремяНачалаФормирования = ОценкаПроизводительности.НачатьЗамерВремени();
		ВесЗамера = ВыборкаДетальныеЗаписи.Количество();
		
		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			ОбработкаРегламентногоЗадания.ВыполнитьСоздание(ВыборкаДетальныеЗаписи);
		КонецЦикла;
		
		ОценкаПроизводительности.ЗакончитьЗамерВремени("ДействиеПоВходящемуСообщениюKafka" + Ключ, ВремяНачалаФормирования, ВесЗамера);
	КонецЕсли;
	
КонецПроцедуры

