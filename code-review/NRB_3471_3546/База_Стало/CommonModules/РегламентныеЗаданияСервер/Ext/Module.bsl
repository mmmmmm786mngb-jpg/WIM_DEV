// Обработчик регламентного задания ЗагрузкаСтатикиЦБизAPIRuData
//
// Параметры:
//  ДатаВремяОбновленияДанных	 - Дата - Дата время с которой выбираются обновления
//  ISIN						 - Массив - Массив номеров ISIN или строка с одним ISIN, Неопределено - по всем ISIN
//
Функция ЗагрузкаСтатикиЦБизAPIRuData(Знач ДатаВремяОбновленияДанных = Неопределено, ISIN = Неопределено) Экспорт
	
	Если Не ЗначениеЗаполнено(ДатаВремяОбновленияДанных) И Не ЗначениеЗаполнено(ISIN) Тогда
		ДатаВремяПоследнегоОбновленияДанных = ТекущаяДатаСеанса();
	Иначе
		ДатаВремяПоследнегоОбновленияДанных = Неопределено;
	КонецЕсли;
	
	Если ДатаВремяОбновленияДанных = Неопределено Тогда
		ДатаВремяОбновленияДанных =
			ОбщегоНазначенияПовтИсп.ЗначениеГлобальногоПараметра("101.RuData_ДатаВремяПоследнегоОбновленияДанных", Дата(1, 1, 1));
	КонецЕсли;
	
	ISINs = Новый Массив;
	Если ЗначениеЗаполнено(ISIN) Тогда
		Если ТипЗнч(ISIN) = Тип("Массив") Тогда
			ISINs = ISIN;
		ИначеЕсли ТипЗнч(ISIN) = Тип("Строка") Тогда
			ISINs = СтрРазделить(ISIN, ",", Ложь);
		Иначе
			ТекстОшибки = "Ошибка: ISIN должен быть массивом или строкой равной ISIN или строкой с ISIN через запятую.";
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстОшибки);
		КонецЕсли;
	КонецЕсли;
	
	ВходныеПараметры = Новый Структура;
	ВходныеПараметры.Вставить("ДатаВремяОбновленияДанных", ДатаВремяОбновленияДанных);
	ВходныеПараметры.Вставить("ISINs", ISINs);
	ВходныеПараметры.Вставить("ОбновитьБумагиВНеактуальномСтатусе", Истина);
	ВходныеПараметры.Вставить("ОбновитьЭмитентовВсехЗагружаемыхЦБ", Истина);
	
	УспешноеСозданиеОбновлениеЦенныхБумагИЭмитентов = RuDataAPI.СозданиеОбновлениеЦенныхБумагИЭмитентов(ВходныеПараметры);
	
	Если ЗначениеЗаполнено(ДатаВремяПоследнегоОбновленияДанных) И УспешноеСозданиеОбновлениеЦенныхБумагИЭмитентов Тогда
		РегистрыСведений.ПараметрыГлобальные.УстановитьЗначениеПараметра("101.RuData_ДатаВремяПоследнегоОбновленияДанных",
			ДатаВремяПоследнегоОбновленияДанных + 1);
	КонецЕсли;
	
	Возврат УспешноеСозданиеОбновлениеЦенныхБумагИЭмитентов;
	
КонецФункции

