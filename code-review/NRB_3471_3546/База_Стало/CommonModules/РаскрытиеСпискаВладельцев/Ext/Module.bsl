	// Если заполнено org тогда пишем
	Если Не ПараметрыТега.Получить("org")=Неопределено Тогда
		individual_document_t.org	= ПараметрыТега.Получить("org");
	КонецЕсли;
	// Если заполнено place тогда пишем
	Если Не ПараметрыТега.Получить("place")=Неопределено Тогда
		individual_document_t.reg_num	= ПараметрыТега.Получить("place");
	КонецЕсли;
	// Если заполнено doc_type тогда пишем
	Если Не ПараметрыТега.Получить("doc_type")=Неопределено Тогда
		individual_document_t.doc_type	= Partad_СформироватьТег_individual_document_type_t(ПространствоИмен, ПараметрыТега.Получить("doc_type"));
