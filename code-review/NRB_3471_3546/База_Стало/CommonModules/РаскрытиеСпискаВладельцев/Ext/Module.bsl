// ПараметрыТега:
//	units	- целая часть и десятичная дробь, при наличии fraction только целая
//	numerator - числитель (fraction)
//	denominator - знаменатель (fraction)

Функция Partad_СформироватьТег_quantity_in_unit_t(ПространствоИмен, ПараметрыТега = Неопределено) Экспорт
	ПараметрыТега	= ?(ПараметрыТега= Неопределено, Новый Соответствие, ПараметрыТега);
	//---
	quantity_in_unit_t	= ФабрикаXDTO.Создать(ФабрикаXDTO.Тип(ПространствоИмен, "quantity_in_unit_t"));
	// Если заполнено total тогда пишем
	Если Не ПараметрыТега.Получить("units")=Неопределено Тогда
		quantity_in_unit_t.units	= ПараметрыТега.Получить("units");
	КонецЕсли;
	// Если заполнено numerator или denominator тогда пишем
	Если Не ПараметрыТега.Получить("numerator")=Неопределено ИЛИ Не ПараметрыТега.Получить("denominator")=Неопределено Тогда
		fraction	= ФабрикаXDTO.Создать(ФабрикаXDTO.Тип(ПространствоИмен, "quantity_in_unit_t").Свойства.Получить("fraction").Тип);
		fraction.numerator		= ?(ПараметрыТега.Получить("numerator")=Неопределено, 0, ПараметрыТега.Получить("numerator"));
		fraction.denominator	= ?(ПараметрыТега.Получить("denominator")=Неопределено, 0, ПараметрыТега.Получить("denominator"));
	КонецЕсли;
	//---
	Возврат quantity_in_unit_t;	
КонецФункции

// ПараметрыТега:
//	block_type_code - код вида обременения / блокировки
//	narrative - текстовое наименование вида обременения / блокировки, заполняется при типе блокировки "OTHR".
//	restrictions - сведения об обременении / блокировке
//	pledgee_info - сведения о залоге, обязательно заполняются при типе блока "COLO"
	
Функция Partad_СформироватьТег_block_type_t(ПространствоИмен, ПараметрыТега = Неопределено) Экспорт
	ПараметрыТега	= ?(ПараметрыТега= Неопределено, Новый Соответствие, ПараметрыТега);
	//---
	block_type_t	= ФабрикаXDTO.Создать(ФабрикаXDTO.Тип(ПространствоИмен, "block_type_t"));
	// Если заполнено block_type_code тогда пишем
	Если Не ПараметрыТега.Получить("block_type_code")=Неопределено Тогда
		block_type_t.block_type_code	= ПараметрыТега.Получить("block_type_code");
	КонецЕсли;
	// Если заполнено narrative тогда пишем
	Если Не ПараметрыТега.Получить("narrative")=Неопределено Тогда
		block_type_t.narrative	= ПараметрыТега.Получить("narrative");
	КонецЕсли;
	// Если заполнено restrictions тогда пишем
	Если Не ПараметрыТега.Получить("restrictions")=Неопределено Тогда
		block_type_t.restrictions	= ПараметрыТега.Получить("restrictions");
	КонецЕсли;
	// Если заполнено pledgee_info тогда пишем
	Если Не ПараметрыТега.Получить("pledgee_info")=Неопределено Тогда
		Параметры_pledgee_info	= ПараметрыТега.Получить("pledgee_info");
		pledgee_info			= ФабрикаXDTO.Создать(ФабрикаXDTO.Тип(ПространствоИмен, "block_type_t").Свойства.Получить("pledgee_info").Тип);
		// Если заполнено account_dtls_v02 тогда пишем
		Если Не Параметры_pledgee_info.Получить("account_dtls_v02")=Неопределено Тогда
			pledgee_info.account_dtls_v02	= Partad_СформироватьТег_account_dtls_t(ПространствоИмен, Параметры_pledgee_info.Получить("account_dtls_v02"));
		КонецЕсли;	
		// Если заполнено pledgee тогда пишем
		Если Не Параметры_pledgee_info.Получить("pledgee")=Неопределено Тогда
			pledgee_info.pledgee	= Partad_СформироватьТег_party_dtls_t(ПространствоИмен, Параметры_pledgee_info.Получить("pledgee"));
		КонецЕсли;			
		// Если заполнено pledgee_narrative тогда пишем
		Если Не Параметры_pledgee_info.Получить("pledgee_narrative")=Неопределено Тогда
			pledgee_info.pledgee_narrative	= Параметры_pledgee_info.Получить("pledgee_narrative");
		КонецЕсли;
		//---
		block_type_t.pledgee_info	= pledgee_info;
	КонецЕсли;
	//---
	Возврат block_type_t;	
КонецФункции

// ПараметрыТега:
//	security	- Ценная бумага
//	total - Общее количество ЦБ
//	blocked - Блокировки и обременения

Функция Partad_СформироватьТег_security_balance_t(ПространствоИмен, ПараметрыТега = Неопределено) Экспорт
	ПараметрыТега	= ?(ПараметрыТега= Неопределено, Новый Соответствие, ПараметрыТега);
	//---
	security_balance_t	= ФабрикаXDTO.Создать(ФабрикаXDTO.Тип(ПространствоИмен, "security_balance_t"));
	// Если заполнено security тогда пишем
	Если Не ПараметрыТега.Получить("security")=Неопределено Тогда
		security_balance_t.security	= Partad_СформироватьТег_security_info_t(ПространствоИмен, ПараметрыТега.Получить("security"));
	КонецЕсли;
	// Если заполнено total тогда пишем
	Если Не ПараметрыТега.Получить("total")=Неопределено Тогда
		security_balance_t.total	= Partad_СформироватьТег_quantity_in_unit_t(ПространствоИмен, ПараметрыТега.Получить("total"));
	КонецЕсли;
	// Если заполнено blocked тогда пишем
	Если Не ПараметрыТега.Получить("blocked")=Неопределено Тогда
		blocked	= ФабрикаXDTO.Создать(ФабрикаXDTO.Тип(ПространствоИмен, "security_balance_t").Свойства.Получить("blocked").Тип);
		Для Каждого Строкаblocked ИЗ ПараметрыТега.Получить("blocked") Цикл
			blocked.quantity	= Partad_СформироватьТег_quantity_in_unit_t(ПространствоИмен, Строкаblocked.Значение.Получить("quantity"));
			blocked.block_type	= Partad_СформироватьТег_block_type_t(ПространствоИмен, Строкаblocked.Значение.Получить("block_type"));
		КонецЦикла;	
		security_balance_t.blocked.Добавить(blocked);
	КонецЕсли;	
	//---
	Возврат security_balance_t;	
КонецФункции

