// ПараметрыТега:
//	e_mail - информация о почтовых адресах;
//	phone_t - информация о телефонных номерах;

Функция Partad_СформироватьТег_party_contacts_t(ПространствоИмен, ПараметрыТега = Неопределено) Экспорт
	ПараметрыТега	= ?(ПараметрыТега= Неопределено, Новый Соответствие, ПараметрыТега);
	//---
	party_contacts_t	= ФабрикаXDTO.Создать(ФабрикаXDTO.Тип(ПространствоИмен, "party_contacts_t"));
	// Если заполнено e_mail тогда пишем
	Если Не ПараметрыТега.Получить("e_mail")=Неопределено Тогда
		Список_e_mail	= ПараметрыТега.Получить("e_mail");
		Для Каждого ЭлементСписка ИЗ Список_e_mail Цикл
			party_contacts_t.e_mail.Добавить(СокрЛП(ЭлементСписка.Значение));
		КонецЦикла;
	КонецЕсли;
	// Если заполнено phone_t тогда пишем
	Если Не ПараметрыТега.Получить("phone_t")=Неопределено Тогда
		Параметры_phone_t	= ПараметрыТега.Получить("phone_t");
		Если ТипЗнч(Параметры_phone_t) = Тип("Соответствие") Тогда
			party_contacts_t.phone_or_fax.Добавить(Partad_СформироватьТег_phone_t(ПространствоИмен, Параметры_phone_t));
		ИначеЕсли ТипЗнч(Параметры_phone_t) = Тип("СписокЗначений") Тогда
			Для Каждого Строка ИЗ Параметры_phone_t Цикл
				party_contacts_t.phone_or_fax.Добавить(Partad_СформироватьТег_phone_t(ПространствоИмен, Строка.Значение));
			КонецЦикла;		
		КонецЕсли;
	КонецЕсли;
	//---
	Возврат party_contacts_t;	
КонецФункции

