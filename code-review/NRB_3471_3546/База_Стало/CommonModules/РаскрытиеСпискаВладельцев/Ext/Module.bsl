// ПараметрыТега:
//	id - ИД для тега (обязательно);
//	issuer - код организации, ведущей справочник идентификационных кодов, не зарегистрированная НКО НРД (FCSM, NSDR, DCLC, OTHR);
//	scheme_name - Наименование схемы кодировки - для организаций, зарегистрированных НКО НРД;

Функция Partad_СформироватьТег_Id_t(ПространствоИмен, ПараметрыТега = Неопределено) Экспорт
	ПараметрыТега	= ?(ПараметрыТега= Неопределено, Новый Соответствие, ПараметрыТега);	
	// Создадим объект для заполнения
	Id_t	= ФабрикаXDTO.Создать(ФабрикаXDTO.Тип(ПространствоИмен, "id_t"));
	// id
	Id_t.id         = ?(ПараметрыТега.Получить("id")=Неопределено, "#", ПараметрыТега.Получить("id"));
	// issuer
	Если Не ПараметрыТега.Получить("issuer")=Неопределено Тогда
		Id_t.issuer		= ПараметрыТега.Получить("issuer");
	КонецЕсли;
	// scheme_name
	Если Не ПараметрыТега.Получить("scheme_name")=Неопределено Тогда
		Id_t.scheme_name= ПараметрыТега.Получить("scheme_name");
	КонецЕсли;
	// Вернем сформированный элемент
	Возврат Id_t;
КонецФункции

// ПараметрыТега:
//	party_id_name - Наименование стороны;
//	id_t - идентификация стороны (список или 1 ИД);

Функция Partad_СформироватьТег_party_id_name_t(ПространствоИмен, ПараметрыТега = Неопределено) Экспорт
	ПараметрыТега	= ?(ПараметрыТега= Неопределено, Новый Соответствие, ПараметрыТега);
	//---
	party_id_name_t		= ФабрикаXDTO.Создать(ФабрикаXDTO.Тип(ПространствоИмен, "party_id_name_t"));
	party_id_name_t.name= ?(ПараметрыТега.Получить("party_id_name")=Неопределено, "#", ПараметрыТега.Получить("party_id_name"));
	//---
	Параметры_id_t					= ПараметрыТега.Получить("id_t");
	// Если у party_id_name_t несколько ID, то должен быть передан список
	Если ТипЗнч(Параметры_id_t) = Тип("Соответствие") Тогда
		party_id_name_t.id.Добавить(Partad_СформироватьТег_Id_t(ПространствоИмен, ПараметрыТега.Получить("id_t")));
	ИначеЕсли ТипЗнч(Параметры_id_t) = Тип("СписокЗначений") Тогда
		Для Каждого Строка ИЗ Параметры_id_t Цикл
			party_id_name_t.id.Добавить(Partad_СформироватьТег_Id_t(ПространствоИмен, Строка.Значение));
		КонецЦикла;		
	КонецЕсли;
	//---
	Возврат party_id_name_t;	
КонецФункции

// ПараметрыТега:
//	account_type - тип счета;
//	id_t - идентификатор (номер) счета;

Функция Partad_СформироватьТег_account_dtls_t(ПространствоИмен, ПараметрыТега = Неопределено) Экспорт
	ПараметрыТега	= ?(ПараметрыТега= Неопределено, Новый Соответствие, ПараметрыТега);
	//---
	account_dtls	= ФабрикаXDTO.Создать(ФабрикаXDTO.Тип(ПространствоИмен, "account_dtls_t"));
	// Возможные значение (01-26 - Тип XDTO: account_type_et) или не заполняется
	Если Не ПараметрыТега.Получить("account_type")=Неопределено Тогда
		account_dtls.account_type	= ПараметрыТега.Получить("account_type");
	КонецЕсли;
	// account_dtls - account_id
	account_dtls.account_id		= Partad_СформироватьТег_Id_t(ПространствоИмен, ПараметрыТега.Получить("id_t"));
	//---
	Возврат account_dtls;
КонецФункции   

