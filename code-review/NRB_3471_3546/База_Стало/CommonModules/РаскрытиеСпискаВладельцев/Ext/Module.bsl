// ПараметрыТега:
//	account_type - тип счета;
//	id_t - идентификация (код) стороны (список или 1 ИД);
//	name - полное наименование юр. лица / ФИО физ. лица;
//	short_name - краткое наименование юр. лица / ФИО физ. лица;
//	ogrn - код ОГРН;
//  address_t - адресс (тип XDTO: address_t);
//	individual_or_entity - признак юр/физ лица;
//	entity_reg_dtls - информация о регистрации для юр. лица;
//	individual_document - информация о регистрации для физ. лица;

Функция Partad_СформироватьТег_party_dtls_t(ПространствоИмен, ПараметрыТега = Неопределено) Экспорт
	ПараметрыТега	= ?(ПараметрыТега= Неопределено, Новый Соответствие, ПараметрыТега);
	//---
	party_dtls_t	= ФабрикаXDTO.Создать(ФабрикаXDTO.Тип(ПространствоИмен, "party_dtls_t"));
	//---
	Параметры_id_t	= ПараметрыТега.Получить("id_t");
	// Если у party_dtls_t несколько ID, то должен быть передан список
	Если ТипЗнч(Параметры_id_t) = Тип("Соответствие") Тогда
		party_dtls_t.id.Добавить(Partad_СформироватьТег_Id_t(ПространствоИмен, ПараметрыТега.Получить("id_t")));
	ИначеЕсли ТипЗнч(Параметры_id_t) = Тип("СписокЗначений") Тогда
		Для Каждого Строка ИЗ Параметры_id_t Цикл
			party_dtls_t.id.Добавить(Partad_СформироватьТег_Id_t(ПространствоИмен, Строка.Значение));
		КонецЦикла;		
	КонецЕсли;
	// Если заполнено name тогда пишем
	Если Не ПараметрыТега.Получить("name")=Неопределено Тогда
		party_dtls_t.name	= ПараметрыТега.Получить("name");
	КонецЕсли;
	// Если заполнено short_name тогда пишем
	Если Не ПараметрыТега.Получить("short_name")=Неопределено Тогда
		party_dtls_t.short_name	= ПараметрыТега.Получить("short_name");
	КонецЕсли;
	// Если заполнено ogrn тогда пишем
	Если Не ПараметрыТега.Получить("ogrn")=Неопределено Тогда
		party_dtls_t.ogrn	= ПараметрыТега.Получить("ogrn");
	КонецЕсли;
	// Если заполнено address_t тогда пишем
	Если Не ПараметрыТега.Получить("address_t")=Неопределено Тогда
		party_dtls_t.address	= Partad_СформироватьТег_address_t(ПространствоИмен, ПараметрыТега.Получить("address_t"));
	КонецЕсли;
	// Если заполнено individual_or_entity тогда пишем (тип XDTO: individual_or_entity_et - LEGL, INDV)
	Если Не ПараметрыТега.Получить("individual_or_entity")=Неопределено Тогда
		party_dtls_t.individual_or_entity	= ПараметрыТега.Получить("individual_or_entity");
	КонецЕсли;
	// Если заполнено entity_reg_dtls тогда пишем (Тип XDTO: entity_reg_dtls_t)
	ПараметрыТега_entity_reg_dtls = ПараметрыТега.Получить("entity_reg_dtls");
	Если ТипЗнч(ПараметрыТега_entity_reg_dtls) = Тип("Соответствие") Тогда
		party_dtls_t.entity_reg_dtls.Добавить(Partad_СформироватьТег_entity_reg_dtls_t(ПространствоИмен, ПараметрыТега.Получить("entity_reg_dtls")));
	ИначеЕсли ТипЗнч(ПараметрыТега_entity_reg_dtls) = Тип("СписокЗначений") Тогда
		Для Каждого Строка ИЗ ПараметрыТега_entity_reg_dtls Цикл
			party_dtls_t.entity_reg_dtls.Добавить(Partad_СформироватьТег_entity_reg_dtls_t(ПространствоИмен, ПараметрыТега.Получить("entity_reg_dtls")));
		КонецЦикла;		
	КонецЕсли;
	// Если заполнено individual_document тогда пишем (Тип XDTO: individual_document_t)
	Если Не ПараметрыТега.Получить("individual_document")=Неопределено Тогда
		party_dtls_t.individual_document	= Partad_СформироватьТег_individual_document_t(ПространствоИмен, ПараметрыТега.Получить("individual_document"));
	КонецЕсли;
	//---
	Возврат party_dtls_t;
КонецФункции

