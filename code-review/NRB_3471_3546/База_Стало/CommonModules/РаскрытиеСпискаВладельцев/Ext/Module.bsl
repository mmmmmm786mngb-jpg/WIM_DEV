// ПараметрыТега:
//	security_classification	- вид ценной бумаги
//	security_classification_CFI - вид ценной бумаги (CFI)
//	financial_instrument_type - Код вида финансового инструмента
//	security_category - категория ценной бумаги по предоставляемым правам
//	security_type - тип ценной бумаги
//	nominal_value - номинал
//	state_reg_num - государственный рег. номер, номер правил ДУ ПИФ
//	state_reg_date - дата госю регистрации
//	ISIN_identifier - код ISIN ценной бумаги
//	proprietary_security_code - частный идентификационный код ценной бумаги

Функция Partad_СформироватьТег_security_info_t(ПространствоИмен, ПараметрыТега = Неопределено) Экспорт
	ПараметрыТега	= ?(ПараметрыТега= Неопределено, Новый Соответствие, ПараметрыТега);
	//---
	security_info_t	= ФабрикаXDTO.Создать(ФабрикаXDTO.Тип(ПространствоИмен, "security_info_t"));
	// Если заполнено security_classification тогда пишем
	Если Не ПараметрыТега.Получить("security_classification")=Неопределено Тогда
		security_info_t.security_classification	= ПараметрыТега.Получить("security_classification");
	КонецЕсли;
	// Если заполнено security_classification_CFI тогда пишем
	Если Не ПараметрыТега.Получить("security_classification_CFI")=Неопределено Тогда
		security_info_t.security_classification_CFI	= ПараметрыТега.Получить("security_classification_CFI");
	КонецЕсли;
	// Если заполнено financial_instrument_type тогда пишем
	Если Не ПараметрыТега.Получить("financial_instrument_type")=Неопределено Тогда
		security_info_t.financial_instrument_type	= ПараметрыТега.Получить("financial_instrument_type");
	КонецЕсли;
	// Если заполнено security_category тогда пишем
	Если Не ПараметрыТега.Получить("security_category")=Неопределено Тогда
		security_info_t.security_category	= ПараметрыТега.Получить("security_category");
	КонецЕсли;
	// Если заполнено security_type тогда пишем
	Если Не ПараметрыТега.Получить("security_type")=Неопределено Тогда
		security_info_t.security_category	= ПараметрыТега.Получить("security_type");
	КонецЕсли;
	// Если заполнено nominal_value тогда пишем
	Если Не ПараметрыТега.Получить("nominal_value")=Неопределено Тогда
		security_info_t.nominal_value	= Partad_СформироватьТег_currency_and_amount_t(ПространствоИмен, ПараметрыТега.Получить("nominal_value"));
	КонецЕсли;
	// Если заполнено state_reg_num тогда пишем
	Если Не ПараметрыТега.Получить("state_reg_num")=Неопределено Тогда
		security_info_t.state_reg_num	= ПараметрыТега.Получить("state_reg_num");
	КонецЕсли;
	// Если заполнено state_reg_date тогда пишем
	Если Не ПараметрыТега.Получить("state_reg_date")=Неопределено Тогда
		security_info_t.state_reg_date	= ПараметрыТега.Получить("state_reg_date");
	КонецЕсли;
	// Если заполнено ISIN_identifier тогда пишем
	Если Не ПараметрыТега.Получить("ISIN_identifier")=Неопределено Тогда
		security_info_t.ISIN_identifier	= ПараметрыТега.Получить("ISIN_identifier");
	КонецЕсли;
	// Если заполнено proprietary_security_code тогда пишем
	Если Не ПараметрыТега.Получить("proprietary_security_code")=Неопределено Тогда
		security_info_t.proprietary_security_code	= Partad_СформироватьТег_Id_t(ПространствоИмен, ПараметрыТега.Получить("proprietary_security_code"));
	КонецЕсли;
	//---
	Возврат security_info_t;	
КонецФункции

