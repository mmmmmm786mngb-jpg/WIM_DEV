//	bank_corr	- счет № / номер корреспондентского счета

Функция Partad_СформироватьТег_cash_rub_dtls_t(ПространствоИмен, ПараметрыТега = Неопределено) Экспорт
	ПараметрыТега	= ?(ПараметрыТега= Неопределено, Новый Соответствие, ПараметрыТега);
	//---
	cash_rub_dtls_t	= ФабрикаXDTO.Создать(ФабрикаXDTO.Тип(ПространствоИмен, "cash_rub_dtls_t"));
	// Если заполнено account тогда пишем
	Если Не ПараметрыТега.Получить("account")=Неопределено Тогда
		cash_rub_dtls_t.account	= Partad_СформироватьТег_Id_t(ПространствоИмен, ПараметрыТега.Получить("account"));
	КонецЕсли;
	// Если заполнено bank_name тогда пишем
	Если Не ПараметрыТега.Получить("bank_name")=Неопределено Тогда
		cash_rub_dtls_t.bank_name	= ПараметрыТега.Получить("bank_name");
	КонецЕсли;
	// Если заполнено bank_city тогда пишем
	Если Не ПараметрыТега.Получить("bank_city")=Неопределено Тогда
		cash_rub_dtls_t.bank_city	= ПараметрыТега.Получить("bank_city");
	КонецЕсли;
	// Если заполнено bank_city тогда пишем
	Если Не ПараметрыТега.Получить("ruic")=Неопределено Тогда
		cash_rub_dtls_t.ruic	= ПараметрыТега.Получить("ruic");
	КонецЕсли;
	// Если заполнено bank_corr тогда пишем
	Если Не ПараметрыТега.Получить("bank_corr")=Неопределено Тогда
		cash_rub_dtls_t.bank_corr	= Partad_СформироватьТег_Id_t(ПространствоИмен, ПараметрыТега.Получить("bank_corr"));
	КонецЕсли;
	//---
	Возврат cash_rub_dtls_t;	
КонецФункции

// ПараметрыТега:
//	pay_name	- Наименование юр. лица или ФИО физ. лица. (плательщика / получателя) платежа.
//	inn - код ИНН стороны (плательщика / получателя).
//	cash_rub_dtls - Информация о банковских реквизитах в рублях.
//	pay_add_info - Дополнительные реквизиты платежа (данные необходимые в поле "Назначение платежа")

Функция Partad_СформироватьТег_bank_prop_rub_t(ПространствоИмен, ПараметрыТега = Неопределено) Экспорт
	ПараметрыТега	= ?(ПараметрыТега= Неопределено, Новый Соответствие, ПараметрыТега);
	//---
	bank_prop_rub_t	= ФабрикаXDTO.Создать(ФабрикаXDTO.Тип(ПространствоИмен, "bank_prop_rub_t"));
	// Если заполнено pay_name тогда пишем
	Если Не ПараметрыТега.Получить("pay_name")=Неопределено Тогда
		bank_prop_rub_t.pay_name	= ПараметрыТега.Получить("pay_name");
	КонецЕсли;
	// Если заполнено inn тогда пишем
	Если Не ПараметрыТега.Получить("inn")=Неопределено Тогда
		bank_prop_rub_t.inn	= ПараметрыТега.Получить("inn");
	КонецЕсли;
	// Если заполнено pay_add_info тогда пишем
	Если Не ПараметрыТега.Получить("pay_add_info")=Неопределено Тогда
		bank_prop_rub_t.pay_add_info	= ПараметрыТега.Получить("pay_add_info");
	КонецЕсли;
	// Если заполнено cash_rub_dtls тогда пишем
	Если Не ПараметрыТега.Получить("cash_rub_dtls")=Неопределено Тогда
		bank_prop_rub_t.cash_rub_dtls	= Partad_СформироватьТег_cash_rub_dtls_t(ПространствоИмен, ПараметрыТега.Получить("cash_rub_dtls"));
	КонецЕсли;
	//---
	Возврат bank_prop_rub_t;	
КонецФункции

#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ТолстыйКлиентУправляемоеПриложение Тогда
	
Процедура ЗагрузитьФайлыРаскрытияСписковИзШлюза(ДатаНачала, ДатаОкончания) Экспорт
	
	МестоХраненияПоУмолчанию = ОбщегоНазначения.ЗначениеКонстанты("МестоХраненияПоУмолчанию");
	СчетДЕПОПоУмолчанию = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(МестоХраненияПоУмолчанию, "ОсновнойСчетДепо");
	
	ПараметрыИсточника = ВнешниеДанные.ПолучитьПараметрыВнешнегоИсточника(ПредопределенноеЗначение("ПланВидовХарактеристик.ВнешниеИсточники.ШлюзНРД"));
	
	ОбработкаЗагрузки = Обработки.ФормированиеРаскрытияСпискаВладельцев.Создать();
	ОбработкаЗагрузки.ПериодНачало 						= ДатаНачала;
	ОбработкаЗагрузки.ПериодКонец 						= ДатаОкончания;
	ОбработкаЗагрузки.ТипЗагрузкиСписковРаскрытия 		= Перечисления.ТипЗагрузкиСписковРаскрытия.PARTAD;
	ОбработкаЗагрузки.СчетДЕПО_ПоУмолчанию				= СчетДЕПОПоУмолчанию;
	
	ПутьККаталогу 				  = ПараметрыИсточника.Папка + "\inbox";
	СоответствиеФайловДляЗагрузки = Новый Соответствие;
	ОбработкаЗагрузки.НайтиФайлыДляЗагрузкиЗаПериод(СоответствиеФайловДляЗагрузки, ПутьККаталогу);
	
	Для каждого ФайлДляЗагрузки из СоответствиеФайловДляЗагрузки Цикл
		
		ОбработкаЗагрузки.ПутьККаталогу = ФайлДляЗагрузки.Значение;
		ОбработкаЗагрузки.ОбработатьZIPФайлы(Ложь);
		ОбработкаЗагрузки.СформироватьДокументы();
		
		НайденнаяСтрокаОбработки = ОбработкаЗагрузки.СоответствиеИдФайлам.Найти(ФайлДляЗагрузки.Значение + ФайлДляЗагрузки.Ключ, "ИмяАрхива");
		Если НЕ НайденнаяСтрокаОбработки = Неопределено И НЕ НайденнаяСтрокаОбработки.ОшибкаОбработки = Истина Тогда
			ОбработкаЗагрузки.ПеренестиФайлыРаскрытияВАрхив(ФайлДляЗагрузки.Значение, ПараметрыИсточника.Папка);
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

Процедура ЗагрузитьФайлыРаскрытияСписковИзЛуча(ДатаНачала, ДатаОкончания) Экспорт
	
	СчетДЕПОПоУмолчанию = Константы.МестоХраненияПоУмолчанию.Получить().ОсновнойСчетДепо;
	
	ПараметрыИсточника = ВнешниеДанные.ПолучитьПараметрыВнешнегоИсточника(ПредопределенноеЗначение("ПланВидовХарактеристик.ВнешниеИсточники.КаталогФайловРаскрытияСпискаВладельцевPartad"));
	
	ОбработкаЗагрузки = Обработки.ФормированиеРаскрытияСпискаВладельцев.Создать();
	ОбработкаЗагрузки.ПериодНачало 						= ДатаНачала;
	ОбработкаЗагрузки.ПериодКонец 						= ДатаОкончания;
	ОбработкаЗагрузки.ТипЗагрузкиСписковРаскрытия 		= Перечисления.ТипЗагрузкиСписковРаскрытия.PARTAD;
	ОбработкаЗагрузки.ПутьККаталогу 					= ПараметрыИсточника.Папка;
	ОбработкаЗагрузки.СчетДЕПО_ПоУмолчанию				= СчетДЕПОПоУмолчанию;
	
	ОбработкаЗагрузки.ПолучитьФайлыИзЛуча(ОбработкаЗагрузки.ПутьККаталогу);
	ОбработкаЗагрузки.ОбработатьZIPФайлы();
	ОбработкаЗагрузки.СформироватьДокументы();

КонецПроцедуры

// Формирует необходимые файлы выгрузки и документы ВыгрузкаРазделаРСВвВышестоящийДепозитарий, ТехническаяОперация, ИсходящийПакетВФайловыйШлюз
// В случае успешного формирования всего вышеназванного меняет статус раскрытия на Выгружено.
//
// Параметры:
//  РаскрытиеСпискаВладельцев	 - ДокументСсылка.РаскрытиеСпискаВладельцев		 - Раскрытие, информацию о котором нужно выгрузить.
//  Разделы						 - Неопределено, Ссылка, Массив, СписокЗначений	 - Разделы, которые необходимо выгрузить. Если не указано, то все не выгружавшиеся или с ошибкой.
// 
// Возвращаемое значение:
//  Структура - Информация о ходе выгрузки
//
Функция РезультатВыгрузкиРазделовРСВ(РаскрытиеСпискаВладельцев, Разделы = Неопределено) Экспорт
	
	Результат = Новый Структура("КоличествоВыгруженных,КоличествоОшибок,ТекстОшибок", 0, 0, "");
	
	Если Не ЗначениеЗаполнено(РаскрытиеСпискаВладельцев) Или ТипЗнч(РаскрытиеСпискаВладельцев) <> Тип("ДокументСсылка.РаскрытиеСпискаВладельцев") Тогда
		Результат.ТекстОшибок = "Некорректная ссылка на раскрытие!";
		Возврат Результат;
	КонецЕсли;
	
	ВнешнийИсточник = ПланыВидовХарактеристик.ВнешниеИсточники.ФайловыйШлюзКаталогКОтправке;
	Путь = СокрП(ВнешниеДанные.ПолучитьПараметрыВнешнегоИсточника(ВнешнийИсточник).Папка);
	Если ПустаяСтрока(Путь) Тогда
		Результат.ТекстОшибок = "Не заполнен внешний источник '"+ВнешнийИсточник+"'!";
		Возврат Результат ;
	КонецЕсли;
	
	Если Прав(Путь, 1) <> "\" Тогда
		Путь = Путь + "\";
	КонецЕсли;
		
	Раскрытие = РаскрытиеСпискаВладельцев.ПолучитьОбъект();
	
	СводныйРезультат = Раскрытие.ВыборкаДанныхЗаполненияСводногоРСВ();
	Если СводныйРезультат.Пустой() Тогда
		Результат.ТекстОшибок = "Некорректное сводное раскрытие!";
		Возврат Результат;
	КонецЕсли;
	
	Если Разделы = Неопределено Тогда
		Разделы = РазделыСводногоРаскрытия(РаскрытиеСпискаВладельцев);
		ВыгружатьПовторно = Ложь;
	Иначе
		ВыгружатьПовторно = Истина;
	КонецЕсли;
	
	Если Разделы.Количество() = 0 Тогда
		Результат.ТекстОшибок = "Нет разделов для выгрузки!";
		Возврат Результат;
	КонецЕсли;
	
	Запрос = Документы.ВыгрузкаРазделаРСВвВышестоящийДепозитарий.ЗапросСостоянийВыгрузкиРазделов(РаскрытиеСпискаВладельцев, Разделы);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		
		НачатьТранзакцию();
		
		ТекущаяДата = ТекущаяДатаСеанса();
		Если Выборка.ВыгрузкаРаздела = Null Тогда
			Выгрузка = Документы.ВыгрузкаРазделаРСВвВышестоящийДепозитарий.СоздатьДокумент();
			Выгрузка.Дата = ТекущаяДата;
			Выгрузка.РаскрытиеСпискаВладельцев = РаскрытиеСпискаВладельцев;
			Выгрузка.РазделСчетаДепоМХ = Выборка.Раздел;
			Выгрузка.Автор = ПараметрыСеанса.ТекущийПользователь;
			Выгрузка.Записать();
		Иначе
			Выгрузка = Выборка.ВыгрузкаРаздела.ПолучитьОбъект();
		КонецЕсли;
		
		ТехОперация = Выборка.ТехническаяОперация;
		Если ВыгружатьПовторно Или ТехОперация = Null Или Выборка.Статус = Перечисления.СтатусыДокументовФайловыйШлюз.ОшибкаФайловыйШлюз Тогда
			
			НовыйПорядковыйНомер = Документы.ТехническаяОперация.НовыйПорядковыйНомерВТечениеДня(ТекущаяДата);
			Если НовыйПорядковыйНомер = 0 Тогда
				ОтменитьТранзакцию();
				Результат.КоличествоОшибок = Результат.КоличествоОшибок + 1;
				Результат.ТекстОшибок = "Не удалось получить новый порядковый номер технической операции.";
				Продолжить;
			КонецЕсли;
			
			Номер = СокрЛП(Выгрузка.Номер);
			
			НоваяТехническаяОперация = Документы.ТехническаяОперация.СоздатьДокумент();
			НоваяТехническаяОперация.Дата = ТекущаяДата;
			НоваяТехническаяОперация.НомерДокументаОснования = Номер;
			НоваяТехническаяОперация.ДатаДокументаОснования = Выгрузка.Дата;
			НоваяТехническаяОперация.ТипОперации = "MT599";
			НоваяТехническаяОперация.КодОперации = "65/3";
			НоваяТехническаяОперация.ДокументОснование = Выгрузка.Ссылка;
			НоваяТехническаяОперация.ПорядковыйНомерВнутриДня = НовыйПорядковыйНомер;
			НоваяТехническаяОперация.УстановитьНовыйНомер();
			НоваяТехническаяОперация.Записать(РежимЗаписиДокумента.Проведение);
			
			РегистрыСведений.СостоянияДокументовВФайловомШлюзе.ДобавитьЗапись(ТекущаяДата
			, НоваяТехническаяОперация.Ссылка
			, Перечисления.СтатусыДокументовФайловыйШлюз.ВыгрузитьФайловыйШлюз);
			
			НовыйИсходящийПакет = Документы.ИсходящийПакетВФайловыйШлюз.СоздатьДокумент();
			НовыйИсходящийПакет.Дата = ТекущаяДата;
			НовыйИсходящийПакет.ДокументОснование = НоваяТехническаяОперация.Ссылка;
			НовыйИсходящийПакет.Статус = Перечисления.СтатусыДокументовФайловыйШлюз.ВыгруженоФайловыйШлюз;
			НовыйИсходящийПакет.Комментарий = "Создан автоматически в " + Формат(ТекущаяДата, "ДЛФ=DT");
			НовыйИсходящийПакет.УстановитьНовыйНомер();

			ИмяФайла = Документы.ВыгрузкаРазделаРСВвВышестоящийДепозитарий.ИмяФайлаВыгрузки(ТекущаяДата, НовыйИсходящийПакет.Номер);
			Если Не ЗначениеЗаполнено(ИмяФайла) Тогда
				ОтменитьТранзакцию();
				Результат.КоличествоОшибок = Результат.КоличествоОшибок + 1;
				Результат.ТекстОшибок = Результат.ТекстОшибок + "Не удалось определить имя пакета для раздела "+Выборка.КодРаздела+"! 
				|Возможно отсутствует исходящий пакет ФШ."+Символы.ПС;
				Продолжить;
			КонецЕсли;
			
			НовыйИсходящийПакет.ОтносительныйПуть = ИмяФайла;
			НовыйИсходящийПакет.ПолныйПуть = Путь+ИмяФайла;
			НовыйИсходящийПакет.Записать(РежимЗаписиДокумента.Запись);
			
			РегистрыСведений.СостоянияДокументовВФайловомШлюзе.ДобавитьЗапись(ТекущаяДатаСеанса()
			, НоваяТехническаяОперация.Ссылка
			, Перечисления.СтатусыДокументовФайловыйШлюз.ВыгруженоФайловыйШлюз
			, НовыйИсходящийПакет.Ссылка);
			
			РегистрыСведений.ДокументыВыгруженныеВЛуч.ДобавитьДокумент(Выгрузка.Ссылка
			, ТекущаяДата
			, НоваяТехническаяОперация.Номер
			, ""
			, ПараметрыСеанса.ТекущийПользователь);
			
			ВыборкаРазделСчетаМХ = СводныйРезультат.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
			Текст = Документы.ВыгрузкаРазделаРСВвВышестоящийДепозитарий.ТекстФайлаВыгрузки(Раскрытие.Ссылка, ВыборкаРазделСчетаМХ, Выборка.Раздел);
			Документы.ВыгрузкаРазделаРСВвВышестоящийДепозитарий.СформироватьФайлыВыгрузки(Текст, ИмяФайла, Путь);
			Выгрузка.ЗафиксироватьВыгрузку(ИмяФайла, Текст);
			
			Результат.КоличествоВыгруженных = Результат.КоличествоВыгруженных + 1;
			
		КонецЕсли;
		
		ЗафиксироватьТранзакцию();
		
	КонецЦикла;
	
	Если Результат.КоличествоВыгруженных > 0 И Результат.КоличествоОшибок = 0 И Раскрытие.Статус <> Перечисления.СтатусыРаскрытияСписковВладельцев.Выгружено Тогда
		Раскрытие.Статус = Перечисления.СтатусыРаскрытияСписковВладельцев.Выгружено;
		Раскрытие.Записать();
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Возвращает список всех разделов, фигуририрующих в сводном раскрытии
//
// Параметры:
//  РСВ	 - ДокументСсылка.РаскрытиеСпискаВладельцев, ДанныеФормыКоллекция	 - Раскрытие списка владельцев со сводным раскрытием
// 
// Возвращаемое значение:
//  СписокЗначений - Содержит СправочникСсылка.РазделСчетаДепоМХ
//
Функция РазделыСводногоРаскрытия(РСВ) Экспорт 
	
	Разделы = Новый СписокЗначений;
	
	Если РСВ.СводноеРаскрытие.Количество() > 0 Тогда
		Сводное = РСВ.СводноеРаскрытие.Выгрузить( , "РазделСчетаДепоМХ");
		Сводное.Свернуть("РазделСчетаДепоМХ");
		Для Каждого Строка Из Сводное Цикл
			Разделы.Добавить(Строка.РазделСчетаДепоМХ);
		КонецЦикла;
	Иначе
		Раскрытие = РСВ.Ссылка.ПолучитьОбъект();
		СводныйРезультат = Раскрытие.ВыборкаДанныхЗаполненияСводногоРСВ();
		Если Не СводныйРезультат.Пустой() Тогда
			Выборка = СводныйРезультат.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
			Пока Выборка.Следующий() Цикл
				Разделы.Добавить(Выборка.РазделСчетаДепоМХ);
			КонецЦикла;
		КонецЕсли;
	КонецЕсли;
	
	Возврат Разделы;
	
КонецФункции

