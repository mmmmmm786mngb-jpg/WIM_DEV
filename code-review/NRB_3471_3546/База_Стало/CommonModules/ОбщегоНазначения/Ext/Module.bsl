// ПРОЦЕДУРЫ И ФУНКЦИИ РАБОТЫ С ДАТАМИ И КАЛЕНДАРЕМ

// Эта функция проверяет дату - рабочий это день или нет по регистру сведений Календарь
// Параметры:
//	ДатаДляПроверки - дата - дата для проверки (по-умолчанию = Неопределено);
//	ЭтоРабочийДеньЦБРФ - Булево - если Истина, то проверяется является ли указанная дата рабочим днем ЦБ РФ,
//								если Ложь, проверяется явлется ли указанная дата рабочим днем нашей организации и ММВБ
// Возвращаемое значение:
//	Истина - это рабочий день, ложь - иначе
//
Функция РабочийДень(Знач ДатаДляПроверки = Неопределено, ЭтоРабочийДеньЦБРФ = Ложь) Экспорт
	
	Результат = Ложь;
	
	// Если дата не указана, проверяем текущую
	Если ДатаДляПроверки = Неопределено Тогда
		ДатаДляПроверки = ТекущаяДатаСеанса();
	КонецЕсли;
	
	Запрос = Новый Запрос();
	Запрос.Текст =
		"ВЫБРАТЬ
		|	Календарь.Значение КАК Выходной
		|ИЗ
		|	РегистрСведений.Календарь КАК Календарь
		|ГДЕ
		|	Календарь.Период = &Период";
	Если ЭтоРабочийДеньЦБРФ Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "Календарь.Значение", "Календарь.ЗначениеЦБРФ");
	КонецЕсли;
	Запрос.УстановитьПараметр("Период", НачалоДня(ДатаДляПроверки));
	РезультатЗапроса = Запрос.Выполнить();
	Если НЕ РезультатЗапроса.Пустой() Тогда
		Выборка = РезультатЗапроса.Выбрать();
		Если Выборка.Следующий() Тогда
			Если НЕ Выборка.Выходной Тогда
				Результат = Истина;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции // РабочийДень()

// Возвращает предыдущий рабочий день
//  - по регистру сведений Календарь
//
// Параметры:
//	ДатаДляПоиска	 - Дата	 - Дата, по отношению к которой определяется предыдущий рабочий день
//	ЭтоРабочийДеньЦБРФ - Булево - если Истина, то проверяется является ли указанная дата рабочим днем ЦБ РФ,
//								если Ложь, проверяется явлется ли указанная дата рабочим днем нашей организации и ММВБ
// 
// Возвращаемое значение:
//  Дата - Рабочий день
//
Функция ПредыдущийРабочийДень(Знач ДатаДляПоиска = Неопределено, ЭтоРабочийДеньЦБРФ = Ложь) Экспорт
	
	ДеньНеделиПонедельник = 1;
	ДеньНеделиВоскресенье = 7;
	СекундВСутках = ОбщегоНазначенияПовтИсп.СекундВСутках();
	
	// Если дата не указана, ищем относительно текущей
	Если ДатаДляПоиска = Неопределено Тогда
		ДатаДляПоиска = ТекущаяДатаСеанса();
	КонецЕсли;
	
	ДатаДляПоиска = НачалоДня(ДатаДляПоиска);
	
	Запрос = Новый Запрос();
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	МАКСИМУМ(Календарь.Период) КАК Период
	|ИЗ
	|	РегистрСведений.Календарь КАК Календарь
	|ГДЕ
	|	Календарь.Период < &Период
	|	И Календарь.Значение = ЛОЖЬ
	|
	|ИМЕЮЩИЕ
	|	НЕ МАКСИМУМ(Календарь.Период) ЕСТЬ NULL";
	Если ЭтоРабочийДеньЦБРФ Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "Календарь.Значение", "Календарь.ЗначениеЦБРФ");
	КонецЕсли;
	Запрос.УстановитьПараметр("Период", ДатаДляПоиска);
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() Тогда
		// Если календарь не заполнен - берем предыдущий день (кроме субботы и воскресенья)
		ДеньНеделиДаты = ДеньНедели(ДатаДляПоиска);
		Если ДеньНеделиДаты = ДеньНеделиВоскресенье Тогда
			СдвигСуток = 2;
		ИначеЕсли ДеньНеделиДаты = ДеньНеделиПонедельник Тогда
			СдвигСуток = 3;
		Иначе
			СдвигСуток = 1;
		КонецЕсли;
		Результат = ДатаДляПоиска - СдвигСуток * СекундВСутках;
	Иначе
		Выборка = РезультатЗапроса.Выбрать();
		Выборка.Следующий();
		Результат = Выборка.Период;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции // ПредыдущийРабочийДень()

// Добавляет к исходной дате указанное количество рабочих дней (Смещение) по регистру сведений Календарь.
// Если количество отрицательное - вычитает рабочие дни.
//
// Параметры:
//	ИсходнаяДата	 - Дата - дата от которой ведется отсчет
//	Смещение		 - Число - число рабочих дней которые нужно прибавить или отнять
//	ЭтоРабочийДеньЦБРФ - Булево - если Истина, рабочие дни считаются рабочими днями ЦБ РФ,
//								если Ложь, рабочими днями нашей организации и ММВБ
// Возвращаемое значение:
//	Дата - требуемый рабочий день или исходная дата, если в календаре не найден искомый рабочий день.
Функция ДобавитьРабочийДень(Знач ИсходнаяДата, Смещение, ЭтоРабочийДеньЦБРФ = Ложь) Экспорт
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Календарь.Период КАК Период
	|ИЗ
	|	РегистрСведений.Календарь КАК Календарь
	|ГДЕ
	|	Календарь.Период > &Период
	|	И НЕ Календарь.Значение		// Не выходной день
	|УПОРЯДОЧИТЬ ПО
	|	Период ВОЗР
	|";
	Если ЭтоРабочийДеньЦБРФ Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "Календарь.Значение", "Календарь.ЗначениеЦБРФ");
	КонецЕсли;
	ИсходнаяДата = НачалоДня(ИсходнаяДата);
	Запрос.УстановитьПараметр("Период", ИсходнаяДата);
	ТребуемыйДень = ИсходнаяДата;
	Если Смещение > 0 Тогда
		КоличествоРабочихДней = Смещение;
	ИначеЕсли Смещение < 0 Тогда
		КоличествоРабочихДней = -Смещение;
		Запрос.Текст = СтрЗаменить(Запрос.Текст, ">", "<");
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "ВОЗР", "УБЫВ");
	Иначе
		Возврат ТребуемыйДень;
	КонецЕсли;
	ТабРабочихДней = Запрос.Выполнить().Выгрузить();
	Если КоличествоРабочихДней <= ТабРабочихДней.Количество() Тогда
		ТребуемыйДень = ТабРабочихДней[КоличествоРабочихДней-1].Период;
	КонецЕсли;
	Возврат ТребуемыйДень;
КонецФункции // ДобавитьРабочийДень()

// Добавляет к исходной дате указанное количество рабочих дней (Смещение) по регистру сведений Календарь.
// Если в календаре не найден искомый рабочий день, добавляет (вычитает) календарные дни.
// Если количество отрицательное - вычитает рабочие/календарные дни.
// Параметры:
//	ИсходнаяДата	 - Дата - дата от которой ведется отсчет
//	Смещение		 - Число - число рабочих дней которые нужно прибавить или отнять
//	ЭтоРабочийДеньЦБРФ - Булево - если Истина, рабочие дни считаются рабочими днями ЦБ РФ,
//								если Ложь, рабочими днями нашей организации и ММВБ
//
// Возвращаемое значение:
//	Дата - требуемый рабочий день или календарный, если в календаре не найден искомый рабочий день.
Функция ДобавитьРабочийКалендарныйДень(Знач ИсходнаяДата, Смещение, ЭтоРабочийДеньЦБРФ = Ложь) Экспорт
	ИсходнаяДата = НачалоДня(ИсходнаяДата);
	Дата = ОбщегоНазначения.ДобавитьРабочийДень(ИсходнаяДата, Смещение, ЭтоРабочийДеньЦБРФ);
	СекундВЧасе = 3600;
	ЧасовВСутках = 24;
	Если Дата = ИсходнаяДата Тогда
		Дата = ИсходнаяДата + Смещение * ЧасовВСутках * СекундВЧасе;
	Конецесли;
	Возврат Дата;
КонецФункции

// Копирует время из даты-источника с дату-приемник
Процедура СкопироватьВремя(Приемник, Источник) Экспорт
	Приемник = Дата(Год(Приемник), Месяц(Приемник), День(Приемник), Час(Источник), Минута(Источник), Секунда(Источник));
КонецПроцедуры

// Возвращает массив календарных месяцев (в виде дат начала месяца), входящих в указанный период хотя бы частично,
// например в период с 30.06.2024 по 02.07.2024 входят два месяца - июнь и июль [01.06.2024 , 01.07.2024].
// Параметры:
//	ДатаНачала - Дата - дата без времени
//	ДатаОкончания - Дата - дата без времени
// Возвращаемое значение:
//	Массив - массив дат начала календарных месяцев, входящих в указанный период хотя бы частично.
Функция КалендарныеМесяцыПопавшиеВПериод(ДатаНачала, ДатаОкончания) Экспорт
	МесяцыПопавшиеВПериод = Новый Массив;
	
	ТекущийМесяц = НачалоМесяца(ДатаНачала);
	ПоследнийМесяц = НачалоМесяца(ДатаОкончания);
	Пока ТекущийМесяц <= ПоследнийМесяц Цикл
		МесяцыПопавшиеВПериод.Добавить(ТекущийМесяц);
		ТекущийМесяц = КонецМесяца(ТекущийМесяц) + 1;
	КонецЦикла;
	
	Возврат МесяцыПопавшиеВПериод;
КонецФункции

