// Функция возвращает дату для документа, введенного на Основании
// Если Основание - это поручение, возвращается ДатаИсполненияПоручения
//
// Параметры:
//  Основание  - ДокументОбъект или ДокументСсылка - документ, по которому определяется дата
//
// Возвращаемое значение:
//  дата
//
Функция ДатаДокумента(Основание) Экспорт
	Если ТипЗнч(Основание) = Тип("ДокументСсылка.Поручение") ИЛИ ТипЗнч(Основание) = Тип("ДокументОбъект.Поручение") Тогда
		Если ЗначениеЗаполнено(Основание.ДатаИсполненияПоручения) Тогда
			Возврат Основание.ДатаИсполненияПоручения;
		КонецЕсли;
	КонецЕсли;	
	
	Если ТекущаяДата() > Основание.Дата Тогда
		ДатаДокумента	= ТекущаяДата();
	иначе
		ДатаДокумента	= Основание.Дата;
	КонецЕсли;
	
	Возврат ДатаДокумента;
	
КонецФункции // ДатаДокумента()

