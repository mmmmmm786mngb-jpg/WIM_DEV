Функция ПолучитьПараметрыУчетаПоЦБ(Портфель, Дата) Экспорт 
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	УчетнаяПолитикаЦенныеБумагиСрезПоследних.СпособСписанияВУ
	               |ИЗ
	               |	РегистрСведений.УчетнаяПолитикаЦенныеБумаги.СрезПоследних(&МоментВремени, Портфель = &Портфель) КАК УчетнаяПолитикаЦенныеБумагиСрезПоследних";	
	Запрос.УстановитьПараметр("МоментВремени", Дата);
	Запрос.УстановитьПараметр("Портфель", Портфель);
	
	Результат = Запрос.Выполнить();
	Если Результат.Пустой() Тогда
		ВыводСообщения("На дату "+Формат(Дата, "ДЛФ = Д")+" данных по параметрам учета ЦБ для портфеля "+Портфель+" нет. Документ не проведен!", СтатусСообщения.ОченьВажное);
		Возврат Неопределено;
	КонецЕсли;
	
	Выборка = Результат.Выбрать();
	
	Если Выборка.Следующий() Тогда
		
		Если Выборка.СпособСписанияВУ.Пустая() Тогда
			
			ВыводСообщения("На дату "+Формат(Дата, "ДЛФ = Д")+" не определен метод списания ЦБ. Документ не проведен!", СтатусСообщения.ОченьВажное);
			Возврат Неопределено;
			
		КонецЕсли;
		
	КонецЕсли;

	Возврат Выборка;
	
КонецФункции

Функция ПолучитьОсновнуюОрганизацию(ТекущийПользователь) Экспорт
	
	Данные = Новый Структура("Пользователь,Настройка", ТекущийПользователь,ПланыВидовХарактеристик.НастройкиПользователей.ОсновнаяОрганизация);
	ОсновнаяОрганизация = РегистрыСведений.НастройкиПользователей.Получить(Данные).Значение;
	
	Возврат ОсновнаяОрганизация;
	
КонецФункции

// Процедура - обработчик ввода нового документа.
