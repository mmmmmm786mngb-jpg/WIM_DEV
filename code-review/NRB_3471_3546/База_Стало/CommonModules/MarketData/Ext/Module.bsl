			+ ТекстЗаголовка + ПС + Символы.ПС;
	
	Ширина300 = "300";
	ПараметрыТрансформацииВHTML = Новый Структура;
	ПараметрыТрансформацииВHTML.Вставить("ПунктПорядкуИспользуется", Истина);
	ПараметрыТрансформацииВHTML.Вставить("ЦветШапки", "eadbaf");
	ПараметрыТрансформацииВHTML.Вставить("ШиринаТаблицы", "900");
	ПараметрыТрансформацииВHTML.Вставить("Ширина1", "200");
	ПараметрыТрансформацииВHTML.Вставить("Ширина2", "500");
	ПараметрыТрансформацииВHTML.Вставить("Ширина3", Ширина300);
	ПараметрыТрансформацииВHTML.Вставить("Ширина4", Ширина300);
	ПараметрыТрансформацииВHTML.Вставить("Ширина5", Ширина300);
	ПараметрыТрансформацииВHTML.Вставить("Заголовок1", "Код");
	ПараметрыТрансформацииВHTML.Вставить("Заголовок2", "Наименование");
	ПараметрыТрансформацииВHTML.Вставить("Заголовок3", "Статус ""Международная компания""");
	ПараметрыТрансформацииВHTML.Вставить("Заголовок4", "Дата начала действия");
	ПараметрыТрансформацииВHTML.Вставить("Заголовок5", "Признак регистрации международной компании");
	
	ТаблицаHTML = ОбщегоНазначения.ТаблицаЗначенийВТаблицуHTML(ТаблицаСтатусовЭмитентов, ПараметрыТрансформацииВHTML);
	Организация = СокрЛП(ОбщегоНазначенияПовтИсп.ОрганизацияПоУмолчанию().Наименование);
	
	Текст = Текст + ВключитьBold + ТаблицаHTML + ОтключитьBold
		+ ПС + Символы.ПС + "Требуется проверить эти данные.";
	
	ГруппаЭмитентыКИсключению = Новый Массив;
	ГруппаЭмитентыКИсключению.Добавить(Справочники.Контрагенты.Эмитенты);
	ПрочиеКонтрагенты = Справочники.Контрагенты.КонтрагентыПоЮрФизЛицам(ЭмитентыКСменеСтатуса, ГруппаЭмитентыКИсключению);
	Если ПрочиеКонтрагенты.Количество() > 0 Тогда
		Текст = Текст + ВключитьКрасный + " Предупреждение! "
			+ " Существуют Контрагенты (не Эмитенты) связанные с Юр. лицами по которым меняется статус 'Международная компания'"
			+ ОтключитьКрасный + ПС + Символы.ПС  + ПС + Символы.ПС;
		Для Каждого ПрочийКонтрагент Из ПрочиеКонтрагенты Цикл
			РеквизитыКонтрагента = ОбщегоНазначения.ПолучитьЗначенияРеквизитов(ПрочийКонтрагент, "Код, Родитель");
			ОписаниеКонтрагента = СтрШаблон(" - %1 [%2] [%3]", ПрочийКонтрагент, РеквизитыКонтрагента.Родитель, РеквизитыКонтрагента.Код);
			Текст = Текст + ВключитьBold + ОписаниеКонтрагента + ОтключитьBold + ПС + Символы.ПС;
