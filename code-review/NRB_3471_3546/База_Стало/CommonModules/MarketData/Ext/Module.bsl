		+ ПС + Символы.ПС;
	
	ГиперссылкаСправочники = "https://"
		+ "confluence/pages/viewpage.action?pageId=215866524#id-Справочники-Списоккодовторговыхплощадокисточниковкотировок"; // BSLLS:Typo-off
	ГиперссылкаSecuritiesQuotes = "https://confluence/pages/viewpage.action?pageId=246387520";
	Текст = Текст + "1) Обновить <a href="
		+ ГиперссылкаСправочники + ">Справочник</a> торговых площадок для модели данных <a href="
		+ ГиперссылкаSecuritiesQuotes + ">SecuritiesQuotes</a>." + ПС + Символы.ПС;
	
	Текст = Текст + "2) В BQ добавить новую секцию торговой площадки в ""Справочники/Торги/Секции торговых площадок""."
