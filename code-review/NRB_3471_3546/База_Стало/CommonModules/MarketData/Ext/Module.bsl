#Область ЗагрузкаКурсовВалют

Процедура ОбработатьКурсыВалютИнтерфакс(ПараметрыОбработки, Отказ, ТекстОтказа, ТабличныйДокумент, ЛогПолученныхДанных)
	
	ДатаКурса			 = ПараметрыОбработки.ДатаКурса;
	БазоваяВалюта		 = ПараметрыОбработки.БазоваяВалюта;
	СписокВалют			 = ПараметрыОбработки.СписокВалют;
	Макет				 = ПараметрыОбработки.Макет;
	Сессия				 = ПараметрыОбработки.Сессия;
	
	БазоваяВалютаСимвольныйКод = ?(БазоваяВалюта.Наименование = "SUR", "RUB", БазоваяВалюта.Наименование);
	
	Для Каждого Валюта Из СписокВалют Цикл
		
		ОтказЗагрузки	 = Ложь;
		ТекстОтказа		 = "";
		
		ПараметрыМетода = Новый Структура;
		ПараметрыМетода.Вставить("from", 	СокрЛП(Валюта.Наименование));
		ПараметрыМетода.Вставить("to", 		СокрЛП(БазоваяВалютаСимвольныйКод));
		ПараметрыМетода.Вставить("date", 	ДатаКурса);
		
		// Лог полученных данных
		Если ТипЗнч(ЛогПолученныхДанных) = Тип("ТекстовыйДокумент") Тогда
			ТекстЛога = СтрШаблон(НСтр("ru='Параметры запроса: from = %1; to = %2; date = %3.'"),
				ПараметрыМетода.from, ПараметрыМетода.to, ПараметрыМетода.date);
			ЛогПолученныхДанных.ДобавитьСтроку(ТекстЛога);
		КонецЕсли;
		
		Если ТестированиеVanessa.ЭтоТест() Тогда
			ПолученныеДанные = Новый Массив;
		Иначе
			ПолученныеДанные
				= RuDataAPI.ДанныеМетода_V2_Archive_CurrencyRate(ПараметрыМетода, ОтказЗагрузки, ТекстОтказа, ЛогПолученныхДанных, Сессия);
		КонецЕсли;
		
		Отказ = Отказ Или ОтказЗагрузки;
		
		Комментарий	 = "";
		Статус		 = "";
		ЗаписатьКурсВалютыИнтерфакс(ПолученныеДанные, Валюта, ДатаКурса, Комментарий, Статус, ОтказЗагрузки, ТекстОтказа);
		
		// Выводим лог по созданным документам
		Если ТабличныйДокумент <> Неопределено Тогда
			ОбластьСтрока = Макет.ПолучитьОбласть("Строка");
			ОбластьСтрока.Параметры.Объект 			= Строка(Валюта) + "/" + Строка(БазоваяВалюта);
			ОбластьСтрока.Параметры.Статус 			= Статус;
			ОбластьСтрока.Параметры.Комментарий 	= Комментарий;
			ТабличныйДокумент.Вывести(ОбластьСтрока, 0);
		КонецЕсли;
		
	КонецЦикла; // По валютам
	
КонецПроцедуры

Процедура ЗаписатьКурсВалютыИнтерфакс(ПолученныеДанные, Валюта, ДатаКурса, Комментарий, Статус, ОтказЗагрузки, ТекстОтказа)
	
	ФорматДаты			 = "ДФ=dd.MM.yyyy";
	ШаблонОшибки		 = "ru='Не удалось загрузить курс валюты %1 за %2. Техническая информация: %3'";
	СтатусОшибка		 = "Ошибка";
	
	Если Не ОтказЗагрузки И ПолученныеДанные.Количество() > 0 Тогда
		
		Попытка
			
			Курс = ПолученныеДанные[0].rate;
			
			Если ЗначениеЗаполнено(Курс) Тогда
				
				НаборЗаписей = РегистрыСведений.КурсыВалют.СоздатьНаборЗаписей();
				НаборЗаписей.Отбор.Валюта.Установить(Валюта);
				НаборЗаписей.Отбор.Период.Установить(ДатаКурса);
				
				Запись = НаборЗаписей.Добавить();
				Запись.Период 					= ДатаКурса;
				Запись.Валюта 					= Валюта;
				ЗаписатьКурсРассчитавКратность(Запись, Курс);
				
				НаборЗаписей.Записать();
				
				Комментарий = НСтр("ru='Дата курса: %1; Курс: %2'");
				Комментарий = СтрШаблон(Комментарий, Формат(ДатаКурса, ФорматДаты), Курс);
				Статус = "Загружен";
				
			Иначе
				ТехническаяИнформация = ПолученныеДанные[0].error;
				Если Не ЗначениеЗаполнено(ТехническаяИнформация) Тогда
					ТехническаяИнформация = " данные о курсе отсутствуют [сервис Интерфакс]";
				КонецЕсли;
				Комментарий = НСтр(ШаблонОшибки);
				Комментарий = СтрШаблон(Комментарий, Валюта, Формат(ДатаКурса, ФорматДаты), ТехническаяИнформация);
				Статус = "Предупреждение";
				
			КонецЕсли;
			
		Исключение
			
			Комментарий = НСтр(ШаблонОшибки);
			Комментарий = СтрШаблон(Комментарий, Валюта, Формат(ДатаКурса, ФорматДаты), ОписаниеОшибки());
			Статус = СтатусОшибка;
			
		КонецПопытки;
		
	Иначе
		
		Комментарий = НСтр(ШаблонОшибки);
		Комментарий = СтрШаблон(Комментарий, Валюта, Формат(ДатаКурса, ФорматДаты), ТекстОтказа);
		Статус = СтатусОшибка;
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ЗагрузкаКотировок

Функция НовыеПараметрыМетода(СквозныеПараметры)
	
	ФорматДаты = "ДФ=yyyy-MM-dd";
	ПараметрыМетода = Новый Структура();
	Если СквозныеПараметры.ИмяНастроекСервиса = СквозныеПараметры.ИмяНастроекСервисаИнтерфакс Тогда
		ПараметрыМетода.Вставить("codes", 				СквозныеПараметры.ПакетКодов);
		ПараметрыМетода.Вставить("dateFrom", 			Формат(СквозныеПараметры.ДатаПолученияКотировок, "ДФ=yyyy-MM-dd;"));
		ПараметрыМетода.Вставить("dateTo", 				Формат(СквозныеПараметры.ДатаПолученияКотировок, "ДФ=yyyy-MM-dd;"));
		ПараметрыМетода.Вставить("tradeSites", 			СквозныеПараметры.ИдентификаторыТорговыхПлощадок);
		ПараметрыМетода.Вставить("fields", 				СквозныеПараметры.ИдентификаторыПолей);
		ПараметрыМетода.Вставить("official", 			Ложь); // ASP-98212 Истина
		ПараметрыМетода.Вставить("pageNum", 			1);
		ПараметрыМетода.Вставить("pageSize", 			100);
	ИначеЕсли СквозныеПараметры.ИмяНастроекСервиса = СквозныеПараметры.ИмяНастроекСервисаНРД Тогда
		МаксимальноеКоличествоПлощадокНаЦеннуюБумагу = 99;
		limit = МаксимальноеКоличествоПлощадокНаЦеннуюБумагу * СквозныеПараметры.ПакетКодов.Количество();
		ПараметрыМетода.Вставить("limit", Формат(limit, "ЧГ=0"));
		// --> filter
		МассивУсловий = Новый Массив;
		// Условие 1: Isin
		УсловиеISIN = Новый Структура("_S_in", СквозныеПараметры.ПакетКодов);
		Условие1 = Новый Структура("isin", УсловиеISIN);
		МассивУсловий.Добавить(Условие1);
		// Условие 2: Категории ценных бумаг
		Условие2 = Новый Структура("security_category", "акции");
		МассивУсловий.Добавить(Условие2);
		// Условие 3: Период
		ПериодСтрокой = Формат(СквозныеПараметры.ДатаПолученияКотировок, ФорматДаты);
		СтруктураПериода = Новый Структура;
		СтруктураПериода.Вставить("_S_gte", ПериодСтрокой);
		СтруктураПериода.Вставить("_S_lte", ПериодСтрокой);
		Условие3 = Новый Структура("last_trade_date", СтруктураПериода);
		МассивУсловий.Добавить(Условие3);
		filter = Новый Структура("_S_and", МассивУсловий);
		ПараметрыМетода.Вставить("filter", filter);
		// <-- filter
		ПараметрыМетода.Вставить("include", СтрСоединить(СквозныеПараметры.ИдентификаторыПолей, ","));
	ИначеЕсли СквозныеПараметры.ИмяНастроекСервиса = СквозныеПараметры.ИмяНастроекСервисаCBonds Тогда
		ПараметрыМетода.Вставить("ДатаНачала"						, Формат(СквозныеПараметры.ДатаПолученияКотировок, ФорматДаты));
		ПараметрыМетода.Вставить("ДатаОкончания"					, Формат(СквозныеПараметры.ДатаПолученияКотировок, ФорматДаты));
		ПараметрыМетода.Вставить("МассивISIN"						, СквозныеПараметры.ПакетКодов);
		ПараметрыМетода.Вставить("МассивИдентификаторовПлощадок"	, СквозныеПараметры.ИдентификаторыТорговыхПлощадок);
		ПараметрыМетода.Вставить("МассивИдентификаторовПолей"		, СквозныеПараметры.ИдентификаторыПолей);
	Иначе
		Возврат Неопределено;
	КонецЕсли;
	
	Возврат ПараметрыМетода;
	
КонецФункции

Процедура ВнешниеСервисыВыполнитьДействиеРассылкаОтчетов(ЗагрузкаВыполнялась,
	ИмяНастроекСервиса, ИмяДействия, ТабличныйДокумент, ДатаНачала)
	
	Если ЗагрузкаВыполнялась И Не ТестированиеVanessa.ЭтоТест() Тогда
		Если ИмяНастроекСервиса = "НастройкиИнтерфакс" Тогда
			ИсточникРассылки = ПланыВидовХарактеристик.ВнешниеИсточники.РассылкаУведомленийОбОшибкахЗагрузкиКотировокAPIRuData;
		ИначеЕсли ИмяНастроекСервиса = "НастройкиНРД" Тогда
			ИсточникРассылки = ПланыВидовХарактеристик.ВнешниеИсточники.РассылкаУведомленийОбОшибкахЗагрузкиКотировокAPINSD;
		ИначеЕсли ИмяНастроекСервиса = "НастройкиCBonds" И ИмяДействия = "ЗагрузитьКупоныCBonds" Тогда
			ИсточникРассылки = ПланыВидовХарактеристик.ВнешниеИсточники.РассылкаУведомленийОбОшибкахЗагрузкиКупоновAPICBonds;
		ИначеЕсли ИмяНастроекСервиса = "НастройкиCBonds" Тогда
			ИсточникРассылки = ПланыВидовХарактеристик.ВнешниеИсточники.РассылкаУведомленийОбОшибкахЗагрузкиКотировокAPICBonds;
		Иначе
			ИсточникРассылки = Неопределено;
		КонецЕсли;
		РассылкаОтчетов.ОтправитьТабличныйДокументОтчетКакУведомлениеHTML(ИсточникРассылки, ИмяДействия, ТабличныйДокумент, ДатаНачала);
	КонецЕсли;
	
КонецПроцедуры

Процедура ЗаписатьКурсРассчитавКратность(Запись, Курс)
	
	Основание			 = 10;
	ПроверяемыхРазрядов	 = 4;
	ПоследнийРазряд		 = 8;
	
	Кратность = Pow(Основание, ПроверяемыхРазрядов);
	КурсСтрокой = Формат(Курс, "ЧЦ=14; ЧДЦ=" + ПоследнийРазряд + "; ЧРД=; ЧГ=0");
	Для Индекс = 1 По ПроверяемыхРазрядов Цикл
		ЗначениеРазряда = 1 * Лев(Прав(КурсСтрокой, Индекс), 1);
		Если ЗначениеРазряда = 0 Тогда
			Кратность = Кратность / Основание;
		Иначе
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	НовыйКурс = Курс * Кратность;
	
	Запись.Курс = НовыйКурс;
	Запись.Кратность = Кратность;
	
КонецПроцедуры

Функция СписокАктивовДляЗапросаКотировок(СквозныеПараметры, НачальнаяДатаПолученияКотировки) Экспорт
	
	ТаблицаСКолонкойISIN = СквозныеПараметры.ТаблицаISIN;
	ИмяРеквизитаISIN	 = "ISIN";
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ДатаПолученияКотировки", НачальнаяДатаПолученияКотировки);
	Если ЗначениеЗаполнено(ТаблицаСКолонкойISIN) Тогда
		Запрос.УстановитьПараметр("ПоВсем", Ложь);
		Запрос.УстановитьПараметр(ИмяРеквизитаISIN, ТаблицаСКолонкойISIN.ВыгрузитьКолонку(ИмяРеквизитаISIN));
	Иначе
		Запрос.УстановитьПараметр("ПоВсем", Истина);
		Запрос.УстановитьПараметр(ИмяРеквизитаISIN, Новый Массив);
	КонецЕсли;
	ТипыЦБ = Новый Массив;
	ПараметрЗапросаПоВсемТипамЦБ = "ПоВсемТипамЦБ";
	ОграничениеПоКоличествуISIN = СквозныеПараметры.ОграничениеПоКоличествуISIN;
	Если СквозныеПараметры.ИмяНастроекСервиса = СквозныеПараметры.ИмяНастроекСервисаНРД Тогда
		Запрос.УстановитьПараметр(ПараметрЗапросаПоВсемТипамЦБ, Ложь);
		ТипыЦБ.Добавить(Перечисления.ТипыЦБ.Акция);
		ТипыЦБ.Добавить(Перечисления.ТипыЦБ.ДепозитарнаяРасписка);
		ТипыЦБ.Добавить(Перечисления.ТипыЦБ.Пай);
		ТипыЦБ.Добавить(Перечисления.ТипыЦБ.КлиринговыйСертификатУчастия);
	ИначеЕсли СквозныеПараметры.ИмяНастроекСервиса = СквозныеПараметры.ИмяНастроекСервисаCBonds Тогда
		Запрос.УстановитьПараметр(ПараметрЗапросаПоВсемТипамЦБ, Ложь);
		ТипыЦБ.Добавить(Перечисления.ТипыЦБ.Облигация);
		Если ЗначениеЗаполнено(ТаблицаСКолонкойISIN) Тогда
			ОграничениеПоКоличествуISIN = 0;
		КонецЕсли;
	Иначе
		Запрос.УстановитьПараметр(ПараметрЗапросаПоВсемТипамЦБ, Истина);
	КонецЕсли;
	Запрос.УстановитьПараметр("ТипыЦБ", ТипыЦБ);
	Запрос.УстановитьПараметр("КромеЦенныхБумагRU", СквозныеПараметры.КромеЦенныхБумагRU);
	Запрос.УстановитьПараметр("ОграничениеПоКоличествуISIN", ОграничениеПоКоличествуISIN);
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ЦенныеБумаги.Ссылка КАК ЦеннаяБумагаВПериоде,
	|	МАКСИМУМ(НоминалЦБ.Период) КАК ПериодНоминала
	|ПОМЕСТИТЬ ТаблицаПериодовНоминала
	|ИЗ
	|	Справочник.ЦенныеБумаги КАК ЦенныеБумаги
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ЦенныеБумагиВЗапросеКотировок КАК ЦенныеБумагиКЗапросуКотировок
	|		ПО ЦенныеБумаги.Ссылка = ЦенныеБумагиКЗапросуКотировок.ЦеннаяБумага
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.НоминалЦБ КАК НоминалЦБ
	|		ПО ЦенныеБумаги.Ссылка = НоминалЦБ.ЦеннаяБумага
	|			И (НоминалЦБ.Период <= &ДатаПолученияКотировки)
	|			И (НоминалЦБ.Сумма <> 0)
	|ГДЕ
	|	ВЫБОР
	|			КОГДА &ОграничениеПоКоличествуISIN = 0
	|				ТОГДА ИСТИНА
	|			ИНАЧЕ НЕ ЦенныеБумагиКЗапросуКотировок.ISIN ЕСТЬ NULL
	|		КОНЕЦ
	|	И НЕ ЦенныеБумаги.ПометкаУдаления
	|	И НЕ ЦенныеБумаги.ЭтоГруппа
	|	И ЦенныеБумаги.ISIN <> """"
	|	И ВЫБОР
	|			КОГДА &ПоВсем
	|				ТОГДА ИСТИНА
	|			ИНАЧЕ ЦенныеБумаги.ISIN В (&ISIN)
	|		КОНЕЦ
	|	И ВЫБОР
	|			КОГДА &КромеЦенныхБумагRU
	|				ТОГДА ВЫБОР
	|						КОГДА ЦенныеБумаги.ТипЦБ = ЗНАЧЕНИЕ(Перечисление.ТипыЦБ.ДепозитарнаяРасписка)
	|							ТОГДА НЕ ЕСТЬNULL(ВЫРАЗИТЬ(ЦенныеБумаги.БазовыйАктив КАК Справочник.ЦенныеБумаги).Эмитент.ЮридическиеФизическиеЛица.Страна, ЗНАЧЕНИЕ(Справочник.КлассификаторСтранМира.ПустаяСсылка)) = ЗНАЧЕНИЕ(Справочник.КлассификаторСтранМира.РОССИЯ)
	|						ИНАЧЕ НЕ ЕСТЬNULL(ЦенныеБумаги.Эмитент.ЮридическиеФизическиеЛица.Страна, ЗНАЧЕНИЕ(Справочник.КлассификаторСтранМира.ПустаяСсылка)) = ЗНАЧЕНИЕ(Справочник.КлассификаторСтранМира.РОССИЯ)
	|					КОНЕЦ
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ
	|	И ВЫБОР
	|			КОГДА ЦенныеБумаги.ДатаСнятияСОбслуживания = ДАТАВРЕМЯ(1, 1, 1, 0, 0, 0)
	|				ТОГДА ИСТИНА
	|			ИНАЧЕ ЦенныеБумаги.ДатаСнятияСОбслуживания >= &ДатаПолученияКотировки
	|		КОНЕЦ
	|	И ЦенныеБумаги.ТипЦБ = ЗНАЧЕНИЕ(Перечисление.ТипыЦБ.Облигация)
	|	И ВЫБОР
	|			КОГДА &ПоВсемТипамЦБ
	|				ТОГДА ИСТИНА
	|			ИНАЧЕ ЦенныеБумаги.ТипЦБ В (&ТипыЦБ)
	|		КОНЕЦ
	|	И ВЫБОР
	|			КОГДА ЦенныеБумаги.ДатаПогашения = ДАТАВРЕМЯ(1, 1, 1, 0, 0, 0)
	|				ТОГДА ИСТИНА
	|			ИНАЧЕ ЦенныеБумаги.ДатаПогашения >= &ДатаПолученияКотировки
	|		КОНЕЦ
	|
	|СГРУППИРОВАТЬ ПО
	|	ЦенныеБумаги.Ссылка
	|
	|ИМЕЮЩИЕ
	|	НЕ МАКСИМУМ(НоминалЦБ.Период) ЕСТЬ NULL
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Активы.Ссылка КАК Актив,
	|	Активы.ТипЦБ = ЗНАЧЕНИЕ(Перечисление.ТипыЦБ.Облигация)
	|		И НЕ Активы.КупоннаяОблигация КАК НулевойНКД,
	|	Активы.ISIN КАК ISIN,
	|	Активы.ТипЦБ = ЗНАЧЕНИЕ(Перечисление.ТипыЦБ.Облигация) КАК ЭтоОблигация,
	|	Активы.ВалютаНоминала КАК ВалютаНоминала,
	|	Активы.ВалютаНоминала.Наименование КАК КодВалютыНоминала,
	|	ЕСТЬNULL(НоминалЦБ.Сумма, 0) КАК Номинал
	|ИЗ
	|	Справочник.ЦенныеБумаги КАК Активы
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ЦенныеБумагиВЗапросеКотировок КАК ЦенныеБумагиКЗапросуКотировок
	|		ПО Активы.Ссылка = ЦенныеБумагиКЗапросуКотировок.ЦеннаяБумага
	|		ЛЕВОЕ СОЕДИНЕНИЕ ТаблицаПериодовНоминала КАК ТаблицаПериодовНоминала
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.НоминалЦБ КАК НоминалЦБ
	|			ПО ТаблицаПериодовНоминала.ЦеннаяБумагаВПериоде = НоминалЦБ.ЦеннаяБумага
	|				И ТаблицаПериодовНоминала.ПериодНоминала = НоминалЦБ.Период
	|		ПО Активы.Ссылка = ТаблицаПериодовНоминала.ЦеннаяБумагаВПериоде
	|ГДЕ
	|	ВЫБОР
	|			КОГДА &ОграничениеПоКоличествуISIN = 0
	|				ТОГДА ИСТИНА
	|			ИНАЧЕ НЕ ЦенныеБумагиКЗапросуКотировок.ISIN ЕСТЬ NULL
	|		КОНЕЦ
	|	И НЕ Активы.ПометкаУдаления
	|	И НЕ Активы.ЭтоГруппа
	|	И Активы.ISIN <> """"
	|	И ВЫБОР
	|			КОГДА &ПоВсем
	|				ТОГДА ИСТИНА
	|			ИНАЧЕ Активы.ISIN В (&ISIN)
	|		КОНЕЦ
	|	И ВЫБОР
	|			КОГДА &КромеЦенныхБумагRU
	|				ТОГДА НЕ ЕСТЬNULL(Активы.Эмитент.ЮридическиеФизическиеЛица.Страна, ЗНАЧЕНИЕ(Справочник.КлассификаторСтранМира.ПустаяСсылка)) = ЗНАЧЕНИЕ(Справочник.КлассификаторСтранМира.РОССИЯ)
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ
	|	И ВЫБОР
	|			КОГДА Активы.ДатаСнятияСОбслуживания = ДАТАВРЕМЯ(1, 1, 1, 0, 0, 0)
	|				ТОГДА ИСТИНА
	|			ИНАЧЕ Активы.ДатаСнятияСОбслуживания >= &ДатаПолученияКотировки
	|		КОНЕЦ
	|	И ВЫБОР
	|			КОГДА НЕ Активы.ТипЦБ = ЗНАЧЕНИЕ(Перечисление.ТипыЦБ.Облигация)
	|				ТОГДА ИСТИНА
	|			ИНАЧЕ ВЫБОР
	|					КОГДА Активы.ДатаПогашения = ДАТАВРЕМЯ(1, 1, 1, 0, 0, 0)
	|						ТОГДА ИСТИНА
	|					ИНАЧЕ Активы.ДатаПогашения >= &ДатаПолученияКотировки
	|				КОНЕЦ
	|		КОНЕЦ
	|	И ВЫБОР
	|			КОГДА &ПоВсемТипамЦБ
	|				ТОГДА ИСТИНА
	|			ИНАЧЕ Активы.ТипЦБ В (&ТипыЦБ)
	|		КОНЕЦ
	|
	|УПОРЯДОЧИТЬ ПО
	|	ISIN";
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ТаблицаАктивов = РезультатЗапроса.Выгрузить();
	ТаблицаАктивов.Индексы.Добавить(ИмяРеквизитаISIN);
	
	Возврат ТаблицаАктивов;
КонецФункции

Функция ПакетыКодов(СписокКодов, МаксимальноеКоличествоЭлементовВПакете = 20)
	
	Результат = Новый Массив();
	
	МассивПорций = Новый Массив();
	
	Для Индекс = 0 По СписокКодов.ВГраница() Цикл
		
		Если МассивПорций.Количество() = МаксимальноеКоличествоЭлементовВПакете Тогда
			Результат.Добавить(МассивПорций);
			МассивПорций = Новый Массив();
		КонецЕсли;
		
		МассивПорций.Добавить(СписокКодов[Индекс]);
		
	КонецЦикла;
	
	Если МассивПорций.Количество() > 0 Тогда
		Результат.Добавить(МассивПорций);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ИсточникКотировокПоТорговойПлощадке(Код, Корень, Площадки, КешИсточниковКотировок = Неопределено)
	
	// Получить, если есть
	Площадка = Справочники.ИсточникиКотировок.Получить(Код, Корень, КешИсточниковКотировок);
	Если ЗначениеЗаполнено(Площадка) Тогда
		Возврат Площадка;
	КонецЕсли;
	
	// Создать
	ПараметрыПоиска = Новый Структура("id", Код);
	НайденыПлощадки = Площадки.НайтиСтроки(ПараметрыПоиска);
	Если НайденыПлощадки.Количество() = 1 Тогда
		
		КодРодителя = НайденыПлощадки[0].id_parent;
		РодительСуществует = РодительВИсточникеСуществует(КодРодителя);
		Если РодительСуществует Тогда
			ПлощадкаРодитель = Справочники.ИсточникиКотировок.Получить(КодРодителя, Корень, КешИсточниковКотировок);
			Если Не ЗначениеЗаполнено(ПлощадкаРодитель) Тогда
				ПараметрыПоискаРодителя = Новый Структура("id", КодРодителя);
				НайденыПлощадкиРодители = Площадки.НайтиСтроки(ПараметрыПоискаРодителя);
				Если НайденыПлощадкиРодители.Количество() = 1 Тогда
					ПлощадкаРодитель = Справочники.ИсточникиКотировок.Создать(Корень, НайденыПлощадкиРодители[0], КешИсточниковКотировок, Корень);
				Иначе
					ПлощадкаРодитель = Корень;
				КонецЕсли;
			КонецЕсли;
		Иначе
			ПлощадкаРодитель = Корень;
		КонецЕсли;
		
		Площадка = Справочники.ИсточникиКотировок.Создать(ПлощадкаРодитель, НайденыПлощадки[0], КешИсточниковКотировок, Корень);
		ОтправитьУведомлениеОНовойТорговойПлощадке(Площадка, Корень);
		Возврат Площадка;
	Иначе
		Возврат Корень;
	КонецЕсли;
	
КонецФункции

Функция РодительВИсточникеСуществует(КодРодителя)
	
	КодРодителяТипЗначения = ТипЗнч(КодРодителя);
	РодительСуществует =
		(КодРодителяТипЗначения = Тип("Число") И КодРодителя > 0) Или (КодРодителяТипЗначения = Тип("Строка") И КодРодителя <> "");
	
	Возврат РодительСуществует;
	
КонецФункции

Процедура ЗаполнитьТаблицуТорговыхПлощадок(ИмяНастроекСервиса, ИмяНастроекСервисаCBonds, ПолученныеДанные,
	ИдентификаторыТорговыхПлощадок, ТЗ_ДанныеПоТорговымПлощадкам)
	
	Для Каждого ТекСтрока Из ПолученныеДанные Цикл
		Если ИмяНастроекСервиса = ИмяНастроекСервисаCBonds Тогда
			Если ЗначениеЗаполнено(ТекСтрока.mic) Тогда
				shortname_rus 	= ТекСтрока.mic;
			Иначе
				shortname_rus 	= ТекСтрока.name_rus;
			КонецЕсли;
			fullname_rus 		= ТекСтрока.name_rus;
		Иначе
			shortname_rus 		= ТекСтрока.shortname_rus;
			fullname_rus 		= ТекСтрока.fullname_rus;
		КонецЕсли;
		
		Если ТекСтрока.id_parent = 0 Тогда
			ИдентификаторыТорговыхПлощадок.Вставить(ТекСтрока.id, fullname_rus);
		КонецЕсли;
		НоваяСтрока = ТЗ_ДанныеПоТорговымПлощадкам.Добавить();
		НоваяСтрока.id 						= ТекСтрока.id;
		НоваяСтрока.id_parent 				= ТекСтрока.id_parent;
		НоваяСтрока.shortname_rus 			= shortname_rus;
		НоваяСтрока.fullname_rus 			= fullname_rus;
		
	КонецЦикла;
	
КонецПроцедуры

Процедура ОтправитьУведомлениеОНовойТорговойПлощадке(Площадка, Корень)
	
	Если Корень = Справочники.ИсточникиКотировок.CBonds Тогда
		Биржа = Справочники.ИсточникиКотировок.CBonds;
	ИначеЕсли Корень = Справочники.ИсточникиКотировок.NSD Тогда
		Биржа = Справочники.ИсточникиКотировок.NSD;
	Иначе
		Возврат;
	КонецЕсли;
	
	ВнешнийИсточник = ПланыВидовХарактеристик.ВнешниеИсточники.РассылкаУведомленийОНовойТорговойПлощадкеЗагрузкиКотировок;
	НастройкиОбмена = ВнешниеДанные.ПолучитьПараметрыВнешнегоИсточника(ВнешнийИсточник).Настройка;
	Если НастройкиОбмена = Неопределено Тогда
		ТекстОшибки = "Не заданы параметры внешнего источника """ + Строка(ВнешнийИсточник) + """";
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстОшибки);
		ИмяСобытия = "Уведомление о новой торговой площадке не отправлено";
		ЗаписьЖурналаРегистрации(ИмяСобытия, УровеньЖурналаРегистрации.Предупреждение, , , ТекстОшибки);
		Возврат;
	КонецЕсли;
	
	Переименования = Новый Соответствие;
	Площадки = Новый Массив;
	СтруктураПлощадки = Новый Структура("Код, Наименование, ПолноеНаименование");
	ЗаполнитьЗначенияСвойств(СтруктураПлощадки, Площадка);
	Площадки.Добавить(СтруктураПлощадки);
	ТаблицаПлощадок = ОбщегоНазначенияПереопределяемый.МассивСтруктурВТаблицуЗначений(Площадки, Переименования);
	
	ТемаПисьма = "SecuritiesQuotes: Новая торговая площадка для источника котировок [" + Биржа + "]";
	ТекстПисьма = ТекстУведомленияОНовойТорговойПлощадке(ТаблицаПлощадок, Биржа);
	ПараметрыУведомления = Новый Соответствие;
	ПараметрыУведомления.Вставить("НастройкиОбмена",	НастройкиОбмена);
	ПараметрыУведомления.Вставить("Кодировка",			"UTF-8");
	ПараметрыУведомления.Вставить("ТемаПисьма",			ТемаПисьма);
	ПараметрыУведомления.Вставить("ТекстПисьма",		ТекстПисьма);
	ПараметрыУведомления.Вставить("ТипТекстаПисьма",	ТипТекстаПочтовогоСообщения.HTML);
	ПараметрыУведомления.Вставить("Важность",			ВажностьИнтернетПочтовогоСообщения.Обычная);
	РегистрыСведений.УведомленияКОтправке.ДобавитьУведомлениеКотправке(ПараметрыУведомления);
	
КонецПроцедуры

Функция ТекстУведомленияОНовойТорговойПлощадке(ТаблицаПлощадок, Биржа)
	
	ПС = "<br>";			// Тег HTML означает перевод строки
	ВключитьBold = "<b>";	// Тег HTML означает включить жирный шрифт
	ОтключитьBold = "</b>";	// Тег HTML означает отключить жирный шрифт
	
	ТекстЗаголовка = "Добрый день!" + ПС + ПС
		+ "В 1С ДЕПО добавлена новая торговая площадка для источника котировок [" + Биржа + "]"
		+ ПС + Символы.ПС;
	Текст = "<html><BODY>" + Символы.ПС
			+ ТекстЗаголовка + ПС + Символы.ПС;
	
	ПараметрыТрансформацииВHTML = Новый Структура;
	ПараметрыТрансформацииВHTML.Вставить("ПунктПорядкуИспользуется", Истина);
	ПараметрыТрансформацииВHTML.Вставить("ЦветШапки", "eadbaf");
	ПараметрыТрансформацииВHTML.Вставить("ШиринаТаблицы", "1000");
	ПараметрыТрансформацииВHTML.Вставить("Ширина1", "200");
	ПараметрыТрансформацииВHTML.Вставить("Ширина2", "200");
	ПараметрыТрансформацииВHTML.Вставить("Ширина3", "600");
	ПараметрыТрансформацииВHTML.Вставить("Заголовок1", "Код");
	ПараметрыТрансформацииВHTML.Вставить("Заголовок2", "Наименование");
	ПараметрыТрансформацииВHTML.Вставить("Заголовок3", "Полное наименование");
	
	ТаблицаHTML = ОбщегоНазначения.ТаблицаЗначенийВТаблицуHTML(ТаблицаПлощадок, ПараметрыТрансформацииВHTML);
	Организация = СокрЛП(ОбщегоНазначенияПовтИсп.ОрганизацияПоУмолчанию().Наименование);
	
	Текст = Текст + ВключитьBold + ТаблицаHTML + ОтключитьBold
		+ ПС + Символы.ПС + ПС + Символы.ПС;
