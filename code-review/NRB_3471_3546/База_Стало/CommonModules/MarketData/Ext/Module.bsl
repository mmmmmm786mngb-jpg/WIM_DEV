
#Область СлужебныйПрограммныйИнтерфейс

#Область ЗагрузкаКотировокЭкспорт

// Процедура выполняет регламентую загрузку котировок и прочих данных из внешних сервисов
//
// Параметры:
//  ИмяНастроекСервиса			 - Строка						 - Имя настроек сервиса
//  Действие					 - Строка						 - ЗагрузитьКурсыВалютИнтерфакс, ЗагрузитьКупоныCBonds,
//  						ЗагрузитьКотировкиСПБИнтерфакс, ЗагрузитьКотировкиПрочихТорговыхПлощадокИнтерфакс, ЗагрузкаИтоговТорговЧерезNSDAPI
//  ТипПериодаЗагрузкиКотировок	 - ПеречислениеСсылка.ПериодыДней	 - ПредыдущийДень, ПредыдущийРабочийДень, ТекущийДень
//  ISINs						 - Строка							 - Фильтр по ISIN через запятую
//
Процедура ВнешниеСервисыВыполнитьДействие(ИмяНастроекСервиса, Действие, ТипПериодаЗагрузкиКотировок, ISINs = "") Экспорт
	
	ВремяНачалаФормирования = ОценкаПроизводительности.НачатьЗамерВремени();
	
	ИмяДействия = СокрЛП(Действие);
	ИмяРегламента = "СервисыMarketData." + ИмяДействия;
	
	ДатаНачала = Перечисления.ПериодыДней.ДатаПоТипуПериода(ТипПериодаЗагрузкиКотировок, ТекущаяДатаСеанса());
	Если Не ЗначениеЗаполнено(ДатаНачала) Тогда
		Настройки = НастройкиСервисаAPI(ИмяНастроекСервиса);
		ПериодИзНастройки = ПериодОтчета(Неопределено, Настройки);
		ДатаНачала = ПериодИзНастройки.ДатаНачала;
	КонецЕсли;
	ДатаОкончания = ДатаНачала;
	Период = Новый СтандартныйПериод(ДатаНачала, ДатаОкончания);
	ПериодЗагрузки = Формат(ДатаНачала, "ДФ=dd.MM.yyyy") + " - " + Формат(ДатаОкончания, "ДФ=dd.MM.yyyy");
	
	Если ЗначениеЗаполнено(ISINs) Тогда
		ИмяКолонкиISIN = "ISIN";
		ТаблицаISIN = Новый ТаблицаЗначений;
		ТаблицаISIN.Колонки.Добавить(ИмяКолонкиISIN);
		МассивISIN = СтрРазделить(ISINs, ",", Ложь);
		ОбщегоНазначенияКлиентСервер.ДополнитьТаблицуИзМассива(ТаблицаISIN, МассивISIN, ИмяКолонкиISIN);
	Иначе
		ТаблицаISIN = Неопределено;
	КонецЕсли;
	
	Макет = Обработки.СервисыMarketDataAPI.ПолучитьМакет("Лог");
	ОбластьВидИнформации	 = Макет.ПолучитьОбласть("ВидИнформации");
	ОбластьОшибкаЗагрузки	 = Макет.ПолучитьОбласть("ОшибкаЗагрузки");
	ТабличныйДокумент		 = Новый ТабличныйДокумент;
	ЛогПолученныхДанных		 = Неопределено;
	Отказ					 = Ложь;
	ТекстОтказа				 = "";
	ЗагрузкаВыполнялась		 = Истина;
	ИмяПараметраВидИсточника = "ВидИсточника";
	ПараметрыИсточника = Новый Структура;
	ПараметрыИсточника.Вставить("ИмяДействия" , ИмяДействия);
	ПараметрыИсточника.Вставить("ТаблицаISIN" , ТаблицаISIN);
	
	ТабличныйДокумент.НачатьАвтогруппировкуСтрок();
	
	Если ИмяДействия = "ЗагрузитьКурсыВалютИнтерфакс" Тогда
		
		Комментарий = "ru ='Загрузка курсов валют за %1'";
		ОбластьВидИнформации.Параметры.ВидЗагружаемойИнформации = СтрШаблон(НСтр(Комментарий), ПериодЗагрузки);
		ТабличныйДокумент.Вывести(ОбластьВидИнформации, 0);
		
		СписокБазовыхВалют		 = Справочники.Валюты.ПолучитьСписокБазовыхВалют();
		ИсключаяБазовыеВалюты	 = Истина;
		РеквизитСортировки		 = "Наименование";
		СписокВалют = Справочники.Валюты.ЗагружаемыеВалюты(ИсключаяБазовыеВалюты, РеквизитСортировки);
		
		ЗагрузитьКурсыВалютИнтерфакс(Период, СписокБазовыхВалют, СписокВалют, Отказ, ТекстОтказа, ТабличныйДокумент, ЛогПолученныхДанных);
		
	ИначеЕсли ИмяДействия = "ЗагрузитьКупоныCBonds" Тогда
		
		Комментарий = "ru ='Загрузка НКД CBonds за %1'";
		ОбластьВидИнформации.Параметры.ВидЗагружаемойИнформации = СтрШаблон(НСтр(Комментарий), ПериодЗагрузки);
		ТабличныйДокумент.Вывести(ОбластьВидИнформации, 0);
		
		ПараметрыИсточника.Вставить(ИмяПараметраВидИсточника, ИмяДействия);
		ЗагрузитьНКДВнешнегоСервиса(ИмяНастроекСервиса,
			Период, ПараметрыИсточника, Отказ, ТекстОтказа, ТабличныйДокумент, ЛогПолученныхДанных);
		
	ИначеЕсли ИмяДействия = "ЗагрузитьКотировкиСПБИнтерфакс" Тогда
		
		Комментарий = "ru ='Загрузка котировок торговых площадок СПБ за %1'";
		ОбластьВидИнформации.Параметры.ВидЗагружаемойИнформации = СтрШаблон(НСтр(Комментарий), ПериодЗагрузки);
		ТабличныйДокумент.Вывести(ОбластьВидИнформации, 0);
		
		ПараметрыИсточника.Вставить(ИмяПараметраВидИсточника	, "ТорговыхПлощадокСПБ");
		ЗагрузитьКотировкиВнешнегоСервиса(ИмяНастроекСервиса,
			Период, ПараметрыИсточника, Отказ, ТекстОтказа, ТабличныйДокумент, ЛогПолученныхДанных);
		
	ИначеЕсли ИмяДействия = "ЗагрузитьКотировкиПрочихТорговыхПлощадокИнтерфакс" Тогда
		
		Комментарий = "ru ='Загрузка котировок прочих торговых площадок за %1'";
		ОбластьВидИнформации.Параметры.ВидЗагружаемойИнформации = СтрШаблон(НСтр(Комментарий), ПериодЗагрузки);
		ТабличныйДокумент.Вывести(ОбластьВидИнформации, 0);
		
		ПараметрыИсточника.Вставить(ИмяПараметраВидИсточника	, "ПрочихТорговыхПлощадок");
		ЗагрузитьКотировкиВнешнегоСервиса(ИмяНастроекСервиса,
			Период, ПараметрыИсточника, Отказ, ТекстОтказа, ТабличныйДокумент, ЛогПолученныхДанных);
		
	ИначеЕсли ИмяДействия = "ЗагрузкаИтоговТорговЧерезNSDAPI" Тогда
		
		Комментарий = "ru ='Загрузка котировок торговых площадок НРД за %1'";
		ОбластьВидИнформации.Параметры.ВидЗагружаемойИнформации = СтрШаблон(НСтр(Комментарий), ПериодЗагрузки);
		ТабличныйДокумент.Вывести(ОбластьВидИнформации, 0);
		
		ПараметрыИсточника.Вставить(ИмяПараметраВидИсточника	, "ТорговыхПлощадокНРД");
		ЗагрузитьКотировкиВнешнегоСервиса(ИмяНастроекСервиса,
			Период, ПараметрыИсточника, Отказ, ТекстОтказа, ТабличныйДокумент, ЛогПолученныхДанных);
		
	ИначеЕсли ИмяДействия = "ЗагрузитьИндикативныеКотировкиCBonds" Тогда
		
		Комментарий = "ru ='Загрузка индикативных котировок торговых площадок CBonds за %1'";
		ОбластьВидИнформации.Параметры.ВидЗагружаемойИнформации = СтрШаблон(НСтр(Комментарий), ПериодЗагрузки);
		ТабличныйДокумент.Вывести(ОбластьВидИнформации, 0);
		
		ПараметрыИсточника.Вставить(ИмяПараметраВидИсточника	, "ТорговыхПлощадокСПБ");
		ЗагрузитьКотировкиВнешнегоСервиса(ИмяНастроекСервиса,
			Период, ПараметрыИсточника, Отказ, ТекстОтказа, ТабличныйДокумент, ЛогПолученныхДанных);
		
	ИначеЕсли ИмяДействия = "ЗагрузитьБиржевыеКотировкиТорговыхПлощадокCBonds" Тогда
		
		Комментарий = "ru ='Загрузка биржевых котировок торговых площадок CBonds за %1'";
		ОбластьВидИнформации.Параметры.ВидЗагружаемойИнформации = СтрШаблон(НСтр(Комментарий), ПериодЗагрузки);
		ТабличныйДокумент.Вывести(ОбластьВидИнформации, 0);
		
		ПараметрыИсточника.Вставить(ИмяПараметраВидИсточника	, "ПрочихТорговыхПлощадок");
		ЗагрузитьКотировкиВнешнегоСервиса(ИмяНастроекСервиса,
			Период, ПараметрыИсточника, Отказ, ТекстОтказа, ТабличныйДокумент, ЛогПолученныхДанных);
		
	Иначе
		
		Комментарий = "ru ='Ошибка загрузки за %1'";
		ОбластьВидИнформации.Параметры.ВидЗагружаемойИнформации = СтрШаблон(НСтр(Комментарий), ПериодЗагрузки);
		ТабличныйДокумент.Вывести(ОбластьВидИнформации, 0);
		
		ЗагрузкаВыполнялась = Ложь;
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ИмяРегламента + " - не предусмотрено.");
	КонецЕсли;
	
	Если Отказ Тогда
		ОбластьОшибкаЗагрузки.Параметры.ТекстОтказа = ТекстОтказа;
		ТабличныйДокумент.Вывести(ОбластьОшибкаЗагрузки);
	КонецЕсли;
	ТабличныйДокумент.ЗакончитьАвтогруппировкуСтрок();
	
	ВесЗамера = 1;
	ОценкаПроизводительности.ЗакончитьЗамерВремени(ИмяРегламента, ВремяНачалаФормирования, ВесЗамера);
	
	ВнешниеСервисыВыполнитьДействиеРассылкаОтчетов(ЗагрузкаВыполнялась, ИмяНастроекСервиса, ИмяДействия, ТабличныйДокумент, ДатаНачала);
	
	Если Отказ Тогда
		ВызватьИсключение ТекстОтказа;
	КонецЕсли;
	
КонецПроцедуры

// Загрузка котировок внешнего сервиса
//
// Параметры:
//  ИмяНастроекСервиса	 - Строка			 - Имя настроек сервиса
//  Период				 - СтандартныйПериод - Период загрузки
//  ПараметрыИсточника	 - Структура		 - Структура с полями: ВидИсточника- Вид источника загрузки; ТаблицаISIN- Таблица с колонкой ISIN
//  Отказ				 - Булево			 - Признак отказа
//  ТекстОтказа			 - Строка			 - Описание ошибки
//  ТабличныйДокумент	 - ТабличныйДокумент - Табличный документ
//  ЛогПолученныхДанных	 - ТекстовыйДокумент - Текстовый Документ
//
Процедура ЗагрузитьКотировкиВнешнегоСервиса(ИмяНастроекСервиса, Период,
	ПараметрыИсточника,
	Отказ,
	ТекстОтказа,
	ТабличныйДокумент = Неопределено,
	ЛогПолученныхДанных = Неопределено) Экспорт
	
	Перем Соединение;
	Перем Токен;
	Перем Сессия;
	
	СквозныеПараметры = НовыеПараметрыЗагрузкиКотировок(ИмяНастроекСервиса, ПараметрыИсточника);
	
	ЗагрузитьКотировкиВнешнегоСервисаПодключение(СквозныеПараметры, Отказ, ТекстОтказа, Соединение, Токен, Сессия);
	Если Отказ Тогда
		Возврат;
	КонецЕсли;
	
	Площадки = ТаблицаТорговыхПлощадок(СквозныеПараметры.ИмяНастроекСервиса, Неопределено, , , Сессия);
	СквозныеПараметры.Вставить("Площадки", Площадки);
	
	ВремяНачалаФормирования = ОценкаПроизводительности.НачатьЗамерВремени();
	
	ПоВсемЦеннымБумагам		 = Не ЗначениеЗаполнено(СквозныеПараметры.ТаблицаISIN);
	СквозныеПараметры.Вставить("ПоВсемЦеннымБумагам", ПоВсемЦеннымБумагам);
	СервисыMarketDataAPI	 = Обработки.СервисыMarketDataAPI.Создать();
	Макет 					 = СервисыMarketDataAPI.ПолучитьМакет("Лог");
	СквозныеПараметры.Вставить("Макет", Макет);
	
	Настройки 				 = НастройкиСервисаAPI(СквозныеПараметры.ИмяНастроекСервиса);
	ПоместитьНастройкиСервисаВСквозныеПараметры(СквозныеПараметры, Настройки);
	
	ПериодОтчета	 = ПериодОтчета(Период, Настройки);
	ДатаНачала		 = ПериодОтчета.ДатаНачала;
	ДатаОкончания	 = ПериодОтчета.ДатаОкончания;
	
	СоответствиеКодовБирж					 = Новый Соответствие;
	СоответствиеПолейПрочихТорговыхПлощадок	 = Новый Соответствие;
	ОпределитьНастройкиТорговыхПлощадок(Настройки,
		СквозныеПараметры.ВидИсточника, СоответствиеКодовБирж, СоответствиеПолейПрочихТорговыхПлощадок);
	Если СоответствиеКодовБирж.Количество() = 0
		Или СоответствиеПолейПрочихТорговыхПлощадок.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	СквозныеПараметры.Вставить("СоответствиеПолейПрочихТорговыхПлощадок", СоответствиеПолейПрочихТорговыхПлощадок);
	СквозныеПараметры.Вставить("СоответствиеКодовБирж", СоответствиеКодовБирж);
	
	СписокАктивов		 = СписокАктивовДляЗапросаКотировок(СквозныеПараметры, ДатаНачала);
	СквозныеПараметры.Вставить("СписокАктивов", СписокАктивов);
	СписокISIN			 = ОбщегоНазначения.ВыгрузитьКолонку(СписокАктивов, "ISIN", Истина);
	КоличествоISIN		 = СписокISIN.Количество();
	ПакетыКодов			 = ПакетыКодов(СписокISIN, СквозныеПараметры.МаксимальноеКоличествоЦенныхБумагВЗапросеКотировок);
	СквозныеПараметры.Вставить("ПакетыКодов", ПакетыКодов);
	ВсегоПакетов		 = ПакетыКодов.Количество();
	СквозныеПараметры.Вставить("ВсегоПакетов", ВсегоПакетов);
	
	// Определяем период получения данных
	ТолькоРабочиеДни	 = СквозныеПараметры.ИмяНастроекСервиса = СквозныеПараметры.ИмяНастроекСервисаНРД
		Или СквозныеПараметры.ИмяНастроекСервиса = СквозныеПараметры.ИмяНастроекСервисаCBonds;
	ТаблицаПериодов		 = ДопустимыйИнтервал(ДатаНачала, ДатаОкончания, ТолькоРабочиеДни);
	СквозныеПараметры.Вставить("ТаблицаПериодов", ТаблицаПериодов);
	КоличествоДней		 = СквозныеПараметры.ТаблицаПериодов.Количество();
	
	// Выводим заголовок таблицы
	Если ТабличныйДокумент <> Неопределено Тогда
		ОбластьЗаголовокТаблицы = СквозныеПараметры.Макет.ПолучитьОбласть("ЗаголовокТаблицы");
		ТабличныйДокумент.Вывести(ОбластьЗаголовокТаблицы, 0);
	КонецЕсли;
	
	// Получение котировок
	ПолученныеДанныеКоличествоСтрокИтого = ПолучитьЗаписатьКотировкиПоБиржам(СквозныеПараметры, ЛогПолученныхДанных,
		Сессия, Соединение, Отказ, ТекстОтказа, ТабличныйДокумент);
	
	// Замер производительности
	ВесЗамера = КоличествоДней * КоличествоISIN;
	КомментарийЗамера = "[" + ПолученныеДанныеКоличествоСтрокИтого + "] - строк данных получено";
	ОценкаПроизводительности.ЗакончитьЗамерВремени("MarketData.ЗагрузитьКотировкиВнешнегоСервиса."
		+ СквозныеПараметры.ИмяДействия, ВремяНачалаФормирования, ВесЗамера, КомментарийЗамера);
	
	// Выходим из сервиса
	Если ИмяНастроекСервиса = СквозныеПараметры.ИмяНастроекСервисаИнтерфакс Тогда
		RuDataAPI.ВыйтиИзСервиса(Соединение, Отказ, ТекстОтказа);
	КонецЕсли;
	
КонецПроцедуры

// Получение периода загруки котировок
//
// Параметры:
//  Период		 - СтандартныйПериод - СтандартныйПериод или Неопределено
//  Настройки	 - Структура		 - Найстройки загрузки котировок с ключем ТипПериодаЗагрузкиКотировок
// 
// Возвращаемое значение:
//   - Структура - ДатаНачала, ДатаОкончания
//
Функция ПериодОтчета(Период, Настройки) Экспорт
	
	ТекущийПериод = ТекущаяДатаСеанса();
	
	Если Период = Неопределено Тогда
		Если Настройки.Свойство("ТипПериодаЗагрузкиКотировок") Тогда
			ТипПериодаЗагрузкиКотировок = Настройки.ТипПериодаЗагрузкиКотировок;
		Иначе
			ТипПериодаЗагрузкиКотировок = Перечисления.ПериодыДней.ПредыдущийДень;
		КонецЕсли;
		
		ДатаНачала = Перечисления.ПериодыДней.ДатаПоТипуПериода(ТипПериодаЗагрузкиКотировок, ТекущийПериод);
		Если Не ЗначениеЗаполнено(ДатаНачала) Тогда
			ДатаНачала = НачалоДня(НачалоДня(ТекущийПериод) - 1);
		КонецЕсли;
		ДатаОкончания		 = ДатаНачала;
	Иначе
		ДатаНачала			 = НачалоДня(Период.ДатаНачала);
		ДатаОкончания		 = НачалоДня(Период.ДатаОкончания);
	КонецЕсли;
	Результат = Новый Структура("ДатаНачала, ДатаОкончания", ДатаНачала, ДатаОкончания);
	
	Возврат Результат;
	
КонецФункции

// Возвращает таблицу торговых площадок
//
// Параметры:
//  ИмяНастроекСервиса				 - Строка		 - Имя настроек сервиса
//  ИдентификаторыТорговыхПлощадок	 - Соответствие	 - Соответствие, необязательное
//  Отказ							 - Булево		 - Признак отказа
//  ТекстОтказа						 - Строка		 - Описание ошибки
//  Сессия							 - Стркутура	 - Кеш соединения
// 
// Возвращаемое значение:
//   - ТаблицаЗначений- Таблица торговых площадок
//
Функция ТаблицаТорговыхПлощадок(ИмяНастроекСервиса,
	ИдентификаторыТорговыхПлощадок, Отказ = Ложь, ТекстОтказа = "", Сессия = Неопределено) Экспорт
	
	ИмяНастроекСервисаНРД		 = "НастройкиНРД";
	ИмяНастроекСервисаИнтерфакс	 = "НастройкиИнтерфакс";
	ИмяНастроекСервисаCBonds	 = "НастройкиCBonds";
	
	Если ИмяНастроекСервиса = ИмяНастроекСервисаНРД Тогда
		ТипID = ОбщегоНазначения.ОписаниеТипаСтрока(10);
	Иначе
		ТипID = ОбщегоНазначения.ОписаниеТипаЧисло(10, 0);
	КонецЕсли;
	
	ТЗ_ДанныеПоТорговымПлощадкам = Новый ТаблицаЗначений;
	ТЗ_ДанныеПоТорговымПлощадкам.Колонки.Добавить("id", 			ТипID);
	ТЗ_ДанныеПоТорговымПлощадкам.Колонки.Добавить("id_parent", 		ТипID);
	ТЗ_ДанныеПоТорговымПлощадкам.Колонки.Добавить("shortname_rus", 	ОбщегоНазначения.ОписаниеТипаСтрока(150));
	ТЗ_ДанныеПоТорговымПлощадкам.Колонки.Добавить("fullname_rus",  	ОбщегоНазначения.ОписаниеТипаСтрока(150));
	
	Если ИмяНастроекСервиса = ИмяНастроекСервисаНРД Тогда
		ПустаяПлощадка = ТЗ_ДанныеПоТорговымПлощадкам.Добавить();
		ПустаяПлощадка.id = "0";
		ПустаяПлощадка.id_parent = "";
		Возврат ТЗ_ДанныеПоТорговымПлощадкам;
	КонецЕсли;
	
	Если ИдентификаторыТорговыхПлощадок = Неопределено Тогда
		ИдентификаторыТорговыхПлощадок = Новый Соответствие();
	КонецЕсли;
	
	ПараметрыМетода = Новый Структура();
	Если ТестированиеVanessa.ЭтоТест() Тогда
		ПолученныеДанные = Новый Массив;
	ИначеЕсли ИмяНастроекСервиса = ИмяНастроекСервисаИнтерфакс Тогда
		ПолученныеДанные = RuDataAPI.ДанныеМетода_V2_Info_ExchangeTree(ПараметрыМетода, Отказ, ТекстОтказа, , Сессия);
	ИначеЕсли ИмяНастроекСервиса = ИмяНастроекСервисаCBonds Тогда
		ПолученныеДанные = CBondsAPI.ДанныеМетода_get_trading_grounds(Отказ, ТекстОтказа);
	Иначе
		Отказ = Истина;
	КонецЕсли;
	Если Отказ Тогда
		Возврат ТЗ_ДанныеПоТорговымПлощадкам;
	КонецЕсли;
	
	ЗаполнитьТаблицуТорговыхПлощадок(ИмяНастроекСервиса, ИмяНастроекСервисаCBonds, ПолученныеДанные,
		ИдентификаторыТорговыхПлощадок, ТЗ_ДанныеПоТорговымПлощадкам);
	ТЗ_ДанныеПоТорговымПлощадкам.Сортировать("id_parent, id");
	
	Возврат ТЗ_ДанныеПоТорговымПлощадкам;
КонецФункции

#Область ЗагрузкаКотировок_МетодыОбработки

// Процедура - Установить настройки сервиса
//
// Параметры:
//  ИмяНастроекСервиса	 - Строка	 - Имя настроек сервиса
//  СтруктураНастроек	 - Структура - Произвольная структура настроек
//
Процедура УстановитьНастройкиСервиса(ИмяНастроекСервиса, СтруктураНастроек) Экспорт
	
	ЗначениеКонстанты = Новый ХранилищеЗначения(СтруктураНастроек);
	
	Константы[ИмяНастроекСервиса].Установить(ЗначениеКонстанты);
	
КонецПроцедуры

// Получает настройки сервиса
//
// Параметры:
//  ИмяНастроекСервиса	 - Строка	 - Имя настроек сервиса
// 
// Возвращаемое значение:
//   - Структура - Произвольная структура настроек
//
Функция НастройкиСервисаAPI(ИмяНастроекСервиса) Экспорт
	
	Если ТестированиеVanessa.ЭтоТест() Тогда
		ИнициализацияНастроек = Обработки.ОбновлениеИнформационнойБазыNew.Создать();
		ИнициализацияНастроек.НастройкаПараметровЗагрузкиКотировокAPIRuData();
		ИнициализацияНастроек.НастройкаПараметровЗагрузкиКотировокAPINSD();
		ИнициализацияНастроек.НастройкаПараметровЗагрузкиКотировокAPICBonds();
	КонецЕсли;
	
	Настройки = ОбщегоНазначенияПовтИсп.ЗначениеКонстанты(ИмяНастроекСервиса);
	Если ТипЗнч(Настройки) <> Тип("ХранилищеЗначения") Тогда
		Возврат Новый Структура;
	КонецЕсли;
	
	НастройкиПодключения = Настройки.Получить();
	
	Если ТипЗнч(НастройкиПодключения) <> Тип("Структура") Тогда
		Возврат Новый Структура;
	КонецЕсли;
	
	Возврат НастройкиПодключения;
	
КонецФункции

// Процедура - Установить значение настройки
//
// Параметры:
//  ИмяНастроекСервиса	 - Строка	 - Имя настроек сервиса
//  КлючНастройки		 - Строка	 - Имя настройки
//  Значение			 - Произвольный	 - Значение настройки
//
Процедура УстановитьЗначениеНастройки(ИмяНастроекСервиса, КлючНастройки, Значение) Экспорт
	
	Настройки = ОбщегоНазначенияПовтИсп.ЗначениеКонстанты(ИмяНастроекСервиса);
	Если ТипЗнч(Настройки) = Тип("ХранилищеЗначения") Тогда
		НастройкиПодключения = Настройки.Получить();
		Если ТипЗнч(НастройкиПодключения) = Тип("Структура") Тогда
			НастройкиПодключения.Вставить(КлючНастройки, Значение);
			УстановитьНастройкиСервиса(ИмяНастроекСервиса, НастройкиПодключения);
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

// Возвращает массив допустимых имен граф котировок
//
// Параметры:
//  ИменаГрафКотировок	 - Строка	 - Имена
// 
// Возвращаемое значение:
//   - Массив- Массив граф
//
Функция ДопустимыеГрафыКотировок(ИменаГрафКотировок = Неопределено) Экспорт
	
	ИменаГрафКотировок = Новый СписокЗначений;
	
	МассивДопустимыхГраф = Новый Массив;
	ДопустимыйТип = Тип("Число");
	ГрафыКотировок = Метаданные.РегистрыСведений.Котировки.Ресурсы;
	
	Для Каждого Графа Из ГрафыКотировок Цикл
		Если Графа.Тип.СодержитТип(ДопустимыйТип) Тогда
			ТекущееИмя = Графа.Имя;
			МассивДопустимыхГраф.Добавить(ТекущееИмя);
			ИменаГрафКотировок.Добавить(ТекущееИмя, Графа.Синоним + " [" + ТекущееИмя + "]");
		КонецЕсли;
	КонецЦикла;
	
	Возврат МассивДопустимыхГраф;
	
КонецФункции

#КонецОбласти

#КонецОбласти

#Область ЗагрузкаКурсовВалютЭкспорт

// Загрузить курсы валют интерфакс.
//
// Параметры:
//  Период				 - СтандартныйПериод - Период загрузки
//  СписокБазовыхВалют	 - Массив			 - Базовые валюты
//  СписокВалют			 - Массив			 - Валюты
//  Отказ				 - Булево			 - Признак отказа
//  ТекстОтказа			 - Строка			 - Описание ошибки
//  ТабличныйДокумент	 - ТабличныйДокумент - Табличный документ
//  ЛогПолученныхДанных	 - ТекстовыйДокумент - Текстовый Документ
//
Процедура ЗагрузитьКурсыВалютИнтерфакс(Период,
	СписокБазовыхВалют, СписокВалют,
	Отказ,
	ТекстОтказа,
	ТабличныйДокумент = Неопределено,
	ЛогПолученныхДанных = Неопределено) Экспорт
	
	Перем Соединение;
	Перем Токен;
	Перем Сессия;
	
	ИмяНастроекСервиса = "НастройкиИнтерфакс";
	
	АдресСервиса	= "/v2/Archive/CurrencyRate";
	СлужебныйВызов = Ложь;
	RuDataAPI.ПодключитьсяКСервису(Соединение, Токен, Отказ, ТекстОтказа, СлужебныйВызов, Сессия);
	Если Отказ Тогда
		Возврат;
	КонецЕсли;
	
	ВремяНачалаФормирования = ОценкаПроизводительности.НачатьЗамерВремени();
	КоличествоВалют = СписокВалют.Количество();
	
	СервисыMarketDataAPI = Обработки.СервисыMarketDataAPI.Создать();
	Макет 				 = СервисыMarketDataAPI.ПолучитьМакет("Лог");
	Настройки 			 = НастройкиСервисаAPI(ИмяНастроекСервиса);
	
	ФорматДаты			 = "ДФ=dd.MM.yyyy";
	
	ПериодОтчета		 = ПериодОтчета(Период, Настройки);
	ДатаНачала			 = ПериодОтчета.ДатаНачала;
	ДатаОкончания		 = ПериодОтчета.ДатаОкончания;
	
	// Определяем период получения данных
	ТаблицаПериодов		 = ДопустимыйИнтервал(ДатаНачала, ДатаОкончания);
	КоличествоДней		 = ТаблицаПериодов.Количество();
	
	// Выводим заголовок таблицы
	Если ТабличныйДокумент <> Неопределено Тогда
		ОбластьЗаголовокТаблицы = Макет.ПолучитьОбласть("ЗаголовокТаблицы");
		ТабличныйДокумент.Вывести(ОбластьЗаголовокТаблицы, 0);
	КонецЕсли;
	
	// Лог полученных данных
	Если ТипЗнч(ЛогПолученныхДанных) = Тип("ТекстовыйДокумент") Тогда
		ПредставлениеПериода = Формат(ДатаНачала, ФорматДаты) + " - " + Формат(ДатаОкончания, ФорматДаты);
		ЛогПолученныхДанных.ДобавитьСтроку(
		"------------------------------------------------------------------------------------------------------------------");
		ТекстЛога = СтрШаблон(НСтр("ru='Получение курсов валют из метода  /v2/Archive/CurrencyRate за период: %1.'"),
			ПредставлениеПериода);
		ЛогПолученныхДанных.ДобавитьСтроку(ТекстЛога);
		ЛогПолученныхДанных.ДобавитьСтроку(
		"------------------------------------------------------------------------------------------------------------------");
	КонецЕсли;
	
	Для Каждого ТекСтрокаПериода Из ТаблицаПериодов Цикл
		
		ДатаКурса = НачалоДня(ТекСтрокаПериода.РезультирующаяДата);
		
		// --> ЖурналРегистрацииВызовов
		ОписаниеВызова = РегистрыСведений.ЖурналРегистрацииВызовов.НовоеОписаниеВызова(
			"URL = " + АдресСервиса,
			"ОбщийМодуль.MarketData.ЗагрузитьКурсыВалютИнтерфакс");
		РегистрыСведений.ЖурналРегистрацииВызовов.ЗафиксироватьНачало(ОписаниеВызова);
		// <--
		
		Для Каждого БазоваяВалюта Из СписокБазовыхВалют Цикл // Здесь только один элемент RUB
			
			ПараметрыОбработки = Новый Структура;
			ПараметрыОбработки.Вставить("ДатаКурса"		, ДатаКурса);
			ПараметрыОбработки.Вставить("БазоваяВалюта"	, БазоваяВалюта);
			ПараметрыОбработки.Вставить("СписокВалют"	, СписокВалют);
			ПараметрыОбработки.Вставить("Макет"			, Макет);
			ПараметрыОбработки.Вставить("Сессия"		, Сессия);
			
			ОбработатьКурсыВалютИнтерфакс(ПараметрыОбработки, Отказ, ТекстОтказа, ТабличныйДокумент, ЛогПолученныхДанных);
		КонецЦикла; // По базовым валютам
		
		РегистрыСведений.ЖурналРегистрацииВызовов.ЗафиксироватьОкончание(ОписаниеВызова, Формат(ДатаКурса, "ДФ=yyyy-MM-dd"));
		
	КонецЦикла; // По периодам
	
	ВесЗамера = КоличествоДней * КоличествоВалют;
	ОценкаПроизводительности.ЗакончитьЗамерВремени("MarketData.ЗагрузитьКурсыВалютИнтерфакс", ВремяНачалаФормирования, ВесЗамера);
	
	// Выходим из сервиса
	RuDataAPI.ВыйтиИзСервиса(Соединение, Отказ, ТекстОтказа);
	
КонецПроцедуры

#КонецОбласти

#Область ЗагрузкаНКДЭкспорт

// Загрузка НКД внешнего сервиса
//
// Параметры:
//  ИмяНастроекСервиса	 - Строка			 - Имя настроек сервиса
//  Период				 - СтандартныйПериод - Период загрузки
//  ПараметрыИсточника	 - Структура		 - Структура с полями: ВидИсточника- Вид источника загрузки; ТаблицаISIN- Таблица с колонкой ISIN
//  Отказ				 - Булево			 - Признак отказа
//  ТекстОтказа			 - Строка			 - Описание ошибки
//  ТабличныйДокумент	 - ТабличныйДокумент - Табличный документ
//  ЛогПолученныхДанных	 - ТекстовыйДокумент - Текстовый Документ
//
Процедура ЗагрузитьНКДВнешнегоСервиса(ИмяНастроекСервиса, Период,
	ПараметрыИсточника,
	Отказ,
	ТекстОтказа,
	ТабличныйДокумент = Неопределено,
	ЛогПолученныхДанных = Неопределено) Экспорт
	
	Перем Соединение;
	Перем Токен;
	Перем Сессия;
	
	СквозныеПараметры = НовыеПараметрыЗагрузкиКотировок(ИмяНастроекСервиса, ПараметрыИсточника);
	ЗагрузитьКотировкиВнешнегоСервисаПодключение(СквозныеПараметры, Отказ, ТекстОтказа, Соединение, Токен, Сессия);
	Если Отказ Тогда
		Возврат;
	КонецЕсли;
	
	ВремяНачалаФормирования = ОценкаПроизводительности.НачатьЗамерВремени();
	
	ПоВсемЦеннымБумагам		 = Не ЗначениеЗаполнено(СквозныеПараметры.ТаблицаISIN);
	СквозныеПараметры.Вставить("ПоВсемЦеннымБумагам", ПоВсемЦеннымБумагам);
	СервисыMarketDataAPI	 = Обработки.СервисыMarketDataAPI.Создать();
	Макет 					 = СервисыMarketDataAPI.ПолучитьМакет("Лог");
	СквозныеПараметры.Вставить("Макет", Макет);
	
	Настройки 				 = НастройкиСервисаAPI(СквозныеПараметры.ИмяНастроекСервиса);
	Если Настройки.Свойство("ТипПериодаЗагрузкиКотировок") Тогда
		Настройки.ТипПериодаЗагрузкиКотировок = Перечисления.ПериодыДней.ТекущийДень;
	КонецЕсли;
	ПоместитьНастройкиСервисаВСквозныеПараметры(СквозныеПараметры, Настройки);
	
	ФорматДаты			 = "ДФ=dd.MM.yyyy";
	
	ПериодОтчета	 = ПериодОтчета(Период, Настройки);
	ДатаНачала		 = ПериодОтчета.ДатаНачала;
	ДатаОкончания	 = ПериодОтчета.ДатаОкончания;
	
	СписокАктивов		 = СписокАктивовДляЗапросаКотировок(СквозныеПараметры, ДатаНачала);
	СквозныеПараметры.Вставить("СписокАктивов", СписокАктивов);
	СписокISIN			 = ОбщегоНазначения.ВыгрузитьКолонку(СписокАктивов, "ISIN", Истина);
	КоличествоISIN		 = СписокISIN.Количество();
	ПакетыКодов			 = ПакетыКодов(СписокISIN, СквозныеПараметры.МаксимальноеКоличествоЦенныхБумагВЗапросеКотировок);
	СквозныеПараметры.Вставить("ПакетыКодов", ПакетыКодов);
	ВсегоПакетов		 = ПакетыКодов.Количество();
	СквозныеПараметры.Вставить("ВсегоПакетов", ВсегоПакетов);
	СквозныеПараметры.Вставить("ИдентификаторыТорговыхПлощадок", Новый Массив);
	СоответствиеПолейБиржи = Новый Соответствие;
	Если СквозныеПараметры.ИмяДействия = "ЗагрузитьКупоныCBonds" Тогда
		СквозныеПараметры.Вставить("Биржа", Справочники.ИнформационноАналитическиеСистемы.CBonds);
		СоответствиеПолейБиржи.Вставить("AccInt", СквозныеПараметры.ИмяРеквизитаНКД);
	Иначе
		СквозныеПараметры.Вставить("Биржа", Справочники.ИнформационноАналитическиеСистемы.ПустаяСсылка());
	КонецЕсли;
	СквозныеПараметры.Вставить("СоответствиеПолейБиржи", СоответствиеПолейБиржи);
	
	// Определяем период получения данных
	ТолькоРабочиеДни	 = Ложь;
	ТаблицаПериодов		 = ДопустимыйИнтервал(ДатаНачала, ДатаОкончания, ТолькоРабочиеДни);
	СквозныеПараметры.Вставить("ТаблицаПериодов", ТаблицаПериодов);
	КоличествоДней		 = СквозныеПараметры.ТаблицаПериодов.Количество();
	
	// Выводим заголовок таблицы
	Если ТабличныйДокумент <> Неопределено Тогда
		ОбластьЗаголовокТаблицы = СквозныеПараметры.Макет.ПолучитьОбласть("ЗаголовокТаблицы");
		ТабличныйДокумент.Вывести(ОбластьЗаголовокТаблицы, 0);
	КонецЕсли;
	
	// Лог полученных данных
	Если ТипЗнч(ЛогПолученныхДанных) = Тип("ТекстовыйДокумент") Тогда
		ПредставлениеПериода = Формат(ДатаНачала, ФорматДаты) + " - " + Формат(ДатаОкончания, ФорматДаты);
		ЛогПолученныхДанных.ДобавитьСтроку(
		"------------------------------------------------------------------------------------------------------------------");
		ТекстЛога = СтрШаблон(НСтр("ru='" + ПараметрыИсточника.ВидИсточника + " за период: %1.'"),
			ПредставлениеПериода);
		ЛогПолученныхДанных.ДобавитьСтроку(ТекстЛога);
		ЛогПолученныхДанных.ДобавитьСтроку(
		"------------------------------------------------------------------------------------------------------------------");
	КонецЕсли;
	
	ПолученныеДанныеКоличествоСтрокИтого = 0;
	Для Каждого ТекСтрокаПериода Из ТаблицаПериодов Цикл
		ТаблицаНКДЦенныхБумагКоличество = 0;
		ДатаПолученияКотировок = НачалоДня(ТекСтрокаПериода.РезультирующаяДата);
		СквозныеПараметры.Вставить("ДатаПолученияКотировок", ДатаПолученияКотировок);
		
		// --> ЖурналРегистрацииВызовов
		ОписаниеВызова = РегистрыСведений.ЖурналРегистрацииВызовов.НовоеОписаниеВызова(
			"URL = " + ПараметрыИсточника.ВидИсточника,
			"ОбщийМодуль.MarketData.ЗагрузитьНКДВнешнегоСервиса");
		РегистрыСведений.ЖурналРегистрацииВызовов.ЗафиксироватьНачало(ОписаниеВызова);
		// <--
		
		ОбработаноПакетов = 0;
		Для Каждого ПакетКодов Из ПакетыКодов Цикл
			СквозныеПараметры.Вставить("ПакетКодов", ПакетКодов);
			СквозныеПараметры.Вставить("ПакетКодовКотировкаНайдена", Новый Массив);
			ТаблицаНКДЦенныхБумагКоличество =
				ПолучитьЗаписатьНКД(СквозныеПараметры, ЛогПолученныхДанных, Сессия, Соединение, Отказ, ТекстОтказа, ТабличныйДокумент);
			ПолученныеДанныеКоличествоСтрокИтого = ПолученныеДанныеКоличествоСтрокИтого + ТаблицаНКДЦенныхБумагКоличество;
			ОбработаноПакетов = ОбработаноПакетов + 1;
		КонецЦикла; // По пакетам ISIN
		
		РегистрыСведений.ЖурналРегистрацииВызовов.ЗафиксироватьОкончание(ОписаниеВызова, Формат(ДатаПолученияКотировок, "ДФ=yyyy-MM-dd"));
		
		ВывестиЛог(ТабличныйДокумент, СквозныеПараметры, ОбработаноПакетов, ТаблицаНКДЦенныхБумагКоличество);
		
	КонецЦикла; // По периодам
	
	// Замер производительности
	ВесЗамера = КоличествоДней * КоличествоISIN;
	КомментарийЗамера = "[" + ПолученныеДанныеКоличествоСтрокИтого + "] - строк данных получено";
	ОценкаПроизводительности.ЗакончитьЗамерВремени("MarketData.ЗагрузитьНКДВнешнегоСервиса."
		+ СквозныеПараметры.ИмяДействия, ВремяНачалаФормирования, ВесЗамера, КомментарийЗамера);
	
КонецПроцедуры

#КонецОбласти

#Область ЗагрузкаПризнакаЭмитентаМеждународнаяКомпанияЭкспорт

// Функция - Эмитенты к изменению признака международная компания
//
// Параметры:
//  СквозныеПараметры	 - Структура - Структура для передачи параметров
// 
// Возвращаемое значение:
//   - Структура - Структура с массивами "МеждународныеКомпании" и "НеМеждународныеКомпании"
//
Функция ЭмитентыКИзменениюПризнакаМеждународнаяКомпания(СквозныеПараметры) Экспорт
	
	ОписаниеОшибки = "";
	Сессия = Неопределено;
	СквозныеПараметры.Вставить("ДатаВремяОбновленияДанных", ТекущаяДатаСеанса());
	СквозныеПараметры.Вставить("filter", "id_category = 8654");
	ТаблицаРезультата = RuDataAPI.InfoEmitentCategoryValue(ОписаниеОшибки, Сессия, СквозныеПараметры);
	
	Если ОписаниеОшибки <> "" Или Не ЗначениеЗаполнено(ТаблицаРезультата) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	ДанныеПоМК = ДанныеПоМеждународнымКомпаниямRuData(ТаблицаРезультата);
	РезультатыЗапроса = ПакетныйЗапросСменыПризнакаМеждународнаяКомпания(СквозныеПараметры, ДанныеПоМК);
	
	РезультатыЗапросаМеждународныеКомпании = РезультатыЗапроса[4];
	МеждународныеКомпании = РезультатыЗапросаМеждународныеКомпании.Выгрузить();
	РезультатыЗапросаНеМеждународныеКомпании = РезультатыЗапроса[5];
	НеМеждународныеКомпании = РезультатыЗапросаНеМеждународныеКомпании.Выгрузить();
	РезультатыЗапросаИзменениеПризнакаРегистрацииМК = РезультатыЗапроса[6];
	ИзменениеПризнакаРегистрацииМК = РезультатыЗапросаИзменениеПризнакаРегистрацииМК.Выгрузить();
	
	СменаПризнакаМеждународнаяКомпания = Новый Структура;
	СменаПризнакаМеждународнаяКомпания.Вставить("МеждународныеКомпании", МеждународныеКомпании);
	СменаПризнакаМеждународнаяКомпания.Вставить("НеМеждународныеКомпании", НеМеждународныеКомпании);
	СменаПризнакаМеждународнаяКомпания.Вставить("ИзменениеПризнакаРегистрацииМК", ИзменениеПризнакаРегистрацииМК);
	
	Возврат СменаПризнакаМеждународнаяКомпания;
	
КонецФункции

// Процедура - Изменить признак эмитента международная компания по данным RuData
//
// Параметры:
//  Выполнено	 - Булево	 - Признак того, что хотя бы одно изменение выполнено
//
Процедура ИзменитьПризнакЭмитентаМеждународнаяКомпанияПоДаннымRuData(Выполнено = Ложь) Экспорт
	
	СквозныеПараметры = Новый Структура;
	СменаПризнакаМеждународнаяКомпания = ЭмитентыКИзменениюПризнакаМеждународнаяКомпания(СквозныеПараметры);
	Если Не ЗначениеЗаполнено(СменаПризнакаМеждународнаяКомпания) Тогда
		Возврат;
	КонецЕсли;
	
	ПризнакМеждународнаяКомпания = Ложь;
	Для Каждого СтрокаПоЭмитенту Из СменаПризнакаМеждународнаяКомпания.НеМеждународныеКомпании Цикл
		ИзменитьПризнакЭмитентаМеждународнаяКомпания(СквозныеПараметры, СтрокаПоЭмитенту, ПризнакМеждународнаяКомпания);
	КонецЦикла;
	
	ПризнакМеждународнаяКомпания = Истина;
	Для Каждого СтрокаПоЭмитенту Из СменаПризнакаМеждународнаяКомпания.МеждународныеКомпании Цикл
		ИзменитьПризнакЭмитентаМеждународнаяКомпания(СквозныеПараметры, СтрокаПоЭмитенту, ПризнакМеждународнаяКомпания);
	КонецЦикла;
	
	Для Каждого СтрокаПоЭмитенту Из СменаПризнакаМеждународнаяКомпания.ИзменениеПризнакаРегистрацииМК Цикл
		ИзменитьПризнакЭмитентаМеждународнаяКомпания(СквозныеПараметры, СтрокаПоЭмитенту, ПризнакМеждународнаяКомпания);
	КонецЦикла;
	
	Выполнено = СменаПризнакаМеждународнаяКомпания.МеждународныеКомпании.Количество() > 0
		Или СменаПризнакаМеждународнаяКомпания.НеМеждународныеКомпании.Количество() > 0
		Или СменаПризнакаМеждународнаяКомпания.ИзменениеПризнакаРегистрацииМК.Количество() > 0;
	
	Если Выполнено Тогда
		ОтправитьУведомлениеОСменеСтатусаМеждународнаяКомпания(СквозныеПараметры, СменаПризнакаМеждународнаяКомпания);
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ФорматыДанныхЭкспорт

// Функция - Текст из PDF
//
// Параметры:
//  ИмяФайлаPDF		 - Строка	 - Полный путь к файлу PDF Или
//  МакетPDF		 - Макет	 - Двоичный макет с файлом PDF
//  ОшибкаЧтенияPDF	 - Строка	 - Описание ошибки
// 
// Возвращаемое значение:
//   - Массив - Текстовое содержание файла PDF в виде массива строк неограниченной длины
//
Функция ТекстPDF(ИмяФайлаPDF = Неопределено, МакетPDF = Неопределено, ОшибкаЧтенияPDF = "") Экспорт
	
	ТекстPDF = Новый Массив;
	
	Попытка
		
		ВременныйФайлTXT = ПолучитьИмяВременногоФайла(".TXT");
		ВременныйФайлPDF = ПолучитьИмяВременногоФайла(".pdf");
		Если ИмяФайлаPDF <> Неопределено Тогда
			КопироватьФайл(ИмяФайлаPDF, ВременныйФайлPDF);
		ИначеЕсли МакетPDF <> Неопределено Тогда
			МакетPDF.Записать(ВременныйФайлPDF);
		Иначе
			ОшибкаЧтенияPDF = "Неверные параметры";
			Возврат ТекстPDF;
		КонецЕсли;
		
		Макет = Обработки.СервисыMarketDataAPI.ПолучитьМакет("pdftotext");
		ВременныйФайлEXE = ПолучитьИмяВременногоФайла(".exe");
		Макет.Записать(ВременныйФайлEXE);
		
		СтрокаЗапуска = ВременныйФайлEXE + " -layout -table -enc UTF-8 -nodiag " + ВременныйФайлPDF + " " + ВременныйФайлTXT;
		ЗапуститьПриложение(СтрокаЗапуска, , Истина);
		УдалитьФайлы(ВременныйФайлEXE);
		УдалитьФайлы(ВременныйФайлPDF);
		
		Файл = Новый Файл(ВременныйФайлTXT);
		Если Файл.Существует() Тогда
			ПрочитатьТекстPDF(ТекстPDF, ВременныйФайлTXT);
			УдалитьФайлы(ВременныйФайлTXT);
		КонецЕсли;
		
	Исключение
		ОшибкаЧтенияPDF = ОбработкаОшибок.КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
	КонецПопытки;
	
	Возврат ТекстPDF;
	
КонецФункции

#КонецОбласти

 // Возвращает признак ценная бумага [Ru]
//
// Параметры:
//  Isin - Строка - ISIN ценной бумаги
// 
// Возвращаемое значение:
//   - Булево - Признак ценная бумага [Ru]
//
Функция ЭтоЦБRu(Isin) Экспорт
	
	Если НРег(Лев(Isin, 2)) = "ru" Тогда
		Возврат Истина;
	Иначе
		Возврат Ложь;
	КонецЕсли;
	
КонецФункции

// Возвращает таблицу с датами из указанного интервала
//
// Параметры:
//  ДатаНачала		 - Дата		 - Начало периода поиска дат
//  ДатаОкончания	 - Дата		 - Окончание периода поиска дат
//  ТолькоРабочиеДни - Булево	 - Поиск только рабочих дат
// 
// Возвращаемое значение:
//   - ТаблицаЗначений - Таблица с колонкой РезультирующаяДата
//
Функция ДопустимыйИнтервал(ДатаНачала, ДатаОкончания, ТолькоРабочиеДни = Ложь) Экспорт
	
	ТаблицаПериодов = Новый ТаблицаЗначений;
	
	КвалификаторДаты = ОбщегоНазначения.ПолучитьОписаниеТиповДаты(ЧастиДаты.Дата);
	
	ТаблицаПериодов.Колонки.Добавить("РезультирующаяДата", КвалификаторДаты);
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Календарь.Период КАК РезультирующаяДата
	|ИЗ
	|	РегистрСведений.Календарь КАК Календарь
	|ГДЕ
	|	Календарь.Период МЕЖДУ &ДатаНач И &ДатаКон
	|	И ВЫБОР
	|			КОГДА НЕ &ТолькоРабочиеДни
	|				ТОГДА ИСТИНА
	|			ИНАЧЕ Календарь.Значение = ЛОЖЬ
	|		КОНЕЦ
	|
	|УПОРЯДОЧИТЬ ПО
	|	РезультирующаяДата";
	
	Запрос.УстановитьПараметр("ТолькоРабочиеДни", ТолькоРабочиеДни);
	Запрос.УстановитьПараметр("ДатаКон", ДатаОкончания);
	Запрос.УстановитьПараметр("ДатаНач", ДатаНачала);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	СтрокаПериода = РезультатЗапроса.Выбрать();
	
	Пока СтрокаПериода.Следующий() Цикл
		НоваяСтрокаПериода = ТаблицаПериодов.Добавить();
		НоваяСтрокаПериода.РезультирующаяДата = СтрокаПериода.РезультирующаяДата;
	КонецЦикла;
	
	Возврат ТаблицаПериодов;
	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

#Область ФорматыДанных

Процедура ПрочитатьТекстPDF(ТекстPDF, ВременныйФайлTXT)
	
	ДвоичныйФайл = Новый ДвоичныеДанные(ВременныйФайлTXT);
	Поток		 = ДвоичныйФайл.ОткрытьПотокДляЧтения();
	ФайлЧтение	 = Новый ЧтениеТекста(Поток, КодировкаТекста.UTF8);
	ЧислоСтраниц = СтрЧислоВхождений(ФайлЧтение.Прочитать(), Символы.ПФ);
	Если ЧислоСтраниц > 0 Тогда
		Поток.Перейти( -Поток.ТекущаяПозиция(), ПозицияВПотоке.Конец); // Вернуться в начало после чтения страниц
		СтрокаФайла		 = ФайлЧтение.ПрочитатьСтроку();
		Пока СтрокаФайла <> Неопределено Цикл
			ДопустимаяСтрокаФайла = СокрЛП(ОбщегоНазначенияКлиентСервер.УдалитьНедопустимыеСимволыXML(СтрокаФайла));
			Если СтрДлина(ДопустимаяСтрокаФайла) > 0 Тогда
				ТекстPDF.Добавить(ДопустимаяСтрокаФайла);
			КонецЕсли;
			СтрокаФайла = ФайлЧтение.ПрочитатьСтроку();
		КонецЦикла;
	КонецЕсли;
	ФайлЧтение.Закрыть();
	Поток.Закрыть();
	
КонецПроцедуры

#КонецОбласти

#Область ЗагрузкаПризнакаЭмитентаМеждународнаяКомпания

Функция ДанныеПоМеждународнымКомпаниямRuData(ИсходныеДанныеRuData)
	
	ДанныеПоМК = Новый ТаблицаЗначений;
	ДанныеПоМК.Колонки.Добавить("КодЗагрузкиЭмитента", ОбщегоНазначения.ОписаниеТипаСтрока(1000));
	ДанныеПоМК.Колонки.Добавить("ПризнакРегистрацииМК",
		Новый ОписаниеТипов("ПеречислениеСсылка.ПризнакРегистрацииМеждународнойКомпании"));
	ДанныеПоМК.Колонки.Добавить("ОставитьПрежнийПризнакРегистрацииМК", Новый ОписаниеТипов("Булево"));
	
	ИмяКолонкиКатегорий = "id_category";
	ЧисловыеРеквизиты = Новый СписокЗначений;
	Для Каждого СтрокаТаблицыРезультата Из ИсходныеДанныеRuData Цикл
	
		НоваяСтрока = ДанныеПоМК.Добавить();
		НоваяСтрока.КодЗагрузкиЭмитента = СтрокаТаблицыРезультата.Fininstid;
		Если ТипЗнч(СтрокаТаблицыРезультата.Categories) = Тип("Массив") Тогда
			Категории = RuDataAPI.ПреобразоватьМассивВТаблицуЗначений(СтрокаТаблицыРезультата.Categories, ЧисловыеРеквизиты);
			Если Категории.Найти(9018, ИмяКолонкиКатегорий) <> Неопределено Тогда
				НоваяСтрока.ПризнакРегистрацииМК = Перечисления.ПризнакРегистрацииМеждународнойКомпании.Редомициляция;
			ИначеЕсли Категории.Найти(9019, ИмяКолонкиКатегорий) <> Неопределено Тогда
				НоваяСтрока.ПризнакРегистрацииМК = Перечисления.ПризнакРегистрацииМеждународнойКомпании.Инкорпорация;
			Иначе
				НоваяСтрока.ОставитьПрежнийПризнакРегистрацииМК = Истина;
			КонецЕсли;
		КонецЕсли;
	
	КонецЦикла;
	
	Возврат ДанныеПоМК;
	
КонецФункции

Функция ПакетныйЗапросСменыПризнакаМеждународнаяКомпания(СквозныеПараметры, ДанныеПоМК)
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Период", НачалоДня(СквозныеПараметры.ДатаВремяОбновленияДанных));
	Запрос.УстановитьПараметр("ДанныеПоМК", ДанныеПоМК);
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ДанныеПоМК.КодЗагрузкиЭмитента КАК КодЗагрузкиЭмитента,
	|	ДанныеПоМК.ПризнакРегистрацииМК КАК ПризнакРегистрацииМК,
	|	ДанныеПоМК.ОставитьПрежнийПризнакРегистрацииМК КАК ОставитьПрежнийПризнакРегистрацииМК
	|ПОМЕСТИТЬ ДанныеПоМК
	|ИЗ
	|	&ДанныеПоМК КАК ДанныеПоМК
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЮридическиеЛицаМеждународныеКомпанииСрезПоследних.Период КАК Период,
	|	ЮридическиеЛицаМеждународныеКомпанииСрезПоследних.ЮридическоеЛицо КАК ЮридическоеЛицо,
	|	ЮридическиеЛицаМеждународныеКомпанииСрезПоследних.МеждународнаяКомпания КАК МеждународнаяКомпания,
	|	ЮридическиеЛицаМеждународныеКомпанииСрезПоследних.ПризнакРегистрацииМеждународнойКомпании КАК ПризнакРегистрацииМеждународнойКомпании
	|ПОМЕСТИТЬ ЮридическиеЛицаМеждународныеКомпании
	|ИЗ
	|	РегистрСведений.ЮридическиеЛицаМеждународныеКомпании.СрезПоследних(&Период, НЕ ЮридическоеЛицо.ПометкаУдаления) КАК ЮридическиеЛицаМеждународныеКомпанииСрезПоследних
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	КодыЗагрузки.Код КАК ID,
