Процедура ИзменитьПризнакЭмитентаМеждународнаяКомпания(СквозныеПараметры, СтрокаПоЭмитенту, МеждународнаяКомпания)
	
	НачатьТранзакцию();
	
	Попытка
		
		Если МеждународнаяКомпания Тогда
			ЭтоНерезидент = Истина;
		Иначе
			Если СтрокаПоЭмитенту.ЮридическоеЛицоСтрана = Справочники.КлассификаторСтранМира.РОССИЯ Тогда
				ЭтоНерезидент = Ложь;
			Иначе
				ЭтоНерезидент = Истина;
			КонецЕсли;
		КонецЕсли;
		
		ДатаСменыСтатусаМеждународнаяКомпания =
			?(ЗначениеЗаполнено(СтрокаПоЭмитенту.Период), СтрокаПоЭмитенту.Период, СквозныеПараметры.ДатаВремяОбновленияДанных);
		
		ЭмитентОбъект = СтрокаПоЭмитенту.ЮридическоеЛицо.ПолучитьОбъект();
		ЭмитентОбъект.ДатаСменыСтатусаМеждународнаяКомпания = ДатаСменыСтатусаМеждународнаяКомпания;
		ЭмитентОбъект.МеждународнаяКомпания = МеждународнаяКомпания;
		Если СтрокаПоЭмитенту.ОставитьПрежнийПризнакРегистрацииМК Тогда
			ПризнакРегистрацииМК = ЭмитентОбъект.ПризнакРегистрацииМеждународнойКомпании;
		Иначе
			ПризнакРегистрацииМК = СтрокаПоЭмитенту.ПризнакРегистрацииМК;
			ЭмитентОбъект.ПризнакРегистрацииМеждународнойКомпании = ПризнакРегистрацииМК;
		КонецЕсли;
		ЭмитентОбъект.НеРезидент = ЭтоНерезидент;
		ЭмитентОбъект.ОбменДанными.Загрузка = Истина;
		ЭмитентОбъект.Записать();
		
		КонтрагентЭмитент = Справочники.Контрагенты.КонтрагентПоЮрФизЛицу(ЭмитентОбъект.Ссылка, Истина);
		Если ЗначениеЗаполнено(КонтрагентЭмитент) Тогда
			КонтрагентОбъект = КонтрагентЭмитент.ПолучитьОбъект();
			// Также важно что реквизит Резидент в справочнике контрагентов, как это ни парадоксально, означает "Нерезидент по документам"
			// - живите теперь с этим, если не знали раньше
			КонтрагентОбъект.Резидент = ЭтоНерезидент;
			Если Не ЭтоНерезидент И Не КонтрагентОбъект.РегионДляОтчетовРучнойВвод Тогда
				КонтрагентОбъект.РегионДляОтчетов = Неопределено;
			КонецЕсли;
			КонтрагентОбъект.ОбменДанными.Загрузка = Истина;
			КонтрагентОбъект.Записать();
		КонецЕсли;
		
		РегистрыСведений.ЮридическиеЛицаМеждународныеКомпании.УстановитьПризнакМеждународнаяКомпания(ДатаСменыСтатусаМеждународнаяКомпания,
			СтрокаПоЭмитенту.ЮридическоеЛицо, МеждународнаяКомпания, ПризнакРегистрацииМК);
		
		ЗафиксироватьТранзакцию();
	Исключение
		ОтменитьТранзакцию();
		
		ТребуемыйУровеньЖурналаРегистрации = УровеньЖурналаРегистрации.Предупреждение;
		ТекстОшибки = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		ЗаписьЖурналаРегистрации("MarketData.ИзменитьПризнакЭмитентаМеждународнаяКомпания",
			ТребуемыйУровеньЖурналаРегистрации, , , ТекстОшибки);
	КонецПопытки;
	
КонецПроцедуры

Процедура ОтправитьУведомлениеОСменеСтатусаМеждународнаяКомпания(СквозныеПараметры, СменаПризнакаМеждународнаяКомпания)
	
	ВнешнийИсточник = ПланыВидовХарактеристик.ВнешниеИсточники.РассылкаУведомленийОСтатусеМеждународнаяКомпания;
	НастройкиОбмена = ВнешниеДанные.ПолучитьПараметрыВнешнегоИсточника(ВнешнийИсточник).Настройка;
	Если НастройкиОбмена = Неопределено Тогда
		ТекстОшибки = "Не заданы параметры внешнего источника """ + Строка(ВнешнийИсточник) + """";
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстОшибки);
		ИмяСобытия = "Уведомление для корректировки по ЮЛ даты статуса 'Международная компания' не отправлено";
		ЗаписьЖурналаРегистрации(ИмяСобытия, УровеньЖурналаРегистрации.Предупреждение, , , ТекстОшибки);
		Возврат;
	КонецЕсли;
	
	ЭмитентыКСменеСтатуса = Новый Массив;
	ТаблицаСтатусовЭмитентов = Новый ТаблицаЗначений;
	ТаблицаСтатусовЭмитентов.Колонки.Добавить("Код");
	ТаблицаСтатусовЭмитентов.Колонки.Добавить("Наименование");
	ТаблицаСтатусовЭмитентов.Колонки.Добавить("МеждународнаяКомпания");
	ТаблицаСтатусовЭмитентов.Колонки.Добавить("ДатаНачалаДействияСтатусаМеждународнаяКомпания");
	ТаблицаСтатусовЭмитентов.Колонки.Добавить("ПризнакРегистрацииМеждународнойКомпании");
	
	ПризнакМеждународнаяКомпания = Ложь;
	ДополнитьТаблицуСтатусовЭмитентов(ТаблицаСтатусовЭмитентов, СменаПризнакаМеждународнаяКомпания.НеМеждународныеКомпании,
		ПризнакМеждународнаяКомпания, СквозныеПараметры.ДатаВремяОбновленияДанных, ЭмитентыКСменеСтатуса);
	ПризнакМеждународнаяКомпания = Истина;
	ДополнитьТаблицуСтатусовЭмитентов(ТаблицаСтатусовЭмитентов, СменаПризнакаМеждународнаяКомпания.МеждународныеКомпании,
		ПризнакМеждународнаяКомпания, СквозныеПараметры.ДатаВремяОбновленияДанных, ЭмитентыКСменеСтатуса);
	ДополнитьТаблицуСтатусовЭмитентов(ТаблицаСтатусовЭмитентов, СменаПризнакаМеждународнаяКомпания.ИзменениеПризнакаРегистрацииМК,
		ПризнакМеждународнаяКомпания, СквозныеПараметры.ДатаВремяОбновленияДанных, ЭмитентыКСменеСтатуса);
	
	ТемаПисьма = "Проверить данные международной компании у эмитентов";
	ТекстПисьма = ТекстУведомленияОСменеСтатусаМеждународнаяКомпания(ТаблицаСтатусовЭмитентов, ЭмитентыКСменеСтатуса);
	ПараметрыУведомления = Новый Соответствие;
	ПараметрыУведомления.Вставить("НастройкиОбмена",	НастройкиОбмена);
	ПараметрыУведомления.Вставить("Кодировка",			"UTF-8");
	ПараметрыУведомления.Вставить("ТемаПисьма",			ТемаПисьма);
	ПараметрыУведомления.Вставить("ТекстПисьма",		ТекстПисьма);
	ПараметрыУведомления.Вставить("ТипТекстаПисьма",	ТипТекстаПочтовогоСообщения.HTML);
	ПараметрыУведомления.Вставить("Важность",			ВажностьИнтернетПочтовогоСообщения.Обычная);
	РегистрыСведений.УведомленияКОтправке.ДобавитьУведомлениеКотправке(ПараметрыУведомления);
	
КонецПроцедуры

Процедура ДополнитьТаблицуСтатусовЭмитентов(ТаблицаСтатусовЭмитентов, ТаблицаЭмитентовИсточник, ПризнакМеждународнаяКомпания,
	ДатаВремяОбновленияДанных, ЭмитентыКСменеСтатуса)
	
	Для Каждого СтрокаПоЭмитенту Из ТаблицаЭмитентовИсточник Цикл
		НовыйСтатус = ТаблицаСтатусовЭмитентов.Добавить();
		НовыйСтатус.Код						 = СтрокаПоЭмитенту.ЮридическоеЛицоКод;
		НовыйСтатус.Наименование			 = СтрокаПоЭмитенту.ЮридическоеЛицоНаименование;
		НовыйСтатус.МеждународнаяКомпания	 = ПризнакМеждународнаяКомпания;
		ДатаНачалаДействияСтатусаМеждународнаяКомпания =
			?(ЗначениеЗаполнено(СтрокаПоЭмитенту.Период), СтрокаПоЭмитенту.Период, ДатаВремяОбновленияДанных);
		НовыйСтатус.ДатаНачалаДействияСтатусаМеждународнаяКомпания =
			Формат(ДатаНачалаДействияСтатусаМеждународнаяКомпания, "ДФ=dd.MM.yyyy");
		НовыйСтатус.ПризнакРегистрацииМеждународнойКомпании = СтрокаПоЭмитенту.ПризнакРегистрацииМК;
		ЭмитентыКСменеСтатуса.Добавить(СтрокаПоЭмитенту.ЮридическоеЛицо);
	КонецЦикла;
	
КонецПроцедуры

Функция ТекстУведомленияОСменеСтатусаМеждународнаяКомпания(ТаблицаСтатусовЭмитентов, ЭмитентыКСменеСтатуса)
	
	ПС = "<br>";			// Тег HTML означает перевод строки
	ВключитьBold = "<b>";	// Тег HTML означает включить жирный шрифт
	ОтключитьBold = "</b>";	// Тег HTML означает отключить жирный шрифт
	ВключитьКрасный = " <font color='red'>";	// Тег HTML означает включить красный шрифт
