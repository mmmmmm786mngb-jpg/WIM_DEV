#Область ЗагрузитьКотировкиВнешнегоСервиса

Процедура ПоместитьНастройкиСервисаВСквозныеПараметры(СквозныеПараметры, Настройки)
	
	НеПроцентныеПоля		 = СтрРазделить(Настройки.НеПроцентныеПоля, ",");
	СквозныеПараметры.Вставить("НеПроцентныеПоля", НеПроцентныеПоля);
	Если Настройки.Свойство("КромеЦенныхБумагRU") Тогда
		КромеЦенныхБумагRU		 = Настройки.КромеЦенныхБумагRU;
	Иначе
		КромеЦенныхБумагRU		 = Ложь;
	КонецЕсли;
	СквозныеПараметры.Вставить("КромеЦенныхБумагRU", КромеЦенныхБумагRU);
	Если Настройки.Свойство("ОграничениеПоКоличествуISIN") Тогда
		ОграничениеПоКоличествуISIN		 = Настройки.ОграничениеПоКоличествуISIN;
	Иначе
		ОграничениеПоКоличествуISIN		 = 0;
	КонецЕсли;
	СквозныеПараметры.Вставить("ОграничениеПоКоличествуISIN", ОграничениеПоКоличествуISIN);
	Если Настройки.Свойство("ЗагружатьКотировкиПоПервичнойБирже") Тогда
		ЗагружатьКотировкиПоПервичнойБирже = Настройки.ЗагружатьКотировкиПоПервичнойБирже;
	Иначе
		ЗагружатьКотировкиПоПервичнойБирже = Ложь;
	КонецЕсли;
	СквозныеПараметры.Вставить("ЗагружатьКотировкиПоПервичнойБирже", ЗагружатьКотировкиПоПервичнойБирже);
	Если Настройки.Свойство("ОбязательныйВыборПлощадкиСогласноСортировке") Тогда
		ОбязательныйВыборПлощадкиСогласноСортировке = Настройки.ОбязательныйВыборПлощадкиСогласноСортировке;
	Иначе
		ОбязательныйВыборПлощадкиСогласноСортировке = Ложь;
	КонецЕсли;
	СквозныеПараметры.Вставить("ОбязательныйВыборПлощадкиСогласноСортировке", ОбязательныйВыборПлощадкиСогласноСортировке);
	Если Настройки.Свойство("ОбязательныйВыборПлощадкиПолеСортировки") Тогда
		ОбязательныйВыборПлощадкиПолеСортировки = Настройки.ОбязательныйВыборПлощадкиПолеСортировки;
	Иначе
		ОбязательныйВыборПлощадкиПолеСортировки = "";
	КонецЕсли;
	СквозныеПараметры.Вставить("ОбязательныйВыборПлощадкиПолеСортировки", ОбязательныйВыборПлощадкиПолеСортировки);
	
КонецПроцедуры

Процедура ЗагрузитьКотировкиВнешнегоСервисаПодключение(СквозныеПараметры, Отказ, ТекстОтказа, Соединение, Токен, Сессия)
	
	СлужебныйВызов = Ложь;
	Если СквозныеПараметры.ИмяНастроекСервиса = СквозныеПараметры.ИмяНастроекСервисаИнтерфакс Тогда
		RuDataAPI.ПодключитьсяКСервису(Соединение, Токен, Отказ, ТекстОтказа, СлужебныйВызов, Сессия);
	ИначеЕсли СквозныеПараметры.ИмяНастроекСервиса = СквозныеПараметры.ИмяНастроекСервисаНРД Тогда
		NSDAPI.ПодключитьсяКСервису(Соединение, Токен, Отказ, ТекстОтказа, СлужебныйВызов, Сессия);
	ИначеЕсли СквозныеПараметры.ИмяНастроекСервиса = СквозныеПараметры.ИмяНастроекСервисаCBonds Тогда
		Если CBondsAPI.ПодключениеИнициализировать(Неопределено, Сессия, Отказ, ТекстОтказа) Тогда
			Соединение = Сессия.WSОпределение;
		КонецЕсли;
	Иначе
		Отказ = Истина;
	КонецЕсли;
	
КонецПроцедуры

Функция НовыеПараметрыЗагрузкиКотировок(ИмяНастроекСервиса, ПараметрыИсточника)
	
	СквозныеПараметры = Новый Структура;
	СквозныеПараметры.Вставить("ИмяНастроекСервиса"										, ИмяНастроекСервиса);
	СквозныеПараметры.Вставить("ЧисловыеРеквизиты"										, Неопределено);
	СквозныеПараметры.Вставить("КореньИсточника"										, Неопределено);
	СквозныеПараметры.Вставить("КешИсточниковКотировок"									, Неопределено);
	СквозныеПараметры.Вставить("КодЛюбойПлощадки"										, Неопределено);
	СквозныеПараметры.Вставить("РежимТоргов"											, Неопределено);
	СквозныеПараметры.Вставить("МаксимальноеКоличествоЦенныхБумагВЗапросеКотировок"		, 0);
	СквозныеПараметры.Вставить("ИмяРеквизитаПлощадка"									, "");
	СквозныеПараметры.Вставить("ИмяРеквизитаПлощадкаОсновная"							, "");
	СквозныеПараметры.Вставить("ИмяМетодаAPI"											, "");
	СквозныеПараметры.Вставить("ИмяРеквизитаLAST"										, "");
	СквозныеПараметры.Вставить("ИмяРеквизитаLAST2"										, "");
	СквозныеПараметры.Вставить("ИмяРеквизитаНКД"										, "");
	СквозныеПараметры.Вставить("ИмяРеквизитаНКД2"										, "");
	СквозныеПараметры.Вставить("ИмяРеквизитаНКД3"										, "");
	СквозныеПараметры.Вставить("ИмяРеквизитаCurrency"									, "currency");
	СквозныеПараметры.Вставить("ИмяРеквизитаIsin"										, "");
	СквозныеПараметры.Вставить("ИмяНастроекСервисаИнтерфакс"							, "НастройкиИнтерфакс");
	СквозныеПараметры.Вставить("ИмяНастроекСервисаНРД"									, "НастройкиНРД");
	СквозныеПараметры.Вставить("ИмяНастроекСервисаCBonds"								, "НастройкиCBonds");
	СквозныеПараметры.Вставить("ИмяДействия"											, ПараметрыИсточника.ИмяДействия);
	СквозныеПараметры.Вставить("ВидИсточника"											, ПараметрыИсточника.ВидИсточника);
	СквозныеПараметры.Вставить("ТаблицаISIN"											, ПараметрыИсточника.ТаблицаISIN);
	СквозныеПараметры.Вставить("ЭтоЗагрузкаНКД"											, Ложь);
	
	ЧисловыеРеквизиты = Новый СписокЗначений;
	
	Если СквозныеПараметры.ИмяНастроекСервиса = СквозныеПараметры.ИмяНастроекСервисаИнтерфакс Тогда
		СквозныеПараметры.КореньИсточника = Справочники.ИсточникиКотировок.RuData;
		СквозныеПараметры.КодЛюбойПлощадки = 0;
		СквозныеПараметры.МаксимальноеКоличествоЦенныхБумагВЗапросеКотировок = 20;
		СквозныеПараметры.ИмяРеквизитаПлощадка = "tradeSite";
		СквозныеПараметры.ИмяРеквизитаПлощадкаОсновная = "tradeSite";
		СквозныеПараметры.ИмяМетодаAPI = "/v2/Archive/EndOfDayOnExchanges";
		СквозныеПараметры.ИмяРеквизитаLAST = "last";
		СквозныеПараметры.ИмяРеквизитаНКД = "accruedint";
		СквозныеПараметры.ИмяРеквизитаIsin = "isin";
		СквозныеПараметры.РежимТоргов = Справочники.РежимыТоргов.Рыночный;
		
		ЧисловыеРеквизиты.Добавить(СквозныеПараметры.ИмяРеквизитаПлощадка);
	КонецЕсли;
	Если СквозныеПараметры.ИмяНастроекСервиса = СквозныеПараметры.ИмяНастроекСервисаНРД Тогда
		СквозныеПараметры.КореньИсточника = Справочники.ИсточникиКотировок.NSD;
		СквозныеПараметры.КодЛюбойПлощадки = "0";
		СквозныеПараметры.МаксимальноеКоличествоЦенныхБумагВЗапросеКотировок = 50;
		СквозныеПараметры.ИмяРеквизитаПлощадка = "mic";
		СквозныеПараметры.ИмяРеквизитаПлощадкаОсновная = "primary_exchange_mic";
		СквозныеПараметры.ИмяМетодаAPI = "/api/get/eod";
		СквозныеПараметры.ИмяРеквизитаLAST = "price_close";
		СквозныеПараметры.ИмяРеквизитаIsin = "isin";
		СквозныеПараметры.РежимТоргов = Справочники.РежимыТоргов.Рыночный;
	КонецЕсли;
	Если СквозныеПараметры.ИмяНастроекСервиса = СквозныеПараметры.ИмяНастроекСервисаCBonds Тогда
		ЭтоЗагрузкаНКД = ПараметрыИсточника.ВидИсточника = "ЗагрузитьКупоныCBonds";
		СквозныеПараметры.Вставить("ЭтоЗагрузкаНКД", ЭтоЗагрузкаНКД);
		СквозныеПараметры.КореньИсточника = Справочники.ИсточникиКотировок.CBonds;
		СквозныеПараметры.КодЛюбойПлощадки = 0;
		СквозныеПараметры.МаксимальноеКоличествоЦенныхБумагВЗапросеКотировок = 200;
		СквозныеПараметры.ИмяРеквизитаПлощадка = "trading_ground_id";
		СквозныеПараметры.ИмяРеквизитаПлощадкаОсновная = "trading_ground_id";
		СквозныеПараметры.ИмяМетодаAPI = ?(СквозныеПараметры.ЭтоЗагрузкаНКД, "/get_aci", "/get_tradings_new");
		СквозныеПараметры.ИмяРеквизитаLAST = "last_price";
		СквозныеПараметры.ИмяРеквизитаLAST2 = "legalcloseprice";
		СквозныеПараметры.ИмяРеквизитаCurrency = "";
		СквозныеПараметры.ИмяРеквизитаНКД = "aci";
		СквозныеПараметры.ИмяРеквизитаНКД2 = "aci_eurobond_nominal";
		СквозныеПараметры.ИмяРеквизитаНКД3 = "aci_full";
		СквозныеПараметры.ИмяРеквизитаIsin = ?(СквозныеПараметры.ЭтоЗагрузкаНКД, "emission_isin", "isin_code");
		Если ПараметрыИсточника.ВидИсточника = "ТорговыхПлощадокСПБ" Тогда
			СквозныеПараметры.РежимТоргов = Справочники.РежимыТоргов.Индикативный;
		Иначе
			СквозныеПараметры.РежимТоргов = Справочники.РежимыТоргов.Рыночный;
		КонецЕсли;
		
		ЧисловыеРеквизиты.Добавить(СквозныеПараметры.ИмяРеквизитаПлощадка);
	КонецЕсли;
	СквозныеПараметры.ЧисловыеРеквизиты			 = ЧисловыеРеквизиты;
	СквозныеПараметры.КешИсточниковКотировок	 = Справочники.ИсточникиКотировок.ПолучитьКеш(СквозныеПараметры.КореньИсточника);
	
	Возврат СквозныеПараметры;
	
КонецФункции

Процедура ОпределитьНастройкиТорговыхПлощадок(Настройки, ВидИсточника, СоответствиеКодовБирж, СоответствиеПолейПрочихТорговыхПлощадок)
	
	ТипХранилищеЗначения = Тип("ХранилищеЗначения");
	
	ИмяТаблицыПлощадок	 = "";
	ИмяТаблицыПолей		 = "";
	ОпределитьНастройкиТорговыхПлощадокИмена(ВидИсточника, ИмяТаблицыПлощадок, ИмяТаблицыПолей);
	
	ТЗ_ПрочиеТорговыеПлощадки = Новый ТаблицаЗначений;
	Если Настройки.Свойство(ИмяТаблицыПлощадок) Тогда
		НастройкиЗаполненияХранилище = XMLЗначение(ТипХранилищеЗначения, Настройки[ИмяТаблицыПлощадок]);
		ТЗ_ПрочиеТорговыеПлощадки = НастройкиЗаполненияХранилище.Получить();
	КонецЕсли;
	Если ТЗ_ПрочиеТорговыеПлощадки.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	ТЗ_ПоляКотировок = Новый ТаблицаЗначений;
	Если Настройки.Свойство(ИмяТаблицыПолей) Тогда
		НастройкиЗаполненияХранилище = XMLЗначение(ТипХранилищеЗначения, Настройки[ИмяТаблицыПолей]);
		ТЗ_ПоляКотировок = НастройкиЗаполненияХранилище.Получить();
	КонецЕсли;
	Если ТЗ_ПоляКотировок.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ТЗ_ПрочиеТорговыеПлощадки.Биржа КАК Биржа,
	|	ТЗ_ПрочиеТорговыеПлощадки.Идентификатор КАК Идентификатор
	|ПОМЕСТИТЬ ВТ_ПрочиеТорговыеПлощадки
	|ИЗ
	|	&ТЗ_ПрочиеТорговыеПлощадки КАК ТЗ_ПрочиеТорговыеПлощадки
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТЗ_ПоляКотировок.ИдентификаторБиржи КАК ИдентификаторБиржи,
	|	ТЗ_ПоляКотировок.Идентификатор КАК ИдентификаторПоля,
	|	ТЗ_ПоляКотировок.КолонкаКотировки КАК КолонкаКотировки
	|ПОМЕСТИТЬ ВТ_ПоляКотировок
	|ИЗ
	|	&ТЗ_ПоляКотировок КАК ТЗ_ПоляКотировок
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_ПрочиеТорговыеПлощадки.Биржа КАК Биржа,
	|	ВТ_ПрочиеТорговыеПлощадки.Идентификатор КАК Идентификатор
	|ИЗ
	|	ВТ_ПрочиеТорговыеПлощадки КАК ВТ_ПрочиеТорговыеПлощадки
	|ИТОГИ ПО
	|	Биржа
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_ПоляКотировок.ИдентификаторБиржи КАК ИдентификаторБиржи,
	|	ВТ_ПоляКотировок.ИдентификаторПоля КАК ИдентификаторПоля,
	|	ВТ_ПоляКотировок.КолонкаКотировки КАК КолонкаКотировки
	|ИЗ
	|	ВТ_ПоляКотировок КАК ВТ_ПоляКотировок
	|ИТОГИ ПО
	|	ИдентификаторБиржи";
	
	Запрос.УстановитьПараметр("ТЗ_ПрочиеТорговыеПлощадки", ТЗ_ПрочиеТорговыеПлощадки);
	Запрос.УстановитьПараметр("ТЗ_ПоляКотировок", ТЗ_ПоляКотировок);
	
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	КоличествоТаблиц = РезультатЗапроса.Количество();
	
	ВыборкаБиржи = РезультатЗапроса[КоличествоТаблиц - 2].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам); // BSLLS:MagicNumber-off
	Пока ВыборкаБиржи.Следующий() Цикл
		ИдентификаторыБиржи = Новый Массив;
		Выборка = ВыборкаБиржи.Выбрать();
		Пока Выборка.Следующий() Цикл
			Если ИдентификаторыБиржи.Найти(Выборка.Идентификатор) = Неопределено Тогда
				ИдентификаторыБиржи.Добавить(Выборка.Идентификатор);
			КонецЕсли;
		КонецЦикла;
		СоответствиеКодовБирж.Вставить(ВыборкаБиржи.Биржа, ИдентификаторыБиржи);
	КонецЦикла;
	
	ВыборкаИдентификаторы = РезультатЗапроса[КоличествоТаблиц - 1].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Пока ВыборкаИдентификаторы.Следующий() Цикл
		СоответствиеПолей = Новый Соответствие;
		Выборка = ВыборкаИдентификаторы.Выбрать();
		Пока Выборка.Следующий() Цикл
			СоответствиеПолей.Вставить(Выборка.КолонкаКотировки, Выборка.ИдентификаторПоля);
		КонецЦикла;
		СоответствиеПолейПрочихТорговыхПлощадок.Вставить(ВыборкаИдентификаторы.ИдентификаторБиржи, СоответствиеПолей);
	КонецЦикла;
	
КонецПроцедуры

Процедура ОпределитьНастройкиТорговыхПлощадокИмена(ВидИсточника, ИмяТаблицыПлощадок, ИмяТаблицыПолей)
	
	Если ВидИсточника = "ТорговыхПлощадокСПБ" Тогда
		ИмяТаблицыПлощадок	 = "ТЗ_ТорговыеПлощадкиСПБ";
		ИмяТаблицыПолей		 = "ТЗ_ПоляКотировокСПБ";
	ИначеЕсли ВидИсточника = "ТорговыхПлощадокНРД" Тогда
		ИмяТаблицыПлощадок	 = "ТЗ_ТорговыеПлощадкиНРД";
		ИмяТаблицыПолей		 = "ТЗ_ПоляКотировокНРД";
	Иначе
		ИмяТаблицыПлощадок	 = "ТЗ_ПрочиеТорговыеПлощадки";
		ИмяТаблицыПолей		 = "ТЗ_ПоляКотировок";
	КонецЕсли;
	
КонецПроцедуры

Процедура УстановитьКотировкуПоСтроке(СквозныеПараметры, Котировка, СтрокаКотировок, СтрокаАктива, КодыПолей, НайденаВалютаGBP)
	
	КоэффициентПриведенияКНоминалу = 0.01;
	КоэффициентПриведенияКФунтам = 0.01;
	
	ПолеКотировкиAPI = НРег(КодыПолей.Значение);
	ПолеКотировки1с	 = НРег(КодыПолей.Ключ);
	
	ЭтоНКД = ПолеКотировкиAPI = СквозныеПараметры.ИмяРеквизитаНКД;
	
	УстановитьКотировкуПоСтрокеПодмены(СквозныеПараметры, СтрокаКотировок, ЭтоНКД, ПолеКотировкиAPI);
	
	Если СтрокаКотировок.Свойство(ПолеКотировкиAPI) Тогда
		Котировка[ПолеКотировки1с] = СтрокаКотировок[ПолеКотировкиAPI];
		
		УстановитьНулевойНКД = ЭтоНКД И СтрокаАктива.ЭтоОблигация И Котировка[ПолеКотировки1с] = 0 И СтрокаКотировок.Свойство("НулевойНКД");
		Если УстановитьНулевойНКД Тогда
			Котировка["НулевойНКД"] = СтрокаАктива.НулевойНКД;
		КонецЕсли;
		
		Если СтрокаАктива.ЭтоОблигация
			И Не ЭтоНКД
			И СквозныеПараметры.НеПроцентныеПоля.Найти(Лев(ПолеКотировкиAPI, 3)) = Неопределено
			Тогда
			Котировка[ПолеКотировки1с] = Котировка[ПолеКотировки1с] * СтрокаАктива.Номинал * КоэффициентПриведенияКНоминалу;
		КонецЕсли; // Привести проценты к номиналу
		
		Если НайденаВалютаGBP Тогда
			ПереводитьВФунты = (СтрокаАктива.ЭтоОблигация И ЭтоНКД)
				Или (Не СтрокаАктива.ЭтоОблигация И СквозныеПараметры.НеПроцентныеПоля.Найти(Лев(ПолеКотировкиAPI, 3)) = Неопределено);
			Если ПереводитьВФунты Тогда
				Котировка[ПолеКотировки1с] = Котировка[ПолеКотировки1с] * КоэффициентПриведенияКФунтам;
			КонецЕсли; // Делим на 100 т.к. GBX = пенсы.	
		КонецЕсли;
		
	КонецЕсли; // Если есть такое поле в соотвествии полей
	
КонецПроцедуры

Процедура УстановитьКотировкуПоСтрокеПодмены(СквозныеПараметры, СтрокаКотировок, ЭтоНКД, ПолеКотировкиAPI)
	
	ВидЕврооблигация = 2;
	
	Если СквозныеПараметры.ИмяНастроекСервиса = СквозныеПараметры.ИмяНастроекСервисаCBonds Тогда
		// Подмены
		Если СквозныеПараметры.ЭтоЗагрузкаНКД Тогда
			ПолеКотировкиAPI = СквозныеПараметры.ИмяРеквизитаНКД3;
		КонецЕсли;
		НеобходимаПодмена = ЭтоНКД
			И (СтрокаКотировок.Свойство("emission_kind_id") И СтрокаКотировок["emission_kind_id"] = ВидЕврооблигация
				Или СтрокаКотировок.Свойство("kind_id") И СтрокаКотировок["kind_id"] = ВидЕврооблигация);
		Если НеобходимаПодмена Тогда
			ПолеКотировкиAPI = СквозныеПараметры.ИмяРеквизитаНКД2;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

Функция ВалютаКурсКотировки(мКешВалют, КодВалютыКотировки, СтрокаАктиваВалютаНоминала, ISIN)
	
	ВалютаСКурсом = мКешВалют[КодВалютыКотировки];
	Если ЗначениеЗаполнено(ВалютаСКурсом) Тогда
		Валюта	 = ВалютаСКурсом.Валюта;
		Курс	 = ВалютаСКурсом.Курс;
	Иначе 
		Валюта	 = Справочники.Валюты.ПустаяСсылка();
		Курс	 = 1;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(Валюта) Тогда
		Если ЗначениеЗаполнено(СтрокаАктиваВалютаНоминала) Тогда
			Валюта = СтрокаАктиваВалютаНоминала;
			ВалютаСКурсом = мКешВалют[ВРЕГ(СокрЛП(Валюта.Наименование))];
			Курс = ВалютаСКурсом.Курс;
		Иначе
			Если MarketData.ЭтоЦБRu(ISIN) Тогда
				Валюта = ОбщегоНазначенияПовтИсп.ЗначениеКонстанты("ВалютаРегламентированногоУчета");
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	Возврат Новый Структура("Валюта, Курс", Валюта, Курс);
	
КонецФункции

Функция РежимТорговКотировкиАктива(СквозныеПараметры, ИсточникКотировок)
	
	Если ЗначениеЗаполнено(ИсточникКотировок) И ИсточникКотировок.Родитель = Справочники.ИсточникиКотировок.IFX Тогда
		РежимТоргов = Справочники.РежимыТоргов.Индикативный;
	Иначе
		РежимТоргов = СквозныеПараметры.РежимТоргов;
	КонецЕсли;
	
	Возврат РежимТоргов;
	
КонецФункции

Процедура ДобавитьКотировкуАктива(СквозныеПараметры, СтрокаКотировок, СтрокаАктива, ТаблицаКотировокЦенныхБумаг)
	
	НайденаВалютаGBP = Ложь;
	КодВалютыКотировки = "";
	ПараметрыПоискаКотировки = Новый Структура("ЦеннаяБумага", СтрокаАктива.Актив);
	Котировки = ТаблицаКотировокЦенныхБумаг.НайтиСтроки(ПараметрыПоискаКотировки);
	Если Котировки.Количество() = 0 Тогда
		Котировка = ТаблицаКотировокЦенныхБумаг.Добавить();
		Котировка.Период = СквозныеПараметры.ДатаПолученияКотировок;
		Котировка.ЦеннаяБумага = СтрокаАктива.Актив;
		Котировка.Биржа = СквозныеПараметры.Биржа;
		
		Если Не СквозныеПараметры.ЭтоЗагрузкаНКД Тогда
			Если СквозныеПараметры.ИмяНастроекСервиса = СквозныеПараметры.ИмяНастроекСервисаНРД Тогда
				СквозныеПараметры.Площадки[0].id = СтрокаКотировок[СквозныеПараметры.ИмяРеквизитаПлощадка];
				СквозныеПараметры.Площадки[0].shortname_rus = СквозныеПараметры.Площадки[0].id;
				СквозныеПараметры.Площадки[0].fullname_rus = СтрокаКотировок["exchange_name"];
			КонецЕсли;
			Котировка.ИсточникКотировок = ИсточникКотировокПоТорговойПлощадке(СтрокаКотировок[СквозныеПараметры.ИмяРеквизитаПлощадка],
				СквозныеПараметры.КореньИсточника, СквозныеПараметры.Площадки, СквозныеПараметры.КешИсточниковКотировок);
			
			Котировка.РежимТоргов = РежимТорговКотировкиАктива(СквозныеПараметры, Котировка.ИсточникКотировок);
			
			Если СквозныеПараметры.Свойство("ЭтоКотировкаОсновногоИсточника") Тогда
				Котировка.ЭтоКотировкаОсновногоИсточника = СквозныеПараметры.ЭтоКотировкаОсновногоИсточника;
			КонецЕсли;
			
			Если ЗначениеЗаполнено(СквозныеПараметры.ИмяРеквизитаCurrency) Тогда
				КодВалютыКотировки = СтрокаКотировок[СквозныеПараметры.ИмяРеквизитаCurrency];
			Иначе
				КодВалютыКотировки = СтрокаАктива.КодВалютыНоминала;
			КонецЕсли;
			ДобавитьВалютуКотировкиАктива(СквозныеПараметры, Котировка, СтрокаКотировок, СтрокаАктива, НайденаВалютаGBP, КодВалютыКотировки);
			
		КонецЕсли;
		СквозныеПараметры.ПакетКодовКотировкаНайдена.Добавить(СтрокаАктива.ISIN);
	Иначе
		Возврат; // Уже есть такая котировка по более приоритетной площадке
	КонецЕсли;
	
	ДобавитьКотировкуАктиваЧисловыеПоля(СквозныеПараметры, Котировка, СтрокаКотировок, СтрокаАктива, НайденаВалютаGBP);
	
КонецПроцедуры

Процедура ДобавитьВалютуКотировкиАктива(СквозныеПараметры, Котировка, СтрокаКотировок, СтрокаАктива, НайденаВалютаGBP, КодВалютыКотировки)
	
	Если КодВалютыКотировки = "GBX" Или КодВалютыКотировки = "GBp" Тогда
		ВалютаКурс = ВалютаКурсКотировки(СквозныеПараметры.мКешВалют, "GBP", Неопределено, "");
		Котировка.ВалютаКотировки = ВалютаКурс.Валюта;
		НайденаВалютаGBP = ЗначениеЗаполнено(Котировка.ВалютаКотировки);
	Иначе
		ВалютаКурс = ВалютаКурсКотировки(СквозныеПараметры.мКешВалют, КодВалютыКотировки, СтрокаАктива.ВалютаНоминала,
			СтрокаКотировок[СквозныеПараметры.ИмяРеквизитаIsin]);
		Котировка.ВалютаКотировки = ВалютаКурс.Валюта;
	КонецЕсли;
	
КонецПроцедуры

Процедура ДобавитьКотировкуАктиваЧисловыеПоля(СквозныеПараметры, Котировка, СтрокаКотировок, СтрокаАктива, НайденаВалютаGBP)
	
	Для Каждого КодыПолей Из СквозныеПараметры.СоответствиеПолейБиржи Цикл
		УстановитьКотировкуПоСтроке(СквозныеПараметры, Котировка, СтрокаКотировок, СтрокаАктива, КодыПолей, НайденаВалютаGBP);
	КонецЦикла; // По полям котировок конкретной торговой площадки конкретного актива
	
	Если Котировка.AccInt > 0 Тогда
		КотировкаВалютаКотировки = ?(СквозныеПараметры.ЭтоЗагрузкаНКД, СтрокаАктива.ВалютаНоминала, Котировка.ВалютаКотировки);
		Если ЗначениеЗаполнено(КотировкаВалютаКотировки) Тогда
			ПараметрыВалюты =
				УстановкиПоУмолчанию.ПолучитьПараметрыВалюты(КотировкаВалютаКотировки, СквозныеПараметры.ДатаПолученияКотировок);
			Котировка.Nkd = Котировка.AccInt * ПараметрыВалюты.Курс;
		Иначе
			Котировка.Nkd = Котировка.AccInt;
		КонецЕсли;
	КонецЕсли; // Пересчет рублевых цен
	
КонецПроцедуры

Функция ДопустимаяПлощадка(СквозныеПараметры, СтрокаКотировок)
	
	Если СквозныеПараметры.ЗагружатьКотировкиПоПервичнойБирже И СквозныеПараметры.КодПлощадки = "*" Тогда
		СквозныеПараметры.Вставить("ЭтоКотировкаОсновногоИсточника", Истина);
		ЭтоДопустимаяПлощадка = СтрокаКотировок.Свойство(СквозныеПараметры.ИмяРеквизитаПлощадка)
			И СтрокаКотировок.Свойство(СквозныеПараметры.ИмяРеквизитаПлощадкаОсновная)
			И СтрокаКотировок[СквозныеПараметры.ИмяРеквизитаПлощадка] = СтрокаКотировок[СквозныеПараметры.ИмяРеквизитаПлощадкаОсновная];
	Иначе
		СквозныеПараметры.Вставить("ЭтоКотировкаОсновногоИсточника", Ложь);
		ЭтоДопустимаяПлощадка = СтрокаКотировок.Свойство(СквозныеПараметры.ИмяРеквизитаПлощадка)
			И СтрокаКотировок[СквозныеПараметры.ИмяРеквизитаПлощадка] = СквозныеПараметры.КодПлощадки;
	КонецЕсли;
	
	Возврат ЭтоДопустимаяПлощадка;
	
КонецФункции

Функция ДопустимаяКотировка(СквозныеПараметры, СтрокаКотировок)
	
	LAST	 = СквозныеПараметры.ИмяРеквизитаLAST;
	LAST2	 = СквозныеПараметры.ИмяРеквизитаLAST2;
	Если СквозныеПараметры.ИмяНастроекСервиса = СквозныеПараметры.ИмяНастроекСервисаИнтерфакс Тогда
		ЭтоДопустимаяКотировка = СтрокаКотировок.Свойство(LAST) И ЗначениеЗаполнено(СтрокаКотировок[LAST]);
	ИначеЕсли СквозныеПараметры.ИмяНастроекСервиса = СквозныеПараметры.ИмяНастроекСервисаНРД Тогда
		ЭтоДопустимаяКотировка = Истина;
	ИначеЕсли СквозныеПараметры.ИмяНастроекСервиса = СквозныеПараметры.ИмяНастроекСервисаCBonds Тогда
		ЭтоДопустимаяКотировка = СквозныеПараметры.ВидИсточника = "ТорговыхПлощадокСПБ"
			Или (СтрокаКотировок.Свойство(LAST) И ЗначениеЗаполнено(СтрокаКотировок[LAST])
			Или СтрокаКотировок.Свойство(LAST2) И ЗначениеЗаполнено(СтрокаКотировок[LAST2]));
	Иначе
		ЭтоДопустимаяКотировка = Ложь;
	КонецЕсли;
	
	Возврат ЭтоДопустимаяКотировка;
	
КонецФункции

Процедура ДобавитьКотировкиАктивовПоПлощадке(СквозныеПараметры, ПолученныеДанные,
	ПолученныеДанныеОбработаноСтрок, ТаблицаКотировокЦенныхБумаг)
	
	Если СквозныеПараметры.СоответствиеПолейБиржи <> Неопределено Тогда
		
		Для Каждого СтрокаКотировок Из ПолученныеДанные Цикл
			
			ЭтоДопустимаяПлощадка = ДопустимаяПлощадка(СквозныеПараметры, СтрокаКотировок);
			Если ЭтоДопустимаяПлощадка Тогда
				ПолученныеДанныеОбработаноСтрок = ПолученныеДанныеОбработаноСтрок + 1;
			КонецЕсли;
			
			ЭтоДопустимаяКотировка = ДопустимаяКотировка(СквозныеПараметры, СтрокаКотировок);
			
			Если ЭтоДопустимаяПлощадка И ЭтоДопустимаяКотировка Тогда
				
				ПараметрыПоискаАктива = Новый Структура("ISIN", СтрокаКотировок[СквозныеПараметры.ИмяРеквизитаIsin]);
				СтрокиАктивов = СквозныеПараметры.СписокАктивов.НайтиСтроки(ПараметрыПоискаАктива);
				Для Каждого СтрокаАктива Из СтрокиАктивов Цикл
					ДобавитьКотировкуАктива(СквозныеПараметры, СтрокаКотировок, СтрокаАктива, ТаблицаКотировокЦенныхБумаг);
				КонецЦикла;
				
			КонецЕсли; // Если совпадает площадка и заполнена котировка last
			
		КонецЦикла; // Для каждой строки котировки из полученных данных
		
	КонецЕсли; // Если для площадки в настройках есть хотя бы одно соотвествие полей котировок
	
КонецПроцедуры

Процедура ДобавитьКотировкиАктивовПоПервойПлощадкеСогласноСортировке(СквозныеПараметры, ПолученныеДанные,
	ПолученныеДанныеКоличествоСтрок, ПолученныеДанныеОбработаноСтрок, ТаблицаКотировокЦенныхБумаг)
	
	СквозныеПараметры.Вставить("ЭтоКотировкаОсновногоИсточника", Ложь);
	
	Если СквозныеПараметры.СоответствиеПолейБиржи <> Неопределено Тогда
		
		Если СквозныеПараметры.ОбязательныйВыборПлощадкиСогласноСортировке
			И ПолученныеДанныеОбработаноСтрок < ПолученныеДанныеКоличествоСтрок Тогда
			
			ПакетКодовКотировкаНеНайдена =
				ОбщегоНазначенияКлиентСервер.РазностьМассивов(СквозныеПараметры.ПакетКодов, СквозныеПараметры.ПакетКодовКотировкаНайдена);
			
			Если ПакетКодовКотировкаНеНайдена.Количество() > 0 Тогда
					
				ОбщегоНазначенияПереопределяемый.СортироватьМассивСтруктур(ПолученныеДанные,
					"УБЫВ", СквозныеПараметры.ОбязательныйВыборПлощадкиПолеСортировки);
				
				ДобавитьКотировкиАктивовПоПервойПлощадкеСогласноСортировкеВТаблицу(СквозныеПараметры, ПолученныеДанные,
					ПакетКодовКотировкаНеНайдена, ТаблицаКотировокЦенныхБумаг);
					
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕсли; // Если для площадки в настройках есть хотя бы одно соотвествие полей котировок
	
КонецПроцедуры

Процедура ДобавитьКотировкиАктивовПоПервойПлощадкеСогласноСортировкеВТаблицу(СквозныеПараметры, ПолученныеДанные,
	ПакетКодовКотировкаНеНайдена, ТаблицаКотировокЦенныхБумаг)
	
	Для Каждого СтрокаКотировок Из ПолученныеДанные Цикл
		ЭтоДопустимаяКотировка = ДопустимаяКотировка(СквозныеПараметры, СтрокаКотировок);
		ЭтоДопустимоеЗначениеПоляСортировки = СтрокаКотировок[СквозныеПараметры.ОбязательныйВыборПлощадкиПолеСортировки] > 0;
		Если ЭтоДопустимаяКотировка И ЭтоДопустимоеЗначениеПоляСортировки
			И ПакетКодовКотировкаНеНайдена.Найти(СтрокаКотировок[СквозныеПараметры.ИмяРеквизитаIsin]) <> Неопределено Тогда
			
			ПараметрыПоискаАктива = Новый Структура("ISIN", СтрокаКотировок[СквозныеПараметры.ИмяРеквизитаIsin]);
			СтрокиАктивов = СквозныеПараметры.СписокАктивов.НайтиСтроки(ПараметрыПоискаАктива);
			Для Каждого СтрокаАктива Из СтрокиАктивов Цикл
				ДобавитьКотировкуАктива(СквозныеПараметры, СтрокаКотировок, СтрокаАктива, ТаблицаКотировокЦенныхБумаг);
			КонецЦикла;
			
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

Процедура ДобавитьКотировкиАктивов(СквозныеПараметры, ПолученныеДанные,
	ПолученныеДанныеКоличествоСтрокИтого, ТаблицаКотировокЦенныхБумаг)
	
	ПолученныеДанныеКоличествоСтрок = ПолученныеДанные.Количество();
	ПолученныеДанныеКоличествоСтрокИтого = ПолученныеДанныеКоличествоСтрокИтого + ПолученныеДанныеКоличествоСтрок;
	Если ПолученныеДанныеКоличествоСтрок > 0 Тогда
		
		ТаблицаПлощадок = ТаблицаПлощадокКотировкиАктивов(СквозныеПараметры, ПолученныеДанные);
		МассивПлощадок = ОбщегоНазначения.ВыгрузитьКолонку(ТаблицаПлощадок, СквозныеПараметры.ИмяРеквизитаПлощадка, Истина);
		
		Если СквозныеПараметры.ЗагружатьКотировкиПоПервичнойБирже Тогда
			МассивПлощадок.Добавить("*");
		КонецЕсли;
		
		ПолученныеДанныеОбработаноСтрок = 0;
		
		Для Каждого КодПлощадки Из СквозныеПараметры.ИдентификаторыТорговыхПлощадок Цикл
			
			Если МассивПлощадок.Найти(КодПлощадки) = Неопределено Тогда
				Продолжить;
			КонецЕсли;
			
			Если ПолученныеДанныеОбработаноСтрок >= ПолученныеДанныеКоличествоСтрок Тогда
				Прервать;
			КонецЕсли;
			
			СквозныеПараметры.Вставить("КодПлощадки", КодПлощадки);
			
			ДобавитьКотировкиАктивовПоПлощадке(СквозныеПараметры, ПолученныеДанные,
				ПолученныеДанныеОбработаноСтрок, ТаблицаКотировокЦенныхБумаг);
			
		КонецЦикла; // Для каждой площадки
		
		ДобавитьКотировкиАктивовПоПервойПлощадкеСогласноСортировке(СквозныеПараметры, ПолученныеДанные,
			ПолученныеДанныеКоличествоСтрок, ПолученныеДанныеОбработаноСтрок, ТаблицаКотировокЦенныхБумаг);
		
	КонецЕсли; // Если есть котировка хотя бы по одной бумаге из пакета
	
КонецПроцедуры

Функция ТаблицаПлощадокКотировкиАктивов(СквозныеПараметры, ПолученныеДанные)
	
	Если СквозныеПараметры.ИмяНастроекСервиса = СквозныеПараметры.ИмяНастроекСервисаИнтерфакс
		Или СквозныеПараметры.ИмяНастроекСервиса = СквозныеПараметры.ИмяНастроекСервисаCBonds Тогда
		ТаблицаПлощадок = RuDataAPI.ПреобразоватьМассивВТаблицуЗначений(ПолученныеДанные, СквозныеПараметры.ЧисловыеРеквизиты);
	ИначеЕсли СквозныеПараметры.ИмяНастроекСервиса = СквозныеПараметры.ИмяНастроекСервисаНРД Тогда
		Переименования = Новый Соответствие;
		ТаблицаПлощадок = ОбщегоНазначенияПереопределяемый.МассивСтруктурВТаблицуЗначений(ПолученныеДанные, Переименования);
	Иначе
		ТаблицаПлощадок = Новый ТаблицаЗначений;
	КонецЕсли;
	
	Возврат ТаблицаПлощадок;
	
КонецФункции

Процедура ОбработатьПакетыПараметрыЖурналаРегистрацииВызовов(СквозныеПараметры, НомерПакета,
	ОставитьЗаписьВЖурналеРегистрацииВызовов, ДополнительныйКомментарийВЖурналеРегистрацииВызовов)
	
	Если НомерПакета = 1 Тогда
		ЭтоПервыйПакет = Истина;
	Иначе
		ЭтоПервыйПакет = Ложь;
	КонецЕсли;
	Если НомерПакета = СквозныеПараметры.ВсегоПакетов Тогда
		ЭтоПоследнийПакет = Истина;
	Иначе
		ЭтоПоследнийПакет = Ложь;
	КонецЕсли;
	Если ЭтоПервыйПакет И ЭтоПоследнийПакет Тогда
		ЭтоЕдинственныйПакет = Истина;
	Иначе
		ЭтоЕдинственныйПакет = Ложь;
	КонецЕсли;
	Если ЭтоЕдинственныйПакет Тогда
		ОставитьЗаписьВЖурналеРегистрацииВызовов = Истина;
		ДополнительныйКомментарийВЖурналеРегистрацииВызовов = СквозныеПараметры.КраткийКомментарий + ЗапрашиваемыеISIN(СквозныеПараметры);
	Иначе
		ПрефиксКомментария = ?(ЗначениеЗаполнено(СквозныеПараметры.КраткийКомментарий), СквозныеПараметры.КраткийКомментарий + "; ", "");
		Если ЭтоПервыйПакет Тогда
			ОставитьЗаписьВЖурналеРегистрацииВызовов = Истина;
			ДополнительныйКомментарийВЖурналеРегистрацииВызовов = ПрефиксКомментария + "Первый пакет" + ЗапрашиваемыеISIN(СквозныеПараметры);
		ИначеЕсли ЭтоПоследнийПакет Тогда
			ОставитьЗаписьВЖурналеРегистрацииВызовов = Истина;
			ДополнительныйКомментарийВЖурналеРегистрацииВызовов = ПрефиксКомментария + "Последний пакет";
		Иначе
			ОставитьЗаписьВЖурналеРегистрацииВызовов = Ложь;
			ДополнительныйКомментарийВЖурналеРегистрацииВызовов = СквозныеПараметры.КраткийКомментарий;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

Функция ЗапрашиваемыеISIN(СквозныеПараметры)
	
	ISINСтрокой = ". Isin: "
		+ СтрСоединить(ОбщегоНазначения.ВыгрузитьКолонку(СквозныеПараметры.СписокАктивов, "ISIN", Истина, Истина), ";");
	
	Возврат ISINСтрокой;
	
КонецФункции

Функция ОбработатьПакетыПолученныеДанные(СквозныеПараметры, ИзменяемыеПараметры, ПараметрыМетода, ЛогПолученныхДанных,
	Сессия, Соединение)
	
	Если ТестированиеVanessa.ЭтоТест() И СквозныеПараметры.ИмяНастроекСервиса = СквозныеПараметры.ИмяНастроекСервисаИнтерфакс Тогда
		ПолученныеДанные = ОбработатьПакетыПолученныеДанныеТестИнтерфакс(СквозныеПараметры);
	Иначе
		Если СквозныеПараметры.ИмяНастроекСервиса = СквозныеПараметры.ИмяНастроекСервисаИнтерфакс Тогда
			ПолученныеДанные = RuDataAPI.ДанныеМетода_v2_Archive_EndOfDayOnExchanges(ПараметрыМетода,
				ИзменяемыеПараметры.ОтказЛокально, ИзменяемыеПараметры.ТекстОтказа, ЛогПолученныхДанных, Сессия,
				СквозныеПараметры.ОставитьЗаписьВЖурналеРегистрацииВызовов, СквозныеПараметры.ДополнительныйКомментарийВЖурналеРегистрацииВызовов);
		ИначеЕсли СквозныеПараметры.ИмяНастроекСервиса = СквозныеПараметры.ИмяНастроекСервисаНРД Тогда
			ПолученныеДанные = NSDAPI.ДанныеМетода_getValuation(ПараметрыМетода,
				ИзменяемыеПараметры.ОтказЛокально, ИзменяемыеПараметры.ТекстОтказа, ЛогПолученныхДанных, Соединение,
				СквозныеПараметры.ОставитьЗаписьВЖурналеРегистрацииВызовов, СквозныеПараметры.ДополнительныйКомментарийВЖурналеРегистрацииВызовов);
		ИначеЕсли СквозныеПараметры.ИмяНастроекСервиса = СквозныеПараметры.ИмяНастроекСервисаCBonds Тогда
			ПолученныеДанные = CBondsAPI.ДанныеМетода_get_tradings_new(ПараметрыМетода,
				ИзменяемыеПараметры.ОтказЛокально, ИзменяемыеПараметры.ТекстОтказа, ЛогПолученныхДанных, Соединение,
				СквозныеПараметры.ОставитьЗаписьВЖурналеРегистрацииВызовов, СквозныеПараметры.ДополнительныйКомментарийВЖурналеРегистрацииВызовов);
		Иначе
			ПолученныеДанные = Новый Массив;
		КонецЕсли;
	КонецЕсли;
	
	Возврат ПолученныеДанные;
	
КонецФункции

Функция ОбработатьПакетыПолученныеДанныеТестИнтерфакс(СквозныеПараметры)
	
	СтруктураВозвратаПоУмолчанию = Новый Массив;
	XMLHTTPОтвет = ТестированиеVanessa.ТестовыеДанные(СквозныеПараметры.ВидИсточника, СтруктураВозвратаПоУмолчанию);
	Если ТипЗнч(XMLHTTPОтвет) = Тип("Массив") Тогда
		ПолученныеДанные = СтруктураВозвратаПоУмолчанию;
	Иначе
		HTTPОтвет = ОбщегоНазначения.ЗначениеИзСтрокиXML(XMLHTTPОтвет);
		Если ЗначениеЗаполнено(HTTPОтвет) И ТипЗнч(HTTPОтвет) = Тип("ХранилищеЗначения") Тогда
			ПолученныеДанные = HTTPОтвет.Получить();
		Иначе
			ПолученныеДанные = СтруктураВозвратаПоУмолчанию;
		КонецЕсли;
	КонецЕсли;
	
	Возврат ПолученныеДанные;
	
КонецФункции

Функция ОбработатьПакеты(СквозныеПараметры, ИзменяемыеПараметры, ЛогПолученныхДанных,
	Сессия, Соединение, ТаблицаКотировокЦенныхБумаг)
	
	ОбработаноПакетов	 = 0;
	НомерПакета			 = 0;
	Пока СквозныеПараметры.ВсегоПакетов > НомерПакета Цикл
		ПакетКодов = СквозныеПараметры.ПакетыКодов[НомерПакета];
		СквозныеПараметры.Вставить("ПакетКодов"					, ПакетКодов);
		СквозныеПараметры.Вставить("ПакетКодовКотировкаНайдена"	, Новый Массив);
		НомерПакета = НомерПакета + 1;
		
		ОставитьЗаписьВЖурналеРегистрацииВызовов = Ложь;
		ДополнительныйКомментарийВЖурналеРегистрацииВызовов = "";
		ОбработатьПакетыПараметрыЖурналаРегистрацииВызовов(СквозныеПараметры, НомерПакета,
			ОставитьЗаписьВЖурналеРегистрацииВызовов, ДополнительныйКомментарийВЖурналеРегистрацииВызовов); 
		СквозныеПараметры.Вставить("ОставитьЗаписьВЖурналеРегистрацииВызовов", ОставитьЗаписьВЖурналеРегистрацииВызовов);
		СквозныеПараметры.Вставить("ДополнительныйКомментарийВЖурналеРегистрацииВызовов", ДополнительныйКомментарийВЖурналеРегистрацииВызовов);
		
		ПараметрыМетода = НовыеПараметрыМетода(СквозныеПараметры);
		
		ПолученныеДанные = ОбработатьПакетыПолученныеДанные(СквозныеПараметры, ИзменяемыеПараметры,
			ПараметрыМетода, ЛогПолученныхДанных, Сессия, Соединение);
		
		Если ИзменяемыеПараметры.ОтказЛокально Тогда
			ИзменяемыеПараметры.ПопытокОсталось = ИзменяемыеПараметры.ПопытокОсталось - 1;
			Если ИзменяемыеПараметры.ПопытокОсталось < 0 Тогда
				ИзменяемыеПараметры.Отказ = ИзменяемыеПараметры.Отказ Или ИзменяемыеПараметры.ОтказЛокально;
				Прервать;
			Иначе
				ИзменяемыеПараметры.ОтказЛокально = Ложь;
				НомерПакета = НомерПакета - 1;
				Продолжить;
			КонецЕсли;
		Иначе
			ОбработаноПакетов = ОбработаноПакетов + 1;
		КонецЕсли;
		
		ДобавитьКотировкиАктивов(СквозныеПараметры, ПолученныеДанные,
			ИзменяемыеПараметры.ПолученныеДанныеКоличествоСтрокИтого, ТаблицаКотировокЦенныхБумаг);
		
	КонецЦикла; // Для каждого пакета бумаг
	
	Возврат ОбработаноПакетов;
	
КонецФункции

Функция ПолучитьЗаписатьКотировки(СквозныеПараметры, ИзменяемыеПараметры, ЛогПолученныхДанных,
		Сессия, Соединение, ТаблицаКотировокЦенныхБумагКоличество)
	
	РегистрыСведенийКотировки = РегистрыСведений.Котировки.СоздатьНаборЗаписей();
	РегистрыСведенийКотировки.Отбор.Период.Установить(СквозныеПараметры.ДатаПолученияКотировок);
	РегистрыСведенийКотировки.Отбор.Биржа.Установить(СквозныеПараметры.Биржа);
	ТаблицаКотировокЦенныхБумаг = РегистрыСведенийКотировки.ВыгрузитьКолонки();
	
	ОбработаноПакетов = ОбработатьПакеты(СквозныеПараметры, ИзменяемыеПараметры, ЛогПолученныхДанных,
		Сессия, Соединение, ТаблицаКотировокЦенныхБумаг);
	
	ТаблицаКотировокЦенныхБумагКоличество = ТаблицаКотировокЦенныхБумаг.Количество();
	Если ТаблицаКотировокЦенныхБумагКоличество > 0 Тогда
		Если СквозныеПараметры.ПоВсемЦеннымБумагам
			И Не СквозныеПараметры.ИмяНастроекСервиса = СквозныеПараметры.ИмяНастроекСервисаCBonds Тогда
			РегистрыСведенийКотировки.Очистить();
			РегистрыСведенийКотировки.Загрузить(ТаблицаКотировокЦенныхБумаг);
			РегистрыСведенийКотировки.Записать();
		Иначе
			Для Каждого КотировкаЦеннойБумаги Из ТаблицаКотировокЦенныхБумаг Цикл
				РегистрыСведенийКотировки.Отбор.ЦеннаяБумага.Установить(КотировкаЦеннойБумаги.ЦеннаяБумага);
				РегистрыСведенийКотировки.Отбор.РежимТоргов.Установить(КотировкаЦеннойБумаги.РежимТоргов);
				РегистрыСведенийКотировки.Очистить();
				НоваяКотировка = РегистрыСведенийКотировки.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяКотировка, КотировкаЦеннойБумаги);
				РегистрыСведенийКотировки.Записать();
			КонецЦикла;
		КонецЕсли;
	КонецЕсли;
	
	Возврат ОбработаноПакетов;
	
КонецФункции

Процедура ВывестиЛог(ТабличныйДокумент, СквозныеПараметры, ОбработаноПакетов, ТаблицаКотировокЦенныхБумагКоличество)
	
	// Выводим лог по созданным котировкам
	Если ТабличныйДокумент <> Неопределено Тогда
		ОбластьСтрока = СквозныеПараметры.Макет.ПолучитьОбласть("Строка");
		ОбластьСтрока.Параметры.Объект = Формат(СквозныеПараметры.ДатаПолученияКотировок, "ДЛФ=DD");
		ОбластьСтрока.Параметры.ОбъектСсылка = "" + СтрСоединить(СквозныеПараметры.ИдентификаторыТорговыхПлощадок, ",");
		Если ТаблицаКотировокЦенныхБумагКоличество > 0 Тогда
			ОбластьСтрока.Параметры.Статус = "Записан";
			Если ОбработаноПакетов = СквозныеПараметры.ВсегоПакетов Тогда
				РезультатЗагрузки = "ОК";
			Иначе
				РезультатЗагрузки = "ЧАСТИЧНО";
			КонецЕсли; 
		Иначе
			ОбластьСтрока.Параметры.Статус = "Обработан";
			РезультатЗагрузки = "НЕТ ДАННЫХ";
		КонецЕсли;
		ШаблонКомментария = "Результат:[%1]. Пакетов к обработке:[%2], обработано:[%3] (%4 шт\пак). Получены %5 по [%6 из %7] ЦБ.";
		ОбластьСтрока.Параметры.Комментарий = СтрШаблон(ШаблонКомментария, РезультатЗагрузки,
			СквозныеПараметры.ВсегоПакетов,
			ОбработаноПакетов,
			СквозныеПараметры.МаксимальноеКоличествоЦенныхБумагВЗапросеКотировок,
			?(СквозныеПараметры.ЭтоЗагрузкаНКД, "НКД", "котировки"),
			ТаблицаКотировокЦенныхБумагКоличество,
			СквозныеПараметры.СписокАктивов.Количество());
		ТабличныйДокумент.Вывести(ОбластьСтрока, 0);
		ВывестиЛогОграничений(ТабличныйДокумент, СквозныеПараметры);
	КонецЕсли;
	
КонецПроцедуры

Процедура ВывестиЛогОграничений(ТабличныйДокумент, СквозныеПараметры)
	
	ОграничениеПоКоличествуISIN = СквозныеПараметры.ОграничениеПоКоличествуISIN;
	Если ОграничениеПоКоличествуISIN > 0 Тогда
		КоличествоЦенныхБумагВЗапросеКотировок =
			РегистрыСведений.ЦенныеБумагиВЗапросеКотировок.КоличествоУникальныхЦенныхБумагВЗапросеКотировок(СквозныеПараметры.Биржа);
		Превышено = КоличествоЦенныхБумагВЗапросеКотировок > ОграничениеПоКоличествуISIN;
		ШаблонСообщения = "Проверка лимита по количеству Isin в запросе к %1 %2 : %3 \ %4";
		ОбластьПодвал = СквозныеПараметры.Макет.ПолучитьОбласть("Подвал" + ?(Превышено, "Ошибка", ""));
		ОбластьПодвал.Параметры.ДополнительнаяИнформация = СтрШаблон(ШаблонСообщения, СквозныеПараметры.Биржа,
			?(Превышено, "[Превышен лимит!]", "[ок]"), КоличествоЦенныхБумагВЗапросеКотировок, СквозныеПараметры.ОграничениеПоКоличествуISIN);
		ТабличныйДокумент.Вывести(ОбластьПодвал, 0);
	КонецЕсли;
	
КонецПроцедуры

Процедура ПолучитьЗаписатьКотировкиПоПериодам(СквозныеПараметры, ИзменяемыеПараметры, ЛогПолученныхДанных,
	Сессия, Соединение, ТабличныйДокумент)
	
	Для Каждого ТекПериод Из СквозныеПараметры.ТаблицаПериодов Цикл
		
		ДатаПолученияКотировок = ТекПериод.РезультирующаяДата;
		СквозныеПараметры.Вставить("ДатаПолученияКотировок", ДатаПолученияКотировок);
		
		мКешВалют = Справочники.Валюты.КешВалют(СквозныеПараметры.ДатаПолученияКотировок);
		СквозныеПараметры.Вставить("мКешВалют", мКешВалют);
		
		Если Не СквозныеПараметры.ИмяНастроекСервиса = СквозныеПараметры.ИмяНастроекСервисаИнтерфакс Тогда
			КраткийКомментарий = Формат(СквозныеПараметры.ДатаПолученияКотировок, "ДФ=yyyy-MM-dd");
		Иначе
			КраткийКомментарий = "";
		КонецЕсли;
		СквозныеПараметры.Вставить("КраткийКомментарий", КраткийКомментарий);
		
		// Лог полученных данных
		Если ТипЗнч(ЛогПолученныхДанных) = Тип("ТекстовыйДокумент") Тогда
			ЛогПолученныхДанных.ДобавитьСтроку(
			"------------------------------------------------------------------------------------------------------------------");
			ТекстЛога = СтрШаблон(НСтр("ru='Получение котировок из сервиса %1 за %2.'"), СквозныеПараметры.ИмяМетодаAPI,
				Формат(СквозныеПараметры.ДатаПолученияКотировок, "ДФ=dd.MM.yyyy"));
			ЛогПолученныхДанных.ДобавитьСтроку(ТекстЛога);
			ЛогПолученныхДанных.ДобавитьСтроку(
			"------------------------------------------------------------------------------------------------------------------");
		КонецЕсли;
		
		ТаблицаКотировокЦенныхБумагКоличество = 0;
		ОбработаноПакетов = ПолучитьЗаписатьКотировки(СквозныеПараметры, ИзменяемыеПараметры, ЛогПолученныхДанных,
			Сессия, Соединение, ТаблицаКотировокЦенныхБумагКоличество);
		
		// Если нет котировок, но запрос был по всем ценным бумагам - это может быть ошибка сервиса
		Если Не ИзменяемыеПараметры.Отказ И СквозныеПараметры.ПоВсемЦеннымБумагам И ТаблицаКотировокЦенныхБумагКоличество = 0 Тогда
			Если СквозныеПараметры.ИмяНастроекСервиса = СквозныеПараметры.ИмяНастроекСервисаНРД Тогда
				ИзменяемыеПараметры.Отказ		 = Ложь;
				ИзменяемыеПараметры.ТекстОтказа	 = "Ошибок подключения нет, но котировки на внешнем сервисе отсутствуют.";
			КонецЕсли;
		КонецЕсли;
		
		ВывестиЛог(ТабличныйДокумент, СквозныеПараметры, ОбработаноПакетов, ТаблицаКотировокЦенныхБумагКоличество);
		
	КонецЦикла; // Для каждой даты в периода
	
КонецПроцедуры

Функция ИдентификаторыПолейСервиса(СквозныеПараметры)
	
	Если СквозныеПараметры.ИмяНастроекСервиса = СквозныеПараметры.ИмяНастроекСервисаИнтерфакс Тогда
		ОбязательныеИдентификаторыПолей = СтрРазделить("isin,tradeSite,time,currency", ",");
	ИначеЕсли СквозныеПараметры.ИмяНастроекСервиса = СквозныеПараметры.ИмяНастроекСервисаНРД Тогда
		ОбязательныеИдентификаторыПолей = СтрРазделить("isin,currency,mic,exchange_name,primary_exchange_mic,primary_exchange_name", ",");
	ИначеЕсли СквозныеПараметры.ИмяНастроекСервиса = СквозныеПараметры.ИмяНастроекСервисаCBonds Тогда
		ОбязательныеИдентификаторыПолей = СтрРазделить("isin_code,trading_ground_id,emission_kind_id,aci_eurobond_nominal", ",");
	Иначе
		ОбязательныеИдентификаторыПолей = Новый Массив;
	КонецЕсли;
	
	Возврат ОбязательныеИдентификаторыПолей;
	
КонецФункции

Функция ПолучитьЗаписатьКотировкиПоБиржам(СквозныеПараметры, ЛогПолученныхДанных,
	Сессия, Соединение, Отказ, ТекстОтказа, ТабличныйДокумент)
	
	// Получение котировок
	ПолученныеДанныеКоличествоСтрокИтого = 0;
	Для Каждого ТекущаяБиржа Из СквозныеПараметры.СоответствиеКодовБирж Цикл
		
		Биржа = ТекущаяБиржа.Ключ;
		СквозныеПараметры.Вставить("Биржа", Биржа);
		ИдентификаторыТорговыхПлощадок = ТекущаяБиржа.Значение;
		СквозныеПараметры.Вставить("ИдентификаторыТорговыхПлощадок", ИдентификаторыТорговыхПлощадок);
		
		ИдентификаторыПолей = Новый Массив;
		СоответствиеПолейБиржи = СквозныеПараметры.СоответствиеПолейПрочихТорговыхПлощадок.Получить(СквозныеПараметры.КодЛюбойПлощадки);
		СквозныеПараметры.Вставить("СоответствиеПолейБиржи", СоответствиеПолейБиржи);
		Если СквозныеПараметры.СоответствиеПолейБиржи <> Неопределено Тогда
			Для Каждого КодыПолей Из СквозныеПараметры.СоответствиеПолейБиржи Цикл
				Если ИдентификаторыПолей.Найти(КодыПолей.Значение) = Неопределено Тогда
					ИдентификаторыПолей.Добавить(КодыПолей.Значение);
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
		
		Если ИдентификаторыПолей.Количество() = 0 Тогда
			Продолжить;
		КонецЕсли;
		
		ОбязательныеИдентификаторыПолей = ИдентификаторыПолейСервиса(СквозныеПараметры);
		ОбщегоНазначенияКлиентСервер.ДополнитьМассив(ИдентификаторыПолей, ОбязательныеИдентификаторыПолей, Истина);
		СквозныеПараметры.Вставить("ИдентификаторыПолей", ИдентификаторыПолей);
		
		////////////////////////////////////////////////
		// Получаем котировки бумаги
		
		ПопытокОсталось	 = 3;
		ОтказЛокально	 = Ложь;
		
		ИзменяемыеПараметры = Новый Структура;
		ИзменяемыеПараметры.Вставить("ПопытокОсталось"						, ПопытокОсталось);
		ИзменяемыеПараметры.Вставить("ОтказЛокально"						, ОтказЛокально);
		ИзменяемыеПараметры.Вставить("Отказ"								, Отказ);
		ИзменяемыеПараметры.Вставить("ТекстОтказа"							, ТекстОтказа);
		ИзменяемыеПараметры.Вставить("ПолученныеДанныеКоличествоСтрокИтого"	, ПолученныеДанныеКоличествоСтрокИтого);
		
		ПолучитьЗаписатьКотировкиПоПериодам(СквозныеПараметры, ИзменяемыеПараметры, ЛогПолученныхДанных,
			Сессия, Соединение, ТабличныйДокумент);
		
		ПопытокОсталось									 = ИзменяемыеПараметры.ПопытокОсталось;
		ОтказЛокально									 = ИзменяемыеПараметры.ОтказЛокально;
		Отказ											 = ИзменяемыеПараметры.Отказ; // BSLLS:UsingCancelParameter-off
		ТекстОтказа										 = ИзменяемыеПараметры.ТекстОтказа;
		ПолученныеДанныеКоличествоСтрокИтого			 = ИзменяемыеПараметры.ПолученныеДанныеКоличествоСтрокИтого;
		
	КонецЦикла; // Для каждого Источника (как правило будет цикл из одной строки)
	
	Возврат ПолученныеДанныеКоличествоСтрокИтого;
	
КонецФункции

Функция ПолучитьЗаписатьНКД(СквозныеПараметры, ЛогПолученныхДанных,
	Сессия, Соединение, Отказ, ТекстОтказа, ТабличныйДокумент)
	ПолученныеДанныеКоличествоСтрокИтого = 0;
	
	ДатаНачала = Формат(СквозныеПараметры.ДатаПолученияКотировок, "ДФ=yyyy-MM-dd");
	ДатаОкончания = ДатаНачала;
	
	МассивИдентификаторовПолей = Новый Массив;
	МассивИдентификаторовПолей.Добавить("anchor_date");
	МассивИдентификаторовПолей.Добавить("emission_isin");
	МассивИдентификаторовПолей.Добавить(СквозныеПараметры.ИмяРеквизитаНКД);
	МассивИдентификаторовПолей.Добавить("kind_id");
	МассивИдентификаторовПолей.Добавить("aci_eurobond_nominal");
	МассивИдентификаторовПолей.Добавить("aci_full");
	
	ВходящиеПараметры = Новый Структура;
	ВходящиеПараметры.Вставить("ДатаНачала"						, ДатаНачала);
	ВходящиеПараметры.Вставить("ДатаОкончания"					, ДатаОкончания);
	ВходящиеПараметры.Вставить("МассивISIN"						, СквозныеПараметры.ПакетКодов);
	ВходящиеПараметры.Вставить("МассивИдентификаторовПолей"		, МассивИдентификаторовПолей);
	ПолученныеДанные = CBondsAPI.ДанныеМетода_get_aci(ВходящиеПараметры, Отказ, ТекстОтказа, ЛогПолученныхДанных, Соединение);
	ПолученныеДанныеКоличествоСтрокИтого = ПолученныеДанные.Количество();
	
	РегистрыСведенийНКД = РегистрыСведений.НКД.СоздатьНаборЗаписей();
	РегистрыСведенийНКД.Отбор.Период.Установить(СквозныеПараметры.ДатаПолученияКотировок);
	РегистрыСведенийНКД.Отбор.Биржа.Установить(СквозныеПараметры.Биржа);
	ТаблицаНКДЦенныхБумаг = РегистрыСведенийНКД.ВыгрузитьКолонки();
	
	Для Каждого СтрокаНКД Из ПолученныеДанные Цикл
		ПараметрыПоискаАктива = Новый Структура("ISIN", СтрокаНКД[СквозныеПараметры.ИмяРеквизитаIsin]);
		СтрокиАктивов = СквозныеПараметры.СписокАктивов.НайтиСтроки(ПараметрыПоискаАктива);
		Для Каждого СтрокаАктива Из СтрокиАктивов Цикл
			ДобавитьКотировкуАктива(СквозныеПараметры, СтрокаНКД, СтрокаАктива, ТаблицаНКДЦенныхБумаг);
		КонецЦикла;
	КонецЦикла; // Для каждой строки котировки из полученных данных
	
	ТаблицаНКДЦенныхБумагКоличество = ТаблицаНКДЦенныхБумаг.Количество();
	Если ТаблицаНКДЦенныхБумагКоличество > 0 Тогда
		Если СквозныеПараметры.ПоВсемЦеннымБумагам Тогда
			РегистрыСведенийНКД.Очистить();
			РегистрыСведенийНКД.Загрузить(ТаблицаНКДЦенныхБумаг);
			РегистрыСведенийНКД.Записать();
		Иначе
			Для Каждого НКДЦеннойБумаги Из ТаблицаНКДЦенныхБумаг Цикл
				РегистрыСведенийНКД.Отбор.Биржа.Установить(СквозныеПараметры.Биржа);
				РегистрыСведенийНКД.Отбор.ЦеннаяБумага.Установить(НКДЦеннойБумаги.ЦеннаяБумага);
				РегистрыСведенийНКД.Очистить();
				НовыйНКД = РегистрыСведенийНКД.Добавить();
				ЗаполнитьЗначенияСвойств(НовыйНКД, НКДЦеннойБумаги);
				РегистрыСведенийНКД.Записать();
			КонецЦикла;
		КонецЕсли;
	КонецЕсли;
	
	Возврат ПолученныеДанныеКоличествоСтрокИтого;
	
КонецФункции

#КонецОбласти

#КонецОбласти
