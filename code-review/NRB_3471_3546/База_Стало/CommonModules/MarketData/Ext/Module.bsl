	Текст = Текст + ПС + Символы.ПС + ПС + Символы.ПС + ПС + Символы.ПС + Организация
		+ ПС + Символы.ПС;
	Текст = Текст + "</BODY></html>";
	
	Возврат Текст;
	
КонецФункции

