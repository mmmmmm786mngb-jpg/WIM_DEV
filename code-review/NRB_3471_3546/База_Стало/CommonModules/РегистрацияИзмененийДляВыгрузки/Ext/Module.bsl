#Область ПрограммныйИнтерфейс

// Делает отметку в РС СтатусыОбъектовКОтправке о том, что прозошли изменения в справочнике
// (ЦБ/Юридические лица или связанным с ними подчиненном справочнике). Предполагается, что
// процедура вызывается из обработчика ПриЗаписи (т.е. уже внутри неявной транзакции).
// Параметры:
//	Объект - СправочникОбъект
//	Отказ - Булево
//
Процедура ОтметитьИзмененияВСправочнике(Объект, Отказ) Экспорт
	Если Отказ Или Не ОбщегоНазначенияПовтИсп.ВыгрузкаИзмененныхОбъектовВКафкаВключена() Тогда
		Возврат;
	КонецЕсли;
	
	Если Объект.ДополнительныеСвойства.Свойство("НеВыгружатьВоВнешниеСистемы")
			И Объект.ДополнительныеСвойства.НеВыгружатьВоВнешниеСистемы = Истина Тогда
		Возврат;
	КонецЕсли;
	
	Если Объект.ПометкаУдаления Или Объект.ЭтоГруппа Тогда
		Возврат;
	КонецЕсли;
	
	ТипОбъекта = ТипЗнч(Объект);
	Если ТипОбъекта = Тип("СправочникОбъект.ЦенныеБумаги") Или ТипОбъекта = Тип("СправочникОбъект.ЮридическиеЛица") Тогда
		ОбъектСсылка = Объект.Ссылка;
	ИначеЕсли ТипОбъекта = Тип("СправочникОбъект.Контрагенты") 
				И Объект.Родитель = Справочники.Контрагенты.Эмитенты
				И ПредусмотренаОтправкаИзмененийСправочника(Объект.ЮридическиеФизическиеЛица) Тогда
		ОбъектСсылка = Объект.ЮридическиеФизическиеЛица;
	ИначеЕсли ТипОбъекта = Тип("СправочникОбъект.КодыЗагрузки") 
				И Объект.Биржа = Справочники.КлассификаторыЗагрузки.RuData
				И ПредусмотренаОтправкаИзмененийСправочника(Объект.Владелец) Тогда
		ОбъектСсылка = Объект.Владелец;
	Иначе
		ОбъектСсылка = Неопределено;
	КонецЕсли;
		
	УжеЕстьЗаписьВРегистреСтатусов = Неопределено;
	ТекущаяДата = ТекущаяДатаСеанса();
	Если НужноСделатьЗаписьОСтатусеКОтправкеОбъекта(ОбъектСсылка, УжеЕстьЗаписьВРегистреСтатусов, ТекущаяДата) Тогда
		СделатьЗаписьОНеобходимостиОтправкиОбъекта(ОбъектСсылка, ТекущаяДата, УжеЕстьЗаписьВРегистреСтатусов);
	КонецЕсли;
	
КонецПроцедуры

// Делает отметку в РС СтатусыОбъектовКОтправке о том, что прозошли изменения в справочнике
// (ЦБ/Юридические лица или связанным с ними подчиненном справочнике). Предполагается, что 
// процедура вызывается из обработчика ПриЗаписи справочника (т.е. уже внутри неявной транзакции).
// Параметры:
//	Набор - РегистрСведенийНаборЗаписей
//	Отказ - Булево
//	Замещение - Булево
//	ИмяИзмеренияСОбъектом - Строка
//
Процедура ОтметитьИзмененияВРегистреСведений(Набор, Отказ, Замещение, ИмяИзмеренияСОбъектом) Экспорт
	Если НеНужноВыгружать(Отказ, Набор) Тогда
		Возврат;
	КонецЕсли;
	
	ИзмененныеОбъекты = Новый Массив;
	ЕстьОтборПоОбъекту = ЕстьОтборПоИзмерению(Набор.Отбор, ИмяИзмерениясОбъектом);
	Если ЕстьОтборПоОбъекту Тогда
		ИзмененныйОбъект = Набор.Отбор[ИмяИзмерениясОбъектом].Значение;
		ИзмененныеОбъекты.Добавить(ИзмененныйОбъект);
	КонецЕсли;
	Если Не ЕстьОтборПоОбъекту Тогда
		Если Замещение Тогда
			ИзмененныеОбъекты = Набор.ДополнительныеСвойства.ОбъектыИзУдаленныхЗаписей;
		КонецЕсли;
		Для каждого ЗаписьНабора Из Набор Цикл
			ИзмененныеОбъекты.Добавить(ЗаписьНабора[ИмяИзмеренияСОбъектом]);
		КонецЦикла;
		ИзмененныеОбъекты = ОбщегоНазначенияКлиентСервер.СвернутьМассив(ИзмененныеОбъекты);
	КонецЕсли;
	
	СделатьОтметкиОСтатусеОбъектов(ИзмененныеОбъекты);
КонецПроцедуры

// Получает массив ссылок на объекты из записей, которые будут удалены в результате записи набора записей
// Регистра сведений. Предполагается, что функция вызывается из обработчика ПередЗаписью набора записей
// регистра сведений.
// Параметры:
//	НаборДляЗаписи - РегистрСведенийНаборЗаписей
//	Отказ - Булево
//	Замещение - Булево
//	ИмяИзмеренияСОбъектом - Строка
//
Процедура ЗапомнитьОбъектыИзУдаляемыхЗаписей(НаборДляЗаписи, Отказ, Замещение, ИмяИзмеренияСОбъектом) Экспорт
	
	Если НеНужноВыгружать(Отказ, НаборДляЗаписи) Тогда
		Возврат;
	КонецЕсли;
	
	Если Замещение И Не ЕстьОтборПоИзмерению(НаборДляЗаписи.Отбор, ИмяИзмеренияСОбъектом) Тогда
		ИмяРегистра = НаборДляЗаписи.Метаданные().Имя;
		НаборДляЧтения = РегистрыСведений[ИмяРегистра].СоздатьНаборЗаписей();
		Для каждого ЭлементОтбора Из НаборДляЗаписи.Отбор Цикл
			НаборДляЧтения.Отбор[ЭлементОтбора.Имя].Установить(ЭлементОтбора.Значение);
		КонецЦикла;
		НаборДляЧтения.Прочитать();
		ОбъектыИзУдаляемыхЗаписей = НаборДляЧтения.ВыгрузитьКолонку(ИмяИзмеренияСОбъектом);
		НаборДляЗаписи.ДополнительныеСвойства.Вставить("ОбъектыИзУдаляемыхЗаписей", ОбъектыИзУдаляемыхЗаписей);
	КонецЕсли;
	
КонецПроцедуры

// Устанавливает флаг Обработано в Истина в регистре сведений СтатусыОбъектовКОтправке для указанного объекта
// Параметры:
//	ОбъектСсылка - СправочникСсылка - ЦенныеБумаги или ЮридическиеЛица
//	ВремяИзменения - Дата - Дата со временем последнего изменения той версии объекта, которую мы отправили
//							или пытались отправить.
//	ХешРеквизитов - Строка - хэш реквизитов объекта - строка(64)
//	ОшибкаОбработки - Булево
//	ОписаниеОшибки - Строка
//
Процедура ЗавершитьОбработку(ОбъектСсылка, ВремяИзменения, ХешРеквизитов, ОшибкаОбработки, ОписаниеОшибки) Экспорт
	Запись = РегистрыСведений.СтатусыОбъектовКОтправке.СоздатьМенеджерЗаписи();
	Запись.Объект = ОбъектСсылка;
	
	// Установим блокировку, чтобы никто не смог презаписать запись пока мы ее обрабатываем
	НачатьТранзакцию(РежимУправленияБлокировкойДанных.Управляемый);
	Попытка
		УстановитьБлокировкуПоОбъектуКОтправке(ОбъектСсылка);
		Запись.Прочитать();
		
		Если Не Запись.Выбран() Тогда // Вообще-то такого быть не должно ...
			Запись.Объект = ОбъектСсылка;
			Запись.ВремяИзменения = ВремяИзменения;
		КонецЕсли;
		
		Запись.ОшибкаОбработки = ОшибкаОбработки;
		Если ОшибкаОбработки Тогда
			Запись.Обработано = Ложь;
			Запись.ОписаниеОшибки = ОписаниеОшибки;
		Иначе
			Запись.ХешРеквизитов = ХешРеквизитов;
			Запись.ОписаниеОшибки = "";
			Запись.Обработано = (Запись.ВремяИзменения = ВремяИзменения);
		КонецЕсли;
		
		Запись.Записать(Истина);
		ЗафиксироватьТранзакцию();	// Тут и блокировка снимается
		
	Исключение
		ОтменитьТранзакцию();
		ТекстОшибки = ПолучитьТекстОшибкиПриЗаписиСтатусыОбъектовКОтправке(ОбъектСсылка);
		ЗаписьЖурналаРегистрации("Не удалось завершить обработку выгрузки", УровеньЖурналаРегистрации.Ошибка, , , ТекстОшибки);		
	КонецПопытки;
	
КонецПроцедуры

#КонецОбласти


#Область СлужебныеПроцедурыИФункции

Процедура СделатьЗаписьОНеобходимостиОтправкиОбъекта(ОбъектСсылка, ВремяИзменения, УжеЕстьЗаписьВРегистреСтатусов)
	// Установим блокировку, чтобы никто не смог презаписать запись пока мы ее обрабатываем
	НачатьТранзакцию(РежимУправленияБлокировкойДанных.Управляемый);
	Попытка
		УстановитьБлокировкуПоОбъектуКОтправке(ОбъектСсылка);
	
		Запись = РегистрыСведений.СтатусыОбъектовКОтправке.СоздатьМенеджерЗаписи();
		Запись.Объект = ОбъектСсылка;
		Если УжеЕстьЗаписьВРегистреСтатусов Тогда
			Запись.Прочитать();
		КонецЕсли;
		Если Не Запись.Выбран() Тогда
			Запись.Объект = ОбъектСсылка;
		КонецЕсли;
		Запись.Обработано = Ложь;
		Запись.ВремяИзменения = ВремяИзменения;
		Запись.Записать(Истина);
		
		ЗафиксироватьТранзакцию();
	Исключение
		ОтменитьТранзакцию();
		ТекстОшибки = ПолучитьТекстОшибкиПриЗаписиСтатусыОбъектовКОтправке(ОбъектСсылка);
		ЗаписьЖурналаРегистрации("Не удалось завершить регистрацию объекта к выгрузке", УровеньЖурналаРегистрации.Ошибка, , , ТекстОшибки);
	КонецПопытки;
КонецПроцедуры

Функция ПолучитьТекстОшибкиПриЗаписиСтатусыОбъектовКОтправке(ОбъектСсылка)
	ТекстОшибки = "Ошибка чтения или записи в РегистрСведений.СтатусыОбъектовКОтправке. Объект: " + Строка(ОбъектСсылка)
					+ " (" +  Строка(ТипЗнч(ОбъектСсылка)) + ")" + "; Причина: " + ОписаниеОшибки();
	Возврат ТекстОшибки;
КонецФункции

Процедура УстановитьБлокировкуПоОбъектуКОтправке(ОбъектСсылка)
	БлокировкаДанных = Новый БлокировкаДанных;
	ЭлементБлокировки = БлокировкаДанных.Добавить("РегистрСведений.СтатусыОбъектовКОтправке");
	ЭлементБлокировки.Режим = РежимБлокировкиДанных.Исключительный;
	ЭлементБлокировки.УстановитьЗначение("Объект", ОбъектСсылка);
	БлокировкаДанных.Заблокировать();
КонецПроцедуры

Функция ПредусмотренаОтправкаИзмененийСправочника(СправочникСсылка)
	ТипОбъекта = ТипЗнч(СправочникСсылка);
	
	Возврат ТипОбъекта = Тип("СправочникСсылка.ЦенныеБумаги") Или ТипОбъекта = Тип("СправочникСсылка.ЮридическиеЛица");
КонецФункции

Функция ЕстьОтборПоИзмерению(Отбор, ИмяИзмерения)
	ЕстьОтборПоИзмерению = Ложь;
	
	Для каждого ЭлементОтбора Из Отбор Цикл
		Если ЭлементОтбора.Имя = ИмяИзмерения Тогда
			ЕстьОтборПоИзмерению = Истина;
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	Возврат ЕстьОтборПоИзмерению;
КонецФункции

Функция НужноСделатьЗаписьОСтатусеКОтправкеОбъекта(ОбъектСсылка, УжеЕстьЗаписьВРегистреСтатусов, ТекущаяДата)
	Если Не ЗначениеЗаполнено(ОбъектСсылка) Тогда
		Возврат Ложь;
	КонецЕсли;
		
	ТипОбъекта = ТипЗнч(ОбъектСсылка);
	Запрос = Новый Запрос;
	Если ТипОбъекта = Тип("СправочникСсылка.ЦенныеБумаги") Тогда
		Запрос.Текст =
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	ВЫБОР
		|		КОГДА СтатусыОбъектовКОтправке.Обработано ЕСТЬ NULL
		|			ТОГДА ИСТИНА
		|		КОГДА СтатусыОбъектовКОтправке.Обработано
		|			ТОГДА ИСТИНА
		|		КОГДА СтатусыОбъектовКОтправке.ВремяИзменения <> &ТекущаяДата
		|			ТОГДА ИСТИНА
		|		ИНАЧЕ ЛОЖЬ
		|	КОНЕЦ КАК ЗаписьНужна,
		|	ВЫБОР
		|		КОГДА СтатусыОбъектовКОтправке.Обработано ЕСТЬ NULL
		|			ТОГДА ЛОЖЬ
		|		ИНАЧЕ ИСТИНА
		|	КОНЕЦ КАК УжеЕстьЗапись
		|ИЗ
		|	Справочник.ЦенныеБумаги КАК ЦенныеБумаги
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СтатусыОбъектовКОтправке КАК СтатусыОбъектовКОтправке
		|		ПО (СтатусыОбъектовКОтправке.Объект = &ОбъектСсылка)
		|ГДЕ
		|	ЦенныеБумаги.Ссылка = &ОбъектСсылка
		|	И НЕ ЦенныеБумаги.ПометкаУдаления";
	Иначе
		Запрос.Текст =
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	ВЫБОР
		|		КОГДА СтатусыОбъектовКОтправке.Обработано ЕСТЬ NULL
		|			ТОГДА ИСТИНА
		|		КОГДА СтатусыОбъектовКОтправке.Обработано
		|			ТОГДА ИСТИНА
		|		КОГДА СтатусыОбъектовКОтправке.ВремяИзменения <> &ТекущаяДата
		|			ТОГДА ИСТИНА
		|		ИНАЧЕ ЛОЖЬ
		|	КОНЕЦ КАК ЗаписьНужна,
		|	ВЫБОР
		|		КОГДА СтатусыОбъектовКОтправке.Обработано ЕСТЬ NULL
		|			ТОГДА ЛОЖЬ
		|		ИНАЧЕ ИСТИНА
		|	КОНЕЦ КАК УжеЕстьЗапись
		|ИЗ
		|	Справочник.ЮридическиеЛица КАК ЮридическиеЛица
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Контрагенты КАК Контрагенты
		|		ПО (ЮридическиеЛица.Ссылка = &ОбъектСсылка)
		|			И ЮридическиеЛица.Ссылка = Контрагенты.ЮридическиеФизическиеЛица
		|			И (НЕ ЮридическиеЛица.ПометкаУдаления)
		|			И (НЕ Контрагенты.ПометкаУдаления)
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.КодыЗагрузки КАК КодыЗагрузки
		|		ПО (Контрагенты.Ссылка = КодыЗагрузки.Владелец)
		|			И (КодыЗагрузки.Биржа = ЗНАЧЕНИЕ(Справочник.КлассификаторыЗагрузки.NrdCode))
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СтатусыОбъектовКОтправке КАК СтатусыОбъектовКОтправке
		|		ПО (СтатусыОбъектовКОтправке.Объект = &ОбъектСсылка)
		|ГДЕ
		|	(Контрагенты.Родитель = ЗНАЧЕНИЕ(Справочник.Контрагенты.Эмитенты)
		|			ИЛИ НЕ КодыЗагрузки.Владелец ЕСТЬ NULL)";
	КонецЕсли;
	Запрос.УстановитьПараметр("ОбъектСсылка", ОбъектСсылка);
	Запрос.УстановитьПараметр("ТекущаяДата", ТекущаяДата);
	РезультатЗапроса = Запрос.Выполнить();
	Если Не РезультатЗапроса.Пустой() Тогда
		Выборка = РезультатЗапроса.Выбрать();
		Выборка.Следующий();
		ЗаписьНужна = Выборка.ЗаписьНужна;
		УжеЕстьЗаписьВРегистреСтатусов = Выборка.УжеЕстьЗапись;
	Иначе
		ЗаписьНужна = Ложь;
		УжеЕстьЗаписьВРегистреСтатусов = Ложь;
	КонецЕсли;
	
	Возврат ЗаписьНужна;
КонецФункции

Процедура СделатьОтметкиОСтатусеОбъектов(ИзмененныеОбъекты)
	УжеЕстьЗаписьВРегистреСтатусов = Неопределено;
	ТекущаяДата = ТекущаяДатаСеанса();
	Для каждого ИзмененныйОбъект Из ИзмененныеОбъекты Цикл
		Если НужноСделатьЗаписьОСтатусеКОтправкеОбъекта(ИзмененныйОбъект, УжеЕстьЗаписьВРегистреСтатусов, ТекущаяДата) Тогда
			СделатьЗаписьОНеобходимостиОтправкиОбъекта(ИзмененныйОбъект, ТекущаяДата, УжеЕстьЗаписьВРегистреСтатусов);
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

Функция НеНужноВыгружать(Отказ, ОбъектИлиНабор)
	НеНужноВыгружать =	Отказ
						Или Не ОбщегоНазначенияПовтИсп.ВыгрузкаИзмененныхОбъектовВКафкаВключена()
						Или (ОбъектИлиНабор.ДополнительныеСвойства.Свойство("НеВыгружатьВоВнешниеСистемы")
								И ОбъектИлиНабор.ДополнительныеСвойства.НеВыгружатьВоВнешниеСистемы = Истина);
	Возврат НеНужноВыгружать;
КонецФункции

#КонецОбласти