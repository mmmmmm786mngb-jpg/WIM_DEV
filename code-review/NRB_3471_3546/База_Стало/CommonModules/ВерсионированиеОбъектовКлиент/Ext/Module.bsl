////////////////////////////////////////////////////////////////////////////////
// ПРОГРАММНЫЙ ИНТЕРФЕЙС

// Открывает отчет по версиям объекта в режиме сравнения версий.
//
// Параметры:
//  Ссылка                       - ЛюбаяСсылка - ссылка на версионируемый объект;
//  АдресСериализованногоОбъекта - Строка - адрес двоичных данных сравниваемой версии
//                                          объекта во временном хранилище.
//
Процедура ОткрытьОтчетПоИзменениям(Ссылка, АдресСериализованногоОбъекта) Экспорт
	
	Параметры = Новый Структура;
	Параметры.Вставить("Ссылка", Ссылка);
	Параметры.Вставить("АдресСериализованногоОбъекта", АдресСериализованногоОбъекта);
	
	ОткрытьФорму("РегистрСведений.ВерсииОбъектов.Форма.ОтчетПоВерсиямОбъекта", Параметры);
	
КонецПроцедуры

// Функция открывает отчет по версии объекта переданной в параметре АдресСериализованногоОбъекта.
//
// Параметры:
//  Ссылка                       - ЛюбаяСсылка - ссылка на версионируемый объект;
//  АдресСериализованногоОбъекта - Строка - адрес двоичных данных версии объекта во временном хранилище.
//
Процедура ОткрытьОтчетПоВерсииОбъекта(Ссылка, АдресСериализованногоОбъекта) Экспорт
	
	Параметры = Новый Структура;
	Параметры.Вставить("Ссылка", Ссылка);
	Параметры.Вставить("АдресСериализованногоОбъекта", АдресСериализованногоОбъекта);
	Параметры.Вставить("ПоВерсии", Истина);
	
	ОткрытьФорму("РегистрСведений.ВерсииОбъектов.Форма.ОтчетПоВерсиямОбъекта", Параметры);
	
КонецПроцедуры

////////////////////////////////////////////////////////////////////////////////
// СЛУЖЕБНЫЙ ПРОГРАММНЫЙ ИНТЕРФЕЙС

////////////////////////////////////////////////////////////////////////////////
// Обработчики условных вызовов в эту подсистему

// Открывает отчет о версии или о сравнении версий
//
// Параметры:
//	Ссылка - Ссылка на объект
//	СравниваемыеВерсии - Массив - Содержит массив сравниваемых версий,
//	если версия одна, то открывается отчет о версии
//
Процедура ПриОткрытииФормыОтчетаПоВерсии(Ссылка, СравниваемыеВерсии) Экспорт
	
	ПараметрыОтчета = Новый Структура;
	ПараметрыОтчета.Вставить("Ссылка", Ссылка);
	ПараметрыОтчета.Вставить("СравниваемыеВерсии", СравниваемыеВерсии);
	ОткрытьФорму("РегистрСведений.ВерсииОбъектов.Форма.ОтчетПоВерсиямОбъекта", ПараметрыОтчета);
	
КонецПроцедуры

#Если ТолстыйКлиентОбычноеПриложение Тогда

Процедура ОбычнаяФормаПередОткрытием(ОбычнаяФорма, Знач Ссылка = Неопределено) Экспорт
	Если Ссылка = Неопределено Тогда
		// Для форм объекта форма уже содержит ссылку
		Ссылка = ОбычнаяФорма.Ссылка;
	КонецЕсли;
	НоваяКнопка = Неопределено;
	ИмяКнопки = "Подключаемый_ВерсионированиеОбъектовКомандаОткрытияИсторииИзменений";
	НадписьКнопки = "История изменений";
	ДействиеКнопки = Новый Действие(""+ИмяКнопки+"Нажатие");
	
	Если ВерсионированиеОбъектов.ВерсионированиеДоступно(Ссылка) Тогда
		// Ищем командную панель формы, в которой есть подменю со связанными элементами
		Для Каждого ЭлементФормы Из ОбычнаяФорма.ЭлементыФормы Цикл 
			Если  ТипЗнч(ЭлементФормы) = Тип("КоманднаяПанель") Тогда 
				// Будем считать что первая попавшаяся нам командная панель и есть командная панель формы
				КоманднаяПанельФормы = ЭлементФормы;
				Для Каждого Подменю Из ЭлементФормы.Кнопки Цикл 
					Если Подменю.ТипКнопки = ТипКнопкиКоманднойПанели.Подменю Тогда             
						Для Каждого КнопкаПодменю Из Подменю.Кнопки Цикл
							Действие = СокрЛП(КнопкаПодменю.Действие);
							Если Действие = "(Связанные регистры сведений)" ИЛИ Действие = "(Подчиненные справочники)" Тогда 
								НоваяКнопка = Подменю.Кнопки.Добавить(ИмяКнопки,ТипКнопкиКоманднойПанели.Действие,НадписьКнопки,ДействиеКнопки);
								Прервать;
							КонецЕсли;
						КонецЦикла;
						Если НЕ НоваяКнопка = Неопределено Тогда
							// Исключим прочие командные панели подчиненных элементов и свзанных регистров сведений
							Прервать;
						КонецЕсли;
					КонецЕсли;       
				КонецЦикла;
				Прервать;
			КонецЕсли;
		КонецЦикла;
		
		Если НоваяКнопка = Неопределено И КоманднаяПанельФормы <> Неопределено Тогда
			НоваяКнопка = КоманднаяПанельФормы.Кнопки.Добавить(ИмяКнопки,ТипКнопкиКоманднойПанели.Действие,НадписьКнопки,ДействиеКнопки);
		КонецЕсли;
		
		Если НоваяКнопка = Неопределено Тогда 
			Возврат;
		КонецЕсли;
		
		НоваяКнопка.Доступность = Истина;
		НоваяКнопка.Картинка = БиблиотекаКартинок.ИсторияВерсий;
		#Если ТолстыйКлиент Тогда
			НоваяКнопка.Отображение = ОтображениеКнопкиКоманднойПанели.НадписьКартинка;
		#КонецЕсли
		НоваяКнопка.Подсказка = "История изменения объекта";
	КонецЕсли;
КонецПроцедуры

Процедура ПоказатьИсториюИзмененийОбъекта(ОбычнаяФорма, Знач ТекущийОбъект = Неопределено) Экспорт
	
	Если ТекущийОбъект = Неопределено Тогда
		// Для форм объекта форма уже содержит ссылку
		ТекущийОбъект = ОбычнаяФорма;
	КонецЕсли;
	
	ОткрытьФорму("РегистрСведений.ВерсииОбъектов.Форма.ВыборХранимыхВерсий",
		Новый Структура("Ссылка", ТекущийОбъект.Ссылка),
		ОбычнаяФорма,
		ОбычнаяФорма.КлючУникальности); 
		
КонецПроцедуры

#КонецЕсли
