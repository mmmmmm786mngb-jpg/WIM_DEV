///////////////////////////////////////////////////////////////
// ОБРАБОТЧИКИ СОБЫТИЙ

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	УправлениеВидимостью(Объект);
КонецПроцедуры

&НаКлиенте
Процедура СоздатьДокументРСВЗавершитьЗадачу(Команда)
	Текст = "Принудительно создать документ раскрытия списка владельцев и завершить задачу?";
	Если Вопрос(Текст, РежимДиалогаВопрос.ДаНет, 0) = КодВозвратаДиалога.Нет Тогда
	    Возврат;
	КонецЕсли;
	СоздатьДокументРСВЗавершитьЗадачуНаСервере();
КонецПроцедуры

///////////////////////////////////////////////////////////////
// СЛУЖЕБНЫЕ ФУНКЦИИ

&НаСервере
Процедура УправлениеВидимостью(Объект)
	Элементы.Депоненты.Видимость =
		(Объект.ТочкаМаршрута.Имя = "ОбработкаWTRCСообщения"
		ИЛИ Объект.ТочкаМаршрута.Имя = "ФормированиеУведомленияОКД");
	Элементы.ФормаСоздатьРСВЗавершитьЗадачу.Доступность = НЕ Объект.Выполнена;
	Элементы.ФормаСоздатьРСВЗавершитьЗадачу.Видимость =
		(Объект.ТочкаМаршрута.Имя = "ФормированиеДокументаРаскрытиеСпискаВладельцев");
КонецПроцедуры

&НаСервере
Процедура СоздатьДокументРСВЗавершитьЗадачуНаСервере()
	ЗадачаОбъект = РеквизитФормыВЗначение("Объект");
	ЗадачаОбъект.ДополнительныеСвойства.Вставить("БезусловноСформироватьДокументРаскрытиеСпискаВладельцев");
	ЗадачаОбъект.ВыполнитьЗадачу();
	ЗначениеВРеквизитФормы(ЗадачаОбъект, "Объект");
	
	УправлениеВидимостью(Объект);
КонецПроцедуры
